    $perp(a, b, a, d)
    $cong(a, b, c, d)
    $cong(a, d, b, c)
    $cong(a, c, b, d)

let draw_rectangle_c fn(a, b point: $diff(a, b)) point
let draw_rectangle_d fn(a, b, c point: $ncoll(a, b, c), $perp(a, b, b, c)) point
know:
    forall a, b point:
        $diff(a, b)
        =>:
            $perp(a, b, b, draw_rectangle_c(a, b))
            $rectangle(a, b, draw_rectangle_c(a, b), draw_rectangle_d(a, b, draw_rectangle_c(a, b)))
