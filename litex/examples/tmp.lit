"""
prop ieq_triangle(a, b, c point):
    $diff(a, b)
    $cong(a, b, b, c)
    $cong(b, c, c, a)
    $eqangle(a, b, a, c, c, a, c, b)
    $eqangle(c, a, c, b, b, c, b, a)

let draw_ieq_triangle_c fn(a, b point: $diff(a, b)) point
know:
    forall a, b point:
