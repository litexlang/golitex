have point nonempty_set

prop ncoll(a, b, c)
prop cong(a, b, c, d)

prop is_circumcenter(x, a, b, c point):
    $ncoll(a, b, c)
    $cong(x, a, x, b)
    $cong(x, b, x, c)

forall x, a, b, c point:
    $ncoll(a, b, c)
    $cong(x, a, x, b)
    $cong(x, b, x, c)
    =>:
        $is_circumcenter(x, a, b, c)
