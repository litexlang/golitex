triangle12
"""
# 1:2 比例三角形：ab 与 ac 长度比为 1:2
# Triangle with ab:ac = 1:2
prop triangle12(a, b, c point):
    $ncoll(a, b, c)
    # rconst a b a c 1 2 表示 ab:ac = 1:2
    # ratio ab:ac = 1:2

# 由线段 ab 构造满足 ab:ac=1:2 的第三顶点 c
# Construct vertex c with ab:ac = 1:2
let draw_triangle12_c fn(a, b point: $diff(a, b)) point
know:
