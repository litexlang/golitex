"""
2l1c x y z i a b c o
x : a b c o y z i, y : a b c o x z i, z : a b c o x y i, i : a b c o x y z
a b c o = cong o a o b, ncoll a b c
x y z i : coll x a c, coll y b c, cong o a o z, coll i o z, cong i x i y, cong i y i z, perp i x a c, perp i y b c
2l1c a b c o
"""
# 两线一圆构型：o 为圆心 oa=ob，x 在 ac 上，y 在 bc 上，z 在圆上
# Two lines one circle: o center, x on ac, y on bc, z on circle
prop two_l1c(x, y, z, i, a, b, c, o point):
    $cong(o, a, o, b)
    $ncoll(a, b, c)
    $coll(x, a, c)
    $coll(y, b, c)
    $cong(o, a, o, z)
    $coll(i, o, z)
    $cong(i, x, i, y)
    $cong(i, y, i, z)
    $perp(i, x, a, c)
    $perp(i, y, b, c)

# 由三角形 abc 和圆心 o 构造两线一圆构型 x、y、z、i
# Construct two-lines-one-circle configuration
let draw_two_l1c fn(a, b, c, o point: $cong(o, a, o, b), $ncoll(a, b, c)) cart(point, point, point, point)
know:
    forall a, b, c, o point:
        $cong(o, a, o, b)
        $ncoll(a, b, c)
        =>:
            $coll(draw_two_l1c(a, b, c, o)[1], a, c)
            $coll(draw_two_l1c(a, b, c, o)[2], b, c)
            $cong(o, a, o, draw_two_l1c(a, b, c, o)[3])
            $coll(draw_two_l1c(a, b, c, o)[4], o, draw_two_l1c(a, b, c, o)[3])
            $cong(draw_two_l1c(a, b, c, o)[4], draw_two_l1c(a, b, c, o)[1], draw_two_l1c(a, b, c, o)[4], draw_two_l1c(a, b, c, o)[2])
            $cong(draw_two_l1c(a, b, c, o)[4], draw_two_l1c(a, b, c, o)[2], draw_two_l1c(a, b, c, o)[4], draw_two_l1c(a, b, c, o)[3])
            $perp(draw_two_l1c(a, b, c, o)[4], draw_two_l1c(a, b, c, o)[1], a, c)
            $perp(draw_two_l1c(a, b, c, o)[4], draw_two_l1c(a, b, c, o)[2], b, c)
            $two_l1c(draw_two_l1c(a, b, c, o)[1], draw_two_l1c(a, b, c, o)[2], draw_two_l1c(a, b, c, o)[3], draw_two_l1c(a, b, c, o)[4], a, b, c, o)

"""
e5128 x y a b c d
x : a b c d y, y : a b c d x
a b c d = cong c b c d, perp b c b a
x y : cong c b c x, coll y a b, coll x y d, eqangle a b a d x a x y
e5128 a b c d
"""
# 几何构型 e5128：cb=cd，cb⊥ba，x 在圆上，y 在 ab 上
# Config e5128: cb=cd, cb⊥ba, x on circle, y on ab
prop e5128(x, y, a, b, c, d point):
    $cong(c, b, c, d)
    $perp(b, c, b, a)
    $cong(c, b, c, x)
    $coll(y, a, b)
    $coll(x, y, d)
    $eqangle(a, b, a, d, x, a, x, y)

# 由构型 a、b、c、d 构造 e5128 中的 x、y
# Construct e5128 configuration points x, y
let draw_e5128 fn(a, b, c, d point: $cong(c, b, c, d), $perp(b, c, b, a)) cart(point, point)
know:
    forall a, b, c, d point:
        $cong(c, b, c, d)
        $perp(b, c, b, a)
        =>:
            $cong(c, b, c, draw_e5128(a, b, c, d)[1])
            $coll(draw_e5128(a, b, c, d)[2], a, b)
            $coll(draw_e5128(a, b, c, d)[1], draw_e5128(a, b, c, d)[2], d)
            $eqangle(a, b, a, d, draw_e5128(a, b, c, d)[1], a, draw_e5128(a, b, c, d)[1], draw_e5128(a, b, c, d)[2])
            $e5128(draw_e5128(a, b, c, d)[1], draw_e5128(a, b, c, d)[2], a, b, c, d)

"""
3peq x y z a b c
z : b c z , x : a b c z y, y : a b c z x
a b c = ncoll a b c
z : coll z b c ; x y : coll x a b, coll y a c, coll x y z, cong z x z y
3peq a b c
"""
# 三点等距：z 在 bc 上，x 在 ab 上，y 在 ac 上，zx = zy
# Three equidistant points: z on bc, x on ab, y on ac, zx = zy
prop three_peq(x, y, z, a, b, c point):
    $ncoll(a, b, c)
    $coll(z, b, c)
    $coll(x, a, b)
    $coll(y, a, c)
    $coll(x, y, z)
    $cong(z, x, z, y)

# 由三角形 abc 构造三点等距构型 x、y、z
# Construct three equidistant points from triangle abc
let draw_three_peq fn(a, b, c point: $ncoll(a, b, c)) cart(point, point, point)
know:
    forall a, b, c point:
        $ncoll(a, b, c)
        =>:
            $coll(draw_three_peq(a, b, c)[3], b, c)
            $coll(draw_three_peq(a, b, c)[1], a, b)
            $coll(draw_three_peq(a, b, c)[2], a, c)
            $coll(draw_three_peq(a, b, c)[1], draw_three_peq(a, b, c)[2], draw_three_peq(a, b, c)[3])
            $cong(draw_three_peq(a, b, c)[3], draw_three_peq(a, b, c)[1], draw_three_peq(a, b, c)[3], draw_three_peq(a, b, c)[2])
            $three_peq(draw_three_peq(a, b, c)[1], draw_three_peq(a, b, c)[2], draw_three_peq(a, b, c)[3], a, b, c)

"""
trisect x y a b c
x : a b c y, y : a b c x
a b c = ncoll a b c
x y : coll x a c, coll y a c, eqangle b a b x b x b y, eqangle b x b y b y b c
trisect a b c
"""
# 三等分角：x、y 在 ac 上，∠abx = ∠xby = ∠ybc
# Angle trisection: x,y on ac, trisect ∠abc
prop trisect(x, y, a, b, c point):
    $ncoll(a, b, c)
    $coll(x, a, c)
    $coll(y, a, c)
    $eqangle(b, a, b, x, b, x, b, y)
    $eqangle(b, x, b, y, b, y, b, c)

# 由角 abc 构造三等分点 x、y
# Construct trisection points x, y of angle abc
let draw_trisect fn(a, b, c point: $ncoll(a, b, c)) cart(point, point)
know:
    forall a, b, c point:
        $ncoll(a, b, c)
        =>:
            $coll(draw_trisect(a, b, c)[1], a, c)
            $coll(draw_trisect(a, b, c)[2], a, c)
            $eqangle(b, a, b, draw_trisect(a, b, c)[1], b, draw_trisect(a, b, c)[1], b, draw_trisect(a, b, c)[2])
            $eqangle(b, draw_trisect(a, b, c)[1], b, draw_trisect(a, b, c)[2], b, draw_trisect(a, b, c)[2], b, c)
            $trisect(draw_trisect(a, b, c)[1], draw_trisect(a, b, c)[2], a, b, c)

"""
trisegment x y a b
x : a b y, y : a b x
a b = diff a b
x y : coll x a b, coll y a b, cong x a x y, cong y x y b
trisegment a b
"""
# 三等分线段：x、y 在 ab 上，ax = xy = yb
# Segment trisection: x,y on ab, ax = xy = yb
prop trisegment(x, y, a, b point):
    $diff(a, b)
    $coll(x, a, b)
    $coll(y, a, b)
    $cong(x, a, x, y)
    $cong(y, x, y, b)

# 由线段 ab 构造三等分点 x、y
# Construct trisection points x, y of segment ab
let draw_trisegment fn(a, b point: $diff(a, b)) cart(point, point)
know:
    forall a, b point:
        $diff(a, b)
        =>:
            $coll(draw_trisegment(a, b)[1], a, b)
            $coll(draw_trisegment(a, b)[2], a, b)
            $cong(draw_trisegment(a, b)[1], a, draw_trisegment(a, b)[1], draw_trisegment(a, b)[2])
            $cong(draw_trisegment(a, b)[2], draw_trisegment(a, b)[1], draw_trisegment(a, b)[2], b)
            $trisegment(draw_trisegment(a, b)[1], draw_trisegment(a, b)[2], a, b)

"""
on_dia x a b
x : x a b
a b = diff a b
x : perp x a x b
dia a b
"""
# 直径端点视角为直角：∠axb 为直角（x 在以 ab 为直径的圆上）
# On diameter: ∠axb right (Thales)
prop on_dia(x, a, b point):
    $diff(a, b)
    $perp(x, a, x, b)

# 由直径 ab 构造圆上点 x
# Construct point x on circle with diameter ab
let draw_on_dia_x fn(a, b point: $diff(a, b)) point
know:
    forall a, b point:
        $diff(a, b)
        =>:
            $perp(draw_on_dia_x(a, b), a, draw_on_dia_x(a, b), b)
            $on_dia(draw_on_dia_x(a, b), a, b)

"""
ieq_triangle a b c
c : a b
 =
a : ; b : ; c : cong a b b c, cong b c c a; eqangle a b a c c a c b, eqangle c a c b b c b a
ieq_triangle
"""
# 等边三角形：ab = bc = ca
# Equilateral triangle: ab = bc = ca
prop ieq_triangle(a, b, c point):
    $diff(a, b)
    $cong(a, b, b, c)
    $cong(b, c, c, a)
    $eqangle(a, b, a, c, c, a, c, b)
    $eqangle(c, a, c, b, b, c, b, a)

# 由线段 ab 构造等边三角形的第三顶点 c
# Construct third vertex c of equilateral triangle
let draw_ieq_triangle_c fn(a, b point: $diff(a, b)) point
know:
    forall a, b point:
        $diff(a, b)
        =>:
            $cong(a, b, b, draw_ieq_triangle_c(a, b))
            $cong(b, draw_ieq_triangle_c(a, b), draw_ieq_triangle_c(a, b), a)
            $eqangle(a, b, a, draw_ieq_triangle_c(a, b), draw_ieq_triangle_c(a, b), a, draw_ieq_triangle_c(a, b), b)
            $eqangle(draw_ieq_triangle_c(a, b), a, draw_ieq_triangle_c(a, b), b, b, draw_ieq_triangle_c(a, b), b, a)
            $ieq_triangle(a, b, draw_ieq_triangle_c(a, b))

"""
on_opline x a b
x : x a b
a b = diff a b
x : coll x a b
on_opline a b
"""
# 直线上的点（同 on_line）：点 x 在直线 ab 上
# Point on line (same as on_line): x on ab
prop on_opline(x, a, b point):
    $diff(a, b)
    $coll(x, a, b)

# 由直线 ab 构造其上的点 x
# Construct point x on line ab
let draw_on_opline_x fn(a, b point: $diff(a, b)) point
know:
    forall a, b point:
        $diff(a, b)
        =>:
            $coll(draw_on_opline_x(a, b), a, b)
            $on_opline(draw_on_opline_x(a, b), a, b)

"""
cc_tangent0 x y o a w b
x : o a w b y, y : o a w b x
o a w b = diff o a, diff w b, diff o w
x y : cong o x o a, cong w y w b, perp x o x y, perp y w y x
cc_tangent0 o a w b
"""
# 两圆外公切线：x、y 为两圆外公切线切点
# External common tangent: x on circle o, y on circle w
prop cc_tangent0(x, y, o, a, w, b point):
    $diff(o, a)
    $diff(w, b)
    $diff(o, w)
    $cong(o, x, o, a)
    $cong(w, y, w, b)
    $perp(x, o, x, y)
    $perp(y, w, y, x)

# 由两圆构造外公切线切点 x、y
# Construct external tangent points x, y of two circles
let draw_cc_tangent0 fn(o, a, w, b point: $diff(o, a), $diff(w, b), $diff(o, w)) cart(point, point)
know:
    forall o, a, w, b point:
        $diff(o, a)
        $diff(w, b)
        $diff(o, w)
        =>:
            $cong(o, draw_cc_tangent0(o, a, w, b)[1], o, a)
            $cong(w, draw_cc_tangent0(o, a, w, b)[2], w, b)
            $perp(draw_cc_tangent0(o, a, w, b)[1], o, draw_cc_tangent0(o, a, w, b)[1], draw_cc_tangent0(o, a, w, b)[2])
            $perp(draw_cc_tangent0(o, a, w, b)[2], w, draw_cc_tangent0(o, a, w, b)[2], draw_cc_tangent0(o, a, w, b)[1])
            $cc_tangent0(draw_cc_tangent0(o, a, w, b)[1], draw_cc_tangent0(o, a, w, b)[2], o, a, w, b)

"""
cc_tangent x y z i o a w b
x : o a w b y, y : o a w b x, z : o a w b i, i : o a w b z
o a w b = diff o a, diff w b, diff o w
x y : cong o x o a, cong w y w b, perp x o x y, perp y w y x; z i : cong o z o a, cong w i w b, perp z o z i, perp i w i z
cc_tangent o a w b
"""
# 两圆两条外公切线：x、y 为一条，z、i 为另一条
# Two external common tangents: (x,y) and (z,i)
prop cc_tangent(x, y, z, i, o, a, w, b point):
    $diff(o, a)
    $diff(w, b)
    $diff(o, w)
    $cong(o, x, o, a)
    $cong(w, y, w, b)
    $perp(x, o, x, y)
    $perp(y, w, y, x)
    $cong(o, z, o, a)
    $cong(w, i, w, b)
    $perp(z, o, z, i)
    $perp(i, w, i, z)

# 由两圆构造两条外公切线的四个切点
# Construct four tangent points of two external tangents
let draw_cc_tangent fn(o, a, w, b point: $diff(o, a), $diff(w, b), $diff(o, w)) cart(point, point, point, point)
know:
    forall o, a, w, b point:
        $diff(o, a)
        $diff(w, b)
        $diff(o, w)
        =>:
            $cong(o, draw_cc_tangent(o, a, w, b)[1], o, a)
            $cong(w, draw_cc_tangent(o, a, w, b)[2], w, b)
            $perp(draw_cc_tangent(o, a, w, b)[1], o, draw_cc_tangent(o, a, w, b)[1], draw_cc_tangent(o, a, w, b)[2])
            $perp(draw_cc_tangent(o, a, w, b)[2], w, draw_cc_tangent(o, a, w, b)[2], draw_cc_tangent(o, a, w, b)[1])
            $cong(o, draw_cc_tangent(o, a, w, b)[3], o, a)
            $cong(w, draw_cc_tangent(o, a, w, b)[4], w, b)
            $perp(draw_cc_tangent(o, a, w, b)[3], o, draw_cc_tangent(o, a, w, b)[3], draw_cc_tangent(o, a, w, b)[4])
            $perp(draw_cc_tangent(o, a, w, b)[4], w, draw_cc_tangent(o, a, w, b)[4], draw_cc_tangent(o, a, w, b)[3])
            $cc_tangent(draw_cc_tangent(o, a, w, b)[1], draw_cc_tangent(o, a, w, b)[2], draw_cc_tangent(o, a, w, b)[3], draw_cc_tangent(o, a, w, b)[4], o, a, w, b)

"""
eqangle3 x a b d e f
x : x a b d e f
a b d e f = ncoll d e f, diff a b, diff d e, diff e f
x : eqangle x a x b d e d f
eqangle3 a b d e f
"""
# 等角线第三种形式：∠xab = ∠def
# Equal-angle line (form 3): ∠xab = ∠def
prop eqangle3(x, a, b, d, e, f point):
    $ncoll(d, e, f)
    $diff(a, b)
    $diff(d, e)
    $diff(e, f)
    $eqangle(x, a, x, b, d, e, d, f)

# 由角 def 和射线 ab 构造满足 ∠xab = ∠def 的点 x
# Construct x with ∠xab = ∠def
let draw_eqangle3_x fn(a, b, d, e, f point: $ncoll(d, e, f), $diff(a, b), $diff(d, e), $diff(e, f)) point
know:
    forall a, b, d, e, f point:
        $ncoll(d, e, f)
        $diff(a, b)
        $diff(d, e)
        $diff(e, f)
        =>:
            $eqangle(draw_eqangle3_x(a, b, d, e, f), a, draw_eqangle3_x(a, b, d, e, f), b, d, e, d, f)
            $eqangle3(draw_eqangle3_x(a, b, d, e, f), a, b, d, e, f)

"""
tangent x y a o b
x y : o a b
a o b = diff o a, diff o b, diff a b
x : cong o x o b, perp a x o x; y : cong o y o b, perp a y o y
tangent a o b
"""
# 从圆外点作圆的切线：从 a 到圆(o,b)的两条切线切点为 x、y
# Tangents from external point a to circle
prop tangent(x, y, a, o, b point):
    $diff(o, a)
    $diff(o, b)
    $diff(a, b)
    $cong(o, x, o, b)
    $perp(a, x, o, x)
    $cong(o, y, o, b)
    $perp(a, y, o, y)

# 由圆外点 a 和圆构造两条切线的切点 x、y
# Construct tangent points x, y from external point a
let draw_tangent fn(a, o, b point: $diff(o, a), $diff(o, b), $diff(a, b)) cart(point, point)
know:
    forall a, o, b point:
        $diff(o, a)
        $diff(o, b)
        $diff(a, b)
        =>:
            $cong(o, draw_tangent(a, o, b)[1], o, b)
            $perp(a, draw_tangent(a, o, b)[1], o, draw_tangent(a, o, b)[1])
            $cong(o, draw_tangent(a, o, b)[2], o, b)
            $perp(a, draw_tangent(a, o, b)[2], o, draw_tangent(a, o, b)[2])
            $tangent(draw_tangent(a, o, b)[1], draw_tangent(a, o, b)[2], a, o, b)

"""
on_circum x a b c
x : a b c
a b c = ncoll a b c
x : cyclic a b c x
cyclic a b c
"""
# 外接圆上的点：点 x 在三角形 abc 的外接圆上
# Point on circumcircle: x on circumcircle of abc
prop on_circum(x, a, b, c point):
    $ncoll(a, b, c)
    # cyclic a b c x 表示 x 在过 a、b、c 的圆上
    # means x on circle through a, b, c

# 由三角形 abc 构造其外接圆上的点 x
# Construct point x on circumcircle of triangle abc
let draw_on_circum_x fn(a, b, c point: $ncoll(a, b, c)) point
know:
    forall a, b, c point:
        $ncoll(a, b, c)
        =>:
            $on_circum(draw_on_circum_x(a, b, c), a, b, c)

"""
Rules-only predicates (not in simplified_def.lit). Base props used by rules are declared here.
Inference rules use AlphaGeometry-style $... names.
"""
# Props moved from simplified_def.lit (only those used by rules below)

prop cyclic(a, b, c, d)
prop cyclic6(a, b, c, p, q, r)
prop eqratio(a, b, c, d, m, n, p, q)
prop eqratio6(d, b, c, a)
prop eqratio3(a, b, c, d, o)
prop contri(a, b, c, p, q, r point):
    $eqangle(b, a, b, c, q, p, q, r)
    $eqangle(c, a, c, b, r, p, r, q)
    $eqangle(a, b, a, c, p, q, p, r)
    $ncoll(a, b, c)
    $ncoll(p, q, r)
    $cong(a, b, p, q)
    $cong(a, c, p, r)
    $cong(b, c, q, r)

prop contri2(a, b, c, p, q, r)
prop simtri(a, b, c, p, q, r)
prop sameside(a, o1, c, b, o2, d)



# Rule 1
### rules.txt 单行:perp a b c d, perp c d e f, ncoll a b e => para a b e f
### If line ab is perpendicular to line cd, and line cd is perpendicular to line ef,
### and points a, b, e are not collinear, then line ab is parallel to line ef.
### 如果直线ab垂直于直线cd，直线cd垂直于直线ef，且点a、b、e不共线，则直线ab平行于直线ef。
know:
    forall a, b, c, d, e, f point:
        $perp(a, b, c, d)
        $perp(c, d, e, f)
        $ncoll(a, b, e)
        =>:
            $para(a, b, e, f)

# Rule 2
### rules.txt 单行:cong o a o b, cong o b o c, cong o c o d => cyclic a b c d
### If segments oa, ob, oc, od are all congruent (oa ≅ ob ≅ oc ≅ od),
### then points a, b, c, d are concyclic (lie on the same circle).
### 如果线段oa、ob、oc、od都相等（oa ≅ ob ≅ oc ≅ od），则点a、b、c、d共圆。
know:
    forall o, a, b, c, d point:
        $cong(o, a, o, b)
        $cong(o, b, o, c)
        $cong(o, c, o, d)
        =>:
            $cyclic(a, b, c, d)

# Rule 3
### rules.txt 单行:eqangle a b p q c d p q => para a b c d
### 自然语言:若 \(\angle(ab,pq)=\angle(cd,pq)\)（两条直线 ab 与 cd 相对同一参考直线 pq 的夹角相等），则 ab ∥ cd。
### If ∠(ab,pq)=∠(cd,pq) (equal angles with respect to line pq), then ab ∥ cd.
know:
    forall a, b, c, d, p, q point:
        $eqangle(a, b, p, q, c, d, p, q)
        =>:
            $para(a, b, c, d)
    forall a, b, c, d, p, q point:
        $para(a, b, c, d)
        =>:
            $eqangle(a, b, p, q, c, d, p, q)


# Rule 4
### rules.txt 单行:cyclic a b p q => eqangle p a p b q a q b
### 自然语言:同圆定理（同弦所对圆周角相等）:若 a,b,p,q 共圆，则 \(\angle apb = \angle aqb\)（同为弦 ab 所对的圆周角）。
### Inscribed angle theorem: if a,b,p,q are concyclic, then ∠apb = ∠aqb (angles subtended by chord ab).
know:
    forall a, b, p, q point:
        $cyclic(a, b, p, q)
        =>:
            $eqangle(p, a, p, b, q, a, q, b)

# Rule 5
### rules.txt 单行:eqangle6 p a p b q a q b, ncoll p q a b => cyclic a b p q
### 自然语言:圆周角定理的逆:若 \(\angle apb=\angle aqb\)，并且不出现 p,q,a,b 全共线的退化情况，则 a,b,p,q 共圆。
### Converse of inscribed angle theorem: if ∠apb = ∠aqb and p,q,a,b not collinear, then a,b,p,q are concyclic.
know:
    forall p, a, b, q point:
        $eqangle(p, a, p, b, q, a, q, b)
        $ncoll2(p, q, a, b)
        =>:
            $cyclic(a, b, p, q)

# Rule 6
### rules.txt 单行:cyclic a b c p q r, eqangle c a c b r p r q => cong a b p q
### 自然语言:同圆中"等角对等弦":在同一圆上，若圆周角 \(\angle acb\) 与 \(\angle prq\) 相等，则它们所对的弦 ab 与 pq 相等。
### Equal angles subtend equal chords: on the same circle, if ∠acb = ∠prq, then chord ab = chord pq.
know:
    forall a, b, c, p, q, r point:
        $cyclic6(a, b, c, p, q, r)
        $eqangle(c, a, c, b, r, p, r, q)
        =>:
            $cong(a, b, p, q)

# Rule 7
### rules.txt 单行:midp e a b, midp f a c => para e f b c
### 自然语言:三角形中位线定理:若 e、f 分别是 ab、ac 的中点，则 ef ∥ bc。
### Midsegment theorem: if e, f are midpoints of ab, ac, then ef ∥ bc.
know:
    forall e, a, b, f, c point:
        $ncoll(a, b, c)
        $midpoint(e, a, b)
        $midpoint(f, a, c)
        =>:
            $para(e, f, b, c)

# Rule 8
### rules.txt 单行:para a b c d, coll o a c, coll o b d => eqratio3 a b c d o o
### 自然语言:平行线截比/相似带来的比例结论:ab ∥ cd 且 o 分别在 ac、bd 上时，会导出关于 a,b,c,d 与交点 o 的一个比例关系。
### Parallel intercept theorem: if ab ∥ cd and o lies on ac, bd, then a ratio holds among a,b,c,d and o.
know:
    forall a, b, c, d, o point:
        $para(a, b, c, d)
        $coll(o, a, c)
        $coll(o, b, d)
        =>:
            $eqratio3(a, b, c, d, o)

# Rule 9
### rules.txt 单行:perp a b c d, perp e f g h, npara a b e f => eqangle a b e f c d g h
### 自然语言:若 ab ⟂ cd 且 ef ⟂ gh，则 \(\angle(ab,ef)=\angle(cd,gh)\)；再加 "ab 与 ef 不平行" 用来排除夹角为 0/180° 的退化情况。
### If ab ⟂ cd and ef ⟂ gh, then ∠(ab,ef)=∠(cd,gh); "ab not parallel to ef" excludes 0/180° degenerate case.
know:
    forall a, b, c, d, e, f, g, h point:
        $perp(a, b, c, d)
        $perp(e, f, g, h)
        $npara(a, b, e, f)
        =>:
            $eqangle(a, b, e, f, c, d, g, h)

# Rule 10
### rules.txt 单行:eqangle a b c d m n p q, eqangle c d e f p q r u => eqangle a b e f m n r u
### 自然语言:第一组:∠(ab, cd) = ∠(mn, pq)第二组:∠(cd, ef) = ∠(pq, ru)
### 结论:∠(ab, ef) = ∠(mn, ru)
### Group 1: ∠(ab, cd) = ∠(mn, pq); Group 2: ∠(cd, ef) = ∠(pq, ru) => ∠(ab, ef) = ∠(mn, ru).
know:
    forall a, b, c, d, m, n, p, q, e, f, r, u point:
        $eqangle(a, b, c, d, m, n, p, q)
        $eqangle(c, d, e, f, p, q, r, u)
        =>:
            $eqangle(a, b, e, f, m, n, r, u)

# Rule 11
### rules.txt 单行:eqratio a b c d m n p q, eqratio c d e f p q r u => eqratio a b e f m n r u
### 自然语言:比例关系的传递性:若 ab/cd = mn/pq 且 cd/ef = pq/ru，则 ab/ef = mn/ru。
### Ratio transitivity: if ab/cd = mn/pq and cd/ef = pq/ru, then ab/ef = mn/ru.
know:
    forall a, b, c, d, m, n, p, q, e, f, r, u point:
        $eqratio(a, b, c, d, m, n, p, q)
        $eqratio(c, d, e, f, p, q, r, u)
        =>:
            $eqratio(a, b, e, f, m, n, r, u)

# Rule 12
### rules.txt 单行:eqratio6 d b d c a b a c, coll d b c, ncoll a b c => eqangle6 a b a d a d a c
### 自然语言:若 db/dc = ab/ac，且 d, b, c 共线，a, b, c 不共线，则角 bad 等于角 cad（即 ad 是角 bac 的角平分线）。
### If db/dc = ab/ac, d,b,c collinear, a,b,c non-collinear, then ∠bad = ∠cad (ad is angle bisector of ∠bac).
know:
    forall d, b, c, a point:
        $eqratio6(d, b, c, a)
        $coll(d, b, c)
        $ncoll(a, b, c)
        =>:
            $eqangle(a, b, a, d, a, d, a, c)

# Rule 13
### rules.txt 单行:eqangle6 a b a d a d a c, coll d b c, ncoll a b c => eqratio6 d b d c a b a c
### 自然语言:Rule 12 的逆:若角 bad 等于角 cad（即 ad 是角 bac 的角平分线），且 d, b, c 共线，a, b, c 不共线，则 db/dc = ab/ac（角平分线定理）。
### Converse of Rule 12 / Angle bisector theorem: if ∠bad = ∠cad (ad bisects ∠bac), then db/dc = ab/ac.
know:
    forall a, b, d, c point:
        $eqangle(a, b, a, d, a, d, a, c)
        $coll(d, b, c)
        $ncoll(a, b, c)
        =>:
            $eqratio6(d, b, c, a)

# Rule 14
### rules.txt 单行:cong o a o b, ncoll o a b => eqangle o a a b a b o b
### 自然语言:等腰三角形底角相等:若 oa = ob（等腰三角形），且 o, a, b 不共线，则角 oab 等于角 oba。
### Isosceles triangle base angles: if oa = ob and o,a,b non-collinear, then ∠oab = ∠oba.
know:
    forall o, a, b point:
        $cong(o, a, o, b)
        $ncoll(o, a, b)
        =>:
            $eqangle(o, a, a, b, a, b, o, b)

# Rule 15
### rules.txt 单行:eqangle6 a o a b b a b o, ncoll o a b => cong o a o b
### 自然语言:Rule 14 的逆:若角 aob 等于角 bao（即角 oab = 角 oba），且 o, a, b 不共线，则 oa = ob（等腰三角形判定）。
### Converse of Rule 14: if ∠oab = ∠oba and o,a,b non-collinear, then oa = ob (isosceles triangle).
know:
    forall a, o, b point:
        $eqangle(a, o, a, b, b, a, b, o)
        $ncoll(o, a, b)
        =>:
            $cong(o, a, o, b)

# Rule 16
### rules.txt 单行:circle o a b c, perp o a a x => eqangle a x a b c a c b
### 自然语言:圆的切线性质:若 o 为圆心，a, b, c 在圆上，且直线 oa 垂直于直线 ax（即 ax 是切线），则角 xab 等于角 acb（切线与弦的夹角等于同弧所对的圆周角）。
### Tangent-chord angle: if o is center, a,b,c on circle, oa ⟂ ax (ax tangent), then ∠xab = ∠acb.
prop tline_eqangle(o,a, b, c ,x point):
    $eqangle(a, x, a, b, c, a, c, b)
know:
    forall o, a, b, c, x point:
        $ncoll(a, b, c)
        $circle(o, a, b, c)
        $perp(o, a, a, x)
        =>:
            $tline_eqangle(o,a, b, c, x)

# Rule 17
### rules.txt 单行:circle o a b c, eqangle a x a b c a c b => perp o a a x
### 自然语言:Rule 16 的逆:若 o 为圆心，a, b, c 在圆上，且角 xab 等于角 acb，则直线 oa 垂直于直线 ax（切线判定）。
### Converse of Rule 16 / Tangent criterion: if ∠xab = ∠acb, then oa ⟂ ax (ax is tangent).
know:
    forall o, a, b, c, x point:
        $ncoll(a, b, c)
        $circle(o, a, b, c)
        $eqangle(a, x, a, b, c, a, c, b)
        =>:
            $perp(o, a, a, x)

# Rule 18
### rules.txt 单行:circle o a b c, midp m b c => eqangle a b a c o b o m
### 自然语言:圆的性质:若 o 为圆心，a, b, c 在圆上，且 m 是 bc 的中点，则角 bac 等于角 bom（圆心角与圆周角的关系）。
### Central angle vs inscribed angle: if m is midpoint of bc, then ∠bac = ∠bom.
know:
    forall o, a, b, c, m point:
        $circle(o, a, b, c)
        $midpoint(m, b, c)
        =>:
            $eqangle(a, b, a, c, o, b, o, m)

# Rule 19
### rules.txt 单行:circle o a b c, coll m b c, eqangle a b a c o b o m => midp m b c
### 自然语言:Rule 18 的逆:若 o 为圆心，a, b, c 在圆上，m 在直线 bc 上，且角 bac 等于角 bom，则 m 是 bc 的中点。
### Converse of Rule 18: if m on bc and ∠bac = ∠bom, then m is midpoint of bc.
know:
    forall o, a, b, c, m point:
        $circle(o, a, b, c)
        $coll(m, b, c)
        $eqangle(a, b, a, c, o, b, o, m)
        =>:
            $midpoint(m, b, c)

# Rule 20
### rules.txt 单行:perp a b b c, midp m a c => cong a m b m
### 自然语言:直角三角形斜边中点性质:若 ab 垂直于 bc（即角 abc 是直角），且 m 是 ac 的中点，则 am = bm（直角三角形斜边上的中线等于斜边的一半，因此 m 到 a 和 b 的距离相等）。
### Right triangle median: if ∠abc is right and m is midpoint of ac, then am = bm.
know:
    forall a, b, c, m point:
        $perp(a, b, b, c)
        $midpoint(m, a, c)
        =>:
            $cong(a, m, b, m)

# Rule 21
### rules.txt 单行:circle o a b c, coll o a c => perp a b b c
### 自然语言:圆的性质:若 o 为圆心，a, b, c 在圆上，且 o, a, c 共线（即 ac 是直径），则 ab 垂直于 bc（直径所对的圆周角是直角）。
### Thales' theorem: if ac is diameter, then ∠abc is right (ab ⟂ bc).
know:
    forall o, a, b, c point:
        $ncoll(a, b, c)
        $circle(o, a, b, c)
        $coll(o, a, c)
        =>:
            $perp(a, b, b, c)

# Rule 22
### rules.txt 单行:cyclic a b c d, para a b c d => eqangle a d c d c d c b
### 自然语言:圆内接梯形的性质:若 a, b, c, d 共圆，且 ab ∥ cd，则角 adc 等于角 bcd（同底角相等）。
### Cyclic trapezoid: if a,b,c,d concyclic and ab ∥ cd, then ∠adc = ∠bcd.
know:
    forall a, b, c, d point:
        $cyclic(a, b, c, d)
        $para(a, b, c, d)
        =>:
            $eqangle(a, d, c, d, c, d, c, b)

# Rule 23
### rules.txt 单行:midp m a b, perp o m a b => cong o a o b
### 自然语言:垂直平分线的性质:若 m 是 ab 的中点，且直线 om 垂直于 ab，则 oa = ob（o 在 ab 的垂直平分线上，因此到 a 和 b 的距离相等）。
### Perpendicular bisector: if m is midpoint of ab and om ⟂ ab, then oa = ob.
know:
    forall m, a, b, o point:
        $midpoint(m, a, b)
        $perp(o, m, a, b)
        =>:
            $cong(o, a, o, b)

# Rule 24
### rules.txt 单行:cong a p b p, cong a q b q => perp a b p q
### 自然语言:到两点距离相等的点的轨迹:若 ap = bp 且 aq = bq（p 和 q 都在 ab 的垂直平分线上），则 ab 垂直于 pq。
### Locus of equidistant points: if ap = bp and aq = bq, then ab ⟂ pq.
know:
    forall a, p, b, q point:
        $cong(a, p, b, p)
        $cong(a, q, b, q)
        =>:
            $perp(a, b, p, q)

# Rule 25
### rules.txt 单行:cong a p b p, cong a q b q, cyclic a b p q => perp p a a q
### 自然语言:圆的性质:若 ap = bp，aq = bq，且 a, b, p, q 共圆，则 pa 垂直于 aq（a 是圆心，pa 和 aq 是半径，因此垂直）。
### If a,b,p,q concyclic with ap = bp = aq = bq (a center), then pa ⟂ aq.
know:
    forall a, p, b, q point:
        $cong(a, p, b, p)
        $cong(a, q, b, q)
        $cyclic(a, b, p, q)
        =>:
            $perp(p, a, a, q)

# Rule 26
### rules.txt 单行:midp m a b, midp m c d => para a c b d
### 自然语言:中点连线性质:若 m 既是 ab 的中点，也是 cd 的中点，则 ac ∥ bd（对角线互相平分的四边形是平行四边形）。
### Parallelogram diagonals: if m bisects both ab and cd, then ac ∥ bd (parallelogram).
know:
    forall m, a, b, c, d point:
        $midpoint(m, a, b)
        $midpoint(m, c, d)
        =>:
            $para(a, c, b, d)

# Rule 27
### rules.txt 单行:midp m a b, para a c b d, para a d b c => midp m c d
### 自然语言:Rule 26 的逆:若 m 是 ab 的中点，且 ac ∥ bd，ad ∥ bc（即 abcd 是平行四边形），则 m 也是 cd 的中点。
### Converse of Rule 26: if abcd is parallelogram (ac∥bd, ad∥bc) and m midpoint of ab, then m midpoint of cd.
know:
    forall m, a, b, c, d point:
        $midpoint(m, a, b)
        $para(a, c, b, d)
        $para(a, d, b, c)
        =>:
            $midpoint(m, c, d)

# Rule 28
### rules.txt 单行:eqratio o a a c o b b d, coll o a c, coll o b d, ncoll a b c, sameside a o c b o d => para a b c d
### 自然语言:比例判定平行:若 oa/ac = ob/bd，o 在 ac 上，o 在 bd 上，a, b, c 不共线，且 a, c 在 o 的同侧，b, d 在 o 的同侧，则 ab ∥ cd。
### Parallel by ratio: if oa/ac = ob/bd with sameside condition, then ab ∥ cd.
know:
    forall o, a, c, b, d point:
        $eqratio(o, a, a, c, o, b, b, d)
        $coll(o, a, c)
        $coll(o, b, d)
        $ncoll(a, b, c)
        $sameside(a, o, c, b, o, d)
        =>:
            $para(a, b, c, d)

# Rule 29
### rules.txt 单行:para a b a c => coll a b c
### 自然语言:平行线的退化情况:若 ab ∥ ac（两条直线都经过点 a），则 a, b, c 共线（同一直线）。
### Degenerate parallel: if ab ∥ ac (both through a), then a, b, c are collinear.
know:
    forall a, b, c point:
        $para(a, b, a, c)
        =>:
            $coll(a, b, c)

# Rule 30
### rules.txt 单行:midp m a b, midp n c d => eqratio m a a b n c c d
### 自然语言:中点比例关系:若 m 是 ab 的中点，n 是 cd 的中点，则 ma/ab = nc/cd（都等于 1/2）。
### Midpoint ratio: if m, n are midpoints of ab, cd, then ma/ab = nc/cd (= 1/2).
know:
    forall m, a, b, n, c, d point:
        $midpoint(m, a, b)
        $midpoint(n, c, d)
        =>:
            $eqratio(m, a, a, b, n, c, c, d)

# Rule 31
### rules.txt 单行:eqangle a b p q c d u v, perp p q u v => perp a b c d
### 自然语言:若直线 ab 与 pq 的夹角等于直线 cd 与 uv 的夹角，且 pq 垂直于 uv，则 ab 垂直于 cd。
### If ∠(ab,pq) = ∠(cd,uv) and pq ⟂ uv, then ab ⟂ cd.
know:
    forall a, b, p, q, c, d, u, v point:        
        $eqangle(a, b, p, q, c, d, u, v)
        $perp(p, q, u, v)
        =>:
            $perp(a, b, c, d)

# Rule 32
### rules.txt 单行:eqratio a b p q c d u v, cong p q u v => cong a b c d
### 自然语言:若 ab/pq = cd/uv，且 pq = uv，则 ab = cd。
### If ab/pq = cd/uv and pq = uv, then ab = cd.
know:
    forall a, b, p, q, c, d, u, v point:
        $eqratio(a, b, p, q, c, d, u, v)
        $cong(p, q, u, v)
        =>:
            $cong(a, b, c, d)

# Rule 33
### rules.txt 单行:cong a b p q, cong b c q r, cong c a r p, ncoll a b c => contri* a b c p q r
### 自然语言:全等三角形判定（SSS）:若 ab = pq，bc = qr，ca = rp，且 a, b, c 不共线，则三角形 abc 与三角形 pqr 全等。
### SSS congruence: if ab=pq, bc=qr, ca=rp and a,b,c non-collinear, then Δabc ≅ Δpqr.
know:
    forall a, b, c, p, q, r point:
        $cong(a, b, p, q)
        $cong(b, c, q, r)
        $cong(c, a, r, p)
        $ncoll(a, b, c)
        $ncoll(p, q, r)
        =>:
            $contri(a, b, c, p, q, r)

# Rule 34
### rules.txt 单行:cong a b p q, cong b c q r, eqangle6 b a b c q p q r, ncoll a b c => contri* a b c p q r
### 自然语言:全等三角形判定（SAS）:若 ab = pq，bc = qr，角 abc = 角 pqr，且 a, b, c 不共线，则三角形 abc 与三角形 pqr 全等。
### SAS congruence: if ab=pq, bc=qr, ∠abc=∠pqr, then Δabc ≅ Δpqr.
know:
    forall a, b, c, p, q, r point:
        $cong(a, b, p, q)
        $cong(b, c, q, r)
        $eqangle(b, a, b, c, q, p, q, r)
        $ncoll(a, b, c)
        $ncoll(p, q, r)
        =>:
            $contri(a, b, c, p, q, r)

# Rule 35
### rules.txt 单行:eqangle6 b a b c q p q r, eqangle6 c a c b r p r q, ncoll a b c => simtri a b c p q r
### 自然语言:相似三角形判定（AA）:若角 abc = 角 pqr，角 acb = 角 prq，且 a, b, c 不共线，则三角形 abc 与三角形 pqr 相似。
### AA similarity: if ∠abc=∠pqr, ∠acb=∠prq, then Δabc ~ Δpqr.
know:
    forall a, b, c, p, q, r point:
        $eqangle(b, a, b, c, q, p, q, r)
        $eqangle(c, a, c, b, r, p, r, q)
        $ncoll(a, b, c)
        $ncoll(p, q, r)
        =>:
            $simtri(a, b, c, p, q, r)

# Rule 36
### rules.txt 单行:eqangle6 b a b c q r q p, eqangle6 c a c b r q r p, ncoll a b c => simtri2 a b c p q r
### 自然语言:相似三角形判定（AA，交替方向）:若角 abc = 角 qrp，角 acb = 角 rqp，且 a, b, c 不共线，则三角形 abc 与三角形 pqr 相似（交替方向）。
### AA similarity (alternate orientation): if ∠abc=∠qrp, ∠acb=∠rqp, then Δabc ~ Δpqr.
###不必要

# Rule 37
### rules.txt 单行:eqangle6 b a b c q p q r, eqangle6 c a c b r p r q, ncoll a b c, cong a b p q => contri a b c p q r
### 自然语言:全等三角形判定（ASA）:若角 abc = 角 pqr，角 acb = 角 prq，ab = pq，且 a, b, c 不共线，则三角形 abc 与三角形 pqr 全等。
### ASA congruence: if ∠abc=∠pqr, ∠acb=∠prq, ab=pq, then Δabc ≅ Δpqr.
know:
    forall a, b, c, p, q, r point:
        $eqangle(b, a, b, c, q, p, q, r)
        $eqangle(c, a, c, b, r, p, r, q)
        $ncoll(a, b, c)
        $ncoll(p, q, r)
        $cong(a, b, p, q)
        =>:
            $contri(a, b, c, p, q, r)

# Rule 38
### rules.txt 单行:eqangle6 b a b c q r q p, eqangle6 c a c b r q r p, ncoll a b c, cong a b p q => contri2 a b c p q r
### 自然语言:全等三角形判定（AAS，交替方向）:若角 abc = 角 qrp，角 acb = 角 rqp，ab = pq，且 a, b, c 不共线，则三角形 abc 与三角形 pqr 全等。
### AAS congruence (alternate): if ∠abc=∠qrp, ∠acb=∠rqp, ab=pq, then Δabc ≅ Δpqr.
know:
    forall a, b, c, p, q, r point:
        $eqangle(b, a, b, c, q, r, q, p)
        $eqangle(c, a, c, b, r, q, r, p)
        $ncoll(a, b, c)
        $ncoll(p, q, r)
        $cong(a, b, p, q)
        =>:
            $contri2(a, b, c, p, q, r)

# Rule 39
### rules.txt 单行:eqratio6 b a b c q p q r, eqratio6 c a c b r p r q, ncoll a b c => simtri* a b c p q r
### 自然语言:相似三角形判定（SSS）:若 ba/bc = qp/qr，ca/cb = rp/rq，且 a, b, c 不共线，则三角形 abc 与三角形 pqr 相似。
### SSS similarity: if ba/bc=qp/qr, ca/cb=rp/rq, then Δabc ~ Δpqr.
know:
    forall a, b, c, p, q, r point:
        $eqratio(b, a, b, c, q, p, q, r)
        $eqratio(c, a, c, b, r, p, r, q)
        $ncoll(a, b, c)
        $ncoll(p, q, r)
        =>:
            $simtri(a, b, c, p, q, r)

# Rule 40
### rules.txt 单行:eqratio6 b a b c q p q r, eqangle6 b a b c q p q r, ncoll a b c => simtri* a b c p q r
### 自然语言:相似三角形判定（SAS）:若 ba/bc = qp/qr，角 abc = 角 pqr，且 a, b, c 不共线，则三角形 abc 与三角形 pqr 相似。
### SAS similarity: if ba/bc=qp/qr, ∠abc=∠pqr, then Δabc ~ Δpqr.
know:
    forall a, b, c, p, q, r point:
        $eqratio(b, a, b, c, q, p, q, r)
        $eqangle(b, a, b, c, q, p, q, r)
        $ncoll(a, b, c)
        $ncoll(p, q, r)
        =>:
            $simtri(a, b, c, p, q, r)

# Rule 41
### rules.txt 单行:eqratio6 b a b c q p q r, eqratio6 c a c b r p r q, ncoll a b c, cong a b p q => contri* a b c p q r
### 自然语言:全等三角形判定（SSS，通过比例）:若 ba/bc = qp/qr，ca/cb = rp/rq，ab = pq，且 a, b, c 不共线，则三角形 abc 与三角形 pqr 全等。
### SSS congruence (via ratios): if ba/bc=qp/qr, ca/cb=rp/rq, ab=pq, then Δabc ≅ Δpqr.
know:
    forall a, b, c, p, q, r point:
        $eqratio(b, a, b, c, q, p, q, r)
        $eqratio(c, a, c, b, r, p, r, q)
        $ncoll(a, b, c)
        $ncoll(p, q, r)
        $cong(a, b, p, q)
        =>:
            $contri(a, b, c, p, q, r)

# Rule 42
### rules.txt 单行:para a b c d, coll m a d, coll n b c, eqratio6 m a m d n b n c, sameside m a d n b c => para m n a b
### 自然语言:平行线截比定理:若 ab ∥ cd，m 在直线 ad 上，n 在直线 bc 上，ma/md = nb/nc，且 m, a, d 与 n, b, c 在各自直线的同侧，则 mn ∥ ab。
### Intercept theorem: if ab ∥ cd, m on ad, n on bc, ma/md=nb/nc (sameside), then mn ∥ ab.
### 注:sameside m a d 表示 m, a, d 在一条直线的同侧，这里简化为 m 不在 a 和 d 之间。
know:
    forall a, b, c, d, m, n point:
        $para(a, b, c, d)
        $coll(m, a, d)
        $coll(n, b, c)
        $eqratio(m, a, m, d, n, b, n, c)
        $sameside(m, a, d, n, b, c)
        =>:
            $para(m, n, a, b)

# Rule 43
### rules.txt 单行:para a b c d, coll m a d, coll n b c, para m n a b => eqratio6 m a m d n b n c
### 自然语言:Rule 42 的逆:若 ab ∥ cd，m 在直线 ad 上，n 在直线 bc 上，且 mn ∥ ab，则 ma/md = nb/nc。
### Converse of intercept theorem: if ab ∥ cd, m on ad, n on bc, mn ∥ ab, then ma/md = nb/nc.
know:
    forall a, b, c, d, m, n point:
        $para(a, b, c, d)
        $coll(m, a, d)
        $coll(n, b, c)
        $para(m, n, a, b)
        =>:
            $eqratio(m, a, m, d, n, b, n, c)

"""
IMO 2000 P1
a b = segment a b; g1 = on_tline g1 a a b; 
g2 = on_tline g2 b b a; m = on_circle m g1 a, on_circle m g2 b; 
n = on_circle n g1 a, on_circle n g2 b; c = on_pline c m a b, on_circle c g1 a; 
d = on_pline d m a b, on_circle d g2 b; e = on_line e a c, on_line e b d; 
p = on_line p a n, on_line p c d; q = on_line q b n, on_line q c d 
? cong e p e q
"""

let a,b,g1,g2,m,n,c,d,e,p,q point
know:
    $segment(a, b)
    $on_tline(g1, a, a, b)
    $on_tline(g2, b, b, a)
    $on_circle(m, g1, a)
    $on_circle(m, g2, b)
    $on_circle(n, g1, a)
    $on_circle(n, g2, b)
    $on_pline(c, m, a, b)
    $on_circle(c, g1, a)
    $on_pline(d, m, a, b)
    $on_circle(d, g2, b)
    $on_line(e, a, c)
    $on_line(e, b, d)
    $on_line(p, a, n)
    $on_line(p, c, d)
    $on_line(q, b, n)
    $on_line(q, c, d)
    $ncoll(b,d,m)
    $ncoll(a,m,c)
    $ncoll(m,b,e)
    $is_circumcenter(g2, b, d, m) #??
    $is_circumcenter(g1, a, c, m) #???
    $circle(g1,a,m,c) #???
    $circle(g2,b,d,m) #???
    $eqangle(b,a,b,d,b,a,b,e) #归一一下直线夹角
    $eqangle(m,b,m,d,b,m,b,a) #归一一下平行线夹角
    $eqangle(b,m,b,a,b,a,b,e) #归一一下夹角传递性
    $angle_bisector(a,m,b,e)  #???
    $eqangle(c,a,c,m,a,b,a,e) #平行线夹角
    $eqangle(a,b,a,e,a,m,a,b) #归一一下角传递性  
    $ncoll(m,a,e)
    $angle_bisector(b,m,a,e)
    $ncoll(a,b,e)
    $ncoll(a,b,m)
    $contri(a,b,e,a,b,m)
    


#step 1:
know:
    forall _g2, _b, _d, _m point:
        $cong(_g2, _b, _g2, _d)
        $cong(_g2, _b, _g2, _m)
        $ncoll(_b, _d, _m)
        =>:
            $congtransitive(_g2, _b, _d, _m)
            $cong(_g2, _d, _g2, _m)
            $is_circumcenter(_g2, _b, _d, _m)
    $cong(g2,b,g2,d)
    $cong(g2,b,g2,m)
    $ncoll(b,d,m)
$congtransitive(g2,b,d,m)
$cong(g2,d,g2,m)
$is_circumcenter(g2, b, d, m) #???
"""
prop is_circumcenter(x, a, b, c point):
    $ncoll(a, b, c)
    $cong(x, a, x, b)
    $cong(x, b, x, c)
"""

#step 2:
know:
    forall _g2, _b, _d, _m, _a point:
        $perp(_g2, _b, _b, _a)
        $ncoll(_b, _d, _m)
        $circle(_g2, _b, _d, _m)
        =>:
            $tline_eqangle(_g2, _b, _d, _m, _a)
            $eqangle(_b, _a, _b, _d, _m, _b, _m, _d)
    $perp(g2,b,b,a)
    $ncoll(b,d,m)
    $circle(g2,b,d,m)
#ABD= BMD.
$tline_eqangle(g2,b,d,m,a)
$eqangle(b,a,b,d,m,b,m,d)

#step 3:
know:
    forall _a, _g1, _c, _m point:
        $cong(_a, _g1, _c, _g1)
        $cong(_a, _g1, _g1, _m)
        =>:
            $is_circumcenter(_g1, _a, _c, _m)
    $cong(a,g1,c,g1)
    $cong(a,g1,g1,m)
$is_circumcenter(g1, a, c, m)

#step 4:
know:
    forall _g1, _a, _m, _c, _b point:
        $perp(_g1, _a, _a, _b)
        $ncoll(_a, _m, _c)
        $circle(_g1, _a, _m, _c)
        =>:
            $tline_eqangle(_g1, _a, _m, _c, _b)
            $eqangle(_a, _b, _a, _m, _c, _a, _c, _m)
    $perp(g1,a,a,b)
    $ncoll(a,m,c)
    $circle(g1,a,m,c)
# BAM= ACM
$tline_eqangle(g1,a,m,c,b)
$eqangle(a,b,a,m,c,a,c,m)

#step 5:
know:
    forall _e, _b, _d, _a, _m point:
        $coll(_e, _b, _d)
        $eqangle(_b, _a, _b, _d, _b, _a, _b, _e)
        $eqangle(_b, _a, _b, _d, _m, _b, _m, _d)
        $para(_d, _m, _a, _b)
        $eqangle(_m, _b, _m, _d, _b, _m, _b, _a)
        $ncoll(_m, _b, _e)
        $eqangle(_b, _m, _b, _a, _b, _a, _b, _e)
        =>:
            $angle_bisector(_a, _m, _b, _e)
    $coll(e,b,d)
    $eqangle(b,a,b,d,b,a,b,e)
    $eqangle(b,a,b,d,m,b,m,d)
    $para(d,m,a,b)
    $eqangle(m,b,m,d,b,m,b,a)
    $ncoll(m,b,e)
    $eqangle(b,m,b,a,b,a,b,e)
$angle_bisector(a,m,b,e)  #??? 
"""
prop angle_bisector(x, a, b, c point):
    $ncoll(a, b, c)
    $eqangle(b, a, b, x, b, x, b, c)
""" 

#step 6:
know:
    forall _e, _a, _c, _b, _m point:
        $coll(_e, _a, _c)
        $eqangle(_a, _b, _a, _m, _c, _a, _c, _m)
        $para(_c, _m, _a, _b)
        $eqangle(_c, _a, _c, _m, _a, _b, _a, _e)
        $eqangle(_a, _b, _a, _e, _a, _m, _a, _b)
        $ncoll(_m, _a, _e)
        =>:
            $angle_bisector(_b, _m, _a, _e)
    $coll(e,a,c)
    $eqangle(a,b,a,m,c,a,c,m)
    $para(c,m,a,b)
    $eqangle(c,a,c,m,a,b,a,e)
    $eqangle(a,b,a,e,a,m,a,b)
    $ncoll(m,a,e)
$angle_bisector(b,m,a,e)

#step 7:
know:
    forall _a, _b, _e, _m point:
        $angle_bisector(_b, _m, _a, _e)
        $angle_bisector(_a, _m, _b, _e)
        $cong(_a, _b, _a, _b)
        $ncoll(_a, _b, _e)
        $ncoll(_a, _b, _m)
        =>:
            $contri(_a, _b, _e, _a, _b, _m)
            $cong(_a, _e, _a, _m)
            $cong(_b, _e, _b, _m)
    $angle_bisector(b,m,a,e)
    $angle_bisector(a,m,b,e)
    $cong(a,b,a,b)
    $ncoll(a,b,e)
    $ncoll(a,b,m)
$contri(a,b,e,a,b,m)
#AE = AM  
$cong(a,e,a,m)
#BE = BM
$cong(b,e,b,m)

#step 8:
know:
    forall _a, _g1, _m, _n point:
        $ncoll(_a, _g1, _m)# AG1 = G1M
        $ncoll(_a, _g1, _n)# AG1 = G1N
        =>:
            $cong(_a,_g1,_g1,_m)
            $cong(_a,_g1,_g1,_n)
            $is_circumcenter(_g1, _a, _m, _n)# G1 is the circumcenter of AMN
    $ncoll(a,g1,m)
    $ncoll(a,g1,n)
    $cong(a,g1,g1,m)
    $cong(a,g1,g1,n)
$is_circumcenter(g1, a, m, n)

#step 9:
know:
    forall _a, _b, _g1, _m, _n point:
        $is_circumcenter(_g1, _a, _m, _n)
        $perp(_a, _b, _a, _g1)
        =>:
            $eqangle(_a, _b, _a, _m, _n, _a, _n, _m)
            $eqangle(_a, _b, _a, _n, _m, _a, _m, _n)
    $is_circumcenter(g1, a, m, n)
    $perp(a,b,a,g1)
    $eqangle(a,b,a,m,n,a,n,m)
    $eqangle(a,b,a,n,m,a,m,n)
# BAM = ANM
$eqangle(a,b,a,m,n,a,n,m)
# BAN = AMN
$eqangle(a,b,a,n,m,a,m,n)

#step 10:
know:
    forall _a, _b, _c, _d, _m point:
        $para(_a, _b, _c, _m)
        $para(_a, _b, _d, _m)
        =>:
            $para(_c, _m, _d, _m)
    $para(a,b,c,m)
    $para(a,b,d,m)
# CM is parallel to DM
$para(c,m,d,m)

#step 11:
know:
    forall _c, _d, _m point:
        $para(_c, _m, _d, _m)
        =>:
            $coll(_c, _d, _m)
    $para(c,m,d,m)
# C,D,M are collinear
$coll(c,d,m)

#step 12:
know:
    forall _a, _n, _p, _c, _d, _m, _b point:
        $coll(_a, _n, _p)
        $coll(_c, _d, _m)
        $coll(_c, _d, _p)
        $eqangle(_a, _b, _a, _n, _m, _a, _m, _n)
        $para(_a, _b, _d, _m)
        =>:
            $eqangle(_m, _a, _m, _n, _p, _a, _p, _m)
    $coll(a,n,p)
    $coll(c,d,m)
    $coll(c,d,p)
    $eqangle(a,b,a,n,m,a,m,n)
    $para(a,b,d,m)
# AMN = MPA
$eqangle(m,a,m,n,p,a,p,m)

#step 13:
know:
    forall _c, _d, _m, _p, _a, _b, _n point:
        $coll(_c, _d, _m)
        $coll(_c, _d, _p)
        $eqangle(_a, _b, _a, _m, _n, _a, _n, _m)
        $para(_a, _b, _d, _m)
        =>:
            $eqangle(_m, _a, _m, _p, _n, _a, _n, _m)
    $coll(c,d,m)
    $coll(c,d,p)
    $eqangle(a,b,a,m,n,a,n,m)
    $para(a,b,d,m)
# AMP = MNA
$eqangle(m,a,m,p,n,a,n,m)

#step 14:
know:
    forall _a, _m, _n, _p point:
        $eqangle(_m, _a, _m, _n, _p, _a, _p, _m)
        $eqangle(_m, _a, _m, _p, _n, _a, _n, _m)
        =>:
            $eqratio(_a, _m, _a, _p, _a, _n, _a, _m)
    $eqangle(m,a,m,n,p,a,p,m)
    $eqangle(m,a,m,p,n,a,n,m)
# AM/AP = AN/AM ratio
$eqratio(a,m,a,p,a,n,a,m)

#step 15:
know:
    forall _a, _e, _m, _n, _p point:
        $cong(_a, _e, _a, _m)
        $eqratio(_a, _m, _a, _p, _a, _n, _a, _m)
        =>:
            $eqratio(_a, _e, _a, _p, _a, _n, _a, _e)
    $cong(a,e,a,m)
    $eqratio(a,m,a,p,a,n,a,m)
# AE/AP = AN/AE ratio
$eqratio(a,e,a,p,a,n,a,e)

#step 16:
know:
    forall _a, _e, _n, _p point:
        $coll(_a, _n, _p)
        =>:
            $eqangle(_a, _e, _a, _n, _a, _e, _a, _p)
    $coll(a,n,p)
# EAN = EAP
$eqangle(a,e,a,n,a,e,a,p)

#step 17:
know:
    forall _a, _e, _n, _p point:
        $eqangle(_a, _e, _a, _n, _a, _e, _a, _p)
        $eqratio(_a, _e, _a, _p, _a, _n, _a, _e)
        =>:
            $eqangle(_e, _a, _e, _n, _p, _e, _p, _a)
    $eqangle(a,e,a,n,a,e,a,p)
    $eqratio(a,e,a,p,a,n,a,e)
# AEN = EPA
$eqangle(e,a,e,n,p,e,p,a)

#step 18:
know:
    forall _a, _g1, _c, _m, _n point:
        $cong(_a, _g1, _c, _g1)
        $cong(_a, _g1, _g1, _m)
        $cong(_a, _g1, _g1, _n)
        =>:
            $cyclic(_a, _c, _m, _n)
    $cong(a,g1,c,g1)
    $cong(a,g1,g1,m)
    $cong(a,g1,g1,n)
# A,C,M,N are cyclic
$cyclic(a,c,m,n)

#step 19:
know:
    forall _a, _c, _m, _n point:
        $cyclic(_a, _c, _m, _n)
        =>:
            $eqangle(_a, _c, _a, _n, _m, _c, _m, _n)
    $cyclic(a,c,m,n)
# CAN = CMN
$eqangle(a,c,a,n,m,c,m,n)

#step 20:
know:
    forall _b, _g2, _d, _m, _n point:
        $cong(_b, _g2, _d, _g2)
        $cong(_b, _g2, _g2, _m)
        $cong(_b, _g2, _g2, _n)
        =>:
            $cyclic(_b, _d, _m, _n)
    $cong(b,g2,d,g2)
    $cong(b,g2,g2,m)
    $cong(b,g2,g2,n)
# B,D,M,N are cyclic
$cyclic(b,d,m,n)

#step 21:
know:
    forall _b, _d, _m, _n point:
        $cyclic(_b, _d, _m, _n)
        =>:
            $eqangle(_b, _d, _b, _n, _m, _d, _m, _n)
    $cyclic(b,d,m,n)
# DBN = DMN
$eqangle(b,d,b,n,m,d,m,n)

#step 22:
know:
    forall _a, _c, _e, _b, _d, _m, _n point:
        $coll(_a, _c, _e)
        $coll(_b, _d, _e)
        $eqangle(_a, _c, _a, _n, _m, _c, _m, _n)
        $eqangle(_b, _d, _b, _n, _m, _d, _m, _n)
        $para(_a, _b, _c, _m)
        $para(_a, _b, _d, _m)
        =>:
            $eqangle(_a, _e, _a, _n, _b, _e, _b, _n)
    $coll(a,c,e)
    $coll(b,d,e)
    $eqangle(a,c,a,n,m,c,m,n)
    $eqangle(b,d,b,n,m,d,m,n)
    $para(a,b,c,m)
    $para(a,b,d,m)
# EAN = EBN
$eqangle(a,e,a,n,b,e,b,n)

#step 23:
know:
    forall _a, _b, _e, _n point:
        $eqangle(_a, _e, _a, _n, _b, _e, _b, _n)
        =>:
            $cyclic(_a, _b, _e, _n)
    $eqangle(a,e,a,n,b,e,b,n)
# A,B,E,N are cyclic
$cyclic(a,b,e,n)

#step 24:
know:
    forall _a, _b, _e, _n point:
        $cyclic(_a, _b, _e, _n)
        =>:
            $eqangle(_a, _b, _a, _e, _n, _b, _n, _e)
            $eqangle(_a, _b, _a, _n, _e, _b, _e, _n)
    $cyclic(a,b,e,n)
# BAE = BNE
$eqangle(a,b,a,e,n,b,n,e)
# BAN = BEN
$eqangle(a,b,a,n,e,b,e,n)

#step 25:
know:
    forall _b, _g2, _d, _n point:
        $cong(_b, _g2, _d, _g2)
        $cong(_b, _g2, _g2, _n)
        =>:
            $is_circumcenter(_g2, _b, _d, _n)
    $cong(b,g2,d,g2)
    $cong(b,g2,g2,n)
# G2 is the circumcenter of BDN
$is_circumcenter(g2, b, d, n)

#step 26:
know:
    forall _a, _b, _g2, _d, _n point:
        $is_circumcenter(_g2, _b, _d, _n)
        $perp(_a, _b, _b, _g2)
        =>:
            $eqangle(_b, _a, _b, _d, _n, _b, _n, _d)
    $is_circumcenter(g2, b, d, n)
    $perp(a,b,b,g2)
# ABD = BND
$eqangle(b,a,b,d,n,b,n,d)

#step 27:
know:
    forall _c, _d, _m, _q, _b, _a, _n point:
        $coll(_c, _d, _m)
        $coll(_c, _d, _q)
        $eqangle(_b, _d, _b, _a, _n, _b, _n, _d)
        $para(_a, _b, _d, _m)
        =>:
            $eqangle(_d, _b, _d, _q, _n, _d, _n, _b)
    $coll(c,d,m)
    $coll(c,d,q)
    $eqangle(b,d,b,a,n,b,n,d)
    $para(a,b,d,m)
# BDQ = DNB
$eqangle(d,b,d,q,n,d,n,b)

#step 28:
know:
    forall _b, _n, _q, _d point:
        $coll(_b, _n, _q)
        =>:
            $eqangle(_b, _d, _b, _n, _b, _d, _b, _q)
    $coll(b,n,q)
# DBN = DBQ
$eqangle(b,d,b,n,b,d,b,q)

#step 29:
know:
    forall _b, _d, _n, _q point:
        $eqangle(_b, _d, _b, _n, _b, _d, _b, _q)
        $eqangle(_d, _b, _d, _q, _n, _d, _n, _b)
        =>:
            $eqratio(_b, _d, _b, _q, _b, _n, _b, _d)
    $eqangle(b,d,b,n,b,d,b,q)
    $eqangle(d,b,d,q,n,d,n,b)
# BD/BQ = BN/BD
$eqratio(b,d,b,q,b,n,b,d)

#step 30:
know:
    forall _b, _g2, _m, _n point:
        $cong(_b, _g2, _g2, _m)
        $cong(_b, _g2, _g2, _n)
        =>:
            $is_circumcenter(_g2, _b, _m, _n)
    $cong(b,g2,g2,m)
    $cong(b,g2,g2,n)
# G2 is the circumcenter of BMN
$is_circumcenter(g2, b, m, n)

#step 31:
know:
    forall _a, _b, _g2, _m, _n point:
        $is_circumcenter(_g2, _b, _m, _n)
        $perp(_a, _b, _b, _g2)
        =>:
            $eqangle(_b, _a, _b, _m, _n, _b, _n, _m)
    $is_circumcenter(g2, b, m, n)
    $perp(a,b,b,g2)
# ABM = BNM
$eqangle(b,a,b,m,n,b,n,m)

#step 32:
know:
    forall _b, _a, _m, _n, _d point:
        $eqangle(_b, _a, _b, _m, _n, _b, _n, _m)
        $para(_a, _b, _d, _m)
        =>:
            $eqangle(_n, _b, _n, _m, _m, _d, _m, _b)
    $eqangle(b,a,b,m,n,b,n,m)
    $para(a,b,d,m)
# BNM = DMB
$eqangle(n,b,n,m,m,d,m,b)

#step 33:
know:
    forall _b, _d, _m, _n point:
        $cyclic(_b, _d, _m, _n)
        $eqangle(_n, _b, _n, _m, _m, _d, _m, _b)
        =>:
            $cong(_b, _d, _b, _m)
    $cyclic(b,d,m,n)
    $eqangle(n,b,n,m,m,d,m,b)
# BD = BM
$cong(b,d,b,m)

#step 34:
know:
    forall _b, _d, _m, _n, _q point:
        $cong(_b, _d, _b, _m)
        $eqratio(_b, _d, _b, _q, _b, _n, _b, _d)
        =>:
            $cong(_b, _q, _b, _n)
    $cong(b,d,b,m)
    $eqratio(b,d,b,q,b,n,b,d)
# BQ = BN
$cong(b,q,b,n)

#step 35:
know:
    forall _b, _e, _n, _q point:
        $coll(_b, _n, _q)
        =>:
            $eqangle(_b, _e, _b, _n, _b, _e, _b, _q)
    $coll(b,n,q)
# EBN = EBQ
$eqangle(b,e,b,n,b,e,b,q)

#step 36:
know:
    forall _b, _e, _n, _q point:
        $eqangle(_b, _e, _b, _n, _b, _e, _b, _q)
        $eqratio(_b, _e, _b, _q, _b, _n, _b, _e)
        =>:
            $eqangle(_e, _b, _e, _n, _q, _e, _q, _b)
    $eqangle(b,e,b,n,b,e,b,q)
    $eqratio(b,e,b,q,b,n,b,e)
# BEN = EQB
$eqangle(e,b,e,n,q,e,q,b)

#step 37:
know:
    forall _a, _n, _p, _b, _e, _d, _m point:
        $coll(_a, _n, _p)
        $eqangle(_a, _b, _a, _e, _n, _b, _n, _e)
        $eqangle(_e, _a, _e, _n, _p, _e, _p, _a)
        $para(_a, _b, _d, _m)
        =>:
            $eqangle(_b, _n, _d, _m, _p, _n, _p, _e)
    $coll(a,n,p)
    $eqangle(a,b,a,e,n,b,n,e)
    $eqangle(e,a,e,n,p,e,p,a)
    $para(a,b,d,m)
# (BN,DM) = NPE
$eqangle(b,n,d,m,p,n,p,e)

#step 38:
know:
    forall _a, _n, _p, _b, _q, _e, _d, _m point:
        $coll(_a, _n, _p)
        $coll(_b, _n, _q)
        $eqangle(_a, _b, _a, _n, _e, _b, _e, _n)
        $eqangle(_e, _b, _e, _n, _q, _e, _q, _b)
        $para(_a, _b, _d, _m)
        =>:
            $eqangle(_b, _n, _e, _q, _n, _p, _d, _m)
    $coll(a,n,p)
    $coll(b,n,q)
    $eqangle(a,b,a,n,e,b,e,n)
    $eqangle(e,b,e,n,q,e,q,b)
    $para(a,b,d,m)
# (BN,EQ) = (NP,DM)
$eqangle(b,n,e,q,n,p,d,m)

#step 39:
know:
    forall _b, _n, _d, _m, _p, _e, _q point:
        $eqangle(_b, _n, _d, _m, _p, _n, _p, _e)
        $eqangle(_b, _n, _e, _q, _n, _p, _d, _m)
        =>:
            $eqangle(_d, _m, _e, _q, _e, _p, _d, _m)
    $eqangle(b,n,d,m,p,n,p,e)
    $eqangle(b,n,e,q,n,p,d,m)
# (DM,EQ) = (EP,DM)
$eqangle(d,m,e,q,e,p,d,m)

#step 40:
know:
    forall _c, _d, _m, _p, _q, _e point:
        $coll(_c, _d, _m)
        $coll(_c, _d, _p)
        $coll(_c, _d, _q)
        $eqangle(_d, _m, _e, _q, _e, _p, _d, _m)
        =>:
            $eqangle(_p, _e, _p, _q, _q, _p, _q, _e)
    $coll(c,d,m)
    $coll(c,d,p)
    $coll(c,d,q)
    $eqangle(d,m,e,q,e,p,d,m)
# EPQ = PQE
$eqangle(p,e,p,q,q,p,q,e)

#step 41:
know:
    forall _p, _e, _q point:
        $eqangle(_p, _e, _p, _q, _q, _p, _q, _e)
        =>:
            $cong(_e, _p, _e, _q)
    $eqangle(p,e,p,q,q,p,q,e)
# EP = EQ
$cong(e,p,e,q)

