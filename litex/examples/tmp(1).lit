triangle a b c

 =
a : ; b : ; c :
triangle
"""
# 三角形：三点 a、b、c 不共线
# Triangle: points a, b, c are non-collinear
prop triangle(a, b, c point):
    $ncoll(a, b, c)

"""
triangle12 a b c
