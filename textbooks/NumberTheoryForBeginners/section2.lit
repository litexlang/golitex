# Number Theory for Beginners, Section II.
#
# source: Weil and Rosenlicht, Number Theory for Beginners, Section II.
# problem: Formalize Euclidean division, the subgroup theorem for Z, gcd via
# linear combinations, and the Section II exercises.
# proof_idea: Reuse Section I's divisibility vocabulary.  State the Euclidean
# division lemma and the subgroup theorem as source-facing interfaces, then
# define binary gcd through divisibility plus Bezout.  Elementary consequences
# of the gcd definition are checked directly.
# litex_code: This file runs Section I first and then adds Section II.
# comments: Broad theorem packages are explicit `proof_debt` debt with source
# handling comments; no std number-theory modules are imported.

trust local import section1

"""
Lemma. For integers d,a with d>0 there is a unique quotient and remainder:
a = dq + r with 0 <= r < d.  Equivalently, dq is the largest multiple of d
not exceeding a.
"""

prop euclidean_division_Z(a, d, q, r Z):
    d > 0
    a = d * q + r
    0 <= r < d

prop is_largest_multiple_leq_Z(a, d, q Z):
    d > 0
    d * q <= a
    forall z Z:
        d * z <= a
        =>:
            d * z <= d * q

prop has_unique_euclidean_division_Z(a Z, d N_pos):
    exist q, r Z st {$euclidean_division_Z(a, d, q, r)}
    forall q, r, q1, r1 Z:
        $euclidean_division_Z(a, d, q, r)
        $euclidean_division_Z(a, d, q1, r1)
        =>:
            q = q1
            r = r1

# The verifier's integer remainder gives the source quotient-remainder
# construction directly: a - (a % d) is a multiple of d.
thm euclidean_division_exists:
    ? forall a Z, d N_pos:
        exist q, r Z st {$euclidean_division_Z(a, d, q, r)}
    (a - a % d) % d = 0
    obtain q from exist q Z st {a - a % d = d * q}
    witness exist q1, r Z st {$euclidean_division_Z(a, d, q1, r)} from q, a % d:
        d > 0
        a = (a - a % d) + a % d = d * q + a % d
        0 <= a % d < d
        $euclidean_division_Z(a, d, q, a % d)

thm euclidean_division_remainder_is_mod:
    ? forall a Z, d N_pos, q, r Z:
        $euclidean_division_Z(a, d, q, r)
        =>:
            a % d = r
    d > 0
    a = d * q + r
    0 <= r < d
    have rN N = r
    rN = r
    rN < d
    a = d * q + rN
    witness exist z Z st {a = d * z + rN} from q:
        a = d * q + rN
    a % d = rN
    a % d = r

thm euclidean_division_unique:
    ? forall a Z, d N_pos, q, r, q1, r1 Z:
        $euclidean_division_Z(a, d, q, r)
        $euclidean_division_Z(a, d, q1, r1)
        =>:
            q = q1
            r = r1
    by thm euclidean_division_remainder_is_mod(a, d, q, r)
    by thm euclidean_division_remainder_is_mod(a, d, q1, r1)
    r = a % d = r1
    r = r1
    a = d * q + r
    a = d * q1 + r1
    d * q + r = d * q1 + r
    d * q = (d * q + r) - r = (d * q1 + r) - r = d * q1
    q = d * q / d = d * q1 / d = q1

thm lemma_II_euclidean_division:
    ? forall a Z, d N_pos:
        $has_unique_euclidean_division_Z(a, d)
    by thm euclidean_division_exists(a, d)
    claim:
        ? forall q, r, q1, r1 Z:
            $euclidean_division_Z(a, d, q, r)
            $euclidean_division_Z(a, d, q1, r1)
            =>:
                q = q1
                r = r1
        by thm euclidean_division_unique(a, d, q, r, q1, r1)
        q = q1
        r = r1
    $has_unique_euclidean_division_Z(a, d)

# The largest-multiple phrasing follows from the same remainder construction.
thm remainder_bounds_multiple:
    ? forall d N_pos, q, r, z Z:
        0 <= r < d
        d * z <= d * q + r
        =>:
            d * z <= d * q
    by contra:
        ? d * z <= d * q
        d * z > d * q
        d * z - d * q > 0
        d * z - d * q = d * (z - q)
        d * (z - q) > 0
        by contra:
            ? z - q > 0
            z - q <= 0
            d * (z - q) <= 0
            impossible d * (z - q) > 0
        z - q >= 1
        d * (z - q) >= d * 1
        d * z - d * q >= d * 1
        d * 1 = d
        d * z - d * q >= d
        d * z <= d * q + r
        d * z - d * q <= (d * q + r) - d * q = r
        d <= r
        impossible d <= r

thm largest_multiple_exists:
    ? forall a Z, d N_pos:
        exist q Z st {$is_largest_multiple_leq_Z(a, d, q)}
    by thm euclidean_division_exists(a, d)
    obtain q, r from exist q, r Z st {$euclidean_division_Z(a, d, q, r)}
    d > 0
    a = d * q + r
    0 <= r < d
    d * q <= d * q + r
    d * q <= a
    claim:
        ? forall z Z:
            d * z <= a
            =>:
                d * z <= d * q
        a = d * q + r
        d * z <= d * q + r
        by thm remainder_bounds_multiple(d, q, r, z)
    witness exist q1 Z st {$is_largest_multiple_leq_Z(a, d, q1)} from q:
        d > 0
        d * q <= a
        forall z Z:
            d * z <= a
            =>:
                d * z <= d * q
        $is_largest_multiple_leq_Z(a, d, q)

thm largest_multiple_unique:
    ? forall a Z, d N_pos, q1, q2 Z:
        $is_largest_multiple_leq_Z(a, d, q1)
        $is_largest_multiple_leq_Z(a, d, q2)
        =>:
            q1 = q2
    d * q1 <= a
    d * q2 <= a
    d * q1 <= d * q2
    d * q2 <= d * q1
    d * q1 = d * q2
    q1 = d * q1 / d = d * q2 / d = q2

thm lemma_II_largest_multiple:
    ? forall a Z, d N_pos:
        exist! q Z st {$is_largest_multiple_leq_Z(a, d, q)}
    by thm largest_multiple_exists(a, d)
    forall q1, q2 Z:
        $is_largest_multiple_leq_Z(a, d, q1)
        $is_largest_multiple_leq_Z(a, d, q2)
        =>:
            d * q1 <= a
            d * q2 <= a
            d * q1 <= d * q2
            d * q2 <= d * q1
            d * q1 = d * q2
            q1 = d * q1 / d = d * q2 / d = q2
    exist! q Z st {$is_largest_multiple_leq_Z(a, d, q)}

"""
Theorem II.1. A nonempty set of integers closed under subtraction is exactly
mZ for a unique m >= 0.
"""

# Subtraction closure is the only residual condition: `M power_set(Z)` already
# gives the integer carrier for M and for every x, y in M.
prop closed_under_subtraction(M power_set(Z)):
    forall x, y M:
        x - y $in M

# The notation mZ is a set-valued construction, not a relation between a set
# and an integer. Its members are exactly the integer multiples of m.
have fn mZ(m N) power_set(Z) = {x Z: $divides_Z(m, x)}

# Keep the historical relation exported for later sections, but make it only
# the equality to the actual mZ value instead of restating its membership law.
prop is_integer_multiple_set(M power_set(Z), m N):
    M = mZ(m)

# Source handling: The book proves closure under addition, all integer
# multiples, and then uses the least positive element.
# trust: The full checked proof still needs this subgroup argument together
# with the Euclidean division lemma above.
trust:
    forall M power_set(Z):
        $is_nonempty_set(M)
        $closed_under_subtraction(M)
        =>:
            exist! m N st {M = mZ(m)}

thm theorem_II_1_subgroups_of_Z:
    ? forall M power_set(Z):
        $is_nonempty_set(M)
        $closed_under_subtraction(M)
        =>:
            exist! m N st {M = mZ(m)}
    exist! m N st {M = mZ(m)}

"""
Corollary 1. The set of all integral linear combinations of finitely many
integers is mZ for a unique m >= 0.
"""

# A finite subset carrier records both the integer ambient set and finiteness.
template<S set>:
    have finite_subsets set = {A power_set(S): $is_finite_set(A)}

# An integer linear combination chooses one integer coefficient for every
# generator and sums the coefficient-generator products.
prop is_integer_linear_combination(A \finite_subsets<Z>, x Z):
    exist c fn(a A) Z st {x = finite_set_sum(A, fn(a A) Z {c(a) * a})}

# The corollary's "set of all integral linear combinations" is a reusable
# set-valued function, so later statements can write integer_linear_span(A).
have fn integer_linear_span(A \finite_subsets<Z>) power_set(Z) = {x Z: $is_integer_linear_combination(A, x)}

# Source handling: zero coefficients make the span nonempty, and subtracting
# coefficient functions gives subtraction closure. The corollary then applies
# Theorem II.1 to this explicit span.
# trust: The remaining debt is the finite-sum coefficient proof of those two
# subgroup facts; the application of Theorem II.1 below is checked.
trust:
    forall A \finite_subsets<Z>:
        $is_nonempty_set(integer_linear_span(A))
        $closed_under_subtraction(integer_linear_span(A))

thm corollary_II_1_integer_linear_span_is_mZ:
    ? forall A \finite_subsets<Z>:
        exist! m N st {integer_linear_span(A) = mZ(m)}
    $is_nonempty_set(integer_linear_span(A))
    $closed_under_subtraction(integer_linear_span(A))
    by thm theorem_II_1_subgroups_of_Z(integer_linear_span(A))
    exist! m N st {integer_linear_span(A) = mZ(m)}

"""
Corollary 2 and Definition. The integer d from Corollary 1 divides each of the
given integers, every common divisor divides d, and d is called their gcd.
"""

# For later sections this file exposes the binary gcd.  The body records the
# divisor characterization and Bezout representation used in Sections III-IV.

prop is_gcd_Z(a, b Z, d N):
    $divides_Z(d, a)
    $divides_Z(d, b)
    forall e Z:
        e > 0
        $divides_Z(e, a)
        $divides_Z(e, b)
        =>:
            $divides_Z(e, d)
    exist x, y Z st {d = a * x + b * y}

# Source handling: The definition comes from Corollaries 1-2 and the statement
# that the gcd itself is a linear combination of the original integers.
# trust: The full proof reduces the finite linear-combination construction
# to the binary case and is not expanded in this chapter file.
trust:
    forall a, b Z:
        exist! d N st {$is_gcd_Z(a, b, d)}

have fn gcd_Z by exist!:
    ? forall a, b Z:
        exist! d N st {$is_gcd_Z(a, b, d)}

thm gcd_Z_dvd_left:
    ? forall a, b Z:
        $divides_Z(gcd_Z(a, b), a)
    $is_gcd_Z(a, b, gcd_Z(a, b))
    $divides_Z(gcd_Z(a, b), a)

thm gcd_Z_dvd_right:
    ? forall a, b Z:
        $divides_Z(gcd_Z(a, b), b)
    $is_gcd_Z(a, b, gcd_Z(a, b))
    $divides_Z(gcd_Z(a, b), b)

thm gcd_Z_bezout:
    ? forall a, b Z:
        exist x, y Z st {gcd_Z(a, b) = a * x + b * y}
    $is_gcd_Z(a, b, gcd_Z(a, b))
    exist x, y Z st {gcd_Z(a, b) = a * x + b * y}

