"""
Exercise II.3. A unimodular linear change of two integers preserves gcd.
"""

# The source's inverse-matrix argument gives mutual integer linear
# combinations between the old and new pairs.  Such changes preserve the two
# divisibility clauses and the Bezout clause of `is_gcd_Z`.
thm is_gcd_Z_preserved_by_mutual_integer_linear_changes:
    ? forall a, b, a1, b1 Z, d N, p, q, r, s, u, v, w, z Z:
        $is_gcd_Z(a, b, d)
        a1 = p * a + q * b
        b1 = r * a + s * b
        a = u * a1 + v * b1
        b = w * a1 + z * b1
        =>:
            $is_gcd_Z(a1, b1, d)
    $is_gcd_Z(a, b, d)
    $divides_Z(d, a)
    $divides_Z(d, b)
    obtain da from exist da Z st {a = d * da}
    obtain db from exist db Z st {b = d * db}
    witness exist da1 Z st {a1 = d * da1} from p * da + q * db:
        a1 = p * a + q * b = p * (d * da) + q * (d * db) = d * (p * da + q * db)
    $divides_Z(d, a1)
    witness exist db1 Z st {b1 = d * db1} from r * da + s * db:
        b1 = r * a + s * b = r * (d * da) + s * (d * db) = d * (r * da + s * db)
    $divides_Z(d, b1)
    claim:
        ? forall e Z:
            e > 0
            $divides_Z(e, a1)
            $divides_Z(e, b1)
            =>:
                $divides_Z(e, d)
        obtain ea1 from exist ea1 Z st {a1 = e * ea1}
        obtain eb1 from exist eb1 Z st {b1 = e * eb1}
        witness exist ea Z st {a = e * ea} from u * ea1 + v * eb1:
            a = u * a1 + v * b1 = u * (e * ea1) + v * (e * eb1) = e * (u * ea1 + v * eb1)
        $divides_Z(e, a)
        witness exist eb Z st {b = e * eb} from w * ea1 + z * eb1:
            b = w * a1 + z * b1 = w * (e * ea1) + z * (e * eb1) = e * (w * ea1 + z * eb1)
        $divides_Z(e, b)
        $divides_Z(e, d)
    obtain x, y from exist x, y Z st {d = a * x + b * y}
    witness exist x1, y1 Z st {d = a1 * x1 + b1 * y1} from u * x + w * y, v * x + z * y:
        d = a * x + b * y = (u * a1 + v * b1) * x + (w * a1 + z * b1) * y = a1 * (u * x + w * y) + b1 * (v * x + z * y)
    $is_gcd_Z(a1, b1, d)

thm exercise_II_3_unimodular_change_preserves_gcd:
    ? forall p, q, r, s, a, b, a1, b1 Z:
        p * s - q * r = 1 or p * s - q * r = -1
        a1 = p * a + q * b
        b1 = r * a + s * b
        =>:
            gcd_Z(a, b) = gcd_Z(a1, b1)
    $is_gcd_Z(a, b, gcd_Z(a, b))
    by cases:
        ? gcd_Z(a, b) = gcd_Z(a1, b1)
        case p * s - q * r = 1:
            s * a1 - q * b1 = s * (p * a + q * b) - q * (r * a + s * b) = (p * s - q * r) * a = 1 * a = a
            a = s * a1 - q * b1
            (-r) * a1 + p * b1 = (-r) * (p * a + q * b) + p * (r * a + s * b) = (p * s - q * r) * b = 1 * b = b
            b = (-r) * a1 + p * b1
            by thm is_gcd_Z_preserved_by_mutual_integer_linear_changes(a, b, a1, b1, gcd_Z(a, b), p, q, r, s, s, -q, -r, p)
            $is_gcd_Z(a1, b1, gcd_Z(a, b))
            gcd_Z(a1, b1) = gcd_Z(a, b)
            gcd_Z(a, b) = gcd_Z(a1, b1)
        case p * s - q * r = -1:
            (-s) * a1 + q * b1 = (-s) * (p * a + q * b) + q * (r * a + s * b) = -(p * s - q * r) * a = -(-1) * a = a
            a = (-s) * a1 + q * b1
            r * a1 - p * b1 = r * (p * a + q * b) - p * (r * a + s * b) = -(p * s - q * r) * b = -(-1) * b = b
            b = r * a1 - p * b1
            by thm is_gcd_Z_preserved_by_mutual_integer_linear_changes(a, b, a1, b1, gcd_Z(a, b), p, q, r, s, -s, q, r, -p)
            $is_gcd_Z(a1, b1, gcd_Z(a, b))
            gcd_Z(a1, b1) = gcd_Z(a, b)
            gcd_Z(a, b) = gcd_Z(a1, b1)

