"""
Exercise II.6. Compute gcds and Bezout coefficients for (56,35), (309,186),
and (1024,729).
"""

# Euclidean back-substitution gives 7=2*56-3*35, 3=-3*309+5*186, and
# 1=-257*1024+361*729.  The same identities show that every common positive
# divisor divides the displayed result.
thm common_divisor_of_fifty_six_and_thirty_five_divides_seven:
    ? forall e Z:
        e > 0
        $divides_Z(e, 56)
        $divides_Z(e, 35)
        =>:
            $divides_Z(e, 7)
    by thm divides_Z_linear_combination(e, 56, 35, 2, -3)
    2 * 56 + (-3) * 35 = 7
    $divides_Z(e, 7)

claim:
    ? $is_gcd_Z(56, 35, 7)
    witness exist x Z st {56 = 7 * x} from 8
    $divides_Z(7, 56)
    witness exist x Z st {35 = 7 * x} from 5
    $divides_Z(7, 35)
    witness exist x, y Z st {7 = 56 * x + 35 * y} from 2, -3
    $is_gcd_Z(56, 35, 7)

thm common_divisor_of_three_hundred_nine_and_one_hundred_eighty_six_divides_three:
    ? forall e Z:
        e > 0
        $divides_Z(e, 309)
        $divides_Z(e, 186)
        =>:
            $divides_Z(e, 3)
    by thm divides_Z_linear_combination(e, 309, 186, -3, 5)
    (-3) * 309 + 5 * 186 = 3
    $divides_Z(e, 3)

claim:
    ? $is_gcd_Z(309, 186, 3)
    witness exist x Z st {309 = 3 * x} from 103
    $divides_Z(3, 309)
    witness exist x Z st {186 = 3 * x} from 62
    $divides_Z(3, 186)
    witness exist x, y Z st {3 = 309 * x + 186 * y} from -3, 5
    $is_gcd_Z(309, 186, 3)

thm common_divisor_of_one_thousand_twenty_four_and_seven_hundred_twenty_nine_divides_one:
    ? forall e Z:
        e > 0
        $divides_Z(e, 1024)
        $divides_Z(e, 729)
        =>:
            $divides_Z(e, 1)
    by thm divides_Z_linear_combination(e, 1024, 729, -257, 361)
    (-257) * 1024 + 361 * 729 = 1
    $divides_Z(e, 1)

claim:
    ? $is_gcd_Z(1024, 729, 1)
    witness exist x Z st {1024 = 1 * x} from 1024
    $divides_Z(1, 1024)
    witness exist x Z st {729 = 1 * x} from 729
    $divides_Z(1, 729)
    witness exist x, y Z st {1 = 1024 * x + 729 * y} from -257, 361
    $is_gcd_Z(1024, 729, 1)

gcd_Z(56, 35) = 7
witness exist x, y Z st {7 = 56 * x + 35 * y} from 2, -3
gcd_Z(309, 186) = 3
witness exist x, y Z st {3 = 309 * x + 186 * y} from -3, 5
gcd_Z(1024, 729) = 1
witness exist x, y Z st {1 = 1024 * x + 729 * y} from -257, 361

"""
Exercise II.7. Scaling all inputs by m scales the gcd by m.
"""

# Scale the two divisor witnesses and the Bezout identity.  Conversely, a
# common divisor of `m*a` and `m*b` divides the scaled Bezout combination.
thm exercise_II_7_scaling_gcd:
    ? forall a, b Z, m N_pos:
        gcd_Z(m * a, m * b) = m * gcd_Z(a, b)
    $is_gcd_Z(a, b, gcd_Z(a, b))
    by thm gcd_Z_dvd_left(a, b)
    obtain u from exist u Z st {a = gcd_Z(a, b) * u}
    by thm gcd_Z_dvd_right(a, b)
    obtain v from exist v Z st {b = gcd_Z(a, b) * v}
    witness exist u1 Z st {m * a = (m * gcd_Z(a, b)) * u1} from u:
        m * a = m * (gcd_Z(a, b) * u) = (m * gcd_Z(a, b)) * u
    $divides_Z(m * gcd_Z(a, b), m * a)
    witness exist v1 Z st {m * b = (m * gcd_Z(a, b)) * v1} from v:
        m * b = m * (gcd_Z(a, b) * v) = (m * gcd_Z(a, b)) * v
    $divides_Z(m * gcd_Z(a, b), m * b)
    claim:
        ? forall e Z:
            e > 0
            $divides_Z(e, m * a)
            $divides_Z(e, m * b)
            =>:
                $divides_Z(e, m * gcd_Z(a, b))
        obtain r from exist r Z st {m * a = e * r}
        obtain s from exist s Z st {m * b = e * s}
        by thm gcd_Z_bezout(a, b)
        obtain x, y from exist x, y Z st {gcd_Z(a, b) = a * x + b * y}
        witness exist t Z st {m * gcd_Z(a, b) = e * t} from r * x + s * y:
            m * gcd_Z(a, b) = m * (a * x + b * y) = (m * a) * x + (m * b) * y = (e * r) * x + (e * s) * y = e * (r * x + s * y)
        $divides_Z(e, m * gcd_Z(a, b))
    by thm gcd_Z_bezout(a, b)
    obtain x, y from exist x, y Z st {gcd_Z(a, b) = a * x + b * y}
    witness exist u1, v1 Z st {m * gcd_Z(a, b) = (m * a) * u1 + (m * b) * v1} from x, y:
        m * gcd_Z(a, b) = m * (a * x + b * y) = (m * a) * x + (m * b) * y
    $is_gcd_Z(m * a, m * b, m * gcd_Z(a, b))
    gcd_Z(m * a, m * b) = m * gcd_Z(a, b)

"""
Exercise II.8. Every rational number has a unique reduced integer numerator
and positive denominator.
"""

sketch:
    # Exercise retained as source text; exercises are outside this theorem-only
    # translation scope.
