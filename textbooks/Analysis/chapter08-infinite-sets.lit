            not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, z, E5)
        by cases:
            ? not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, z, E5)
            case z = E12:
                by thm example_8_5_6_not_subset_gives_not_less(E12, E5)
            case z = E2:
                by thm example_8_5_6_not_subset_gives_not_less(E2, E5)
            case z = E23:
