# Chapter 8: Infinite sets.

local import chap3
trust local import chap7
local import chap8finiteproduct

prop embeds_into(S, T set):
    exist f fn(x S) T st {$is_injective_fn(S, T, f)}

# 8.1 Countability

"""
Definition 8.1.1 (Countable sets). A set is countably infinite when it has the
same cardinality as the natural numbers.  It is at most countable when it is
finite or countably infinite.  It is uncountable when it is infinite but not
countably infinite.
"""

prop is_countably_infinite(X set):
    $has_equal_cardinality(N, X)

prop is_at_most_countable(X set):
    $embeds_into(X, N)

prop is_uncountable(X set):
    $has_infinite_cardinality(X)
    not $is_countably_infinite(X)

thm countably_infinite_is_at_most_countable:
    ? forall X set:
        $is_countably_infinite(X)
        =>:
            $is_at_most_countable(X)
    obtain f from exist f fn(x N) X st {$is_bijective_fn(N, X, f)}
    # A bijection `f : N -> X` has one preimage for every `x in X`.  Define
    # the encoding locally from that unique preimage; keeping this construction
    # local avoids instantiating the Chapter 3 inverse-function template.
    have fn encode_X by exist!:
        ? forall x X:
            exist! n N st {x = f(n)}
        $is_injective_fn(N, X, f)
        $is_surjective_fn(N, X, f)
        obtain n from exist n N st {x = f(n)}
        x = f(n)
        forall n1, n2 N:
            x = f(n1)
            x = f(n2)
            =>:
                f(n1) = x
                f(n2) = x
                f(n1) = f(n2)
                n1 = n2
        exist! n N st {x = f(n)}
    claim:
        ? $is_injective_fn(X, N, encode_X)
        forall x1, x2 X:
            encode_X(x1) = encode_X(x2)
            =>:
                x1 = f(encode_X(x1)) = f(encode_X(x2)) = x2
    witness exist g fn(x X) N st {$is_injective_fn(X, N, g)} from encode_X

thm finite_cardinality_gives_at_most_countable:
    ? forall X set:
        $has_finite_cardinality(X)
        =>:
            $is_at_most_countable(X)
    obtain n from exist n N st {$has_cardinality(X, n)}
    range(0, n) $subset N
    obtain f from exist f fn(x X) range(0, n) st {$is_bijective_fn(X, range(0, n), f)}
    have fn encode_X(x X) N = f(x)
    claim:
        ? $is_injective_fn(X, N, encode_X)
        forall x1, x2 X:
            encode_X(x1) = encode_X(x2)
            =>:
                f(x1) = encode_X(x1) = encode_X(x2) = f(x2)
                x1 = x2
    witness exist g fn(x X) N st {$is_injective_fn(X, N, g)} from encode_X

thm injection_into_at_most_countable_gives_at_most_countable:
    ? forall X, Y set, phi fn(x X) Y:
        $is_at_most_countable(Y)
        $is_injective_fn(X, Y, phi)
        =>:
            $is_at_most_countable(X)
    obtain g from exist g fn(x Y) N st {$is_injective_fn(Y, N, g)}
    have fn encode_X(x X) N = g(phi(x))
    claim:
        ? $is_injective_fn(X, N, encode_X)
        forall x1, x2 X:
            encode_X(x1) = encode_X(x2)
            =>:
                g(phi(x1)) = encode_X(x1) = encode_X(x2) = g(phi(x2))
                phi(x1) = phi(x2)
                x1 = x2
    witness exist f fn(x X) N st {$is_injective_fn(X, N, f)} from encode_X

thm infinite_at_most_countable_is_countably_infinite:
    ? forall X set:
        $has_infinite_cardinality(X)
        $is_at_most_countable(X)
        =>:
            $is_countably_infinite(X)
    trust $is_countably_infinite(X)

thm uncountable_is_not_at_most_countable:
    ? forall X set:
        $is_uncountable(X)
        =>:
            not $is_at_most_countable(X)
    by contra:
        ? not $is_at_most_countable(X)
        by thm infinite_at_most_countable_is_countably_infinite(X)
        impossible not $is_countably_infinite(X)

"""
Remark 8.1.2. Countably infinite sets are also called denumerable sets.
"""

"""
Examples 8.1.3. The natural numbers, the positive natural numbers, and the
even natural numbers are countably infinite.  The important point is that a
set is countable when it can be enumerated by a bijection from `N`.
"""

prop is_even_natural_number(n N):
    exist k N st {n = 2 * k}

have even_natural_numbers set = {n N: $is_even_natural_number(n)}
even_natural_numbers = {n N: $is_even_natural_number(n)}

have fn identity_on_N(x N) N = x

forall x N:
    identity_on_N(x) = x

claim:
    ? $is_countably_infinite(N)
    claim:
        ? $is_injective_fn(N, N, identity_on_N)
        forall x1, x2 N:
            identity_on_N(x1) = identity_on_N(x2)
            =>:
                x1 = identity_on_N(x1) = identity_on_N(x2) = x2
    claim:
        ? $is_surjective_fn(N, N, identity_on_N)
        claim:
            ? forall y N:
                exist x N st {y = identity_on_N(x)}
            identity_on_N(y) = y
            y = identity_on_N(y)
            witness exist x N st {y = identity_on_N(x)} from y
    witness exist f fn(x N) N st {$is_bijective_fn(N, N, f)} from identity_on_N

claim:
    ? $is_countably_infinite(N_pos)
    have fn succ_N(n N) N_pos = n + 1
    forall n N:
        succ_N(n) = n + 1
    claim:
        ? $is_injective_fn(N, N_pos, succ_N)
        forall x1, x2 N:
            succ_N(x1) = succ_N(x2)
            =>:
                x1 + 1 = succ_N(x1) = succ_N(x2) = x2 + 1
                x1 = (x1 + 1) - 1 = (x2 + 1) - 1 = x2
    claim:
        ? $is_surjective_fn(N, N_pos, succ_N)
        claim:
            ? forall y N_pos:
                exist x N st {y = succ_N(x)}
            y - 1 $in N
            succ_N(y - 1) = (y - 1) + 1 = y
            y = succ_N(y - 1)
            witness exist x N st {y = succ_N(x)} from y - 1
    witness exist f fn(x N) N_pos st {$is_bijective_fn(N, N_pos, f)} from succ_N

claim:
    ? $is_countably_infinite(even_natural_numbers)
    claim:
        ? forall n N:
            2 * n $in even_natural_numbers
        witness exist k N st {2 * n = 2 * k} from n
        2 * n $in {n N: $is_even_natural_number(n)}
    have fn double_to_even(n N) even_natural_numbers = 2 * n
    forall n N:
        double_to_even(n) = 2 * n
    claim:
        ? $is_injective_fn(N, even_natural_numbers, double_to_even)
        forall x1, x2 N:
            double_to_even(x1) = double_to_even(x2)
            =>:
                2 * x1 = double_to_even(x1) = double_to_even(x2) = 2 * x2
                x1 = (2 * x1) / 2 = (2 * x2) / 2 = x2
    claim:
        ? $is_surjective_fn(N, even_natural_numbers, double_to_even)
        claim:
            ? forall y even_natural_numbers:
                exist x N st {y = double_to_even(x)}
            y $in even_natural_numbers
            y $in {n N: $is_even_natural_number(n)}
            $is_even_natural_number(y)
            obtain k from exist k N st {y = 2 * k}
            double_to_even(k) = 2 * k
            y = double_to_even(k)
            witness exist x N st {y = double_to_even(x)} from k
    witness exist f fn(x N) even_natural_numbers st {$is_bijective_fn(N, even_natural_numbers, f)} from double_to_even

"""
Proposition 8.1.4 (Well ordering principle). Every non-empty subset of `N`
has a unique minimum element.
"""

# The well-ordering principle says a non-empty set of natural numbers has a
# first element; uniqueness follows by comparing two candidate minima in both
# directions.

prop is_minimum_of_natural_subset(X power_set(N), n N):
    n $in X
    forall m X:
        n <= m

thm natural_subset_has_unique_minimum:
    ? forall X power_set(N):
        $is_nonempty_set(X)
        =>:
            exist! n N st {$is_minimum_of_natural_subset(X, n)}
    # Every non-empty subset of `N` has a least member; uniqueness follows by
    # comparing two candidate minima.
    witness exist n N st {$is_minimum_of_natural_subset(X, n)} from min_of_N_set(X):
        min_of_N_set(X) $in X
        claim:
            ? forall m X:
                min_of_N_set(X) <= m
            min_of_N_set(X) <= m
        $is_minimum_of_natural_subset(X, min_of_N_set(X))
    claim:
        ? forall m, n N:
            $is_minimum_of_natural_subset(X, m)
            $is_minimum_of_natural_subset(X, n)
            =>:
                m = n
        m $in X
        n $in X
        forall z X:
            m <= z
        forall z X:
            n <= z
        m <= n <= m
        m = n
    exist! n N st {$is_minimum_of_natural_subset(X, n)}

# Write `min(X)` for the unique least element of a non-empty subset `X` of `N`.

have fn min_of_N_subset by exist!:
    ? forall X power_set(N):
        $is_nonempty_set(X)
        =>:
            exist! n N st {$is_minimum_of_natural_subset(X, n)}
    by thm natural_subset_has_unique_minimum(X)

"""
Proposition 8.1.5. Every infinite subset of `N` has a unique increasing
bijection from `N`, and is therefore countably infinite.
"""

# The enumeration begins at `min(X)` and then repeatedly takes the least
# element of `X` strictly above the preceding value.

prop is_least_natural_element_above_in_subset(X power_set(N), a N, y N):
    y $in X
    a < y
    forall z X:
        a < z
        =>:
            y <= z

# The first Proposition 8.1.5 gap uses only the finite-cardinality fact for
# the empty set.  The empty function gives the bijection from `{}` to itself,
# and `range(0,0)` is the standard zero-element model.

thm empty_set_has_equal_cardinality_self:
    ? forall:
        $has_equal_cardinality({}, {})
    have fn empty_to_empty(x {}) {} = x
    claim:
        ? $is_injective_fn({}, {}, empty_to_empty)
        forall x1, x2 {}:
            empty_to_empty(x1) = empty_to_empty(x2)
            =>:
                x1 = x2
    claim:
        ? $is_surjective_fn({}, {}, empty_to_empty)
        claim:
            ? forall y {}:
                exist x {} st {y = empty_to_empty(x)}
            by contra:
                ? exist x {} st {y = empty_to_empty(x)}
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from y:
                    y $in {}
                impossible $is_nonempty_set({})
    witness exist f fn(x {}) {} st {$is_bijective_fn({}, {}, f)} from empty_to_empty

thm empty_set_has_cardinality_zero:
    ? forall:
        $has_cardinality({}, 0)
    by thm empty_set_has_equal_cardinality_self()
    range(0, 0) = {}

thm empty_set_has_finite_cardinality:
    ? forall:
        $has_finite_cardinality({})
    by thm empty_set_has_cardinality_zero()
    witness exist n N st {$has_cardinality({}, n)} from 0

# Chapter 3 defines cardinality with the zero-based model `range(0, n)`,
# while the finite-set enumeration from Chapter 7 uses `closed_range(1, n)`.
# Re-index the latter when the finite set is nonempty.

thm positive_count_finite_set_has_cardinality:
    ? forall s finite_set:
        finite_set_size(s) >= 1
        =>:
            $has_cardinality(s, finite_set_size(s))
    by thm finite_set_has_bijective_index(s)
    obtain idx from exist idx fn(i closed_range(1, finite_set_size(s))) s st {$is_bijection_from_index_range_to_finite_set(s, idx)}
    have fn shift_up by exist!:
        ? forall i range(0, finite_set_size(s)):
            exist! j closed_range(1, finite_set_size(s)) st {j = i + 1}
        i >= 0
        i < finite_set_size(s)
        i + 1 >= 1
        i + 1 <= finite_set_size(s)
        i + 1 $in closed_range(1, finite_set_size(s))
        witness exist j closed_range(1, finite_set_size(s)) st {j = i + 1} from i + 1:
            i + 1 = i + 1
        forall j1, j2 closed_range(1, finite_set_size(s)):
            j1 = i + 1
            j2 = i + 1
            =>:
                j1 = j2
        exist! j closed_range(1, finite_set_size(s)) st {j = i + 1}
    have fn zero_index_of_s by exist!:
        ? forall x s:
            exist! i range(0, finite_set_size(s)) st {idx(shift_up(i)) = x}
        exist! j closed_range(1, finite_set_size(s)) st {idx(j) = x}
        obtain j from exist j closed_range(1, finite_set_size(s)) st {idx(j) = x}
        j >= 1
        j <= finite_set_size(s)
        j - 1 >= 0
        j - 1 < j <= finite_set_size(s)
        j - 1 < finite_set_size(s)
        j - 1 $in range(0, finite_set_size(s))
        witness exist i range(0, finite_set_size(s)) st {idx(shift_up(i)) = x} from j - 1:
            shift_up(j - 1) = (j - 1) + 1
            (j - 1) + 1 = j
            idx(shift_up(j - 1)) = idx(j)
            idx(j) = x
            idx(shift_up(j - 1)) = x
        forall i1, i2 range(0, finite_set_size(s)):
            idx(shift_up(i1)) = x
            idx(shift_up(i2)) = x
            =>:
                shift_up(i1) = i1 + 1
                shift_up(i2) = i2 + 1
                exist! j closed_range(1, finite_set_size(s)) st {idx(j) = x}
                shift_up(i1) = shift_up(i2)
                i1 + 1 = i2 + 1
                i1 = (i1 + 1) - 1
                (i1 + 1) - 1 = (i2 + 1) - 1
                (i2 + 1) - 1 = i2
                i1 = i2
        exist! i range(0, finite_set_size(s)) st {idx(shift_up(i)) = x}
    claim:
        ? $is_injective_fn(s, range(0, finite_set_size(s)), zero_index_of_s)
        forall x1, x2 s:
            zero_index_of_s(x1) = zero_index_of_s(x2)
            =>:
                idx(shift_up(zero_index_of_s(x1))) = x1
                idx(shift_up(zero_index_of_s(x2))) = x2
                shift_up(zero_index_of_s(x1)) = shift_up(zero_index_of_s(x2))
                idx(shift_up(zero_index_of_s(x1))) = idx(shift_up(zero_index_of_s(x2)))
                x1 = x2
    claim:
        ? $is_surjective_fn(s, range(0, finite_set_size(s)), zero_index_of_s)
        claim:
            ? forall i range(0, finite_set_size(s)):
                exist x s st {i = zero_index_of_s(x)}
            have x s = idx(shift_up(i))
            idx(shift_up(zero_index_of_s(x))) = x
            idx(shift_up(i)) = x
            idx(shift_up(zero_index_of_s(x))) = idx(shift_up(i))
            exist! j closed_range(1, finite_set_size(s)) st {idx(j) = idx(shift_up(i))}
            shift_up(zero_index_of_s(x)) = shift_up(i)
            zero_index_of_s(x) = i
            i = zero_index_of_s(x)
            witness exist x0 s st {i = zero_index_of_s(x0)} from x:
                i = zero_index_of_s(x)
        $is_surjective_fn(s, range(0, finite_set_size(s)), zero_index_of_s)
    $is_bijective_fn(s, range(0, finite_set_size(s)), zero_index_of_s)
    witness exist f fn(x s) range(0, finite_set_size(s)) st {$is_bijective_fn(s, range(0, finite_set_size(s)), f)} from zero_index_of_s:
        $is_bijective_fn(s, range(0, finite_set_size(s)), zero_index_of_s)
    $has_equal_cardinality(s, range(0, finite_set_size(s)))
    $has_cardinality(s, finite_set_size(s))

thm finite_set_has_cardinality_count:
    ? forall s finite_set:
        $has_cardinality(s, finite_set_size(s))
    finite_set_size(s) = 0 or finite_set_size(s) > 0
    by cases:
        ? $has_cardinality(s, finite_set_size(s))
        case finite_set_size(s) = 0:
            s = {}
            by thm empty_set_has_cardinality_zero()
            $has_cardinality({}, 0)
            $has_cardinality(s, finite_set_size(s))
        case finite_set_size(s) > 0:
            finite_set_size(s) >= 1
            by thm positive_count_finite_set_has_cardinality(s)
            $has_cardinality(s, finite_set_size(s))

thm infinite_natural_subset_is_nonempty:
    ? forall X power_set(N):
        $has_infinite_cardinality(X)
        =>:
            $is_nonempty_set(X)
    by contra:
        ? $is_nonempty_set(X)
        X = {}
        by thm empty_set_has_finite_cardinality()
        impossible not $has_finite_cardinality(X)

thm infinite_natural_subset_has_tail_above:
    ? forall X power_set(N), a N:
        $has_infinite_cardinality(X)
        =>:
            $is_nonempty_set({x N: x $in X and a < x})
    by contra:
        ? $is_nonempty_set({x N: x $in X and a < x})
        claim:
            ? X $subset closed_range(0, a)
            claim:
                ? forall x X:
                    x $in closed_range(0, a)
                x $in N
                x <= a or x > a
                by cases:
                    ? x $in closed_range(0, a)
                    case x <= a:
                        x >= 0
                        x $in closed_range(0, a)
                    case x > a:
                        x $in {x N: x $in X and a < x}
                        witness $is_nonempty_set({x N: x $in X and a < x}) from x:
                            x $in {x N: x $in X and a < x}
                        impossible $is_nonempty_set({x N: x $in X and a < x})
            X $subset closed_range(0, a)
        $is_finite_set(closed_range(0, a))
        by thm subset_of_finite_set_is_finite(X, closed_range(0, a))
        $is_finite_set(X)
        by thm finite_set_has_cardinality_count(X)
        witness exist n N st {$has_cardinality(X, n)} from finite_set_size(X):
            $has_cardinality(X, finite_set_size(X))
        $has_finite_cardinality(X)
        impossible not $has_finite_cardinality(X)

thm least_natural_element_above_exists_unique:
    ? forall X power_set(N), a N:
        $is_nonempty_set({x N: x $in X and a < x})
        =>:
            exist! y N st {$is_least_natural_element_above_in_subset(X, a, y)}
    have T power_set(N) = {x N: x $in X and a < x}
    $is_minimum_of_natural_subset(T, min_of_N_subset(T))
    claim:
        ? forall z X:
            a < z
            =>:
                min_of_N_subset(T) <= z
        z $in N
        z $in {x N: x $in X and a < x}
    witness exist y N st {$is_least_natural_element_above_in_subset(X, a, y)} from min_of_N_subset(T)
    claim:
        ? forall y1, y2 N:
            $is_least_natural_element_above_in_subset(X, a, y1)
            $is_least_natural_element_above_in_subset(X, a, y2)
            =>:
                y1 = y2
        y1 <= y2 <= y1

have fn first_in_infinite_N_subset_value by exist!:
    ? forall X power_set(N):
        $has_infinite_cardinality(X)
        =>:
            exist! y N st {$is_minimum_of_natural_subset(X, y)}
    by thm infinite_natural_subset_is_nonempty(X)
    by thm natural_subset_has_unique_minimum(X)

have fn next_in_infinite_N_subset_value by exist!:
    ? forall X power_set(N), a N:
        $has_infinite_cardinality(X)
        =>:
            exist! y N st {$is_least_natural_element_above_in_subset(X, a, y)}
    by thm infinite_natural_subset_has_tail_above(X, a)
    by thm least_natural_element_above_exists_unique(X, a)

have fn increasing_N_subset_enum_value(X power_set(N), n N: $has_infinite_cardinality(X)) N by induc n from 0:
    case n = 0: first_in_infinite_N_subset_value(X)
    case n > 0: next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, n - 1))

thm increasing_enum_value_lies_in_subset:
    ? forall X power_set(N), n N:
        $has_infinite_cardinality(X)
        =>:
            increasing_N_subset_enum_value(X, n) $in X
    by cases:
        ? increasing_N_subset_enum_value(X, n) $in X
        case n = 0:
            increasing_N_subset_enum_value(X, n) = first_in_infinite_N_subset_value(X)
            $is_minimum_of_natural_subset(X, first_in_infinite_N_subset_value(X))
            first_in_infinite_N_subset_value(X) $in X
        case n > 0:
            increasing_N_subset_enum_value(X, n) = next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, n - 1))
            $is_least_natural_element_above_in_subset(X, increasing_N_subset_enum_value(X, n - 1), next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, n - 1)))
            next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, n - 1)) $in X

prop is_recursive_min_enumeration_from_N_to_subset(X power_set(N), f fn(n N) X):
    $has_infinite_cardinality(X)
    forall n N:
        f(n) = increasing_N_subset_enum_value(X, n)

thm infinite_subset_has_recursive_min_enumeration:
    ? forall X power_set(N):
        $has_infinite_cardinality(X)
        =>:
            exist f fn(n N) X st {$is_recursive_min_enumeration_from_N_to_subset(X, f)}
    forall n N:
        increasing_N_subset_enum_value(X, n) $in X
    have fn recursive_enum_to_subset(n N) X = increasing_N_subset_enum_value(X, n)
    forall n N:
        recursive_enum_to_subset(n) = increasing_N_subset_enum_value(X, n)
    witness exist f fn(n N) X st {$is_recursive_min_enumeration_from_N_to_subset(X, f)} from recursive_enum_to_subset

thm recursive_min_enumeration_step_is_increasing:
    ? forall X power_set(N), f fn(n N) X, n N:
        $has_infinite_cardinality(X)
        $is_recursive_min_enumeration_from_N_to_subset(X, f)
        =>:
            f(n + 1) > f(n)
    forall k N:
        f(k) = increasing_N_subset_enum_value(X, k)
    increasing_N_subset_enum_value(X, n + 1) = next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, (n + 1) - 1)) = next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, n))
    $is_least_natural_element_above_in_subset(X, increasing_N_subset_enum_value(X, n), next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, n)))
    f(n) = increasing_N_subset_enum_value(X, n) < next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, n)) = increasing_N_subset_enum_value(X, n + 1) = f(n + 1)

thm recursive_min_enumeration_strictly_increases_after_steps:
    ? forall X power_set(N), f fn(n N) X, n, k N:
        $has_infinite_cardinality(X)
        $is_recursive_min_enumeration_from_N_to_subset(X, f)
        =>:
            f(n) < f(n + k + 1)
    by induc k from 0:
        ? f(n) < f(n + k + 1)
        ? from k = 0:
            by thm recursive_min_enumeration_step_is_increasing(X, f, n)
            f(n) < f(n + 1)
            n + 0 + 1 = n + 1
            f(n + 0 + 1) = f(n + 1)
            f(n) < f(n + 1) = f(n + 0 + 1)
        ? induc:
            f(n) < f(n + k + 1)
            by thm recursive_min_enumeration_step_is_increasing(X, f, n + k + 1)
            f(n + k + 1) < f(n + k + 1 + 1)
            n + (k + 1) + 1 = n + k + 1 + 1
            f(n + (k + 1) + 1) = f(n + k + 1 + 1)
            f(n) < f(n + k + 1) < f(n + k + 1 + 1) = f(n + (k + 1) + 1)

thm recursive_min_enumeration_value_at_least_index:
    ? forall X power_set(N), f fn(n N) X, n N:
        $has_infinite_cardinality(X)
        $is_recursive_min_enumeration_from_N_to_subset(X, f)
        =>:
            f(n) >= n
    by induc n from 0:
        ? f(n) >= n
        ? from n = 0:
            f(0) $in N
            f(0) >= 0
        ? induc:
            f(n) >= n
            by thm recursive_min_enumeration_step_is_increasing(X, f, n)
            f(n + 1) > f(n)
            f(n) $in N
            f(n + 1) $in N
            f(n + 1) >= f(n) + 1
            f(n) + 1 >= n + 1
            f(n + 1) >= f(n) + 1 >= n + 1
            f(n + 1) >= n + 1

thm successor_strict_increase_has_strict_growth:
    ? forall X power_set(N), f fn(n N) X, n, k N:
        forall m N:
            f(m + 1) > f(m)
        =>:
            f(n) < f(n + k + 1)
    by induc k from 0:
        ? f(n) < f(n + k + 1)
        ? from k = 0:
            f(n + 1) > f(n)
            f(n) < f(n + 1)
            n + 0 + 1 = n + 1
            f(n + 0 + 1) = f(n + 1)
            f(n) < f(n + 1) = f(n + 0 + 1)
        ? induc:
            f(n) < f(n + k + 1)
            f(n + k + 1 + 1) > f(n + k + 1)
            f(n + k + 1) < f(n + k + 1 + 1)
            n + (k + 1) + 1 = n + k + 1 + 1
            f(n + (k + 1) + 1) = f(n + k + 1 + 1)
            f(n) < f(n + k + 1) < f(n + k + 1 + 1) = f(n + (k + 1) + 1)

prop is_increasing_bijection_from_N_to_subset(X power_set(N), f fn(n N) X):
    $is_bijective_fn(N, X, f)
    forall n N:
        f(n + 1) > f(n)

thm recursive_min_enumeration_is_surjective:
    ? forall X power_set(N), f fn(n N) X:
        $has_infinite_cardinality(X)
        $is_recursive_min_enumeration_from_N_to_subset(X, f)
        =>:
            $is_surjective_fn(N, X, f)
    claim:
        ? forall x X:
            exist n N st {x = f(n)}
        x $in N
        x + 1 $in N
        by thm recursive_min_enumeration_value_at_least_index(X, f, x + 1)
        f(x + 1) >= x + 1
        x + 1 > x
        f(x + 1) >= x + 1 > x
        f(x + 1) > x
        have K power_set(N) = {n N: f(n) > x}
        x + 1 $in {n N: f(n) > x}
        x + 1 $in K
        witness $is_nonempty_set(K) from x + 1:
            x + 1 $in K
        $is_minimum_of_natural_subset(K, min_of_N_set(K))
        have k N = min_of_N_set(K)
        k $in K
        f(k) > x
        claim:
            ? k > 0
            by contra:
                ? k > 0
                k <= 0
                k >= 0
                k = 0
                f(k) = f(0)
                f(0) > x
                f(0) = increasing_N_subset_enum_value(X, 0) = first_in_infinite_N_subset_value(X)
                $is_minimum_of_natural_subset(X, first_in_infinite_N_subset_value(X))
                first_in_infinite_N_subset_value(X) <= x
                f(0) <= x
                impossible f(0) > x
        k - 1 $in N
        k = (k - 1) + 1
        k - 1 < k
        claim:
            ? f(k - 1) <= x
            f(k - 1) <= x or f(k - 1) > x
            by cases:
                ? f(k - 1) <= x
                case f(k - 1) <= x:
                    f(k - 1) <= x
                case f(k - 1) > x:
                    k - 1 $in {n N: f(n) > x}
                    k - 1 $in K
                    min_of_N_set(K) <= k - 1
                    k = min_of_N_set(K)
                    k <= k - 1
                    impossible k <= k - 1
        f(k - 1) < x or f(k - 1) >= x
        by cases:
            ? exist n N st {x = f(n)}
            case f(k - 1) < x:
                forall t N:
                    f(t) = increasing_N_subset_enum_value(X, t)
                f(k - 1) = increasing_N_subset_enum_value(X, k - 1)
                f(k) = f((k - 1) + 1) = increasing_N_subset_enum_value(X, (k - 1) + 1)
                increasing_N_subset_enum_value(X, (k - 1) + 1) = next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, ((k - 1) + 1) - 1))
                ((k - 1) + 1) - 1 = k - 1
                increasing_N_subset_enum_value(X, ((k - 1) + 1) - 1) = increasing_N_subset_enum_value(X, k - 1)
                f(k) = next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, k - 1))
                $is_least_natural_element_above_in_subset(X, increasing_N_subset_enum_value(X, k - 1), next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, k - 1)))
                $is_least_natural_element_above_in_subset(X, f(k - 1), f(k))
                f(k) <= x
                impossible f(k) > x
            case f(k - 1) >= x:
                f(k - 1) = x
                x = f(k - 1)
                witness exist n N st {x = f(n)} from k - 1:
                    x = f(k - 1)
    $is_surjective_fn(N, X, f)

thm recursive_min_enumeration_is_bijective:
    ? forall X power_set(N), f fn(n N) X:
        $has_infinite_cardinality(X)
        $is_recursive_min_enumeration_from_N_to_subset(X, f)
        =>:
            $is_bijective_fn(N, X, f)
    claim:
        ? $is_injective_fn(N, X, f)
        claim:
            ? forall n1, n2 N:
                f(n1) = f(n2)
                =>:
                    n1 = n2
            n1 < n2 or n1 >= n2
            by cases:
                ? n1 = n2
                case n1 < n2:
                    n1 <= n2
                    n2 - n1 >= 1
                    n2 - n1 - 1 $in N
                    by thm recursive_min_enumeration_strictly_increases_after_steps(X, f, n1, n2 - n1 - 1)
                    f(n1) < f(n1 + (n2 - n1 - 1) + 1)
                    n1 + (n2 - n1 - 1) + 1 = n2
                    f(n1 + (n2 - n1 - 1) + 1) = f(n2)
                    f(n1) < f(n2)
                    impossible f(n1) = f(n2)
                case n1 >= n2:
                    n2 < n1 or n2 >= n1
                    by cases:
                        ? n1 = n2
                        case n2 < n1:
                            n2 <= n1
                            n1 - n2 >= 1
                            n1 - n2 - 1 $in N
                            by thm recursive_min_enumeration_strictly_increases_after_steps(X, f, n2, n1 - n2 - 1)
                            f(n2) < f(n2 + (n1 - n2 - 1) + 1)
                            n2 + (n1 - n2 - 1) + 1 = n1
                            f(n2 + (n1 - n2 - 1) + 1) = f(n1)
                            f(n2) < f(n1)
                            impossible f(n1) = f(n2)
                        case n2 >= n1:
                            n1 = n2
        $is_injective_fn(N, X, f)
    by thm recursive_min_enumeration_is_surjective(X, f)
    $is_surjective_fn(N, X, f)
    $is_bijective_fn(N, X, f)

thm increasing_bijection_zero_is_minimum:
    ? forall X power_set(N), f fn(n N) X:
        $is_increasing_bijection_from_N_to_subset(X, f)
        =>:
            $is_minimum_of_natural_subset(X, f(0))
    $is_bijective_fn(N, X, f)
    $is_surjective_fn(N, X, f)
    f(0) $in X
    claim:
        ? forall z X:
            f(0) <= z
        exist m N st {z = f(m)}
        obtain m from exist m N st {z = f(m)}
        m <= 0 or m > 0
        by cases:
            ? f(0) <= z
            case m <= 0:
                m >= 0
                m = 0
                z = f(m) = f(0)
                f(0) <= z
            case m > 0:
                m - 1 $in N
                by thm successor_strict_increase_has_strict_growth(X, f, 0, m - 1)
                f(0) < f(0 + (m - 1) + 1)
                0 + (m - 1) + 1 = m
                f(0 + (m - 1) + 1) = f(m) = z
                f(0) < z
                f(0) <= z
    $is_minimum_of_natural_subset(X, f(0))

thm increasing_bijection_successor_is_least_above:
    ? forall X power_set(N), f fn(n N) X, n N:
        $is_increasing_bijection_from_N_to_subset(X, f)
        =>:
            $is_least_natural_element_above_in_subset(X, f(n), f(n + 1))
    $is_bijective_fn(N, X, f)
    $is_surjective_fn(N, X, f)
    f(n + 1) $in X
    f(n + 1) > f(n)
    claim:
        ? forall z X:
            f(n) < z
            =>:
                f(n + 1) <= z
        exist m N st {z = f(m)}
        obtain m from exist m N st {z = f(m)}
        m < n + 1 or m >= n + 1
        by cases:
            ? f(n + 1) <= z
            case m < n + 1:
                m <= n
                m < n or m >= n
                by cases:
                    ? f(n + 1) <= z
                    case m < n:
                        n - m >= 1
                        n - m - 1 $in N
                        by thm successor_strict_increase_has_strict_growth(X, f, m, n - m - 1)
                        f(m) < f(m + (n - m - 1) + 1)
                        m + (n - m - 1) + 1 = n
                        f(m + (n - m - 1) + 1) = f(n)
                        f(m) < f(n)
                        z = f(m) < f(n)
                        f(n) < z < f(n)
                        f(n) $in N
                        f(n) + 1 <= f(n)
                        f(n) + 1 > f(n)
                        impossible f(n) + 1 > f(n)
                    case m >= n:
                        m = n
                        z = f(m) = f(n)
                        f(n) < z = f(n)
                        f(n) $in N
                        f(n) + 1 <= f(n)
                        f(n) + 1 > f(n)
                        impossible f(n) + 1 > f(n)
            case m >= n + 1:
                m <= n + 1 or m > n + 1
                by cases:
                    ? f(n + 1) <= z
                    case m <= n + 1:
                        m = n + 1
                        z = f(m) = f(n + 1)
                        f(n + 1) <= z
                    case m > n + 1:
                        m - (n + 1) >= 1
                        m - (n + 1) - 1 $in N
                        by thm successor_strict_increase_has_strict_growth(X, f, n + 1, m - (n + 1) - 1)
                        f(n + 1) < f(n + 1 + (m - (n + 1) - 1) + 1)
                        n + 1 + (m - (n + 1) - 1) + 1 = m
                        f(n + 1 + (m - (n + 1) - 1) + 1) = f(m) = z
                        f(n + 1) < z
                        f(n + 1) <= z
    $is_least_natural_element_above_in_subset(X, f(n), f(n + 1))

thm increasing_bijection_from_N_to_subset_is_recursive_min_enumeration:
    ? forall X power_set(N), f fn(n N) X:
        $has_infinite_cardinality(X)
        $is_increasing_bijection_from_N_to_subset(X, f)
        =>:
            $is_recursive_min_enumeration_from_N_to_subset(X, f)
    claim:
        ? forall n N:
            f(n) = increasing_N_subset_enum_value(X, n)
        by induc n from 0:
            ? f(n) = increasing_N_subset_enum_value(X, n)
            ? from n = 0:
                by thm increasing_bijection_zero_is_minimum(X, f)
                $is_minimum_of_natural_subset(X, f(0))
                $is_minimum_of_natural_subset(X, first_in_infinite_N_subset_value(X))
                exist! y N st {$is_minimum_of_natural_subset(X, y)}
                f(0) = first_in_infinite_N_subset_value(X)
                increasing_N_subset_enum_value(X, 0) = first_in_infinite_N_subset_value(X)
                f(0) = increasing_N_subset_enum_value(X, 0)
            ? induc:
                f(n) = increasing_N_subset_enum_value(X, n)
                by thm increasing_bijection_successor_is_least_above(X, f, n)
                $is_least_natural_element_above_in_subset(X, f(n), f(n + 1))
                $is_least_natural_element_above_in_subset(X, increasing_N_subset_enum_value(X, n), f(n + 1))
                $is_least_natural_element_above_in_subset(X, increasing_N_subset_enum_value(X, n), next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, n)))
                exist! y N st {$is_least_natural_element_above_in_subset(X, increasing_N_subset_enum_value(X, n), y)}
                f(n + 1) = next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, n))
                increasing_N_subset_enum_value(X, n + 1) = next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, (n + 1) - 1))
                (n + 1) - 1 = n
                increasing_N_subset_enum_value(X, (n + 1) - 1) = increasing_N_subset_enum_value(X, n)
                increasing_N_subset_enum_value(X, n + 1) = next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, (n + 1) - 1)) = next_in_infinite_N_subset_value(X, increasing_N_subset_enum_value(X, n))
                f(n + 1) = increasing_N_subset_enum_value(X, n + 1)
    $is_recursive_min_enumeration_from_N_to_subset(X, f)

thm infinite_subset_of_N_has_unique_increasing_enumeration:
    ? forall X power_set(N):
        $has_infinite_cardinality(X)
        =>:
            exist! f fn(n N) X st {$is_increasing_bijection_from_N_to_subset(X, f)}
            $is_countably_infinite(X)
    obtain f from exist f fn(n N) X st {$is_recursive_min_enumeration_from_N_to_subset(X, f)}
    by thm recursive_min_enumeration_is_bijective(X, f)
    claim:
        ? forall n N:
            f(n + 1) > f(n)
        by thm recursive_min_enumeration_step_is_increasing(X, f, n)
    witness exist f0 fn(n N) X st {$is_increasing_bijection_from_N_to_subset(X, f0)} from f
    claim:
        ? forall f1, f2 fn(n N) X:
            $is_increasing_bijection_from_N_to_subset(X, f1)
            $is_increasing_bijection_from_N_to_subset(X, f2)
            =>:
                f1 = f2
        by thm increasing_bijection_from_N_to_subset_is_recursive_min_enumeration(X, f1)
        by thm increasing_bijection_from_N_to_subset_is_recursive_min_enumeration(X, f2)
        forall n N:
            f1(n) = increasing_N_subset_enum_value(X, n) = f2(n)
        $fn_eq(f1, f2)
    witness exist f0 fn(x N) X st {$is_bijective_fn(N, X, f0)} from f

"""
Corollary 8.1.6. Every subset of the natural numbers is at most countable.
"""

# With the injection formulation, the inclusion map from a subset of `N` into
# `N` proves at-most-countability directly.

thm natural_subset_is_at_most_countable:
    ? forall X power_set(N):
        $is_at_most_countable(X)
    have fn include_in_N(x X) N = x
    claim:
        ? $is_injective_fn(X, N, include_in_N)
        forall x1, x2 X:
            include_in_N(x1) = include_in_N(x2)
            =>:
                x1 = include_in_N(x1) = include_in_N(x2) = x2
    witness exist f fn(x X) N st {$is_injective_fn(X, N, f)} from include_in_N

"""
Corollary 8.1.7. A subset of an at most countable set is at most countable.
"""

# If `X` injects into `N`, then any subset `Y` injects into `N` by restricting
# that injection to `Y`.

thm subset_of_at_most_countable_is_at_most_countable:
    ? forall X, Y set:
        $is_at_most_countable(X)
        Y $subset X
        =>:
            $is_at_most_countable(Y)
    obtain f from exist f fn(x X) N st {$is_injective_fn(X, N, f)}
    have fn f_on_Y(y Y) N = f(y)
    claim:
        ? $is_injective_fn(Y, N, f_on_Y)
        forall y1, y2 Y:
            f_on_Y(y1) = f_on_Y(y2)
            =>:
                y1 $in X
                y2 $in X
                f(y1) = f_on_Y(y1) = f_on_Y(y2) = f(y2)
                y1 = y2
    witness exist f0 fn(x Y) N st {$is_injective_fn(Y, N, f0)} from f_on_Y

"""
Proposition 8.1.8. The image of a function from `N` is at most countable.
"""

# The image is counted by keeping only first-occurrence indices in `N`; this
# turns the function into an enumeration of its range.

thm natural_image_is_at_most_countable:
    ? forall Y set, f fn(n N) Y:
        $is_at_most_countable(fn_range(f))
    have fn first_index by exist!:
        ? forall y fn_range(f):
            exist! n N st {$is_minimum_of_natural_subset({m N: y = f(m)}, n)}
        have by preimage p from y $in fn_range(f)
        witness $is_nonempty_set({m N: y = f(m)}) from p
        by thm natural_subset_has_unique_minimum({m N: y = f(m)})
    claim:
        ? $is_injective_fn(fn_range(f), N, first_index)
        forall y1, y2 fn_range(f):
            first_index(y1) = first_index(y2)
            =>:
                $is_minimum_of_natural_subset({m N: y1 = f(m)}, first_index(y1))
                $is_minimum_of_natural_subset({m N: y2 = f(m)}, first_index(y2))
                y1 = f(first_index(y1)) = f(first_index(y2)) = y2
    witness exist g fn(x fn_range(f)) N st {$is_injective_fn(fn_range(f), N, g)} from first_index

"""
Corollary 8.1.9. The image of a countable set is at most countable.
"""

# Compose an enumeration of the countable domain with the given function, then
# apply the image-of-`N` result.

thm countable_image_is_at_most_countable:
    ? forall X, Y set, f fn(x X) Y:
        $is_countably_infinite(X)
        =>:
            $is_at_most_countable(fn_range(f))
    obtain enum from exist enum fn(x N) X st {$is_bijective_fn(N, X, enum)}
    have fn composed_image(n N) Y = f(enum(n))
    by thm natural_image_is_at_most_countable(Y, composed_image)
    claim:
        ? fn_range(f) $subset fn_range(composed_image)
        claim:
            ? forall y fn_range(f):
                y $in fn_range(composed_image)
            have by preimage x from y $in fn_range(f)
            obtain n from exist n N st {x = enum(n)}
            composed_image(n) = f(enum(n)) = f(x) = y
            composed_image(n) $in fn_range(composed_image)
    by thm subset_of_at_most_countable_is_at_most_countable(fn_range(composed_image), fn_range(f))

"""
Proposition 8.1.10. The union of two countable sets is countable.
"""

# Interleave two enumerations by sending even indices to one set and odd
# indices to the other, then use image countability.

thm union_of_two_countable_sets_is_countable:
    ? forall X, Y set:
        $is_countably_infinite(X)
        $is_countably_infinite(Y)
        =>:
            $is_countably_infinite(union(X, Y))
    trust $is_countably_infinite(union(X, Y))

"""
Corollary 8.1.11. The integers are countable.
"""

# Split the integers into non-negative and negative parts, enumerate both, and
# combine them with the two-set union result.

prop is_negative_natural_part_member(z Z):
    exist n N st {z = -n}

have negative_natural_part set = {z Z: $is_negative_natural_part_member(z)}
negative_natural_part = {z Z: $is_negative_natural_part_member(z)}

claim:
    ? forall n N:
        -n $in negative_natural_part
    witness exist k N st {-n = -k} from n
    -n $in {z Z: $is_negative_natural_part_member(z)}

have fn neg_to_negative_part(n N) negative_natural_part = -n

forall n N:
    neg_to_negative_part(n) = -n

claim:
    ? $is_injective_fn(N, negative_natural_part, neg_to_negative_part)
    forall x1, x2 N:
        neg_to_negative_part(x1) = neg_to_negative_part(x2)
        =>:
            -x1 = neg_to_negative_part(x1) = neg_to_negative_part(x2) = -x2
            x1 = -(-x1) = -(-x2) = x2

claim:
    ? $is_surjective_fn(N, negative_natural_part, neg_to_negative_part)
    claim:
        ? forall y negative_natural_part:
            exist x N st {y = neg_to_negative_part(x)}
        y $in negative_natural_part
        y $in {z Z: $is_negative_natural_part_member(z)}
        $is_negative_natural_part_member(y)
        obtain n from exist n N st {y = -n}
        neg_to_negative_part(n) = -n
        y = neg_to_negative_part(n)
        witness exist x N st {y = neg_to_negative_part(x)} from n

witness exist f fn(x N) negative_natural_part st {$is_bijective_fn(N, negative_natural_part, f)} from neg_to_negative_part

claim:
    ? union(N, negative_natural_part) = Z
    by extension:
        ? union(N, negative_natural_part) = Z
        claim:
            ? forall x union(N, negative_natural_part):
                x $in Z
            by cases:
                ? x $in Z
                case x $in N:
                    x $in Z
                case x $in negative_natural_part:
                    x $in Z
        claim:
            ? forall z Z:
                z $in union(N, negative_natural_part)
            by cases:
                ? z $in union(N, negative_natural_part)
                case z >= 0:
                    z $in N
                case z < 0:
                    abs(z) $in N
                    abs(z) = -z
                    witness exist k N st {z = -k} from abs(z)
                    z $in negative_natural_part

by thm union_of_two_countable_sets_is_countable(N, negative_natural_part)

"""
Lemma 8.1.12. The triangular subset `{(n,m) in N x N : m <= n}` is countable.
"""

# Enumerate the finite rows of the triangle by diagonal or triangular-number
# indexing, which gives a countable listing of all pairs with `m <= n`.

have natural_triangle set = {p cart(N, N): p[2] <= p[1]}
natural_triangle = {p cart(N, N): p[2] <= p[1]}

forall p natural_triangle:
    p $in natural_triangle
    p $in {q cart(N, N): q[2] <= q[1]}
    p $in cart(N, N)

claim:
    ? forall n N:
        exist! y N st {2 * y = n * (n + 1)}

    by cases:
        ? n * (n + 1) % 2 = 0
        case n % 2 = 0:
            n * (n + 1) % 2 = (n % 2) * ((n + 1) % 2) % 2 = 0 * ((n + 1) % 2) % 2 = 0 % 2 = 0
        case n % 2 = 1:
            (n + 1) % 2 = (n % 2 + 1 % 2) % 2 = 0
            n * (n + 1) % 2 = (n % 2) * ((n + 1) % 2) % 2 = 1 * 0 % 2 = 0 % 2 = 0
    obtain r from exist r N st {n * (n + 1) = 2 * r}
    witness exist y N st {2 * y = n * (n + 1)} from r
    forall y1, y2 N:
        2 * y1 = n * (n + 1)
        2 * y2 = n * (n + 1)
        =>:
            y1 = n * (n + 1) / 2 = y2

have fn tri by exist!:
    ? forall n N:
        exist! y N st {2 * y = n * (n + 1)}

2 * tri(0) = 0 * (0 + 1)
tri(0) = (2 * tri(0)) / 2 = (0 * (0 + 1)) / 2 = 0

forall n N:
    2 * tri(n + 1) = (n + 1) * ((n + 1) + 1) = (n + 1) * (n + 2)
    2 * tri(n) = n * (n + 1)
    2 * (tri(n) + n + 1) = 2 * tri(n) + 2 * n + 2 = n * (n + 1) + 2 * n + 2 = (n + 1) * (n + 2)
    tri(n + 1) = (2 * tri(n + 1)) / 2 = ((n + 1) * (n + 2)) / 2 = (2 * (tri(n) + n + 1)) / 2 = tri(n) + n + 1

prop triangular_interval(n, s N):
    tri(s) <= n < tri(s + 1)

have fn diagonal_index(u natural_triangle) N = tri(u[1]) + u[2]

forall u natural_triangle:
    diagonal_index(u) = tri(u[1]) + u[2]

claim:
    ? forall n, m N:
        m <= n
        =>:
            (n, m) $in natural_triangle
    (n, m) $in {p cart(N, N): p[2] <= p[1]}

claim:
    ? forall u natural_triangle:
        tri(u[1]) <= diagonal_index(u) < tri(u[1] + 1)
    tri(u[1]) <= tri(u[1]) + u[2] = diagonal_index(u) = tri(u[1]) + u[2] <= tri(u[1]) + u[1] < tri(u[1]) + u[1] + 1 = tri(u[1] + 1)

claim:
    ? forall a, b N:
        a < b
        =>:
            tri(a + 1) <= tri(b)
    a + 1 <= b
    2 * tri(a + 1) = (a + 1) * ((a + 1) + 1) <= b * (b + 1) = 2 * tri(b)
    tri(a + 1) = (2 * tri(a + 1)) / 2 <= (2 * tri(b)) / 2 = tri(b)

claim:
    ? forall u, v natural_triangle:
        u[1] < v[1]
        =>:
            diagonal_index(u) < diagonal_index(v)
    diagonal_index(u) < tri(u[1] + 1) <= tri(v[1]) <= diagonal_index(v)

claim:
    ? forall u, v natural_triangle:
        diagonal_index(u) = diagonal_index(v)
        =>:
            u[1] = v[1]
    by contra:
        ? not u[1] < v[1]
        diagonal_index(u) < diagonal_index(v)
        impossible diagonal_index(u) = diagonal_index(v)
    by contra:
        ? not v[1] < u[1]
        diagonal_index(v) < diagonal_index(u)
        impossible diagonal_index(u) = diagonal_index(v)

claim:
    ? forall u, v natural_triangle:
        u[1] = v[1]
        diagonal_index(u) = diagonal_index(v)
        =>:
            u[2] = v[2]
    u[2] = (tri(u[1]) + u[2]) - tri(u[1]) = diagonal_index(u) - tri(u[1]) = diagonal_index(v) - tri(v[1]) = (tri(v[1]) + v[2]) - tri(v[1]) = v[2]

claim:
    ? $is_injective_fn(natural_triangle, N, diagonal_index)
    forall x1, x2 natural_triangle:
        diagonal_index(x1) = diagonal_index(x2)
        =>:
            x1[1] = x2[1]
            x1[2] = x2[2]
            x1 = (x1[1], x1[2]) = (x2[1], x2[2]) = x2

claim:
    ? forall n, s N:
        $triangular_interval(n, s)
        =>:
            n - tri(s) <= s
    tri(s + 1) = tri(s) + s + 1
    n - tri(s) < (tri(s) + s + 1) - tri(s) = s + 1

by induc n from 0:
    ? exist s N st {$triangular_interval(n, s)}

    ? from n = 0:
        0 < 1 = tri(0) + 0 + 1 = tri(0 + 1)
        witness exist s N st {$triangular_interval(0, s)} from 0

    ? induc:
        obtain s from exist s N st {$triangular_interval(n, s)}
        by cases:
            ? exist t N st {$triangular_interval(n + 1, t)}
            case n + 1 < tri(s + 1):
                witness exist t N st {$triangular_interval(n + 1, t)} from s
            case n + 1 >= tri(s + 1):
                n + 1 < n + 2 <= tri(s + 1) + s + 2 = tri(s + 1) + (s + 1) + 1 = tri((s + 1) + 1)
                witness exist t N st {$triangular_interval(n + 1, t)} from s + 1

claim:
    ? $is_surjective_fn(natural_triangle, N, diagonal_index)
    claim:
        ? forall y N:
            exist x natural_triangle st {y = diagonal_index(x)}
        obtain s from exist s N st {$triangular_interval(y, s)}
        have b N = y - tri(s)
        b = y - tri(s) <= s
        (s, b) $in natural_triangle
        diagonal_index((s, b)) = tri((s, b)[1]) + (s, b)[2] = tri(s) + b = tri(s) + (y - tri(s)) = y
        witness exist x natural_triangle st {y = diagonal_index(x)} from (s, b)


have fn triangle_unrank by exist!:
    ? forall y N:
        exist! x natural_triangle st {y = diagonal_index(x)}

claim:
    ? $is_injective_fn(N, natural_triangle, triangle_unrank)
    forall y1, y2 N:
        triangle_unrank(y1) = triangle_unrank(y2)
        =>:
            y1 = diagonal_index(triangle_unrank(y1)) = diagonal_index(triangle_unrank(y2)) = y2

claim:
    ? $is_surjective_fn(N, natural_triangle, triangle_unrank)
    claim:
        ? forall p natural_triangle:
            exist y N st {p = triangle_unrank(y)}
        witness exist y N st {p = triangle_unrank(y)} from diagonal_index(p)

witness exist f fn(x N) natural_triangle st {$is_bijective_fn(N, natural_triangle, f)} from triangle_unrank

"""
Corollary 8.1.13. The Cartesian product `N x N` is countable.
"""

# Cover `N x N` by the two triangular halves and use the countability of each
# half together with the union result.

have upper_natural_triangle set = {p cart(N, N): p[1] <= p[2]}
upper_natural_triangle = {p cart(N, N): p[1] <= p[2]}

forall p upper_natural_triangle:
    p $in upper_natural_triangle
    p $in {q cart(N, N): q[1] <= q[2]}
    p $in cart(N, N)

claim:
    ? forall n, m N:
        n <= m
        =>:
            (n, m) $in upper_natural_triangle
    (n, m) $in {p cart(N, N): p[1] <= p[2]}

forall p natural_triangle:
    (p[2], p[1]) $in upper_natural_triangle

have fn lower_to_upper(p natural_triangle) upper_natural_triangle = (p[2], p[1])

forall p natural_triangle:
    lower_to_upper(p) = (p[2], p[1])

claim:
    ? $is_injective_fn(natural_triangle, upper_natural_triangle, lower_to_upper)
    forall p1, p2 natural_triangle:
        lower_to_upper(p1) = lower_to_upper(p2)
        =>:
            (p1[2], p1[1]) = lower_to_upper(p1) = lower_to_upper(p2) = (p2[2], p2[1])
            p1[2] = (p1[2], p1[1])[1] = (p2[2], p2[1])[1] = p2[2]
            p1[1] = (p1[2], p1[1])[2] = (p2[2], p2[1])[2] = p2[1]
            p1 = (p1[1], p1[2]) = (p2[1], p2[2]) = p2

claim:
    ? $is_surjective_fn(natural_triangle, upper_natural_triangle, lower_to_upper)
    claim:
        ? forall q upper_natural_triangle:
            exist p natural_triangle st {q = lower_to_upper(p)}
        (q[2], q[1]) $in natural_triangle
        lower_to_upper((q[2], q[1])) = ((q[2], q[1])[2], (q[2], q[1])[1]) = (q[1], q[2]) = q
        q = lower_to_upper((q[2], q[1]))
        witness exist p natural_triangle st {q = lower_to_upper(p)} from (q[2], q[1])

have fn upper_triangle_enum(n N) upper_natural_triangle = lower_to_upper(triangle_unrank(n))

forall n N:
    upper_triangle_enum(n) = lower_to_upper(triangle_unrank(n))

claim:
    ? $is_injective_fn(N, upper_natural_triangle, upper_triangle_enum)
    forall n1, n2 N:
        upper_triangle_enum(n1) = upper_triangle_enum(n2)
        =>:
            lower_to_upper(triangle_unrank(n1)) = upper_triangle_enum(n1) = upper_triangle_enum(n2) = lower_to_upper(triangle_unrank(n2))
            triangle_unrank(n1) = triangle_unrank(n2)
            n1 = n2

claim:
    ? $is_surjective_fn(N, upper_natural_triangle, upper_triangle_enum)
    claim:
        ? forall q upper_natural_triangle:
            exist n N st {q = upper_triangle_enum(n)}
        obtain p from exist p natural_triangle st {q = lower_to_upper(p)}
        obtain n from exist n N st {p = triangle_unrank(n)}
        upper_triangle_enum(n) = lower_to_upper(triangle_unrank(n)) = lower_to_upper(p) = q
        q = upper_triangle_enum(n)
        witness exist n0 N st {q = upper_triangle_enum(n0)} from n

witness exist f fn(x N) upper_natural_triangle st {$is_bijective_fn(N, upper_natural_triangle, f)} from upper_triangle_enum

claim:
    ? union(natural_triangle, upper_natural_triangle) = cart(N, N)
    by extension:
        ? union(natural_triangle, upper_natural_triangle) = cart(N, N)
        claim:
            ? forall p union(natural_triangle, upper_natural_triangle):
                p $in cart(N, N)
            by cases:
                ? p $in cart(N, N)
                case p $in natural_triangle:
                    p $in cart(N, N)
                case p $in upper_natural_triangle:
                    p $in cart(N, N)
        claim:
            ? forall p cart(N, N):
                p $in union(natural_triangle, upper_natural_triangle)
            by cases:
                ? p $in union(natural_triangle, upper_natural_triangle)
                case p[2] <= p[1]:
                    p $in {p cart(N, N): p[2] <= p[1]}
                    p $in natural_triangle
                case p[2] > p[1]:
                    p $in {p cart(N, N): p[1] <= p[2]}
                    p $in upper_natural_triangle

by thm union_of_two_countable_sets_is_countable(natural_triangle, upper_natural_triangle)

thm proposition_3_6_14_N_embedding_implies_infinite:
    ? forall X set:
        $embeds_into(N, X)
        =>:
            $has_infinite_cardinality(X)
    trust $has_infinite_cardinality(X)

thm at_most_countable_with_N_embedding_is_countably_infinite:
    ? forall X set:
        $is_at_most_countable(X)
        $embeds_into(N, X)
        =>:
            $is_countably_infinite(X)
    by thm proposition_3_6_14_N_embedding_implies_infinite(X)
    by thm infinite_at_most_countable_is_countably_infinite(X)

"""
Corollary 8.1.14. A Cartesian product of two countable sets is countable.
"""

# Transport the countable enumeration of `N x N` through bijections from `N` to
# the two countable sets.

thm product_of_countable_sets_is_countable:
    ? forall X, Y set:
        $is_countably_infinite(X)
        $is_countably_infinite(Y)
        =>:
            $is_countably_infinite(cart(X, Y))
    obtain enumX from exist enumX fn(x N) X st {$is_bijective_fn(N, X, enumX)}
    obtain enumY from exist enumY fn(x N) Y st {$is_bijective_fn(N, Y, enumY)}
    have fn product_map(p cart(N, N)) cart(X, Y) = (enumX(p[1]), enumY(p[2]))
    by thm countable_image_is_at_most_countable(cart(N, N), cart(X, Y), product_map)
    claim:
        ? cart(X, Y) $subset fn_range(product_map)
        claim:
            ? forall q cart(X, Y):
                q $in fn_range(product_map)
            obtain nx from exist nx N st {q[1] = enumX(nx)}
            obtain ny from exist ny N st {q[2] = enumY(ny)}
            product_map((nx, ny)) = (enumX((nx, ny)[1]), enumY((nx, ny)[2])) = (enumX(nx), enumY(ny)) = (q[1], q[2]) = q
            product_map((nx, ny)) $in fn_range(product_map)
    by thm subset_of_at_most_countable_is_at_most_countable(fn_range(product_map), cart(X, Y))
    have fn embed_N_into_cart(n N) cart(X, Y) = (enumX(n), enumY(0))
    claim:
        ? $is_injective_fn(N, cart(X, Y), embed_N_into_cart)
        forall n1, n2 N:
            embed_N_into_cart(n1) = embed_N_into_cart(n2)
            =>:
                (enumX(n1), enumY(0)) = embed_N_into_cart(n1) = embed_N_into_cart(n2) = (enumX(n2), enumY(0))
                enumX(n1) = (enumX(n1), enumY(0))[1] = (enumX(n2), enumY(0))[1] = enumX(n2)
                n1 = n2
    witness exist e fn(x N) cart(X, Y) st {$is_injective_fn(N, cart(X, Y), e)} from embed_N_into_cart
    by thm at_most_countable_with_N_embedding_is_countably_infinite(cart(X, Y))

"""
Corollary 8.1.15. The rationals are countable.
"""

# Represent each rational by an integer numerator and nonzero integer
# denominator; the quotient map from `Z x (Z minus {0})` has image `Q`.

forall n N:
    -(n + 1) $in Z_neg

have fn negative_integer_enum(n N) Z_neg = -(n + 1)

forall n N:
    negative_integer_enum(n) = -(n + 1)

claim:
    ? $is_injective_fn(N, Z_neg, negative_integer_enum)
    forall x1, x2 N:
        negative_integer_enum(x1) = negative_integer_enum(x2)
        =>:
            -(x1 + 1) = negative_integer_enum(x1) = negative_integer_enum(x2) = -(x2 + 1)
            x1 + 1 = -(-(x1 + 1)) = -(-(x2 + 1)) = x2 + 1
            x1 = (x1 + 1) - 1 = (x2 + 1) - 1 = x2

claim:
    ? $is_surjective_fn(N, Z_neg, negative_integer_enum)
    claim:
        ? forall y Z_neg:
            exist n N st {y = negative_integer_enum(n)}
        abs(y) $in N_pos
        abs(y) - 1 $in N
        negative_integer_enum(abs(y) - 1) = -((abs(y) - 1) + 1) = -abs(y) = y
        y = negative_integer_enum(abs(y) - 1)
        witness exist n N st {y = negative_integer_enum(n)} from abs(y) - 1

witness exist f fn(x N) Z_neg st {$is_bijective_fn(N, Z_neg, f)} from negative_integer_enum

claim:
    ? union(N_pos, Z_neg) = Z_nz
    by extension:
        ? union(N_pos, Z_neg) = Z_nz
        claim:
            ? forall x union(N_pos, Z_neg):
                x $in Z_nz
            by cases:
                ? x $in Z_nz
                case x $in N_pos:
                    x $in Z_nz
                case x $in Z_neg:
                    x $in Z_nz
        claim:
            ? forall x Z_nz:
                x $in union(N_pos, Z_neg)
            by cases:
                ? x $in union(N_pos, Z_neg)
                case x > 0:
                    x $in N_pos
                case x <= 0:
                    by cases:
                        ? x $in union(N_pos, Z_neg)
                        case x < 0:
                            x $in Z_neg
                        case x >= 0:
                            impossible x != 0

by thm union_of_two_countable_sets_is_countable(N_pos, Z_neg)

forall p cart(Z, Z_nz):
    p[1] / p[2] $in Q

have fn rational_quotient(p cart(Z, Z_nz)) Q = p[1] / p[2]

claim:
    ? forall q Q:
        exist p cart(Z, Z_nz) st {q = rational_quotient(p)}
    obtain a, b from exist a Z, b Z_nz st {q = a / b}
    witness exist p0 cart(Z, Z_nz) st {q = rational_quotient(p0)} from (a, b)

claim:
    ? fn_range(rational_quotient) = Q
    by extension:
        ? fn_range(rational_quotient) = Q
        claim:
            ? forall q Q:
                q $in fn_range(rational_quotient)
            obtain p from exist p cart(Z, Z_nz) st {q = rational_quotient(p)}
            rational_quotient(p) $in fn_range(rational_quotient)

by thm product_of_countable_sets_is_countable(Z, Z_nz)
by thm countable_image_is_at_most_countable(cart(Z, Z_nz), Q, rational_quotient)


have fn natural_to_rational(n N) Q = n

claim:
    ? $embeds_into(N, Q)
    claim:
        ? $is_injective_fn(N, Q, natural_to_rational)
        forall x1, x2 N:
            natural_to_rational(x1) = natural_to_rational(x2)
            =>:
                x1 = natural_to_rational(x1) = natural_to_rational(x2) = x2
    witness exist f fn(x N) Q st {$is_injective_fn(N, Q, f)} from natural_to_rational

by thm at_most_countable_with_N_embedding_is_countably_infinite(Q)

"""
Remark 8.1.16. The rationals can be arranged as a sequence, although finding an
explicit injective and surjective enumeration takes care.
"""

"""
Exercise after Section 8.1.  Countable unions of at most countable sets are at
most countable; this is used later and requires choice.
"""

# Choose an enumeration for each at most countable fiber, then diagonalize over
# the countable index set.

thm countable_union_of_at_most_countable_sets:
    ? forall I, U set, A fn(i I) power_set(U):
        $is_at_most_countable(I)
        forall i I:
            $is_at_most_countable(A(i))
        =>:
            $is_at_most_countable(cup(fn_range(A)))
    trust $is_at_most_countable(cup(fn_range(A)))


# 8.2 Summation on infinite sets

"""
Definition 8.2.1 (Series on countable sets). A series over a countable set is
absolutely convergent if one countable enumeration gives an absolutely
convergent ordinary series.  Its value is the corresponding ordinary series
sum, and Proposition 7.4.3 makes the value independent of the enumeration.
"""

prop is_countable_enumeration(X set, g fn(n N_pos) X):
    $is_bijective_fn(N_pos, X, g)

# Given an enumeration `g : N_pos -> X`, the countable-set series for `f` is
# the ordinary sequence of terms `f(g(n))`.
template<X set, f fn(x X) R, g fn(n N_pos) X>:
    have fn countable_set_series_terms(n N_pos) R = f(g(n))

prop is_absolutely_convergent_countable_set_series(X set, f fn(x X) R):
    exist g fn(n N_pos) X st {$is_countable_enumeration(X, g), $is_absolutely_convergent_series(\countable_set_series_terms<X, f, g>)}

prop has_countable_set_series_sum(X set, f fn(x X) R, L R):
    exist g fn(n N_pos) X st {$is_countable_enumeration(X, g), $has_series_sum(\countable_set_series_terms<X, f, g>, L)}

thm countable_set_series_sum_well_defined:
    ? forall X set, f fn(x X) R, g, h fn(n N_pos) X, Lg, Lh R:
        $is_countable_enumeration(X, g)
        $is_countable_enumeration(X, h)
        $has_series_sum(\countable_set_series_terms<X, f, g>, Lg)
        $has_series_sum(\countable_set_series_terms<X, f, h>, Lh)
        $is_absolutely_convergent_series(\countable_set_series_terms<X, f, g>)
        =>:
            Lg = Lh
    trust Lg = Lh

"""
Theorem 8.2.2 (Fubini's theorem for infinite sums). If the sum over `N x N`
is absolutely convergent, then row-first, whole-product, swapped-product, and
column-first sums all agree.
"""

have fn swap_pair(p cart(N_pos, N_pos)) cart(N_pos, N_pos) = (p[2], p[1])

prop has_double_sum(f fn(p cart(N_pos, N_pos)) R, L R):
    $has_countable_set_series_sum(cart(N_pos, N_pos), f, L)

prop has_row_sums(f fn(p cart(N_pos, N_pos)) R, r seq(R)):
    forall n N_pos:
        $has_series_sum(fn(m N_pos) R {f((n, m))}, r(n))

prop has_row_first_sum(f fn(p cart(N_pos, N_pos)) R, L R):
    exist r seq(R) st {$has_row_sums(f, r), $has_series_sum(r, L)}

prop has_column_sums(f fn(p cart(N_pos, N_pos)) R, c seq(R)):
    forall m N_pos:
        $has_series_sum(fn(n N_pos) R {f((n, m))}, c(m))

prop has_column_first_sum(f fn(p cart(N_pos, N_pos)) R, L R):
    exist c seq(R) st {$has_column_sums(f, c), $has_series_sum(c, L)}

prop has_swapped_double_sum(f fn(p cart(N_pos, N_pos)) R, L R):
    $has_countable_set_series_sum(cart(N_pos, N_pos), fn(p cart(N_pos, N_pos)) R {f(swap_pair(p))}, L)

prop is_absolutely_convergent_double_sum(f fn(p cart(N_pos, N_pos)) R):
    $is_absolutely_convergent_countable_set_series(cart(N_pos, N_pos), f)

prop is_nonnegative_double_series(f fn(p cart(N_pos, N_pos)) R):
    forall p cart(N_pos, N_pos):
        f(p) >= 0

prop has_finite_double_subsum_bound(f fn(p cart(N_pos, N_pos)) R, L R):
    forall A finite_set:
        A $subset cart(N_pos, N_pos)
        =>:
            finite_set_sum(A, fn(p A) R {f(p)}) <= L

prop has_double_sum_finite_support_capture(f fn(p cart(N_pos, N_pos)) R, L R):
    forall epsilon R_pos:
        exist A finite_set st {A $subset cart(N_pos, N_pos), finite_set_sum(A, fn(p A) R {f(p)}) >= L - epsilon}

thm nonnegative_double_sum_bounds_finite_subsums:
    ? forall f fn(p cart(N_pos, N_pos)) R, L R:
        $has_double_sum(f, L)
        $is_nonnegative_double_series(f)
        =>:
            $has_finite_double_subsum_bound(f, L)
    trust $has_finite_double_subsum_bound(f, L)

thm nonnegative_double_sum_has_finite_support_capture:
    ? forall f fn(p cart(N_pos, N_pos)) R, L R:
        $has_double_sum(f, L)
        $is_nonnegative_double_series(f)
        =>:
            $has_double_sum_finite_support_capture(f, L)
    trust $has_double_sum_finite_support_capture(f, L)

thm bounded_rectangles_and_capture_give_row_first_sum:
    ? forall f fn(p cart(N_pos, N_pos)) R, L R:
        $is_nonnegative_double_series(f)
        $has_finite_double_subsum_bound(f, L)
        $has_double_sum_finite_support_capture(f, L)
        =>:
            $has_row_first_sum(f, L)
    trust $has_row_first_sum(f, L)

thm fubini_row_first_nonnegative_case:
    ? forall f fn(p cart(N_pos, N_pos)) R, L R:
        $has_double_sum(f, L)
        $is_nonnegative_double_series(f)
        =>:
            $has_row_first_sum(f, L)
    by thm nonnegative_double_sum_bounds_finite_subsums(f, L)
    by thm nonnegative_double_sum_has_finite_support_capture(f, L)
    by thm bounded_rectangles_and_capture_give_row_first_sum(f, L)

template<f fn(p cart(N_pos, N_pos)) R>:
    have fn double_positive_part(p cart(N_pos, N_pos)) R = max(f(p), 0)

template<f fn(p cart(N_pos, N_pos)) R>:
    have fn double_negative_part(p cart(N_pos, N_pos)) R = min(f(p), 0)

thm fubini_row_first_general_case:
    ? forall f fn(p cart(N_pos, N_pos)) R, L R:
        $has_double_sum(f, L)
        $is_absolutely_convergent_double_sum(f)
        =>:
            $has_row_first_sum(f, L)
    trust $has_row_first_sum(f, L)

thm fubini_swapped_double_sum_from_absolute_convergence:
    ? forall f fn(p cart(N_pos, N_pos)) R, L R:
        $has_double_sum(f, L)
        $is_absolutely_convergent_double_sum(f)
        =>:
            $has_swapped_double_sum(f, L)
    trust $has_swapped_double_sum(f, L)

thm fubini_column_first_from_swapped_sum:
    ? forall f fn(p cart(N_pos, N_pos)) R, L R:
        $has_swapped_double_sum(f, L)
        $is_absolutely_convergent_double_sum(f)
        =>:
            $has_column_first_sum(f, L)
    trust $has_column_first_sum(f, L)

thm fubini_for_infinite_sums:
    ? forall f fn(p cart(N_pos, N_pos)) R, L R:
        $has_double_sum(f, L)
        $is_absolutely_convergent_double_sum(f)
        =>:
            $has_row_first_sum(f, L)
            $has_swapped_double_sum(f, L)
            $has_column_first_sum(f, L)
    # The source gives this as an optional sketch: the second equality is a
    # rearrangement by `swap_pair`; the first equality is proved first for
    # non-negative `f` by finite rectangles and epsilon capture, then extended
    # to a general absolutely convergent `f` by positive and negative parts.
    # The named lemmas above keep exactly those proof nodes visible.
    by thm fubini_row_first_general_case(f, L)
    by thm fubini_swapped_double_sum_from_absolute_convergence(f, L)
    by thm fubini_column_first_from_swapped_sum(f, L)

"""
Lemma 8.2.3. For an at most countable set, absolute convergence is equivalent
to boundedness of all finite absolute subsums.
"""

# For an enumerated countable set, absolute convergence bounds every finite
# absolute subsum; conversely bounded finite subsums bound the ordinary
# absolute partial sums.

prop is_finite_subsum_abs_bound(X set, f fn(x X) R, M R):
    forall A finite_set:
        A $subset X
        =>:
            finite_set_sum(A, fn(x A) R {abs(f(x))}) <= M

prop has_bounded_finite_absolute_subsums(X set, f fn(x X) R):
    exist M R st {$is_finite_subsum_abs_bound(X, f, M)}

thm countable_absolute_convergence_implies_bounded_finite_subsums:
    ? forall X set, f fn(x X) R:
        $is_at_most_countable(X)
        $is_absolutely_convergent_countable_set_series(X, f)
        =>:
            $has_bounded_finite_absolute_subsums(X, f)
    trust $has_bounded_finite_absolute_subsums(X, f)

thm bounded_finite_subsums_imply_countable_absolute_convergence:
    ? forall X set, f fn(x X) R:
        $is_at_most_countable(X)
        $has_bounded_finite_absolute_subsums(X, f)
        =>:
            $is_absolutely_convergent_countable_set_series(X, f)
    trust $is_absolutely_convergent_countable_set_series(X, f)

"""
Definition 8.2.4. For any set, possibly uncountable, absolute convergence of
`sum_{x in X} f(x)` means that all finite absolute subsums are bounded.
"""

prop is_absolutely_summable_on_set(X set, f fn(x X) R):
    $has_bounded_finite_absolute_subsums(X, f)

"""
Lemma 8.2.5. If a series over an arbitrary set is absolutely summable, then the
support `{x in X : f(x) != 0}` is at most countable.
"""

# The nonzero support is the union of the level sets `{x : abs(f(x)) > 1/n}`;
# bounded finite absolute subsums make each level set finite.

template<X set, f fn(t X) R>:
    have nonzero_support set = {u X: f(u) != 0}

thm absolutely_summable_support_is_at_most_countable:
    ? forall X set, f fn(x X) R:
        $is_absolutely_summable_on_set(X, f)
        =>:
            $is_at_most_countable(\nonzero_support<X, f>)
    trust $is_at_most_countable(\nonzero_support<X, f>)

"""
The value of an absolutely summable arbitrary-set series is the value of the
same function restricted to its at most countable nonzero support.
"""

prop has_set_series_sum(X set, f fn(t X) R, L R):
    $is_absolutely_summable_on_set(X, f)
    $has_countable_set_series_sum(\nonzero_support<X, f>, fn(v \nonzero_support<X, f>) R {f(v)}, L)

"""
Proposition 8.2.6 (Absolutely convergent series laws). Absolutely summable
families are closed under addition, scalar multiplication, disjoint union, and
bijection change of variables; the sums obey the expected identities.
"""

# The laws reduce arbitrary-set sums to their countable nonzero supports, then
# apply the Chapter 7 absolute-convergence and finite-sum laws.

thm arbitrary_set_series_add:
    ? forall X set, f, g fn(x X) R, Lf, Lg R:
        $has_set_series_sum(X, f, Lf)
        $has_set_series_sum(X, g, Lg)
        =>:
            $has_set_series_sum(X, fn(w X) R {f(w) + g(w)}, Lf + Lg)
    trust $has_set_series_sum(X, fn(w X) R {f(w) + g(w)}, Lf + Lg)

thm arbitrary_set_series_scalar_mul:
    ? forall X set, f fn(x X) R, c, L R:
        $has_set_series_sum(X, f, L)
        =>:
            $has_set_series_sum(X, fn(w X) R {c * f(w)}, c * L)
    trust $has_set_series_sum(X, fn(w X) R {c * f(w)}, c * L)

thm arbitrary_set_series_disjoint_union:
    ? forall X, X1, X2 set, f fn(x X) R, L1, L2 R:
        X = union(X1, X2)
        intersect(X1, X2) = {}
        X1 $subset X
        X2 $subset X
        $has_set_series_sum(X1, fn(w X1) R {f(w)}, L1)
        $has_set_series_sum(X2, fn(z X2) R {f(z)}, L2)
        =>:
            $has_set_series_sum(X, f, L1 + L2)
    trust $has_set_series_sum(X, f, L1 + L2)

thm arbitrary_set_series_bijection_change:
    ? forall X, Y set, f fn(x X) R, phi fn(y Y) X, L R:
        $is_bijective_fn(Y, X, phi)
        $has_set_series_sum(X, f, L)
        =>:
            $has_set_series_sum(Y, fn(w Y) R {f(phi(w))}, L)
    trust $has_set_series_sum(Y, fn(w Y) R {f(phi(w))}, L)

"""
Lemma 8.2.7. A conditionally convergent but not absolutely convergent series
has divergent positive and negative subseries.
"""

# If one sign subseries converged absolutely, combining it with convergence of
# the original series would force absolute convergence of the whole series.

prop is_only_conditionally_convergent_series(a seq(R)):
    $is_convergent_series(a)
    not $is_absolutely_convergent_series(a)

template<a seq(R)>:
    have positive_index_set set = {n N_pos: a(n) >= 0}

template<a seq(R)>:
    have negative_index_set set = {n N_pos: a(n) < 0}

thm positive_and_negative_parts_of_conditional_series_diverge:
    ? forall a seq(R):
        $is_only_conditionally_convergent_series(a)
        =>:
            not $is_absolutely_convergent_countable_set_series(\positive_index_set<a>, fn(n \positive_index_set<a>) R {a(n)})
            not $is_absolutely_convergent_countable_set_series(\negative_index_set<a>, fn(n \negative_index_set<a>) R {a(n)})
    trust:
        not $is_absolutely_convergent_countable_set_series(\positive_index_set<a>, fn(n \positive_index_set<a>) R {a(n)})
        not $is_absolutely_convergent_countable_set_series(\negative_index_set<a>, fn(n \negative_index_set<a>) R {a(n)})

"""
Theorem 8.2.8 (Riemann rearrangement theorem). A conditionally convergent
non-absolutely convergent series can be rearranged to converge to any real
number.
"""

# The rearrangement alternately takes unused positive or negative terms so the
# partial sums cross the target value with overshoot tending to zero.

prop is_permutation_of_positive_integers(phi fn(i N_pos) N_pos):
    $is_bijective_fn(N_pos, N_pos, phi)

have fn rearranged_series(a seq(R), phi fn(i N_pos) N_pos) seq(R) = fn(j N_pos) R {a(phi(j))}

thm riemann_rearrangement_theorem:
    ? forall a seq(R), L R:
        $is_only_conditionally_convergent_series(a)
        =>:
            exist phi fn(i N_pos) N_pos st {$is_permutation_of_positive_integers(phi), $has_series_sum(rearranged_series(a, phi), L), $is_only_conditionally_convergent_series(rearranged_series(a, phi))}
    trust exist phi fn(i N_pos) N_pos st {$is_permutation_of_positive_integers(phi), $has_series_sum(rearranged_series(a, phi), L), $is_only_conditionally_convergent_series(rearranged_series(a, phi))}


# 8.3 Uncountable sets

"""
Theorem 8.3.1 (Cantor's theorem). No set has the same cardinality as its power
set.  The diagonal set is `{x in X : x notin f(x)}`.
"""

template<X set, f fn(x X) power_set(X)>:
    have cantor_diagonal_set power_set(X) = {x X: not x $in f(x)}

thm cantor_theorem:
    ? forall X set:
        not $has_equal_cardinality(X, power_set(X))
    by contra:
        ? not $has_equal_cardinality(X, power_set(X))
        obtain f from exist f fn(x X) power_set(X) st {$is_bijective_fn(X, power_set(X), f)}
        obtain a from exist a X st {\cantor_diagonal_set<X, f> = f(a)}

        claim:
            ? a $in \cantor_diagonal_set<X, f>
            by contra:
                ? a $in \cantor_diagonal_set<X, f>
                a $in {x X: not x $in f(x)}
                impossible not a $in \cantor_diagonal_set<X, f>

        impossible not a $in f(a)

"""
Remark 8.3.2. Cantor's diagonal proof resembles Russell's paradox: a universal
listing of all subsets would have to decide membership in the self-avoiding
subset.
"""

"""
Corollary 8.3.3. The power set of `N` is uncountable.
"""

have fn singleton_subset_of_N(n N) power_set(N) = {n}

claim:
    ? $is_injective_fn(N, power_set(N), singleton_subset_of_N)
    forall x1, x2 N:
        singleton_subset_of_N(x1) = singleton_subset_of_N(x2)
        =>:
            {x1} = singleton_subset_of_N(x1) = singleton_subset_of_N(x2) = {x2}
            x1 $in {x1}
            x1 $in {x2}
            x1 = x2

witness exist f fn(x N) power_set(N) st {$is_injective_fn(N, power_set(N), f)} from singleton_subset_of_N

claim:
    ? $is_uncountable(power_set(N))
    by thm cantor_theorem(N)
    by contra:
        ? not $is_countably_infinite(power_set(N))
        impossible not $has_equal_cardinality(N, power_set(N))
    by thm proposition_3_6_14_N_embedding_implies_infinite(power_set(N))

"""
Corollary 8.3.4. The real numbers are uncountable.  The source injects
`power_set(N)` into `R` by sending a subset A to the decimal-style sum of
`10^-n`.
"""

abstract_prop has_binary_decimal_subset_sum(A, L)

have fn binary_decimal_subset_sum by exist!:
    ? forall A power_set(N):
        exist! L R st {$has_binary_decimal_subset_sum(A, L)}
    trust exist! L R st {$has_binary_decimal_subset_sum(A, L)}

claim:
    ? $is_injective_fn(power_set(N), R, binary_decimal_subset_sum)
    trust $is_injective_fn(power_set(N), R, binary_decimal_subset_sum)

thm uncountability_transfers_to_codomain_of_injection:
    ? forall X, Y set, phi fn(x X) Y:
        $is_uncountable(X)
        $is_injective_fn(X, Y, phi)
        =>:
            $is_uncountable(Y)
    claim:
        ? $has_infinite_cardinality(Y)
        claim:
            ? not $has_finite_cardinality(Y)
            by contra:
                ? not $has_finite_cardinality(Y)
                by thm finite_cardinality_gives_at_most_countable(Y)
                by thm injection_into_at_most_countable_gives_at_most_countable(X, Y, phi)
                by thm uncountable_is_not_at_most_countable(X)
                impossible not $is_at_most_countable(X)
    claim:
        ? not $is_countably_infinite(Y)
        by contra:
            ? not $is_countably_infinite(Y)
            by thm countably_infinite_is_at_most_countable(Y)
            by thm injection_into_at_most_countable_gives_at_most_countable(X, Y, phi)
            by thm uncountable_is_not_at_most_countable(X)
            impossible not $is_at_most_countable(X)

by thm uncountability_transfers_to_codomain_of_injection(power_set(N), R, binary_decimal_subset_sum)

"""
Remark 8.3.5. Measure theory gives another proof that the real numbers are
uncountable.
"""

# This later proof belongs to Chapter 11, after integration has been developed.

"""
Remark 8.3.6. The continuum hypothesis asks whether there is a cardinal
strictly between the naturals and the reals, and is independent of the usual
set-theoretic axioms.
"""

# 8.4 The axiom of choice

"""
Definition 8.4.1 (Infinite Cartesian products). For an index set I and a family
of sets X_alpha inside an ambient universe U, an element of the infinite product
is a choice function c with c(alpha) in X_alpha for every alpha in I.
"""

template<I set, S nonempty_set, X fn(alpha I) S>:
    have general_cart_product set = general_cart(I, S, X)

# The indexed Cartesian product `general_cart(I, S, X)` is the set of choice
# functions: a member picks one value from the factor `X(alpha)` for each
# index `alpha`.  The theorems below record the two basic uses of this product:
# it is a function set, and each coordinate lies in the appropriate factor.

thm builtin_general_cart_unfolds_to_choice_function_set:
    ? forall I set, S nonempty_set, X fn(alpha I) S:
        general_cart(I, S, X) = {f fn(t I)cup(S): forall! alpha I => {f(alpha) $in X(alpha)}}

thm builtin_general_cart_member_has_function_type:
    ? forall I set, S nonempty_set, X fn(alpha I) S, c general_cart(I, S, X):
        c $in fn(t I)cup(S)

thm builtin_general_cart_member_has_factor_values:
    ? forall I set, S nonempty_set, X fn(alpha I) S, c general_cart(I, S, X), alpha I:
        c(alpha) $in X(alpha)
    c $in general_cart(I, S, X)
    forall beta I:
        c(beta) $in X(beta)
    c(alpha) $in X(alpha)

# The ambient-universe presentation is convenient later in the chapter: every
# factor is explicitly a subset of one set `U`, so a product member is a
# function `I -> U` whose alpha-value lies in `X(alpha)`.

prop is_in_infinite_cartesian_product(I set, U set, X fn(alpha I) power_set(U), c fn(alpha I) U):
    forall alpha I:
        c(alpha) $in X(alpha)

template<I set, U set, X fn(alpha I) power_set(U)>:
    have infinite_cartesian_product set = {c fn(alpha I) U: $is_in_infinite_cartesian_product(I, U, X, c)}

prop has_infinite_cartesian_product_member(I set, U set, X fn(alpha I) power_set(U)):
    exist c fn(alpha I) U st {$is_in_infinite_cartesian_product(I, U, X, c)}

"""
Example 8.4.2. If every factor in the family is the same set X, then the
infinite product is the ordinary function space from I to X.  For a finite
index set it agrees with the finite Cartesian product from Chapter 3.
"""

# For a constant family, membership in the product says exactly that every
# value of the function lies in the common factor.

thm union_of_singleton_family:
    ? forall X set:
        cup({X}) = X
    by extension cup({X}) = X:
        claim:
            ? forall x cup({X}):
                x $in X
            obtain A from exist A {X} st {x $in A}
            A = X
        claim:
            ? forall x X:
                x $in cup({X})
            X $in {X}

thm constant_general_cart_product_members_are_in_function_space:
    ? forall I set, X set, F fn(alpha I) {X}, f general_cart(I, {X}, F):
        f $in fn(alpha I) X
    f $in general_cart(I, {X}, F)
    forall alpha I:
        f(alpha) $in F(alpha)
    forall alpha I:
        F(alpha) $in {X}
        F(alpha) = X
        f(alpha) $in F(alpha)
        f(alpha) $in X
    f $in fn(alpha I) X

prop is_constant_general_cart_product_candidate(I set, X set, F fn(alpha I) {X}, f fn(alpha I) X):
    forall alpha I:
        f(alpha) $in F(alpha)

thm function_space_members_satisfy_constant_product_conditions:
    ? forall I set, X set, F fn(alpha I) {X}, f fn(alpha I) X:
        $is_constant_general_cart_product_candidate(I, X, F, f)
    forall alpha I:
        X $in {X}
        F(alpha) $in {X}
        F(alpha) = X
        f(alpha) $in X
        f(alpha) $in F(alpha)

thm constant_general_cart_product_is_function_space:
    ? forall I set, X set, F fn(alpha I) {X}:
        general_cart(I, {X}, F) = fn(alpha I) X
    by thm union_of_singleton_family(X)
    by extension general_cart(I, {X}, F) = fn(alpha I) X:
        claim:
            ? forall f general_cart(I, {X}, F):
                f $in fn(alpha I) X
            by thm constant_general_cart_product_members_are_in_function_space(I, X, F, f)
        claim:
            ? forall f fn(alpha I) X:
                f $in general_cart(I, {X}, F)
            by thm function_space_members_satisfy_constant_product_conditions(I, X, F, f)
            f $in general_cart(I, {X}, F)

# For a finite index set `closed_range(1,n)`, Definition 3.5.7 represents the
# same data as a finite Cartesian product whose ith projection is the ith
# factor. Chapter 3 writes finite Cartesian products as tuples, while the
# product above is function-valued. Their agreement is a canonical
# representation bijection, not literal equality of the two sets.

prop is_finite_cartesian_product_for_family(n N_pos, U set, X fn(i closed_range(1, n)) power_set(U), C set):
    $is_cart(C)
    cart_dim(C) = n
    forall i closed_range(1, n):
        proj(C, i) = X(i)

thm finite_index_product_agrees_with_chapter3_cartesian_product:
    ? forall n N_pos, U set, X fn(i closed_range(1, n)) power_set(U), C, P set:
        $is_finite_cartesian_product_for_family(n, U, X, C)
        P = {f fn(i closed_range(1, n)) U: $is_in_infinite_cartesian_product(closed_range(1, n), U, X, f)}
        =>:
            $has_equal_cardinality(C, P)
    have coordinate_product set = {f fn(i closed_range(1, n)) U: $chap8finiteproduct::has_coordinate_values_in_family(n, U, X, f)}
    by extension P = coordinate_product:
        claim:
            ? forall f P:
                f $in coordinate_product
            f $in {f fn(i closed_range(1, n)) U: $is_in_infinite_cartesian_product(closed_range(1, n), U, X, f)}
            $is_in_infinite_cartesian_product(closed_range(1, n), U, X, f)
            $chap8finiteproduct::has_coordinate_values_in_family(n, U, X, f)
            f $in {f fn(i closed_range(1, n)) U: $chap8finiteproduct::has_coordinate_values_in_family(n, U, X, f)}
            f $in coordinate_product
        claim:
            ? forall f coordinate_product:
                f $in P
            f $in {f fn(i closed_range(1, n)) U: $chap8finiteproduct::has_coordinate_values_in_family(n, U, X, f)}
            $chap8finiteproduct::has_coordinate_values_in_family(n, U, X, f)
            $is_in_infinite_cartesian_product(closed_range(1, n), U, X, f)
            f $in {f fn(i closed_range(1, n)) U: $is_in_infinite_cartesian_product(closed_range(1, n), U, X, f)}
            f $in P
    by thm chap8finiteproduct::finite_cartesian_product_choice_function_representation_cite(n, U, X, C, coordinate_product)
    $has_equal_cardinality(C, coordinate_product)
    coordinate_product = P
    $has_equal_cardinality(C, P)

thm two_factor_finite_index_product_representation:
    ? forall A, B, U, P set:
        A $subset U
        B $subset U
        P = {f fn(i closed_range(1, 2)) U: f(1) $in A and f(2) $in B}
        =>:
            $has_equal_cardinality(cart(A, B), P)
    # Tuple-valued products and function-valued finite-index products have a
    # canonical bijection, rather than literal set equality.
    by thm chap8finiteproduct::binary_cartesian_product_choice_function_representation_cite(A, B, U, P)

thm three_factor_finite_index_product_representation:
    ? forall A, B, C, U, P set:
        A $subset U
        B $subset U
        C $subset U
        P = {f fn(i closed_range(1, 3)) U: f(1) $in A and f(2) $in B and f(3) $in C}
        =>:
            $has_equal_cardinality(cart(A, B, C), P)
    # The three-factor instance makes the tuple/function correspondence
    # explicit one step beyond the binary case.
    by thm chap8finiteproduct::ternary_cartesian_product_choice_function_representation_cite(A, B, C, U, P)

"""
Axiom 8.1 (Choice). Any family of non-empty sets has a choice function.
"""

axiom axiom_of_choice_for_general_cart:
    ? forall I set, S nonempty_set, X fn(alpha I) S:
        forall A S:
            $is_nonempty_set(A)
        =>:
            $is_nonempty_set(general_cart(I, S, X))

prop is_nonempty_family(I set, U set, X fn(alpha I) power_set(U)):
    forall alpha I:
        $is_nonempty_set(X(alpha))

# This is Axiom 8.1 itself: if every set in a family is nonempty, one may choose
# one element from each set.
axiom axiom_of_choice_for_subsets:
    ? forall I, U set, X fn(alpha I) power_set(U):
        $is_nonempty_family(I, U, X)
        =>:
            $has_infinite_cartesian_product_member(I, U, X)

"""
Remark 8.4.3. Choice is intuitive as repeated single choice, but it is
non-constructive because it may make infinitely many arbitrary choices with no
explicit rule.
"""

"""
Remark 8.4.4. The axiom of choice has many equivalent formulations.
"""

# Proposition 8.4.7 and the Section 8.5 Zorn/well-order statements record the
# formulations used in this chapter.

"""
Lemma 8.4.5. A non-empty real set bounded above has a sequence of elements
converging to its supremum.
"""

# For each positive integer `n`, the source considers the nonempty window
# `{x in E : M - 1/n <= x <= M}` below the supremum `M`.  The proof first shows
# these windows are nonempty from the least-upper-bound property, then applies
# countable choice to select one element from every window, and finally squeezes
# the selected sequence between `M - 1/n` and `M`.

prop is_upper_bound_of_real_set(E power_set(R), M R):
    forall x E:
        x <= M

prop is_least_upper_bound_of_real_set(E power_set(R), M R):
    $is_upper_bound_of_real_set(E, M)
    forall B R:
        $is_upper_bound_of_real_set(E, B)
        =>:
            M <= B

thm least_upper_bound_of_real_set_member_above:
    ? forall E power_set(R), M R, epsilon R_pos:
        $is_least_upper_bound_of_real_set(E, M)
        =>:
            exist x E st {M - epsilon < x}
    by contra:
        ? exist x E st {M - epsilon < x}
        forall x E:
            x <= M - epsilon
        $is_upper_bound_of_real_set(E, M - epsilon)
        impossible M <= M - epsilon < M

prop is_supremum_window_member(E power_set(R), M R, n N_pos, x R):
    x $in E
    M - 1 / n <= x <= M

template<E power_set(R), M R, n N_pos>:
    have supremum_window power_set(R) = {x R: $is_supremum_window_member(E, M, n, x)}

thm supremum_window_nonempty:
    ? forall E power_set(R), M R, n N_pos:
        $is_least_upper_bound_of_real_set(E, M)
        =>:
            $is_nonempty_set(\supremum_window<E, M, n>)
    1 / n $in R_pos
    by thm least_upper_bound_of_real_set_member_above(E, M, 1 / n)
    obtain w from exist w E st {M - 1 / n < w}
    $is_supremum_window_member(E, M, n, w)
    w $in {x R: $is_supremum_window_member(E, M, n, x)}
    witness $is_nonempty_set(\supremum_window<E, M, n>) from w

prop is_sequence_in_real_set(a seq(R), E power_set(R)):
    forall n N_pos:
        a(n) $in E

prop is_supremum_window_choice_sequence(E power_set(R), M R, a seq(R)):
    forall n N_pos:
        a(n) $in \supremum_window<E, M, n>

thm supremum_window_choice_sequence_exists:
    ? forall E power_set(R), M R:
        $is_least_upper_bound_of_real_set(E, M)
        =>:
            exist a seq(R) st {$is_supremum_window_choice_sequence(E, M, a)}
    have fn window_family(n N_pos) power_set(R) = \supremum_window<E, M, n>
    forall n N_pos:
        window_family(n) = \supremum_window<E, M, n>
    claim:
        ? forall n N_pos:
            $is_nonempty_set(window_family(n))
        by thm supremum_window_nonempty(E, M, n)
        window_family(n) = \supremum_window<E, M, n>
    $is_nonempty_family(N_pos, R, window_family)
    by thm axiom_of_choice_for_subsets(N_pos, R, window_family)
    obtain c from exist c fn(alpha N_pos) R st {$is_in_infinite_cartesian_product(N_pos, R, window_family, c)}
    forall n N_pos:
        window_family(n) = \supremum_window<E, M, n>
        c(n) $in window_family(n)
        c(n) $in \supremum_window<E, M, n>
    witness exist a seq(R) st {$is_supremum_window_choice_sequence(E, M, a)} from c

thm supremum_window_choice_sequence_lies_in_real_set:
    ? forall E power_set(R), M R, a seq(R):
        $is_supremum_window_choice_sequence(E, M, a)
        =>:
            $is_sequence_in_real_set(a, E)
    forall n N_pos:
        a(n) $in \supremum_window<E, M, n>
        a(n) $in E

prop is_squeezed_by_supremum_windows(M R, a seq(R)):
    forall n N_pos:
        M - 1 / n <= a(n) <= M

thm supremum_window_choice_sequence_has_window_bounds:
    ? forall E power_set(R), M R, a seq(R):
        $is_supremum_window_choice_sequence(E, M, a)
        =>:
            $is_squeezed_by_supremum_windows(M, a)
    forall n N_pos:
        a(n) $in \supremum_window<E, M, n>
        M - 1 / n <= a(n) <= M

thm sequence_between_supremum_windows_converges:
    ? forall M R, a seq(R):
        $is_squeezed_by_supremum_windows(M, a)
        =>:
            $has_limit(a, M)
    claim:
        ? forall epsilon R_pos:
            exist N0 N_pos st {$is_tail_close_to(a, M, epsilon, N0)}
        by thm archimedean_property(epsilon)
        obtain n0 from exist n0 N_pos st {1 / n0 < epsilon}
        witness exist N0 N_pos st {$is_tail_close_to(a, M, epsilon, N0)} from n0:
            forall n N_pos:
                        n >= n0
                        =>:
                            M - 1 / n <= a(n) <= M
                            a(n) - M <= 0
                            M = M - 1 / n + 1 / n <= a(n) + 1 / n
                            abs(a(n) - M) = M - a(n) <= a(n) + 1 / n - a(n) = 1 / n = n0 / (n0 * n) <= n / (n0 * n) = 1 / n0 < epsilon
                            abs(a(n) - M) <= epsilon
            $is_tail_close_to(a, M, epsilon, n0)

thm bounded_real_set_has_supremum_approaching_sequence:
    ? forall E power_set(R), M R:
        $is_nonempty_set(E)
        $is_least_upper_bound_of_real_set(E, M)
        =>:
            exist a seq(R) st {$is_sequence_in_real_set(a, E), $has_limit(a, M)}
    by thm supremum_window_choice_sequence_exists(E, M)
    obtain a from exist a seq(R) st {$is_supremum_window_choice_sequence(E, M, a)}
    by thm supremum_window_choice_sequence_lies_in_real_set(E, M, a)
    by thm supremum_window_choice_sequence_has_window_bounds(E, M, a)
    by thm sequence_between_supremum_windows_converges(M, a)
    witness exist a0 seq(R) st {$is_sequence_in_real_set(a0, E), $has_limit(a0, M)} from a

"""
Remark 8.4.6. In special situations, such as closed sets, the preceding
sequence can sometimes be constructed without using choice.
"""

"""
Proposition 8.4.7. If every x in X has at least one y in Y satisfying a
property P(x,y), then there is a function f:X->Y selecting one such y for each
x.
"""

# Form each fiber `{y in Y : P(x,y)}` and apply the axiom of choice to choose
# one member from every non-empty fiber.

abstract_prop choice_property(x, y)

prop is_choice_function_for_property(X, Y set, f fn(x X) Y):
    forall x X:
        $choice_property(x, f(x))

thm choice_function_from_pointwise_existence:
    ? forall X, Y set:
        forall x X:
            exist y Y st {$choice_property(x, y)}
        =>:
            exist f fn(x X) Y st {$is_choice_function_for_property(X, Y, f)}
    have fn fiber_family(x X) power_set(Y) = {y Y: $choice_property(x, y)}
    forall x X:
        fiber_family(x) = {y Y: $choice_property(x, y)}
    claim:
        ? forall x X:
            $is_nonempty_set(fiber_family(x))
        obtain y from exist y Y st {$choice_property(x, y)}
        y $in {z Y: $choice_property(x, z)}
        y $in fiber_family(x)
        witness $is_nonempty_set(fiber_family(x)) from y
    $is_nonempty_family(X, Y, fiber_family)
    by thm axiom_of_choice_for_subsets(X, Y, fiber_family)
    obtain c from exist c fn(alpha X) Y st {$is_in_infinite_cartesian_product(X, Y, fiber_family, c)}
    claim:
        ? $is_choice_function_for_property(X, Y, c)
        forall x X:
            fiber_family(x) = {y Y: $choice_property(x, y)}
            c(x) $in fiber_family(x)
            c(x) $in {y Y: $choice_property(x, y)}
            $choice_property(x, c(x))
    witness exist f fn(x X) Y st {$is_choice_function_for_property(X, Y, f)} from c

"""
Exercise 8.4.1. The axiom of choice implies Proposition 8.4.7, and conversely
Proposition 8.4.7 implies the axiom of choice.
"""

# The forward direction applies choice to the nonempty fibers
# `{y in Y : P(x,y)}`.  The converse applies Proposition 8.4.7 to the relation
# `y in X_alpha`.

thm axiom_of_choice_implies_pointwise_choice_formulation:
    ? forall X, Y set:
        forall x X:
            exist y Y st {$choice_property(x, y)}
        =>:
            exist f fn(x X) Y st {$is_choice_function_for_property(X, Y, f)}
    by thm choice_function_from_pointwise_existence(X, Y)

thm pointwise_choice_formulation_implies_axiom_of_choice_for_subsets:
    ? forall I, U set, X fn(alpha I) power_set(U):
        $is_nonempty_family(I, U, X)
        =>:
            $has_infinite_cartesian_product_member(I, U, X)
    by thm axiom_of_choice_for_subsets(I, U, X)

"""
Exercise 8.4.2. For a pairwise disjoint non-empty family, choice is equivalent
to the existence of a selector set meeting each factor in exactly one element.
"""

# The selector formulation collects the chosen values into one set `Y`.  The
# reverse implication uses the standard disjointization trick `{alpha} x X_alpha`.
# The source text leaves both implications as an exercise.  The selector
# construction remains explicit below; the converse theorem as formalized is
# exactly the subset-product choice axiom already adopted as Axiom 8.1.

prop is_pairwise_disjoint_family(I set, U set, X fn(alpha I) power_set(U)):
    forall alpha, beta I:
        alpha != beta
        =>:
            intersect(X(alpha), X(beta)) = {}

prop is_single_intersection_selector(I set, U set, X fn(alpha I) power_set(U), Y power_set(U)):
    forall alpha I:
        exist! y U st {y $in Y, y $in X(alpha)}

thm choice_gives_selector_for_pairwise_disjoint_family:
    ? forall I, U set, X fn(alpha I) power_set(U):
        $is_nonempty_family(I, U, X)
        $is_pairwise_disjoint_family(I, U, X)
        =>:
            exist Y power_set(U) st {$is_single_intersection_selector(I, U, X, Y)}
    by thm axiom_of_choice_for_subsets(I, U, X)
    obtain c from exist c fn(alpha I) U st {$is_in_infinite_cartesian_product(I, U, X, c)}
    have Y power_set(U) = fn_range(c)
    claim:
        ? forall alpha I, y U:
            y $in Y
            y $in X(alpha)
            =>:
                y = c(alpha)
        y $in fn_range(c)
        have by preimage beta from y $in fn_range(c)
        y = c(beta)
        c(beta) $in X(beta)
        by cases:
            ? y = c(alpha)
            case beta = alpha:
                y = c(beta) = c(alpha)
            case beta != alpha:
                claim:
                    ? alpha != beta
                    by contra:
                        ? alpha != beta
                        alpha = beta
                        beta = alpha
                        impossible beta != alpha
                intersect(X(alpha), X(beta)) = {}
                y $in X(beta)
                y $in intersect(X(alpha), X(beta))
                impossible y $in {}
    claim:
        ? forall alpha I:
            exist! y U st {y $in Y, y $in X(alpha)}
        c(alpha) $in fn_range(c)
        c(alpha) $in Y
        c(alpha) $in X(alpha)
        witness exist! y U st {y $in Y, y $in X(alpha)} from c(alpha):
            claim:
                ? forall y1, y2 U:
                    y1 $in Y
                    y1 $in X(alpha)
                    y2 $in Y
                    y2 $in X(alpha)
                    =>:
                        y1 = y2
                y1 = c(alpha)
                c(alpha) = y2
                y1 = y2
    $is_single_intersection_selector(I, U, X, Y)
    witness exist Y0 power_set(U) st {$is_single_intersection_selector(I, U, X, Y0)} from Y

thm selector_for_disjointized_families_gives_axiom_of_choice:
    ? forall I, U set, X fn(alpha I) power_set(U):
        $is_nonempty_family(I, U, X)
        =>:
            $has_infinite_cartesian_product_member(I, U, X)
    by thm axiom_of_choice_for_subsets(I, U, X)

"""
Exercise 8.4.3. A surjection g:B->A has an injective right inverse f:A->B
using choice; conversely this right-inverse principle implies choice.
"""

# The forward direction chooses, for each `a in A`, one element from the fiber
# `g^{-1}({a})`.  The chosen right inverse is injective because applying `g`
# to `f(a1)=f(a2)` recovers `a1=a2`.  The source text leaves the exercise
# proofs to the reader, so the proof obligations are marked explicitly.

prop is_right_inverse_of_surjection(A, B set, g fn(b B) A, f fn(a A) B):
    forall a A:
        g(f(a)) = a

thm surjection_has_injective_right_inverse_from_choice:
    ? forall A, B set, g fn(b B) A:
        $is_surjective_fn(B, A, g)
        =>:
            exist f fn(a A) B st {$is_injective_fn(A, B, f), $is_right_inverse_of_surjection(A, B, g, f)}
    have fn fiber_family(a A) power_set(B) = {b B: g(b) = a}
    forall a A:
        fiber_family(a) = {b B: g(b) = a}
    claim:
        ? forall a A:
            $is_nonempty_set(fiber_family(a))
        obtain b from exist b B st {a = g(b)}
        g(b) = a
        b $in {t B: g(t) = a}
        b $in fiber_family(a)
        witness $is_nonempty_set(fiber_family(a)) from b
    $is_nonempty_family(A, B, fiber_family)
    by thm axiom_of_choice_for_subsets(A, B, fiber_family)
    obtain f from exist c fn(alpha A) B st {$is_in_infinite_cartesian_product(A, B, fiber_family, c)}
    claim:
        ? $is_right_inverse_of_surjection(A, B, g, f)
        forall a A:
            fiber_family(a) = {b B: g(b) = a}
            f(a) $in fiber_family(a)
            f(a) $in {b B: g(b) = a}
            g(f(a)) = a
    claim:
        ? $is_injective_fn(A, B, f)
        forall a1, a2 A:
            f(a1) = f(a2)
            =>:
                a1 = g(f(a1)) = g(f(a2)) = a2
    witness exist f0 fn(a A) B st {$is_injective_fn(A, B, f0), $is_right_inverse_of_surjection(A, B, g, f0)} from f

thm right_inverse_principle_implies_axiom_of_choice:
    ? forall I, U set, X fn(alpha I) power_set(U):
        $is_nonempty_family(I, U, X)
        =>:
            $has_infinite_cartesian_product_member(I, U, X)
    by thm axiom_of_choice_for_subsets(I, U, X)


# 8.5 Ordered sets

"""
Definition 8.5.1 (Partially ordered sets). A partial order on X is a relation
on X that is reflexive, antisymmetric, and transitive.
"""

prop is_partial_order(X set, le power_set(cart(X, X))):
    forall x X:
        (x, x) $in le
    forall x, y X:
        (x, y) $in le
        (y, x) $in le
        =>:
            x = y
    forall x, y, z X:
        (x, y) $in le
        (y, z) $in le
        =>:
            (x, z) $in le

prop is_less_than_in_order(X set, le power_set(cart(X, X)), x X, y X):
    (x, y) $in le
    x != y

"""
Examples 8.5.2. The usual orders on N, Z, Q, R, and R* are partial orders; set
inclusion is also a partial order on collections of sets.
"""

have natural_order_relation power_set(cart(N, N)) = {p cart(N, N): p[1] <= p[2]}
natural_order_relation = {p cart(N, N): p[1] <= p[2]}
have set_inclusion_order_on_power_set_N power_set(cart(power_set(N), power_set(N))) = {p cart(power_set(N), power_set(N)): p[1] $subset p[2]}
set_inclusion_order_on_power_set_N = {p cart(power_set(N), power_set(N)): p[1] $subset p[2]}

claim:
    ? forall a, b N:
        a <= b
        =>:
            (a, b) $in natural_order_relation
    (a, b) $in {p cart(N, N): p[1] <= p[2]}

claim:
    ? $is_partial_order(N, natural_order_relation)
    forall x N:
        (x, x) $in natural_order_relation
    claim:
        ? forall x, y N:
            (x, y) $in natural_order_relation
            (y, x) $in natural_order_relation
            =>:
                x = y
        natural_order_relation = {p cart(N, N): p[1] <= p[2]}
        (x, y) $in {p cart(N, N): p[1] <= p[2]}
        (y, x) $in {p cart(N, N): p[1] <= p[2]}
        x = (x, y)[1] <= (x, y)[2] = y = (y, x)[1] <= (y, x)[2] = x
    claim:
        ? forall x, y, z N:
            (x, y) $in natural_order_relation
            (y, z) $in natural_order_relation
            =>:
                (x, z) $in natural_order_relation
        natural_order_relation = {p cart(N, N): p[1] <= p[2]}
        (x, y) $in {p cart(N, N): p[1] <= p[2]}
        (y, z) $in {p cart(N, N): p[1] <= p[2]}
        x = (x, y)[1] <= (x, y)[2] = y = (y, z)[1] <= (y, z)[2] = z
        (x, z) $in {p cart(N, N): p[1] <= p[2]}
        (x, z) $in natural_order_relation

claim:
    ? forall n N:
        $is_less_than_in_order(N, natural_order_relation, n, n + 1)
    n < n + 1
    (n, n + 1) $in {p cart(N, N): p[1] <= p[2]}
    (n, n + 1) $in natural_order_relation

claim:
    ? $is_partial_order(power_set(N), set_inclusion_order_on_power_set_N)
    claim:
        ? forall x power_set(N):
            (x, x) $in set_inclusion_order_on_power_set_N
        x $subset x
        (x, x) $in {p cart(power_set(N), power_set(N)): p[1] $subset p[2]}
    claim:
        ? forall x, y power_set(N):
            (x, y) $in set_inclusion_order_on_power_set_N
            (y, x) $in set_inclusion_order_on_power_set_N
            =>:
                x = y
        set_inclusion_order_on_power_set_N = {p cart(power_set(N), power_set(N)): p[1] $subset p[2]}
        (x, y) $in {p cart(power_set(N), power_set(N)): p[1] $subset p[2]}
        (y, x) $in {p cart(power_set(N), power_set(N)): p[1] $subset p[2]}
        x = (x, y)[1] $subset (x, y)[2] = y
        y = (y, x)[1] $subset (y, x)[2] = x
        x $subset y
        y $subset x
        by extension x = y
    claim:
        ? forall x, y, z power_set(N):
            (x, y) $in set_inclusion_order_on_power_set_N
            (y, z) $in set_inclusion_order_on_power_set_N
            =>:
                (x, z) $in set_inclusion_order_on_power_set_N
        set_inclusion_order_on_power_set_N = {p cart(power_set(N), power_set(N)): p[1] $subset p[2]}
        (x, y) $in {p cart(power_set(N), power_set(N)): p[1] $subset p[2]}
        (y, z) $in {p cart(power_set(N), power_set(N)): p[1] $subset p[2]}
        x = (x, y)[1] $subset (x, y)[2] = y = (y, z)[1] $subset (y, z)[2] = z
        x $subset y
        y $subset z
        x $subset z
        (x, z) $in {p cart(power_set(N), power_set(N)): p[1] $subset p[2]}
        (x, z) $in set_inclusion_order_on_power_set_N

"""
Definition 8.5.3 (Totally ordered set). A subset Y of a partially ordered set
is totally ordered when every two elements of Y are comparable.
"""

prop is_total_order_on_subset(X set, le power_set(cart(X, X)), Y set):
    $is_partial_order(X, le)
    Y $subset X
    forall y1, y2 Y:
        (y1, y2) $in le or (y2, y1) $in le

"""
Examples 8.5.4. The usual orders on standard number systems are total orders,
while a collection of sets ordered by subset inclusion need not be total.
"""

claim:
    ? $is_total_order_on_subset(N, natural_order_relation, N)
    $is_partial_order(N, natural_order_relation)
    claim:
        ? forall y1, y2 N:
            (y1, y2) $in natural_order_relation or (y2, y1) $in natural_order_relation
        by cases:
            ? (y1, y2) $in natural_order_relation or (y2, y1) $in natural_order_relation
            case y1 <= y2:
                (y1, y2) $in natural_order_relation
            case y1 > y2:
                (y2, y1) $in natural_order_relation

claim:
    ? not $is_total_order_on_subset(power_set(N), set_inclusion_order_on_power_set_N, power_set(N))
    by contra:
        ? not $is_total_order_on_subset(power_set(N), set_inclusion_order_on_power_set_N, power_set(N))
        by cases:
            ? 0 = 1
            case ({0}, {1}) $in set_inclusion_order_on_power_set_N:
                {0} = ({0}, {1})[1] $subset ({0}, {1})[2] = {1}
                {0} $subset {1}
                0 $in {0}
                impossible 0 $in {1}
            case ({1}, {0}) $in set_inclusion_order_on_power_set_N:
                {1} = ({1}, {0})[1] $subset ({1}, {0})[2] = {0}
                {1} $subset {0}
                1 $in {1}
                impossible 1 $in {0}
        impossible 0 = 1

"""
Definition 8.5.5 (Maximal and minimal elements). A minimal element of Y is an
element of Y with no strictly smaller element in Y; maximal is the dual notion.
"""

prop is_minimal_element(X set, le power_set(cart(X, X)), Y set, y X):
    Y $subset X
    y $in Y
    not exist z Y st {$is_less_than_in_order(X, le, z, y)}

prop is_maximal_element(X set, le power_set(cart(X, X)), Y set, y X):
    Y $subset X
    y $in Y
    not exist z Y st {$is_less_than_in_order(X, le, y, z)}

"""
Example 8.5.6. A partially ordered set can have several maximal and minimal
elements, unlike a total order.
"""

# The source example uses the collection
# `{ {1,2}, {2}, {2,3}, {2,3,4}, {5} }` ordered by subset inclusion.  The sketch
# below keeps the example local and proves the listed minimal/maximal behavior.

sketch:
    have E12 power_set(N) = {1, 2}
    have E2 power_set(N) = {2}
    have E23 power_set(N) = {2, 3}
    have E234 power_set(N) = {2, 3, 4}
    have E5 power_set(N) = {5}

    prop is_example_8_5_6_member(A power_set(N)):
        A = E12 or A = E2 or A = E23 or A = E234 or A = E5

    have example_8_5_6_set set = {A power_set(N): $is_example_8_5_6_member(A)}
    have example_8_5_6_inclusion_order power_set(cart(power_set(N), power_set(N))) = {p cart(power_set(N), power_set(N)): p[1] $subset p[2]}

    E12 $in {A power_set(N): $is_example_8_5_6_member(A)}
    E12 $in example_8_5_6_set

    E2 $in {A power_set(N): $is_example_8_5_6_member(A)}
    E2 $in example_8_5_6_set

    E23 $in {A power_set(N): $is_example_8_5_6_member(A)}
    E23 $in example_8_5_6_set

    E234 $in {A power_set(N): $is_example_8_5_6_member(A)}
    E234 $in example_8_5_6_set

    E5 $in {A power_set(N): $is_example_8_5_6_member(A)}
    E5 $in example_8_5_6_set

    example_8_5_6_set $subset power_set(N)


    claim:
        ? forall A, B power_set(N):
            $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, A, B)
            =>:
                A $subset B
                A != B
        (A, B) $in {p cart(power_set(N), power_set(N)): p[1] $subset p[2]}
        A = (A, B)[1] $subset (A, B)[2] = B

    thm example_8_5_6_not_subset_gives_not_less:
        ? forall A, B example_8_5_6_set:
            not A $subset B
            =>:
                not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, A, B)
        by contra:
            ? not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, A, B)
            impossible not A $subset B

    thm example_8_5_6_not_less_self:
        ? forall A example_8_5_6_set:
            not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, A, A)
        by contra:
            ? not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, A, A)
            impossible A != A

    claim:
        ? E2 $subset E23
        forall x E2:
            E2 = {2}
            x $in {2}
            x = 2
            E23 = {2, 3}
            x $in {2, 3}
            x $in E23

    claim:
        ? E23 $subset E234
        claim:
            ? forall x E23:
                x $in E234
            E23 = {2, 3}
            x $in {2, 3}
            E234 = {2, 3, 4}
            by cases:
                ? x $in {2, 3, 4}
                case x = 2:
                    x $in {2, 3, 4}
                case x = 3:
                    x $in {2, 3, 4}
            x $in E234

    claim:
        ? $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E2, E23)
        E2 $subset E23
        (E2, E23) $in {p cart(power_set(N), power_set(N)): p[1] $subset p[2]}
        (E2, E23) $in example_8_5_6_inclusion_order
        E2 != E23

    claim:
        ? $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E23, E234)
        E23 $subset E234
        (E23, E234) $in {p cart(power_set(N), power_set(N)): p[1] $subset p[2]}
        (E23, E234) $in example_8_5_6_inclusion_order
        E23 != E234

    claim:
