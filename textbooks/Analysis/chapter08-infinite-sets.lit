                by thm example_8_5_6_not_subset_gives_not_less(E23, E2)
            case z = E234:
                by thm example_8_5_6_not_subset_gives_not_less(E234, E2)
            case z = E5:
                by thm example_8_5_6_not_subset_gives_not_less(E5, E2)

    claim:
