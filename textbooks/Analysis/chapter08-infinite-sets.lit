            case z = E234:
                by thm example_8_5_6_not_subset_gives_not_less(E234, E5)
            case z = E5:
                by thm example_8_5_6_not_less_self(E5)

    claim:
        ? forall z example_8_5_6_set:
            not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E12, z)
        by cases:
            ? not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E12, z)
            case z = E12:
                by thm example_8_5_6_not_less_self(E12)
            case z = E2:
                by thm example_8_5_6_not_subset_gives_not_less(E12, E2)
            case z = E23:
                by thm example_8_5_6_not_subset_gives_not_less(E12, E23)
            case z = E234:
                by thm example_8_5_6_not_subset_gives_not_less(E12, E234)
            case z = E5:
                by thm example_8_5_6_not_subset_gives_not_less(E12, E5)

    claim:
        ? forall z example_8_5_6_set:
            not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E234, z)
        by cases:
            ? not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E234, z)
            case z = E12:
                by thm example_8_5_6_not_subset_gives_not_less(E234, E12)
            case z = E2:
                by thm example_8_5_6_not_subset_gives_not_less(E234, E2)
            case z = E23:
                by thm example_8_5_6_not_subset_gives_not_less(E234, E23)
            case z = E234:
                by thm example_8_5_6_not_less_self(E234)
            case z = E5:
                by thm example_8_5_6_not_subset_gives_not_less(E234, E5)

    claim:
        ? forall z example_8_5_6_set:
            not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E5, z)
        by cases:
            ? not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E5, z)
            case z = E12:
                by thm example_8_5_6_not_subset_gives_not_less(E5, E12)
            case z = E2:
                by thm example_8_5_6_not_subset_gives_not_less(E5, E2)
            case z = E23:
                by thm example_8_5_6_not_subset_gives_not_less(E5, E23)
            case z = E234:
                by thm example_8_5_6_not_subset_gives_not_less(E5, E234)
            case z = E5:
                by thm example_8_5_6_not_less_self(E5)

    claim:
        ? $is_minimal_element(power_set(N), example_8_5_6_inclusion_order, example_8_5_6_set, E2)
        by contra:
            ? not exist z example_8_5_6_set st {$is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, z, E2)}
            obtain z from exist z example_8_5_6_set st {$is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, z, E2)}
            impossible not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, z, E2)

    claim:
        ? $is_minimal_element(power_set(N), example_8_5_6_inclusion_order, example_8_5_6_set, E5)
        by contra:
            ? not exist z example_8_5_6_set st {$is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, z, E5)}
            obtain z from exist z example_8_5_6_set st {$is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, z, E5)}
            impossible not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, z, E5)

    claim:
        ? $is_maximal_element(power_set(N), example_8_5_6_inclusion_order, example_8_5_6_set, E12)
        by contra:
            ? not exist z example_8_5_6_set st {$is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E12, z)}
            obtain z from exist z example_8_5_6_set st {$is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E12, z)}
            impossible not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E12, z)

    claim:
        ? $is_maximal_element(power_set(N), example_8_5_6_inclusion_order, example_8_5_6_set, E234)
        by contra:
            ? not exist z example_8_5_6_set st {$is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E234, z)}
            obtain z from exist z example_8_5_6_set st {$is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E234, z)}
            impossible not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E234, z)

    claim:
        ? $is_maximal_element(power_set(N), example_8_5_6_inclusion_order, example_8_5_6_set, E5)
        by contra:
            ? not exist z example_8_5_6_set st {$is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E5, z)}
            obtain z from exist z example_8_5_6_set st {$is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E5, z)}
            impossible not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E5, z)

    claim:
        ? not $is_minimal_element(power_set(N), example_8_5_6_inclusion_order, example_8_5_6_set, E23)
        by contra:
            ? not $is_minimal_element(power_set(N), example_8_5_6_inclusion_order, example_8_5_6_set, E23)
            impossible not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E2, E23)

    claim:
        ? not $is_maximal_element(power_set(N), example_8_5_6_inclusion_order, example_8_5_6_set, E23)
        by contra:
            ? not $is_maximal_element(power_set(N), example_8_5_6_inclusion_order, example_8_5_6_set, E23)
            impossible not $is_less_than_in_order(power_set(N), example_8_5_6_inclusion_order, E23, E234)

"""
Example 8.5.7. The natural numbers have a minimal element and no maximal
element; the integers have neither a minimal nor a maximal element.
"""

claim:
    ? $is_minimal_element(N, natural_order_relation, N, 0)
    by contra:
        ? not exist z N st {$is_less_than_in_order(N, natural_order_relation, z, 0)}
        obtain z from exist z N st {$is_less_than_in_order(N, natural_order_relation, z, 0)}
        z = (z, 0)[1] <= (z, 0)[2] = 0
        impossible z != 0

claim:
    ? not exist n N st {$is_maximal_element(N, natural_order_relation, N, n)}
    by contra:
        ? not exist n N st {$is_maximal_element(N, natural_order_relation, N, n)}
        obtain n from exist n N st {$is_maximal_element(N, natural_order_relation, N, n)}
        impossible not $is_less_than_in_order(N, natural_order_relation, n, n + 1)

"""
Definition 8.5.8 (Well-ordered sets). A totally ordered subset is well-ordered
when every non-empty subset has a minimal element.
"""

prop is_well_ordered_subset(X set, le power_set(cart(X, X)), Y set):
    $is_total_order_on_subset(X, le, Y)
    forall A power_set(Y):
        $is_nonempty_set(A)
        =>:
            exist m X st {$is_minimal_element(X, le, A, m)}

"""
Examples 8.5.9. The natural numbers are well-ordered; the integers, rationals,
and reals are not.  Every finite total order is well-ordered, and every subset
of a well-ordered set is well-ordered.
"""

# Natural-number well-ordering is Proposition 8.1.4 in relation form.  The
# `Z`, `Q`, and `R` examples use explicit descending witnesses.  The finite
# total order clause is Exercise 8.5.8 in the source text.

claim:
    ? $is_well_ordered_subset(N, natural_order_relation, N)
    $is_total_order_on_subset(N, natural_order_relation, N)
    claim:
        ? forall A power_set(N):
            $is_nonempty_set(A)
            =>:
                exist m N st {$is_minimal_element(N, natural_order_relation, A, m)}
        by thm natural_subset_has_unique_minimum(A)
        obtain n from exist n N st {$is_minimum_of_natural_subset(A, n)}
        claim:
            ? not exist z A st {$is_less_than_in_order(N, natural_order_relation, z, n)}
            by contra:
                ? not exist z A st {$is_less_than_in_order(N, natural_order_relation, z, n)}
                obtain z from exist z A st {$is_less_than_in_order(N, natural_order_relation, z, n)}
                z = (z, n)[1] <= (z, n)[2] = n <= z
                impossible z != n
        witness exist m N st {$is_minimal_element(N, natural_order_relation, A, m)} from n

have integer_order_relation power_set(cart(Z, Z)) = {p cart(Z, Z): p[1] <= p[2]}
have rational_order_relation power_set(cart(Q, Q)) = {p cart(Q, Q): p[1] <= p[2]}
have real_line_order_relation power_set(cart(R, R)) = {p cart(R, R): p[1] <= p[2]}

claim:
    ? forall z Z:
        $is_less_than_in_order(Z, integer_order_relation, z - 1, z)
    z - 1 < z
    (z - 1, z) $in {p cart(Z, Z): p[1] <= p[2]}

claim:
    ? forall q Q:
        $is_less_than_in_order(Q, rational_order_relation, q - 1, q)
    q - 1 < q
    (q - 1, q) $in {p cart(Q, Q): p[1] <= p[2]}

claim:
    ? forall x R:
        $is_less_than_in_order(R, real_line_order_relation, x - 1, x)
    x - 1 < x
    (x - 1, x) $in {p cart(R, R): p[1] <= p[2]}

claim:
    ? not $is_well_ordered_subset(Z, integer_order_relation, Z)
    by contra:
        ? not $is_well_ordered_subset(Z, integer_order_relation, Z)
        obtain m from exist m Z st {$is_minimal_element(Z, integer_order_relation, Z, m)}
        impossible not $is_less_than_in_order(Z, integer_order_relation, m - 1, m)

claim:
    ? not $is_well_ordered_subset(Q, rational_order_relation, Q)
    by contra:
        ? not $is_well_ordered_subset(Q, rational_order_relation, Q)
        obtain m from exist m Q st {$is_minimal_element(Q, rational_order_relation, Q, m)}
        impossible not $is_less_than_in_order(Q, rational_order_relation, m - 1, m)

claim:
    ? not $is_well_ordered_subset(R, real_line_order_relation, R)
    by contra:
        ? not $is_well_ordered_subset(R, real_line_order_relation, R)
        obtain m from exist m R st {$is_minimal_element(R, real_line_order_relation, R, m)}
        impossible not $is_less_than_in_order(R, real_line_order_relation, m - 1, m)

claim:
    ? forall X finite_set, le power_set(cart(X, X)):
        $is_total_order_on_subset(X, le, X)
        =>:
            $is_well_ordered_subset(X, le, X)
    trust $is_well_ordered_subset(X, le, X)

claim:
    ? forall X set, le power_set(cart(X, X)), Y set:
        $is_well_ordered_subset(X, le, X)
        Y $subset X
        =>:
            $is_well_ordered_subset(X, le, Y)
    $is_total_order_on_subset(X, le, X)
    claim:
        ? $is_total_order_on_subset(X, le, Y)
        $is_partial_order(X, le)
        forall y1, y2 Y:
            (y1, y2) $in le or (y2, y1) $in le
    claim:
        ? forall A power_set(Y):
            $is_nonempty_set(A)
            =>:
                exist m X st {$is_minimal_element(X, le, A, m)}
        A $subset X
        obtain m from exist m X st {$is_minimal_element(X, le, A, m)}
        witness exist m X st {$is_minimal_element(X, le, A, m)} from m

"""
Proposition 8.5.10 (Principle of strong induction). On a well-ordered set, if
every element follows from all smaller elements, then the property holds for
all elements.
"""

# If the property failed somewhere, the set of counterexamples would have a
# least element, contradicting the induction step from all smaller elements.

abstract_prop well_order_induction_property(x)

prop has_well_order_induction_step(X set, le power_set(cart(X, X))):
    forall n X:
        forall m X:
            $is_less_than_in_order(X, le, m, n)
            =>:
                $well_order_induction_property(m)
        =>:
            $well_order_induction_property(n)

prop well_order_induction_property_holds_on(X set):
    forall n X:
        $well_order_induction_property(n)

thm well_order_induction_step_apply:
    ? forall X set, le power_set(cart(X, X)), n X:
        $has_well_order_induction_step(X, le)
        forall m X:
            $is_less_than_in_order(X, le, m, n)
            =>:
                $well_order_induction_property(m)
        =>:
            $well_order_induction_property(n)
    $has_well_order_induction_step(X, le)
    forall m X:
        $is_less_than_in_order(X, le, m, n)
        =>:
            $well_order_induction_property(m)
    $well_order_induction_property(n)

thm well_order_strong_induction:
    ? forall X set, le power_set(cart(X, X)):
        $is_well_ordered_subset(X, le, X)
        $has_well_order_induction_step(X, le)
        =>:
            $well_order_induction_property_holds_on(X)
    by contra:
        ? $well_order_induction_property_holds_on(X)
        not $well_order_induction_property_holds_on(X)
        have bad power_set(X) = {n X: not $well_order_induction_property(n)}
        claim:
            ? $is_nonempty_set(bad)
            by contra:
                ? $is_nonempty_set(bad)
                not $is_nonempty_set(bad)
                claim:
                    ? forall n X:
                        $well_order_induction_property(n)
                    by contra:
                        ? $well_order_induction_property(n)
                        not $well_order_induction_property(n)
                        n $in {t X: not $well_order_induction_property(t)}
                        n $in bad
                        witness $is_nonempty_set(bad) from n
                        impossible $is_nonempty_set(bad)
                $well_order_induction_property_holds_on(X)
                impossible not $well_order_induction_property_holds_on(X)
        obtain m from exist m X st {$is_minimal_element(X, le, bad, m)}
        m $in bad
        not $well_order_induction_property(m)
        claim:
            ? forall z X:
                $is_less_than_in_order(X, le, z, m)
                =>:
                    $well_order_induction_property(z)
            by contra:
                ? $well_order_induction_property(z)
                not $well_order_induction_property(z)
                z $in {t X: not $well_order_induction_property(t)}
                z $in bad
                impossible $is_less_than_in_order(X, le, z, m)
        by thm well_order_induction_step_apply(X, le, m)
        impossible not $well_order_induction_property(m)

"""
Remark 8.5.11. The base case in strong induction is implicit: at a minimal
element there are no smaller counterexamples to assume.
"""

# The remark is recorded by the structure of `has_well_order_induction_step`.

"""
Definition 8.5.12 (Upper bounds and strict upper bounds). An upper bound of Y
is an element above every element of Y.  A strict upper bound is an upper bound
which is not itself in Y, equivalently it is strictly above every element of Y.
"""

prop is_upper_bound(X set, le power_set(cart(X, X)), Y set, x X):
    Y $subset X
    forall y Y:
        (y, x) $in le

prop is_strict_upper_bound(X set, le power_set(cart(X, X)), Y set, x X):
    $is_upper_bound(X, le, Y, x)
    not x $in Y

thm strict_upper_bound_equivalence:
    ? forall X set, le power_set(cart(X, X)), Y set, x X, z Y:
        $is_partial_order(X, le)
        $is_strict_upper_bound(X, le, Y, x)
        =>:
            $is_less_than_in_order(X, le, z, x)
    by contra:
        ? z != x
        impossible not x $in Y

"""
Example 8.5.13. In the usual order on R, 2 is an upper bound but not a strict
upper bound for [1,2], while 3 is a strict upper bound.
"""

have real_order_relation power_set(cart(R, R)) = {p cart(R, R): p[1] <= p[2]}

claim:
    ? $is_upper_bound(R, real_order_relation, closed_range(1, 2), 2)
    claim:
        ? forall y closed_range(1, 2):
            (y, 2) $in real_order_relation
        (y, 2) $in {p cart(R, R): p[1] <= p[2]}

claim:
    ? $is_strict_upper_bound(R, real_order_relation, closed_range(1, 2), 3)
    claim:
        ? forall y closed_range(1, 2):
            (y, 3) $in real_order_relation
        y <= 2 <= 3
        (y, 3) $in {p cart(R, R): p[1] <= p[2]}
    claim:
        ? not 3 $in closed_range(1, 2)
        by contra:
            ? not 3 $in closed_range(1, 2)
            impossible 3 <= 2

"""
Lemma 8.5.14. Starting from x0 in a partially ordered set, there is a
well-ordered subset with x0 as its minimal element and no strict upper bound.
"""

# Choose one strict upper bound for each well-ordered chain. A chain is good
# when each non-initial point is the chosen upper bound of its initial segment;
# the union of all good chains is then the candidate maximal chain.

prop is_well_ordered_chain_with_minimum(X set, le power_set(cart(X, X)), x0 X, Y set):
    Y $subset X
    $is_well_ordered_subset(X, le, Y)
    $is_minimal_element(X, le, Y, x0)

prop has_strict_upper_bound(X set, le power_set(cart(X, X)), Y set):
    exist u X st {$is_strict_upper_bound(X, le, Y, u)}

thm subset_member_of_power_set:
    ? forall X, Y set:
        Y $subset X
        =>:
            Y $in power_set(X)

prop is_well_ordered_chain_from_without_strict_upper_bound(X set, le power_set(cart(X, X)), x0 X, Y set):
    $is_well_ordered_chain_with_minimum(X, le, x0, Y)
    not $has_strict_upper_bound(X, le, Y)

thm failed_target_gives_strict_upper_bound:
    ? forall X set, le power_set(cart(X, X)), x0 X, Y power_set(X):
        not exist W power_set(X) st {$is_well_ordered_chain_from_without_strict_upper_bound(X, le, x0, W)}
        $is_well_ordered_chain_with_minimum(X, le, x0, Y)
        =>:
            $has_strict_upper_bound(X, le, Y)
    by contra:
        ? $has_strict_upper_bound(X, le, Y)
        witness exist W power_set(X) st {$is_well_ordered_chain_from_without_strict_upper_bound(X, le, x0, W)} from Y
        impossible $is_well_ordered_chain_from_without_strict_upper_bound(X, le, x0, Y)

prop is_strict_upper_bound_choice_relation(X set, le power_set(cart(X, X)), x0 X, C power_set(cart(power_set(X), X))):
    forall Y power_set(X):
        $is_well_ordered_chain_with_minimum(X, le, x0, Y)
        =>:
            exist u X st {(Y, u) $in C, $is_strict_upper_bound(X, le, Y, u)}
    forall Y power_set(X), u X:
        (Y, u) $in C
        $is_well_ordered_chain_with_minimum(X, le, x0, Y)
        =>:
            $is_strict_upper_bound(X, le, Y, u)

thm strict_upper_bound_choice_relation_exists:
    ? forall X set, le power_set(cart(X, X)), x0 X:
        $is_partial_order(X, le)
        forall Y power_set(X):
            $is_well_ordered_chain_with_minimum(X, le, x0, Y)
            =>:
                $has_strict_upper_bound(X, le, Y)
        =>:
            exist C power_set(cart(power_set(X), X)) st {$is_strict_upper_bound_choice_relation(X, le, x0, C)}
    have fn upper_choice_family(Y power_set(X)) power_set(X) = {u X: not $is_well_ordered_chain_with_minimum(X, le, x0, Y) or $is_strict_upper_bound(X, le, Y, u)}
    forall Y power_set(X):
        upper_choice_family(Y) = {u X: not $is_well_ordered_chain_with_minimum(X, le, x0, Y) or $is_strict_upper_bound(X, le, Y, u)}
    claim:
        ? forall Y power_set(X):
            $is_nonempty_set(upper_choice_family(Y))
        by cases:
            ? $is_nonempty_set(upper_choice_family(Y))
            case $is_well_ordered_chain_with_minimum(X, le, x0, Y):
                $has_strict_upper_bound(X, le, Y)
                obtain u from exist u X st {$is_strict_upper_bound(X, le, Y, u)}
                witness $is_nonempty_set(upper_choice_family(Y)) from u
            case not $is_well_ordered_chain_with_minimum(X, le, x0, Y):
                witness $is_nonempty_set(upper_choice_family(Y)) from x0
    $is_nonempty_family(power_set(X), X, upper_choice_family)
    by thm axiom_of_choice_for_subsets(power_set(X), X, upper_choice_family)
    obtain s from exist c fn(alpha power_set(X)) X st {$is_in_infinite_cartesian_product(power_set(X), X, upper_choice_family, c)}
    have C power_set(cart(power_set(X), X)) = {p cart(power_set(X), X): p[2] = s(p[1])}
    claim:
        ? $is_strict_upper_bound_choice_relation(X, le, x0, C)
        claim:
            ? forall Y power_set(X):
                $is_well_ordered_chain_with_minimum(X, le, x0, Y)
                =>:
                    exist u X st {(Y, u) $in C, $is_strict_upper_bound(X, le, Y, u)}
            upper_choice_family(Y) = {u X: not $is_well_ordered_chain_with_minimum(X, le, x0, Y) or $is_strict_upper_bound(X, le, Y, u)}
            s(Y) $in upper_choice_family(Y)
            s(Y) $in {u X: not $is_well_ordered_chain_with_minimum(X, le, x0, Y) or $is_strict_upper_bound(X, le, Y, u)}
            by cases:
                ? $is_strict_upper_bound(X, le, Y, s(Y))
                case not $is_well_ordered_chain_with_minimum(X, le, x0, Y):
                    impossible not $is_well_ordered_chain_with_minimum(X, le, x0, Y)
                case $is_strict_upper_bound(X, le, Y, s(Y)):
                    $is_strict_upper_bound(X, le, Y, s(Y))
            (Y, s(Y)) $in {p cart(power_set(X), X): p[2] = s(p[1])}
            (Y, s(Y)) $in C
            witness exist u X st {(Y, u) $in C, $is_strict_upper_bound(X, le, Y, u)} from s(Y)
        claim:
            ? forall Y power_set(X), u X:
                (Y, u) $in C
                $is_well_ordered_chain_with_minimum(X, le, x0, Y)
                =>:
                    $is_strict_upper_bound(X, le, Y, u)
            upper_choice_family(Y) = {u X: not $is_well_ordered_chain_with_minimum(X, le, x0, Y) or $is_strict_upper_bound(X, le, Y, u)}
            (Y, u) $in {p cart(power_set(X), X): p[2] = s(p[1])}
            u = (Y, u)[2] = s((Y, u)[1]) = s(Y)
            s(Y) $in upper_choice_family(Y)
            s(Y) $in {v X: not $is_well_ordered_chain_with_minimum(X, le, x0, Y) or $is_strict_upper_bound(X, le, Y, v)}
            by cases:
                ? $is_strict_upper_bound(X, le, Y, s(Y))
                case not $is_well_ordered_chain_with_minimum(X, le, x0, Y):
                    impossible not $is_well_ordered_chain_with_minimum(X, le, x0, Y)
                case $is_strict_upper_bound(X, le, Y, s(Y)):
                    $is_strict_upper_bound(X, le, Y, s(Y))
    witness exist C0 power_set(cart(power_set(X), X)) st {$is_strict_upper_bound_choice_relation(X, le, x0, C0)} from C

template<X set, le power_set(cart(X, X)), Y power_set(X), x X>:
    have initial_segment_below power_set(X) = {y Y: $is_less_than_in_order(X, le, y, x)}

prop is_good_well_ordered_chain(X set, le power_set(cart(X, X)), x0 X, C power_set(cart(power_set(X), X)), Y power_set(X)):
    $is_well_ordered_chain_with_minimum(X, le, x0, Y)
    forall x Y:
        x != x0
        =>:
            exist u X st {(\initial_segment_below<X, le, Y, x>, u) $in C, x = u}

template<X set, le power_set(cart(X, X)), x0 X, C power_set(cart(power_set(X), X))>:
    have good_chain_family set = {Y power_set(X): $is_good_well_ordered_chain(X, le, x0, C, Y)}

template<X set, le power_set(cart(X, X)), x0 X, C power_set(cart(power_set(X), X))>:
    have good_chain_union set = cup(\good_chain_family<X, le, x0, C>)

prop second_good_chain_difference_strictly_bounds_first(X set, le power_set(cart(X, X)), Y, W power_set(X)):
    forall z set_minus(W, Y):
        $is_strict_upper_bound(X, le, Y, z)

prop first_good_chain_difference_strictly_bounds_second(X set, le power_set(cart(X, X)), Y, W power_set(X)):
    forall y set_minus(Y, W):
        $is_strict_upper_bound(X, le, W, y)

thm good_chain_comparison_forward_from_exercise_8_5_13:
    ? forall X set, le power_set(cart(X, X)), x0 X, C power_set(cart(power_set(X), X)), Y, W power_set(X):
        $is_partial_order(X, le)
        $is_strict_upper_bound_choice_relation(X, le, x0, C)
        $is_good_well_ordered_chain(X, le, x0, C, Y)
        $is_good_well_ordered_chain(X, le, x0, C, W)
        =>:
            $second_good_chain_difference_strictly_bounds_first(X, le, Y, W)
    trust $second_good_chain_difference_strictly_bounds_first(X, le, Y, W)

thm good_chain_comparison_reverse_from_exercise_8_5_13:
    ? forall X set, le power_set(cart(X, X)), x0 X, C power_set(cart(power_set(X), X)), Y, W power_set(X):
        $is_partial_order(X, le)
        $is_strict_upper_bound_choice_relation(X, le, x0, C)
        $is_good_well_ordered_chain(X, le, x0, C, Y)
        $is_good_well_ordered_chain(X, le, x0, C, W)
        =>:
            $first_good_chain_difference_strictly_bounds_second(X, le, Y, W)
    trust $first_good_chain_difference_strictly_bounds_second(X, le, Y, W)

thm good_chain_union_is_chain_with_minimum:
    ? forall X set, le power_set(cart(X, X)), x0 X, C power_set(cart(power_set(X), X)):
        $is_partial_order(X, le)
        $is_strict_upper_bound_choice_relation(X, le, x0, C)
        =>:
            $is_well_ordered_chain_with_minimum(X, le, x0, \good_chain_union<X, le, x0, C>)
    trust $is_well_ordered_chain_with_minimum(X, le, x0, \good_chain_union<X, le, x0, C>)

thm good_chain_union_has_no_strict_upper_bound:
    ? forall X set, le power_set(cart(X, X)), x0 X, C power_set(cart(power_set(X), X)):
        $is_partial_order(X, le)
        $is_strict_upper_bound_choice_relation(X, le, x0, C)
        =>:
            not $has_strict_upper_bound(X, le, \good_chain_union<X, le, x0, C>)
    trust not $has_strict_upper_bound(X, le, \good_chain_union<X, le, x0, C>)

thm good_chain_union_construction:
    ? forall X set, le power_set(cart(X, X)), x0 X, C power_set(cart(power_set(X), X)):
        $is_partial_order(X, le)
        $is_strict_upper_bound_choice_relation(X, le, x0, C)
        =>:
            exist Y power_set(X) st {$is_well_ordered_chain_from_without_strict_upper_bound(X, le, x0, Y)}
    have Yinf set = \good_chain_union<X, le, x0, C>
    by thm good_chain_union_is_chain_with_minimum(X, le, x0, C)
    by thm good_chain_union_has_no_strict_upper_bound(X, le, x0, C)
    by thm subset_member_of_power_set(X, Yinf)
    witness exist Y power_set(X) st {$is_well_ordered_chain_from_without_strict_upper_bound(X, le, x0, Y)} from Yinf

thm well_ordered_subset_without_strict_upper_bound:
    ? forall X set, le power_set(cart(X, X)), x0 X:
        $is_partial_order(X, le)
        =>:
            exist Y power_set(X) st {$is_well_ordered_chain_from_without_strict_upper_bound(X, le, x0, Y)}
    by contra:
        ? exist Y power_set(X) st {$is_well_ordered_chain_from_without_strict_upper_bound(X, le, x0, Y)}
        claim:
            ? forall Y power_set(X):
                $is_well_ordered_chain_with_minimum(X, le, x0, Y)
                =>:
                    $has_strict_upper_bound(X, le, Y)
            by thm failed_target_gives_strict_upper_bound(X, le, x0, Y)
        by thm strict_upper_bound_choice_relation_exists(X, le, x0)
        obtain C from exist C power_set(cart(power_set(X), X)) st {$is_strict_upper_bound_choice_relation(X, le, x0, C)}
        by thm good_chain_union_construction(X, le, x0, C)
        obtain Y from exist Y power_set(X) st {$is_well_ordered_chain_from_without_strict_upper_bound(X, le, x0, Y)}
        impossible $is_well_ordered_chain_from_without_strict_upper_bound(X, le, x0, Y)

"""
Lemma 8.5.15 (Zorn's lemma). If every totally ordered subset of a non-empty
partial order has an upper bound, then there is a maximal element.
"""

# Apply Lemma 8.5.14 from an initial element; if no maximal element existed,
# every well-ordered chain would have a strict upper bound, contradicting that
# lemma.

thm partial_order_antisymmetric_step:
    ? forall X set, le power_set(cart(X, X)), a, b X:
        $is_partial_order(X, le)
        (a, b) $in le
        (b, a) $in le
        =>:
            a = b
    a = b

thm partial_order_transitive_step:
    ? forall X set, le power_set(cart(X, X)), a, b, c X:
        $is_partial_order(X, le)
        (a, b) $in le
        (b, c) $in le
        =>:
            (a, c) $in le
    (a, c) $in le

prop every_total_ordered_subset_has_upper_bound(X set, le power_set(cart(X, X))):
    forall Y power_set(X):
        $is_total_order_on_subset(X, le, Y)
        =>:
            exist u X st {$is_upper_bound(X, le, Y, u)}

thm zorn_maximal_element_principle:
    ? forall X nonempty_set, le power_set(cart(X, X)):
        $is_partial_order(X, le)
        $every_total_ordered_subset_has_upper_bound(X, le)
        =>:
            exist m X st {$is_maximal_element(X, le, X, m)}
    have x0 X
    by thm well_ordered_subset_without_strict_upper_bound(X, le, x0)
    obtain Y from exist Y power_set(X) st {$is_well_ordered_chain_from_without_strict_upper_bound(X, le, x0, Y)}
    $is_well_ordered_chain_with_minimum(X, le, x0, Y)
    $is_well_ordered_subset(X, le, Y)
    $is_total_order_on_subset(X, le, Y)
    not $has_strict_upper_bound(X, le, Y)
    obtain u from exist u X st {$is_upper_bound(X, le, Y, u)}
    claim:
        ? $is_maximal_element(X, le, X, u)
        X $subset X
        u $in X
        claim:
            ? not exist z X st {$is_less_than_in_order(X, le, u, z)}
            by contra:
                ? not exist z X st {$is_less_than_in_order(X, le, u, z)}
                obtain z from exist z X st {$is_less_than_in_order(X, le, u, z)}
                (u, z) $in le
                u != z
                claim:
                    ? $is_upper_bound(X, le, Y, z)
                    Y $subset X
                    claim:
                        ? forall y Y:
                            (y, z) $in le
                        (y, u) $in le
                        by thm partial_order_transitive_step(X, le, y, u, z)
                        (y, z) $in le
                    $is_upper_bound(X, le, Y, z)
                claim:
                    ? not z $in Y
                    by contra:
                        ? not z $in Y
                        (z, u) $in le
                        by thm partial_order_antisymmetric_step(X, le, z, u)
                        z = u
                        impossible u != z
                $is_strict_upper_bound(X, le, Y, z)
                witness exist s X st {$is_strict_upper_bound(X, le, Y, s)} from z:
                    $is_strict_upper_bound(X, le, Y, z)
                $has_strict_upper_bound(X, le, Y)
                impossible not $has_strict_upper_bound(X, le, Y)
        $is_maximal_element(X, le, X, u)
    witness exist m X st {$is_maximal_element(X, le, X, m)} from u:
        $is_maximal_element(X, le, X, u)
