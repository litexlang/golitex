# Analysis I, Chapter 11: The Riemann integral.
#
# source: Analysis I, Chapter 11.
#
# This file is a standalone Litex framework for Sections 11.1-11.10.  It keeps
# Tao's source order and the main Riemann-integration vocabulary visible.  The
# finite partition algebra, Darboux upper/lower constructions, and fundamental
# theorem estimates are recorded as named proof debt so later passes can remove
# them one theorem-package at a time.

# Chapter-level background interfaces

trust local import chap9
trust local import chap10

"""
Chapter 11 imports the Chapter 9 continuity and Chapter 10 differentiability
interfaces.  The definitions below remain only where this chapter deliberately
uses a distinct source-facing formulation.
"""

prop is_real_set_bounded_by(X power_set(R), M R_pos):
    forall x X:
        abs(x) <= M

prop is_bounded_real_set(X power_set(R)):
    exist M R_pos st {$is_real_set_bounded_by(X, M)}

prop is_upper_bound_of_real_set(E power_set(R), M R):
    forall x E:
        x <= M

prop is_lower_bound_of_real_set(E power_set(R), M R):
    forall x E:
        M <= x

prop is_supremum_of_real_set(E power_set(R), s R):
    $is_upper_bound_of_real_set(E, s)
    forall M R:
        $is_upper_bound_of_real_set(E, M)
        =>:
            s <= M

prop is_infimum_of_real_set(E power_set(R), s R):
    $is_lower_bound_of_real_set(E, s)
    forall M R:
        $is_lower_bound_of_real_set(E, M)
        =>:
            M <= s

prop has_supremum_of_real_set(E power_set(R)):
    exist s R st {$is_supremum_of_real_set(E, s)}

prop has_infimum_of_real_set(E power_set(R)):
    exist s R st {$is_infimum_of_real_set(E, s)}

thm supremum_of_real_set_value_unique:
    ? forall E power_set(R), s1, s2 R:
        $is_supremum_of_real_set(E, s1)
        $is_supremum_of_real_set(E, s2)
        =>:
            s1 = s2
    $is_upper_bound_of_real_set(E, s1)
    $is_upper_bound_of_real_set(E, s2)
    forall M R:
        $is_upper_bound_of_real_set(E, M)
        =>:
            s1 <= M
    s1 <= s2
    forall M R:
        $is_upper_bound_of_real_set(E, M)
        =>:
            s2 <= M
    s2 <= s1
    s1 = s2

thm infimum_of_real_set_value_unique:
    ? forall E power_set(R), s1, s2 R:
        $is_infimum_of_real_set(E, s1)
        $is_infimum_of_real_set(E, s2)
        =>:
            s1 = s2
    $is_lower_bound_of_real_set(E, s1)
    $is_lower_bound_of_real_set(E, s2)
    forall M R:
        $is_lower_bound_of_real_set(E, M)
        =>:
            M <= s1
    s2 <= s1
    forall M R:
        $is_lower_bound_of_real_set(E, M)
        =>:
            M <= s2
    s1 <= s2
    s1 = s2

trust have sup fn(E power_set(R)) R:
    forall E power_set(R):
        $has_supremum_of_real_set(E)
        =>:
            $is_supremum_of_real_set(E, sup(E))

trust have inf fn(E power_set(R)) R:
    forall E power_set(R):
        $has_infimum_of_real_set(E)
        =>:
            $is_infimum_of_real_set(E, inf(E))

thm nonempty_bounded_real_set_has_supremum_and_infimum:
    ? forall E power_set(R):
        $is_nonempty_set(E)
        $is_bounded_real_set(E)
        =>:
            $has_supremum_of_real_set(E)
            $has_infimum_of_real_set(E)
    # Chapter 5/6 background: bounded non-empty real sets have least upper and
    # greatest lower bounds.  Chapter 11 only records the interface.
    trust:
        $has_supremum_of_real_set(E)
        $has_infimum_of_real_set(E)

prop has_interval_endpoints(I power_set(R), a, b R):
    I = '[a, b] or I = '[a, b) or I = '(a, b] or I = '(a, b)

prop is_bounded_interval(I power_set(R)):
    exist a, b R st {$has_interval_endpoints(I, a, b)}

prop is_function_bounded_by(X power_set(R), f fn(x X) R, M R_pos):
    forall x X:
        abs(f(x)) <= M

prop is_bounded_function_on(X power_set(R), f fn(x X) R):
    exist M R_pos st {$is_function_bounded_by(X, f, M)}

prop is_nonnegative_on(X power_set(R), f fn(x X) R):
    forall x X:
        f(x) >= 0

prop is_monotone_increasing_on(X power_set(R), f fn(x X) R):
    forall x, y X:
        x <= y
        =>:
            f(x) <= f(y)

prop is_monotone_decreasing_on(X power_set(R), f fn(x X) R):
    forall x, y X:
        x <= y
        =>:
            f(y) <= f(x)

prop is_monotone_on(X power_set(R), f fn(x X) R):
    $is_monotone_increasing_on(X, f) or $is_monotone_decreasing_on(X, f)

prop is_uniform_delta_continuous_on(X power_set(R), f fn(x X) R, epsilon R_pos, delta R_pos):
    forall x, y X:
        abs(x - y) < delta
        =>:
            abs(f(x) - f(y)) < epsilon

prop is_uniformly_continuous_on(X power_set(R), f fn(x X) R):
    forall epsilon R_pos:
        exist delta R_pos st {$is_uniform_delta_continuous_on(X, f, epsilon, delta)}

prop is_tail_close_to_value(a fn(k N_pos) R, L R, epsilon R_pos, N0 N_pos):
    forall k N_pos:
        k >= N0
        =>:
            abs(a(k) - L) <= epsilon

prop has_sequence_limit_value(a fn(k N_pos) R, L R):
    forall epsilon R_pos:
        exist N0 N_pos st {$is_tail_close_to_value(a, L, epsilon, N0)}

have fn zero_indexed_partial_sum(a fn(n N) R, k N) R by induc k from 0:
    case k = 0: a(0)
    case k > 0: zero_indexed_partial_sum(a, k - 1) + a(k)

have fn one_indexed_partial_sum(a fn(n N_pos) R, k N) R by induc k from 0:
    case k = 0: 0
    case k > 0: one_indexed_partial_sum(a, k - 1) + a(k)

prop has_series_sum_from_zero(a fn(n N) R, S R):
    $has_sequence_limit_value(fn(k N_pos) R {zero_indexed_partial_sum(a, k)}, S)

prop has_series_sum_from_one(a fn(n N_pos) R, S R):
    $has_sequence_limit_value(fn(k N_pos) R {one_indexed_partial_sum(a, k)}, S)

prop is_restriction_to_subset(X power_set(R), E power_set(R), f fn(x X) R, g fn(x E) R):
    E $subset X
    forall x E:
        g(x) = f(x)


# 11.1 Partitions

"""
Definition 11.1.1.  A subset of the real line is connected when every closed
interval between two of its points stays inside the subset.
"""

prop is_connected_subset_of_R(X power_set(R)):
    forall x, y X:
        x < y
        =>:
            '[x, y] $subset X

"""
Remark 11.1.2.  The chapter uses connectedness only for subsets of the real
line.  A later metric-space chapter generalizes the same idea.
"""

"""
Examples 11.1.3.  Closed and open intervals are connected; separated unions
such as `[1,2] union [3,4]` are not connected.  The empty set and singleton
sets are connected vacuously.
"""

thm closed_interval_is_connected:
    ? forall a, b R:
        a <= b
        =>:
            $is_connected_subset_of_R('[a, b])
    # Source handling: Tao verifies this directly from the interval
    # inequalities in the example.
    '[a, b] $subset R
    '[a, b] $in power_set(R)
    claim:
        ? forall x, y '[a, b]:
            x < y
            =>:
                '[x, y] $subset '[a, b]
        claim:
            ? '[x, y] $subset '[a, b]
            forall z '[x, y]:
                a <= x <= z
                z <= y <= b
                a <= z
                z <= b
                z $in '[a, b]
            '[x, y] $subset '[a, b]
    $is_connected_subset_of_R('[a, b])

thm open_interval_is_connected:
    ? forall a, b R:
        a < b
        =>:
            $is_connected_subset_of_R('(a, b))
    # Source handling: Tao says the same argument as for `[1,2]` applies.
    '(a, b) $subset R
    '(a, b) $in power_set(R)
    claim:
        ? forall x, y '(a, b):
            x < y
            =>:
                '[x, y] $subset '(a, b)
        claim:
            ? '[x, y] $subset '(a, b)
            forall z '[x, y]:
                a < x <= z
                z <= y < b
                a < z
                z < b
                z $in '(a, b)
            '[x, y] $subset '(a, b)
    $is_connected_subset_of_R('(a, b))

thm closed_open_interval_is_connected:
    ? forall a, b R:
        $is_connected_subset_of_R('[a, b))
    # Source handling: half-open intervals use the same order argument; the
    # left endpoint is closed and the right endpoint is open.
    '[a, b) $subset R
    '[a, b) $in power_set(R)
    claim:
        ? forall x, y '[a, b):
            x < y
            =>:
                '[x, y] $subset '[a, b)
        claim:
            ? '[x, y] $subset '[a, b)
            forall z '[x, y]:
                a <= x <= z
                z <= y < b
                a <= z
                z < b
                z $in '[a, b)
            '[x, y] $subset '[a, b)
    $is_connected_subset_of_R('[a, b))

thm open_closed_interval_is_connected:
    ? forall a, b R:
        $is_connected_subset_of_R('(a, b])
    # Source handling: this is the symmetric half-open case.
    '(a, b] $subset R
    '(a, b] $in power_set(R)
    claim:
        ? forall x, y '(a, b]:
            x < y
            =>:
                '[x, y] $subset '(a, b]
        claim:
            ? '[x, y] $subset '(a, b]
            forall z '[x, y]:
                a < x <= z
                z <= y <= b
                a < z
                z <= b
                z $in '(a, b]
            '[x, y] $subset '(a, b]
    $is_connected_subset_of_R('(a, b])

thm empty_set_is_connected:
    ? forall:
        $is_connected_subset_of_R({})
    # Source handling: the connectedness condition is vacuous for the empty set.
    claim:
        ? {} $subset R
        claim:
            ? forall z {}:
                z $in R
            by contra:
                ? z $in R
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from z
                impossible $is_nonempty_set({})
        {} $subset R
    {} $in power_set(R)
    claim:
        ? forall x, y {}:
            x < y
            =>:
                '[x, y] $subset {}
        by contra:
            ? '[x, y] $subset {}
            not $is_nonempty_set({})
            witness $is_nonempty_set({}) from x
            impossible $is_nonempty_set({})
    $is_connected_subset_of_R({})

thm singleton_is_connected:
    ? forall a R:
        $is_connected_subset_of_R({a})
    # Source handling: two points of a singleton are equal, so every interval
    # between them is the same singleton.
    claim:
        ? {a} $subset R
        claim:
            ? forall z {a}:
                z $in R
            z = a
            z $in R
        {a} $subset R
    {a} $in power_set(R)
    claim:
        ? forall x, y {a}:
            x < y
            =>:
                '[x, y] $subset {a}
        x = a
        y = a
        claim:
            ? '[x, y] $subset {a}
            forall z '[x, y]:
                x <= z <= y
                a <= z <= a
                z = a
                z $in {a}
            '[x, y] $subset {a}
    $is_connected_subset_of_R({a})

thm separated_closed_intervals_are_not_connected:
    ? forall:
        not $is_connected_subset_of_R(union('[1, 2], '[3, 4]))
    # Source handling: Tao's separated-union example fails connectedness
    # because the midpoint gap would have to belong to the union.
    by contra:
        ? not $is_connected_subset_of_R(union('[1, 2], '[3, 4]))
        $is_connected_subset_of_R(union('[1, 2], '[3, 4]))
        1 $in '[1, 2]
        1 $in union('[1, 2], '[3, 4])
        4 $in '[3, 4]
        4 $in union('[1, 2], '[3, 4])
        1 < 4
        '[1, 4] $subset union('[1, 2], '[3, 4])
        5 / 2 $in '[1, 4]
        5 / 2 $in union('[1, 2], '[3, 4])
        by contra not 5 / 2 $in '[1, 2]:
            5 / 2 $in '[1, 2]
            5 / 2 <= 2
            2 < 5 / 2
            impossible 5 / 2 <= 2
        by contra not 5 / 2 $in '[3, 4]:
            5 / 2 $in '[3, 4]
            3 <= 5 / 2
            5 / 2 < 3
            impossible 3 <= 5 / 2
        5 / 2 $in '[1, 2] or 5 / 2 $in '[3, 4]
        by cases:
            ? 5 / 2 <= 2
            case 5 / 2 $in '[1, 2]:
                impossible not 5 / 2 $in '[1, 2]
            case 5 / 2 $in '[3, 4]:
                impossible not 5 / 2 $in '[3, 4]
        2 < 5 / 2
        impossible 5 / 2 <= 2

"""
Lemma 11.1.4.  A subset of the real line is a bounded interval exactly when it
is both bounded and connected.
"""

thm bounded_connected_subsets_are_bounded_intervals:
    ? forall X power_set(R):
        $is_bounded_real_set(X)
        $is_connected_subset_of_R(X)
        =>:
            $is_bounded_interval(X)
    # Source handling: Tao proves this in Exercise 11.1.1.
    # trust: the non-empty case takes endpoints from `inf(X)` and `sup(X)`;
    # the remaining work is proving the correct open/closed endpoint form.
    by cases:
        ? $is_bounded_interval(X)
        case $is_nonempty_set(X):
            by thm nonempty_bounded_real_set_has_supremum_and_infimum(X)
            $is_supremum_of_real_set(X, sup(X))
            $is_infimum_of_real_set(X, inf(X))
            trust $is_bounded_interval(X)
        case not $is_nonempty_set(X):
            by extension X = {}:
                claim:
                    ? forall z X:
                        z $in {}
                    by contra:
                        ? z $in {}
                        not z $in {}
                        witness $is_nonempty_set(X) from z
                        impossible $is_nonempty_set(X)
                claim:
                    ? forall z {}:
                        z $in X
                    by contra:
                        ? z $in X
                        not $is_nonempty_set({})
                        witness $is_nonempty_set({}) from z
                        impossible $is_nonempty_set({})
            by extension {} = '(0, 0):
                claim:
                    ? forall z {}:
                        z $in '(0, 0)
                    by contra:
                        ? z $in '(0, 0)
                        not $is_nonempty_set({})
                        witness $is_nonempty_set({}) from z
                        impossible $is_nonempty_set({})
                claim:
                    ? forall z '(0, 0):
                        z $in {}
                    0 < z
                    z < 0
                    by contra:
                        ? z $in {}
                        not z $in {}
                        z <= 0
                        impossible 0 < z
            X = '(0, 0)
            claim:
                ? $has_interval_endpoints(X, 0, 0)
                X = '(0, 0)
                X = '[0, 0] or X = '[0, 0) or X = '(0, 0] or X = '(0, 0)
            witness exist a, b R st {$has_interval_endpoints(X, a, b)} from 0, 0:
                $has_interval_endpoints(X, 0, 0)
            $is_bounded_interval(X)

thm bounded_intervals_are_bounded_connected:
    ? forall X power_set(R):
        $is_bounded_interval(X)
        =>:
            $is_bounded_real_set(X)
            $is_connected_subset_of_R(X)
    # Source handling: this is the reverse direction of Exercise 11.1.1.
    # trust: check the endpoint-form cases from the Chapter 9 interval
    # definition.
    trust:
        $is_bounded_real_set(X)
        $is_connected_subset_of_R(X)

# The source lemma is an iff statement; the two named theorems above are the
# reusable directions used by later proofs.
forall X power_set(R):
    =>:
        $is_bounded_interval(X)
    <=>:
        $is_bounded_real_set(X)
        $is_connected_subset_of_R(X)

"""
Remark 11.1.5.  Bounded intervals include degenerate intervals such as
singleton points, and also include the empty set.
"""

"""
Corollary 11.1.6.  The intersection of two bounded intervals is again a
bounded interval.
"""

thm intersection_of_bounded_intervals_is_bounded_interval:
    ? forall I, J power_set(R):
        $is_bounded_interval(I)
        $is_bounded_interval(J)
        =>:
            $is_bounded_interval(intersect(I, J))
    # Source handling: Tao proves this in Exercise 11.1.2 by using Lemma
    # 11.1.4.
    # trust: prove boundedness and connectedness of the intersection, then
    # apply the bounded-connected characterization above.
    trust $is_bounded_interval(intersect(I, J))

"""
Example 11.1.7.  `[2,4] intersect [4,6]` is the singleton `{4}`, while
`(2,4) intersect (4,6)` is empty.
"""

thm example_11_1_7_intersections:
    ? forall:
        intersect('[2, 4], '[4, 6]) = {4}
        intersect('(2, 4), '(4, 6)) = {}
    # Source handling: this is the direct interval-membership computation in
    # the example.
    by extension intersect('[2, 4], '[4, 6]) = {4}:
        forall z intersect('[2, 4], '[4, 6]):
            z $in '[2, 4]
            z $in '[4, 6]
            z <= 4 <= z
            z = 4
            z $in {4}
        forall z {4}:
            z = 4
            z $in '[2, 4]
            z $in '[4, 6]
            z $in intersect('[2, 4], '[4, 6])
    by extension intersect('(2, 4), '(4, 6)) = {}:
        claim:
            ? forall z intersect('(2, 4), '(4, 6)):
                z $in {}
            z $in '(2, 4)
            z $in '(4, 6)
            z < 4
            4 < z
            z <= 4
            by contra:
                ? z $in {}
                not z $in {}
                impossible z <= 4
        claim:
            ? forall z {}:
                z $in intersect('(2, 4), '(4, 6))
            by contra:
                ? z $in intersect('(2, 4), '(4, 6))
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from z
                impossible $is_nonempty_set({})

"""
Definition 11.1.8 (Length of intervals).  The length of a bounded interval is
`b-a` for any non-degenerate interval with endpoints `a<b`, and is `0` for a
singleton or the empty set.
"""

# Litex packages the source case split by allowing all endpoint orders and
# taking the positive part of the endpoint difference.

prop has_interval_length_with_endpoints(I power_set(R), l, a, b R):
    $has_interval_endpoints(I, a, b)
    l = max(b - a, 0)

prop has_interval_length(I power_set(R), l R):
    exist a0, b0 R st {$has_interval_length_with_endpoints(I, l, a0, b0)}

thm interval_length_endpoint_case:
    ? forall I power_set(R), l, a, b R:
        $has_interval_length_with_endpoints(I, l, a, b)
        =>:
            $has_interval_length(I, l)
    witness exist a0, b0 R st {$has_interval_length_with_endpoints(I, l, a0, b0)} from a, b:
        $has_interval_length_with_endpoints(I, l, a, b)

thm interval_endpoint_case_has_total_length:
    ? forall I power_set(R), a, b R:
        $has_interval_endpoints(I, a, b)
        =>:
            $has_interval_length(I, max(b - a, 0))
    claim:
        ? $has_interval_length_with_endpoints(I, max(b - a, 0), a, b)
        $has_interval_endpoints(I, a, b)
        max(b - a, 0) = max(b - a, 0)
    by thm interval_length_endpoint_case(I, max(b - a, 0), a, b)

thm interval_length_value_unique:
    ? forall I power_set(R), l1, l2 R:
        $has_interval_length(I, l1)
        $has_interval_length(I, l2)
        =>:
            l1 = l2
    # Source handling: the endpoint-only definition assigns the same
    # `max(b-a,0)` value to every endpoint representation of the same
    # bounded interval.
    # trust: split the two endpoint representations and compare their
    # positive-part lengths by interval extensionality.
    trust l1 = l2

have fn interval_length by exist!:
    ? forall I power_set(R):
        $is_bounded_interval(I)
        =>:
            exist! l R st {$has_interval_length(I, l)}
    # Source handling: this packages the endpoint-only length formula as a
    # selector.  Degenerate and empty intervals are represented by degenerate
    # endpoint forms, so no separate length branch is needed.
    obtain a, b from exist a, b R st {$has_interval_endpoints(I, a, b)}
    by thm interval_endpoint_case_has_total_length(I, a, b)
    claim:
        ? exist l R st {$has_interval_length(I, l)}
        witness exist l R st {$has_interval_length(I, l)} from max(b - a, 0):
            $has_interval_length(I, max(b - a, 0))
    claim:
        ? forall l1, l2 R:
            $has_interval_length(I, l1)
            $has_interval_length(I, l2)
            =>:
                l1 = l2
        by thm interval_length_value_unique(I, l1, l2)
    exist! l R st {$has_interval_length(I, l)}

thm interval_endpoint_forms_are_bounded_intervals:
    ? forall a, b R:
        '[a, b] $in power_set(R)
        '[a, b) $in power_set(R)
        '(a, b] $in power_set(R)
        '(a, b) $in power_set(R)
        $is_bounded_interval('[a, b])
        $is_bounded_interval('[a, b))
        $is_bounded_interval('(a, b])
        $is_bounded_interval('(a, b))
    '[a, b] $subset R
    '[a, b] $in power_set(R)
    '[a, b) $subset R
    '[a, b) $in power_set(R)
    '(a, b] $subset R
    '(a, b] $in power_set(R)
    '(a, b) $subset R
    '(a, b) $in power_set(R)
    claim:
        ? $has_interval_endpoints('[a, b], a, b)
        '[a, b] = '[a, b]
        '[a, b] = '[a, b] or '[a, b] = '[a, b) or '[a, b] = '(a, b] or '[a, b] = '(a, b)
    claim:
        ? $is_bounded_interval('[a, b])
        witness exist a0, b0 R st {$has_interval_endpoints('[a, b], a0, b0)} from a, b:
            $has_interval_endpoints('[a, b], a, b)
    $is_bounded_interval('[a, b])
    claim:
        ? $has_interval_endpoints('[a, b), a, b)
        '[a, b) = '[a, b)
        '[a, b) = '[a, b] or '[a, b) = '[a, b) or '[a, b) = '(a, b] or '[a, b) = '(a, b)
    claim:
        ? $is_bounded_interval('[a, b))
        witness exist a0, b0 R st {$has_interval_endpoints('[a, b), a0, b0)} from a, b:
            $has_interval_endpoints('[a, b), a, b)
    $is_bounded_interval('[a, b))
    claim:
        ? $has_interval_endpoints('(a, b], a, b)
        '(a, b] = '(a, b]
        '(a, b] = '[a, b] or '(a, b] = '[a, b) or '(a, b] = '(a, b] or '(a, b] = '(a, b)
    claim:
        ? $is_bounded_interval('(a, b])
        witness exist a0, b0 R st {$has_interval_endpoints('(a, b], a0, b0)} from a, b:
            $has_interval_endpoints('(a, b], a, b)
    $is_bounded_interval('(a, b])
    claim:
        ? $has_interval_endpoints('(a, b), a, b)
        '(a, b) = '(a, b)
        '(a, b) = '[a, b] or '(a, b) = '[a, b) or '(a, b) = '(a, b] or '(a, b) = '(a, b)
    claim:
        ? $is_bounded_interval('(a, b))
        witness exist a0, b0 R st {$has_interval_endpoints('(a, b), a0, b0)} from a, b:
            $has_interval_endpoints('(a, b), a, b)
    $is_bounded_interval('(a, b))

thm non_degenerate_interval_forms_are_bounded_intervals:
    ? forall a, b R:
        a < b
        =>:
            '[a, b] $in power_set(R)
            '[a, b) $in power_set(R)
            '(a, b] $in power_set(R)
            '(a, b) $in power_set(R)
            $is_bounded_interval('[a, b])
            $is_bounded_interval('[a, b))
            $is_bounded_interval('(a, b])
            $is_bounded_interval('(a, b))
    by thm interval_endpoint_forms_are_bounded_intervals(a, b)

thm singleton_interval_is_closed_degenerate:
    ? forall a R:
        {a} = '[a, a]
    by extension {a} = '[a, a]:
        forall x {a}:
            x = a
            a <= x
            x <= a
            x $in '[a, a]
        forall x '[a, a]:
            a <= x
            x <= a
            x = a
            x $in {a}

thm empty_interval_is_open_degenerate:
    ? forall a R:
        {} = '(a, a)
    by extension {} = '(a, a):
        claim:
            ? forall x {}:
                x $in '(a, a)
            by contra:
                ? x $in '(a, a)
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from x
                impossible $is_nonempty_set({})
        claim:
            ? forall x '(a, a):
                x $in {}
            a < x
            x < a
            by contra:
                ? x $in {}
                not x $in {}
                x <= a
                impossible a < x

thm singleton_interval_is_bounded:
    ? forall a R:
        {a} $in power_set(R)
        $is_bounded_interval({a})
    claim:
        ? {a} $subset R
        claim:
            ? forall z {a}:
                z $in R
            z = a
            z $in R
        {a} $subset R
    {a} $in power_set(R)
    claim:
        ? $has_interval_endpoints({a}, a, a)
        by thm singleton_interval_is_closed_degenerate(a)
        {a} = '[a, a]
        {a} = '[a, a] or {a} = '[a, a) or {a} = '(a, a] or {a} = '(a, a)
    witness exist a0, b0 R st {$has_interval_endpoints({a}, a0, b0)} from a, a:
        $has_interval_endpoints({a}, a, a)
    $is_bounded_interval({a})

thm empty_interval_is_bounded:
    ? forall:
        {} $in power_set(R)
        $is_bounded_interval({})
    claim:
        ? {} $subset R
        claim:
            ? forall z {}:
                z $in R
            by contra:
                ? z $in R
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from z
                impossible $is_nonempty_set({})
        {} $subset R
    {} $in power_set(R)
    by thm empty_interval_is_open_degenerate(0)
    claim:
        ? $has_interval_endpoints({}, 0, 0)
        {} = '(0, 0)
        {} = '[0, 0] or {} = '[0, 0) or {} = '(0, 0] or {} = '(0, 0)
    witness exist a, b R st {$has_interval_endpoints({}, a, b)} from 0, 0:
        $has_interval_endpoints({}, 0, 0)
    $is_bounded_interval({})

thm max_positive_part_identity_when_positive:
    ? forall a, b R:
        a < b
        =>:
            max(b - a, 0) = b - a
    b - a > 0
    b - a >= 0
    b - a <= b - a
    0 <= b - a
    max(b - a, 0) <= b - a
    b - a <= max(b - a, 0)
    max(b - a, 0) = b - a

thm max_positive_part_zero_when_nonpositive:
    ? forall a, b R:
        b <= a
        =>:
            max(b - a, 0) = 0
    b - a <= 0
    0 <= 0
    max(b - a, 0) <= 0
    0 <= max(b - a, 0)
    max(b - a, 0) = 0

thm interval_endpoint_forms_have_total_length:
    ? forall a, b R:
        $has_interval_length('[a, b], max(b - a, 0))
        $has_interval_length('[a, b), max(b - a, 0))
        $has_interval_length('(a, b], max(b - a, 0))
        $has_interval_length('(a, b), max(b - a, 0))
    by thm interval_endpoint_forms_are_bounded_intervals(a, b)
    claim:
        ? $has_interval_endpoints('[a, b], a, b)
        '[a, b] = '[a, b]
        '[a, b] = '[a, b] or '[a, b] = '[a, b) or '[a, b] = '(a, b] or '[a, b] = '(a, b)
    by thm interval_endpoint_case_has_total_length('[a, b], a, b)
    claim:
        ? $has_interval_endpoints('[a, b), a, b)
        '[a, b) = '[a, b)
        '[a, b) = '[a, b] or '[a, b) = '[a, b) or '[a, b) = '(a, b] or '[a, b) = '(a, b)
    by thm interval_endpoint_case_has_total_length('[a, b), a, b)
    claim:
        ? $has_interval_endpoints('(a, b], a, b)
        '(a, b] = '(a, b]
        '(a, b] = '[a, b] or '(a, b] = '[a, b) or '(a, b] = '(a, b] or '(a, b] = '(a, b)
    by thm interval_endpoint_case_has_total_length('(a, b], a, b)
    claim:
        ? $has_interval_endpoints('(a, b), a, b)
        '(a, b) = '(a, b)
        '(a, b) = '[a, b] or '(a, b) = '[a, b) or '(a, b) = '(a, b] or '(a, b) = '(a, b)
    by thm interval_endpoint_case_has_total_length('(a, b), a, b)

thm interval_endpoint_forms_have_zero_length_when_nonpositive:
    ? forall a, b R:
        b <= a
        =>:
            $has_interval_length('[a, b], 0)
            $has_interval_length('[a, b), 0)
            $has_interval_length('(a, b], 0)
            $has_interval_length('(a, b), 0)
    by thm interval_endpoint_forms_have_total_length(a, b)
    by thm max_positive_part_zero_when_nonpositive(a, b)
    $has_interval_length('[a, b], max(b - a, 0))
    $has_interval_length('[a, b], 0)
    $has_interval_length('[a, b), max(b - a, 0))
    $has_interval_length('[a, b), 0)
    $has_interval_length('(a, b], max(b - a, 0))
    $has_interval_length('(a, b], 0)
    $has_interval_length('(a, b), max(b - a, 0))
    $has_interval_length('(a, b), 0)

thm non_degenerate_interval_forms_have_length:
    ? forall a, b R:
        a < b
        =>:
            $has_interval_length('[a, b], b - a)
            $has_interval_length('[a, b), b - a)
            $has_interval_length('(a, b], b - a)
            $has_interval_length('(a, b), b - a)
    # Source handling: this is the non-degenerate branch of Definition
    # 11.1.8, obtained by simplifying the total endpoint formula.
    by thm interval_endpoint_forms_have_total_length(a, b)
    by thm max_positive_part_identity_when_positive(a, b)
    $has_interval_length('[a, b], max(b - a, 0))
    $has_interval_length('[a, b], b - a)
    $has_interval_length('[a, b), max(b - a, 0))
    $has_interval_length('[a, b), b - a)
    $has_interval_length('(a, b], max(b - a, 0))
    $has_interval_length('(a, b], b - a)
    $has_interval_length('(a, b), max(b - a, 0))
    $has_interval_length('(a, b), b - a)

thm singleton_interval_has_length_zero:
    ? forall a R:
        $has_interval_length({a}, 0)
    by thm singleton_interval_is_bounded(a)
    by thm singleton_interval_is_closed_degenerate(a)
    claim:
        ? $has_interval_endpoints({a}, a, a)
        {a} = '[a, a]
        {a} = '[a, a] or {a} = '[a, a) or {a} = '(a, a] or {a} = '(a, a)
    by thm interval_endpoint_case_has_total_length({a}, a, a)
    a <= a
    by thm max_positive_part_zero_when_nonpositive(a, a)
    $has_interval_length({a}, max(a - a, 0))
    $has_interval_length({a}, 0)

thm empty_interval_has_length_zero:
    ? forall:
        $has_interval_length({}, 0)
    by thm empty_interval_is_bounded()
    by thm empty_interval_is_open_degenerate(0)
    claim:
        ? $has_interval_endpoints({}, 0, 0)
        {} = '(0, 0)
        {} = '[0, 0] or {} = '[0, 0) or {} = '(0, 0] or {} = '(0, 0)
    by thm interval_endpoint_case_has_total_length({}, 0, 0)
    0 <= 0
    by thm max_positive_part_zero_when_nonpositive(0, 0)
    $has_interval_length({}, max(0 - 0, 0))
    $has_interval_length({}, 0)

"""
Example 11.1.9.  `[3,5]` and `(3,5)` both have length `2`; a singleton and
the empty set have length `0`.
"""

thm example_11_1_9_interval_lengths:
    ? forall:
        $has_interval_length('[3, 5], 2)
        $has_interval_length('(3, 5), 2)
        $has_interval_length({5}, 0)
        $has_interval_length({}, 0)
    # Source handling: these are direct evaluations from Definition 11.1.8.
    by thm non_degenerate_interval_forms_have_length(3, 5)
    5 - 3 = 2
    $has_interval_length('[3, 5], 5 - 3)
    $has_interval_length('[3, 5], 2)
    $has_interval_length('(3, 5), 5 - 3)
    $has_interval_length('(3, 5), 2)
    by thm singleton_interval_has_length_zero(5)
    by thm empty_interval_has_length_zero()

"""
Definition 11.1.10 (Partitions).  A partition of a bounded interval `I` is a
finite set of bounded intervals contained in `I`, and each point of `I` lies in
exactly one member of the partition.
"""

prop is_partition_of_bounded_interval(I power_set(R), P finite_set):
    $is_bounded_interval(I)
    forall J P:
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset I
    forall x I:
        exist! J P st {J $in power_set(R), x $in J}

thm one_piece_partition_of_bounded_interval:
    ? forall I power_set(R):
        $is_bounded_interval(I)
        =>:
            $is_partition_of_bounded_interval(I, {I})
    # Source handling: this is the degenerate partition used repeatedly in
    # 11.2: the single piece is the whole bounded interval.
    $is_bounded_interval(I)
    claim:
        ? forall J {I}:
            J $in power_set(R)
            $is_bounded_interval(J)
            J $subset I
        J = I
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset I
    claim:
        ? forall x I:
            exist! J {I} st {J $in power_set(R), x $in J}
        witness exist! J {I} st {J $in power_set(R), x $in J} from I:
            I $in {I}
            I $in power_set(R)
            x $in I
    $is_partition_of_bounded_interval(I, {I})

"""
Remark 11.1.11.  A partition is a finite set whose elements are intervals, so
it is a set of sets.
"""

"""
Examples 11.1.12.  A valid partition covers every point exactly once; overlaps,
missing points, and pieces that leave the ambient interval invalidate the
partition.
"""

thm example_11_1_12_touching_closed_pieces_distinct:
    ? forall:
        '[0, 1] != '[1, 2]
    by contra:
        ? '[0, 1] != '[1, 2]
        '[0, 1] = '[1, 2]
        0 $in '[0, 1]
        0 $in '[1, 2]
        impossible 1 <= 0

thm example_11_1_12_gap_pieces_distinct:
    ? forall:
        '[0, 1] != '[2, 3]
    by contra:
        ? '[0, 1] != '[2, 3]
        '[0, 1] = '[2, 3]
        0 $in '[0, 1]
        0 $in '[2, 3]
        impossible 2 <= 0

thm example_11_1_12_outside_pieces_distinct:
    ? forall:
        '[0, 1] != '[2, 4]
    by contra:
        ? '[0, 1] != '[2, 4]
        '[0, 1] = '[2, 4]
        0 $in '[0, 1]
        0 $in '[2, 4]
        impossible 2 <= 0

thm example_11_1_12_valid_one_piece_partition:
    ? forall:
        $is_partition_of_bounded_interval('[0, 1], {'[0, 1]})
    by thm non_degenerate_interval_forms_are_bounded_intervals(0, 1)
    by thm one_piece_partition_of_bounded_interval('[0, 1])

thm example_11_1_12_overlap_breaks_uniqueness:
    ? forall:
        not $is_partition_of_bounded_interval('[0, 2], {'[0, 1], '[1, 2]})
    by contra:
        ? not $is_partition_of_bounded_interval('[0, 2], {'[0, 1], '[1, 2]})
        $is_partition_of_bounded_interval('[0, 2], {'[0, 1], '[1, 2]})
        1 $in '[0, 2]
        exist! J {'[0, 1], '[1, 2]} st {J $in power_set(R), 1 $in J}
        '[0, 1] $in {'[0, 1], '[1, 2]}
        '[1, 2] $in {'[0, 1], '[1, 2]}
        '[0, 1] $subset R
        '[0, 1] $in power_set(R)
        '[1, 2] $subset R
        '[1, 2] $in power_set(R)
        1 $in '[0, 1]
        1 $in '[1, 2]
        '[0, 1] = '[1, 2]
        impossible '[0, 1] != '[1, 2]

thm example_11_1_12_gap_breaks_existence:
    ? forall:
        not $is_partition_of_bounded_interval('[0, 3], {'[0, 1], '[2, 3]})
    by contra:
        ? not $is_partition_of_bounded_interval('[0, 3], {'[0, 1], '[2, 3]})
        $is_partition_of_bounded_interval('[0, 3], {'[0, 1], '[2, 3]})
        3 / 2 $in '[0, 3]
        exist! J {'[0, 1], '[2, 3]} st {J $in power_set(R), 3 / 2 $in J}
        obtain J from exist J {'[0, 1], '[2, 3]} st {J $in power_set(R), 3 / 2 $in J}
        J = '[0, 1] or J = '[2, 3]
        by cases:
            ? 1 = 0
            case J = '[0, 1]:
                3 / 2 $in '[0, 1]
                3 / 2 <= 1
                1 < 3 / 2
                impossible 3 / 2 <= 1
            case J = '[2, 3]:
                3 / 2 $in '[2, 3]
                2 <= 3 / 2
                3 / 2 < 2
                impossible 2 <= 3 / 2
        impossible 1 = 0

thm example_11_1_12_outside_piece_breaks_containment:
    ? forall:
        not $is_partition_of_bounded_interval('[0, 3], {'[0, 1], '[2, 4]})
    by contra:
        ? not $is_partition_of_bounded_interval('[0, 3], {'[0, 1], '[2, 4]})
        $is_partition_of_bounded_interval('[0, 3], {'[0, 1], '[2, 4]})
        '[2, 4] $in {'[0, 1], '[2, 4]}
        '[2, 4] $subset '[0, 3]
        4 $in '[2, 4]
        4 $in '[0, 3]
        4 <= 3
        3 < 4
        impossible 4 <= 3

thm empty_interval_length_value:
    ? forall:
        interval_length({}) = 0
    by thm empty_interval_is_bounded()
    $has_interval_length({}, interval_length({}))
    by thm empty_interval_has_length_zero()
    by thm interval_length_value_unique({}, interval_length({}), 0)
    interval_length({}) = 0

thm empty_bounded_interval_length_value:
    ? forall J power_set(R):
        $is_bounded_interval(J)
        not $is_nonempty_set(J)
        =>:
            interval_length(J) = 0
    by extension J = {}:
        claim:
            ? forall x J:
                x $in {}
            by contra:
                ? x $in {}
                x $in J
                not $is_nonempty_set(J)
                witness $is_nonempty_set(J) from x
                impossible $is_nonempty_set(J)
        claim:
            ? forall x {}:
                x $in J
            by contra:
                ? x $in J
                x $in {}
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from x
                impossible $is_nonempty_set({})
    by thm empty_interval_length_value()
    interval_length(J) = interval_length({}) = 0

thm singleton_interval_length_value:
    ? forall a R:
        interval_length({a}) = 0
    by thm singleton_interval_is_bounded(a)
    $has_interval_length({a}, interval_length({a}))
    by thm singleton_interval_has_length_zero(a)
    by thm interval_length_value_unique({a}, interval_length({a}), 0)
    interval_length({a}) = 0

thm interval_endpoint_forms_length_value:
    ? forall a, b R:
        interval_length('[a, b]) = max(b - a, 0)
        interval_length('[a, b)) = max(b - a, 0)
        interval_length('(a, b]) = max(b - a, 0)
        interval_length('(a, b)) = max(b - a, 0)
    by thm interval_endpoint_forms_are_bounded_intervals(a, b)
    by thm interval_endpoint_forms_have_total_length(a, b)
    $has_interval_length('[a, b], interval_length('[a, b]))
    $has_interval_length('[a, b], max(b - a, 0))
    by thm interval_length_value_unique('[a, b], interval_length('[a, b]), max(b - a, 0))
    $has_interval_length('[a, b), interval_length('[a, b)))
    $has_interval_length('[a, b), max(b - a, 0))
    by thm interval_length_value_unique('[a, b), interval_length('[a, b)), max(b - a, 0))
    $has_interval_length('(a, b], interval_length('(a, b]))
    $has_interval_length('(a, b], max(b - a, 0))
    by thm interval_length_value_unique('(a, b], interval_length('(a, b]), max(b - a, 0))
    $has_interval_length('(a, b), interval_length('(a, b)))
    $has_interval_length('(a, b), max(b - a, 0))
    by thm interval_length_value_unique('(a, b), interval_length('(a, b)), max(b - a, 0))

thm interval_endpoint_forms_zero_length_value_when_nonpositive:
    ? forall a, b R:
        b <= a
        =>:
            interval_length('[a, b]) = 0
            interval_length('[a, b)) = 0
            interval_length('(a, b]) = 0
            interval_length('(a, b)) = 0
    by thm interval_endpoint_forms_are_bounded_intervals(a, b)
    by thm interval_endpoint_forms_have_zero_length_when_nonpositive(a, b)
    $has_interval_length('[a, b], interval_length('[a, b]))
    $has_interval_length('[a, b], 0)
    by thm interval_length_value_unique('[a, b], interval_length('[a, b]), 0)
    $has_interval_length('[a, b), interval_length('[a, b)))
    $has_interval_length('[a, b), 0)
    by thm interval_length_value_unique('[a, b), interval_length('[a, b)), 0)
    $has_interval_length('(a, b], interval_length('(a, b]))
    $has_interval_length('(a, b], 0)
    by thm interval_length_value_unique('(a, b], interval_length('(a, b]), 0)
    $has_interval_length('(a, b), interval_length('(a, b)))
    $has_interval_length('(a, b), 0)
    by thm interval_length_value_unique('(a, b), interval_length('(a, b)), 0)

thm endpoint_interval_length_degenerate_examples:
    ? forall:
        interval_length('[5, 5]) = 0
        interval_length('(0, 0)) = 0
        interval_length('[5, 3]) = 0
        interval_length('[3, 3)) = 0
    by thm interval_endpoint_forms_zero_length_value_when_nonpositive(5, 5)
    by thm interval_endpoint_forms_zero_length_value_when_nonpositive(0, 0)
    by thm interval_endpoint_forms_zero_length_value_when_nonpositive(5, 3)
    by thm interval_endpoint_forms_zero_length_value_when_nonpositive(3, 3)

thm non_degenerate_interval_forms_length_value:
    ? forall a, b R:
        a < b
        =>:
            interval_length('[a, b]) = b - a
            interval_length('[a, b)) = b - a
            interval_length('(a, b]) = b - a
            interval_length('(a, b)) = b - a
    by thm non_degenerate_interval_forms_are_bounded_intervals(a, b)
    by thm non_degenerate_interval_forms_have_length(a, b)
    $has_interval_length('[a, b], interval_length('[a, b]))
    $has_interval_length('[a, b], b - a)
    by thm interval_length_value_unique('[a, b], interval_length('[a, b]), b - a)
    $has_interval_length('[a, b), interval_length('[a, b)))
    $has_interval_length('[a, b), b - a)
    by thm interval_length_value_unique('[a, b), interval_length('[a, b)), b - a)
    $has_interval_length('(a, b], interval_length('(a, b]))
    $has_interval_length('(a, b], b - a)
    by thm interval_length_value_unique('(a, b], interval_length('(a, b]), b - a)
    $has_interval_length('(a, b), interval_length('(a, b)))
    $has_interval_length('(a, b), b - a)
    by thm interval_length_value_unique('(a, b), interval_length('(a, b)), b - a)

thm interval_length_adds_for_adjacent_closed_split:
    ? forall a, b, c R:
        a < b
        b < c
        a < c
        =>:
            interval_length('[a, c]) = interval_length('[a, b)) + interval_length('[b, c])
    a < b < c
    a < c
    by thm non_degenerate_interval_forms_length_value(a, c)
    by thm non_degenerate_interval_forms_length_value(a, b)
    by thm non_degenerate_interval_forms_length_value(b, c)
    interval_length('[a, c]) = c - a
    interval_length('[a, b)) = b - a
    interval_length('[b, c]) = c - b
    c - a = (b - a) + (c - b)
    interval_length('[a, c]) = interval_length('[a, b)) + interval_length('[b, c])

thm adjacent_left_open_right_closed_pieces_distinct:
    ? forall a, b, c R:
        a < b
        b < c
        =>:
            '[a, b) != '[b, c]
    by contra:
        prove:
            '[a, b) != '[b, c]
        '[a, b) = '[b, c]
        b $in '[b, c]
        b $in '[a, b)
        b < b
        impossible b < b

thm finite_set_sum_two_interval_lengths_expands:
    ? forall A, B power_set(R):
        A != B
        $is_bounded_interval(A)
        $is_bounded_interval(B)
        =>:
            finite_set_sum({A, B}, fn(J power_set(R): $is_bounded_interval(J)) R {interval_length(J)}) = interval_length(A) + interval_length(B)

thm interval_length_two_piece_adjacent_closed_split_sum:
    ? forall a, b, c R:
        a < b
        b < c
        =>:
            interval_length('[a, c]) = finite_set_sum({'[a, b), '[b, c]}, fn(J power_set(R): $is_bounded_interval(J)) R {interval_length(J)})
    a < b < c
    a < c
    by thm interval_length_adds_for_adjacent_closed_split(a, b, c)
    by thm adjacent_left_open_right_closed_pieces_distinct(a, b, c)
    by thm non_degenerate_interval_forms_are_bounded_intervals(a, b)
    by thm non_degenerate_interval_forms_are_bounded_intervals(b, c)
    by thm finite_set_sum_two_interval_lengths_expands('[a, b), '[b, c])
    finite_set_sum({'[a, b), '[b, c]}, fn(J power_set(R): $is_bounded_interval(J)) R {interval_length(J)}) = interval_length('[a, b)) + interval_length('[b, c])
    interval_length('[a, c]) = interval_length('[a, b)) + interval_length('[b, c])
    interval_length('[a, c]) = finite_set_sum({'[a, b), '[b, c]}, fn(J power_set(R): $is_bounded_interval(J)) R {interval_length(J)})

"""
Theorem 11.1.13 (Length is finitely additive).  If `P` partitions a bounded
interval `I`, the length of `I` is the finite sum of the lengths of the pieces.
"""

thm interval_length_is_finitely_additive_over_partition:
    ? forall I power_set(R), P finite_set:
        $is_partition_of_bounded_interval(I, P)
        =>:
            interval_length(I) = finite_set_sum(P, fn(J P) R {interval_length(J)})
    # Source handling: Tao proves this by induction on the cardinality of the
    # partition and repeatedly removes an endpoint piece.  The checked lemmas
    # above prove the interval-length selector evaluations, the adjacent
    # two-piece additivity calculation, and the corresponding two-element
    # finite-set sum expansion.
    $is_bounded_interval(I)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_bounded_interval(J)
            J $subset I
    claim:
        ? forall x I:
            exist! J P st {J $in power_set(R), x $in J}
    # trust: formalize the endpoint-piece selection, the partition-minus
    # interval identity, and the finite-set sum induction for arbitrary finite
    # partitions.
    trust interval_length(I) = finite_set_sum(P, fn(J P) R {interval_length(J)})

"""
Definition 11.1.14 (Finer and coarser partitions).  A partition `P2` is finer
than `P1` when every piece of `P2` is contained in some piece of `P1`.
"""

prop is_finer_partition_than(I power_set(R), P2, P1 finite_set):
    $is_partition_of_bounded_interval(I, P2)
    $is_partition_of_bounded_interval(I, P1)
    forall J P2:
        exist K P1 st {J $in power_set(R), K $in power_set(R), J $subset K}

"""
Example 11.1.15.  Splitting `[1,4]` into `[1,2)`, `{2}`, `(2,3)`, and
`[3,4]` gives a partition finer than `{[1,2],(2,4]}`.  There is no finest
finite partition of `[1,4]`.
"""

# The concrete refinement check is the four piece-containment computations.
# The no-finest assertion is the general observation that any non-degenerate
# finite partition can be split again.

thm example_11_1_15_refinement_piece_containments:
    ? forall:
        '[1, 2) $subset '[1, 2]
        {2} $subset '[1, 2]
        '(2, 3) $subset '(2, 4]
        '[3, 4] $subset '(2, 4]
    claim:
        ? '[1, 2) $subset '[1, 2]
        forall x '[1, 2):
            1 <= x
            x < 2
            x <= 2
            x $in '[1, 2]
        '[1, 2) $subset '[1, 2]
    claim:
        ? {2} $subset '[1, 2]
        forall x {2}:
            x = 2
            1 <= x
            x <= 2
            x $in '[1, 2]
        {2} $subset '[1, 2]
    claim:
        ? '(2, 3) $subset '(2, 4]
        forall x '(2, 3):
            2 < x
            x < 3
            x <= 3 < 4
            x <= 4
            x $in '(2, 4]
        '(2, 3) $subset '(2, 4]
    claim:
        ? '[3, 4] $subset '(2, 4]
        forall x '[3, 4]:
            3 <= x
            2 < 3 <= x
            2 < x
            x <= 4
            x $in '(2, 4]
        '[3, 4] $subset '(2, 4]

thm example_11_1_15_membership_pattern_is_finer:
    ? forall Pfine, Pcoarse finite_set:
        $is_partition_of_bounded_interval('[1, 4], Pfine)
        $is_partition_of_bounded_interval('[1, 4], Pcoarse)
        forall J Pfine:
            J = '[1, 2) or J = {2} or J = '(2, 3) or J = '[3, 4]
        '[1, 2] $in Pcoarse
        '(2, 4] $in Pcoarse
        =>:
            $is_finer_partition_than('[1, 4], Pfine, Pcoarse)
    # Source handling: once the displayed families are known to be partitions,
    # Definition 11.1.14 reduces the refinement check to the four containments
    # above.
    by thm example_11_1_15_refinement_piece_containments()
    claim:
        ? forall J Pfine:
            exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K}
        J = '[1, 2) or J = {2} or J = '(2, 3) or J = '[3, 4]
        J $in power_set(R)
        '[1, 2] $in power_set(R)
        '(2, 4] $in power_set(R)
        by cases:
            ? exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K}
            case J = '[1, 2):
                witness exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K} from '[1, 2]:
                    J $in power_set(R)
                    '[1, 2] $in power_set(R)
                    J $subset '[1, 2]
            case J = {2}:
                witness exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K} from '[1, 2]:
                    J $in power_set(R)
                    '[1, 2] $in power_set(R)
                    J $subset '[1, 2]
            case J = '(2, 3):
                witness exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K} from '(2, 4]:
                    J $in power_set(R)
                    '(2, 4] $in power_set(R)
                    J $subset '(2, 4]
            case J = '[3, 4]:
                witness exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K} from '(2, 4]:
                    J $in power_set(R)
                    '(2, 4] $in power_set(R)
                    J $subset '(2, 4]
    $is_finer_partition_than('[1, 4], Pfine, Pcoarse)

"""
Definition 11.1.16 (Common refinement).  The common refinement `P#Q` consists
of all intersections `J intersect K` with `J in P` and `K in Q`.
"""

prop is_common_refinement_of_partitions(I power_set(R), P, Qpart, Rf finite_set):
    $is_partition_of_bounded_interval(I, P)
    $is_partition_of_bounded_interval(I, Qpart)
    $is_partition_of_bounded_interval(I, Rf)
    forall H Rf:
        exist J P, K Qpart st {J $in power_set(R), K $in power_set(R), H = intersect(J, K)}
    forall J P, K Qpart:
        J $in power_set(R)
        K $in power_set(R)
        =>:
            exist H Rf st {H = intersect(J, K)}

"""
Example 11.1.17.  Intersecting the pieces of `{[1,3),[3,4]}` with the pieces
of `{[1,2],(2,4]}` gives `{[1,2],(2,3),[3,4],empty}`.
"""

thm example_11_1_17_common_refinement_intersections:
    ? forall:
        intersect('[1, 3), '[1, 2]) = '[1, 2]
        intersect('[1, 3), '(2, 4]) = '(2, 3)
        intersect('[3, 4], '[1, 2]) = {}
        intersect('[3, 4], '(2, 4]) = '[3, 4]
    # Source handling: this is the direct endpoint calculation behind the
    # displayed common-refinement family.
    by extension intersect('[1, 3), '[1, 2]) = '[1, 2]:
        forall z intersect('[1, 3), '[1, 2]):
            z $in '[1, 3)
            z $in '[1, 2]
            z $in '[1, 2]
        forall z '[1, 2]:
            1 <= z
            z <= 2
            2 < 3
            z <= 2 < 3
            z < 3
            z $in '[1, 3)
            z $in '[1, 2]
            z $in intersect('[1, 3), '[1, 2])
    by extension intersect('[1, 3), '(2, 4]) = '(2, 3):
        forall z intersect('[1, 3), '(2, 4]):
            z $in '[1, 3)
            z $in '(2, 4]
            2 < z
            z < 3
            z $in '(2, 3)
        forall z '(2, 3):
            2 < z
            z < 3
            1 < 2 < z
            1 < z
            1 <= z
            z < 3 < 4
            z < 4
            z <= 4
            z $in '[1, 3)
            z $in '(2, 4]
            z $in intersect('[1, 3), '(2, 4])
    by extension intersect('[3, 4], '[1, 2]) = {}:
        claim:
            ? forall z intersect('[3, 4], '[1, 2]):
                z $in {}
            z $in '[3, 4]
            z $in '[1, 2]
            3 <= z
            z <= 2
            2 < 3 <= z
            2 < z
            by contra:
                ? z $in {}
                not z $in {}
                impossible z <= 2
        claim:
            ? forall z {}:
                z $in intersect('[3, 4], '[1, 2])
            by contra:
                ? z $in intersect('[3, 4], '[1, 2])
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from z
                impossible $is_nonempty_set({})
    by extension intersect('[3, 4], '(2, 4]) = '[3, 4]:
        forall z intersect('[3, 4], '(2, 4]):
            z $in '[3, 4]
            z $in '[3, 4]
        forall z '[3, 4]:
            3 <= z
            z <= 4
            2 < 3 <= z
            2 < z
            z $in '(2, 4]
            z $in '[3, 4]
            z $in intersect('[3, 4], '(2, 4])

"""
Lemma 11.1.18.  The common refinement of two partitions of `I` is a partition
of `I`, and it is finer than both original partitions.
"""

thm common_refinement_is_partition_and_finer:
    ? forall I power_set(R), P, Qpart, Rf finite_set:
        $is_common_refinement_of_partitions(I, P, Qpart, Rf)
        =>:
            $is_partition_of_bounded_interval(I, Rf)
            $is_finer_partition_than(I, Rf, P)
            $is_finer_partition_than(I, Rf, Qpart)
    # Source handling: Tao proves this in Exercise 11.1.4.
    $is_partition_of_bounded_interval(I, P)
    $is_partition_of_bounded_interval(I, Qpart)
    $is_partition_of_bounded_interval(I, Rf)
    claim:
        ? forall H Rf:
            exist K P st {H $in power_set(R), K $in power_set(R), H $subset K}
        obtain J, K from exist J P, K Qpart st {J $in power_set(R), K $in power_set(R), H = intersect(J, K)}
        claim:
            ? H $subset J
            forall x H:
                x $in intersect(J, K)
                x $in J
            H $subset J
        witness exist K0 P st {H $in power_set(R), K0 $in power_set(R), H $subset K0} from J:
            H $in power_set(R)
            J $in power_set(R)
            H $subset J
    $is_finer_partition_than(I, Rf, P)
    claim:
        ? forall H Rf:
            exist K Qpart st {H $in power_set(R), K $in power_set(R), H $subset K}
        obtain J, K from exist J P, K Qpart st {J $in power_set(R), K $in power_set(R), H = intersect(J, K)}
        claim:
            ? H $subset K
            forall x H:
                x $in intersect(J, K)
                x $in K
            H $subset K
        witness exist K0 Qpart st {H $in power_set(R), K0 $in power_set(R), H $subset K0} from K:
            H $in power_set(R)
            K $in power_set(R)
            H $subset K
    $is_finer_partition_than(I, Rf, Qpart)

thm common_refinement_exists_for_partitions:
    ? forall I power_set(R), P, Qpart finite_set:
        $is_partition_of_bounded_interval(I, P)
        $is_partition_of_bounded_interval(I, Qpart)
        =>:
            exist Rf finite_set st {$is_common_refinement_of_partitions(I, P, Qpart, Rf)}
    # Source handling: the intended witness is the finite set of all
    # intersections `J intersect K` with `J in P` and `K in Qpart`.
    # trust: formalize the finite image/product construction of this set.
    trust exist Rf finite_set st {$is_common_refinement_of_partitions(I, P, Qpart, Rf)}


# 11.2 Piecewise constant functions

"""
Definition 11.2.1 (Constant functions).  A function is constant on a set when
there is a real number `c` such that every value on the set equals `c`.
"""

prop has_constant_value_on_subset(I power_set(R), E power_set(R), f fn(x I) R, c R):
    E $subset I
    forall x E:
        f(x) = c

prop is_constant_on_subset(I power_set(R), E power_set(R), f fn(x I) R):
    exist c R st {$has_constant_value_on_subset(I, E, f, c)}

"""
Remark 11.2.2.  On a non-empty set, the constant value is unique; on the empty
set every real number is vacuously a constant value.
"""

thm nonempty_constant_value_unique:
    ? forall I power_set(R), E power_set(R), f fn(x I) R, c1, c2 R:
        E $subset I
        $is_nonempty_set(E)
        forall x E:
            f(x) = c1
        forall x E:
            f(x) = c2
        =>:
            c1 = c2
    # Source handling: this is the direct non-empty witness argument in the
    # remark.
    have x E
    f(x) = c1
    f(x) = c2
    c1 = f(x) = c2

thm constant_on_subset_add:
    ? forall I power_set(R), E power_set(R), f, g fn(x I) R:
        E $subset I
        $is_constant_on_subset(I, E, f)
        $is_constant_on_subset(I, E, g)
        =>:
            $is_constant_on_subset(I, E, fn(x I) R {f(x) + g(x)})
    # Source handling: this is the same-piece algebra step used in Exercise
    # 11.2.2 before passing to a common refinement.
    obtain cf from exist c R st {$has_constant_value_on_subset(I, E, f, c)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, E, g, c)}
    witness exist c R st {$has_constant_value_on_subset(I, E, fn(x I) R {f(x) + g(x)}, c)} from cf + cg:
        E $subset I
        forall x E:
            x $in I
            f(x) = cf
            g(x) = cg
            fn(x I) R {f(x) + g(x)}(x) = f(x) + g(x)
            fn(x I) R {f(x) + g(x)}(x) = cf + cg
        $has_constant_value_on_subset(I, E, fn(x I) R {f(x) + g(x)}, cf + cg)
    $is_constant_on_subset(I, E, fn(x I) R {f(x) + g(x)})

thm constant_on_subset_sub:
    ? forall I power_set(R), E power_set(R), f, g fn(x I) R:
        E $subset I
        $is_constant_on_subset(I, E, f)
        $is_constant_on_subset(I, E, g)
        =>:
            $is_constant_on_subset(I, E, fn(x I) R {f(x) - g(x)})
    # Source handling: this is the same-piece subtraction step used in
    # Exercise 11.2.2.
    obtain cf from exist c R st {$has_constant_value_on_subset(I, E, f, c)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, E, g, c)}
    witness exist c R st {$has_constant_value_on_subset(I, E, fn(x I) R {f(x) - g(x)}, c)} from cf - cg:
        E $subset I
        forall x E:
            x $in I
            f(x) = cf
            g(x) = cg
            fn(x I) R {f(x) - g(x)}(x) = f(x) - g(x)
            fn(x I) R {f(x) - g(x)}(x) = cf - cg
        $has_constant_value_on_subset(I, E, fn(x I) R {f(x) - g(x)}, cf - cg)
    $is_constant_on_subset(I, E, fn(x I) R {f(x) - g(x)})

thm constant_on_subset_mul:
    ? forall I power_set(R), E power_set(R), f, g fn(x I) R:
        E $subset I
        $is_constant_on_subset(I, E, f)
        $is_constant_on_subset(I, E, g)
        =>:
            $is_constant_on_subset(I, E, fn(x I) R {f(x) * g(x)})
    # Source handling: this is the same-piece multiplication step used in
    # Exercise 11.2.2.
    obtain cf from exist c R st {$has_constant_value_on_subset(I, E, f, c)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, E, g, c)}
    witness exist c R st {$has_constant_value_on_subset(I, E, fn(x I) R {f(x) * g(x)}, c)} from cf * cg:
        E $subset I
        forall x E:
            x $in I
            f(x) = cf
            g(x) = cg
            fn(x I) R {f(x) * g(x)}(x) = f(x) * g(x)
            fn(x I) R {f(x) * g(x)}(x) = cf * cg
        $has_constant_value_on_subset(I, E, fn(x I) R {f(x) * g(x)}, cf * cg)
    $is_constant_on_subset(I, E, fn(x I) R {f(x) * g(x)})

thm constant_on_subset_max:
    ? forall I power_set(R), E power_set(R), f, g fn(x I) R:
        E $subset I
        $is_constant_on_subset(I, E, f)
        $is_constant_on_subset(I, E, g)
        =>:
            $is_constant_on_subset(I, E, fn(x I) R {max(f(x), g(x))})
    # Source handling: this is the same-piece maximum step used in Exercise
    # 11.2.2.
    obtain cf from exist c R st {$has_constant_value_on_subset(I, E, f, c)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, E, g, c)}
    witness exist c R st {$has_constant_value_on_subset(I, E, fn(x I) R {max(f(x), g(x))}, c)} from max(cf, cg):
        E $subset I
        forall x E:
            x $in I
            f(x) = cf
            g(x) = cg
            fn(x I) R {max(f(x), g(x))}(x) = max(f(x), g(x))
            fn(x I) R {max(f(x), g(x))}(x) = max(cf, cg)
        $has_constant_value_on_subset(I, E, fn(x I) R {max(f(x), g(x))}, max(cf, cg))
    $is_constant_on_subset(I, E, fn(x I) R {max(f(x), g(x))})

thm constant_on_subset_min:
    ? forall I power_set(R), E power_set(R), f, g fn(x I) R:
        E $subset I
        $is_constant_on_subset(I, E, f)
        $is_constant_on_subset(I, E, g)
        =>:
            $is_constant_on_subset(I, E, fn(x I) R {min(f(x), g(x))})
    # Source handling: this is the same-piece minimum step used in Theorem
    # 11.4.3.
    obtain cf from exist c R st {$has_constant_value_on_subset(I, E, f, c)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, E, g, c)}
    witness exist c R st {$has_constant_value_on_subset(I, E, fn(x I) R {min(f(x), g(x))}, c)} from min(cf, cg):
        E $subset I
        forall x E:
            x $in I
            f(x) = cf
            g(x) = cg
            fn(x I) R {min(f(x), g(x))}(x) = min(f(x), g(x))
            fn(x I) R {min(f(x), g(x))}(x) = min(cf, cg)
        $has_constant_value_on_subset(I, E, fn(x I) R {min(f(x), g(x))}, min(cf, cg))
    $is_constant_on_subset(I, E, fn(x I) R {min(f(x), g(x))})

thm constant_on_subset_scalar_mul:
    ? forall I power_set(R), E power_set(R), f fn(x I) R, c R:
        E $subset I
        $is_constant_on_subset(I, E, f)
        =>:
            $is_constant_on_subset(I, E, fn(x I) R {c * f(x)})
    # Source handling: scalar multiplication is another same-piece algebra
    # step used by the linearity laws.
    obtain cf from exist cf R st {$has_constant_value_on_subset(I, E, f, cf)}
    witness exist c0 R st {$has_constant_value_on_subset(I, E, fn(x I) R {c * f(x)}, c0)} from c * cf:
        E $subset I
        forall x E:
            x $in I
            f(x) = cf
            fn(x I) R {c * f(x)}(x) = c * f(x)
            fn(x I) R {c * f(x)}(x) = c * cf
        $has_constant_value_on_subset(I, E, fn(x I) R {c * f(x)}, c * cf)
    $is_constant_on_subset(I, E, fn(x I) R {c * f(x)})

thm constant_on_subset_quotient:
    ? forall I power_set(R), E power_set(R), f, g fn(x I) R:
        E $subset I
        $is_constant_on_subset(I, E, f)
        $is_constant_on_subset(I, E, g)
        $is_nonzero_on(I, g)
        =>:
            $is_constant_on_subset(I, E, fn(x I) R {f(x) / g(x)})
    # Source handling: this is the same-piece quotient step used in Exercise
    # 11.2.2 when the denominator is nonzero on the whole interval.
    obtain cf from exist c R st {$has_constant_value_on_subset(I, E, f, c)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, E, g, c)}
    by cases:
        ? $is_constant_on_subset(I, E, fn(x I) R {f(x) / g(x)})
        case $is_nonempty_set(E):
            have x0 E
            x0 $in I
            g(x0) = cg
            g(x0) != 0
            cg != 0
            witness exist c0 R st {$has_constant_value_on_subset(I, E, fn(x I) R {f(x) / g(x)}, c0)} from cf / cg:
                E $subset I
                forall x E:
                    x $in I
                    f(x) = cf
                    g(x) = cg
                    g(x) != 0
                    cg != 0
                    fn(x I) R {f(x) / g(x)}(x) = f(x) / g(x)
                    fn(x I) R {f(x) / g(x)}(x) = cf / cg
                $has_constant_value_on_subset(I, E, fn(x I) R {f(x) / g(x)}, cf / cg)
        case not $is_nonempty_set(E):
            witness exist c0 R st {$has_constant_value_on_subset(I, E, fn(x I) R {f(x) / g(x)}, c0)} from 0:
                E $subset I
                claim:
                    ? forall x E:
                        fn(x I) R {f(x) / g(x)}(x) = 0
                    by contra:
                        ? fn(x I) R {f(x) / g(x)}(x) = 0
                        x $in E
                        not $is_nonempty_set(E)
                        witness $is_nonempty_set(E) from x
                        impossible $is_nonempty_set(E)
                $has_constant_value_on_subset(I, E, fn(x I) R {f(x) / g(x)}, 0)

"""
Definition 11.2.3 (Piecewise constant functions I).  A function is piecewise
constant with respect to a partition when it is constant on each partition
piece.
"""

prop is_piecewise_constant_with_partition(I power_set(R), P finite_set, f fn(x I) R):
    $is_partition_of_bounded_interval(I, P)
    forall J P:
        J $in power_set(R)
        $is_constant_on_subset(I, J, f)

thm piecewise_constant_same_partition_add:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        $is_piecewise_constant_with_partition(I, P, g)
        =>:
            $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) + g(x)})
    # Source handling: this proves the easy same-partition part of the
    # addition law; the full law still needs a common refinement.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {f(x) + g(x)})
        J $in power_set(R)
        J $subset I
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        by thm constant_on_subset_add(I, J, f, g)
        $is_constant_on_subset(I, J, fn(x I) R {f(x) + g(x)})
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) + g(x)})

thm piecewise_constant_same_partition_sub:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        $is_piecewise_constant_with_partition(I, P, g)
        =>:
            $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) - g(x)})
    # Source handling: this proves the easy same-partition part of the
    # subtraction law.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {f(x) - g(x)})
        J $in power_set(R)
        J $subset I
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        by thm constant_on_subset_sub(I, J, f, g)
        $is_constant_on_subset(I, J, fn(x I) R {f(x) - g(x)})
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) - g(x)})

thm piecewise_constant_same_partition_mul:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        $is_piecewise_constant_with_partition(I, P, g)
        =>:
            $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) * g(x)})
    # Source handling: this proves the easy same-partition part of the
    # multiplication law.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {f(x) * g(x)})
        J $in power_set(R)
        J $subset I
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        by thm constant_on_subset_mul(I, J, f, g)
        $is_constant_on_subset(I, J, fn(x I) R {f(x) * g(x)})
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) * g(x)})

thm piecewise_constant_same_partition_max:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        $is_piecewise_constant_with_partition(I, P, g)
        =>:
            $is_piecewise_constant_with_partition(I, P, fn(x I) R {max(f(x), g(x))})
    # Source handling: this proves the easy same-partition part of the maximum
    # law.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {max(f(x), g(x))})
        J $in power_set(R)
        J $subset I
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        by thm constant_on_subset_max(I, J, f, g)
        $is_constant_on_subset(I, J, fn(x I) R {max(f(x), g(x))})
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {max(f(x), g(x))})

thm piecewise_constant_same_partition_min:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        $is_piecewise_constant_with_partition(I, P, g)
        =>:
            $is_piecewise_constant_with_partition(I, P, fn(x I) R {min(f(x), g(x))})
    # Source handling: this proves the easy same-partition part of the
    # minimum law.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {min(f(x), g(x))})
        J $in power_set(R)
        J $subset I
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        by thm constant_on_subset_min(I, J, f, g)
        $is_constant_on_subset(I, J, fn(x I) R {min(f(x), g(x))})
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {min(f(x), g(x))})

thm piecewise_constant_same_partition_scalar_mul:
    ? forall I power_set(R), P finite_set, f fn(x I) R, c R:
        $is_piecewise_constant_with_partition(I, P, f)
        =>:
            $is_piecewise_constant_with_partition(I, P, fn(x I) R {c * f(x)})
    # Source handling: this is the same-partition scalar multiplication step.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {c * f(x)})
        J $in power_set(R)
        J $subset I
        $is_constant_on_subset(I, J, f)
        by thm constant_on_subset_scalar_mul(I, J, f, c)
        $is_constant_on_subset(I, J, fn(x I) R {c * f(x)})
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {c * f(x)})

thm piecewise_constant_same_partition_quotient:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        $is_piecewise_constant_with_partition(I, P, g)
        $is_nonzero_on(I, g)
        =>:
            $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) / g(x)})
    # Source handling: this is the same-partition quotient step.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {f(x) / g(x)})
        J $in power_set(R)
        J $subset I
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        by thm constant_on_subset_quotient(I, J, f, g)
        $is_constant_on_subset(I, J, fn(x I) R {f(x) / g(x)})
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) / g(x)})

"""
Example 11.2.4.  The function on `[1,6]` with values `7` on `[1,3)`, `4` at
`3`, `5` on `(3,6)`, and `2` at `6` is piecewise constant for the displayed
partition and for any refinement that keeps the same constant pieces.
"""

prop is_example_11_2_4_function(f fn(x '[1, 6]) R):
    forall x '[1, 6]:
        x < 3
        =>:
            f(x) = 7
    forall x '[1, 6]:
        x = 3
        =>:
            f(x) = 4
    forall x '[1, 6]:
        x > 3
        x < 6
        =>:
            f(x) = 5
    forall x '[1, 6]:
        x = 6
        =>:
            f(x) = 2

prop is_example_11_2_4_displayed_partition(P finite_set):
    '[1, 3) $in P
    {3} $in P
    '(3, 6) $in P
    {6} $in P
    forall J P:
        J = '[1, 3) or J = {3} or J = '(3, 6) or J = {6}

prop is_example_11_2_4_book_refined_partition(P finite_set):
    '[1, 2) $in P
    {2} $in P
    '(2, 3) $in P
    {3} $in P
    '(3, 5) $in P
    '[5, 6) $in P
    {6} $in P
    {} $in P
    forall J P:
        J = '[1, 2) or J = {2} or J = '(2, 3) or J = {3} or J = '(3, 5) or J = '[5, 6) or J = {6} or J = {}

prop is_example_11_2_4_constant_preserving_partition(P finite_set):
    $is_partition_of_bounded_interval('[1, 6], P)
    forall J P:
        J $subset '[1, 3) or J $subset {3} or J $subset '(3, 6) or J $subset {6}

thm example_11_2_4_piecewise_constant_for_constant_preserving_partitions:
    ? forall f fn(x '[1, 6]) R, P finite_set:
        $is_example_11_2_4_function(f)
        $is_example_11_2_4_constant_preserving_partition(P)
        =>:
            $is_piecewise_constant_with_partition('[1, 6], P, f)
    # Source handling: each piece of such a partition sits inside one of the
    # four regions on which the displayed function has a fixed value.
    $is_partition_of_bounded_interval('[1, 6], P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset('[1, 6], J, f)
        J $in power_set(R)
        J $subset '[1, 6]
        J $subset '[1, 3) or J $subset {3} or J $subset '(3, 6) or J $subset {6}
        by cases:
            ? $is_constant_on_subset('[1, 6], J, f)
            case J $subset '[1, 3):
                witness exist c R st {$has_constant_value_on_subset('[1, 6], J, f, c)} from 7:
                    J $subset '[1, 6]
                    forall x J:
                        x $in '[1, 6]
                        x $in '[1, 3)
                        x < 3
                        f(x) = 7
                    $has_constant_value_on_subset('[1, 6], J, f, 7)
            case J $subset {3}:
                witness exist c R st {$has_constant_value_on_subset('[1, 6], J, f, c)} from 4:
                    J $subset '[1, 6]
                    forall x J:
                        x $in '[1, 6]
                        x $in {3}
                        x = 3
                        f(x) = 4
                    $has_constant_value_on_subset('[1, 6], J, f, 4)
            case J $subset '(3, 6):
                witness exist c R st {$has_constant_value_on_subset('[1, 6], J, f, c)} from 5:
                    J $subset '[1, 6]
                    forall x J:
                        x $in '[1, 6]
                        x $in '(3, 6)
                        3 < x
                        x > 3
                        x < 6
                        f(x) = 5
                    $has_constant_value_on_subset('[1, 6], J, f, 5)
            case J $subset {6}:
                witness exist c R st {$has_constant_value_on_subset('[1, 6], J, f, c)} from 2:
                    J $subset '[1, 6]
                    forall x J:
                        x $in '[1, 6]
                        x $in {6}
                        x = 6
                        f(x) = 2
                    $has_constant_value_on_subset('[1, 6], J, f, 2)
        $is_constant_on_subset('[1, 6], J, f)
    $is_piecewise_constant_with_partition('[1, 6], P, f)

"""
Definition 11.2.5 (Piecewise constant functions II).  A function is piecewise
constant on `I` if some partition of `I` makes it piecewise constant.
"""

prop is_piecewise_constant_on(I power_set(R), f fn(x I) R):
    exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f)}

thm piecewise_constant_with_partition_is_piecewise_constant:
    ? forall I power_set(R), P finite_set, f fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        =>:
            $is_piecewise_constant_on(I, f)
    # Source handling: this is just Definition 11.2.5 with the displayed
    # partition as witness.
    witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, f)} from P:
        $is_piecewise_constant_with_partition(I, P, f)
    $is_piecewise_constant_on(I, f)

"""
Example 11.2.6.  The previous example is piecewise constant on `[1,6]`, and
every constant function on a bounded interval is piecewise constant.
"""

thm constant_function_is_piecewise_constant_with_one_piece_partition:
    ? forall I power_set(R), c R:
        $is_bounded_interval(I)
        =>:
            $is_piecewise_constant_with_partition(I, {I}, fn(x I) R {c})
    # Source handling: the single piece is the whole interval, so the displayed
    # constant function has value `c` on every point of that piece.
    by thm one_piece_partition_of_bounded_interval(I)
    $is_partition_of_bounded_interval(I, {I})
    claim:
        ? forall J {I}:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {c})
        J = I
        J $in power_set(R)
        J $subset I
        witness exist c0 R st {$has_constant_value_on_subset(I, J, fn(x I) R {c}, c0)} from c:
            J $subset I
            forall x J:
                x $in I
                fn(x I) R {c}(x) = c
            $has_constant_value_on_subset(I, J, fn(x I) R {c}, c)
        $is_constant_on_subset(I, J, fn(x I) R {c})
    $is_piecewise_constant_with_partition(I, {I}, fn(x I) R {c})

thm constant_function_is_piecewise_constant:
    ? forall I power_set(R), c R:
        $is_bounded_interval(I)
        =>:
            $is_piecewise_constant_on(I, fn(x I) R {c})
    # Source handling: Tao marks this as `(why?)`; the one-piece partition
    # `{I}` witnesses piecewise constancy.
    by thm constant_function_is_piecewise_constant_with_one_piece_partition(I, c)
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {c})} from {I}:
        $is_piecewise_constant_with_partition(I, {I}, fn(x I) R {c})
    $is_piecewise_constant_on(I, fn(x I) R {c})

"""
Lemma 11.2.7.  If a partition is refined, a function piecewise constant on the
coarser partition remains piecewise constant on the finer partition.
"""

thm piecewise_constant_refines:
    ? forall I power_set(R), Pcoarse, Pfine finite_set, f fn(x I) R:
        $is_piecewise_constant_with_partition(I, Pcoarse, f)
        $is_finer_partition_than(I, Pfine, Pcoarse)
        =>:
            $is_piecewise_constant_with_partition(I, Pfine, f)
    # Source handling: Tao proves this in Exercise 11.2.1.
    # Each fine piece lies in a coarse piece, and the coarse constant value
    # restricts to the fine piece.
    $is_partition_of_bounded_interval(I, Pfine)
    claim:
        ? forall J Pfine:
            J $in power_set(R)
            $is_constant_on_subset(I, J, f)
        J $in power_set(R)
        J $subset I
        obtain K from exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K}
        K $in power_set(R)
        J $subset K
        $is_constant_on_subset(I, K, f)
        obtain c from exist c R st {$has_constant_value_on_subset(I, K, f, c)}
        witness exist c0 R st {$has_constant_value_on_subset(I, J, f, c0)} from c:
            J $subset I
            forall x J:
                x $in K
                f(x) = c
            $has_constant_value_on_subset(I, J, f, c)
        $is_constant_on_subset(I, J, f)
    $is_piecewise_constant_with_partition(I, Pfine, f)

"""
Lemma 11.2.8.  Piecewise constant functions are closed under addition,
subtraction, max, min, multiplication, and quotients by non-vanishing
denominators.
"""

thm piecewise_constant_algebra:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_piecewise_constant_on(I, f)
        $is_piecewise_constant_on(I, g)
        =>:
            $is_piecewise_constant_on(I, fn(x I) R {f(x) + g(x)})
            $is_piecewise_constant_on(I, fn(x I) R {f(x) - g(x)})
            $is_piecewise_constant_on(I, fn(x I) R {max(f(x), g(x))})
            $is_piecewise_constant_on(I, fn(x I) R {min(f(x), g(x))})
            $is_piecewise_constant_on(I, fn(x I) R {f(x) * g(x)})
    # Source handling: Tao proves this in Exercise 11.2.2 by passing to a
    # common refinement.
    obtain Pf from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f)}
    obtain Pg from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, g)}
    $is_partition_of_bounded_interval(I, Pf)
    $is_partition_of_bounded_interval(I, Pg)
    by thm common_refinement_exists_for_partitions(I, Pf, Pg)
    obtain Rf from exist Rf finite_set st {$is_common_refinement_of_partitions(I, Pf, Pg, Rf)}
    by thm common_refinement_is_partition_and_finer(I, Pf, Pg, Rf)
    by thm piecewise_constant_refines(I, Pf, Rf, f)
    by thm piecewise_constant_refines(I, Pg, Rf, g)
    by thm piecewise_constant_same_partition_add(I, Rf, f, g)
    by thm piecewise_constant_same_partition_sub(I, Rf, f, g)
    by thm piecewise_constant_same_partition_max(I, Rf, f, g)
    by thm piecewise_constant_same_partition_min(I, Rf, f, g)
    by thm piecewise_constant_same_partition_mul(I, Rf, f, g)
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) + g(x)})} from Rf:
        $is_piecewise_constant_with_partition(I, Rf, fn(x I) R {f(x) + g(x)})
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) - g(x)})} from Rf:
        $is_piecewise_constant_with_partition(I, Rf, fn(x I) R {f(x) - g(x)})
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {max(f(x), g(x))})} from Rf:
        $is_piecewise_constant_with_partition(I, Rf, fn(x I) R {max(f(x), g(x))})
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {min(f(x), g(x))})} from Rf:
        $is_piecewise_constant_with_partition(I, Rf, fn(x I) R {min(f(x), g(x))})
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) * g(x)})} from Rf:
        $is_piecewise_constant_with_partition(I, Rf, fn(x I) R {f(x) * g(x)})
    $is_piecewise_constant_on(I, fn(x I) R {f(x) + g(x)})
    $is_piecewise_constant_on(I, fn(x I) R {f(x) - g(x)})
    $is_piecewise_constant_on(I, fn(x I) R {max(f(x), g(x))})
    $is_piecewise_constant_on(I, fn(x I) R {min(f(x), g(x))})
    $is_piecewise_constant_on(I, fn(x I) R {f(x) * g(x)})

thm piecewise_constant_quotient:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_piecewise_constant_on(I, f)
        $is_piecewise_constant_on(I, g)
        $is_nonzero_on(I, g)
        =>:
            $is_piecewise_constant_on(I, fn(x I) R {f(x) / g(x)})
    # Source handling: this is the quotient clause of Exercise 11.2.2.
    obtain Pf from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f)}
    obtain Pg from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, g)}
    $is_partition_of_bounded_interval(I, Pf)
    $is_partition_of_bounded_interval(I, Pg)
    by thm common_refinement_exists_for_partitions(I, Pf, Pg)
    obtain Rf from exist Rf finite_set st {$is_common_refinement_of_partitions(I, Pf, Pg, Rf)}
    by thm common_refinement_is_partition_and_finer(I, Pf, Pg, Rf)
    by thm piecewise_constant_refines(I, Pf, Rf, f)
    by thm piecewise_constant_refines(I, Pg, Rf, g)
    by thm piecewise_constant_same_partition_quotient(I, Rf, f, g)
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) / g(x)})} from Rf:
        $is_piecewise_constant_with_partition(I, Rf, fn(x I) R {f(x) / g(x)})
    $is_piecewise_constant_on(I, fn(x I) R {f(x) / g(x)})

"""
Definition 11.2.9 (Piecewise constant integral I).  With respect to a
partition `P`, the piecewise constant integral is the finite sum of each
constant value on a piece times that piece's length.
"""

prop has_piecewise_constant_integral_piece_contribution(I power_set(R), J power_set(R), f fn(x I) R, t R):
    $is_bounded_interval(J)
    $is_constant_on_subset(I, J, f)
    exist c R st {$has_constant_value_on_subset(I, J, f, c), t = c * interval_length(J)}

thm piecewise_constant_integral_piece_contribution_unique:
    ? forall I, J power_set(R), f fn(x I) R, t1, t2 R:
        $has_piecewise_constant_integral_piece_contribution(I, J, f, t1)
        $has_piecewise_constant_integral_piece_contribution(I, J, f, t2)
        =>:
            t1 = t2
    # Source handling: on a non-empty piece, the constant value is unique; on
    # the empty piece, every constant value gives contribution zero because
    # `interval_length({}) = 0`.
    obtain c1 from exist c R st {$has_constant_value_on_subset(I, J, f, c), t1 = c * interval_length(J)}
    obtain c2 from exist c R st {$has_constant_value_on_subset(I, J, f, c), t2 = c * interval_length(J)}
    $has_constant_value_on_subset(I, J, f, c1)
    $has_constant_value_on_subset(I, J, f, c2)
    t1 = c1 * interval_length(J)
    t2 = c2 * interval_length(J)
    by cases:
        ? t1 = t2
        case $is_nonempty_set(J):
            by thm nonempty_constant_value_unique(I, J, f, c1, c2)
            c1 = c2
            t1 = c1 * interval_length(J) = c2 * interval_length(J) = t2
        case not $is_nonempty_set(J):
            by thm empty_bounded_interval_length_value(J)
            t1 = c1 * interval_length(J) = c1 * 0 = 0
            t2 = c2 * interval_length(J) = c2 * 0 = 0
            t1 = t2

have fn piecewise_constant_integral_piece_contribution by exist!:
    ? forall I, J power_set(R), f fn(x I) R:
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        =>:
            exist! t R st {$has_piecewise_constant_integral_piece_contribution(I, J, f, t)}
    obtain cv from exist c R st {$has_constant_value_on_subset(I, J, f, c)}
    witness exist t R st {$has_piecewise_constant_integral_piece_contribution(I, J, f, t)} from cv * interval_length(J):
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        witness exist c R st {$has_constant_value_on_subset(I, J, f, c), cv * interval_length(J) = c * interval_length(J)} from cv:
            $has_constant_value_on_subset(I, J, f, cv)
            cv * interval_length(J) = cv * interval_length(J)
        exist c R st {$has_constant_value_on_subset(I, J, f, c), cv * interval_length(J) = c * interval_length(J)}
        $has_piecewise_constant_integral_piece_contribution(I, J, f, cv * interval_length(J))
    claim:
        ? forall t1, t2 R:
            $has_piecewise_constant_integral_piece_contribution(I, J, f, t1)
            $has_piecewise_constant_integral_piece_contribution(I, J, f, t2)
            =>:
                t1 = t2
        by thm piecewise_constant_integral_piece_contribution_unique(I, J, f, t1, t2)
    exist! t R st {$has_piecewise_constant_integral_piece_contribution(I, J, f, t)}

thm piecewise_constant_integral_piece_contribution_has_value:
    ? forall I, J power_set(R), f fn(x I) R, t R:
        $has_piecewise_constant_integral_piece_contribution(I, J, f, t)
        =>:
            piecewise_constant_integral_piece_contribution(I, J, f) = t
    $is_bounded_interval(J)
    $is_constant_on_subset(I, J, f)
    $has_piecewise_constant_integral_piece_contribution(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f))
    by thm piecewise_constant_integral_piece_contribution_unique(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f), t)
    piecewise_constant_integral_piece_contribution(I, J, f) = t

thm piecewise_constant_partition_is_set_of_real_subsets:
    ? forall I power_set(R), P finite_set, f fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        =>:
            P $in power_set(power_set(R))
    # Source handling: every member of a partition is a bounded interval, hence
    # a real subset.  This bridge exposes the type fact needed by the
    # function-valued notation below.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? P $subset power_set(R)
        forall J P:
            J $in power_set(R)
        P $subset power_set(R)
    P $in power_set(power_set(R))

have fn piecewise_constant_integral_with_partition(I power_set(R), P power_set(power_set(R)), f fn(x I) R: $is_finite_set(P), $is_piecewise_constant_with_partition(I, P, f)) R = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)})

prop has_piecewise_constant_integral_with_partition(I power_set(R), P finite_set, f fn(x I) R, s R):
    P $in power_set(power_set(R))
    $is_piecewise_constant_with_partition(I, P, f)
    s = piecewise_constant_integral_with_partition(I, P, f)

thm piecewise_constant_integral_with_partition_has_value:
    ? forall I power_set(R), P finite_set, f fn(x I) R:
        P $in power_set(power_set(R))
        $is_piecewise_constant_with_partition(I, P, f)
        =>:
            $has_piecewise_constant_integral_with_partition(I, P, f, piecewise_constant_integral_with_partition(I, P, f))

thm one_piece_piecewise_constant_integral_with_partition_value:
    ? forall I power_set(R), f fn(x I) R, t R:
        $is_piecewise_constant_with_partition(I, {I}, f)
        $has_piecewise_constant_integral_piece_contribution(I, I, f, t)
        =>:
            $has_piecewise_constant_integral_with_partition(I, {I}, f, t)
    # Source handling: on the one-piece partition, Definition 11.2.9 is just
    # the single rectangle contribution of the whole interval.
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, {I}, f)
    {I} $in power_set(power_set(R))
    piecewise_constant_integral_with_partition(I, {I}, f) = finite_set_sum({I}, fn(J {I}) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    finite_set_sum({I}, fn(J {I}) R {piecewise_constant_integral_piece_contribution(I, J, f)}) = piecewise_constant_integral_piece_contribution(I, I, f)
    by thm piecewise_constant_integral_piece_contribution_has_value(I, I, f, t)
    piecewise_constant_integral_piece_contribution(I, I, f) = t
    piecewise_constant_integral_with_partition(I, {I}, f) = t
    $has_piecewise_constant_integral_with_partition(I, {I}, f, t)

"""
Remark 11.2.10.  Empty pieces do not make the value ambiguous because their
length is zero, and the sum is finite because partitions are finite.
"""

"""
Remark 11.2.11.  The piecewise constant integral is the signed-rectangle area
formula for functions that are constant on finitely many pieces.
"""

"""
Example 11.2.12.  The function taking values `2`, `4`, and `6` on the pieces
`[1,3)`, `{3}`, and `(3,4]` has piecewise constant integral `10`, and the same
value is obtained after refining the first piece and adding an empty piece.
"""

prop is_example_11_2_12_function(f fn(x '[1, 4]) R):
    forall x '[1, 4]:
        x < 3
        =>:
            f(x) = 2
    forall x '[1, 4]:
        x = 3
        =>:
            f(x) = 4
    forall x '[1, 4]:
        x > 3
        =>:
            f(x) = 6

thm example_11_2_12_partition_pieces_are_distinct:
    ? forall:
        '[1, 3) != {3}
        '[1, 3) != '(3, 4]
        {3} != '(3, 4]
        '[1, 2) != '[2, 3)
        '[1, 2) != {3}
        '[1, 2) != '(3, 4]
        '[1, 2) != {}
        '[2, 3) != {3}
        '[2, 3) != '(3, 4]
        '[2, 3) != {}
        {3} != {}
        '(3, 4] != {}
    # Source handling: these are concrete endpoint checks needed only so the
    # displayed finite partitions are well-defined finite sets in Litex.
    by contra:
        ? '[1, 3) != {3}
        '[1, 3) = {3}
        1 $in '[1, 3)
        1 $in {3}
        1 = 3
        impossible 1 = 3
    by contra:
        ? '[1, 3) != '(3, 4]
        '[1, 3) = '(3, 4]
        1 $in '[1, 3)
        1 $in '(3, 4]
        3 < 1
        impossible 3 < 1
    by contra:
        ? {3} != '(3, 4]
        {3} = '(3, 4]
        3 $in {3}
        3 $in '(3, 4]
        3 < 3
        impossible 3 < 3
    by contra:
        ? '[1, 2) != '[2, 3)
        '[1, 2) = '[2, 3)
        1 $in '[1, 2)
        1 $in '[2, 3)
        2 <= 1
        impossible 2 <= 1
    by contra:
        ? '[1, 2) != {3}
        '[1, 2) = {3}
        1 $in '[1, 2)
        1 $in {3}
        1 = 3
        impossible 1 = 3
    by contra:
        ? '[1, 2) != '(3, 4]
        '[1, 2) = '(3, 4]
        1 $in '[1, 2)
        1 $in '(3, 4]
        3 < 1
        impossible 3 < 1
    by contra:
        ? '[1, 2) != {}
        '[1, 2) = {}
        1 $in '[1, 2)
        1 $in {}
        not $is_nonempty_set({})
        witness $is_nonempty_set({}) from 1
        impossible $is_nonempty_set({})
    by contra:
        ? '[2, 3) != {3}
        '[2, 3) = {3}
        2 $in '[2, 3)
        2 $in {3}
        2 = 3
        impossible 2 = 3
    by contra:
        ? '[2, 3) != '(3, 4]
        '[2, 3) = '(3, 4]
        2 $in '[2, 3)
        2 $in '(3, 4]
        3 < 2
        impossible 3 < 2
    by contra:
        ? '[2, 3) != {}
        '[2, 3) = {}
        2 $in '[2, 3)
        2 $in {}
        not $is_nonempty_set({})
        witness $is_nonempty_set({}) from 2
        impossible $is_nonempty_set({})
    by contra:
        ? {3} != {}
        {3} = {}
        3 $in {3}
        3 $in {}
        not $is_nonempty_set({})
        witness $is_nonempty_set({}) from 3
        impossible $is_nonempty_set({})
    by contra:
        ? '(3, 4] != {}
        '(3, 4] = {}
        4 $in '(3, 4]
        4 $in {}
        not $is_nonempty_set({})
        witness $is_nonempty_set({}) from 4
        impossible $is_nonempty_set({})

by thm example_11_2_12_partition_pieces_are_distinct()

have example_11_2_12_partition_set finite_set = {'[1, 3), {3}, '(3, 4]}

have example_11_2_12_refined_partition_set finite_set = {'[1, 2), '[2, 3), {3}, '(3, 4], {}}

thm example_11_2_12_displayed_partition_piece_clauses:
    ? forall J example_11_2_12_partition_set:
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset '[1, 4]
    # trust: expand membership in this named three-cell finite set.  The
    # current finite-set enumeration tactic accepts literal lists but does not
    # enumerate a local finite-set alias.
    trust J = '[1, 3) or J = {3} or J = '(3, 4]
    by cases:
        prove:
            J $in power_set(R)
            $is_bounded_interval(J)
            J $subset '[1, 4]
        case J = '[1, 3):
            by thm non_degenerate_interval_forms_are_bounded_intervals(1, 3)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                forall x J:
                    x $in '[1, 3)
                    1 <= x
                    x < 3
                    x < 3 < 4
                    x < 4
                    x <= 4
                    x $in '[1, 4]
                J $subset '[1, 4]
        case J = {3}:
            by thm singleton_interval_is_bounded(3)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                forall x J:
                    x = 3
                    1 <= x
                    x <= 4
                    x $in '[1, 4]
                J $subset '[1, 4]
        case J = '(3, 4]:
            by thm non_degenerate_interval_forms_are_bounded_intervals(3, 4)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                forall x J:
                    x $in '(3, 4]
                    3 < x
                    x <= 4
                    1 < 3 < x
                    1 < x
                    1 <= x
                    x $in '[1, 4]
                J $subset '[1, 4]

thm example_11_2_12_refined_partition_piece_clauses:
    ? forall J example_11_2_12_refined_partition_set:
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset '[1, 4]
    # trust: this is the five-cell version of the named finite-set
    # enumeration bridge used immediately above.
    trust J = '[1, 2) or J = '[2, 3) or J = {3} or J = '(3, 4] or J = {}
    by cases:
        prove:
            J $in power_set(R)
            $is_bounded_interval(J)
            J $subset '[1, 4]
        case J = '[1, 2):
            by thm non_degenerate_interval_forms_are_bounded_intervals(1, 2)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                forall x J:
                    x $in '[1, 2)
                    1 <= x
                    x < 2
                    x < 2 < 4
                    x < 4
                    x <= 4
                    x $in '[1, 4]
                J $subset '[1, 4]
        case J = '[2, 3):
            by thm non_degenerate_interval_forms_are_bounded_intervals(2, 3)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                forall x J:
                    x $in '[2, 3)
                    2 <= x
                    x < 3
                    1 < 2 <= x
                    1 <= x
                    x < 3 < 4
                    x < 4
                    x <= 4
                    x $in '[1, 4]
                J $subset '[1, 4]
        case J = {3}:
            by thm singleton_interval_is_bounded(3)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                forall x J:
                    x = 3
                    1 <= x
                    x <= 4
                    x $in '[1, 4]
                J $subset '[1, 4]
        case J = '(3, 4]:
            by thm non_degenerate_interval_forms_are_bounded_intervals(3, 4)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                forall x J:
                    x $in '(3, 4]
                    3 < x
                    x <= 4
                    1 < 3 < x
                    1 < x
                    1 <= x
                    x $in '[1, 4]
                J $subset '[1, 4]
        case J = {}:
            by thm empty_interval_is_bounded()
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                claim:
                    ? forall x J:
                        x $in '[1, 4]
                    by contra:
                        ? x $in '[1, 4]
                        x $in J
                        x $in {}
                        not $is_nonempty_set({})
                        witness $is_nonempty_set({}) from x
                        impossible $is_nonempty_set({})
                J $subset '[1, 4]

thm example_11_2_12_displayed_partition_unique_cover:
    ? forall x '[1, 4]:
        exist! J example_11_2_12_partition_set st {J $in power_set(R), x $in J}
    by cases:
        ? exist! J example_11_2_12_partition_set st {J $in power_set(R), x $in J}
        case x < 3:
            claim:
                ? '[1, 3) $in example_11_2_12_partition_set
                '[1, 3) $in {'[1, 3), {3}, '(3, 4]}
                example_11_2_12_partition_set = {'[1, 3), {3}, '(3, 4]}
                '[1, 3) $in example_11_2_12_partition_set
            witness exist! J example_11_2_12_partition_set st {J $in power_set(R), x $in J} from '[1, 3):
                '[1, 3) $in example_11_2_12_partition_set
                '[1, 3) $in power_set(R)
                x $in '[1, 3)
        case x = 3:
            claim:
                ? {3} $in example_11_2_12_partition_set
                {3} $in {'[1, 3), {3}, '(3, 4]}
                example_11_2_12_partition_set = {'[1, 3), {3}, '(3, 4]}
                {3} $in example_11_2_12_partition_set
            witness exist! J example_11_2_12_partition_set st {J $in power_set(R), x $in J} from {3}:
                {3} $in example_11_2_12_partition_set
                {3} $in power_set(R)
                x $in {3}
        case x > 3:
            claim:
                ? '(3, 4] $in example_11_2_12_partition_set
                '(3, 4] $in {'[1, 3), {3}, '(3, 4]}
                example_11_2_12_partition_set = {'[1, 3), {3}, '(3, 4]}
                '(3, 4] $in example_11_2_12_partition_set
            witness exist! J example_11_2_12_partition_set st {J $in power_set(R), x $in J} from '(3, 4]:
                '(3, 4] $in example_11_2_12_partition_set
                '(3, 4] $in power_set(R)
                x $in '(3, 4]

thm example_11_2_12_refined_partition_unique_cover:
    ? forall x '[1, 4]:
        exist! J example_11_2_12_refined_partition_set st {J $in power_set(R), x $in J}
    by cases:
        ? exist! J example_11_2_12_refined_partition_set st {J $in power_set(R), x $in J}
        case x < 2:
            claim:
                ? '[1, 2) $in example_11_2_12_refined_partition_set
                '[1, 2) $in {'[1, 2), '[2, 3), {3}, '(3, 4], {}}
                example_11_2_12_refined_partition_set = {'[1, 2), '[2, 3), {3}, '(3, 4], {}}
                '[1, 2) $in example_11_2_12_refined_partition_set
            witness exist! J example_11_2_12_refined_partition_set st {J $in power_set(R), x $in J} from '[1, 2):
                '[1, 2) $in example_11_2_12_refined_partition_set
                '[1, 2) $in power_set(R)
                x $in '[1, 2)
        case x >= 2:
            by cases:
                ? exist! J example_11_2_12_refined_partition_set st {J $in power_set(R), x $in J}
                case x < 3:
                    claim:
                        ? '[2, 3) $in example_11_2_12_refined_partition_set
                        '[2, 3) $in {'[1, 2), '[2, 3), {3}, '(3, 4], {}}
                        example_11_2_12_refined_partition_set = {'[1, 2), '[2, 3), {3}, '(3, 4], {}}
                        '[2, 3) $in example_11_2_12_refined_partition_set
                    witness exist! J example_11_2_12_refined_partition_set st {J $in power_set(R), x $in J} from '[2, 3):
                        '[2, 3) $in example_11_2_12_refined_partition_set
                        '[2, 3) $in power_set(R)
                        x $in '[2, 3)
                case x = 3:
                    claim:
                        ? {3} $in example_11_2_12_refined_partition_set
                        {3} $in {'[1, 2), '[2, 3), {3}, '(3, 4], {}}
                        example_11_2_12_refined_partition_set = {'[1, 2), '[2, 3), {3}, '(3, 4], {}}
                        {3} $in example_11_2_12_refined_partition_set
                    witness exist! J example_11_2_12_refined_partition_set st {J $in power_set(R), x $in J} from {3}:
                        {3} $in example_11_2_12_refined_partition_set
                        {3} $in power_set(R)
                        x $in {3}
                case x > 3:
                    claim:
                        ? '(3, 4] $in example_11_2_12_refined_partition_set
                        '(3, 4] $in {'[1, 2), '[2, 3), {3}, '(3, 4], {}}
                        example_11_2_12_refined_partition_set = {'[1, 2), '[2, 3), {3}, '(3, 4], {}}
                        '(3, 4] $in example_11_2_12_refined_partition_set
                    witness exist! J example_11_2_12_refined_partition_set st {J $in power_set(R), x $in J} from '(3, 4]:
                        '(3, 4] $in example_11_2_12_refined_partition_set
                        '(3, 4] $in power_set(R)
                        x $in '(3, 4]

thm example_11_2_12_displayed_partition_piecewise_constant:
    ? forall f fn(x '[1, 4]) R:
        $is_example_11_2_12_function(f)
        =>:
            $is_piecewise_constant_with_partition('[1, 4], example_11_2_12_partition_set, f)
    # Source handling: the displayed partition separates the three regions on
    # which `f` has the fixed values `2`, `4`, and `6`.
    claim:
        ? $is_partition_of_bounded_interval('[1, 4], example_11_2_12_partition_set)
        by thm non_degenerate_interval_forms_are_bounded_intervals(1, 4)
        claim:
            ? forall J example_11_2_12_partition_set:
                J $in power_set(R)
                $is_bounded_interval(J)
                J $subset '[1, 4]
            by thm example_11_2_12_displayed_partition_piece_clauses(J)
        claim:
            ? forall x '[1, 4]:
                exist! J example_11_2_12_partition_set st {J $in power_set(R), x $in J}
            by thm example_11_2_12_displayed_partition_unique_cover(x)
        $is_partition_of_bounded_interval('[1, 4], example_11_2_12_partition_set)
    claim:
        ? forall J example_11_2_12_partition_set:
            $is_constant_on_subset('[1, 4], J, f)
        # trust: enumerate the three members of the named partition set.
        trust J = '[1, 3) or J = {3} or J = '(3, 4]
        by cases:
            ? $is_constant_on_subset('[1, 4], J, f)
            case J = '[1, 3):
                by thm non_degenerate_interval_forms_are_bounded_intervals(1, 3)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 3)
                        1 <= x
                        x < 3
                        x < 3 < 4
                        x < 4
                        x <= 4
                        x $in '[1, 4]
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 2:
                    J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 4]
                        x $in '[1, 3)
                        x < 3
                        f(x) = 2
                    $has_constant_value_on_subset('[1, 4], J, f, 2)
            case J = {3}:
                by thm singleton_interval_is_bounded(3)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    forall x J:
                        x = 3
                        1 <= x
                        x <= 4
                        x $in '[1, 4]
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 4:
                    J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 4]
                        x = 3
                        f(x) = 4
                    $has_constant_value_on_subset('[1, 4], J, f, 4)
            case J = '(3, 4]:
                by thm non_degenerate_interval_forms_are_bounded_intervals(3, 4)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    forall x J:
                        x $in '(3, 4]
                        3 < x
                        x <= 4
                        1 < 3 < x
                        1 < x
                        1 <= x
                        x $in '[1, 4]
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 6:
                    J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 4]
                        x $in '(3, 4]
                        3 < x
                        x > 3
                        f(x) = 6
                    $has_constant_value_on_subset('[1, 4], J, f, 6)
    $is_piecewise_constant_with_partition('[1, 4], example_11_2_12_partition_set, f)

thm example_11_2_12_refined_partition_piecewise_constant:
    ? forall f fn(x '[1, 4]) R:
        $is_example_11_2_12_function(f)
        =>:
            $is_piecewise_constant_with_partition('[1, 4], example_11_2_12_refined_partition_set, f)
    # Source handling: the refined partition only splits the first constant
    # region and adds an empty piece, so it preserves the same piecewise
    # constant values.
    claim:
        ? $is_partition_of_bounded_interval('[1, 4], example_11_2_12_refined_partition_set)
        by thm non_degenerate_interval_forms_are_bounded_intervals(1, 4)
        claim:
            ? forall J example_11_2_12_refined_partition_set:
                J $in power_set(R)
                $is_bounded_interval(J)
                J $subset '[1, 4]
            by thm example_11_2_12_refined_partition_piece_clauses(J)
        claim:
            ? forall x '[1, 4]:
                exist! J example_11_2_12_refined_partition_set st {J $in power_set(R), x $in J}
            by thm example_11_2_12_refined_partition_unique_cover(x)
        $is_partition_of_bounded_interval('[1, 4], example_11_2_12_refined_partition_set)
    claim:
        ? forall J example_11_2_12_refined_partition_set:
            $is_constant_on_subset('[1, 4], J, f)
        # trust: enumerate the five members of the named refined
        # partition set before splitting into the displayed cases.
        trust J = '[1, 2) or J = '[2, 3) or J = {3} or J = '(3, 4] or J = {}
        by cases:
            ? $is_constant_on_subset('[1, 4], J, f)
            case J = '[1, 2):
                by thm non_degenerate_interval_forms_are_bounded_intervals(1, 2)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 2)
                        1 <= x
                        x < 2
                        x < 2 < 4
                        x < 4
                        x <= 4
                        x $in '[1, 4]
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 2:
                    J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 4]
                        x $in '[1, 2)
                        x < 2
                        x < 2 < 3
                        x < 3
                        f(x) = 2
                    $has_constant_value_on_subset('[1, 4], J, f, 2)
            case J = '[2, 3):
                by thm non_degenerate_interval_forms_are_bounded_intervals(2, 3)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    forall x J:
                        x $in '[2, 3)
                        2 <= x
                        x < 3
                        1 < 2 <= x
                        1 <= x
                        x < 3 < 4
                        x < 4
                        x <= 4
                        x $in '[1, 4]
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 2:
                    J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 4]
                        x $in '[2, 3)
                        x < 3
                        f(x) = 2
                    $has_constant_value_on_subset('[1, 4], J, f, 2)
            case J = {3}:
                by thm singleton_interval_is_bounded(3)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    forall x J:
                        x = 3
                        1 <= x
                        x <= 4
                        x $in '[1, 4]
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 4:
                    J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 4]
                        x = 3
                        f(x) = 4
                    $has_constant_value_on_subset('[1, 4], J, f, 4)
            case J = '(3, 4]:
                by thm non_degenerate_interval_forms_are_bounded_intervals(3, 4)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    forall x J:
                        x $in '(3, 4]
                        3 < x
                        x <= 4
                        1 < 3 < x
                        1 < x
                        1 <= x
                        x $in '[1, 4]
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 6:
                    J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 4]
                        x $in '(3, 4]
                        3 < x
                        x > 3
                        f(x) = 6
                    $has_constant_value_on_subset('[1, 4], J, f, 6)
            case J = {}:
                by thm empty_interval_is_bounded()
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    claim:
                        ? forall x J:
                            x $in '[1, 4]
                        by contra:
                            ? x $in '[1, 4]
                            x $in J
                            x $in {}
                            not $is_nonempty_set({})
                            witness $is_nonempty_set({}) from x
                            impossible $is_nonempty_set({})
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 0:
                    J $subset '[1, 4]
                    claim:
                        ? forall x J:
                            f(x) = 0
                        by contra:
                            ? f(x) = 0
                            x $in J
                            x $in {}
                            not $is_nonempty_set({})
                            witness $is_nonempty_set({}) from x
                            impossible $is_nonempty_set({})
                    $has_constant_value_on_subset('[1, 4], J, f, 0)
    $is_piecewise_constant_with_partition('[1, 4], example_11_2_12_refined_partition_set, f)

thm example_11_2_12_piece_contribution_has_values:
    ? forall f fn(x '[1, 4]) R:
        $is_example_11_2_12_function(f)
        =>:
            $has_piecewise_constant_integral_piece_contribution('[1, 4], '[1, 3), f, 4)
            $has_piecewise_constant_integral_piece_contribution('[1, 4], {3}, f, 0)
            $has_piecewise_constant_integral_piece_contribution('[1, 4], '(3, 4], f, 6)
            $has_piecewise_constant_integral_piece_contribution('[1, 4], '[1, 2), f, 2)
            $has_piecewise_constant_integral_piece_contribution('[1, 4], '[2, 3), f, 2)
            $has_piecewise_constant_integral_piece_contribution('[1, 4], {}, f, 0)
    # Source handling: this performs the rectangle-value calculation on each
    # concrete piece used in Example 11.2.12.
