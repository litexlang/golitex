# Chapter 9: Continuous functions on R.

# Sequence and compactness vocabulary from Chapter 6 is reused below.
# In particular, Chapter 6 supplies the canonical Cauchy, subsequence, and
# bounded-sequence predicates. Chapter 9 keeps only the set-relative
# predicates introduced for compactness arguments.

prop is_sequence_in_real_set(a seq(R), X power_set(R)):
    forall n N_pos:
        a(n) $in X

prop has_limit_in_set(a seq(R), X power_set(R)):
    exist L R st {L $in X, $chap6::has_limit(a, L)}

# 9.1 Subsets of the real line

"""
Definition 9.1.1 (Intervals). Closed, open, and half-open intervals are sets of
real points satisfying the corresponding endpoint inequalities.  Litex already
has the interval literals `'[a, b]`, `'(a, b)`, `'[a, b)`, `'(a, b]`,
`'(a,)`, `'[a,)`, `'(,a)`, and `'(,a]`.
"""

forall a, b R, x '[a, b]:
    x $in R
    a <= x
    x <= b

forall a, b R, x '(a, b):
    x $in R
    a < x
    x < b

forall a, b R, x '[a, b):
    x $in R
    a <= x
    x < b

forall a, b R, x '(a, b]:
    x $in R
    a < x
    x <= b

forall a R, x '(a,):
    x $in R
    a < x

forall a R, x '[a,):
    x $in R
    a <= x

forall a R, x '(,a):
    x $in R
    x < a

forall a R, x '(,a]:
    x $in R
    x <= a

# Litex already provides the builtin closed-interval object `'[l, r]`, which
# is the canonical notation used throughout this chapter.  Users can also
# define the same mathematical concept directly with a set-builder function;
# this local function makes Tao's source convention explicit for the
# reversed-endpoint example below.

have fn closed_interval(l, r R) power_set(R) = {x R: l <= x <= r}

"""
Remark 9.1.2. In Tao's source notation, parentheses are used both for ordered
pairs and for open intervals.  Litex makes this distinction syntactic: a
leading apostrophe marks an interval, as in `'(a, b)`, while ordinary
parentheses retain their tuple and expression meaning.
"""

forall a, b R:
    '(a, b) $subset R
    '(a, b) $in power_set(R)
    (a, b) $in cart(R, R)

"""
Examples 9.1.3. Ordinary finite intervals are subsets of R.  The positive,
non-negative, negative, and non-positive axes are the four one-sided interval
objects.
"""

forall a, b R:
    '[a, b] $subset R
    '[a, b] $in power_set(R)
    '(a, b) $subset R
    '(a, b) $in power_set(R)
    '[a, b) $subset R
    '[a, b) $in power_set(R)
    '(a, b] $subset R
    '(a, b] $in power_set(R)

forall a R:
    '(a,) $subset R
    '(a,) $in power_set(R)
    '[a,) $subset R
    '[a,) $in power_set(R)
    '(,a) $subset R
    '(,a) $in power_set(R)
    '(,a] $subset R
    '(,a] $in power_set(R)

N $in power_set(R)
N_pos $in power_set(R)
Z $in power_set(R)
Q $in power_set(R)
R $in power_set(R)
{} $in power_set(R)

forall x '(0,):
    x > 0

forall x '[0,):
    x >= 0

forall x '(,0):
    x < 0

forall x '(,0]:
    x <= 0

"""
Example 9.1.4. Degenerate intervals can be empty or singletons depending on the
endpoint inequalities.  In Tao's book-style set-builder convention, `[a, b]`
means `{x R: a <= x <= b}` even when `a > b`; then any alleged point gives
incompatible endpoint inequalities.  Litex's builtin two-sided interval literals
are the concise objects used later, while `closed_interval` exposes the
set-builder proof of the reversed-endpoint closed interval directly.
"""

forall a R:
    a $in closed_interval(a, a)
    a $in '[a, a]

thm closed_singleton_intervals_nonempty:
    ? forall a R:
        $is_nonempty_set(closed_interval(a, a))
        $is_nonempty_set('[a, a])
    have A set = closed_interval(a, a)
    a $in closed_interval(a, a)
    a $in A
    witness $is_nonempty_set(A) from a:
        a $in A
    $is_nonempty_set(closed_interval(a, a))
    have B set = '[a, a]
    a $in '[a, a]
    a $in B
    witness $is_nonempty_set(B) from a:
        a $in B
    $is_nonempty_set('[a, a])

thm self_closed_interval_empty_when_endpoints_reversed:
    ? forall a, b R:
        a > b
        =>:
            closed_interval(a, b) = {}
    by extension closed_interval(a, b) = {}:
        claim:
            ? forall x closed_interval(a, b):
                x $in {}
            a <= x
            x <= b
            a <= b
            by contra:
                ? x $in {}
                not x $in {}
                impossible a > b
        claim:
            ? forall x {}:
                x $in closed_interval(a, b)
            by contra:
                ? x $in closed_interval(a, b)
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from x
                impossible $is_nonempty_set({})

thm open_degenerate_interval_empty:
    ? forall a R:
        '(a, a) = {}
    by extension '(a, a) = {}:
        claim:
            ? forall x '(a, a):
                x $in {}
            a < x
            x < a
            x <= a
            by contra:
                ? x $in {}
                not x $in {}
                impossible x <= a
        claim:
            ? forall x {}:
                x $in '(a, a)
            by contra:
                ? x $in '(a, a)
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from x
                impossible $is_nonempty_set({})

"""
Definition 9.1.5 (epsilon-adherent points). A real point x is epsilon-adherent
to X when some point of X lies within epsilon of x.
"""

prop is_epsilon_adherent_to_set(X power_set(R), x R, epsilon R_pos):
    exist y R st {y $in X, abs(x - y) <= epsilon}

"""
Remark 9.1.6. Epsilon-adherence is a temporary finite-radius notion used to
define ordinary adherent points.
"""

"""
Example 9.1.7. Points just outside an interval can be adherent for a large
radius and not adherent for a smaller radius; points of a finite real set are
automatically epsilon-adherent to that finite set for every positive epsilon.
"""

claim:
    ? forall epsilon R_pos:
        $is_epsilon_adherent_to_set('[1, 1], 1, epsilon)
    witness exist y R st {y $in '[1, 1], abs(1 - y) <= epsilon} from 1:
        1 $in '[1, 1]
        abs(1 - 1) = 0
        0 <= epsilon
        abs(1 - 1) <= epsilon
    $is_epsilon_adherent_to_set('[1, 1], 1, epsilon)

"""
Definition 9.1.8 (Adherent points). A point is adherent to X when it is
epsilon-adherent to X for every positive epsilon.
"""

prop is_adherent_point(X power_set(R), x R):
    forall epsilon R_pos:
        $is_epsilon_adherent_to_set(X, x, epsilon)

"""
Example 9.1.9. Interior points of an interval are adherent.  Endpoints of an
open interval are also adherent because points of the interval approach them
arbitrarily closely.
"""

thm interval_member_is_adherent:
    ? forall X power_set(R), x R:
        x $in X
        =>:
            $is_adherent_point(X, x)
    claim:
        ? forall epsilon R_pos:
            $is_epsilon_adherent_to_set(X, x, epsilon)
        witness exist y R st {y $in X, abs(x - y) <= epsilon} from x:
            x $in X
            abs(x - x) = 0
            0 <= epsilon
            abs(x - x) <= epsilon
        $is_epsilon_adherent_to_set(X, x, epsilon)
    $is_adherent_point(X, x)

"""
Definition 9.1.10 (Closure). The closure of X is the set of all real adherent
points of X.
"""

have fn closure_of_real_set(X power_set(R)) power_set(R) = {x R: $is_adherent_point(X, x)}

prop is_closure_of(C, X power_set(R)):
    C = closure_of_real_set(X)

thm closure_member_is_adherent:
    ? forall X power_set(R), x closure_of_real_set(X):
        $is_adherent_point(X, x)
    x $in closure_of_real_set(X)
    $is_adherent_point(X, x)

"""
Lemma 9.1.11 (Elementary properties of closures). Closure contains the
original set, is monotone under subset inclusion, distributes over binary
unions, and has one-sided compatibility with intersections.
"""

# The closure laws say adherent points behave well under the elementary set
# operations: membership gives adherence, union witnesses can be kept on one
# side, intersections give one-sided containment, and subset inclusion transfers
# adherent witnesses.
# Tao leaves this proof to Exercise 9.1.2.  The direct proofs below check
# containment, monotonicity, and intersection containment; the finite-union
# equality still records its unexpanded exercise step.

thm closure_contains_set:
    ? forall X power_set(R):
        X $subset closure_of_real_set(X)
    claim:
        ? forall x X:
            x $in closure_of_real_set(X)
        by thm interval_member_is_adherent(X, x)
        x $in closure_of_real_set(X)
    X $subset closure_of_real_set(X)

# Closure statements use unions, intersections, and set differences of real
# subsets.  The proof is ordinary subset checking: a member of one of these
# operations is still a real number.
thm real_set_operations_stay_in_power_set:
    ? forall X, Y power_set(R):
        union(X, Y) $in power_set(R)
        intersect(X, Y) $in power_set(R)
        set_minus(X, Y) $in power_set(R)
    claim:
        ? union(X, Y) $subset R
        claim:
            ? forall z union(X, Y):
                z $in R
            z $in X or z $in Y
            by cases:
                ? z $in R
                case z $in X:
                    z $in R
                case z $in Y:
                    z $in R
            z $in R
        union(X, Y) $subset R
    union(X, Y) $in power_set(R)
    claim:
        ? intersect(X, Y) $subset R
        claim:
            ? forall z intersect(X, Y):
                z $in R
            z $in X
            z $in R
        intersect(X, Y) $subset R
    intersect(X, Y) $in power_set(R)
    claim:
        ? set_minus(X, Y) $subset R
        claim:
            ? forall z set_minus(X, Y):
                z $in R
            z $in X
            z $in R
        set_minus(X, Y) $subset R
    set_minus(X, Y) $in power_set(R)

# Punctured-set definitions use singleton subsets of `R`.  A member of `{x}` is
# equal to the real point `x`, hence the singleton is a subset of `R`.
thm real_singleton_in_power_set:
    ? forall x R:
        {x} $in power_set(R)
    claim:
        ? {x} $subset R
        claim:
            ? forall z {x}:
                z $in R
            z = x
            z $in R
        {x} $subset R
    {x} $in power_set(R)

thm closure_monotone:
    ? forall X, Y power_set(R):
        X $subset Y
        =>:
            closure_of_real_set(X) $subset closure_of_real_set(Y)
    claim:
        ? forall x closure_of_real_set(X):
            x $in closure_of_real_set(Y)
        $is_adherent_point(X, x)
        claim:
            ? forall epsilon R_pos:
                $is_epsilon_adherent_to_set(Y, x, epsilon)
            $is_epsilon_adherent_to_set(X, x, epsilon)
            obtain y from exist y R st {y $in X, abs(x - y) <= epsilon}
            y $in Y
            witness exist z R st {z $in Y, abs(x - z) <= epsilon} from y:
                y $in Y
                abs(x - y) <= epsilon
            $is_epsilon_adherent_to_set(Y, x, epsilon)
        $is_adherent_point(Y, x)
        x $in closure_of_real_set(Y)
    closure_of_real_set(X) $subset closure_of_real_set(Y)

thm closure_of_intersection_subset:
    ? forall X, Y power_set(R):
        closure_of_real_set(intersect(X, Y)) $subset intersect(closure_of_real_set(X), closure_of_real_set(Y))
    by thm real_set_operations_stay_in_power_set(X, Y)
    claim:
        ? forall x closure_of_real_set(intersect(X, Y)):
            x $in intersect(closure_of_real_set(X), closure_of_real_set(Y))
        $is_adherent_point(intersect(X, Y), x)
        claim:
            ? forall epsilon R_pos:
                $is_epsilon_adherent_to_set(X, x, epsilon)
            $is_epsilon_adherent_to_set(intersect(X, Y), x, epsilon)
            obtain y from exist y R st {y $in intersect(X, Y), abs(x - y) <= epsilon}
            y $in X
            witness exist z R st {z $in X, abs(x - z) <= epsilon} from y:
                y $in X
                abs(x - y) <= epsilon
            $is_epsilon_adherent_to_set(X, x, epsilon)
        $is_adherent_point(X, x)
        x $in closure_of_real_set(X)
        claim:
            ? forall epsilon R_pos:
                $is_epsilon_adherent_to_set(Y, x, epsilon)
            $is_epsilon_adherent_to_set(intersect(X, Y), x, epsilon)
            obtain y from exist y R st {y $in intersect(X, Y), abs(x - y) <= epsilon}
            y $in Y
            witness exist z R st {z $in Y, abs(x - z) <= epsilon} from y:
                y $in Y
                abs(x - y) <= epsilon
            $is_epsilon_adherent_to_set(Y, x, epsilon)
        $is_adherent_point(Y, x)
        x $in closure_of_real_set(Y)
        x $in intersect(closure_of_real_set(X), closure_of_real_set(Y))
    closure_of_real_set(intersect(X, Y)) $subset intersect(closure_of_real_set(X), closure_of_real_set(Y))

thm non_closure_gives_failed_radius:
    ? forall X power_set(R), z R:
        not z $in closure_of_real_set(X)
        =>:
            exist epsilon R_pos st {not $is_epsilon_adherent_to_set(X, z, epsilon)}
    by contra:
        ? exist epsilon R_pos st {not $is_epsilon_adherent_to_set(X, z, epsilon)}
        not exist epsilon R_pos st {not $is_epsilon_adherent_to_set(X, z, epsilon)}
        forall epsilon R_pos:
            $is_epsilon_adherent_to_set(X, z, epsilon)
        $is_adherent_point(X, z)
        z $in closure_of_real_set(X)
        impossible not z $in closure_of_real_set(X)

thm closure_union_subset_forward:
    ? forall X, Y power_set(R):
        closure_of_real_set(union(X, Y)) $subset union(closure_of_real_set(X), closure_of_real_set(Y))
    by thm real_set_operations_stay_in_power_set(X, Y)
    claim:
        ? forall z closure_of_real_set(union(X, Y)):
            z $in union(closure_of_real_set(X), closure_of_real_set(Y))
        z $in closure_of_real_set(X) or not z $in closure_of_real_set(X)
        by cases:
            ? z $in union(closure_of_real_set(X), closure_of_real_set(Y))
            case z $in closure_of_real_set(X):
                z $in union(closure_of_real_set(X), closure_of_real_set(Y))
            case not z $in closure_of_real_set(X):
                z $in closure_of_real_set(Y) or not z $in closure_of_real_set(Y)
                by cases:
                    ? z $in union(closure_of_real_set(X), closure_of_real_set(Y))
                    case z $in closure_of_real_set(Y):
                        z $in union(closure_of_real_set(X), closure_of_real_set(Y))
                    case not z $in closure_of_real_set(Y):
                        by thm non_closure_gives_failed_radius(X, z)
                        obtain epsilon_x from exist epsilon_x R_pos st {not $is_epsilon_adherent_to_set(X, z, epsilon_x)}
                        by thm non_closure_gives_failed_radius(Y, z)
                        obtain epsilon_y from exist epsilon_y R_pos st {not $is_epsilon_adherent_to_set(Y, z, epsilon_y)}
                        finite_set_min(union({epsilon_x}, { epsilon_y})) $in R_pos
                        $is_adherent_point(union(X, Y), z)
                        $is_epsilon_adherent_to_set(union(X, Y), z, finite_set_min(union({epsilon_x}, { epsilon_y})))
                        obtain w from exist w R st {w $in union(X, Y), abs(z - w) <= finite_set_min(union({epsilon_x}, { epsilon_y}))}
                        finite_set_min(union({epsilon_x}, { epsilon_y})) <= epsilon_x
                        finite_set_min(union({epsilon_x}, { epsilon_y})) <= epsilon_y
                        w $in X or w $in Y
                        by cases:
                            ? z $in union(closure_of_real_set(X), closure_of_real_set(Y))
                            case w $in X:
                                witness exist u R st {u $in X, abs(z - u) <= epsilon_x} from w:
                                    w $in X
                                    abs(z - w) <= finite_set_min(union({epsilon_x}, { epsilon_y})) <= epsilon_x
                                    abs(z - w) <= epsilon_x
                                $is_epsilon_adherent_to_set(X, z, epsilon_x)
                                impossible not $is_epsilon_adherent_to_set(X, z, epsilon_x)
                            case w $in Y:
                                witness exist u R st {u $in Y, abs(z - u) <= epsilon_y} from w:
                                    w $in Y
                                    abs(z - w) <= finite_set_min(union({epsilon_x}, { epsilon_y})) <= epsilon_y
                                    abs(z - w) <= epsilon_y
                                $is_epsilon_adherent_to_set(Y, z, epsilon_y)
                                impossible not $is_epsilon_adherent_to_set(Y, z, epsilon_y)
    closure_of_real_set(union(X, Y)) $subset union(closure_of_real_set(X), closure_of_real_set(Y))

thm closure_union_subset_reverse:
    ? forall X, Y power_set(R):
        union(closure_of_real_set(X), closure_of_real_set(Y)) $subset closure_of_real_set(union(X, Y))
    by thm real_set_operations_stay_in_power_set(X, Y)
    claim:
        ? forall z union(closure_of_real_set(X), closure_of_real_set(Y)):
            z $in closure_of_real_set(union(X, Y))
        z $in closure_of_real_set(X) or z $in closure_of_real_set(Y)
        by cases:
            ? z $in closure_of_real_set(union(X, Y))
            case z $in closure_of_real_set(X):
                $is_adherent_point(X, z)
                claim:
                    ? forall epsilon R_pos:
                        $is_epsilon_adherent_to_set(union(X, Y), z, epsilon)
                    $is_epsilon_adherent_to_set(X, z, epsilon)
                    obtain w from exist w R st {w $in X, abs(z - w) <= epsilon}
                    w $in union(X, Y)
                    witness exist u R st {u $in union(X, Y), abs(z - u) <= epsilon} from w:
                        w $in union(X, Y)
                        abs(z - w) <= epsilon
                $is_adherent_point(union(X, Y), z)
                z $in closure_of_real_set(union(X, Y))
            case z $in closure_of_real_set(Y):
                $is_adherent_point(Y, z)
                claim:
                    ? forall epsilon R_pos:
                        $is_epsilon_adherent_to_set(union(X, Y), z, epsilon)
                    $is_epsilon_adherent_to_set(Y, z, epsilon)
                    obtain w from exist w R st {w $in Y, abs(z - w) <= epsilon}
                    w $in union(X, Y)
                    witness exist u R st {u $in union(X, Y), abs(z - u) <= epsilon} from w:
                        w $in union(X, Y)
                        abs(z - w) <= epsilon
                $is_adherent_point(union(X, Y), z)
                z $in closure_of_real_set(union(X, Y))
    union(closure_of_real_set(X), closure_of_real_set(Y)) $subset closure_of_real_set(union(X, Y))

thm closure_union_identity:
    ? forall X, Y power_set(R):
        closure_of_real_set(union(X, Y)) = union(closure_of_real_set(X), closure_of_real_set(Y))
    by thm closure_union_subset_forward(X, Y)
    by thm closure_union_subset_reverse(X, Y)
    by extension closure_of_real_set(union(X, Y)) = union(closure_of_real_set(X), closure_of_real_set(Y))
    closure_of_real_set(union(X, Y)) = union(closure_of_real_set(X), closure_of_real_set(Y))

thm closure_elementary_properties:
    ? forall X, Y power_set(R):
        closure_of_real_set(union(X, Y)) = union(closure_of_real_set(X), closure_of_real_set(Y))
        closure_of_real_set(intersect(X, Y)) $subset intersect(closure_of_real_set(X), closure_of_real_set(Y))
        X $subset Y
        =>:
            closure_of_real_set(X) $subset closure_of_real_set(Y)
    by thm closure_union_identity(X, Y)
    by thm closure_of_intersection_subset(X, Y)
    by thm closure_monotone(X, Y)

"""
Lemma 9.1.12 (Closures of intervals). Non-degenerate finite intervals have
closed interval closure, and one-sided intervals close by including the finite
endpoint.
"""

# The source proves the representative case `closure((a,b)) = [a,b]` in two
# inclusions: endpoints are adherent because points from inside `(a,b)` approach
# them, interior points are adherent because they already belong to `(a,b)`,
# and points outside `[a,b]` fail epsilon-adherence.  The formal proof below
# follows that argument for `(a,b)` and repeats the same endpoint/exterior-point
# argument for closed intervals and rays.  The half-open interval cases are
# obtained by sandwiching them between `(a,b)` and `[a,b]`, matching the
# source's "similarly" argument.

thm left_endpoint_adherent_to_open_interval:
    ? forall a, b R:
        a < b
        =>:
            $is_adherent_point('(a, b), a)
    claim:
        ? forall epsilon R_pos:
            $is_epsilon_adherent_to_set('(a, b), a, epsilon)
        epsilon <= b - a or epsilon > b - a
        by cases:
            ? $is_epsilon_adherent_to_set('(a, b), a, epsilon)
            case epsilon <= b - a:
                witness exist y R st {y $in '(a, b), abs(a - y) <= epsilon} from a + epsilon / 2:
                    epsilon / 2 > 0
                    a < a + epsilon / 2
                    b - a > 0
                    epsilon / 2 <= (b - a) / 2
                    (b - a) / 2 < b - a
                    epsilon / 2 <= (b - a) / 2 < b - a
                    epsilon / 2 < b - a
                    a + epsilon / 2 < a + (b - a)
                    a + (b - a) = b
                    a + epsilon / 2 < a + (b - a) = b
                    a + epsilon / 2 < b
                    a + epsilon / 2 $in '(a, b)
                    a - (a + epsilon / 2) = -epsilon / 2
                    -epsilon / 2 < 0
                    abs(-epsilon / 2) = epsilon / 2
                    abs(a - (a + epsilon / 2)) = abs(-epsilon / 2)
                    abs(a - (a + epsilon / 2)) = abs(-epsilon / 2) = epsilon / 2
                    abs(a - (a + epsilon / 2)) = epsilon / 2
                    epsilon / 2 < epsilon
                    epsilon / 2 <= epsilon
                    abs(a - (a + epsilon / 2)) <= epsilon
            case epsilon > b - a:
                witness exist y R st {y $in '(a, b), abs(a - y) <= epsilon} from (a + b) / 2:
                    b - a > 0
                    (b - a) / 2 > 0
                    (a + b) / 2 - a = (b - a) / 2
                    (a + b) / 2 - a > 0
                    a < (a + b) / 2
                    b - (a + b) / 2 = (b - a) / 2
                    b - (a + b) / 2 > 0
                    (a + b) / 2 < b
                    (a + b) / 2 $in '(a, b)
                    a - (a + b) / 2 = -(b - a) / 2
                    -(b - a) / 2 < 0
                    abs(-(b - a) / 2) = (b - a) / 2
                    abs(a - (a + b) / 2) = abs(-(b - a) / 2)
                    abs(a - (a + b) / 2) = abs(-(b - a) / 2) = (b - a) / 2
                    abs(a - (a + b) / 2) = (b - a) / 2
                    (b - a) / 2 < b - a
                    b - a < epsilon
                    (b - a) / 2 < b - a < epsilon
                    (b - a) / 2 < epsilon
                    abs(a - (a + b) / 2) <= epsilon
        $is_epsilon_adherent_to_set('(a, b), a, epsilon)
    $is_adherent_point('(a, b), a)

thm right_endpoint_adherent_to_open_interval:
    ? forall a, b R:
        a < b
        =>:
            $is_adherent_point('(a, b), b)
    claim:
        ? forall epsilon R_pos:
            $is_epsilon_adherent_to_set('(a, b), b, epsilon)
        epsilon <= b - a or epsilon > b - a
        by cases:
            ? $is_epsilon_adherent_to_set('(a, b), b, epsilon)
            case epsilon <= b - a:
                witness exist y R st {y $in '(a, b), abs(b - y) <= epsilon} from b - epsilon / 2:
                    epsilon / 2 > 0
                    b - epsilon / 2 < b
                    b - a > 0
                    epsilon / 2 <= (b - a) / 2
                    (b - a) / 2 < b - a
                    epsilon / 2 <= (b - a) / 2 < b - a
                    epsilon / 2 < b - a
                    b - epsilon / 2 > b - (b - a)
                    b - (b - a) = a
                    b - epsilon / 2 > b - (b - a) = a
                    a < b - epsilon / 2
                    b - epsilon / 2 $in '(a, b)
                    b - (b - epsilon / 2) = epsilon / 2
                    abs(epsilon / 2) = epsilon / 2
                    abs(b - (b - epsilon / 2)) = abs(epsilon / 2)
                    abs(b - (b - epsilon / 2)) = abs(epsilon / 2) = epsilon / 2
                    abs(b - (b - epsilon / 2)) = epsilon / 2
                    epsilon / 2 < epsilon
                    epsilon / 2 <= epsilon
                    abs(b - (b - epsilon / 2)) <= epsilon
            case epsilon > b - a:
                witness exist y R st {y $in '(a, b), abs(b - y) <= epsilon} from (a + b) / 2:
                    b - a > 0
                    (b - a) / 2 > 0
                    (a + b) / 2 - a = (b - a) / 2
                    (a + b) / 2 - a > 0
                    a < (a + b) / 2
                    b - (a + b) / 2 = (b - a) / 2
                    b - (a + b) / 2 > 0
                    (a + b) / 2 < b
                    (a + b) / 2 $in '(a, b)
                    b - (a + b) / 2 = (b - a) / 2
                    abs((b - a) / 2) = (b - a) / 2
                    abs(b - (a + b) / 2) = abs((b - a) / 2)
                    abs(b - (a + b) / 2) = abs((b - a) / 2) = (b - a) / 2
                    abs(b - (a + b) / 2) = (b - a) / 2
                    (b - a) / 2 < b - a
                    b - a < epsilon
                    (b - a) / 2 < b - a < epsilon
                    (b - a) / 2 < epsilon
                    abs(b - (a + b) / 2) <= epsilon
        $is_epsilon_adherent_to_set('(a, b), b, epsilon)
    $is_adherent_point('(a, b), b)

thm closed_interval_subset_open_interval_closure:
    ? forall a, b R:
        a < b
        =>:
            '[a, b] $subset closure_of_real_set('(a, b))
    claim:
        ? forall x '[a, b]:
            x $in closure_of_real_set('(a, b))
        x = a or x > a
        by cases:
            ? $is_adherent_point('(a, b), x)
            case x = a:
                by thm left_endpoint_adherent_to_open_interval(a, b)
                $is_adherent_point('(a, b), x)
            case x > a:
                x = b or x < b
                by cases:
                    ? $is_adherent_point('(a, b), x)
                    case x = b:
                        by thm right_endpoint_adherent_to_open_interval(a, b)
                        $is_adherent_point('(a, b), x)
                    case x < b:
                        a < x
                        x < b
                        x $in '(a, b)
                        by thm interval_member_is_adherent('(a, b), x)
        $is_adherent_point('(a, b), x)
        x $in closure_of_real_set('(a, b))
    '[a, b] $subset closure_of_real_set('(a, b))

thm open_interval_closure_subset_closed_interval:
    ? forall a, b R:
        a < b
        =>:
            closure_of_real_set('(a, b)) $subset '[a, b]
    claim:
        ? forall x closure_of_real_set('(a, b)):
            x $in '[a, b]
        by thm closure_member_is_adherent('(a, b), x)
        x < a or x >= a
        by cases:
            ? x $in '[a, b]
            case x < a:
                a - x $in R_pos
                $is_epsilon_adherent_to_set('(a, b), x, a - x)
                obtain y from exist y R st {y $in '(a, b), abs(x - y) <= a - x}
                y $in '(a, b)
                abs(x - y) <= a - x
                a < y
                x < a < y
                x < y
                a - x < y - x
                y - x > 0
                x - y < 0
                x - y = -(y - x)
                abs(-(y - x)) = y - x
                abs(x - y) = abs(-(y - x))
                abs(x - y) = abs(-(y - x)) = y - x
                abs(x - y) = y - x
                a - x < abs(x - y)
                a - x < abs(x - y) <= a - x
                impossible a - x < a - x
            case x >= a:
                x <= b or x > b
                by cases:
                    ? x $in '[a, b]
                    case x <= b:
                        a <= x
                        x <= b
                        x $in '[a, b]
                    case x > b:
                        x - b $in R_pos
                        $is_epsilon_adherent_to_set('(a, b), x, x - b)
                        obtain y from exist y R st {y $in '(a, b), abs(x - y) <= x - b}
                        y $in '(a, b)
                        abs(x - y) <= x - b
                        y < b
                        y < b < x
                        y < x
                        x - b < x - y
                        x - y > 0
                        abs(x - y) = x - y
                        x - b < abs(x - y)
                        x - b < abs(x - y) <= x - b
                        impossible x - b < x - b
    closure_of_real_set('(a, b)) $subset '[a, b]

thm closure_of_open_interval:
    ? forall a, b R:
        a < b
        =>:
            closure_of_real_set('(a, b)) = '[a, b]
    by thm closed_interval_subset_open_interval_closure(a, b)
    by thm open_interval_closure_subset_closed_interval(a, b)
    by extension closure_of_real_set('(a, b)) = '[a, b]
    closure_of_real_set('(a, b)) = '[a, b]

thm closed_interval_closure_subset_closed_interval:
    ? forall a, b R:
        a < b
        =>:
            closure_of_real_set('[a, b]) $subset '[a, b]
    claim:
        ? forall x closure_of_real_set('[a, b]):
            x $in '[a, b]
        by thm closure_member_is_adherent('[a, b], x)
        x < a or x >= a
        by cases:
            ? x $in '[a, b]
            case x < a:
                (a - x) / 2 $in R_pos
                $is_epsilon_adherent_to_set('[a, b], x, (a - x) / 2)
                obtain y from exist y R st {y $in '[a, b], abs(x - y) <= (a - x) / 2}
                y $in '[a, b]
                abs(x - y) <= (a - x) / 2
                a <= y
                x < a <= y
                x < y
                a - x <= y - x
                (a - x) / 2 < a - x
                (a - x) / 2 < a - x <= y - x
                (a - x) / 2 < y - x
                y - x > 0
                x - y < 0
                x - y = -(y - x)
                abs(-(y - x)) = y - x
                abs(x - y) = abs(-(y - x))
                abs(x - y) = abs(-(y - x)) = y - x
                abs(x - y) = y - x
                (a - x) / 2 < abs(x - y)
                (a - x) / 2 < abs(x - y) <= (a - x) / 2
                impossible (a - x) / 2 < (a - x) / 2
            case x >= a:
                x <= b or x > b
                by cases:
                    ? x $in '[a, b]
                    case x <= b:
                        a <= x
                        x <= b
                        x $in '[a, b]
                    case x > b:
                        (x - b) / 2 $in R_pos
                        $is_epsilon_adherent_to_set('[a, b], x, (x - b) / 2)
                        obtain y from exist y R st {y $in '[a, b], abs(x - y) <= (x - b) / 2}
                        y $in '[a, b]
                        abs(x - y) <= (x - b) / 2
                        y <= b
                        y <= b < x
                        y < x
                        x - b <= x - y
                        (x - b) / 2 < x - b
                        (x - b) / 2 < x - b <= x - y
                        (x - b) / 2 < x - y
                        x - y > 0
                        abs(x - y) = x - y
                        (x - b) / 2 < abs(x - y)
                        (x - b) / 2 < abs(x - y) <= (x - b) / 2
                        impossible (x - b) / 2 < (x - b) / 2
    closure_of_real_set('[a, b]) $subset '[a, b]

thm closure_of_closed_interval:
    ? forall a, b R:
        a < b
        =>:
            closure_of_real_set('[a, b]) = '[a, b]
    by thm closure_contains_set('[a, b])
    by thm closed_interval_closure_subset_closed_interval(a, b)
    by extension closure_of_real_set('[a, b]) = '[a, b]
    closure_of_real_set('[a, b]) = '[a, b]

thm finite_interval_containment_relations:
    ? forall a, b R:
        a < b
        =>:
            '(a, b) $subset '(a, b]
            '(a, b) $subset '[a, b)
            '(a, b] $subset '[a, b]
            '[a, b) $subset '[a, b]
    claim:
        ? forall x '(a, b):
            x $in '(a, b]
        a < x
        x < b
        x <= b
        x $in '(a, b]
    '(a, b) $subset '(a, b]
    claim:
        ? forall x '(a, b):
            x $in '[a, b)
        a < x
        a <= x
        x < b
        x $in '[a, b)
    '(a, b) $subset '[a, b)
    claim:
        ? forall x '(a, b]:
            x $in '[a, b]
        a < x
        a <= x
        x <= b
        x $in '[a, b]
    '(a, b] $subset '[a, b]
    claim:
        ? forall x '[a, b):
            x $in '[a, b]
        a <= x
        x < b
        x <= b
        x $in '[a, b]
    '[a, b) $subset '[a, b]

thm closure_of_open_closed_interval:
    ? forall a, b R:
        a < b
        =>:
            closure_of_real_set('(a, b]) = '[a, b]
    by thm finite_interval_containment_relations(a, b)
    '(a, b] $subset '[a, b]
    by thm closure_monotone('(a, b), '(a, b])
    by thm closure_of_open_interval(a, b)
    '[a, b] $subset closure_of_real_set('(a, b])
    by thm closure_monotone('(a, b], '[a, b])
    by thm closure_of_closed_interval(a, b)
    closure_of_real_set('(a, b]) $subset '[a, b]
    by extension closure_of_real_set('(a, b]) = '[a, b]
    closure_of_real_set('(a, b]) = '[a, b]

thm closure_of_closed_open_interval:
    ? forall a, b R:
        a < b
        =>:
            closure_of_real_set('[a, b)) = '[a, b]
    by thm finite_interval_containment_relations(a, b)
    '[a, b) $subset '[a, b]
    by thm closure_monotone('(a, b), '[a, b))
    by thm closure_of_open_interval(a, b)
    '[a, b] $subset closure_of_real_set('[a, b))
    by thm closure_monotone('[a, b), '[a, b])
    by thm closure_of_closed_interval(a, b)
    closure_of_real_set('[a, b)) $subset '[a, b]
    by extension closure_of_real_set('[a, b)) = '[a, b]
    closure_of_real_set('[a, b)) = '[a, b]

thm closure_of_bounded_intervals:
    ? forall a, b R:
        a < b
        =>:
            closure_of_real_set('(a, b)) = '[a, b]
            closure_of_real_set('(a, b]) = '[a, b]
            closure_of_real_set('[a, b)) = '[a, b]
            closure_of_real_set('[a, b]) = '[a, b]
    by thm closure_of_open_interval(a, b)
    by thm closure_of_open_closed_interval(a, b)
    by thm closure_of_closed_open_interval(a, b)
    by thm closure_of_closed_interval(a, b)

thm endpoint_adherent_to_open_right_ray:
    ? forall a R:
        $is_adherent_point('(a,), a)
    claim:
        ? forall epsilon R_pos:
            $is_epsilon_adherent_to_set('(a,), a, epsilon)
        witness exist y R st {y $in '(a,), abs(a - y) <= epsilon} from a + epsilon / 2:
            epsilon / 2 > 0
            a < a + epsilon / 2
            a + epsilon / 2 $in '(a,)
            a - (a + epsilon / 2) = -epsilon / 2
            -epsilon / 2 < 0
            abs(-epsilon / 2) = epsilon / 2
            abs(a - (a + epsilon / 2)) = abs(-epsilon / 2)
            abs(a - (a + epsilon / 2)) = epsilon / 2
            epsilon / 2 < epsilon
            epsilon / 2 <= epsilon
            abs(a - (a + epsilon / 2)) <= epsilon
    $is_adherent_point('(a,), a)

thm closed_right_ray_subset_open_right_ray_closure:
    ? forall a R:
        '[a,) $subset closure_of_real_set('(a,))
    claim:
        ? forall x '[a,):
            x $in closure_of_real_set('(a,))
        x = a or x > a
        by cases:
            ? $is_adherent_point('(a,), x)
            case x = a:
                by thm endpoint_adherent_to_open_right_ray(a)
                $is_adherent_point('(a,), x)
            case x > a:
                a < x
                x $in '(a,)
                by thm interval_member_is_adherent('(a,), x)
        x $in closure_of_real_set('(a,))
    '[a,) $subset closure_of_real_set('(a,))

thm open_right_ray_closure_subset_closed_right_ray:
    ? forall a R:
        closure_of_real_set('(a,)) $subset '[a,)
    claim:
        ? forall x closure_of_real_set('(a,)):
            x $in '[a,)
        by thm closure_member_is_adherent('(a,), x)
        x < a or x >= a
        by cases:
            ? x $in '[a,)
            case x < a:
                a - x $in R_pos
                $is_epsilon_adherent_to_set('(a,), x, a - x)
                obtain y from exist y R st {y $in '(a,), abs(x - y) <= a - x}
                y $in '(a,)
                a < y
                x < a < y
                x < y
                a - x < y - x
                y - x > 0
                x - y < 0
                x - y = -(y - x)
                abs(-(y - x)) = y - x
                abs(x - y) = abs(-(y - x))
                abs(x - y) = y - x
                a - x < abs(x - y)
                abs(x - y) <= a - x
                a - x < abs(x - y) <= a - x
                impossible a - x < a - x
            case x >= a:
                x $in '[a,)
    closure_of_real_set('(a,)) $subset '[a,)

thm closure_of_open_right_ray:
    ? forall a R:
        closure_of_real_set('(a,)) = '[a,)
    by thm open_right_ray_closure_subset_closed_right_ray(a)
    by thm closed_right_ray_subset_open_right_ray_closure(a)
    by extension closure_of_real_set('(a,)) = '[a,)
    closure_of_real_set('(a,)) = '[a,)

