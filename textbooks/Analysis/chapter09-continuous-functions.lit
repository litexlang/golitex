                abs(x - y) <= (a - x) / 2
                (a - x) / 2 < abs(x - y) <= (a - x) / 2
                impossible (a - x) / 2 < (a - x) / 2
            case x >= a:
                x $in '[a,)
    closure_of_real_set('[a,)) $subset '[a,)

thm closure_of_closed_right_ray:
    ? forall a R:
        closure_of_real_set('[a,)) = '[a,)
    by thm closure_contains_set('[a,))
    by thm closed_right_ray_closure_subset_closed_right_ray(a)
    by extension closure_of_real_set('[a,)) = '[a,)
    closure_of_real_set('[a,)) = '[a,)

thm endpoint_adherent_to_open_left_ray:
    ? forall a R:
        $is_adherent_point('(,a), a)
    claim:
