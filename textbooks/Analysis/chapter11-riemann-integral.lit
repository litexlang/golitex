# Chapter 11: The Riemann integral.

# 11.1 Partitions

"""
Definition 11.1.1.  A subset of the real line is connected when every closed
interval between two of its points stays inside the subset.
"""

prop is_connected_subset_of_R(X power_set(R)):
    forall x, y X:
        x < y
        =>:
            '[x, y] $subset X

"""
Remark 11.1.2.  The chapter uses connectedness only for subsets of the real
line.  A later metric-space chapter generalizes the same idea.
"""

"""
Examples 11.1.3.  Closed and open intervals are connected; separated unions
such as `[1,2] union [3,4]` are not connected.  The empty set and singleton
sets are connected vacuously.
"""

thm closed_interval_is_connected:
    ? forall a, b R:
        a <= b
        =>:
            $is_connected_subset_of_R('[a, b])
    # Source handling: Tao verifies this directly from the interval
    # inequalities in the example.
    '[a, b] $subset R
    '[a, b] $in power_set(R)
    claim:
        ? forall x, y '[a, b]:
            x < y
            =>:
                '[x, y] $subset '[a, b]
        claim:
            ? '[x, y] $subset '[a, b]
            forall z '[x, y]:
                a <= x <= z
                z <= y <= b
                a <= z
                z <= b
                z $in '[a, b]
            '[x, y] $subset '[a, b]
    $is_connected_subset_of_R('[a, b])

thm open_interval_is_connected:
    ? forall a, b R:
        a < b
        =>:
            $is_connected_subset_of_R('(a, b))
    # Source handling: Tao says the same argument as for `[1,2]` applies.
    '(a, b) $subset R
    '(a, b) $in power_set(R)
    claim:
        ? forall x, y '(a, b):
            x < y
            =>:
                '[x, y] $subset '(a, b)
        claim:
            ? '[x, y] $subset '(a, b)
            forall z '[x, y]:
                a < x <= z
                z <= y < b
                a < z
                z < b
                z $in '(a, b)
            '[x, y] $subset '(a, b)
    $is_connected_subset_of_R('(a, b))

thm closed_interval_is_connected_without_endpoint_order:
    ? forall a, b R:
        $is_connected_subset_of_R('[a, b])
    '[a, b] $subset R
    '[a, b] $in power_set(R)
    claim:
        ? forall x, y '[a, b]:
            x < y
            =>:
                '[x, y] $subset '[a, b]
        claim:
            ? '[x, y] $subset '[a, b]
            forall z '[x, y]:
                a <= x <= z
                z <= y <= b
                a <= z
                z <= b
                z $in '[a, b]
            '[x, y] $subset '[a, b]
    $is_connected_subset_of_R('[a, b])

thm open_interval_is_connected_without_endpoint_order:
    ? forall a, b R:
        $is_connected_subset_of_R('(a, b))
    '(a, b) $subset R
    '(a, b) $in power_set(R)
    claim:
        ? forall x, y '(a, b):
            x < y
            =>:
                '[x, y] $subset '(a, b)
        claim:
            ? '[x, y] $subset '(a, b)
            forall z '[x, y]:
                a < x <= z
                z <= y < b
                a < z
                z < b
                z $in '(a, b)
            '[x, y] $subset '(a, b)
    $is_connected_subset_of_R('(a, b))

thm closed_open_interval_is_connected:
    ? forall a, b R:
        $is_connected_subset_of_R('[a, b))
    # Source handling: half-open intervals use the same order argument; the
    # left endpoint is closed and the right endpoint is open.
    '[a, b) $subset R
    '[a, b) $in power_set(R)
    claim:
        ? forall x, y '[a, b):
            x < y
            =>:
                '[x, y] $subset '[a, b)
        claim:
            ? '[x, y] $subset '[a, b)
            forall z '[x, y]:
                a <= x <= z
                z <= y < b
                a <= z
                z < b
                z $in '[a, b)
            '[x, y] $subset '[a, b)
    $is_connected_subset_of_R('[a, b))

thm open_closed_interval_is_connected:
    ? forall a, b R:
        $is_connected_subset_of_R('(a, b])
    # Source handling: this is the symmetric half-open case.
    '(a, b] $subset R
    '(a, b] $in power_set(R)
    claim:
        ? forall x, y '(a, b]:
            x < y
            =>:
                '[x, y] $subset '(a, b]
        claim:
            ? '[x, y] $subset '(a, b]
            forall z '[x, y]:
                a < x <= z
                z <= y <= b
                a < z
                z <= b
                z $in '(a, b]
            '[x, y] $subset '(a, b]
    $is_connected_subset_of_R('(a, b])

thm empty_set_is_connected:
    ? forall:
        $is_connected_subset_of_R({})
    # Source handling: the connectedness condition is vacuous for the empty set.
    claim:
        ? {} $subset R
        claim:
            ? forall z {}:
                z $in R
            by contra:
                ? z $in R
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from z
                impossible $is_nonempty_set({})
        {} $subset R
    {} $in power_set(R)
    claim:
        ? forall x, y {}:
            x < y
            =>:
                '[x, y] $subset {}
        by contra:
            ? '[x, y] $subset {}
            not $is_nonempty_set({})
            witness $is_nonempty_set({}) from x
            impossible $is_nonempty_set({})
    $is_connected_subset_of_R({})

thm singleton_is_connected:
    ? forall a R:
        $is_connected_subset_of_R({a})
    # Source handling: two points of a singleton are equal, so every interval
    # between them is the same singleton.
    claim:
        ? {a} $subset R
        claim:
            ? forall z {a}:
                z $in R
            z = a
            z $in R
        {a} $subset R
    {a} $in power_set(R)
    claim:
        ? forall x, y {a}:
            x < y
            =>:
                '[x, y] $subset {a}
        x = a
        y = a
        claim:
            ? '[x, y] $subset {a}
            forall z '[x, y]:
                x <= z <= y
                a <= z <= a
                z = a
                z $in {a}
            '[x, y] $subset {a}
    $is_connected_subset_of_R({a})

thm separated_closed_intervals_are_not_connected:
    ? forall:
        not $is_connected_subset_of_R(union('[1, 2], '[3, 4]))
    # Source handling: Tao's separated-union example fails connectedness
    # because the midpoint gap would have to belong to the union.
    by contra:
        ? not $is_connected_subset_of_R(union('[1, 2], '[3, 4]))
        $is_connected_subset_of_R(union('[1, 2], '[3, 4]))
        1 $in '[1, 2]
        1 $in union('[1, 2], '[3, 4])
        4 $in '[3, 4]
        4 $in union('[1, 2], '[3, 4])
        1 < 4
        '[1, 4] $subset union('[1, 2], '[3, 4])
        5 / 2 $in '[1, 4]
        5 / 2 $in union('[1, 2], '[3, 4])
        by contra not 5 / 2 $in '[1, 2]:
            5 / 2 $in '[1, 2]
            5 / 2 <= 2
            2 < 5 / 2
            impossible 5 / 2 <= 2
        by contra not 5 / 2 $in '[3, 4]:
            5 / 2 $in '[3, 4]
            3 <= 5 / 2
            5 / 2 < 3
            impossible 3 <= 5 / 2
        5 / 2 $in '[1, 2] or 5 / 2 $in '[3, 4]
        by cases:
            ? 5 / 2 <= 2
            case 5 / 2 $in '[1, 2]:
                impossible not 5 / 2 $in '[1, 2]
            case 5 / 2 $in '[3, 4]:
                impossible not 5 / 2 $in '[3, 4]
        2 < 5 / 2
        impossible 5 / 2 <= 2

prop has_interval_endpoints(I power_set(R), a, b R):
    I = '[a, b] or I = '[a, b) or I = '(a, b] or I = '(a, b)

prop is_bounded_interval(I power_set(R)):
    exist a, b R st {$has_interval_endpoints(I, a, b)}

thm interval_endpoint_form_is_a_bounded_interval:
    ? forall I power_set(R), a, b R:
        $has_interval_endpoints(I, a, b)
        =>:
            $is_bounded_interval(I)
    witness exist u, v R st {$has_interval_endpoints(I, u, v)} from a, b:
        $has_interval_endpoints(I, a, b)
    $is_bounded_interval(I)

thm endpoint_forms_are_bounded_intervals_for_intersection:
    ? forall a, b R:
        $is_bounded_interval('[a, b])
        $is_bounded_interval('[a, b))
        $is_bounded_interval('(a, b])
        $is_bounded_interval('(a, b))
    '[a, b] $subset R
    '[a, b] $in power_set(R)
    '[a, b) $subset R
    '[a, b) $in power_set(R)
    '(a, b] $subset R
    '(a, b] $in power_set(R)
    '(a, b) $subset R
    '(a, b) $in power_set(R)
    claim:
        ? $has_interval_endpoints('[a, b], a, b)
        '[a, b] = '[a, b]
        '[a, b] = '[a, b] or '[a, b] = '[a, b) or '[a, b] = '(a, b] or '[a, b] = '(a, b)
        $has_interval_endpoints('[a, b], a, b)
    claim:
        ? $is_bounded_interval('[a, b])
        witness exist a0, b0 R st {$has_interval_endpoints('[a, b], a0, b0)} from a, b:
            $has_interval_endpoints('[a, b], a, b)
    $is_bounded_interval('[a, b])
    claim:
        ? $has_interval_endpoints('[a, b), a, b)
        '[a, b) = '[a, b)
        '[a, b) = '[a, b] or '[a, b) = '[a, b) or '[a, b) = '(a, b] or '[a, b) = '(a, b)
        $has_interval_endpoints('[a, b), a, b)
    claim:
        ? $is_bounded_interval('[a, b))
        witness exist a0, b0 R st {$has_interval_endpoints('[a, b), a0, b0)} from a, b:
            $has_interval_endpoints('[a, b), a, b)
    $is_bounded_interval('[a, b))
    claim:
        ? $has_interval_endpoints('(a, b], a, b)
        '(a, b] = '(a, b]
        '(a, b] = '[a, b] or '(a, b] = '[a, b) or '(a, b] = '(a, b] or '(a, b] = '(a, b)
        $has_interval_endpoints('(a, b], a, b)
    claim:
        ? $is_bounded_interval('(a, b])
        witness exist a0, b0 R st {$has_interval_endpoints('(a, b], a0, b0)} from a, b:
            $has_interval_endpoints('(a, b], a, b)
    $is_bounded_interval('(a, b])
    claim:
        ? $has_interval_endpoints('(a, b), a, b)
        '(a, b) = '(a, b)
        '(a, b) = '[a, b] or '(a, b) = '[a, b) or '(a, b) = '(a, b] or '(a, b) = '(a, b)
        $has_interval_endpoints('(a, b), a, b)
    claim:
        ? $is_bounded_interval('(a, b))
        witness exist a0, b0 R st {$has_interval_endpoints('(a, b), a0, b0)} from a, b:
            $has_interval_endpoints('(a, b), a, b)
    $is_bounded_interval('(a, b))

# The four displayed endpoint forms have the same order-theoretic core.  The
# following lemmas keep the later intersection proof at that level rather than
# enumerating all sixteen pairs of open/closed endpoints.
thm interval_endpoint_member_is_between:
    ? forall I power_set(R), a, b, z R:
        $has_interval_endpoints(I, a, b)
        z $in I
        =>:
            a <= z
            z <= b
    by cases:
        ? a <= z
        ? z <= b
        case I = '[a, b]:
            z $in '[a, b]
            a <= z
            z <= b
        case I = '[a, b):
            z $in '[a, b)
            a <= z
            z < b
            z <= b
        case I = '(a, b]:
            z $in '(a, b]
            a < z
            a <= z
            z <= b
        case I = '(a, b):
            z $in '(a, b)
            a < z
            a <= z
            z < b
            z <= b

thm strict_between_interval_endpoints_is_member:
    ? forall I power_set(R), a, b, z R:
        $has_interval_endpoints(I, a, b)
        a < z
        z < b
        =>:
            z $in I
    by cases:
        ? z $in I
        case I = '[a, b]:
            z $in '[a, b]
            z $in I
        case I = '[a, b):
            z $in '[a, b)
            z $in I
        case I = '(a, b]:
            z $in '(a, b]
            z $in I
        case I = '(a, b):
            z $in '(a, b)
            z $in I

thm strict_between_intersections_of_interval_endpoint_forms_is_member:
    ? forall I, J power_set(R), a, b, c, d, z R:
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        finite_set_max(union({a}, { c})) < z
        z < finite_set_min(union({b}, { d}))
        =>:
            z $in intersect(I, J)
    a <= finite_set_max(union({a}, { c}))
    c <= finite_set_max(union({a}, { c}))
    a < z
    c < z
    finite_set_min(union({b}, { d})) <= b
    finite_set_min(union({b}, { d})) <= d
    z < b
    z < finite_set_min(union({b}, { d})) <= d
    z < d
    by thm strict_between_interval_endpoints_is_member(I, a, b, z)
    by thm strict_between_interval_endpoints_is_member(J, c, d, z)
    z $in intersect(I, J)

thm intersection_of_interval_endpoint_forms_member_bounds:
    ? forall I, J power_set(R), a, b, c, d R, z intersect(I, J):
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        =>:
            finite_set_max(union({a}, { c})) <= z
            z <= finite_set_min(union({b}, { d}))
    have z0 R = z
    z0 = z
    z0 $in I
    z0 $in J
    by thm interval_endpoint_member_is_between(I, a, b, z0)
    by thm interval_endpoint_member_is_between(J, c, d, z0)
    finite_set_max(union({a}, { c})) <= z0
    z0 <= finite_set_min(union({b}, { d}))
    finite_set_max(union({a}, { c})) <= z
    z <= finite_set_min(union({b}, { d}))

thm intersection_of_interval_endpoint_forms_member_is_in_closed_hull:
    ? forall I, J power_set(R), a, b, c, d R, z intersect(I, J):
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        =>:
            z $in '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]
    have z0 R = z
    z0 = z
    by thm intersection_of_interval_endpoint_forms_member_bounds(I, J, a, b, c, d, z)
    finite_set_max(union({a}, { c})) <= z0
    z0 <= finite_set_min(union({b}, { d}))
    z0 $in '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]
    z $in '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]

thm intersection_of_interval_endpoint_forms_member_is_in_closed_open_hull:
    ? forall I, J power_set(R), a, b, c, d R, z intersect(I, J):
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        finite_set_max(union({a}, { c})) $in intersect(I, J)
        not finite_set_min(union({b}, { d})) $in intersect(I, J)
        =>:
            z $in '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d})))
    have z0 R = z
    z0 = z
    z0 $in intersect(I, J)
    by thm intersection_of_interval_endpoint_forms_member_bounds(I, J, a, b, c, d, z)
    claim:
        ? z0 < finite_set_min(union({b}, { d}))
        by contra:
            ? z0 < finite_set_min(union({b}, { d}))
            z0 >= finite_set_min(union({b}, { d}))
            z0 = finite_set_min(union({b}, { d}))
            z0 $in intersect(I, J)
            impossible not finite_set_min(union({b}, { d})) $in intersect(I, J)
    finite_set_max(union({a}, { c})) <= z0
    z0 $in '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d})))
    z $in '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d})))

thm intersection_of_interval_endpoint_forms_member_is_in_open_closed_hull:
    ? forall I, J power_set(R), a, b, c, d R, z intersect(I, J):
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        not finite_set_max(union({a}, { c})) $in intersect(I, J)
        finite_set_min(union({b}, { d})) $in intersect(I, J)
        =>:
            z $in '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]
    have z0 R = z
    z0 = z
    z0 $in intersect(I, J)
    by thm intersection_of_interval_endpoint_forms_member_bounds(I, J, a, b, c, d, z)
    claim:
        ? finite_set_max(union({a}, { c})) < z0
        by contra:
            ? finite_set_max(union({a}, { c})) < z0
            finite_set_max(union({a}, { c})) >= z0
            finite_set_max(union({a}, { c})) = z0
            z0 $in intersect(I, J)
            impossible not finite_set_max(union({a}, { c})) $in intersect(I, J)
    z0 <= finite_set_min(union({b}, { d}))
    z0 $in '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]
    z $in '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]

thm intersection_of_interval_endpoint_forms_member_is_in_open_hull:
    ? forall I, J power_set(R), a, b, c, d R, z intersect(I, J):
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        not finite_set_max(union({a}, { c})) $in intersect(I, J)
        not finite_set_min(union({b}, { d})) $in intersect(I, J)
        =>:
            z $in '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d})))
    have z0 R = z
    z0 = z
    z0 $in intersect(I, J)
    by thm intersection_of_interval_endpoint_forms_member_bounds(I, J, a, b, c, d, z)
    claim:
        ? finite_set_max(union({a}, { c})) < z0
        by contra:
            ? finite_set_max(union({a}, { c})) < z0
            finite_set_max(union({a}, { c})) >= z0
            finite_set_max(union({a}, { c})) = z0
            z0 $in intersect(I, J)
            impossible not finite_set_max(union({a}, { c})) $in intersect(I, J)
    claim:
        ? z0 < finite_set_min(union({b}, { d}))
        by contra:
            ? z0 < finite_set_min(union({b}, { d}))
            z0 >= finite_set_min(union({b}, { d}))
            z0 = finite_set_min(union({b}, { d}))
            z0 $in intersect(I, J)
            impossible not finite_set_min(union({b}, { d})) $in intersect(I, J)
    z0 $in '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d})))
    z $in '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d})))

thm closed_between_intersection_of_interval_endpoint_forms_is_member:
    ? forall I, J power_set(R), a, b, c, d, z R:
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        finite_set_max(union({a}, { c})) $in intersect(I, J)
        finite_set_min(union({b}, { d})) $in intersect(I, J)
        z $in '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]
        =>:
            z $in intersect(I, J)
    finite_set_max(union({a}, { c})) < z or finite_set_max(union({a}, { c})) >= z
    by cases:
        ? z $in intersect(I, J)
        case finite_set_max(union({a}, { c})) < z:
            z < finite_set_min(union({b}, { d})) or z >= finite_set_min(union({b}, { d}))
            by cases:
                ? z $in intersect(I, J)
                case z < finite_set_min(union({b}, { d})):
                    by thm strict_between_intersections_of_interval_endpoint_forms_is_member(I, J, a, b, c, d, z)
                    z $in intersect(I, J)
                case z >= finite_set_min(union({b}, { d})):
                    z = finite_set_min(union({b}, { d}))
                    z $in intersect(I, J)
        case finite_set_max(union({a}, { c})) >= z:
            z = finite_set_max(union({a}, { c}))
            z $in intersect(I, J)

thm closed_between_intersection_of_interval_endpoint_forms_is_member_subtype:
    ? forall I, J power_set(R), a, b, c, d R, z '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]:
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        finite_set_max(union({a}, { c})) $in intersect(I, J)
        finite_set_min(union({b}, { d})) $in intersect(I, J)
        =>:
            z $in intersect(I, J)
    have z0 R = z
    z0 = z
    finite_set_max(union({a}, { c})) <= z0
    z0 <= finite_set_min(union({b}, { d}))
    by thm closed_between_intersection_of_interval_endpoint_forms_is_member(I, J, a, b, c, d, z0)
    z0 $in intersect(I, J)
    z $in intersect(I, J)

thm closed_open_between_intersection_of_interval_endpoint_forms_is_member:
    ? forall I, J power_set(R), a, b, c, d R, z '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))):
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        finite_set_max(union({a}, { c})) $in intersect(I, J)
        =>:
            z $in intersect(I, J)
    have z0 R = z
    z0 = z
    finite_set_max(union({a}, { c})) < z0 or finite_set_max(union({a}, { c})) >= z0
    by cases:
        ? z0 $in intersect(I, J)
        case finite_set_max(union({a}, { c})) < z0:
            z0 < finite_set_min(union({b}, { d}))
            by thm strict_between_intersections_of_interval_endpoint_forms_is_member(I, J, a, b, c, d, z0)
            z0 $in intersect(I, J)
        case finite_set_max(union({a}, { c})) >= z0:
            z0 = finite_set_max(union({a}, { c}))
            z0 $in intersect(I, J)
    z $in intersect(I, J)

thm open_closed_between_intersection_of_interval_endpoint_forms_is_member:
    ? forall I, J power_set(R), a, b, c, d R, z '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]:
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        finite_set_min(union({b}, { d})) $in intersect(I, J)
        =>:
            z $in intersect(I, J)
    have z0 R = z
    z0 = z
    z0 < finite_set_min(union({b}, { d})) or z0 >= finite_set_min(union({b}, { d}))
    by cases:
        ? z0 $in intersect(I, J)
        case z0 < finite_set_min(union({b}, { d})):
            finite_set_max(union({a}, { c})) < z0
            by thm strict_between_intersections_of_interval_endpoint_forms_is_member(I, J, a, b, c, d, z0)
            z0 $in intersect(I, J)
        case z0 >= finite_set_min(union({b}, { d})):
            z0 = finite_set_min(union({b}, { d}))
            z0 $in intersect(I, J)
    z $in intersect(I, J)

thm open_between_intersection_of_interval_endpoint_forms_is_member:
    ? forall I, J power_set(R), a, b, c, d R, z '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))):
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        =>:
            z $in intersect(I, J)
    have z0 R = z
    z0 = z
    finite_set_max(union({a}, { c})) < z0
    z0 < finite_set_min(union({b}, { d}))
    by thm strict_between_intersections_of_interval_endpoint_forms_is_member(I, J, a, b, c, d, z0)
    z0 $in intersect(I, J)
    z $in intersect(I, J)

thm intersection_of_interval_endpoint_forms_with_both_endpoints_is_closed:
    ? forall I, J power_set(R), a, b, c, d R:
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        finite_set_max(union({a}, { c})) $in intersect(I, J)
        finite_set_min(union({b}, { d})) $in intersect(I, J)
        =>:
            intersect(I, J) = '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]
    by extension intersect(I, J) = '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]:
        forall z intersect(I, J):
            z $in '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]
        forall z '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]:
            z $in intersect(I, J)

thm intersection_of_interval_endpoint_forms_with_left_endpoint_is_closed_open:
    ? forall I, J power_set(R), a, b, c, d R:
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        finite_set_max(union({a}, { c})) $in intersect(I, J)
        not finite_set_min(union({b}, { d})) $in intersect(I, J)
        =>:
            intersect(I, J) = '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d})))
    by extension intersect(I, J) = '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))):
        forall z intersect(I, J):
            z $in '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d})))
        forall z '[finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))):
            z $in intersect(I, J)

thm intersection_of_interval_endpoint_forms_with_right_endpoint_is_open_closed:
    ? forall I, J power_set(R), a, b, c, d R:
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        not finite_set_max(union({a}, { c})) $in intersect(I, J)
        finite_set_min(union({b}, { d})) $in intersect(I, J)
        =>:
            intersect(I, J) = '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]
    by extension intersect(I, J) = '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]:
        forall z intersect(I, J):
            z $in '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]
        forall z '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))]:
            z $in intersect(I, J)

thm intersection_of_interval_endpoint_forms_without_endpoints_is_open:
    ? forall I, J power_set(R), a, b, c, d R:
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(J, c, d)
        not finite_set_max(union({a}, { c})) $in intersect(I, J)
        not finite_set_min(union({b}, { d})) $in intersect(I, J)
        =>:
            intersect(I, J) = '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d})))
    by extension intersect(I, J) = '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))):
        forall z intersect(I, J):
            z $in '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d})))
        forall z '(finite_set_max(union({a}, { c})), finite_set_min(union({b}, { d}))):
            z $in intersect(I, J)

thm closed_interval_is_bounded_without_endpoint_order:
    ? forall a, b R:
        $chap9::is_bounded_real_set('[a, b])
    by cases:
        ? $chap9::is_bounded_real_set('[a, b])
        case a <= b:
            by thm chap9::closed_interval_is_bounded(a, b)
            $chap9::is_bounded_real_set('[a, b])
        case not a <= b:
            by extension '[a, b] = {}:
                claim:
                    ? forall x '[a, b]:
                        x $in {}
                    a <= x
                    x <= b
                    a <= x <= b
                    a <= b
                    by contra:
                        ? x $in {}
                        not x $in {}
                        impossible a <= b
                claim:
                    ? forall x {}:
                        x $in '[a, b]
                    by contra:
                        ? x $in '[a, b]
                        not $is_nonempty_set({})
                        witness $is_nonempty_set({}) from x
                        impossible $is_nonempty_set({})
            by thm chap9::empty_real_set_is_bounded()
            $chap9::is_bounded_real_set({})
            $chap9::is_bounded_real_set('[a, b])

"""
Lemma 11.1.4.  A subset of the real line is a bounded interval exactly when it
is both bounded and connected.
"""

thm bounded_connected_subsets_are_bounded_intervals:
    ? forall X power_set(R):
        $chap9::is_bounded_real_set(X)
        $is_connected_subset_of_R(X)
        =>:
            $is_bounded_interval(X)
    # Source handling: Lemma 11.1.4 leaves the endpoint construction to
    # Exercise 11.1.1.  The trust below records exactly that source-deferred
    # step rather than presenting the lemma as checked.
    # proof_debt: the endpoint existence and open/closed case analysis remain
    # to be formalized.
    by cases:
        ? $is_bounded_interval(X)
        case $is_nonempty_set(X):
            # Source handling: this is the non-empty endpoint-classification
            # step deferred by Exercise 11.1.1.
            # proof_debt: endpoint openness and closedness still need the
            # local order-case proof.
            trust $is_bounded_interval(X)
        case not $is_nonempty_set(X):
            by extension X = {}:
                claim:
                    ? forall z X:
                        z $in {}
                    by contra:
                        ? z $in {}
                        not z $in {}
                        witness $is_nonempty_set(X) from z
                        impossible $is_nonempty_set(X)
                claim:
                    ? forall z {}:
                        z $in X
                    by contra:
                        ? z $in X
                        not $is_nonempty_set({})
                        witness $is_nonempty_set({}) from z
                        impossible $is_nonempty_set({})
            by extension {} = '(0, 0):
                claim:
                    ? forall z {}:
                        z $in '(0, 0)
                    by contra:
                        ? z $in '(0, 0)
                        not $is_nonempty_set({})
                        witness $is_nonempty_set({}) from z
                        impossible $is_nonempty_set({})
                claim:
                    ? forall z '(0, 0):
                        z $in {}
                    0 < z
                    z < 0
                    by contra:
                        ? z $in {}
                        not z $in {}
                        z <= 0
                        impossible 0 < z
            X = '(0, 0)
            claim:
                ? $has_interval_endpoints(X, 0, 0)
                X = '(0, 0)
                X = '[0, 0] or X = '[0, 0) or X = '(0, 0] or X = '(0, 0)
            witness exist a, b R st {$has_interval_endpoints(X, a, b)} from 0, 0:
                $has_interval_endpoints(X, 0, 0)
            $is_bounded_interval(X)

thm bounded_intervals_are_bounded_connected:
    ? forall X power_set(R):
        $is_bounded_interval(X)
        =>:
            $chap9::is_bounded_real_set(X)
            $is_connected_subset_of_R(X)
    # Source handling: split the displayed endpoint forms.  Each form is
    # connected directly; boundedness comes from containment in `[a,b]`.
    obtain a, b from exist a, b R st {$has_interval_endpoints(X, a, b)}
    by cases:
        ? $chap9::is_bounded_real_set(X)
        ? $is_connected_subset_of_R(X)
        case X = '[a, b]:
            by thm closed_interval_is_bounded_without_endpoint_order(a, b)
            $chap9::is_bounded_real_set('[a, b])
            $chap9::is_bounded_real_set(X)
            by thm closed_interval_is_connected_without_endpoint_order(a, b)
            $is_connected_subset_of_R('[a, b])
            $is_connected_subset_of_R(X)
        case X = '[a, b):
            claim:
                ? '[a, b) $subset '[a, b]
                forall x '[a, b):
                    a <= x
                    x < b
                    x <= b
                    x $in '[a, b]
                '[a, b) $subset '[a, b]
            by thm closed_interval_is_bounded_without_endpoint_order(a, b)
            $chap9::is_bounded_real_set('[a, b])
            by thm chap9::bounded_real_set_subset('[a, b), '[a, b])
            $chap9::is_bounded_real_set('[a, b))
            $chap9::is_bounded_real_set(X)
            by thm closed_open_interval_is_connected(a, b)
            $is_connected_subset_of_R('[a, b))
            $is_connected_subset_of_R(X)
        case X = '(a, b]:
            claim:
                ? '(a, b] $subset '[a, b]
                forall x '(a, b]:
                    a < x
                    x <= b
                    a <= x
                    x $in '[a, b]
                '(a, b] $subset '[a, b]
            by thm closed_interval_is_bounded_without_endpoint_order(a, b)
            $chap9::is_bounded_real_set('[a, b])
            by thm chap9::bounded_real_set_subset('(a, b], '[a, b])
            $chap9::is_bounded_real_set('(a, b])
            $chap9::is_bounded_real_set(X)
            by thm open_closed_interval_is_connected(a, b)
            $is_connected_subset_of_R('(a, b])
            $is_connected_subset_of_R(X)
        case X = '(a, b):
            claim:
                ? '(a, b) $subset '[a, b]
                forall x '(a, b):
                    a < x
                    x < b
                    a <= x
                    x <= b
                    x $in '[a, b]
                '(a, b) $subset '[a, b]
            by thm closed_interval_is_bounded_without_endpoint_order(a, b)
            $chap9::is_bounded_real_set('[a, b])
            by thm chap9::bounded_real_set_subset('(a, b), '[a, b])
            $chap9::is_bounded_real_set('(a, b))
            $chap9::is_bounded_real_set(X)
            by thm open_interval_is_connected_without_endpoint_order(a, b)
            $is_connected_subset_of_R('(a, b))
            $is_connected_subset_of_R(X)

# The source lemma is an iff statement; the two named theorems above are the
# reusable directions used by later proofs.
forall X power_set(R):
    =>:
        $is_bounded_interval(X)
    <=>:
        $chap9::is_bounded_real_set(X)
        $is_connected_subset_of_R(X)

"""
Remark 11.1.5.  Bounded intervals include degenerate intervals such as
singleton points, and also include the empty set.
"""

"""
Corollary 11.1.6.  The intersection of two bounded intervals is again a
bounded interval.
"""

thm intersection_of_bounded_intervals_is_bounded_interval:
    ? forall I, J power_set(R):
        $is_bounded_interval(I)
        $is_bounded_interval(J)
        =>:
            $is_bounded_interval(intersect(I, J))
    # Source handling: Tao proves this in Exercise 11.1.2 by using Lemma
    # 11.1.4. Boundedness descends from either factor, while connectedness
    # descends from both.
    by thm chap9::real_set_operations_stay_in_power_set(I, J)
    intersect(I, J) $in power_set(R)
    by thm bounded_intervals_are_bounded_connected(I)
    by thm bounded_intervals_are_bounded_connected(J)
    claim:
        ? intersect(I, J) $subset I
        forall x intersect(I, J):
            x $in I
        intersect(I, J) $subset I
    by thm chap9::bounded_real_set_subset(intersect(I, J), I)
    $chap9::is_bounded_real_set(intersect(I, J))
    claim:
        ? $is_connected_subset_of_R(intersect(I, J))
        claim:
            ? forall x, y intersect(I, J):
                x < y
                =>:
                    '[x, y] $subset intersect(I, J)
            x $in I
            y $in I
            x $in J
            y $in J
            '[x, y] $subset I
            '[x, y] $subset J
            claim:
                ? '[x, y] $subset intersect(I, J)
                forall z '[x, y]:
                    z $in I
                    z $in J
                    z $in intersect(I, J)
                '[x, y] $subset intersect(I, J)
        $is_connected_subset_of_R(intersect(I, J))
    by thm bounded_connected_subsets_are_bounded_intervals(intersect(I, J))
    $is_bounded_interval(intersect(I, J))

"""
Example 11.1.7.  `[2,4] intersect [4,6]` is the singleton `{4}`, while
`(2,4) intersect (4,6)` is empty.
"""

thm example_11_1_7_intersections:
    ? forall:
        intersect('[2, 4], '[4, 6]) = {4}
        intersect('(2, 4), '(4, 6)) = {}
    # Source handling: this is the direct interval-membership computation in
    # the example.
    by extension intersect('[2, 4], '[4, 6]) = {4}:
        forall z intersect('[2, 4], '[4, 6]):
            z $in '[2, 4]
            z $in '[4, 6]
            z <= 4 <= z
            z = 4
            z $in {4}
        forall z {4}:
            z = 4
            z $in '[2, 4]
            z $in '[4, 6]
            z $in intersect('[2, 4], '[4, 6])
    by extension intersect('(2, 4), '(4, 6)) = {}:
        claim:
            ? forall z intersect('(2, 4), '(4, 6)):
                z $in {}
            z $in '(2, 4)
            z $in '(4, 6)
            z < 4
            4 < z
            z <= 4
            by contra:
                ? z $in {}
                not z $in {}
                impossible z <= 4
        claim:
            ? forall z {}:
                z $in intersect('(2, 4), '(4, 6))
            by contra:
                ? z $in intersect('(2, 4), '(4, 6))
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from z
                impossible $is_nonempty_set({})

"""
Definition 11.1.8 (Length of intervals).  The length of a bounded interval is
`b-a` for any non-degenerate interval with endpoints `a<b`, and is `0` for a
singleton or the empty set.
"""

# Litex packages the source case split by allowing all endpoint orders and
# taking the positive part of the endpoint difference.

prop has_interval_length_with_endpoints(I power_set(R), l, a, b R):
    $has_interval_endpoints(I, a, b)
    l = finite_set_max(union({b - a}, { 0}))

prop has_interval_length(I power_set(R), l R):
    exist a0, b0 R st {$has_interval_length_with_endpoints(I, l, a0, b0)}

thm interval_length_endpoint_case:
    ? forall I power_set(R), l, a, b R:
        $has_interval_length_with_endpoints(I, l, a, b)
        =>:
            $has_interval_length(I, l)
    witness exist a0, b0 R st {$has_interval_length_with_endpoints(I, l, a0, b0)} from a, b:
        $has_interval_length_with_endpoints(I, l, a, b)

thm interval_endpoint_case_has_total_length:
    ? forall I power_set(R), a, b R:
        $has_interval_endpoints(I, a, b)
        =>:
            $has_interval_length(I, finite_set_max(union({b - a}, { 0})))
    claim:
        ? $has_interval_length_with_endpoints(I, finite_set_max(union({b - a}, { 0})), a, b)
        $has_interval_endpoints(I, a, b)
        finite_set_max(union({b - a}, { 0})) = finite_set_max(union({b - a}, { 0}))
    by thm interval_length_endpoint_case(I, finite_set_max(union({b - a}, { 0})), a, b)

thm nonempty_interval_endpoint_representation_unique:
    ? forall I power_set(R), a, b, c, d R:
        $has_interval_endpoints(I, a, b)
        $has_interval_endpoints(I, c, d)
        $is_nonempty_set(I)
        =>:
            a = c
            b = d
    obtain x from exist x I st {x $in I}
    by thm interval_endpoint_member_is_between(I, a, b, x)
    by thm interval_endpoint_member_is_between(I, c, d, x)
    claim:
        ? a = c
        by contra:
            ? a = c
            a < c or c < a
            by cases:
                ? a = c
                case a < c:
                    have z R = (a + c) / 2
                    a < z < c
                    c <= x <= b
                    z < b
                    by thm strict_between_interval_endpoints_is_member(I, a, b, z)
                    z $in I
                    by thm interval_endpoint_member_is_between(I, c, d, z)
                    c <= z
                    impossible z < c
                case c < a:
                    have z R = (c + a) / 2
                    c < z < a
                    a <= x <= d
                    z < d
                    by thm strict_between_interval_endpoints_is_member(I, c, d, z)
                    z $in I
                    by thm interval_endpoint_member_is_between(I, a, b, z)
                    a <= z
                    impossible z < a
            impossible a != c
    claim:
        ? b = d
        by contra:
            ? b = d
            b < d or d < b
            by cases:
                ? b = d
                case b < d:
                    have z R = (b + d) / 2
                    b < z < d
                    c = a
                    a <= x <= b
                    c < z
                    by thm strict_between_interval_endpoints_is_member(I, c, d, z)
                    z $in I
                    by thm interval_endpoint_member_is_between(I, a, b, z)
                    z <= b
                    impossible b < z
                case d < b:
                    have z R = (d + b) / 2
                    d < z < b
                    a = c
                    c <= x <= d
                    a < z
                    by thm strict_between_interval_endpoints_is_member(I, a, b, z)
                    z $in I
                    by thm interval_endpoint_member_is_between(I, c, d, z)
                    z <= d
                    impossible d < z
            impossible b != d

thm interval_length_value_unique:
    ? forall I power_set(R), l1, l2 R:
        $has_interval_length(I, l1)
        $has_interval_length(I, l2)
        =>:
            l1 = l2
    # Source handling: a nonempty interval determines its two order endpoints
    # even when their membership is open or closed. For the empty interval,
    # every endpoint representation has nonpositive endpoint difference.
    obtain a, b from exist a0, b0 R st {$has_interval_length_with_endpoints(I, l1, a0, b0)}
    obtain c, d from exist c0, d0 R st {$has_interval_length_with_endpoints(I, l2, c0, d0)}
    $is_nonempty_set(I) or not $is_nonempty_set(I)
    by cases:
        ? l1 = l2
        case not $is_nonempty_set(I):
            claim:
                ? b <= a
                by contra:
                    ? b <= a
                    a < b
                    have z R = (a + b) / 2
                    a < z < b
                    by thm strict_between_interval_endpoints_is_member(I, a, b, z)
                    z $in I
                    witness $is_nonempty_set(I) from z
                    impossible not $is_nonempty_set(I)
            claim:
                ? d <= c
                by contra:
                    ? d <= c
                    c < d
                    have z R = (c + d) / 2
                    c < z < d
                    by thm strict_between_interval_endpoints_is_member(I, c, d, z)
                    z $in I
                    witness $is_nonempty_set(I) from z
                    impossible not $is_nonempty_set(I)
            by thm max_positive_part_zero_when_nonpositive(a, b)
            by thm max_positive_part_zero_when_nonpositive(c, d)
            l1 = finite_set_max(union({b - a}, { 0})) = 0
            l2 = finite_set_max(union({d - c}, { 0})) = 0
            l1 = l2
        case $is_nonempty_set(I):
            by thm nonempty_interval_endpoint_representation_unique(I, a, b, c, d)
            b - a = d - c
            finite_set_max(union({b - a}, { 0})) = finite_set_max(union({d - c}, { 0}))
            l1 = finite_set_max(union({b - a}, { 0}))
            l2 = finite_set_max(union({d - c}, { 0}))
            l1 = l2

have fn interval_length by exist!:
    ? forall I power_set(R):
        $is_bounded_interval(I)
        =>:
            exist! l R st {$has_interval_length(I, l)}
    # Source handling: this packages the endpoint-only length formula as a
    # selector.  Degenerate and empty intervals are represented by degenerate
    # endpoint forms, so no separate length branch is needed.
    obtain a, b from exist a, b R st {$has_interval_endpoints(I, a, b)}
    by thm interval_endpoint_case_has_total_length(I, a, b)
    claim:
        ? exist l R st {$has_interval_length(I, l)}
        witness exist l R st {$has_interval_length(I, l)} from finite_set_max(union({b - a}, { 0})):
            $has_interval_length(I, finite_set_max(union({b - a}, { 0})))
    claim:
        ? forall l1, l2 R:
            $has_interval_length(I, l1)
            $has_interval_length(I, l2)
            =>:
                l1 = l2
        by thm interval_length_value_unique(I, l1, l2)
    exist! l R st {$has_interval_length(I, l)}

thm interval_length_nonnegative:
    ? forall I power_set(R):
        $is_bounded_interval(I)
        =>:
            interval_length(I) >= 0
    # Source handling: interval length is the positive part of an endpoint
    # difference, so it is non-negative in every endpoint convention.
    obtain a, b from exist a, b R st {$has_interval_endpoints(I, a, b)}
    by thm interval_endpoint_case_has_total_length(I, a, b)
    $has_interval_length(I, finite_set_max(union({b - a}, { 0})))
    $has_interval_length(I, interval_length(I))
    by thm interval_length_value_unique(I, interval_length(I), finite_set_max(union({b - a}, { 0})))
    interval_length(I) = finite_set_max(union({b - a}, { 0}))
    finite_set_max(union({b - a}, { 0})) >= 0
    interval_length(I) >= 0

thm interval_endpoint_forms_are_bounded_intervals:
    ? forall a, b R:
        '[a, b] $in power_set(R)
        '[a, b) $in power_set(R)
        '(a, b] $in power_set(R)
        '(a, b) $in power_set(R)
        $is_bounded_interval('[a, b])
        $is_bounded_interval('[a, b))
        $is_bounded_interval('(a, b])
        $is_bounded_interval('(a, b))
    '[a, b] $subset R
    '[a, b] $in power_set(R)
    '[a, b) $subset R
    '[a, b) $in power_set(R)
    '(a, b] $subset R
    '(a, b] $in power_set(R)
    '(a, b) $subset R
    '(a, b) $in power_set(R)
    claim:
        ? $has_interval_endpoints('[a, b], a, b)
        '[a, b] = '[a, b]
        '[a, b] = '[a, b] or '[a, b] = '[a, b) or '[a, b] = '(a, b] or '[a, b] = '(a, b)
    claim:
        ? $is_bounded_interval('[a, b])
        witness exist a0, b0 R st {$has_interval_endpoints('[a, b], a0, b0)} from a, b:
            $has_interval_endpoints('[a, b], a, b)
    $is_bounded_interval('[a, b])
    claim:
        ? $has_interval_endpoints('[a, b), a, b)
        '[a, b) = '[a, b)
        '[a, b) = '[a, b] or '[a, b) = '[a, b) or '[a, b) = '(a, b] or '[a, b) = '(a, b)
    claim:
        ? $is_bounded_interval('[a, b))
        witness exist a0, b0 R st {$has_interval_endpoints('[a, b), a0, b0)} from a, b:
            $has_interval_endpoints('[a, b), a, b)
    $is_bounded_interval('[a, b))
    claim:
        ? $has_interval_endpoints('(a, b], a, b)
        '(a, b] = '(a, b]
        '(a, b] = '[a, b] or '(a, b] = '[a, b) or '(a, b] = '(a, b] or '(a, b] = '(a, b)
    claim:
        ? $is_bounded_interval('(a, b])
        witness exist a0, b0 R st {$has_interval_endpoints('(a, b], a0, b0)} from a, b:
            $has_interval_endpoints('(a, b], a, b)
    $is_bounded_interval('(a, b])
    claim:
        ? $has_interval_endpoints('(a, b), a, b)
        '(a, b) = '(a, b)
        '(a, b) = '[a, b] or '(a, b) = '[a, b) or '(a, b) = '(a, b] or '(a, b) = '(a, b)
    claim:
        ? $is_bounded_interval('(a, b))
        witness exist a0, b0 R st {$has_interval_endpoints('(a, b), a0, b0)} from a, b:
            $has_interval_endpoints('(a, b), a, b)
    $is_bounded_interval('(a, b))

thm non_degenerate_interval_forms_are_bounded_intervals:
    ? forall a, b R:
        a < b
        =>:
            '[a, b] $in power_set(R)
            '[a, b) $in power_set(R)
            '(a, b] $in power_set(R)
            '(a, b) $in power_set(R)
            $is_bounded_interval('[a, b])
            $is_bounded_interval('[a, b))
            $is_bounded_interval('(a, b])
            $is_bounded_interval('(a, b))
    by thm interval_endpoint_forms_are_bounded_intervals(a, b)

thm singleton_interval_is_closed_degenerate:
    ? forall a R:
        {a} = '[a, a]
    by extension {a} = '[a, a]:
        forall x {a}:
            x = a
            a <= x
            x <= a
            x $in '[a, a]
        forall x '[a, a]:
            a <= x
            x <= a
            x = a
            x $in {a}

thm empty_interval_is_open_degenerate:
    ? forall a R:
        {} = '(a, a)
    by extension {} = '(a, a):
        claim:
            ? forall x {}:
                x $in '(a, a)
            by contra:
                ? x $in '(a, a)
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from x
                impossible $is_nonempty_set({})
        claim:
            ? forall x '(a, a):
                x $in {}
            a < x
            x < a
            by contra:
                ? x $in {}
                not x $in {}
                x <= a
                impossible a < x

thm singleton_interval_is_bounded:
    ? forall a R:
        {a} $in power_set(R)
        $is_bounded_interval({a})
    claim:
        ? {a} $subset R
        claim:
            ? forall z {a}:
                z $in R
            z = a
            z $in R
        {a} $subset R
    {a} $in power_set(R)
    claim:
        ? $has_interval_endpoints({a}, a, a)
        by thm singleton_interval_is_closed_degenerate(a)
        {a} = '[a, a]
        {a} = '[a, a] or {a} = '[a, a) or {a} = '(a, a] or {a} = '(a, a)
    witness exist a0, b0 R st {$has_interval_endpoints({a}, a0, b0)} from a, a:
        $has_interval_endpoints({a}, a, a)
    $is_bounded_interval({a})

thm empty_interval_is_bounded:
    ? forall:
        {} $in power_set(R)
        $is_bounded_interval({})
    claim:
        ? {} $subset R
        claim:
            ? forall z {}:
                z $in R
            by contra:
                ? z $in R
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from z
                impossible $is_nonempty_set({})
        {} $subset R
    {} $in power_set(R)
    by thm empty_interval_is_open_degenerate(0)
    claim:
        ? $has_interval_endpoints({}, 0, 0)
        {} = '(0, 0)
        {} = '[0, 0] or {} = '[0, 0) or {} = '(0, 0] or {} = '(0, 0)
    witness exist a, b R st {$has_interval_endpoints({}, a, b)} from 0, 0:
        $has_interval_endpoints({}, 0, 0)
    $is_bounded_interval({})

thm max_positive_part_identity_when_positive:
    ? forall a, b R:
        a < b
        =>:
            finite_set_max(union({b - a}, { 0})) = b - a
    b - a > 0
    b - a >= 0
    b - a <= b - a
    0 <= b - a
    finite_set_max(union({b - a}, { 0})) <= b - a
    b - a <= finite_set_max(union({b - a}, { 0}))
    finite_set_max(union({b - a}, { 0})) = b - a

thm max_positive_part_zero_when_nonpositive:
    ? forall a, b R:
        b <= a
        =>:
            finite_set_max(union({b - a}, { 0})) = 0
    b - a <= 0
    0 <= 0
    finite_set_max(union({b - a}, { 0})) <= 0
    0 <= finite_set_max(union({b - a}, { 0}))
    finite_set_max(union({b - a}, { 0})) = 0

thm interval_endpoint_forms_have_total_length:
    ? forall a, b R:
        $has_interval_length('[a, b], finite_set_max(union({b - a}, { 0})))
        $has_interval_length('[a, b), finite_set_max(union({b - a}, { 0})))
        $has_interval_length('(a, b], finite_set_max(union({b - a}, { 0})))
        $has_interval_length('(a, b), finite_set_max(union({b - a}, { 0})))
    by thm interval_endpoint_forms_are_bounded_intervals(a, b)
    claim:
        ? $has_interval_endpoints('[a, b], a, b)
        '[a, b] = '[a, b]
        '[a, b] = '[a, b] or '[a, b] = '[a, b) or '[a, b] = '(a, b] or '[a, b] = '(a, b)
    by thm interval_endpoint_case_has_total_length('[a, b], a, b)
    claim:
        ? $has_interval_endpoints('[a, b), a, b)
        '[a, b) = '[a, b)
        '[a, b) = '[a, b] or '[a, b) = '[a, b) or '[a, b) = '(a, b] or '[a, b) = '(a, b)
    by thm interval_endpoint_case_has_total_length('[a, b), a, b)
    claim:
        ? $has_interval_endpoints('(a, b], a, b)
        '(a, b] = '(a, b]
        '(a, b] = '[a, b] or '(a, b] = '[a, b) or '(a, b] = '(a, b] or '(a, b] = '(a, b)
    by thm interval_endpoint_case_has_total_length('(a, b], a, b)
    claim:
        ? $has_interval_endpoints('(a, b), a, b)
        '(a, b) = '(a, b)
        '(a, b) = '[a, b] or '(a, b) = '[a, b) or '(a, b) = '(a, b] or '(a, b) = '(a, b)
    by thm interval_endpoint_case_has_total_length('(a, b), a, b)

thm interval_endpoint_forms_have_zero_length_when_nonpositive:
    ? forall a, b R:
        b <= a
        =>:
            $has_interval_length('[a, b], 0)
            $has_interval_length('[a, b), 0)
            $has_interval_length('(a, b], 0)
            $has_interval_length('(a, b), 0)
    by thm interval_endpoint_forms_have_total_length(a, b)
    by thm max_positive_part_zero_when_nonpositive(a, b)
    $has_interval_length('[a, b], finite_set_max(union({b - a}, { 0})))
    $has_interval_length('[a, b], 0)
    $has_interval_length('[a, b), finite_set_max(union({b - a}, { 0})))
    $has_interval_length('[a, b), 0)
    $has_interval_length('(a, b], finite_set_max(union({b - a}, { 0})))
    $has_interval_length('(a, b], 0)
    $has_interval_length('(a, b), finite_set_max(union({b - a}, { 0})))
    $has_interval_length('(a, b), 0)

thm non_degenerate_interval_forms_have_length:
    ? forall a, b R:
        a < b
        =>:
            $has_interval_length('[a, b], b - a)
            $has_interval_length('[a, b), b - a)
            $has_interval_length('(a, b], b - a)
            $has_interval_length('(a, b), b - a)
    # Source handling: this is the non-degenerate branch of Definition
    # 11.1.8, obtained by simplifying the total endpoint formula.
    by thm interval_endpoint_forms_have_total_length(a, b)
    by thm max_positive_part_identity_when_positive(a, b)
    $has_interval_length('[a, b], finite_set_max(union({b - a}, { 0})))
    $has_interval_length('[a, b], b - a)
    $has_interval_length('[a, b), finite_set_max(union({b - a}, { 0})))
    $has_interval_length('[a, b), b - a)
    $has_interval_length('(a, b], finite_set_max(union({b - a}, { 0})))
    $has_interval_length('(a, b], b - a)
    $has_interval_length('(a, b), finite_set_max(union({b - a}, { 0})))
    $has_interval_length('(a, b), b - a)

thm singleton_interval_has_length_zero:
    ? forall a R:
        $has_interval_length({a}, 0)
    by thm singleton_interval_is_bounded(a)
    by thm singleton_interval_is_closed_degenerate(a)
    claim:
        ? $has_interval_endpoints({a}, a, a)
        {a} = '[a, a]
        {a} = '[a, a] or {a} = '[a, a) or {a} = '(a, a] or {a} = '(a, a)
    by thm interval_endpoint_case_has_total_length({a}, a, a)
    a <= a
    by thm max_positive_part_zero_when_nonpositive(a, a)
    $has_interval_length({a}, finite_set_max(union({a - a}, { 0})))
    $has_interval_length({a}, 0)

thm empty_interval_has_length_zero:
    ? forall:
        $has_interval_length({}, 0)
    by thm empty_interval_is_bounded()
    by thm empty_interval_is_open_degenerate(0)
    claim:
        ? $has_interval_endpoints({}, 0, 0)
        {} = '(0, 0)
        {} = '[0, 0] or {} = '[0, 0) or {} = '(0, 0] or {} = '(0, 0)
    by thm interval_endpoint_case_has_total_length({}, 0, 0)
    0 <= 0
    by thm max_positive_part_zero_when_nonpositive(0, 0)
    $has_interval_length({}, finite_set_max(union({0 - 0}, { 0})))
    $has_interval_length({}, 0)

"""
Example 11.1.9.  `[3,5]` and `(3,5)` both have length `2`; a singleton and
the empty set have length `0`.
"""

thm example_11_1_9_interval_lengths:
    ? forall:
        $has_interval_length('[3, 5], 2)
        $has_interval_length('(3, 5), 2)
        $has_interval_length({5}, 0)
        $has_interval_length({}, 0)
    # Source handling: these are direct evaluations from Definition 11.1.8.
    by thm non_degenerate_interval_forms_have_length(3, 5)
    5 - 3 = 2
    $has_interval_length('[3, 5], 5 - 3)
    $has_interval_length('[3, 5], 2)
    $has_interval_length('(3, 5), 5 - 3)
    $has_interval_length('(3, 5), 2)
    by thm singleton_interval_has_length_zero(5)
    by thm empty_interval_has_length_zero()

"""
Definition 11.1.10 (Partitions).  A partition of a bounded interval `I` is a
finite set of bounded intervals contained in `I`, and each point of `I` lies in
exactly one member of the partition.
"""

prop is_partition_of_bounded_interval(I power_set(R), P finite_set):
    $is_bounded_interval(I)
    forall J P:
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset I
    forall x I:
        exist! J P st {J $in power_set(R), x $in J}

thm partition_is_set_of_real_subsets:
    ? forall I power_set(R), P finite_set:
        $is_partition_of_bounded_interval(I, P)
        =>:
            P $in power_set(power_set(R))
    # Every partition piece is a real subset.  This is the carrier bridge for
    # construction-valued APIs whose arguments are finite families of pieces.
    claim:
        ? P $subset power_set(R)
        forall J P:
            J $in power_set(R)
        P $subset power_set(R)
    P $in power_set(power_set(R))

# A partition supplies a canonical piece for each point of its interval. This
# is an object-level selector because step functions later apply it to a point.
have fn partition_piece_containing by exist!:
    ? forall I power_set(R), P power_set(power_set(R)), x I:
        $is_finite_set(P)
        $is_partition_of_bounded_interval(I, P)
        =>:
            exist! J power_set(R) st {J $in P, x $in J}
    $is_partition_of_bounded_interval(I, P)
    obtain J0 from exist J P st {J $in power_set(R), x $in J}
    witness exist! J power_set(R) st {J $in P, x $in J} from J0:
        J0 $in P
        x $in J0
        claim:
            ? forall J1, J2 power_set(R):
                J1 $in P
                J2 $in P
                x $in J1
                x $in J2
                =>:
                    J1 = J2
            exist! H P st {H $in power_set(R), x $in H}
            J1 $in power_set(R)
            J2 $in power_set(R)
            J1 = J2

thm partition_piece_containing_has_value:
    ? forall I power_set(R), P power_set(power_set(R)), x I:
        $is_finite_set(P)
        $is_partition_of_bounded_interval(I, P)
        =>:
            partition_piece_containing(I, P, x) $in P
            x $in partition_piece_containing(I, P, x)
    have J power_set(R) = partition_piece_containing(I, P, x)
    J $in P
    x $in J
    J = partition_piece_containing(I, P, x)
    partition_piece_containing(I, P, x) $in P
    x $in partition_piece_containing(I, P, x)

thm partition_piece_containing_eq_given_piece:
    ? forall I power_set(R), P power_set(power_set(R)), x I, J power_set(R):
        $is_finite_set(P)
        $is_partition_of_bounded_interval(I, P)
        J $in P
        x $in J
        =>:
            partition_piece_containing(I, P, x) = J
    by thm partition_piece_containing_has_value(I, P, x)
    partition_piece_containing(I, P, x) $in P
    x $in partition_piece_containing(I, P, x)
    $is_partition_of_bounded_interval(I, P)
    exist! K P st {K $in power_set(R), x $in K}
    partition_piece_containing(I, P, x) $in power_set(R)
    J $in power_set(R)
    partition_piece_containing(I, P, x) = J

thm one_piece_partition_of_bounded_interval:
    ? forall I power_set(R):
        $is_bounded_interval(I)
        =>:
            $is_partition_of_bounded_interval(I, {I})
    # Source handling: this is the degenerate partition used repeatedly in
    # 11.2: the single piece is the whole bounded interval.
    $is_bounded_interval(I)
    claim:
        ? forall J {I}:
            J $in power_set(R)
            $is_bounded_interval(J)
            J $subset I
        J = I
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset I
    claim:
        ? forall x I:
            exist J {I} st {J $in power_set(R), x $in J}
        witness exist J {I} st {J $in power_set(R), x $in J} from I:
            I $in {I}
            I $in power_set(R)
            x $in I
    claim:
        ? forall x I, J1, J2 {I}:
            J1 $in power_set(R)
            J2 $in power_set(R)
            x $in J1
            x $in J2
            =>:
                J1 = J2
        J1 = I
        J2 = I
        J1 = J2
    forall x I:
        exist! J {I} st {J $in power_set(R), x $in J}
    $is_partition_of_bounded_interval(I, {I})

prop is_strictly_left_of_interval(J, K power_set(R)):
    forall x J, y K:
        x < y

# Two nonempty disjoint intervals are linearly separated: every point of one
# lies strictly to one side of every point of the other.  This order-geometric
# fact is shared by endpoint-piece selection and interval-length splitting.
thm disjoint_nonempty_bounded_intervals_are_ordered:
    ? forall J, K power_set(R):
        $is_bounded_interval(J)
        $is_bounded_interval(K)
        $is_nonempty_set(J)
        $is_nonempty_set(K)
        intersect(J, K) = {}
        =>:
            $is_strictly_left_of_interval(J, K) or $is_strictly_left_of_interval(K, J)
    by thm bounded_intervals_are_bounded_connected(J)
    by thm bounded_intervals_are_bounded_connected(K)
    $is_connected_subset_of_R(J)
    $is_connected_subset_of_R(K)
    obtain j from exist j J st {j $in J}
    obtain k from exist k K st {k $in K}
    claim:
        ? j != k
        by contra:
            ? j != k
            j = k
            j $in J
            j $in K
            j $in intersect(J, K)
            intersect(J, K) = {}
            j $in {}
            impossible j $in {}

    claim:
        ? forall A, B power_set(R), a A, b B:
            $is_connected_subset_of_R(A)
            $is_connected_subset_of_R(B)
            intersect(A, B) = {}
            a < b
            =>:
                $is_strictly_left_of_interval(A, B)
        claim:
            ? forall x A, y B:
                x < y
            by contra:
                ? x < y
                x >= y
                y < a or y >= a
                by cases:
                    ? 1 = 0
                    case y < a:
                        x <= b or x > b
                        by cases:
                            ? 1 = 0
                            case x <= b:
                                y < a < b
                                y < b
                                '[y, b] $subset B
                                y <= x <= b
                                x $in '[y, b]
                                x $in B
                                x $in A
                                x $in intersect(A, B)
                                intersect(A, B) = {}
                                x $in {}
                                impossible x $in {}
                            case x > b:
                                a < b < x
                                a < x
                                '[a, x] $subset A
                                a <= b <= x
                                b $in '[a, x]
                                b $in A
                                b $in B
                                b $in intersect(A, B)
                                intersect(A, B) = {}
                                b $in {}
                                impossible b $in {}
                    case y >= a:
                        y = a or y > a
                        by cases:
                            ? 1 = 0
                            case y = a:
                                y $in A
                                y $in B
                                y $in intersect(A, B)
                                intersect(A, B) = {}
                                y $in {}
                                impossible y $in {}
                            case y > a:
                                a < y <= x
                                a < x
                                '[a, x] $subset A
                                y $in '[a, x]
                                y $in A
                                y $in B
                                y $in intersect(A, B)
                                intersect(A, B) = {}
                                y $in {}
                                impossible y $in {}
                impossible 1 = 0
        forall x A, y B:
            x < y
        $is_strictly_left_of_interval(A, B)

    j < k or k < j
    by cases:
        ? $is_strictly_left_of_interval(J, K) or $is_strictly_left_of_interval(K, J)
        case j < k:
            claim:
                ? $is_strictly_left_of_interval(J, K)
                $is_connected_subset_of_R(J)
                $is_connected_subset_of_R(K)
                intersect(J, K) = {}
                j < k
            $is_strictly_left_of_interval(J, K) or $is_strictly_left_of_interval(K, J)
        case k < j:
            intersect(K, J) = intersect(J, K) = {}
            claim:
                ? $is_strictly_left_of_interval(K, J)
                $is_connected_subset_of_R(K)
                $is_connected_subset_of_R(J)
                intersect(K, J) = {}
                k < j
            $is_strictly_left_of_interval(J, K) or $is_strictly_left_of_interval(K, J)

thm distinct_partition_pieces_are_disjoint:
    ? forall I power_set(R), P finite_set, J, K P:
        $is_partition_of_bounded_interval(I, P)
        J != K
        =>:
            intersect(J, K) = {}
    by extension intersect(J, K) = {}:
        claim:
            ? forall x intersect(J, K):
                x $in {}
            by contra:
                ? x $in {}
                x $in J
                x $in K
                exist! H P st {H $in power_set(R), x $in H}
                J = K
                impossible J != K
        claim:
            ? forall x {}:
                x $in intersect(J, K)
            by contra:
                ? x $in intersect(J, K)
                impossible x $in {}

thm strictly_left_of_intervals_transitive:
    ? forall I, J, K power_set(R):
        $is_nonempty_set(J)
        $is_strictly_left_of_interval(I, J)
        $is_strictly_left_of_interval(J, K)
        =>:
            $is_strictly_left_of_interval(I, K)
    obtain y from exist y J st {y $in J}
    claim:
        ? forall x I, z K:
            x < z
        x < y
        y < z
        x < z
    $is_strictly_left_of_interval(I, K)

prop is_pairwise_strictly_ordered_nonempty_interval_family(P finite_set):
    $is_nonempty_set(P)
    forall J P:
        J $in power_set(R)
        $is_nonempty_set(J)
    forall J, K P:
        J != K
        =>:
            $is_strictly_left_of_interval(J, K) or $is_strictly_left_of_interval(K, J)

prop has_only_nonempty_partition_pieces(P finite_set):
    forall J P:
        $is_nonempty_set(J)

prop has_empty_partition_piece(P finite_set):
    exist J P st {not $is_nonempty_set(J)}

prop is_leftmost_interval_in_family(J0 power_set(R), P finite_set):
    J0 $in P
    forall K P:
        K = J0 or $is_strictly_left_of_interval(J0, K)

# A finite nonempty family whose nonempty members are pairwise strictly
# ordered has a leftmost member.  The result is existential: no canonical
# enumeration or global choice function is introduced.
thm finite_pairwise_ordered_nonempty_intervals_have_leftmost:
    ? forall P finite_set:
        $is_pairwise_strictly_ordered_nonempty_interval_family(P)
        =>:
            exist J0 power_set(R) st {$is_leftmost_interval_in_family(J0, P)}
    prop has_leftmost_interval_in_finite_family(S finite_set):
        exist J0 power_set(R) st {$is_leftmost_interval_in_family(J0, S)}

    prop leftmost_exists_for_finite_interval_family(S finite_set):
        not $is_pairwise_strictly_ordered_nonempty_interval_family(S) or $has_leftmost_interval_in_finite_family(S)

    by induc P:
        ? $leftmost_exists_for_finite_interval_family(P)
        ? from P = {}:
            claim:
                ? not $is_pairwise_strictly_ordered_nonempty_interval_family({})
                by contra:
                    ? not $is_pairwise_strictly_ordered_nonempty_interval_family({})
                    by def $is_pairwise_strictly_ordered_nonempty_interval_family({})
                    impossible not $is_nonempty_set({})
            by def $leftmost_exists_for_finite_interval_family({})
        ? induc A, T:
            $leftmost_exists_for_finite_interval_family(T)
            $is_pairwise_strictly_ordered_nonempty_interval_family(union({A}, T)) or not $is_pairwise_strictly_ordered_nonempty_interval_family(union({A}, T))
            by cases:
                ? $leftmost_exists_for_finite_interval_family(union({A}, T))
                case not $is_pairwise_strictly_ordered_nonempty_interval_family(union({A}, T)):
                    by def $leftmost_exists_for_finite_interval_family(union({A}, T))
                case $is_pairwise_strictly_ordered_nonempty_interval_family(union({A}, T)):
                    by def $is_pairwise_strictly_ordered_nonempty_interval_family(union({A}, T))
                    claim:
                        ? $has_leftmost_interval_in_finite_family(union({A}, T))
                        $is_nonempty_set(T) or not $is_nonempty_set(T)
                        by cases:
                            ? exist J0 power_set(R) st {$is_leftmost_interval_in_family(J0, union({A}, T))}
                            case not $is_nonempty_set(T):
                                claim:
                                    ? T = {}
                                    by extension T = {}:
                                        claim:
                                            ? forall x T:
                                                x $in {}
                                            by contra:
                                                ? x $in {}
                                                witness $is_nonempty_set(T) from x
                                                impossible not $is_nonempty_set(T)
                                        claim:
                                            ? forall x {}:
                                                x $in T
                                            by contra:
                                                ? x $in T
                                                impossible x $in {}
                                witness exist J0 power_set(R) st {$is_leftmost_interval_in_family(J0, union({A}, T))} from A:
                                    by def $is_leftmost_interval_in_family(A, union({A}, T))
                                    A $in union({A}, T)
                                    claim:
                                        ? forall K union({A}, T):
                                            K = A or $is_strictly_left_of_interval(A, K)
                                        K $in {A} or K $in T
                                        by cases:
                                            ? K = A or $is_strictly_left_of_interval(A, K)
                                            case K $in {A}:
                                                K = A
                                            case K $in T:
                                                T = {}
                                                K $in {}
                                                impossible K $in {}
                            case $is_nonempty_set(T):
                                claim:
                                    ? $is_pairwise_strictly_ordered_nonempty_interval_family(T)
                                    $is_nonempty_set(T)
                                    claim:
                                        ? forall J T:
                                            J $in power_set(R)
                                            $is_nonempty_set(J)
                                        J $in union({A}, T)
                                        J $in power_set(R)
                                        $is_nonempty_set(J)
                                    claim:
                                        ? forall J, K T:
                                            J != K
                                            =>:
                                                $is_strictly_left_of_interval(J, K) or $is_strictly_left_of_interval(K, J)
                                        J $in union({A}, T)
                                        K $in union({A}, T)
                                        $is_strictly_left_of_interval(J, K) or $is_strictly_left_of_interval(K, J)
                                    by def $is_pairwise_strictly_ordered_nonempty_interval_family(T)
                                by def $leftmost_exists_for_finite_interval_family(T)
                                claim:
                                    ? $has_leftmost_interval_in_finite_family(T)
                                    by cases:
                                        ? $has_leftmost_interval_in_finite_family(T)
                                        case not $is_pairwise_strictly_ordered_nonempty_interval_family(T):
                                            by contra:
                                                ? $has_leftmost_interval_in_finite_family(T)
                                                impossible $is_pairwise_strictly_ordered_nonempty_interval_family(T)
                                        case $has_leftmost_interval_in_finite_family(T):
                                            $has_leftmost_interval_in_finite_family(T)
                                by def $has_leftmost_interval_in_finite_family(T)
                                obtain M from exist M power_set(R) st {$is_leftmost_interval_in_family(M, T)}
                                by def $is_leftmost_interval_in_family(M, T)
                                claim:
                                    ? A != M
                                    by contra:
                                        ? A != M
                                        A = M
                                        M $in T
                                        A $in T
                                        impossible not A $in T
                                A $in union({A}, T)
                                M $in union({A}, T)
                                $is_strictly_left_of_interval(A, M) or $is_strictly_left_of_interval(M, A)
                                by cases:
                                    ? exist J0 power_set(R) st {$is_leftmost_interval_in_family(J0, union({A}, T))}
                                    case $is_strictly_left_of_interval(A, M):
                                        witness exist J0 power_set(R) st {$is_leftmost_interval_in_family(J0, union({A}, T))} from A:
                                            by def $is_leftmost_interval_in_family(A, union({A}, T))
                                            A $in union({A}, T)
                                            claim:
                                                ? forall K union({A}, T):
                                                    K = A or $is_strictly_left_of_interval(A, K)
                                                K $in {A} or K $in T
                                                by cases:
                                                    ? K = A or $is_strictly_left_of_interval(A, K)
                                                    case K $in {A}:
                                                        K = A
                                                    case K $in T:
                                                        K = M or $is_strictly_left_of_interval(M, K)
                                                        by cases:
                                                            ? K = A or $is_strictly_left_of_interval(A, K)
                                                            case K = M:
                                                                $is_strictly_left_of_interval(A, K)
                                                            case $is_strictly_left_of_interval(M, K):
                                                                by thm strictly_left_of_intervals_transitive(A, M, K)
                                                                $is_strictly_left_of_interval(A, K)
                                    case $is_strictly_left_of_interval(M, A):
                                        witness exist J0 power_set(R) st {$is_leftmost_interval_in_family(J0, union({A}, T))} from M:
                                            by def $is_leftmost_interval_in_family(M, union({A}, T))
                                            M $in T
                                            M $in union({A}, T)
                                            claim:
                                                ? forall K union({A}, T):
                                                    K = M or $is_strictly_left_of_interval(M, K)
                                                K $in {A} or K $in T
                                                by cases:
                                                    ? K = M or $is_strictly_left_of_interval(M, K)
                                                    case K $in {A}:
                                                        K = A
                                                        $is_strictly_left_of_interval(M, K)
                                                    case K $in T:
                                                        K = M or $is_strictly_left_of_interval(M, K)
                        by def $has_leftmost_interval_in_finite_family(union({A}, T))
                    by def $leftmost_exists_for_finite_interval_family(union({A}, T))

    $leftmost_exists_for_finite_interval_family(P)
    by def $leftmost_exists_for_finite_interval_family(P)
    claim:
        ? $has_leftmost_interval_in_finite_family(P)
        by cases:
            ? $has_leftmost_interval_in_finite_family(P)
            case not $is_pairwise_strictly_ordered_nonempty_interval_family(P):
                by contra:
                    ? $has_leftmost_interval_in_finite_family(P)
                    impossible $is_pairwise_strictly_ordered_nonempty_interval_family(P)
            case $has_leftmost_interval_in_finite_family(P):
                $has_leftmost_interval_in_finite_family(P)
    by def $has_leftmost_interval_in_finite_family(P)
    exist J0 power_set(R) st {$is_leftmost_interval_in_family(J0, P)}

# Removing the leftmost nonempty piece preserves connectedness: if a point x
# remains, the partition piece containing x lies strictly to the right of the
# removed piece, so no point between x and a later remaining point was removed.
thm removing_leftmost_partition_piece_leaves_bounded_interval:
    ? forall I power_set(R), P finite_set, J0 P:
        $is_partition_of_bounded_interval(I, P)
        $is_nonempty_set(J0)
        forall K P:
            K = J0 or $is_strictly_left_of_interval(J0, K)
        =>:
            $is_bounded_interval(set_minus(I, J0))
    by thm chap9::real_set_operations_stay_in_power_set(I, J0)
    set_minus(I, J0) $in power_set(R)
    by thm bounded_intervals_are_bounded_connected(I)
    $chap9::is_bounded_real_set(I)
    $is_connected_subset_of_R(I)
    claim:
        ? set_minus(I, J0) $subset I
        forall x set_minus(I, J0):
            x $in I
        set_minus(I, J0) $subset I
    by thm chap9::bounded_real_set_subset(set_minus(I, J0), I)
    $chap9::is_bounded_real_set(set_minus(I, J0))
    claim:
        ? $is_connected_subset_of_R(set_minus(I, J0))
        claim:
            ? forall x, y set_minus(I, J0):
                x < y
                =>:
                    '[x, y] $subset set_minus(I, J0)
            x $in I
            y $in I
            not x $in J0
            '[x, y] $subset I
            by thm partition_is_set_of_real_subsets(I, P)
            P $in power_set(power_set(R))
            have K power_set(R) = partition_piece_containing(I, P, x)
            by thm partition_piece_containing_has_value(I, P, x)
            K $in P
            x $in K
            claim:
                ? K != J0
                by contra:
                    ? K != J0
                    K = J0
                    x $in J0
                    impossible not x $in J0
            K = J0 or $is_strictly_left_of_interval(J0, K)
            claim:
                ? $is_strictly_left_of_interval(J0, K)
                by cases:
                    ? $is_strictly_left_of_interval(J0, K)
                    case K = J0:
                        impossible K != J0
                    case $is_strictly_left_of_interval(J0, K):
                        $is_strictly_left_of_interval(J0, K)
            claim:
                ? '[x, y] $subset set_minus(I, J0)
                claim:
                    ? forall z '[x, y]:
                        z $in set_minus(I, J0)
                    z $in I
                    claim:
                        ? not z $in J0
                        by contra:
                            ? not z $in J0
                            z $in J0
                            z < x
                            x <= z
                            impossible z < x
                    z $in set_minus(I, J0)
                '[x, y] $subset set_minus(I, J0)
        $is_connected_subset_of_R(set_minus(I, J0))
    by thm bounded_connected_subsets_are_bounded_intervals(set_minus(I, J0))
    $is_bounded_interval(set_minus(I, J0))

# Every nonempty finite interval partition has a piece at one of the two ends.
# Removing such a piece leaves another bounded interval.  This is the geometric
# selection step in Tao's cardinality induction.
thm partition_has_removable_piece:
    ? forall I power_set(R), P finite_set:
        $is_partition_of_bounded_interval(I, P)
        $is_nonempty_set(P)
        =>:
            exist J P st {$is_bounded_interval(set_minus(I, J))}
    $has_only_nonempty_partition_pieces(P) or not $has_only_nonempty_partition_pieces(P)
    by cases:
        ? exist J P st {$is_bounded_interval(set_minus(I, J))}
        case $has_only_nonempty_partition_pieces(P):
            claim:
                ? $is_pairwise_strictly_ordered_nonempty_interval_family(P)
                $is_nonempty_set(P)
                claim:
                    ? forall J P:
                        J $in power_set(R)
                        $is_nonempty_set(J)
                    J $in power_set(R)
                    $is_nonempty_set(J)
                claim:
                    ? forall J, K P:
                        J != K
                        =>:
                            $is_strictly_left_of_interval(J, K) or $is_strictly_left_of_interval(K, J)
                    by thm distinct_partition_pieces_are_disjoint(I, P, J, K)
                    intersect(J, K) = {}
                    by thm disjoint_nonempty_bounded_intervals_are_ordered(J, K)
                    $is_strictly_left_of_interval(J, K) or $is_strictly_left_of_interval(K, J)
                by def $is_pairwise_strictly_ordered_nonempty_interval_family(P)
            by thm finite_pairwise_ordered_nonempty_intervals_have_leftmost(P)
            obtain J0 from exist J0 power_set(R) st {$is_leftmost_interval_in_family(J0, P)}
            by def $is_leftmost_interval_in_family(J0, P)
            $is_nonempty_set(J0)
            by thm removing_leftmost_partition_piece_leaves_bounded_interval(I, P, J0)
            witness exist J P st {$is_bounded_interval(set_minus(I, J))} from J0:
                $is_bounded_interval(set_minus(I, J0))
        case not $has_only_nonempty_partition_pieces(P):
            claim:
                ? $has_empty_partition_piece(P)
                $has_empty_partition_piece(P) or not $has_empty_partition_piece(P)
                by cases:
                    ? $has_empty_partition_piece(P)
                    case $has_empty_partition_piece(P):
                        $has_empty_partition_piece(P)
                    case not $has_empty_partition_piece(P):
                        claim:
                            ? forall J P:
                                $is_nonempty_set(J)
                            by contra:
                                ? $is_nonempty_set(J)
                                not $is_nonempty_set(J)
                                claim:
                                    ? $has_empty_partition_piece(P)
                                    witness exist K P st {not $is_nonempty_set(K)} from J:
                                        not $is_nonempty_set(J)
                                    by def $has_empty_partition_piece(P)
                                impossible $has_empty_partition_piece(P)
                        by def $has_only_nonempty_partition_pieces(P)
                        impossible not $has_only_nonempty_partition_pieces(P)
            by def $has_empty_partition_piece(P)
            obtain J0 from exist J P st {not $is_nonempty_set(J)}
            claim:
                ? J0 = {}
                by extension J0 = {}:
                    claim:
                        ? forall x J0:
                            x $in {}
                        by contra:
                            ? x $in {}
                            witness $is_nonempty_set(J0) from x
                            impossible not $is_nonempty_set(J0)
                    claim:
                        ? forall x {}:
                            x $in J0
                        by contra:
                            ? x $in J0
                            impossible x $in {}
            claim:
                ? set_minus(I, J0) = I
                by extension set_minus(I, J0) = I:
                    claim:
                        ? forall x set_minus(I, J0):
                            x $in I
                        x $in I
                    claim:
                        ? forall x I:
                            x $in set_minus(I, J0)
                        J0 = {}
                        not x $in J0
                        x $in set_minus(I, J0)
            $is_bounded_interval(set_minus(I, J0))
            witness exist J P st {$is_bounded_interval(set_minus(I, J))} from J0:
                $is_bounded_interval(set_minus(I, J0))

# Removing one partition piece leaves a partition of the set-theoretic
# remainder whenever that remainder is itself a bounded interval.  The
# endpoint argument that supplies this hypothesis belongs to finite length
# additivity, not to this finite-set bookkeeping theorem.
thm partition_removal_partitions_bounded_remainder:
    ? forall I power_set(R), P finite_set, J P:
        $is_partition_of_bounded_interval(I, P)
        $is_bounded_interval(set_minus(I, J))
        =>:
            $is_partition_of_bounded_interval(set_minus(I, J), set_minus(P, {J}))
    $is_finite_set(set_minus(P, {J}))
    claim:
        ? forall K set_minus(P, {J}):
            K $in power_set(R)
            $is_bounded_interval(K)
            K $subset set_minus(I, J)
        K $in P
        not K $in {J}
        K != J
        K $subset I
        claim:
            ? K $subset set_minus(I, J)
            claim:
                ? forall x K:
                    x $in set_minus(I, J)
                x $in I
                claim:
                    ? not x $in J
                    by contra:
                        ? not not x $in J
                        x $in J
                        exist! H P st {H $in power_set(R), x $in H}
                        J $in P
                        K = J
                        impossible K != J
                x $in set_minus(I, J)
            K $subset set_minus(I, J)
        K $in power_set(R)
        $is_bounded_interval(K)
        K $subset set_minus(I, J)
    claim:
        ? forall x set_minus(I, J):
            exist! K set_minus(P, {J}) st {K $in power_set(R), x $in K}
        x $in I
        not x $in J
        obtain K from exist K P st {K $in power_set(R), x $in K}
        claim:
            ? K != J
            by contra:
                ? K != J
                K = J
                x $in J
                impossible not x $in J
        K $in set_minus(P, {J})
        witness exist! K0 set_minus(P, {J}) st {K0 $in power_set(R), x $in K0} from K:
            K $in power_set(R)
            x $in K
            claim:
                ? forall K1, K2 set_minus(P, {J}):
                    K1 $in power_set(R)
                    K2 $in power_set(R)
                    x $in K1
                    x $in K2
                    =>:
                        K1 = K2
                K1 $in P
                K2 $in P
                exist! H P st {H $in power_set(R), x $in H}
                K1 = K2
    $is_partition_of_bounded_interval(set_minus(I, J), set_minus(P, {J}))

# The same endpoint geometry identifies the length of the ambient interval as
# the length of the removed endpoint piece plus the bounded remainder.
thm interval_length_adds_across_bounded_difference:
    ? forall I, J power_set(R):
        $is_bounded_interval(I)
        $is_bounded_interval(J)
        J $subset I
        $is_bounded_interval(set_minus(I, J))
        =>:
            interval_length(I) = interval_length(J) + interval_length(set_minus(I, J))
    # Source handling: the proof of Theorem 11.1.13 uses this length split but
    # leaves the compatible open/closed endpoint cases implicit.  The trust
    # keeps that compressed source step visible.
    # proof_debt: classify the endpoint forms of I and J and reduce each
    # possible bounded-remainder case to subtraction of their endpoints.
    trust interval_length(I) = interval_length(J) + interval_length(set_minus(I, J))

"""
Remark 11.1.11.  A partition is a finite set whose elements are intervals, so
it is a set of sets.
"""

"""
Examples 11.1.12.  A valid partition covers every point exactly once; overlaps,
missing points, and pieces that leave the ambient interval invalidate the
partition.
"""

thm example_11_1_12_touching_closed_pieces_distinct:
    ? forall:
        '[0, 1] != '[1, 2]
    by contra:
        ? '[0, 1] != '[1, 2]
        '[0, 1] = '[1, 2]
        0 $in '[0, 1]
        0 $in '[1, 2]
        impossible 1 <= 0

thm example_11_1_12_gap_pieces_distinct:
    ? forall:
        '[0, 1] != '[2, 3]
    by contra:
        ? '[0, 1] != '[2, 3]
        '[0, 1] = '[2, 3]
        0 $in '[0, 1]
        0 $in '[2, 3]
        impossible 2 <= 0

thm example_11_1_12_outside_pieces_distinct:
    ? forall:
        '[0, 1] != '[2, 4]
    by contra:
        ? '[0, 1] != '[2, 4]
        '[0, 1] = '[2, 4]
        0 $in '[0, 1]
        0 $in '[2, 4]
        impossible 2 <= 0

thm example_11_1_12_valid_one_piece_partition:
    ? forall:
        $is_partition_of_bounded_interval('[0, 1], {'[0, 1]})
    by thm non_degenerate_interval_forms_are_bounded_intervals(0, 1)
    by thm one_piece_partition_of_bounded_interval('[0, 1])

thm example_11_1_12_overlap_breaks_uniqueness:
    ? forall:
        not $is_partition_of_bounded_interval('[0, 2], {'[0, 1], '[1, 2]})
    by contra:
        ? not $is_partition_of_bounded_interval('[0, 2], {'[0, 1], '[1, 2]})
        $is_partition_of_bounded_interval('[0, 2], {'[0, 1], '[1, 2]})
        1 $in '[0, 2]
        exist! J {'[0, 1], '[1, 2]} st {J $in power_set(R), 1 $in J}
        '[0, 1] $in {'[0, 1], '[1, 2]}
        '[1, 2] $in {'[0, 1], '[1, 2]}
        '[0, 1] $subset R
        '[0, 1] $in power_set(R)
        '[1, 2] $subset R
        '[1, 2] $in power_set(R)
        1 $in '[0, 1]
        1 $in '[1, 2]
        '[0, 1] = '[1, 2]
        impossible '[0, 1] != '[1, 2]

thm example_11_1_12_gap_breaks_existence:
    ? forall:
        not $is_partition_of_bounded_interval('[0, 3], {'[0, 1], '[2, 3]})
    by contra:
        ? not $is_partition_of_bounded_interval('[0, 3], {'[0, 1], '[2, 3]})
        $is_partition_of_bounded_interval('[0, 3], {'[0, 1], '[2, 3]})
        3 / 2 $in '[0, 3]
        exist! J {'[0, 1], '[2, 3]} st {J $in power_set(R), 3 / 2 $in J}
        obtain J from exist J {'[0, 1], '[2, 3]} st {J $in power_set(R), 3 / 2 $in J}
        J = '[0, 1] or J = '[2, 3]
        by cases:
            ? 1 = 0
            case J = '[0, 1]:
                3 / 2 $in '[0, 1]
                3 / 2 <= 1
                1 < 3 / 2
                impossible 3 / 2 <= 1
            case J = '[2, 3]:
                3 / 2 $in '[2, 3]
                2 <= 3 / 2
                3 / 2 < 2
                impossible 2 <= 3 / 2
        impossible 1 = 0

thm example_11_1_12_outside_piece_breaks_containment:
    ? forall:
        not $is_partition_of_bounded_interval('[0, 3], {'[0, 1], '[2, 4]})
    by contra:
        ? not $is_partition_of_bounded_interval('[0, 3], {'[0, 1], '[2, 4]})
        $is_partition_of_bounded_interval('[0, 3], {'[0, 1], '[2, 4]})
        '[2, 4] $in {'[0, 1], '[2, 4]}
        '[2, 4] $subset '[0, 3]
        4 $in '[2, 4]
        4 $in '[0, 3]
        4 <= 3
        3 < 4
        impossible 4 <= 3

thm empty_interval_length_value:
    ? forall:
        interval_length({}) = 0
    by thm empty_interval_is_bounded()
    $has_interval_length({}, interval_length({}))
    by thm empty_interval_has_length_zero()
    by thm interval_length_value_unique({}, interval_length({}), 0)
    interval_length({}) = 0

thm empty_bounded_interval_length_value:
    ? forall J power_set(R):
        $is_bounded_interval(J)
        not $is_nonempty_set(J)
        =>:
            interval_length(J) = 0
    by extension J = {}:
        claim:
            ? forall x J:
                x $in {}
            by contra:
                ? x $in {}
                x $in J
                not $is_nonempty_set(J)
                witness $is_nonempty_set(J) from x
                impossible $is_nonempty_set(J)
        claim:
            ? forall x {}:
                x $in J
            by contra:
                ? x $in J
                x $in {}
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from x
                impossible $is_nonempty_set({})
    by thm empty_interval_length_value()
    interval_length(J) = interval_length({}) = 0

thm singleton_interval_length_value:
    ? forall a R:
        interval_length({a}) = 0
    by thm singleton_interval_is_bounded(a)
    $has_interval_length({a}, interval_length({a}))
    by thm singleton_interval_has_length_zero(a)
    by thm interval_length_value_unique({a}, interval_length({a}), 0)
    interval_length({a}) = 0

thm interval_endpoint_forms_length_value:
    ? forall a, b R:
        interval_length('[a, b]) = finite_set_max(union({b - a}, { 0}))
        interval_length('[a, b)) = finite_set_max(union({b - a}, { 0}))
        interval_length('(a, b]) = finite_set_max(union({b - a}, { 0}))
        interval_length('(a, b)) = finite_set_max(union({b - a}, { 0}))
    by thm interval_endpoint_forms_are_bounded_intervals(a, b)
    by thm interval_endpoint_forms_have_total_length(a, b)
    $has_interval_length('[a, b], interval_length('[a, b]))
    $has_interval_length('[a, b], finite_set_max(union({b - a}, { 0})))
    by thm interval_length_value_unique('[a, b], interval_length('[a, b]), finite_set_max(union({b - a}, { 0})))
    $has_interval_length('[a, b), interval_length('[a, b)))
    $has_interval_length('[a, b), finite_set_max(union({b - a}, { 0})))
    by thm interval_length_value_unique('[a, b), interval_length('[a, b)), finite_set_max(union({b - a}, { 0})))
    $has_interval_length('(a, b], interval_length('(a, b]))
    $has_interval_length('(a, b], finite_set_max(union({b - a}, { 0})))
    by thm interval_length_value_unique('(a, b], interval_length('(a, b]), finite_set_max(union({b - a}, { 0})))
    $has_interval_length('(a, b), interval_length('(a, b)))
    $has_interval_length('(a, b), finite_set_max(union({b - a}, { 0})))
    by thm interval_length_value_unique('(a, b), interval_length('(a, b)), finite_set_max(union({b - a}, { 0})))

thm interval_endpoint_forms_zero_length_value_when_nonpositive:
    ? forall a, b R:
        b <= a
        =>:
            interval_length('[a, b]) = 0
            interval_length('[a, b)) = 0
            interval_length('(a, b]) = 0
            interval_length('(a, b)) = 0
    by thm interval_endpoint_forms_are_bounded_intervals(a, b)
    by thm interval_endpoint_forms_have_zero_length_when_nonpositive(a, b)
    $has_interval_length('[a, b], interval_length('[a, b]))
    $has_interval_length('[a, b], 0)
    by thm interval_length_value_unique('[a, b], interval_length('[a, b]), 0)
    $has_interval_length('[a, b), interval_length('[a, b)))
    $has_interval_length('[a, b), 0)
    by thm interval_length_value_unique('[a, b), interval_length('[a, b)), 0)
    $has_interval_length('(a, b], interval_length('(a, b]))
    $has_interval_length('(a, b], 0)
    by thm interval_length_value_unique('(a, b], interval_length('(a, b]), 0)
    $has_interval_length('(a, b), interval_length('(a, b)))
    $has_interval_length('(a, b), 0)
    by thm interval_length_value_unique('(a, b), interval_length('(a, b)), 0)

thm endpoint_interval_length_degenerate_examples:
    ? forall:
        interval_length('[5, 5]) = 0
        interval_length('(0, 0)) = 0
        interval_length('[5, 3]) = 0
        interval_length('[3, 3)) = 0
    by thm interval_endpoint_forms_zero_length_value_when_nonpositive(5, 5)
    by thm interval_endpoint_forms_zero_length_value_when_nonpositive(0, 0)
    by thm interval_endpoint_forms_zero_length_value_when_nonpositive(5, 3)
    by thm interval_endpoint_forms_zero_length_value_when_nonpositive(3, 3)

thm non_degenerate_interval_forms_length_value:
    ? forall a, b R:
        a < b
        =>:
            interval_length('[a, b]) = b - a
            interval_length('[a, b)) = b - a
            interval_length('(a, b]) = b - a
            interval_length('(a, b)) = b - a
    by thm non_degenerate_interval_forms_are_bounded_intervals(a, b)
    by thm non_degenerate_interval_forms_have_length(a, b)
    $has_interval_length('[a, b], interval_length('[a, b]))
    $has_interval_length('[a, b], b - a)
    by thm interval_length_value_unique('[a, b], interval_length('[a, b]), b - a)
    $has_interval_length('[a, b), interval_length('[a, b)))
    $has_interval_length('[a, b), b - a)
    by thm interval_length_value_unique('[a, b), interval_length('[a, b)), b - a)
    $has_interval_length('(a, b], interval_length('(a, b]))
    $has_interval_length('(a, b], b - a)
    by thm interval_length_value_unique('(a, b], interval_length('(a, b]), b - a)
    $has_interval_length('(a, b), interval_length('(a, b)))
    $has_interval_length('(a, b), b - a)
    by thm interval_length_value_unique('(a, b), interval_length('(a, b)), b - a)

thm interval_length_adds_for_adjacent_closed_split:
    ? forall a, b, c R:
        a < b
        b < c
        a < c
        =>:
            interval_length('[a, c]) = interval_length('[a, b)) + interval_length('[b, c])
    a < b < c
    a < c
    by thm non_degenerate_interval_forms_length_value(a, c)
    by thm non_degenerate_interval_forms_length_value(a, b)
    by thm non_degenerate_interval_forms_length_value(b, c)
    interval_length('[a, c]) = c - a
    interval_length('[a, b)) = b - a
    interval_length('[b, c]) = c - b
    c - a = (b - a) + (c - b)
    interval_length('[a, c]) = interval_length('[a, b)) + interval_length('[b, c])

thm adjacent_left_open_right_closed_pieces_distinct:
    ? forall a, b, c R:
        a < b
        b < c
        =>:
            '[a, b) != '[b, c]
    by contra:
        ? '[a, b) != '[b, c]
        '[a, b) = '[b, c]
        b $in '[b, c]
        b $in '[a, b)
        b < b
        impossible b < b

thm finite_set_sum_two_interval_lengths_expands:
    ? forall A, B power_set(R):
        A != B
        $is_bounded_interval(A)
        $is_bounded_interval(B)
        =>:
            finite_set_sum({A, B}, fn(J power_set(R): $is_bounded_interval(J)) R {interval_length(J)}) = interval_length(A) + interval_length(B)

thm interval_length_two_piece_adjacent_closed_split_sum:
    ? forall a, b, c R:
        a < b
        b < c
        =>:
            interval_length('[a, c]) = finite_set_sum({'[a, b), '[b, c]}, fn(J power_set(R): $is_bounded_interval(J)) R {interval_length(J)})
    a < b < c
    a < c
    by thm interval_length_adds_for_adjacent_closed_split(a, b, c)
    by thm adjacent_left_open_right_closed_pieces_distinct(a, b, c)
    by thm non_degenerate_interval_forms_are_bounded_intervals(a, b)
    by thm non_degenerate_interval_forms_are_bounded_intervals(b, c)
    by thm finite_set_sum_two_interval_lengths_expands('[a, b), '[b, c])
    finite_set_sum({'[a, b), '[b, c]}, fn(J power_set(R): $is_bounded_interval(J)) R {interval_length(J)}) = interval_length('[a, b)) + interval_length('[b, c])
    interval_length('[a, c]) = interval_length('[a, b)) + interval_length('[b, c])
    interval_length('[a, c]) = finite_set_sum({'[a, b), '[b, c]}, fn(J power_set(R): $is_bounded_interval(J)) R {interval_length(J)})

# This is the reusable finite-regrouping core of Tao's endpoint-piece
# induction.  A weight on bounded intervals that vanishes on the empty set and
# splits across every removable endpoint piece sums over every finite interval
# partition.
thm interval_weight_is_finitely_additive_over_partition:
    ? forall w fn(J power_set(R): $is_bounded_interval(J)) R, I power_set(R), P finite_set:
        w({}) = 0
        forall I0, J0 power_set(R):
            $is_bounded_interval(I0)
            $is_bounded_interval(J0)
            J0 $subset I0
            $is_bounded_interval(set_minus(I0, J0))
            =>:
                w(I0) = w(J0) + w(set_minus(I0, J0))
        $is_partition_of_bounded_interval(I, P)
        =>:
            w(I) = finite_set_sum(P, fn(J P) R {w(J)})
    prop interval_weight_additivity_at_partition_size(n N):
        forall I0 power_set(R), P0 finite_set:
            finite_set_size(P0) = n
            $is_partition_of_bounded_interval(I0, P0)
            =>:
                w(I0) = finite_set_sum(P0, fn(J0 P0) R {w(J0)})

    claim:
        ? $interval_weight_additivity_at_partition_size(0)
        forall I0 power_set(R), P0 finite_set:
            finite_set_size(P0) = 0
            $is_partition_of_bounded_interval(I0, P0)
            =>:
                w(I0) = finite_set_sum(P0, fn(J0 P0) R {w(J0)})
        P0 = {}
        claim:
            ? I0 = {}
            by extension I0 = {}:
                claim:
                    ? forall x I0:
                        x $in {}
                    by contra:
                        ? x $in {}
                        obtain J0 from exist J0 P0 st {J0 $in power_set(R), x $in J0}
                        J0 $in P0
                        P0 = {}
                        J0 $in {}
                        impossible J0 $in {}
                claim:
                    ? forall x {}:
                        x $in I0
                    by contra:
                        ? x $in I0
                        impossible x $in {}
        by thm chap7::finite_set_sum_empty(fn(J0 {}) R {w(J0)})
        w(I0) = w({}) = 0
        finite_set_sum(P0, fn(J0 P0) R {w(J0)}) = finite_set_sum({}, fn(J0 {}) R {w(J0)}) = 0
        w(I0) = finite_set_sum(P0, fn(J0 P0) R {w(J0)})

    claim:
        ? forall n N:
            forall y N:
                y <= n
                =>:
                    $interval_weight_additivity_at_partition_size(y)
            =>:
                $interval_weight_additivity_at_partition_size(n + 1)
        claim:
            ? forall I0 power_set(R), P0 finite_set:
                finite_set_size(P0) = n + 1
                $is_partition_of_bounded_interval(I0, P0)
                =>:
                    w(I0) = finite_set_sum(P0, fn(J0 P0) R {w(J0)})
            finite_set_size(P0) = n + 1 >= 1
            $is_nonempty_set(P0)
            by thm partition_has_removable_piece(I0, P0)
            obtain J0 from exist J0 P0 st {$is_bounded_interval(set_minus(I0, J0))}
            have P1 finite_set = set_minus(P0, {J0})
            by thm partition_removal_partitions_bounded_remainder(I0, P0, J0)
            $is_partition_of_bounded_interval(set_minus(I0, J0), P1)
            {J0} $subset P0
            finite_set_size(P1) = finite_set_size(set_minus(P0, {J0})) = finite_set_size(P0) - finite_set_size({J0}) = (n + 1) - 1 = n
            n <= n
            $interval_weight_additivity_at_partition_size(n)
            w(set_minus(I0, J0)) = finite_set_sum(P1, fn(K P1) R {w(K)})
            w(I0) = w(J0) + w(set_minus(I0, J0))
            claim:
                ? P0 = union({J0}, P1)
                by extension P0 = union({J0}, P1):
                    claim:
                        ? forall K P0:
                            K $in union({J0}, P1)
                        K = J0 or K != J0
                        by cases:
                            ? K $in union({J0}, P1)
                            case K = J0:
                                K $in {J0}
                                K $in union({J0}, P1)
                            case K != J0:
                                not K $in {J0}
                                K $in set_minus(P0, {J0})
                                K $in P1
                                K $in union({J0}, P1)
                    claim:
                        ? forall K union({J0}, P1):
                            K $in P0
                        K $in {J0} or K $in P1
                        by cases:
                            ? K $in P0
                            case K $in {J0}:
                                K = J0
                                J0 $in P0
                                K $in P0
                            case K $in P1:
                                K $in set_minus(P0, {J0})
                                K $in P0
            claim:
                ? intersect({J0}, P1) = {}
                by extension intersect({J0}, P1) = {}:
                    claim:
                        ? forall K intersect({J0}, P1):
                            K $in {}
                        by contra:
                            ? K $in {}
                            K $in {J0}
                            K = J0
                            K $in P1
                            K $in set_minus(P0, {J0})
                            not K $in {J0}
                            impossible not K $in {J0}
                    claim:
                        ? forall K {}:
                            K $in intersect({J0}, P1)
                        by contra:
                            ? K $in intersect({J0}, P1)
                            impossible K $in {}
            by thm chap7::finite_set_sum_disjoint_union({J0}, P1, fn(K union({J0}, P1)) R {w(K)})
            finite_set_sum(union({J0}, P1), fn(K union({J0}, P1)) R {w(K)}) = finite_set_sum({J0}, fn(K {J0}) R {w(K)}) + finite_set_sum(P1, fn(K P1) R {w(K)})
            by thm chap7::finite_set_sum_singleton(J0, fn(K {J0}) R {w(K)})
            finite_set_sum({J0}, fn(K {J0}) R {w(K)}) = w(J0)
            finite_set_sum(P0, fn(K P0) R {w(K)}) = w(J0) + finite_set_sum(P1, fn(K P1) R {w(K)})
            w(I0) = w(J0) + w(set_minus(I0, J0)) = w(J0) + finite_set_sum(P1, fn(K P1) R {w(K)}) = finite_set_sum(P0, fn(K P0) R {w(K)})
        $interval_weight_additivity_at_partition_size(n + 1)

    claim:
        ? forall n N:
            $interval_weight_additivity_at_partition_size(n)
        by strong_induc n from 0:
            ? $interval_weight_additivity_at_partition_size(n)
            ? from n = 0:
                $interval_weight_additivity_at_partition_size(0)
            ? strong_induc:
                $interval_weight_additivity_at_partition_size(n + 1)

    finite_set_size(P) $in N
    $interval_weight_additivity_at_partition_size(finite_set_size(P))
    w(I) = finite_set_sum(P, fn(J P) R {w(J)})

"""
Theorem 11.1.13 (Length is finitely additive).  If `P` partitions a bounded
interval `I`, the length of `I` is the finite sum of the lengths of the pieces.
"""

thm interval_length_is_finitely_additive_over_partition:
    ? forall I power_set(R), P finite_set:
        $is_partition_of_bounded_interval(I, P)
        =>:
            interval_length(I) = finite_set_sum(P, fn(J P) R {interval_length(J)})
    by thm empty_interval_length_value()
    claim:
        ? forall I0, J0 power_set(R):
            $is_bounded_interval(I0)
            $is_bounded_interval(J0)
            J0 $subset I0
            $is_bounded_interval(set_minus(I0, J0))
            =>:
                interval_length(I0) = interval_length(J0) + interval_length(set_minus(I0, J0))
        by thm interval_length_adds_across_bounded_difference(I0, J0)
    by thm interval_weight_is_finitely_additive_over_partition(fn(J power_set(R): $is_bounded_interval(J)) R {interval_length(J)}, I, P)
    interval_length(I) = finite_set_sum(P, fn(J P) R {interval_length(J)})

"""
Definition 11.1.14 (Finer and coarser partitions).  A partition `P2` is finer
than `P1` when every piece of `P2` is contained in some piece of `P1`.
"""

prop is_finer_partition_than(I power_set(R), P2, P1 finite_set):
    $is_partition_of_bounded_interval(I, P2)
    $is_partition_of_bounded_interval(I, P1)
    forall J P2:
        exist K P1 st {J $in power_set(R), K $in power_set(R), J $subset K}

"""
Example 11.1.15.  Splitting `[1,4]` into `[1,2)`, `{2}`, `(2,3)`, and
`[3,4]` gives a partition finer than `{[1,2],(2,4]}`.  There is no finest
finite partition of `[1,4]`.
"""

# The concrete refinement check is the four piece-containment computations.
# The no-finest assertion is the general observation that any non-degenerate
# finite partition can be split again.

thm example_11_1_15_refinement_piece_containments:
    ? forall:
        '[1, 2) $subset '[1, 2]
        {2} $subset '[1, 2]
        '(2, 3) $subset '(2, 4]
        '[3, 4] $subset '(2, 4]
    claim:
        ? '[1, 2) $subset '[1, 2]
        forall x '[1, 2):
            1 <= x
            x < 2
            x <= 2
            x $in '[1, 2]
        '[1, 2) $subset '[1, 2]
    claim:
        ? {2} $subset '[1, 2]
        forall x {2}:
            x = 2
            1 <= x
            x <= 2
            x $in '[1, 2]
        {2} $subset '[1, 2]
    claim:
        ? '(2, 3) $subset '(2, 4]
        forall x '(2, 3):
            2 < x
            x < 3
            x <= 3 < 4
            x <= 4
            x $in '(2, 4]
        '(2, 3) $subset '(2, 4]
    claim:
        ? '[3, 4] $subset '(2, 4]
        forall x '[3, 4]:
            3 <= x
            2 < 3 <= x
            2 < x
            x <= 4
            x $in '(2, 4]
        '[3, 4] $subset '(2, 4]

thm example_11_1_15_membership_pattern_is_finer:
    ? forall Pfine, Pcoarse finite_set:
        $is_partition_of_bounded_interval('[1, 4], Pfine)
        $is_partition_of_bounded_interval('[1, 4], Pcoarse)
        forall J Pfine:
            J = '[1, 2) or J = {2} or J = '(2, 3) or J = '[3, 4]
        '[1, 2] $in Pcoarse
        '(2, 4] $in Pcoarse
        =>:
            $is_finer_partition_than('[1, 4], Pfine, Pcoarse)
    # Source handling: once the displayed families are known to be partitions,
    # Definition 11.1.14 reduces the refinement check to the four containments
    # above.
    by thm example_11_1_15_refinement_piece_containments()
    claim:
        ? forall J Pfine:
            exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K}
        J = '[1, 2) or J = {2} or J = '(2, 3) or J = '[3, 4]
        J $in power_set(R)
        '[1, 2] $in power_set(R)
        '(2, 4] $in power_set(R)
        by cases:
            ? exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K}
            case J = '[1, 2):
                witness exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K} from '[1, 2]:
                    J $in power_set(R)
                    '[1, 2] $in power_set(R)
                    J $subset '[1, 2]
            case J = {2}:
                witness exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K} from '[1, 2]:
                    J $in power_set(R)
                    '[1, 2] $in power_set(R)
                    J $subset '[1, 2]
            case J = '(2, 3):
                witness exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K} from '(2, 4]:
                    J $in power_set(R)
                    '(2, 4] $in power_set(R)
                    J $subset '(2, 4]
            case J = '[3, 4]:
                witness exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K} from '(2, 4]:
                    J $in power_set(R)
                    '(2, 4] $in power_set(R)
                    J $subset '(2, 4]
    $is_finer_partition_than('[1, 4], Pfine, Pcoarse)

"""
Definition 11.1.16 (Common refinement).  The common refinement `P#Q` consists
of all intersections `J intersect K` with `J in P` and `K in Q`.
"""

prop is_common_refinement_of_partitions(I power_set(R), P, Qpart, Rf finite_set):
    $is_partition_of_bounded_interval(I, P)
    $is_partition_of_bounded_interval(I, Qpart)
    $is_partition_of_bounded_interval(I, Rf)
    forall H Rf:
        exist J P, K Qpart st {J $in power_set(R), K $in power_set(R), H = intersect(J, K)}
    forall J P, K Qpart:
        J $in power_set(R)
        K $in power_set(R)
        =>:
            exist H Rf st {H = intersect(J, K)}

"""
Example 11.1.17.  Intersecting the pieces of `{[1,3),[3,4]}` with the pieces
of `{[1,2],(2,4]}` gives `{[1,2],(2,3),[3,4],empty}`.
"""

thm example_11_1_17_common_refinement_intersections:
    ? forall:
        intersect('[1, 3), '[1, 2]) = '[1, 2]
        intersect('[1, 3), '(2, 4]) = '(2, 3)
        intersect('[3, 4], '[1, 2]) = {}
        intersect('[3, 4], '(2, 4]) = '[3, 4]
    # Source handling: this is the direct endpoint calculation behind the
    # displayed common-refinement family.
    by extension intersect('[1, 3), '[1, 2]) = '[1, 2]:
        forall z intersect('[1, 3), '[1, 2]):
            z $in '[1, 3)
            z $in '[1, 2]
            z $in '[1, 2]
        forall z '[1, 2]:
            1 <= z
            z <= 2
            2 < 3
            z <= 2 < 3
            z < 3
            z $in '[1, 3)
            z $in '[1, 2]
            z $in intersect('[1, 3), '[1, 2])
    by extension intersect('[1, 3), '(2, 4]) = '(2, 3):
        forall z intersect('[1, 3), '(2, 4]):
            z $in '[1, 3)
            z $in '(2, 4]
            2 < z
            z < 3
            z $in '(2, 3)
        forall z '(2, 3):
            2 < z
            z < 3
            1 < 2 < z
            1 < z
            1 <= z
            z < 3 < 4
            z < 4
            z <= 4
            z $in '[1, 3)
            z $in '(2, 4]
            z $in intersect('[1, 3), '(2, 4])
    by extension intersect('[3, 4], '[1, 2]) = {}:
        claim:
            ? forall z intersect('[3, 4], '[1, 2]):
                z $in {}
            z $in '[3, 4]
            z $in '[1, 2]
            3 <= z
            z <= 2
            2 < 3 <= z
            2 < z
            by contra:
                ? z $in {}
                not z $in {}
                impossible z <= 2
        claim:
            ? forall z {}:
                z $in intersect('[3, 4], '[1, 2])
            by contra:
                ? z $in intersect('[3, 4], '[1, 2])
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from z
                impossible $is_nonempty_set({})
    by extension intersect('[3, 4], '(2, 4]) = '[3, 4]:
        forall z intersect('[3, 4], '(2, 4]):
            z $in '[3, 4]
            z $in '[3, 4]
        forall z '[3, 4]:
            3 <= z
            z <= 4
            2 < 3 <= z
            2 < z
            z $in '(2, 4]
            z $in '[3, 4]
            z $in intersect('[3, 4], '(2, 4])

"""
Lemma 11.1.18.  The common refinement of two partitions of `I` is a partition
of `I`, and it is finer than both original partitions.
"""

thm common_refinement_is_partition_and_finer:
    ? forall I power_set(R), P, Qpart, Rf finite_set:
        $is_common_refinement_of_partitions(I, P, Qpart, Rf)
        =>:
            $is_partition_of_bounded_interval(I, Rf)
            $is_finer_partition_than(I, Rf, P)
            $is_finer_partition_than(I, Rf, Qpart)
    # Source handling: Tao proves this in Exercise 11.1.4.
    $is_partition_of_bounded_interval(I, P)
    $is_partition_of_bounded_interval(I, Qpart)
    $is_partition_of_bounded_interval(I, Rf)
    claim:
        ? forall H Rf:
            exist K P st {H $in power_set(R), K $in power_set(R), H $subset K}
        obtain J, K from exist J P, K Qpart st {J $in power_set(R), K $in power_set(R), H = intersect(J, K)}
        claim:
            ? H $subset J
            forall x H:
                x $in intersect(J, K)
                x $in J
            H $subset J
        witness exist K0 P st {H $in power_set(R), K0 $in power_set(R), H $subset K0} from J:
            H $in power_set(R)
            J $in power_set(R)
            H $subset J
    $is_finer_partition_than(I, Rf, P)
    claim:
        ? forall H Rf:
            exist K Qpart st {H $in power_set(R), K $in power_set(R), H $subset K}
        obtain J, K from exist J P, K Qpart st {J $in power_set(R), K $in power_set(R), H = intersect(J, K)}
        claim:
            ? H $subset K
            forall x H:
                x $in intersect(J, K)
                x $in K
            H $subset K
        witness exist K0 Qpart st {H $in power_set(R), K0 $in power_set(R), H $subset K0} from K:
            H $in power_set(R)
            K $in power_set(R)
            H $subset K
    $is_finer_partition_than(I, Rf, Qpart)

thm intersection_image_of_two_partition_families_is_finite:
    ? forall I power_set(R), P, Qpart finite_set:
        $is_partition_of_bounded_interval(I, P)
        $is_partition_of_bounded_interval(I, Qpart)
        =>:
            $is_finite_set(fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}))
    # Source handling: this constructs the finite family underlying Tao's
    # common refinement, before proving that it covers I exactly once.
    $is_partition_of_bounded_interval(I, P)
    $is_partition_of_bounded_interval(I, Qpart)
    forall p cart(P, Qpart):
        p[1] $in P
        p[2] $in Qpart
        p[1] $in power_set(R)
        p[2] $in power_set(R)
        p[1] $subset R
        intersect(p[1], p[2]) $subset p[1]
        intersect(p[1], p[2]) $subset R
        intersect(p[1], p[2]) $in power_set(R)
    $is_finite_set(fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}))

thm intersection_image_of_two_partition_families_is_partition:
    ? forall I power_set(R), P, Qpart finite_set:
        $is_partition_of_bounded_interval(I, P)
        $is_partition_of_bounded_interval(I, Qpart)
        =>:
            $is_partition_of_bounded_interval(I, fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}))
    # Source handling: each point lies in one piece of P and one piece of
    # Qpart; their intersection gives the unique common-refinement piece.
    $is_partition_of_bounded_interval(I, P)
    $is_partition_of_bounded_interval(I, Qpart)
    $is_bounded_interval(I)
    claim:
        ? forall H fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}):
            H $in power_set(R)
            $is_bounded_interval(H)
            H $subset I
        have by preimage p from H $in fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])})
        p[1] $in P
        p[2] $in Qpart
        p[1] $in power_set(R)
        p[2] $in power_set(R)
        H = intersect(p[1], p[2])
        $is_bounded_interval(p[1])
        $is_bounded_interval(p[2])
        by thm intersection_of_bounded_intervals_is_bounded_interval(p[1], p[2])
        $is_bounded_interval(H)
        intersect(p[1], p[2]) $subset p[1]
        p[1] $subset I
        H $subset p[1]
        H $subset I
        H $in power_set(R)
    claim:
        ? forall x I:
            exist H fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}) st {H $in power_set(R), x $in H}
        obtain J from exist J P st {J $in power_set(R), x $in J}
        obtain K from exist K Qpart st {K $in power_set(R), x $in K}
        J $in power_set(R)
        K $in power_set(R)
        J $subset R
        intersect(J, K) $subset J
        intersect(J, K) $subset R
        (J, K) $in cart(P, Qpart)
        intersect(J, K) $in power_set(R)
        fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}((J, K)) = intersect(J, K)
        fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}((J, K)) $in fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])})
        intersect(J, K) $in fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])})
        witness exist H fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}) st {H $in power_set(R), x $in H} from intersect(J, K):
            intersect(J, K) $in power_set(R)
            x $in J
            x $in K
            x $in intersect(J, K)
    claim:
        ? forall x I, H1, H2 fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}):
            H1 $in power_set(R)
            H2 $in power_set(R)
            x $in H1
            x $in H2
            =>:
                H1 = H2
        have by preimage p1 from H1 $in fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])})
        have by preimage p2 from H2 $in fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])})
        p1[1] $in P
        p1[2] $in Qpart
        p2[1] $in P
        p2[2] $in Qpart
        p1[1] $in power_set(R)
        p1[2] $in power_set(R)
        p2[1] $in power_set(R)
        p2[2] $in power_set(R)
        H1 = intersect(p1[1], p1[2])
        H2 = intersect(p2[1], p2[2])
        x $in intersect(p1[1], p1[2])
        x $in intersect(p2[1], p2[2])
        x $in p1[1]
        x $in p1[2]
        x $in p2[1]
        x $in p2[2]
        exist! J P st {J $in power_set(R), x $in J}
        exist! K Qpart st {K $in power_set(R), x $in K}
        p1[1] = p2[1]
        p1[2] = p2[2]
        H1 = intersect(p1[1], p1[2]) = intersect(p2[1], p2[2]) = H2
    forall x I:
        exist! H fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}) st {H $in power_set(R), x $in H}
    $is_partition_of_bounded_interval(I, fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}))

thm common_refinement_exists_for_partitions:
    ? forall I power_set(R), P, Qpart finite_set:
        $is_partition_of_bounded_interval(I, P)
        $is_partition_of_bounded_interval(I, Qpart)
        =>:
            exist Rf finite_set st {$is_common_refinement_of_partitions(I, P, Qpart, Rf)}
    # Source handling: the common refinement is the finite image of P times
    # Qpart under intersection.  Its partition and unique-cover clauses are
    # supplied by the preceding theorem.
    $is_partition_of_bounded_interval(I, P)
    $is_partition_of_bounded_interval(I, Qpart)
    by thm intersection_image_of_two_partition_families_is_finite(I, P, Qpart)
    witness exist Rf finite_set st {$is_common_refinement_of_partitions(I, P, Qpart, Rf)} from fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}):
        by thm intersection_image_of_two_partition_families_is_partition(I, P, Qpart)
        claim:
            ? forall H fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}):
                exist J P, K Qpart st {J $in power_set(R), K $in power_set(R), H = intersect(J, K)}
            have by preimage p from H $in fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])})
            p[1] $in P
            p[2] $in Qpart
            p[1] $in power_set(R)
            p[2] $in power_set(R)
            H = intersect(p[1], p[2])
            witness exist J P, K Qpart st {J $in power_set(R), K $in power_set(R), H = intersect(J, K)} from p[1], p[2]:
                p[1] $in power_set(R)
                p[2] $in power_set(R)
                H = intersect(p[1], p[2])
        claim:
            ? forall J P, K Qpart:
                J $in power_set(R)
                K $in power_set(R)
                =>:
                    exist H fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}) st {H = intersect(J, K)}
            (J, K) $in cart(P, Qpart)
            fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}((J, K)) = intersect(J, K)
            fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}((J, K)) $in fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])})
            intersect(J, K) $in fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])})
            witness exist H fn_range(fn(p cart(P, Qpart)) power_set(R) {intersect(p[1], p[2])}) st {H = intersect(J, K)} from intersect(J, K):
                intersect(J, K) = intersect(J, K)

thm common_refinement_unique:
    ? forall I power_set(R), P, Qpart, Rf1, Rf2 finite_set:
        $is_common_refinement_of_partitions(I, P, Qpart, Rf1)
        $is_common_refinement_of_partitions(I, P, Qpart, Rf2)
        =>:
            Rf1 = Rf2
    # Source handling: Definition 11.1.16 describes the common refinement by
    # exactly its intersection pieces, so two such families have the same
    # members.
    by extension Rf1 = Rf2:
        claim:
            ? forall H Rf1:
                H $in Rf2
            obtain J, K from exist J P, K Qpart st {J $in power_set(R), K $in power_set(R), H = intersect(J, K)}
            obtain H0 from exist H0 Rf2 st {H0 = intersect(J, K)}
            H = intersect(J, K)
            H0 = intersect(J, K)
            H = H0
            H $in Rf2
        claim:
            ? forall H Rf2:
                H $in Rf1
            obtain J, K from exist J P, K Qpart st {J $in power_set(R), K $in power_set(R), H = intersect(J, K)}
            obtain H0 from exist H0 Rf1 st {H0 = intersect(J, K)}
            H = intersect(J, K)
            H0 = intersect(J, K)
            H = H0
            H $in Rf1

have fn common_refinement by exist!:
    ? forall I power_set(R), P, Qpart power_set(power_set(R)):
        $is_finite_set(P)
        $is_finite_set(Qpart)
        $is_partition_of_bounded_interval(I, P)
        $is_partition_of_bounded_interval(I, Qpart)
        =>:
            exist! Rf power_set(power_set(R)) st {$is_finite_set(Rf), $is_common_refinement_of_partitions(I, P, Qpart, Rf)}
    # Source handling: this is the canonical `P#Q` from Definition 11.1.16.
    # Its selector shape lets later constructions use the refinement itself,
    # instead of reopening an existential witness at every use site.
    by thm common_refinement_exists_for_partitions(I, P, Qpart)
    obtain Rf from exist Rf finite_set st {$is_common_refinement_of_partitions(I, P, Qpart, Rf)}
    by thm partition_is_set_of_real_subsets(I, Rf)
    claim:
        ? exist Rf0 power_set(power_set(R)) st {$is_finite_set(Rf0), $is_common_refinement_of_partitions(I, P, Qpart, Rf0)}
        witness exist Rf0 power_set(power_set(R)) st {$is_finite_set(Rf0), $is_common_refinement_of_partitions(I, P, Qpart, Rf0)} from Rf:
            $is_finite_set(Rf)
            $is_common_refinement_of_partitions(I, P, Qpart, Rf)
    claim:
        ? forall Rf1, Rf2 power_set(power_set(R)):
            $is_finite_set(Rf1)
            $is_finite_set(Rf2)
            $is_common_refinement_of_partitions(I, P, Qpart, Rf1)
            $is_common_refinement_of_partitions(I, P, Qpart, Rf2)
            =>:
                Rf1 = Rf2
        by thm common_refinement_unique(I, P, Qpart, Rf1, Rf2)
    exist! Rf0 power_set(power_set(R)) st {$is_finite_set(Rf0), $is_common_refinement_of_partitions(I, P, Qpart, Rf0)}

# A refinement fiber is the finite family of nonempty fine pieces lying inside
# one prospective coarse piece.  Empty pieces have zero length and zero
# rectangle contribution, but cannot be assigned to a unique coarse piece.
# Excluding them here makes the later finite regrouping disjoint.

prop is_refinement_fiber(Pfine power_set(power_set(R)), K power_set(R), F power_set(power_set(R))):
    $is_finite_set(Pfine)
    $is_finite_set(F)
    F $subset Pfine
    forall J F:
        $is_nonempty_set(J)
        J $subset K
    forall J Pfine:
        $is_nonempty_set(J)
        J $subset K
        =>:
            J $in F

thm refinement_fiber_exists:
    ? forall Pfine power_set(power_set(R)), K power_set(R):
        $is_finite_set(Pfine)
        =>:
            exist F power_set(power_set(R)) st {$is_refinement_fiber(Pfine, K, F)}
    claim:
        ? {J Pfine: $is_nonempty_set(J), J $subset K} $subset Pfine
        forall J {J Pfine: $is_nonempty_set(J), J $subset K}:
            J $in Pfine
    by thm basics::subset_of_finite_set_is_finite({J Pfine: $is_nonempty_set(J), J $subset K}, Pfine)
    claim:
        ? $is_finite_set({J Pfine: $is_nonempty_set(J), J $subset K})
        $is_finite_set({J Pfine: $is_nonempty_set(J), J $subset K})
    witness exist F power_set(power_set(R)) st {$is_refinement_fiber(Pfine, K, F)} from {J Pfine: $is_nonempty_set(J), J $subset K}:
        $is_finite_set(Pfine)
        $is_finite_set({J Pfine: $is_nonempty_set(J), J $subset K})
        {J Pfine: $is_nonempty_set(J), J $subset K} $subset Pfine
        forall J {J Pfine: $is_nonempty_set(J), J $subset K}:
            $is_nonempty_set(J)
            J $subset K
        forall J Pfine:
            $is_nonempty_set(J)
            J $subset K
            =>:
                J $in {X Pfine: $is_nonempty_set(X), X $subset K}
        $is_refinement_fiber(Pfine, K, {J Pfine: $is_nonempty_set(J), J $subset K})

thm refinement_fiber_unique:
    ? forall Pfine, F1, F2 power_set(power_set(R)), K power_set(R):
        $is_refinement_fiber(Pfine, K, F1)
        $is_refinement_fiber(Pfine, K, F2)
        =>:
            F1 = F2
    by extension F1 = F2:
        claim:
            ? forall J F1:
                J $in F2
            J $in Pfine
            $is_nonempty_set(J)
            J $subset K
            J $in F2
        claim:
            ? forall J F2:
                J $in F1
            J $in Pfine
            $is_nonempty_set(J)
            J $subset K
            J $in F1

have fn refinement_fiber by exist!:
    ? forall Pfine power_set(power_set(R)), K power_set(R):
        $is_finite_set(Pfine)
        =>:
            exist! F power_set(power_set(R)) st {$is_refinement_fiber(Pfine, K, F)}
    by thm refinement_fiber_exists(Pfine, K)
    obtain F from exist F power_set(power_set(R)) st {$is_refinement_fiber(Pfine, K, F)}
    claim:
        ? exist F0 power_set(power_set(R)) st {$is_refinement_fiber(Pfine, K, F0)}
        witness exist F0 power_set(power_set(R)) st {$is_refinement_fiber(Pfine, K, F0)} from F:
            $is_refinement_fiber(Pfine, K, F)
    claim:
        ? forall F1, F2 power_set(power_set(R)):
            $is_refinement_fiber(Pfine, K, F1)
            $is_refinement_fiber(Pfine, K, F2)
            =>:
                F1 = F2
        by thm refinement_fiber_unique(Pfine, K, F1, F2)
    exist! F0 power_set(power_set(R)) st {$is_refinement_fiber(Pfine, K, F0)}

thm refinement_fiber_has_value:
    ? forall Pfine power_set(power_set(R)), K power_set(R):
        $is_finite_set(Pfine)
        =>:
            $is_refinement_fiber(Pfine, K, refinement_fiber(Pfine, K))
    have F power_set(power_set(R)) = refinement_fiber(Pfine, K)
    $is_refinement_fiber(Pfine, K, F)
    F = refinement_fiber(Pfine, K)
    $is_refinement_fiber(Pfine, K, refinement_fiber(Pfine, K))

thm refinement_fiber_has_finite_representative:
    ? forall Pfine power_set(power_set(R)), K power_set(R):
        $is_finite_set(Pfine)
        =>:
            exist F finite_set st {F = refinement_fiber(Pfine, K), $is_refinement_fiber(Pfine, K, F)}
    # The selector's public carrier is a set of real subsets.  This bridge
    # packages its finite value for finite_set_sum and other finite APIs.
    claim:
        ? {J Pfine: $is_nonempty_set(J), J $subset K} $subset Pfine
        forall J {J Pfine: $is_nonempty_set(J), J $subset K}:
            J $in Pfine
    by thm basics::subset_of_finite_set_is_finite({J Pfine: $is_nonempty_set(J), J $subset K}, Pfine)
    claim:
        ? $is_finite_set({J Pfine: $is_nonempty_set(J), J $subset K})
        $is_finite_set({J Pfine: $is_nonempty_set(J), J $subset K})
    claim:
        ? $is_refinement_fiber(Pfine, K, {J Pfine: $is_nonempty_set(J), J $subset K})
        $is_finite_set(Pfine)
        $is_finite_set({J Pfine: $is_nonempty_set(J), J $subset K})
        {J Pfine: $is_nonempty_set(J), J $subset K} $subset Pfine
        forall J {J Pfine: $is_nonempty_set(J), J $subset K}:
            $is_nonempty_set(J)
            J $subset K
        forall J Pfine:
            $is_nonempty_set(J)
            J $subset K
            =>:
                J $in {X Pfine: $is_nonempty_set(X), X $subset K}
    by thm refinement_fiber_has_value(Pfine, K)
    by thm refinement_fiber_unique(Pfine, {J Pfine: $is_nonempty_set(J), J $subset K}, refinement_fiber(Pfine, K), K)
    {J Pfine: $is_nonempty_set(J), J $subset K} = refinement_fiber(Pfine, K)
    witness exist F finite_set st {F = refinement_fiber(Pfine, K), $is_refinement_fiber(Pfine, K, F)} from {J Pfine: $is_nonempty_set(J), J $subset K}:
        $is_finite_set({J Pfine: $is_nonempty_set(J), J $subset K})
        {J Pfine: $is_nonempty_set(J), J $subset K} = refinement_fiber(Pfine, K)
        $is_refinement_fiber(Pfine, K, {J Pfine: $is_nonempty_set(J), J $subset K})

thm refinement_fiber_partitions_coarse_piece:
    ? forall I power_set(R), Pfine, Pcoarse, F finite_set, K power_set(R):
        $is_finer_partition_than(I, Pfine, Pcoarse)
        K $in Pcoarse
        $is_refinement_fiber(Pfine, K, F)
        =>:
            $is_partition_of_bounded_interval(K, F)
    # A fine piece through x lies in some coarse piece.  Since both that
    # coarse piece and K contain x, unique coverage by Pcoarse identifies
    # them.  Thus the fiber covers K exactly once.
    $is_partition_of_bounded_interval(I, Pfine)
    $is_partition_of_bounded_interval(I, Pcoarse)
    $is_bounded_interval(K)
    claim:
        ? K $subset I
        K $in Pcoarse
        K $subset I
    claim:
        ? forall J F:
            J $in power_set(R)
            $is_bounded_interval(J)
            J $subset K
        J $in Pfine
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset I
        J $subset K
    claim:
        ? forall x K:
            exist J F st {J $in power_set(R), x $in J}
        x $in I
        obtain J from exist J Pfine st {J $in power_set(R), x $in J}
        obtain K0 from exist K0 Pcoarse st {J $in power_set(R), K0 $in power_set(R), J $subset K0}
        x $in J
        witness $is_nonempty_set(J) from x
        x $in K0
        J $subset K0
        K $in power_set(R)
        exist! K1 Pcoarse st {K1 $in power_set(R), x $in K1}
        K0 = K
        J $subset K
        J $in F
        witness exist J0 F st {J0 $in power_set(R), x $in J0} from J:
            J $in power_set(R)
            x $in J
    claim:
        ? forall x K, J1, J2 F:
            J1 $in power_set(R)
            J2 $in power_set(R)
            x $in J1
            x $in J2
            =>:
                J1 = J2
        J1 $in Pfine
        J2 $in Pfine
        exist! J Pfine st {J $in power_set(R), x $in J}
        J1 = J2
    $is_partition_of_bounded_interval(K, F)

thm nonempty_fine_piece_has_unique_coarse_piece:
    ? forall I power_set(R), Pfine, Pcoarse finite_set, J power_set(R):
        $is_finer_partition_than(I, Pfine, Pcoarse)
        J $in Pfine
        $is_nonempty_set(J)
        =>:
            exist! K Pcoarse st {K $in power_set(R), J $subset K}
    # A nonempty fine piece has a point.  The unique-cover clause of the
    # coarse partition then makes its containing coarse piece unique.
    $is_partition_of_bounded_interval(I, Pfine)
    $is_partition_of_bounded_interval(I, Pcoarse)
    J $in power_set(R)
    J $subset I
    obtain K0 from exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K}
    witness exist! K Pcoarse st {K $in power_set(R), J $subset K} from K0:
        K0 $in power_set(R)
        J $subset K0
        claim:
            ? forall K1, K2 Pcoarse:
                K1 $in power_set(R)
                K2 $in power_set(R)
                J $subset K1
                J $subset K2
                =>:
                    K1 = K2
            obtain x from exist x J st {x $in J}
            x $in K1
            x $in K2
            exist! Kcover Pcoarse st {Kcover $in power_set(R), x $in Kcover}
            K1 = K2

have fn refinement_owner by exist!:
    ? forall I power_set(R), Pfine, Pcoarse power_set(power_set(R)), J power_set(R):
        $is_finite_set(Pfine)
        $is_finite_set(Pcoarse)
        $is_finer_partition_than(I, Pfine, Pcoarse)
        J $in Pfine
        $is_nonempty_set(J)
        =>:
            exist! K power_set(R) st {K $in Pcoarse, J $subset K}
    by thm nonempty_fine_piece_has_unique_coarse_piece(I, Pfine, Pcoarse, J)

thm refinement_owner_has_value:
    ? forall I power_set(R), Pfine, Pcoarse power_set(power_set(R)), J power_set(R):
        $is_finite_set(Pfine)
        $is_finite_set(Pcoarse)
        $is_finer_partition_than(I, Pfine, Pcoarse)
        J $in Pfine
        $is_nonempty_set(J)
        =>:
            refinement_owner(I, Pfine, Pcoarse, J) $in Pcoarse
            J $subset refinement_owner(I, Pfine, Pcoarse, J)
    have K power_set(R) = refinement_owner(I, Pfine, Pcoarse, J)
    K $in Pcoarse
    J $subset K
    K = refinement_owner(I, Pfine, Pcoarse, J)
    refinement_owner(I, Pfine, Pcoarse, J) $in Pcoarse
    J $subset refinement_owner(I, Pfine, Pcoarse, J)

thm refinement_owner_is_in_refinement_fiber:
    ? forall I power_set(R), Pfine, Pcoarse power_set(power_set(R)), J power_set(R):
        $is_finite_set(Pfine)
        $is_finite_set(Pcoarse)
        $is_finer_partition_than(I, Pfine, Pcoarse)
        J $in Pfine
        $is_nonempty_set(J)
        =>:
            J $in refinement_fiber(Pfine, refinement_owner(I, Pfine, Pcoarse, J))
    have K power_set(R) = refinement_owner(I, Pfine, Pcoarse, J)
    by thm refinement_owner_has_value(I, Pfine, Pcoarse, J)
    J $subset K
    by thm refinement_fiber_has_value(Pfine, K)
    $is_refinement_fiber(Pfine, K, refinement_fiber(Pfine, K))
    J $in refinement_fiber(Pfine, K)
    K = refinement_owner(I, Pfine, Pcoarse, J)
    J $in refinement_fiber(Pfine, refinement_owner(I, Pfine, Pcoarse, J))

thm refinement_fiber_member_has_owner:
    ? forall I power_set(R), Pfine, Pcoarse power_set(power_set(R)), J, K power_set(R):
        $is_finite_set(Pfine)
        $is_finite_set(Pcoarse)
        $is_finer_partition_than(I, Pfine, Pcoarse)
        K $in Pcoarse
        J $in refinement_fiber(Pfine, K)
        =>:
            refinement_owner(I, Pfine, Pcoarse, J) = K
    # The fiber condition recovers a nonempty fine piece contained in K.
    # Uniqueness of the coarse cover then identifies K with its owner.
    by thm refinement_fiber_has_value(Pfine, K)
    $is_refinement_fiber(Pfine, K, refinement_fiber(Pfine, K))
    J $in Pfine
    $is_nonempty_set(J)
    J $subset K
    by thm refinement_owner_has_value(I, Pfine, Pcoarse, J)
    refinement_owner(I, Pfine, Pcoarse, J) $in Pcoarse
    J $subset refinement_owner(I, Pfine, Pcoarse, J)
    by thm nonempty_fine_piece_has_unique_coarse_piece(I, Pfine, Pcoarse, J)
    K = refinement_owner(I, Pfine, Pcoarse, J)
    refinement_owner(I, Pfine, Pcoarse, J) = K

prop has_refinement_fiber_sum(Pfine power_set(power_set(R)), K power_set(R), h fn(J Pfine) R, s R):
    $is_finite_set(Pfine)
    exist F finite_set st {$is_refinement_fiber(Pfine, K, F), s = finite_set_sum(F, fn(J F) R {h(J)})}

thm refinement_fiber_sum_exists:
    ? forall Pfine power_set(power_set(R)), K power_set(R), h fn(J Pfine) R:
        $is_finite_set(Pfine)
        =>:
            exist s R st {$has_refinement_fiber_sum(Pfine, K, h, s)}
    by thm refinement_fiber_has_finite_representative(Pfine, K)
    obtain F from exist F finite_set st {F = refinement_fiber(Pfine, K), $is_refinement_fiber(Pfine, K, F)}
    $is_finite_set(Pfine)
    witness exist F0 finite_set st {$is_refinement_fiber(Pfine, K, F0), finite_set_sum(F, fn(J F) R {h(J)}) = finite_set_sum(F0, fn(J F0) R {h(J)})} from F:
        $is_refinement_fiber(Pfine, K, F)
        finite_set_sum(F, fn(J F) R {h(J)}) = finite_set_sum(F, fn(J F) R {h(J)})
    $has_refinement_fiber_sum(Pfine, K, h, finite_set_sum(F, fn(J F) R {h(J)}))
    witness exist s R st {$has_refinement_fiber_sum(Pfine, K, h, s)} from finite_set_sum(F, fn(J F) R {h(J)}):
        $has_refinement_fiber_sum(Pfine, K, h, finite_set_sum(F, fn(J F) R {h(J)}))

thm refinement_fiber_sum_unique:
    ? forall Pfine power_set(power_set(R)), K power_set(R), h fn(J Pfine) R, s1, s2 R:
        $has_refinement_fiber_sum(Pfine, K, h, s1)
        $has_refinement_fiber_sum(Pfine, K, h, s2)
        =>:
            s1 = s2
    obtain F1 from exist F1 finite_set st {$is_refinement_fiber(Pfine, K, F1), s1 = finite_set_sum(F1, fn(J F1) R {h(J)})}
    obtain F2 from exist F2 finite_set st {$is_refinement_fiber(Pfine, K, F2), s2 = finite_set_sum(F2, fn(J F2) R {h(J)})}
    by thm refinement_fiber_unique(Pfine, F1, F2, K)
    F1 = F2
    finite_set_sum(F1, fn(J F1) R {h(J)}) = finite_set_sum(F2, fn(J F2) R {h(J)})
    s1 = finite_set_sum(F1, fn(J F1) R {h(J)}) = finite_set_sum(F2, fn(J F2) R {h(J)}) = s2

have fn refinement_fiber_sum by exist!:
    ? forall Pfine power_set(power_set(R)), K power_set(R), h fn(J Pfine) R:
        $is_finite_set(Pfine)
        =>:
            exist! s R st {$has_refinement_fiber_sum(Pfine, K, h, s)}
    by thm refinement_fiber_sum_exists(Pfine, K, h)
    obtain s from exist s R st {$has_refinement_fiber_sum(Pfine, K, h, s)}
    claim:
        ? exist s0 R st {$has_refinement_fiber_sum(Pfine, K, h, s0)}
        witness exist s0 R st {$has_refinement_fiber_sum(Pfine, K, h, s0)} from s:
            $has_refinement_fiber_sum(Pfine, K, h, s)
    claim:
        ? forall s1, s2 R:
            $has_refinement_fiber_sum(Pfine, K, h, s1)
            $has_refinement_fiber_sum(Pfine, K, h, s2)
            =>:
                s1 = s2
        by thm refinement_fiber_sum_unique(Pfine, K, h, s1, s2)
    exist! s0 R st {$has_refinement_fiber_sum(Pfine, K, h, s0)}

thm refinement_fiber_sum_has_value:
    ? forall Pfine power_set(power_set(R)), K power_set(R), h fn(J Pfine) R:
        $is_finite_set(Pfine)
        =>:
            $has_refinement_fiber_sum(Pfine, K, h, refinement_fiber_sum(Pfine, K, h))
    have s R = refinement_fiber_sum(Pfine, K, h)
    $has_refinement_fiber_sum(Pfine, K, h, s)
    s = refinement_fiber_sum(Pfine, K, h)
    $has_refinement_fiber_sum(Pfine, K, h, refinement_fiber_sum(Pfine, K, h))

have fn nonempty_refinement_support(Pfine power_set(power_set(R))) power_set(power_set(R)) = {J Pfine: $is_nonempty_set(J)}

thm nonempty_refinement_support_is_finite:
    ? forall Pfine power_set(power_set(R)):
        $is_finite_set(Pfine)
        =>:
            $is_finite_set(nonempty_refinement_support(Pfine))
    claim:
        ? nonempty_refinement_support(Pfine) $subset Pfine
        forall J nonempty_refinement_support(Pfine):
            J $in Pfine
    by thm basics::subset_of_finite_set_is_finite(nonempty_refinement_support(Pfine), Pfine)
    $is_finite_set(nonempty_refinement_support(Pfine))

# Generic finite-family vocabulary for the later regrouping theorem.  The
# family S lives in the common carrier U, while T indexes its finite fibers.
# Chapter 11 still fixes objects to real subsets, but a caller may now choose
# the mathematically natural common family U rather than all real subsets.
prop is_finite_indexed_subfamily(U, S, T power_set(power_set(R)), F fn(L T) power_set(power_set(R))):
    S $subset U
    $is_finite_set(S)
    $is_finite_set(T)
    forall K T:
        $is_finite_set(F(K))
        F(K) $subset S

prop has_indexed_fiber_sum(U, S, T power_set(power_set(R)), F fn(L T) power_set(power_set(R)), h fn(x U) R, K T, s R):
    $is_finite_indexed_subfamily(U, S, T, F)
    exist A finite_set st {A = F(K), A $subset S, A $subset U, s = finite_set_sum(A, fn(x A) R {h(x)})}

prop is_finite_unique_cover_of(U, S, T power_set(power_set(R)), F fn(L T) power_set(power_set(R))):
    $is_finite_indexed_subfamily(U, S, T, F)
    forall J S:
        exist! K T st {J $in F(K)}

# A unique cover makes distinct fibers disjoint. This is the structural
# premise required before a finite-set sum can split into fiber sums.
thm finite_unique_cover_distinct_fibers_are_disjoint:
    ? forall U, S, T power_set(power_set(R)), F fn(L T) power_set(power_set(R)), K1, K2 T:
        $is_finite_unique_cover_of(U, S, T, F)
        K1 != K2
        =>:
            intersect(F(K1), F(K2)) = {}
    forall J S:
        exist! K0 T st {J $in F(K0)}
    claim:
        ? forall J intersect(F(K1), F(K2)):
            J $in {}
        by contra:
            ? J $in {}
            not J $in {}
            J $in F(K1)
            J $in F(K2)
            F(K1) $subset S
            J $in S
            exist! K0 T st {J $in F(K0)}
            obtain K0 from exist! K0 T st {J $in F(K0)}
            K0 = K1
            K0 = K2
            K1 = K2
            impossible K1 != K2
    by extension intersect(F(K1), F(K2)) = {}:
        claim:
            ? forall J intersect(F(K1), F(K2)):
                J $in {}
            J $in {}
        claim:
            ? forall J {}:
                J $in intersect(F(K1), F(K2))
            by contra:
                ? J $in intersect(F(K1), F(K2))
                J $in {}
                not J $in {}
                impossible not J $in {}

# After removing one index, the remaining fibers still cover precisely the
# complement of that fiber. This is the structural induction step for finite
# regrouping.
thm finite_unique_cover_residual_after_removing_index:
    ? forall U, S, T power_set(power_set(R)), F fn(L T) power_set(power_set(R)), K T:
        $is_finite_unique_cover_of(U, S, T, F)
        =>:
            $is_finite_unique_cover_of(U, set_minus(S, F(K)), set_minus(T, {K}), fn(L set_minus(T, {K})) power_set(power_set(R)) {F(L)})
    set_minus(S, F(K)) $subset U
    set_minus(T, {K}) $subset power_set(R)
    set_minus(T, {K}) $in power_set(power_set(R))
    have S0 power_set(power_set(R)) = set_minus(S, F(K))
    have T0 power_set(power_set(R)) = set_minus(T, {K})
    have fn F0(L T0) power_set(power_set(R)) = F(L)
    claim:
        ? $is_finite_indexed_subfamily(U, S0, T0, F0)
        S0 $subset S
        S $subset U
        S0 $subset U
        by thm basics::subset_of_finite_set_is_finite(S0, S)
        T0 $subset T
        by thm basics::subset_of_finite_set_is_finite(T0, T)
        claim:
            ? forall L T0:
                $is_finite_set(F0(L))
                F0(L) $subset S0
            F0(L) = F(L)
            $is_finite_set(F(L))
            F(L) $subset S
            L != K
            by thm finite_unique_cover_distinct_fibers_are_disjoint(U, S, T, F, L, K)
            intersect(F(L), F(K)) = {}
            claim:
                ? forall J F(L):
                    J $in S0
                J $in S
                by contra:
                    ? J $in S0
                    not J $in S0
                    J $in F(K)
                    J $in intersect(F(L), F(K))
                    J $in {}
                    not J $in {}
                    impossible not J $in {}
                J $in set_minus(S, F(K))
                J $in S0
            F(L) $subset S0
            F0(L) $subset S0
        $is_finite_indexed_subfamily(U, S0, T0, F0)

# An ambient weight remains the same function after a fiber and its index are
# removed. Only the finite family being summed changes.
thm indexed_fiber_sum_persists_after_removing_index:
    ? forall U, S, T power_set(power_set(R)), F fn(L T) power_set(power_set(R)), h fn(x U) R, K T, L set_minus(T, {K}), s R:
        $is_finite_unique_cover_of(U, S, T, F)
        $has_indexed_fiber_sum(U, S, T, F, h, L, s)
        =>:
            $has_indexed_fiber_sum(U, set_minus(S, F(K)), set_minus(T, {K}), fn(L0 set_minus(T, {K})) power_set(power_set(R)) {F(L0)}, h, L, s)
    set_minus(S, F(K)) $subset U
    set_minus(T, {K}) $subset power_set(R)
    set_minus(T, {K}) $in power_set(power_set(R))
    have S0 power_set(power_set(R)) = set_minus(S, F(K))
    have T0 power_set(power_set(R)) = set_minus(T, {K})
    have fn F0(L0 T0) power_set(power_set(R)) = F(L0)
    by thm finite_unique_cover_residual_after_removing_index(U, S, T, F, K)
    $is_finite_indexed_subfamily(U, S0, T0, F0)
    obtain A from exist A finite_set st {A = F(L), A $subset S, A $subset U, s = finite_set_sum(A, fn(x A) R {h(x)})}
    s = finite_set_sum(A, fn(x A) R {h(x)})
    A = F(L)
    F0(L) = F(L)
    F0(L) = A
    F0(L) $subset S0
    A $subset S0
    by thm finite_unique_cover_residual_after_removing_index(U, S, T, F, K)
    $is_finite_indexed_subfamily(U, set_minus(S, F(K)), set_minus(T, {K}), fn(L0 set_minus(T, {K})) power_set(power_set(R)) {F(L0)})
    witness exist B finite_set st {B = fn(L0 set_minus(T, {K})) power_set(power_set(R)) {F(L0)}(L), B $subset set_minus(S, F(K)), B $subset U, s = finite_set_sum(B, fn(x B) R {h(x)})} from A:
        B = A
        A = F(L)
        fn(L0 set_minus(T, {K})) power_set(power_set(R)) {F(L0)}(L) = F(L)
        B = F(L) = fn(L0 set_minus(T, {K})) power_set(power_set(R)) {F(L0)}(L)
        B $subset S0
        B $subset set_minus(S, F(K))
        B $subset U
        s = finite_set_sum(A, fn(x A) R {h(x)})
        finite_set_sum(B, fn(x B) R {h(x)}) = finite_set_sum(A, fn(x A) R {h(x)})
        s = finite_set_sum(B, fn(x B) R {h(x)})
    $has_indexed_fiber_sum(U, set_minus(S, F(K)), set_minus(T, {K}), fn(L0 set_minus(T, {K})) power_set(power_set(R)) {F(L0)}, h, L, s)

# A finite-set induction presents its recursive index set as a named set T,
# whereas residual-cover elimination produces the literal set_minus(U, {K}).
# This bridge changes only that index carrier; no mathematical fiber changes.
thm finite_unique_cover_retype_residual_index:
    ? forall V, S, T, U power_set(power_set(R)), K U, F fn(L U) power_set(power_set(R)):
        T = set_minus(U, {K})
        T $subset U
        $is_finite_unique_cover_of(V, S, U, F)
        =>:
            $is_finite_unique_cover_of(V, set_minus(S, F(K)), T, fn(L T) power_set(power_set(R)) {F(L)})
    set_minus(S, F(K)) $subset V
    by thm finite_unique_cover_residual_after_removing_index(V, S, U, F, K)
    $is_finite_unique_cover_of(V, set_minus(S, F(K)), set_minus(U, {K}), fn(L set_minus(U, {K})) power_set(power_set(R)) {F(L)})
    $is_finite_unique_cover_of(V, set_minus(S, F(K)), T, fn(L T) power_set(power_set(R)) {F(L)})

thm indexed_fiber_sum_retype_residual_index:
    ? forall V, S, T, U power_set(power_set(R)), K U, F fn(L U) power_set(power_set(R)), h fn(x V) R, L T, s R:
        T = set_minus(U, {K})
        T $subset U
        $is_finite_unique_cover_of(V, S, U, F)
        $has_indexed_fiber_sum(V, S, U, F, h, L, s)
        =>:
            $has_indexed_fiber_sum(V, set_minus(S, F(K)), T, fn(L0 T) power_set(power_set(R)) {F(L0)}, h, L, s)
    set_minus(S, F(K)) $subset V
    by thm indexed_fiber_sum_persists_after_removing_index(V, S, U, F, h, K, L, s)
    $has_indexed_fiber_sum(V, set_minus(S, F(K)), set_minus(U, {K}), fn(L0 set_minus(U, {K})) power_set(power_set(R)) {F(L0)}, h, L, s)
    $has_indexed_fiber_sum(V, set_minus(S, F(K)), T, fn(L0 T) power_set(power_set(R)) {F(L0)}, h, L, s)

# This is the induction predicate for the generic reindexing theorem below.
# It says that every unique finite cover indexed by T may be summed fiberwise.
prop finite_unique_cover_sum_reindexing_holds(U, T power_set(power_set(R))):
    forall S power_set(power_set(R)), F fn(L T) power_set(power_set(R)), h fn(x U) R, g fn(K T) R:
        $is_finite_unique_cover_of(U, S, T, F)
        forall K T:
            $has_indexed_fiber_sum(U, S, T, F, h, K, g(K))
        =>:
            finite_set_sum(S, fn(x S) R {h(x)}) = finite_set_sum(T, g)

# This is the index-set algebra used by the insertion case of finite-set
# induction: removing the newly inserted index recovers the old family.
thm finite_set_insert_residual_index:
    ? forall K power_set(R), T power_set(power_set(R)):
        not K $in T
        =>:
            T = set_minus(union({K}, T), {K})
    by extension T = set_minus(union({K}, T), {K}):
        claim:
            ? forall L T:
                L $in set_minus(union({K}, T), {K})
            L $in union({K}, T)
            claim:
                ? not L $in {K}
                by contra:
                    ? not L $in {K}
                    L $in {K}
                    L = K
                    K $in T
                    impossible not K $in T
            L $in set_minus(union({K}, T), {K})
        claim:
            ? forall L set_minus(union({K}, T), {K}):
                L $in T
            L $in union({K}, T)
            L $in {K} or L $in T
            by cases:
                ? L $in T
                case L $in {K}:
                    L = K
                    L $in {K}
                    not L $in {K}
                    impossible not L $in {K}
                case L $in T:
                    L $in T

# The empty index family can cover only the empty source family. This is the
# actual base case of finite-index induction (the singleton theorem below is
# the first nonempty case).
thm finite_set_sum_over_empty_unique_cover:
    ? forall U, S, T power_set(power_set(R)), F fn(L T) power_set(power_set(R)), h fn(x U) R, g fn(K T) R:
        $is_finite_unique_cover_of(U, S, T, F)
        T = {}
        =>:
            finite_set_sum(S, fn(x S) R {h(x)}) = finite_set_sum(T, g)
    claim:
        ? S = {}
        by extension S = {}:
            claim:
                ? forall J S:
                    J $in {}
                by contra:
                    ? J $in {}
                    exist! k T st {J $in F(k)}
                    obtain k from exist! k T st {J $in F(k)}
                    k $in T
                    T = {}
                    k $in {}
                    impossible k $in {}
            claim:
                ? forall J {}:
                    J $in S
                by contra:
                    ? J $in S
                    J $in {}
                    impossible J $in {}
    S = {}
    by thm chap7::finite_set_sum_empty(fn(x {}) R {h(x)})
    finite_set_sum({}, fn(x {}) R {h(x)}) = 0
    T = {}
    by thm chap7::finite_set_sum_empty(g)
    finite_set_sum(T, g) = 0
    finite_set_sum(S, fn(x S) R {h(x)}) = 0 = finite_set_sum(T, g)

# The one-index case is the base interface for finite regrouping: a unique
# cover indexed by a singleton has no reindexing ambiguity at all.
thm finite_set_sum_over_singleton_unique_cover:
    ? forall U, S, T power_set(power_set(R)), F fn(L T) power_set(power_set(R)), h fn(x U) R, K T, s R:
        $is_finite_unique_cover_of(U, S, T, F)
        $has_indexed_fiber_sum(U, S, T, F, h, K, s)
        T = {K}
        =>:
            finite_set_sum(S, fn(x S) R {h(x)}) = s
    $is_finite_indexed_subfamily(U, S, T, F)
    forall J S:
        exist! K0 T st {J $in F(K0)}
    claim:
        ? S = F(K)
        by extension S = F(K):
            claim:
                ? forall J S:
                    J $in F(K)
                exist! K0 T st {J $in F(K0)}
                obtain K0 from exist! K0 T st {J $in F(K0)}
                K0 $in T
                T = {K}
                K0 = K
                J $in F(K0)
                F(K0) = F(K)
                J $in F(K)
            F(K) $subset S
    obtain A from exist A finite_set st {A = F(K), A $subset S, A $subset U, s = finite_set_sum(A, fn(x A) R {h(x)})}
    A = F(K) = S
    s = finite_set_sum(A, fn(x A) R {h(x)}) = finite_set_sum(S, fn(x S) R {h(x)})
    finite_set_sum(S, fn(x S) R {h(x)}) = s

thm indexed_fiber_sum_exists:
    ? forall U, S, T power_set(power_set(R)), F fn(L T) power_set(power_set(R)), h fn(x U) R, K T:
        $is_finite_indexed_subfamily(U, S, T, F)
        =>:
            exist s R st {$has_indexed_fiber_sum(U, S, T, F, h, K, s)}
    $is_finite_set(F(K))
    F(K) $subset S
    S $subset U
    F(K) $subset U
    witness exist A finite_set st {A = F(K), A $subset S, A $subset U, finite_set_sum(F(K), fn(x F(K)) R {h(x)}) = finite_set_sum(A, fn(x A) R {h(x)})} from F(K):
        $is_finite_set(F(K))
        F(K) = F(K)
        F(K) $subset S
        F(K) $subset U
        finite_set_sum(F(K), fn(x F(K)) R {h(x)}) = finite_set_sum(F(K), fn(x F(K)) R {h(x)})
    $has_indexed_fiber_sum(U, S, T, F, h, K, finite_set_sum(F(K), fn(x F(K)) R {h(x)}))
    witness exist s R st {$has_indexed_fiber_sum(U, S, T, F, h, K, s)} from finite_set_sum(F(K), fn(x F(K)) R {h(x)}):
        $has_indexed_fiber_sum(U, S, T, F, h, K, finite_set_sum(F(K), fn(x F(K)) R {h(x)}))

thm indexed_fiber_sum_unique:
    ? forall U, S, T power_set(power_set(R)), F fn(L T) power_set(power_set(R)), h fn(x U) R, K T, s1, s2 R:
        $has_indexed_fiber_sum(U, S, T, F, h, K, s1)
        $has_indexed_fiber_sum(U, S, T, F, h, K, s2)
        =>:
            s1 = s2
    obtain A1 from exist A1 finite_set st {A1 = F(K), A1 $subset S, A1 $subset U, s1 = finite_set_sum(A1, fn(x A1) R {h(x)})}
    obtain A2 from exist A2 finite_set st {A2 = F(K), A2 $subset S, A2 $subset U, s2 = finite_set_sum(A2, fn(x A2) R {h(x)})}
    A1 = F(K) = A2
    A1 = A2
    finite_set_sum(A1, fn(x A1) R {h(x)}) = finite_set_sum(A2, fn(x A2) R {h(x)})
    s1 = finite_set_sum(A1, fn(x A1) R {h(x)}) = finite_set_sum(A2, fn(x A2) R {h(x)}) = s2

# Finite sums reindex over a finite family of pairwise-disjoint fibers that
# uniquely covers their source. The proof is a structural induction on the
# index family: separate one fiber, invoke the residual-cover induction
# hypothesis, and use Chapter 7's disjoint-union sum law on both sides.
thm finite_set_sum_over_unique_cover:
    ? forall U, S, T power_set(power_set(R)), F fn(L T) power_set(power_set(R)), h fn(x U) R, g fn(K T) R:
        $is_finite_unique_cover_of(U, S, T, F)
        forall K T:
            $has_indexed_fiber_sum(U, S, T, F, h, K, g(K))
        =>:
            finite_set_sum(S, fn(x S) R {h(x)}) = finite_set_sum(T, g)
    by induc P:
        ? $finite_unique_cover_sum_reindexing_holds(U, P)
        ? from P = {}:
            forall V power_set(power_set(R)), G fn(L {}) power_set(power_set(R)), q fn(x U) R, r fn(K {}) R:
                $is_finite_unique_cover_of(U, V, {}, G)
                forall K {}:
                    $has_indexed_fiber_sum(U, V, {}, G, q, K, r(K))
                =>:
                    finite_set_sum(V, fn(x V) R {q(x)}) = finite_set_sum({}, r)
            by thm finite_set_sum_over_empty_unique_cover(U, V, {}, G, q, r)
            finite_set_sum(V, fn(x V) R {q(x)}) = finite_set_sum({}, r)
        ? induc K, T:
            $finite_unique_cover_sum_reindexing_holds(U, T)
            forall V power_set(power_set(R)), G fn(L union({K}, T)) power_set(power_set(R)), q fn(x U) R, r fn(L union({K}, T)) R:
                $is_finite_unique_cover_of(U, V, union({K}, T), G)
                forall L union({K}, T):
                    $has_indexed_fiber_sum(U, V, union({K}, T), G, q, L, r(L))
                =>:
                    finite_set_sum(V, fn(x V) R {q(x)}) = finite_set_sum(union({K}, T), r)
            have V0 power_set(power_set(R)) = set_minus(V, G(K))
            have fn G0(L T) power_set(power_set(R)) = G(L)
            claim:
                ? T $subset union({K}, T)
                forall L T:
                    L $in union({K}, T)
            by thm finite_set_insert_residual_index(K, T)
            T = set_minus(union({K}, T), {K})
            by thm finite_unique_cover_retype_residual_index(U, V, T, union({K}, T), K, G)
            $is_finite_unique_cover_of(U, V0, T, G0)
            claim:
                ? forall L T:
                    $has_indexed_fiber_sum(U, V0, T, G0, q, L, r(L))
                L $in union({K}, T)
                $has_indexed_fiber_sum(U, V, union({K}, T), G, q, L, r(L))
                by thm indexed_fiber_sum_retype_residual_index(U, V, T, union({K}, T), K, G, q, L, r(L))
                $has_indexed_fiber_sum(U, V0, T, G0, q, L, r(L))
            $finite_unique_cover_sum_reindexing_holds(U, T)
            finite_set_sum(V0, fn(x V0) R {q(x)}) = finite_set_sum(T, fn(L T) R {r(L)})
            obtain A from exist A finite_set st {A = G(K), A $subset V, A $subset U, r(K) = finite_set_sum(A, fn(x A) R {q(x)})}
            A = G(K)
            r(K) = finite_set_sum(G(K), fn(x G(K)) R {q(x)})
            claim:
                ? V = union(G(K), V0)
                by extension V = union(G(K), V0):
                    claim:
                        ? forall J V:
                            J $in union(G(K), V0)
                        J $in G(K) or not J $in G(K)
                        by cases:
                            ? J $in union(G(K), V0)
                            case J $in G(K):
                                J $in union(G(K), V0)
                            case not J $in G(K):
                                J $in set_minus(V, G(K))
                                J $in V0
                                J $in union(G(K), V0)
                    claim:
                        ? forall J union(G(K), V0):
                            J $in V
                        J $in G(K) or J $in V0
                        by cases:
                            ? J $in V
                            case J $in G(K):
                                G(K) $subset V
                                J $in V
                            case J $in V0:
                                V0 $subset V
                                J $in V
            claim:
                ? intersect(G(K), V0) = {}
                by extension intersect(G(K), V0) = {}:
                    claim:
                        ? forall J intersect(G(K), V0):
                            J $in {}
                        J $in G(K)
                        J $in V0
                        J $in set_minus(V, G(K))
                        not J $in G(K)
                        by contra:
                            ? J $in {}
                            impossible not J $in G(K)
                    claim:
                        ? forall J {}:
                            J $in intersect(G(K), V0)
                        by contra:
                            ? J $in intersect(G(K), U0)
                            J $in {}
                            impossible J $in {}
            by thm chap7::finite_set_sum_disjoint_union(G(K), V0, fn(J union(G(K), V0)) R {q(J)})
            finite_set_sum(union(G(K), V0), fn(J union(G(K), V0)) R {q(J)}) = finite_set_sum(G(K), fn(x G(K)) R {q(x)}) + finite_set_sum(V0, fn(x V0) R {q(x)})
            V = union(G(K), V0)
            finite_set_sum(V, fn(x V) R {q(x)}) = finite_set_sum(G(K), fn(x G(K)) R {q(x)}) + finite_set_sum(V0, fn(x V0) R {q(x)})
            claim:
                ? intersect({K}, T) = {}
                by extension intersect({K}, T) = {}:
                    claim:
                        ? forall L intersect({K}, T):
                            L $in {}
                        L $in {K}
                        L = K
                        L $in T
                        K $in T
                        by contra:
                            ? L $in {}
                            impossible K $in T
                    claim:
                        ? forall L {}:
                            L $in intersect({K}, T)
                        by contra:
                            ? L $in intersect({K}, T)
                            L $in {}
                            impossible L $in {}
            by thm chap7::finite_set_sum_disjoint_union({K}, T, r)
            finite_set_sum(union({K}, T), r) = finite_set_sum({K}, fn(x {K}) R {r(x)}) + finite_set_sum(T, fn(L T) R {r(L)})
            by thm chap7::finite_set_sum_singleton(K, fn(x {K}) R {r(x)})
            finite_set_sum({K}, fn(x {K}) R {r(x)}) = r(K)
            finite_set_sum(V, fn(x V) R {q(x)}) = r(K) + finite_set_sum(T, fn(L T) R {r(L)}) = finite_set_sum(union({K}, T), r)
    $finite_unique_cover_sum_reindexing_holds(U, T)
    finite_set_sum(S, fn(x S) R {h(x)}) = finite_set_sum(T, g)

# A finite sum may discard elements outside T when their summands are zero.
# This is the bridge from a whole refinement family to its nonempty support.
thm finite_set_sum_ignores_zero_outside_subset:
    ? forall U, S, T power_set(power_set(R)), h fn(x U) R:
        $is_finite_set(S)
        S $subset U
        T $subset S
        forall x S:
            not x $in T
            =>:
                h(x) = 0
        =>:
            finite_set_sum(S, fn(x S) R {h(x)}) = finite_set_sum(T, fn(x T) R {h(x)})
    by thm basics::subset_of_finite_set_is_finite(T, S)
    $is_finite_set(T)
    T $subset U
    have R0 power_set(power_set(R)) = set_minus(S, T)
    R0 $subset S
    R0 $subset U
    by thm basics::subset_of_finite_set_is_finite(R0, S)
    $is_finite_set(R0)
    claim:
        ? S = union(T, R0)
        by extension S = union(T, R0):
            claim:
                ? forall x S:
                    x $in union(T, R0)
                x $in T or not x $in T
                by cases:
                    ? x $in union(T, R0)
                    case x $in T:
                        x $in union(T, R0)
                    case not x $in T:
                        x $in set_minus(S, T)
                        x $in R0
                        x $in union(T, R0)
            claim:
                ? forall x union(T, R0):
                    x $in S
                x $in T or x $in R0
                by cases:
                    ? x $in S
                    case x $in T:
                        T $subset S
                        x $in S
                    case x $in R0:
                        R0 $subset S
                        x $in S
    claim:
        ? intersect(T, R0) = {}
        by extension intersect(T, R0) = {}:
            claim:
                ? forall x intersect(T, R0):
                    x $in {}
                x $in T
                x $in R0
                x $in set_minus(S, T)
                not x $in T
                by contra:
                    ? x $in {}
                    impossible not x $in T
            claim:
                ? forall x {}:
                    x $in intersect(T, R0)
                by contra:
                    ? x $in intersect(T, R0)
                    x $in {}
                    impossible x $in {}
    by thm chap7::finite_set_sum_disjoint_union(T, R0, fn(x union(T, R0)) R {h(x)})
    finite_set_sum(union(T, R0), fn(x union(T, R0)) R {h(x)}) = finite_set_sum(T, fn(x T) R {h(x)}) + finite_set_sum(R0, fn(x R0) R {h(x)})
    S = union(T, R0)
    finite_set_sum(S, fn(x S) R {h(x)}) = finite_set_sum(T, fn(x T) R {h(x)}) + finite_set_sum(R0, fn(x R0) R {h(x)})
    claim:
        ? $fn_eq(fn(x R0) R {h(x)}, fn(x R0) R {0})
        forall x R0:
            not x $in T
            h(x) = 0
            fn(x R0) R {h(x)}(x) = h(x)
            fn(x R0) R {0}(x) = 0
            fn(x R0) R {h(x)}(x) = fn(x R0) R {0}(x)
        $fn_eq(fn(x R0) R {h(x)}, fn(x R0) R {0})
    fn(x R0) R {h(x)} = fn(x R0) R {0}
    finite_set_sum(R0, fn(x R0) R {h(x)}) = finite_set_sum(R0, fn(x R0) R {0}) = 0
    finite_set_sum(S, fn(x S) R {h(x)}) = finite_set_sum(T, fn(x T) R {h(x)}) + 0 = finite_set_sum(T, fn(x T) R {h(x)})

thm refinement_fiber_family_is_finite_unique_cover:
    ? forall I, Pfine, Pcoarse power_set(power_set(R)), F fn(L Pcoarse) power_set(power_set(R)):
        $is_finite_set(Pfine)
        $is_finite_set(Pcoarse)
        $is_finer_partition_than(I, Pfine, Pcoarse)
        forall K Pcoarse:
            F(K) = refinement_fiber(Pfine, K)
        =>:
            $is_finite_unique_cover_of(Pfine, nonempty_refinement_support(Pfine), Pcoarse, F)
    claim:
        ? $is_finite_indexed_subfamily(Pfine, nonempty_refinement_support(Pfine), Pcoarse, F)
        claim:
            ? nonempty_refinement_support(Pfine) $subset Pfine
            forall J nonempty_refinement_support(Pfine):
                J $in Pfine
        $is_finite_set(nonempty_refinement_support(Pfine))
        $is_finite_set(Pcoarse)
        claim:
            ? forall K Pcoarse:
                $is_finite_set(F(K))
                F(K) $subset nonempty_refinement_support(Pfine)
            F(K) = refinement_fiber(Pfine, K)
            by thm refinement_fiber_has_finite_representative(Pfine, K)
            obtain A from exist A finite_set st {A = refinement_fiber(Pfine, K), $is_refinement_fiber(Pfine, K, A)}
            F(K) = A
            $is_finite_set(F(K))
            claim:
                ? forall J F(K):
                    J $in nonempty_refinement_support(Pfine)
                F(K) = refinement_fiber(Pfine, K)
                J $in refinement_fiber(Pfine, K)
                by thm refinement_fiber_has_value(Pfine, K)
                $is_refinement_fiber(Pfine, K, refinement_fiber(Pfine, K))
                J $in Pfine
                $is_nonempty_set(J)
                J $in {X Pfine: $is_nonempty_set(X)}
                J $in nonempty_refinement_support(Pfine)
            F(K) $subset nonempty_refinement_support(Pfine)
        $is_finite_indexed_subfamily(Pfine, nonempty_refinement_support(Pfine), Pcoarse, F)
    claim:
        ? forall J nonempty_refinement_support(Pfine):
            exist! K Pcoarse st {J $in F(K)}
        J $in {X Pfine: $is_nonempty_set(X)}
        J $in Pfine
        $is_nonempty_set(J)
        by thm refinement_owner_has_value(I, Pfine, Pcoarse, J)
        refinement_owner(I, Pfine, Pcoarse, J) $in Pcoarse
        by thm refinement_owner_is_in_refinement_fiber(I, Pfine, Pcoarse, J)
        J $in refinement_fiber(Pfine, refinement_owner(I, Pfine, Pcoarse, J))
        refinement_owner(I, Pfine, Pcoarse, J) $in Pcoarse
        F(refinement_owner(I, Pfine, Pcoarse, J)) = refinement_fiber(Pfine, refinement_owner(I, Pfine, Pcoarse, J))
        J $in F(refinement_owner(I, Pfine, Pcoarse, J))
        witness exist! K Pcoarse st {J $in F(K)} from refinement_owner(I, Pfine, Pcoarse, J):
            J $in F(refinement_owner(I, Pfine, Pcoarse, J))
            claim:
                ? forall K1, K2 Pcoarse:
                    J $in F(K1)
                    J $in F(K2)
                    =>:
                        K1 = K2
                F(K1) = refinement_fiber(Pfine, K1)
                F(K2) = refinement_fiber(Pfine, K2)
                J $in refinement_fiber(Pfine, K1)
                J $in refinement_fiber(Pfine, K2)
                by thm refinement_fiber_member_has_owner(I, Pfine, Pcoarse, J, K1)
                refinement_owner(I, Pfine, Pcoarse, J) = K1
                by thm refinement_fiber_member_has_owner(I, Pfine, Pcoarse, J, K2)
                refinement_owner(I, Pfine, Pcoarse, J) = K2
                K1 = refinement_owner(I, Pfine, Pcoarse, J) = K2
    $is_finite_unique_cover_of(Pfine, nonempty_refinement_support(Pfine), Pcoarse, F)

# Representative consumer of the generic reindexing theorem: the nonempty
# fine pieces in a common refinement may be summed coarse piece by coarse
# piece. Later step-integral and Darboux arguments can supply their own
# ambient weight h to this exact interface.
thm refinement_fiber_cover_reindexes_ambient_sum:
    ? forall I, Pfine, Pcoarse power_set(power_set(R)), F fn(L Pcoarse) power_set(power_set(R)), h fn(J Pfine) R:
        $is_finite_set(Pfine)
        $is_finite_set(Pcoarse)
        $is_finer_partition_than(I, Pfine, Pcoarse)
        forall K Pcoarse:
            F(K) = refinement_fiber(Pfine, K)
        =>:
            finite_set_sum(nonempty_refinement_support(Pfine), fn(J nonempty_refinement_support(Pfine)) R {h(J)}) = finite_set_sum(Pcoarse, fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {h(J)})})
    by thm refinement_fiber_family_is_finite_unique_cover(I, Pfine, Pcoarse, F)
    $is_finite_unique_cover_of(Pfine, nonempty_refinement_support(Pfine), Pcoarse, F)
    claim:
        ? forall K Pcoarse:
            $has_indexed_fiber_sum(Pfine, nonempty_refinement_support(Pfine), Pcoarse, F, h, K, finite_set_sum(F(K), fn(J F(K)) R {h(J)}))
        $is_finite_indexed_subfamily(Pfine, nonempty_refinement_support(Pfine), Pcoarse, F)
        $is_finite_set(F(K))
        F(K) $subset nonempty_refinement_support(Pfine)
        F(K) $subset Pfine
        witness exist A finite_set st {A = F(K), A $subset nonempty_refinement_support(Pfine), A $subset Pfine, finite_set_sum(F(K), fn(J F(K)) R {h(J)}) = finite_set_sum(A, fn(J A) R {h(J)})} from F(K):
            A = F(K)
            A $subset nonempty_refinement_support(Pfine)
            A $subset Pfine
            finite_set_sum(F(K), fn(J F(K)) R {h(J)}) = finite_set_sum(F(K), fn(J F(K)) R {h(J)})
        $has_indexed_fiber_sum(Pfine, nonempty_refinement_support(Pfine), Pcoarse, F, h, K, finite_set_sum(F(K), fn(J F(K)) R {h(J)}))
    by thm finite_set_sum_over_unique_cover(Pfine, nonempty_refinement_support(Pfine), Pcoarse, F, h, fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {h(J)})})
    finite_set_sum(nonempty_refinement_support(Pfine), fn(J nonempty_refinement_support(Pfine)) R {h(J)}) = finite_set_sum(Pcoarse, fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {h(J)})})

# A refinement fiber is itself a finite partition of its coarse piece.  This
# specializes finite additivity of interval length to the form used by later
# rectangle and Darboux sums.
thm interval_length_reindexes_over_refinement_fiber:
    ? forall I, Pfine, Pcoarse power_set(power_set(R)), F fn(L Pcoarse) power_set(power_set(R)), K Pcoarse:
        $is_finite_set(Pfine)
        $is_finite_set(Pcoarse)
        $is_finer_partition_than(I, Pfine, Pcoarse)
        forall L Pcoarse:
            F(L) = refinement_fiber(Pfine, L)
        =>:
            interval_length(K) = finite_set_sum(F(K), fn(J F(K)) R {interval_length(J)})
    by thm refinement_fiber_family_is_finite_unique_cover(I, Pfine, Pcoarse, F)
    $is_finite_unique_cover_of(Pfine, nonempty_refinement_support(Pfine), Pcoarse, F)
    $is_finite_indexed_subfamily(Pfine, nonempty_refinement_support(Pfine), Pcoarse, F)
    $is_finite_set(F(K))
    F(K) = refinement_fiber(Pfine, K)
    by thm refinement_fiber_has_value(Pfine, K)
    $is_refinement_fiber(Pfine, K, refinement_fiber(Pfine, K))
    $is_refinement_fiber(Pfine, K, F(K))
    by thm refinement_fiber_partitions_coarse_piece(I, Pfine, Pcoarse, F(K), K)
    $is_partition_of_bounded_interval(K, F(K))
    by thm interval_length_is_finitely_additive_over_partition(K, F(K))
    interval_length(K) = finite_set_sum(F(K), fn(J F(K)) R {interval_length(J)})


# 11.2 Piecewise constant functions

"""
Definition 11.2.1 (Constant functions).  A function is constant on a set when
there is a real number `c` such that every value on the set equals `c`.
"""

prop has_constant_value_on_subset(I power_set(R), E power_set(R), f fn(x I) R, c R):
    E $subset I
    forall x E:
        f(x) = c

prop is_constant_on_subset(I power_set(R), E power_set(R), f fn(x I) R):
    exist c R st {$has_constant_value_on_subset(I, E, f, c)}

"""
Remark 11.2.2.  On a non-empty set, the constant value is unique; on the empty
set every real number is vacuously a constant value.
"""

thm nonempty_constant_value_unique:
    ? forall I power_set(R), E power_set(R), f fn(x I) R, c1, c2 R:
        E $subset I
        $is_nonempty_set(E)
        forall x E:
            f(x) = c1
        forall x E:
            f(x) = c2
        =>:
            c1 = c2
    # Source handling: this is the direct non-empty witness argument in the
    # remark.
    have x E
    f(x) = c1
    f(x) = c2
    c1 = f(x) = c2

thm constant_on_subset_add:
    ? forall I power_set(R), E power_set(R), f, g fn(x I) R:
        E $subset I
        $is_constant_on_subset(I, E, f)
        $is_constant_on_subset(I, E, g)
        =>:
            $is_constant_on_subset(I, E, fn(x I) R {f(x) + g(x)})
    # Source handling: this is the same-piece algebra step used in Exercise
    # 11.2.2 before passing to a common refinement.
    obtain cf from exist c R st {$has_constant_value_on_subset(I, E, f, c)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, E, g, c)}
    witness exist c R st {$has_constant_value_on_subset(I, E, fn(x I) R {f(x) + g(x)}, c)} from cf + cg:
        E $subset I
        forall x E:
            x $in I
            f(x) = cf
            g(x) = cg
            fn(x I) R {f(x) + g(x)}(x) = f(x) + g(x)
            fn(x I) R {f(x) + g(x)}(x) = cf + cg
        $has_constant_value_on_subset(I, E, fn(x I) R {f(x) + g(x)}, cf + cg)
    $is_constant_on_subset(I, E, fn(x I) R {f(x) + g(x)})

thm constant_on_subset_sub:
    ? forall I power_set(R), E power_set(R), f, g fn(x I) R:
        E $subset I
        $is_constant_on_subset(I, E, f)
        $is_constant_on_subset(I, E, g)
        =>:
            $is_constant_on_subset(I, E, fn(x I) R {f(x) - g(x)})
    # Source handling: this is the same-piece subtraction step used in
    # Exercise 11.2.2.
    obtain cf from exist c R st {$has_constant_value_on_subset(I, E, f, c)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, E, g, c)}
    witness exist c R st {$has_constant_value_on_subset(I, E, fn(x I) R {f(x) - g(x)}, c)} from cf - cg:
        E $subset I
        forall x E:
            x $in I
            f(x) = cf
            g(x) = cg
            fn(x I) R {f(x) - g(x)}(x) = f(x) - g(x)
            fn(x I) R {f(x) - g(x)}(x) = cf - cg
        $has_constant_value_on_subset(I, E, fn(x I) R {f(x) - g(x)}, cf - cg)
    $is_constant_on_subset(I, E, fn(x I) R {f(x) - g(x)})

thm constant_on_subset_mul:
    ? forall I power_set(R), E power_set(R), f, g fn(x I) R:
        E $subset I
        $is_constant_on_subset(I, E, f)
        $is_constant_on_subset(I, E, g)
        =>:
            $is_constant_on_subset(I, E, fn(x I) R {f(x) * g(x)})
    # Source handling: this is the same-piece multiplication step used in
    # Exercise 11.2.2.
    obtain cf from exist c R st {$has_constant_value_on_subset(I, E, f, c)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, E, g, c)}
    witness exist c R st {$has_constant_value_on_subset(I, E, fn(x I) R {f(x) * g(x)}, c)} from cf * cg:
        E $subset I
        forall x E:
            x $in I
            f(x) = cf
            g(x) = cg
            fn(x I) R {f(x) * g(x)}(x) = f(x) * g(x)
            fn(x I) R {f(x) * g(x)}(x) = cf * cg
        $has_constant_value_on_subset(I, E, fn(x I) R {f(x) * g(x)}, cf * cg)
    $is_constant_on_subset(I, E, fn(x I) R {f(x) * g(x)})

thm constant_on_subset_max:
    ? forall I power_set(R), E power_set(R), f, g fn(x I) R:
        E $subset I
        $is_constant_on_subset(I, E, f)
        $is_constant_on_subset(I, E, g)
        =>:
            $is_constant_on_subset(I, E, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
    # Source handling: this is the same-piece maximum step used in Exercise
    # 11.2.2.
    obtain cf from exist c R st {$has_constant_value_on_subset(I, E, f, c)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, E, g, c)}
    witness exist c R st {$has_constant_value_on_subset(I, E, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}, c)} from finite_set_max(union({cf}, { cg})):
        E $subset I
        forall x E:
            x $in I
            f(x) = cf
            g(x) = cg
            fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}(x) = finite_set_max(union({f(x)}, { g(x)}))
            fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}(x) = finite_set_max(union({cf}, { cg}))
        $has_constant_value_on_subset(I, E, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}, finite_set_max(union({cf}, { cg})))
    $is_constant_on_subset(I, E, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})

thm constant_on_subset_min:
    ? forall I power_set(R), E power_set(R), f, g fn(x I) R:
        E $subset I
        $is_constant_on_subset(I, E, f)
        $is_constant_on_subset(I, E, g)
        =>:
            $is_constant_on_subset(I, E, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))})
    # Source handling: this is the same-piece minimum step used in Theorem
    # 11.4.3.
    obtain cf from exist c R st {$has_constant_value_on_subset(I, E, f, c)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, E, g, c)}
    witness exist c R st {$has_constant_value_on_subset(I, E, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))}, c)} from finite_set_min(union({cf}, { cg})):
        E $subset I
        forall x E:
            x $in I
            f(x) = cf
            g(x) = cg
            fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))}(x) = finite_set_min(union({f(x)}, { g(x)}))
            fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))}(x) = finite_set_min(union({cf}, { cg}))
        $has_constant_value_on_subset(I, E, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))}, finite_set_min(union({cf}, { cg})))
    $is_constant_on_subset(I, E, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))})

thm constant_on_subset_scalar_mul:
    ? forall I power_set(R), E power_set(R), f fn(x I) R, c R:
        E $subset I
        $is_constant_on_subset(I, E, f)
        =>:
            $is_constant_on_subset(I, E, fn(x I) R {c * f(x)})
    # Source handling: scalar multiplication is another same-piece algebra
    # step used by the linearity laws.
    obtain cf from exist cf R st {$has_constant_value_on_subset(I, E, f, cf)}
    witness exist c0 R st {$has_constant_value_on_subset(I, E, fn(x I) R {c * f(x)}, c0)} from c * cf:
        E $subset I
        forall x E:
            x $in I
            f(x) = cf
            fn(x I) R {c * f(x)}(x) = c * f(x)
            fn(x I) R {c * f(x)}(x) = c * cf
        $has_constant_value_on_subset(I, E, fn(x I) R {c * f(x)}, c * cf)
    $is_constant_on_subset(I, E, fn(x I) R {c * f(x)})

thm constant_on_subset_quotient:
    ? forall I power_set(R), E power_set(R), f, g fn(x I) R:
        E $subset I
        $is_constant_on_subset(I, E, f)
        $is_constant_on_subset(I, E, g)
        $chap10::is_nonzero_on(I, g)
        =>:
            $is_constant_on_subset(I, E, fn(x I) R {f(x) / g(x)})
    # Source handling: this is the same-piece quotient step used in Exercise
    # 11.2.2 when the denominator is nonzero on the whole interval.
    obtain cf from exist c R st {$has_constant_value_on_subset(I, E, f, c)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, E, g, c)}
    by cases:
        ? $is_constant_on_subset(I, E, fn(x I) R {f(x) / g(x)})
        case $is_nonempty_set(E):
            have x0 E
            x0 $in I
            g(x0) = cg
            g(x0) != 0
            cg != 0
            witness exist c0 R st {$has_constant_value_on_subset(I, E, fn(x I) R {f(x) / g(x)}, c0)} from cf / cg:
                E $subset I
                forall x E:
                    x $in I
                    f(x) = cf
                    g(x) = cg
                    g(x) != 0
                    cg != 0
                    fn(x I) R {f(x) / g(x)}(x) = f(x) / g(x)
                    fn(x I) R {f(x) / g(x)}(x) = cf / cg
                $has_constant_value_on_subset(I, E, fn(x I) R {f(x) / g(x)}, cf / cg)
        case not $is_nonempty_set(E):
            witness exist c0 R st {$has_constant_value_on_subset(I, E, fn(x I) R {f(x) / g(x)}, c0)} from 0:
                E $subset I
                claim:
                    ? forall x E:
                        fn(x I) R {f(x) / g(x)}(x) = 0
                    by contra:
                        ? fn(x I) R {f(x) / g(x)}(x) = 0
                        x $in E
                        not $is_nonempty_set(E)
                        witness $is_nonempty_set(E) from x
                        impossible $is_nonempty_set(E)
                $has_constant_value_on_subset(I, E, fn(x I) R {f(x) / g(x)}, 0)

"""
Definition 11.2.3 (Piecewise constant functions I).  A function is piecewise
constant with respect to a partition when it is constant on each partition
piece.
"""

prop is_piecewise_constant_with_partition(I power_set(R), P finite_set, f fn(x I) R):
    $is_partition_of_bounded_interval(I, P)
    forall J P:
        J $in power_set(R)
        $is_constant_on_subset(I, J, f)

thm piecewise_constant_same_partition_add:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        $is_piecewise_constant_with_partition(I, P, g)
        =>:
            $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) + g(x)})
    # Source handling: this proves the easy same-partition part of the
    # addition law; the full law still needs a common refinement.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {f(x) + g(x)})
        J $in power_set(R)
        J $subset I
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        by thm constant_on_subset_add(I, J, f, g)
        $is_constant_on_subset(I, J, fn(x I) R {f(x) + g(x)})
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) + g(x)})

thm piecewise_constant_same_partition_sub:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        $is_piecewise_constant_with_partition(I, P, g)
        =>:
            $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) - g(x)})
    # Source handling: this proves the easy same-partition part of the
    # subtraction law.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {f(x) - g(x)})
        J $in power_set(R)
        J $subset I
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        by thm constant_on_subset_sub(I, J, f, g)
        $is_constant_on_subset(I, J, fn(x I) R {f(x) - g(x)})
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) - g(x)})

thm piecewise_constant_same_partition_mul:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        $is_piecewise_constant_with_partition(I, P, g)
        =>:
            $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) * g(x)})
    # Source handling: this proves the easy same-partition part of the
    # multiplication law.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {f(x) * g(x)})
        J $in power_set(R)
        J $subset I
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        by thm constant_on_subset_mul(I, J, f, g)
        $is_constant_on_subset(I, J, fn(x I) R {f(x) * g(x)})
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) * g(x)})

thm piecewise_constant_same_partition_max:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        $is_piecewise_constant_with_partition(I, P, g)
        =>:
            $is_piecewise_constant_with_partition(I, P, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
    # Source handling: this proves the easy same-partition part of the maximum
    # law.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
        J $in power_set(R)
        J $subset I
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        by thm constant_on_subset_max(I, J, f, g)
        $is_constant_on_subset(I, J, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})

thm piecewise_constant_same_partition_min:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        $is_piecewise_constant_with_partition(I, P, g)
        =>:
            $is_piecewise_constant_with_partition(I, P, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))})
    # Source handling: this proves the easy same-partition part of the
    # minimum law.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))})
        J $in power_set(R)
        J $subset I
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        by thm constant_on_subset_min(I, J, f, g)
        $is_constant_on_subset(I, J, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))})
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))})

thm piecewise_constant_same_partition_scalar_mul:
    ? forall I power_set(R), P finite_set, f fn(x I) R, c R:
        $is_piecewise_constant_with_partition(I, P, f)
        =>:
            $is_piecewise_constant_with_partition(I, P, fn(x I) R {c * f(x)})
    # Source handling: this is the same-partition scalar multiplication step.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {c * f(x)})
        J $in power_set(R)
        J $subset I
        $is_constant_on_subset(I, J, f)
        by thm constant_on_subset_scalar_mul(I, J, f, c)
        $is_constant_on_subset(I, J, fn(x I) R {c * f(x)})
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {c * f(x)})

thm piecewise_constant_same_partition_quotient:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        $is_piecewise_constant_with_partition(I, P, g)
        $chap10::is_nonzero_on(I, g)
        =>:
            $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) / g(x)})
    # Source handling: this is the same-partition quotient step.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {f(x) / g(x)})
        J $in power_set(R)
        J $subset I
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        by thm constant_on_subset_quotient(I, J, f, g)
        $is_constant_on_subset(I, J, fn(x I) R {f(x) / g(x)})
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) / g(x)})

"""
Example 11.2.4.  The function on `[1,6]` with values `7` on `[1,3)`, `4` at
`3`, `5` on `(3,6)`, and `2` at `6` is piecewise constant for the displayed
partition and for any refinement that keeps the same constant pieces.
"""

prop is_example_11_2_4_function(f fn(x '[1, 6]) R):
    forall x '[1, 6]:
        x < 3
        =>:
            f(x) = 7
    forall x '[1, 6]:
        x = 3
        =>:
            f(x) = 4
    forall x '[1, 6]:
        x > 3
        x < 6
        =>:
            f(x) = 5
    forall x '[1, 6]:
        x = 6
        =>:
            f(x) = 2

prop is_example_11_2_4_displayed_partition(P finite_set):
    '[1, 3) $in P
    {3} $in P
    '(3, 6) $in P
    {6} $in P
    forall J P:
        J = '[1, 3) or J = {3} or J = '(3, 6) or J = {6}

prop is_example_11_2_4_book_refined_partition(P finite_set):
    '[1, 2) $in P
    {2} $in P
    '(2, 3) $in P
    {3} $in P
    '(3, 5) $in P
    '[5, 6) $in P
    {6} $in P
    {} $in P
    forall J P:
        J = '[1, 2) or J = {2} or J = '(2, 3) or J = {3} or J = '(3, 5) or J = '[5, 6) or J = {6} or J = {}

prop is_example_11_2_4_constant_preserving_partition(P finite_set):
    $is_partition_of_bounded_interval('[1, 6], P)
    forall J P:
        J $subset '[1, 3) or J $subset {3} or J $subset '(3, 6) or J $subset {6}

thm example_11_2_4_piecewise_constant_for_constant_preserving_partitions:
    ? forall f fn(x '[1, 6]) R, P finite_set:
        $is_example_11_2_4_function(f)
        $is_example_11_2_4_constant_preserving_partition(P)
        =>:
            $is_piecewise_constant_with_partition('[1, 6], P, f)
    # Source handling: each piece of such a partition sits inside one of the
    # four regions on which the displayed function has a fixed value.
    $is_partition_of_bounded_interval('[1, 6], P)
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset('[1, 6], J, f)
        J $in power_set(R)
        J $subset '[1, 6]
        J $subset '[1, 3) or J $subset {3} or J $subset '(3, 6) or J $subset {6}
        by cases:
            ? $is_constant_on_subset('[1, 6], J, f)
            case J $subset '[1, 3):
                witness exist c R st {$has_constant_value_on_subset('[1, 6], J, f, c)} from 7:
                    J $subset '[1, 6]
                    forall x J:
                        x $in '[1, 6]
                        x $in '[1, 3)
                        x < 3
                        f(x) = 7
                    $has_constant_value_on_subset('[1, 6], J, f, 7)
            case J $subset {3}:
                witness exist c R st {$has_constant_value_on_subset('[1, 6], J, f, c)} from 4:
                    J $subset '[1, 6]
                    forall x J:
                        x $in '[1, 6]
                        x $in {3}
                        x = 3
                        f(x) = 4
                    $has_constant_value_on_subset('[1, 6], J, f, 4)
            case J $subset '(3, 6):
                witness exist c R st {$has_constant_value_on_subset('[1, 6], J, f, c)} from 5:
                    J $subset '[1, 6]
                    forall x J:
                        x $in '[1, 6]
                        x $in '(3, 6)
                        3 < x
                        x > 3
                        x < 6
                        f(x) = 5
                    $has_constant_value_on_subset('[1, 6], J, f, 5)
            case J $subset {6}:
                witness exist c R st {$has_constant_value_on_subset('[1, 6], J, f, c)} from 2:
                    J $subset '[1, 6]
                    forall x J:
                        x $in '[1, 6]
                        x $in {6}
                        x = 6
                        f(x) = 2
                    $has_constant_value_on_subset('[1, 6], J, f, 2)
        $is_constant_on_subset('[1, 6], J, f)
    $is_piecewise_constant_with_partition('[1, 6], P, f)

"""
Definition 11.2.5 (Piecewise constant functions II).  A function is piecewise
constant on `I` if some partition of `I` makes it piecewise constant.
"""

prop is_piecewise_constant_on(I power_set(R), f fn(x I) R):
    exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f)}

thm piecewise_constant_with_partition_is_piecewise_constant:
    ? forall I power_set(R), P finite_set, f fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        =>:
            $is_piecewise_constant_on(I, f)
    # Source handling: this is just Definition 11.2.5 with the displayed
    # partition as witness.
    witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, f)} from P:
        $is_piecewise_constant_with_partition(I, P, f)
    $is_piecewise_constant_on(I, f)

"""
Example 11.2.6.  The previous example is piecewise constant on `[1,6]`, and
every constant function on a bounded interval is piecewise constant.
"""

thm constant_function_is_piecewise_constant_with_one_piece_partition:
    ? forall I power_set(R), c R:
        $is_bounded_interval(I)
        =>:
            $is_piecewise_constant_with_partition(I, {I}, fn(x I) R {c})
    # Source handling: the single piece is the whole interval, so the displayed
    # constant function has value `c` on every point of that piece.
    by thm one_piece_partition_of_bounded_interval(I)
    $is_partition_of_bounded_interval(I, {I})
    claim:
        ? forall J {I}:
            J $in power_set(R)
            $is_constant_on_subset(I, J, fn(x I) R {c})
        J = I
        J $in power_set(R)
        J $subset I
        witness exist c0 R st {$has_constant_value_on_subset(I, J, fn(x I) R {c}, c0)} from c:
            J $subset I
            forall x J:
                x $in I
                fn(x I) R {c}(x) = c
            $has_constant_value_on_subset(I, J, fn(x I) R {c}, c)
        $is_constant_on_subset(I, J, fn(x I) R {c})
    $is_piecewise_constant_with_partition(I, {I}, fn(x I) R {c})

thm constant_function_is_piecewise_constant:
    ? forall I power_set(R), c R:
        $is_bounded_interval(I)
        =>:
            $is_piecewise_constant_on(I, fn(x I) R {c})
    # Source handling: Tao marks this as `(why?)`; the one-piece partition
    # `{I}` witnesses piecewise constancy.
    by thm constant_function_is_piecewise_constant_with_one_piece_partition(I, c)
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {c})} from {I}:
        $is_piecewise_constant_with_partition(I, {I}, fn(x I) R {c})
    $is_piecewise_constant_on(I, fn(x I) R {c})

"""
Lemma 11.2.7.  If a partition is refined, a function piecewise constant on the
coarser partition remains piecewise constant on the finer partition.
"""

thm piecewise_constant_refines:
    ? forall I power_set(R), Pcoarse, Pfine finite_set, f fn(x I) R:
        $is_piecewise_constant_with_partition(I, Pcoarse, f)
        $is_finer_partition_than(I, Pfine, Pcoarse)
        =>:
            $is_piecewise_constant_with_partition(I, Pfine, f)
    # Source handling: Tao proves this in Exercise 11.2.1.
    # Each fine piece lies in a coarse piece, and the coarse constant value
    # restricts to the fine piece.
    $is_partition_of_bounded_interval(I, Pfine)
    claim:
        ? forall J Pfine:
            J $in power_set(R)
            $is_constant_on_subset(I, J, f)
        J $in power_set(R)
        J $subset I
        obtain K from exist K Pcoarse st {J $in power_set(R), K $in power_set(R), J $subset K}
        K $in power_set(R)
        J $subset K
        $is_constant_on_subset(I, K, f)
        obtain c from exist c R st {$has_constant_value_on_subset(I, K, f, c)}
        witness exist c0 R st {$has_constant_value_on_subset(I, J, f, c0)} from c:
            J $subset I
            forall x J:
                x $in K
                f(x) = c
            $has_constant_value_on_subset(I, J, f, c)
        $is_constant_on_subset(I, J, f)
    $is_piecewise_constant_with_partition(I, Pfine, f)

"""
Lemma 11.2.8.  Piecewise constant functions are closed under addition,
subtraction, max, min, multiplication, and quotients by non-vanishing
denominators.
"""

thm piecewise_constant_algebra:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_piecewise_constant_on(I, f)
        $is_piecewise_constant_on(I, g)
        =>:
            $is_piecewise_constant_on(I, fn(x I) R {f(x) + g(x)})
            $is_piecewise_constant_on(I, fn(x I) R {f(x) - g(x)})
            $is_piecewise_constant_on(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
            $is_piecewise_constant_on(I, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))})
            $is_piecewise_constant_on(I, fn(x I) R {f(x) * g(x)})
    # Source handling: Tao proves this in Exercise 11.2.2 by passing to a
    # common refinement.
    obtain Pf from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f)}
    obtain Pg from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, g)}
    $is_partition_of_bounded_interval(I, Pf)
    $is_partition_of_bounded_interval(I, Pg)
    by thm partition_is_set_of_real_subsets(I, Pf)
    by thm partition_is_set_of_real_subsets(I, Pg)
    have Rf finite_set = common_refinement(I, Pf, Pg)
    $is_common_refinement_of_partitions(I, Pf, Pg, Rf)
    by thm common_refinement_is_partition_and_finer(I, Pf, Pg, Rf)
    by thm piecewise_constant_refines(I, Pf, Rf, f)
    by thm piecewise_constant_refines(I, Pg, Rf, g)
    by thm piecewise_constant_same_partition_add(I, Rf, f, g)
    by thm piecewise_constant_same_partition_sub(I, Rf, f, g)
    by thm piecewise_constant_same_partition_max(I, Rf, f, g)
    by thm piecewise_constant_same_partition_min(I, Rf, f, g)
    by thm piecewise_constant_same_partition_mul(I, Rf, f, g)
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) + g(x)})} from Rf:
        $is_piecewise_constant_with_partition(I, Rf, fn(x I) R {f(x) + g(x)})
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) - g(x)})} from Rf:
        $is_piecewise_constant_with_partition(I, Rf, fn(x I) R {f(x) - g(x)})
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})} from Rf:
        $is_piecewise_constant_with_partition(I, Rf, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))})} from Rf:
        $is_piecewise_constant_with_partition(I, Rf, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))})
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) * g(x)})} from Rf:
        $is_piecewise_constant_with_partition(I, Rf, fn(x I) R {f(x) * g(x)})
    $is_piecewise_constant_on(I, fn(x I) R {f(x) + g(x)})
    $is_piecewise_constant_on(I, fn(x I) R {f(x) - g(x)})
    $is_piecewise_constant_on(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
    $is_piecewise_constant_on(I, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))})
    $is_piecewise_constant_on(I, fn(x I) R {f(x) * g(x)})

thm piecewise_constant_quotient:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_piecewise_constant_on(I, f)
        $is_piecewise_constant_on(I, g)
        $chap10::is_nonzero_on(I, g)
        =>:
            $is_piecewise_constant_on(I, fn(x I) R {f(x) / g(x)})
    # Source handling: this is the quotient clause of Exercise 11.2.2.
    obtain Pf from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f)}
    obtain Pg from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, g)}
    $is_partition_of_bounded_interval(I, Pf)
    $is_partition_of_bounded_interval(I, Pg)
    by thm partition_is_set_of_real_subsets(I, Pf)
    by thm partition_is_set_of_real_subsets(I, Pg)
    have Rf finite_set = common_refinement(I, Pf, Pg)
    $is_common_refinement_of_partitions(I, Pf, Pg, Rf)
    by thm common_refinement_is_partition_and_finer(I, Pf, Pg, Rf)
    by thm piecewise_constant_refines(I, Pf, Rf, f)
    by thm piecewise_constant_refines(I, Pg, Rf, g)
    by thm piecewise_constant_same_partition_quotient(I, Rf, f, g)
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) / g(x)})} from Rf:
        $is_piecewise_constant_with_partition(I, Rf, fn(x I) R {f(x) / g(x)})
    $is_piecewise_constant_on(I, fn(x I) R {f(x) / g(x)})

"""
Definition 11.2.9 (Piecewise constant integral I).  With respect to a
partition `P`, the piecewise constant integral is the finite sum of each
constant value on a piece times that piece's length.
"""

prop has_piecewise_constant_integral_piece_contribution(I power_set(R), J power_set(R), f fn(x I) R, t R):
    $is_bounded_interval(J)
    $is_constant_on_subset(I, J, f)
    exist c R st {$has_constant_value_on_subset(I, J, f, c), t = c * interval_length(J)}

thm piecewise_constant_integral_piece_contribution_unique:
    ? forall I, J power_set(R), f fn(x I) R, t1, t2 R:
        $has_piecewise_constant_integral_piece_contribution(I, J, f, t1)
        $has_piecewise_constant_integral_piece_contribution(I, J, f, t2)
        =>:
            t1 = t2
    # Source handling: on a non-empty piece, the constant value is unique; on
    # the empty piece, every constant value gives contribution zero because
    # `interval_length({}) = 0`.
    obtain c1 from exist c R st {$has_constant_value_on_subset(I, J, f, c), t1 = c * interval_length(J)}
    obtain c2 from exist c R st {$has_constant_value_on_subset(I, J, f, c), t2 = c * interval_length(J)}
    $has_constant_value_on_subset(I, J, f, c1)
    $has_constant_value_on_subset(I, J, f, c2)
    t1 = c1 * interval_length(J)
    t2 = c2 * interval_length(J)
    by cases:
        ? t1 = t2
        case $is_nonempty_set(J):
            by thm nonempty_constant_value_unique(I, J, f, c1, c2)
            c1 = c2
            t1 = c1 * interval_length(J) = c2 * interval_length(J) = t2
        case not $is_nonempty_set(J):
            by thm empty_bounded_interval_length_value(J)
            t1 = c1 * interval_length(J) = c1 * 0 = 0
            t2 = c2 * interval_length(J) = c2 * 0 = 0
            t1 = t2

have fn piecewise_constant_integral_piece_contribution by exist!:
    ? forall I, J power_set(R), f fn(x I) R:
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        =>:
            exist! t R st {$has_piecewise_constant_integral_piece_contribution(I, J, f, t)}
    obtain cv from exist c R st {$has_constant_value_on_subset(I, J, f, c)}
    witness exist t R st {$has_piecewise_constant_integral_piece_contribution(I, J, f, t)} from cv * interval_length(J):
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        witness exist c R st {$has_constant_value_on_subset(I, J, f, c), cv * interval_length(J) = c * interval_length(J)} from cv:
            $has_constant_value_on_subset(I, J, f, cv)
            cv * interval_length(J) = cv * interval_length(J)
        exist c R st {$has_constant_value_on_subset(I, J, f, c), cv * interval_length(J) = c * interval_length(J)}
        $has_piecewise_constant_integral_piece_contribution(I, J, f, cv * interval_length(J))
    claim:
        ? forall t1, t2 R:
            $has_piecewise_constant_integral_piece_contribution(I, J, f, t1)
            $has_piecewise_constant_integral_piece_contribution(I, J, f, t2)
            =>:
                t1 = t2
        by thm piecewise_constant_integral_piece_contribution_unique(I, J, f, t1, t2)
    exist! t R st {$has_piecewise_constant_integral_piece_contribution(I, J, f, t)}

thm piecewise_constant_integral_piece_contribution_has_value:
    ? forall I, J power_set(R), f fn(x I) R, t R:
        $has_piecewise_constant_integral_piece_contribution(I, J, f, t)
        =>:
            piecewise_constant_integral_piece_contribution(I, J, f) = t
    $is_bounded_interval(J)
    $is_constant_on_subset(I, J, f)
    $has_piecewise_constant_integral_piece_contribution(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f))
    by thm piecewise_constant_integral_piece_contribution_unique(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f), t)
    piecewise_constant_integral_piece_contribution(I, J, f) = t

# A constant rectangle may be split across any finite partition once the
# corresponding length-additivity equality is available.  Refinement fibers
# are one later caller; keeping this statement independent of their origin
# makes the finite geometric step reusable.
thm constant_rectangle_reindexes_over_partition:
    ? forall I, K power_set(R), F finite_set, f fn(x I) R, c R:
        $is_bounded_interval(K)
        $has_constant_value_on_subset(I, K, f, c)
        $is_partition_of_bounded_interval(K, F)
        interval_length(K) = finite_set_sum(F, fn(J F) R {interval_length(J)})
        =>:
            piecewise_constant_integral_piece_contribution(I, K, f) = finite_set_sum(F, fn(J F) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    claim:
        ? $has_piecewise_constant_integral_piece_contribution(I, K, f, c * interval_length(K))
        witness exist c0 R st {$has_constant_value_on_subset(I, K, f, c0), c * interval_length(K) = c0 * interval_length(K)} from c:
            $has_constant_value_on_subset(I, K, f, c)
            c * interval_length(K) = c * interval_length(K)
        $has_piecewise_constant_integral_piece_contribution(I, K, f, c * interval_length(K))
    by thm piecewise_constant_integral_piece_contribution_has_value(I, K, f, c * interval_length(K))
    piecewise_constant_integral_piece_contribution(I, K, f) = c * interval_length(K)
    claim:
        ? forall J F:
            piecewise_constant_integral_piece_contribution(I, J, f) = c * interval_length(J)
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset K
        claim:
            ? $has_constant_value_on_subset(I, J, f, c)
            J $subset K
            K $subset I
            J $subset I
            forall x J:
                x $in K
                f(x) = c
            $has_constant_value_on_subset(I, J, f, c)
        claim:
            ? $has_piecewise_constant_integral_piece_contribution(I, J, f, c * interval_length(J))
            witness exist c0 R st {$has_constant_value_on_subset(I, J, f, c0), c * interval_length(J) = c0 * interval_length(J)} from c:
                $has_constant_value_on_subset(I, J, f, c)
                c * interval_length(J) = c * interval_length(J)
            $has_piecewise_constant_integral_piece_contribution(I, J, f, c * interval_length(J))
        by thm piecewise_constant_integral_piece_contribution_has_value(I, J, f, c * interval_length(J))
        piecewise_constant_integral_piece_contribution(I, J, f) = c * interval_length(J)
    claim:
        ? $fn_eq(fn(J F) R {piecewise_constant_integral_piece_contribution(I, J, f)}, fn(J F) R {c * interval_length(J)})
        forall J F:
            piecewise_constant_integral_piece_contribution(I, J, f) = c * interval_length(J)
            fn(J F) R {piecewise_constant_integral_piece_contribution(I, J, f)}(J) = piecewise_constant_integral_piece_contribution(I, J, f)
            fn(J F) R {c * interval_length(J)}(J) = c * interval_length(J)
            fn(J F) R {piecewise_constant_integral_piece_contribution(I, J, f)}(J) = fn(J F) R {c * interval_length(J)}(J)
        $fn_eq(fn(J F) R {piecewise_constant_integral_piece_contribution(I, J, f)}, fn(J F) R {c * interval_length(J)})
    fn(J F) R {piecewise_constant_integral_piece_contribution(I, J, f)} = fn(J F) R {c * interval_length(J)}
    finite_set_sum(F, fn(J F) R {piecewise_constant_integral_piece_contribution(I, J, f)}) = finite_set_sum(F, fn(J F) R {c * interval_length(J)})
    by thm chap7::finite_set_sum_scalar_mul(F, fn(J F) R {interval_length(J)}, c)
    finite_set_sum(F, fn(J F) R {c * interval_length(J)}) = c * finite_set_sum(F, fn(J F) R {interval_length(J)})
    piecewise_constant_integral_piece_contribution(I, K, f) = c * interval_length(K) = c * finite_set_sum(F, fn(J F) R {interval_length(J)}) = finite_set_sum(F, fn(J F) R {piecewise_constant_integral_piece_contribution(I, J, f)})

thm piecewise_constant_integral_piece_contribution_add:
    ? forall I, J power_set(R), f, g fn(x I) R, sf, sg R:
        $has_piecewise_constant_integral_piece_contribution(I, J, f, sf)
        $has_piecewise_constant_integral_piece_contribution(I, J, g, sg)
        =>:
            $has_piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {f(x) + g(x)}, sf + sg)
    # Source handling: on one partition piece, the rectangle for `f+g` is the
    # sum of the two rectangles because the two constant values share the same
    # interval length.
    obtain cf from exist c R st {$has_constant_value_on_subset(I, J, f, c), sf = c * interval_length(J)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, J, g, c), sg = c * interval_length(J)}
    $is_bounded_interval(J)
    $has_constant_value_on_subset(I, J, f, cf)
    $has_constant_value_on_subset(I, J, g, cg)
    sf = cf * interval_length(J)
    sg = cg * interval_length(J)
    claim:
        ? $has_constant_value_on_subset(I, J, fn(x I) R {f(x) + g(x)}, cf + cg)
        J $subset I
        forall x J:
            x $in I
            f(x) = cf
            g(x) = cg
            fn(x I) R {f(x) + g(x)}(x) = f(x) + g(x)
            fn(x I) R {f(x) + g(x)}(x) = cf + cg
    sf + sg = cf * interval_length(J) + cg * interval_length(J) = (cf + cg) * interval_length(J)
    witness exist c R st {$has_constant_value_on_subset(I, J, fn(x I) R {f(x) + g(x)}, c), sf + sg = c * interval_length(J)} from cf + cg:
        $has_constant_value_on_subset(I, J, fn(x I) R {f(x) + g(x)}, cf + cg)
        sf + sg = (cf + cg) * interval_length(J)
    $has_piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {f(x) + g(x)}, sf + sg)

thm piecewise_constant_integral_piece_contribution_scalar_mul:
    ? forall I, J power_set(R), f fn(x I) R, sf, c R:
        $has_piecewise_constant_integral_piece_contribution(I, J, f, sf)
        =>:
            $has_piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {c * f(x)}, c * sf)
    # Source handling: multiplying a constant rectangle by `c` multiplies its
    # height and therefore its contribution by `c`.
    obtain cf from exist c0 R st {$has_constant_value_on_subset(I, J, f, c0), sf = c0 * interval_length(J)}
    $is_bounded_interval(J)
    $has_constant_value_on_subset(I, J, f, cf)
    sf = cf * interval_length(J)
    claim:
        ? $has_constant_value_on_subset(I, J, fn(x I) R {c * f(x)}, c * cf)
        J $subset I
        forall x J:
            x $in I
            f(x) = cf
            fn(x I) R {c * f(x)}(x) = c * f(x)
            fn(x I) R {c * f(x)}(x) = c * cf
    c * sf = c * (cf * interval_length(J)) = (c * cf) * interval_length(J)
    witness exist c0 R st {$has_constant_value_on_subset(I, J, fn(x I) R {c * f(x)}, c0), c * sf = c0 * interval_length(J)} from c * cf:
        $has_constant_value_on_subset(I, J, fn(x I) R {c * f(x)}, c * cf)
        c * sf = (c * cf) * interval_length(J)
    $has_piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {c * f(x)}, c * sf)

thm piecewise_constant_partition_is_set_of_real_subsets:
    ? forall I power_set(R), P finite_set, f fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        =>:
            P $in power_set(power_set(R))
    # Source handling: every member of a partition is a bounded interval, hence
    # a real subset.  This bridge exposes the type fact needed by the
    # function-valued notation below.
    $is_partition_of_bounded_interval(I, P)
    claim:
        ? P $subset power_set(R)
        forall J P:
            J $in power_set(R)
        P $subset power_set(R)
    P $in power_set(power_set(R))

have fn piecewise_constant_integral_with_partition(I power_set(R), P power_set(power_set(R)), f fn(x I) R: $is_finite_set(P), $is_piecewise_constant_with_partition(I, P, f)) R = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)})

prop has_piecewise_constant_integral_with_partition(I power_set(R), P finite_set, f fn(x I) R, s R):
    P $in power_set(power_set(R))
    $is_piecewise_constant_with_partition(I, P, f)
    s = piecewise_constant_integral_with_partition(I, P, f)

thm piecewise_constant_integral_with_partition_has_value:
    ? forall I power_set(R), P finite_set, f fn(x I) R:
        P $in power_set(power_set(R))
        $is_piecewise_constant_with_partition(I, P, f)
        =>:
            $has_piecewise_constant_integral_with_partition(I, P, f, piecewise_constant_integral_with_partition(I, P, f))

thm one_piece_piecewise_constant_integral_with_partition_value:
    ? forall I power_set(R), f fn(x I) R, t R:
        $is_piecewise_constant_with_partition(I, {I}, f)
        $has_piecewise_constant_integral_piece_contribution(I, I, f, t)
        =>:
            $has_piecewise_constant_integral_with_partition(I, {I}, f, t)
    # Source handling: on the one-piece partition, Definition 11.2.9 is just
    # the single rectangle contribution of the whole interval.
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, {I}, f)
    {I} $in power_set(power_set(R))
    piecewise_constant_integral_with_partition(I, {I}, f) = finite_set_sum({I}, fn(J {I}) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    finite_set_sum({I}, fn(J {I}) R {piecewise_constant_integral_piece_contribution(I, J, f)}) = piecewise_constant_integral_piece_contribution(I, I, f)
    by thm piecewise_constant_integral_piece_contribution_has_value(I, I, f, t)
    piecewise_constant_integral_piece_contribution(I, I, f) = t
    piecewise_constant_integral_with_partition(I, {I}, f) = t
    $has_piecewise_constant_integral_with_partition(I, {I}, f, t)

"""
Remark 11.2.10.  Empty pieces do not make the value ambiguous because their
length is zero, and the sum is finite because partitions are finite.
"""

"""
Remark 11.2.11.  The piecewise constant integral is the signed-rectangle area
formula for functions that are constant on finitely many pieces.
"""

"""
Example 11.2.12.  The function taking values `2`, `4`, and `6` on the pieces
`[1,3)`, `{3}`, and `(3,4]` has piecewise constant integral `10`, and the same
value is obtained after refining the first piece and adding an empty piece.
"""

prop is_example_11_2_12_function(f fn(x '[1, 4]) R):
    forall x '[1, 4]:
        x < 3
        =>:
            f(x) = 2
    forall x '[1, 4]:
        x = 3
        =>:
            f(x) = 4
    forall x '[1, 4]:
        x > 3
        =>:
            f(x) = 6

thm example_11_2_12_partition_pieces_are_distinct:
    ? forall:
        '[1, 3) != {3}
        '[1, 3) != '(3, 4]
        {3} != '(3, 4]
        '[1, 2) != '[2, 3)
        '[1, 2) != {3}
        '[1, 2) != '(3, 4]
        '[1, 2) != {}
        '[2, 3) != {3}
        '[2, 3) != '(3, 4]
        '[2, 3) != {}
        {3} != {}
        '(3, 4] != {}
    # Source handling: these are concrete endpoint checks needed only so the
    # displayed finite partitions are well-defined finite sets in Litex.
    by contra:
        ? '[1, 3) != {3}
        '[1, 3) = {3}
        1 $in '[1, 3)
        1 $in {3}
        1 = 3
        impossible 1 = 3
    by contra:
        ? '[1, 3) != '(3, 4]
        '[1, 3) = '(3, 4]
        1 $in '[1, 3)
        1 $in '(3, 4]
        3 < 1
        impossible 3 < 1
    by contra:
        ? {3} != '(3, 4]
        {3} = '(3, 4]
        3 $in {3}
        3 $in '(3, 4]
        3 < 3
        impossible 3 < 3
    by contra:
        ? '[1, 2) != '[2, 3)
        '[1, 2) = '[2, 3)
        1 $in '[1, 2)
        1 $in '[2, 3)
        2 <= 1
        impossible 2 <= 1
    by contra:
        ? '[1, 2) != {3}
        '[1, 2) = {3}
        1 $in '[1, 2)
        1 $in {3}
        1 = 3
        impossible 1 = 3
    by contra:
        ? '[1, 2) != '(3, 4]
        '[1, 2) = '(3, 4]
        1 $in '[1, 2)
        1 $in '(3, 4]
        3 < 1
        impossible 3 < 1
    by contra:
        ? '[1, 2) != {}
        '[1, 2) = {}
        1 $in '[1, 2)
        1 $in {}
        not $is_nonempty_set({})
        witness $is_nonempty_set({}) from 1
        impossible $is_nonempty_set({})
    by contra:
        ? '[2, 3) != {3}
        '[2, 3) = {3}
        2 $in '[2, 3)
        2 $in {3}
        2 = 3
        impossible 2 = 3
    by contra:
        ? '[2, 3) != '(3, 4]
        '[2, 3) = '(3, 4]
        2 $in '[2, 3)
        2 $in '(3, 4]
        3 < 2
        impossible 3 < 2
    by contra:
        ? '[2, 3) != {}
        '[2, 3) = {}
        2 $in '[2, 3)
        2 $in {}
        not $is_nonempty_set({})
        witness $is_nonempty_set({}) from 2
        impossible $is_nonempty_set({})
    by contra:
        ? {3} != {}
        {3} = {}
        3 $in {3}
        3 $in {}
        not $is_nonempty_set({})
        witness $is_nonempty_set({}) from 3
        impossible $is_nonempty_set({})
    by contra:
        ? '(3, 4] != {}
        '(3, 4] = {}
        4 $in '(3, 4]
        4 $in {}
        not $is_nonempty_set({})
        witness $is_nonempty_set({}) from 4
        impossible $is_nonempty_set({})

by thm example_11_2_12_partition_pieces_are_distinct()

have example_11_2_12_partition_set finite_set = {'[1, 3), {3}, '(3, 4]}

have example_11_2_12_refined_partition_set finite_set = {'[1, 2), '[2, 3), {3}, '(3, 4], {}}

thm example_11_2_12_displayed_partition_piece_clauses:
    ? forall J example_11_2_12_partition_set:
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset '[1, 4]
    # Source handling: this is the listed-partition case split in Example
    # 11.2.12.
    by enumerate finite_set:
        ? forall K example_11_2_12_partition_set:
            K = '[1, 3) or K = {3} or K = '(3, 4]
    by cases:
        ? J $in power_set(R)
        ? $is_bounded_interval(J)
        ? J $subset '[1, 4]
        case J = '[1, 3):
            by thm non_degenerate_interval_forms_are_bounded_intervals(1, 3)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                forall x J:
                    x $in '[1, 3)
                    1 <= x
                    x < 3
                    x < 3 < 4
                    x < 4
                    x <= 4
                    x $in '[1, 4]
                J $subset '[1, 4]
        case J = {3}:
            by thm singleton_interval_is_bounded(3)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                forall x J:
                    x = 3
                    1 <= x
                    x <= 4
                    x $in '[1, 4]
                J $subset '[1, 4]
        case J = '(3, 4]:
            by thm non_degenerate_interval_forms_are_bounded_intervals(3, 4)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                forall x J:
                    x $in '(3, 4]
                    3 < x
                    x <= 4
                    1 < 3 < x
                    1 < x
                    1 <= x
                    x $in '[1, 4]
                J $subset '[1, 4]

thm example_11_2_12_refined_partition_piece_clauses:
    ? forall J example_11_2_12_refined_partition_set:
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset '[1, 4]
    # Source handling: this is the refined-partition case split in Example
    # 11.2.12.
    by enumerate finite_set:
        ? forall K example_11_2_12_refined_partition_set:
            K = '[1, 2) or K = '[2, 3) or K = {3} or K = '(3, 4] or K = {}
    by cases:
        ? J $in power_set(R)
        ? $is_bounded_interval(J)
        ? J $subset '[1, 4]
        case J = '[1, 2):
            by thm non_degenerate_interval_forms_are_bounded_intervals(1, 2)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                forall x J:
                    x $in '[1, 2)
                    1 <= x
                    x < 2
                    x < 2 < 4
                    x < 4
                    x <= 4
                    x $in '[1, 4]
                J $subset '[1, 4]
        case J = '[2, 3):
            by thm non_degenerate_interval_forms_are_bounded_intervals(2, 3)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                forall x J:
                    x $in '[2, 3)
                    2 <= x
                    x < 3
                    1 < 2 <= x
                    1 <= x
                    x < 3 < 4
                    x < 4
                    x <= 4
                    x $in '[1, 4]
                J $subset '[1, 4]
        case J = {3}:
            by thm singleton_interval_is_bounded(3)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                forall x J:
                    x = 3
                    1 <= x
                    x <= 4
                    x $in '[1, 4]
                J $subset '[1, 4]
        case J = '(3, 4]:
            by thm non_degenerate_interval_forms_are_bounded_intervals(3, 4)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                forall x J:
                    x $in '(3, 4]
                    3 < x
                    x <= 4
                    1 < 3 < x
                    1 < x
                    1 <= x
                    x $in '[1, 4]
                J $subset '[1, 4]
        case J = {}:
            by thm empty_interval_is_bounded()
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 4]
                claim:
                    ? forall x J:
                        x $in '[1, 4]
                    by contra:
                        ? x $in '[1, 4]
                        x $in J
                        x $in {}
                        not $is_nonempty_set({})
                        witness $is_nonempty_set({}) from x
                        impossible $is_nonempty_set({})
