                            {3} $in {'[1, 2), '[2, 3), {3}, '(3, 4], {}}
                            example_11_2_12_refined_partition_set = {'[1, 2), '[2, 3), {3}, '(3, 4], {}}
                            {3} $in example_11_2_12_refined_partition_set
                        witness exist J example_11_2_12_refined_partition_set st {J $in power_set(R), y $in J} from {3}:
