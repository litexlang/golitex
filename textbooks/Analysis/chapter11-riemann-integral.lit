thm max_of_bounded_functions_is_bounded:
    ? forall I power_set(R), f, g fn(x I) R:
        $chap9::is_bounded_function_on(I, f)
        $chap9::is_bounded_function_on(I, g)
        =>:
            $chap9::is_bounded_function_on(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
    obtain Mf from exist Mf0 R_pos st {$chap9::is_function_bounded_by(I, f, Mf0)}
    obtain Mg from exist Mg0 R_pos st {$chap9::is_function_bounded_by(I, g, Mg0)}
    Mf + Mg > 0
    witness exist M R_pos st {$chap9::is_function_bounded_by(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}, M)} from Mf + Mg:
        claim:
            ? forall x I:
                abs(fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}(x)) <= M
            by cases:
                ? f(x) >= g(x) or f(x) < g(x)
                case f(x) >= g(x):
                    by thm max_of_ge(f(x), g(x))
                    finite_set_max(union({f(x)}, { g(x)})) = f(x)
                    abs(f(x)) <= Mf
                    Mf <= Mf + Mg
                    abs(finite_set_max(union({f(x)}, { g(x)}))) <= Mf + Mg
                case f(x) < g(x):
                    f(x) <= g(x)
                    by thm max_of_le(f(x), g(x))
                    finite_set_max(union({f(x)}, { g(x)})) = g(x)
                    abs(g(x)) <= Mg
                    Mg <= Mf + Mg
                    abs(finite_set_max(union({f(x)}, { g(x)}))) <= Mf + Mg
            fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}(x) = finite_set_max(union({f(x)}, { g(x)}))
            abs(fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}(x)) <= Mf + Mg
            M = Mf + Mg
            abs(fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}(x)) <= M
        $chap9::is_function_bounded_by(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}, M)
    $chap9::is_bounded_function_on(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})

thm darboux_approximations_max:
    ? forall I power_set(R), f, g, hf, gf, hg, gg fn(x I) R, shf, sgf, shg, sgg, epsilon_f, epsilon_g R_pos:
        $is_bounded_interval(I)
        $has_darboux_approximation(I, f, hf, gf, shf, sgf, epsilon_f)
        $has_darboux_approximation(I, g, hg, gg, shg, sgg, epsilon_g)
        =>:
            exist h, k fn(x I) R, sh, sk R st {$has_darboux_approximation(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}, h, k, sh, sk, epsilon_f + epsilon_g)}
    by thm piecewise_constant_algebra(I, hf, hg)
    $is_piecewise_constant_on(I, fn(x I) R {finite_set_max(union({hf(x)}, { hg(x)}))})
    by thm piecewise_constant_algebra(I, gf, gg)
    $is_piecewise_constant_on(I, fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)}))})
    by thm piecewise_constant_on_bounded_interval_has_piecewise_constant_integral(I, fn(x I) R {finite_set_max(union({hf(x)}, { hg(x)}))})
    obtain sh from exist s R st {$has_piecewise_constant_integral(I, fn(x I) R {finite_set_max(union({hf(x)}, { hg(x)}))}, s)}
    by thm piecewise_constant_on_bounded_interval_has_piecewise_constant_integral(I, fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)}))})
    obtain sg from exist s R st {$has_piecewise_constant_integral(I, fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)}))}, s)}
    claim:
        ? $minorizes_on(I, fn(x I) R {finite_set_max(union({hf(x)}, { hg(x)}))}, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
        claim:
            ? forall x I:
                fn(x I) R {finite_set_max(union({hf(x)}, { hg(x)}))}(x) <= fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}(x)
            hf(x) <= f(x)
            hg(x) <= g(x)
            by cases:
                ? hf(x) >= hg(x) or hf(x) < hg(x)
                case hf(x) >= hg(x):
                    by thm max_of_ge(hf(x), hg(x))
                    finite_set_max(union({hf(x)}, { hg(x)})) = hf(x)
                    hf(x) <= f(x)
                    f(x) <= finite_set_max(union({f(x)}, { g(x)}))
                    finite_set_max(union({hf(x)}, { hg(x)})) <= finite_set_max(union({f(x)}, { g(x)}))
                case hf(x) < hg(x):
                    hf(x) <= hg(x)
                    by thm max_of_le(hf(x), hg(x))
                    finite_set_max(union({hf(x)}, { hg(x)})) = hg(x)
                    hg(x) <= g(x)
                    g(x) <= finite_set_max(union({f(x)}, { g(x)}))
                    finite_set_max(union({hf(x)}, { hg(x)})) <= finite_set_max(union({f(x)}, { g(x)}))
            fn(x I) R {finite_set_max(union({hf(x)}, { hg(x)}))}(x) = finite_set_max(union({hf(x)}, { hg(x)}))
            fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}(x) = finite_set_max(union({f(x)}, { g(x)}))
            fn(x I) R {finite_set_max(union({hf(x)}, { hg(x)}))}(x) <= fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}(x)
        $minorizes_on(I, fn(x I) R {finite_set_max(union({hf(x)}, { hg(x)}))}, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
    claim:
        ? $majorizes_on(I, fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)}))}, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
        claim:
            ? forall x I:
                fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)}))}(x) >= fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}(x)
            f(x) <= gf(x)
            g(x) <= gg(x)
            by cases:
                ? f(x) >= g(x) or f(x) < g(x)
                case f(x) >= g(x):
                    by thm max_of_ge(f(x), g(x))
                    finite_set_max(union({f(x)}, { g(x)})) = f(x)
                    f(x) <= gf(x)
                    gf(x) <= finite_set_max(union({gf(x)}, { gg(x)}))
                    finite_set_max(union({f(x)}, { g(x)})) <= finite_set_max(union({gf(x)}, { gg(x)}))
                case f(x) < g(x):
                    f(x) <= g(x)
                    by thm max_of_le(f(x), g(x))
                    finite_set_max(union({f(x)}, { g(x)})) = g(x)
                    g(x) <= gg(x)
                    gg(x) <= finite_set_max(union({gf(x)}, { gg(x)}))
                    finite_set_max(union({f(x)}, { g(x)})) <= finite_set_max(union({gf(x)}, { gg(x)}))
            fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)}))}(x) = finite_set_max(union({gf(x)}, { gg(x)}))
            fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}(x) = finite_set_max(union({f(x)}, { g(x)}))
            fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)}))}(x) >= fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}(x)
        $majorizes_on(I, fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)}))}, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
    by thm piecewise_constant_integral_laws(I, gf, hf, sgf, shf, 1)
    $has_piecewise_constant_integral(I, fn(x I) R {gf(x) - hf(x)}, sgf - shf)
    by thm piecewise_constant_integral_laws(I, gg, hg, sgg, shg, 1)
    $has_piecewise_constant_integral(I, fn(x I) R {gg(x) - hg(x)}, sgg - shg)
    by thm piecewise_constant_integral_laws(I, fn(x I) R {gf(x) - hf(x)}, fn(x I) R {gg(x) - hg(x)}, sgf - shf, sgg - shg, 1)
    $has_piecewise_constant_integral(I, fn(x I) R {(gf(x) - hf(x)) + (gg(x) - hg(x))}, (sgf - shf) + (sgg - shg))
    by thm piecewise_constant_integral_laws(I, fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)}))}, fn(x I) R {finite_set_max(union({hf(x)}, { hg(x)}))}, sg, sh, 1)
    $has_piecewise_constant_integral(I, fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)})) - finite_set_max(union({hf(x)}, { hg(x)}))}, sg - sh)
    claim:
        ? $is_nonnegative_on(I, fn(x I) R {(gf(x) - hf(x)) + (gg(x) - hg(x))})
        forall x I:
            hf(x) <= f(x)
            f(x) <= gf(x)
            hg(x) <= g(x)
            g(x) <= gg(x)
            0 <= gf(x) - hf(x)
            0 <= gg(x) - hg(x)
            fn(x I) R {(gf(x) - hf(x)) + (gg(x) - hg(x))}(x) = (gf(x) - hf(x)) + (gg(x) - hg(x))
            fn(x I) R {(gf(x) - hf(x)) + (gg(x) - hg(x))}(x) >= 0
        $is_nonnegative_on(I, fn(x I) R {(gf(x) - hf(x)) + (gg(x) - hg(x))})
    claim:
        ? forall x I:
            fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)})) - finite_set_max(union({hf(x)}, { hg(x)}))}(x) <= fn(x I) R {(gf(x) - hf(x)) + (gg(x) - hg(x))}(x)
        hf(x) <= f(x)
        f(x) <= gf(x)
        hg(x) <= g(x)
        g(x) <= gg(x)
        hf(x) <= gf(x)
        hg(x) <= gg(x)
        0 <= gf(x) - hf(x)
        0 <= gg(x) - hg(x)
        by cases:
            ? gf(x) >= gg(x) or gf(x) < gg(x)
            case gf(x) >= gg(x):
                by thm max_of_ge(gf(x), gg(x))
                finite_set_max(union({gf(x)}, { gg(x)})) = gf(x)
                by cases:
                    ? hf(x) >= hg(x) or hf(x) < hg(x)
                    case hf(x) >= hg(x):
                        by thm max_of_ge(hf(x), hg(x))
                        finite_set_max(union({hf(x)}, { hg(x)})) = hf(x)
                        gf(x) - hf(x) <= (gf(x) - hf(x)) + (gg(x) - hg(x))
                        finite_set_max(union({gf(x)}, { gg(x)})) - finite_set_max(union({hf(x)}, { hg(x)})) <= (gf(x) - hf(x)) + (gg(x) - hg(x))
                    case hf(x) < hg(x):
                        hf(x) <= hg(x)
                        by thm max_of_le(hf(x), hg(x))
                        finite_set_max(union({hf(x)}, { hg(x)})) = hg(x)
                        gf(x) - hg(x) <= gf(x) - hf(x)
                        gf(x) - hf(x) <= (gf(x) - hf(x)) + (gg(x) - hg(x))
                        finite_set_max(union({gf(x)}, { gg(x)})) - finite_set_max(union({hf(x)}, { hg(x)})) <= (gf(x) - hf(x)) + (gg(x) - hg(x))
            case gf(x) < gg(x):
                gf(x) <= gg(x)
                by thm max_of_le(gf(x), gg(x))
                finite_set_max(union({gf(x)}, { gg(x)})) = gg(x)
                by cases:
                    ? hf(x) >= hg(x) or hf(x) < hg(x)
                    case hf(x) >= hg(x):
                        by thm max_of_ge(hf(x), hg(x))
                        finite_set_max(union({hf(x)}, { hg(x)})) = hf(x)
                        gg(x) - hf(x) <= gg(x) - hg(x)
                        gg(x) - hg(x) <= (gf(x) - hf(x)) + (gg(x) - hg(x))
                        finite_set_max(union({gf(x)}, { gg(x)})) - finite_set_max(union({hf(x)}, { hg(x)})) <= (gf(x) - hf(x)) + (gg(x) - hg(x))
                    case hf(x) < hg(x):
                        hf(x) <= hg(x)
                        by thm max_of_le(hf(x), hg(x))
                        finite_set_max(union({hf(x)}, { hg(x)})) = hg(x)
                        gg(x) - hg(x) <= (gf(x) - hf(x)) + (gg(x) - hg(x))
                        finite_set_max(union({gf(x)}, { gg(x)})) - finite_set_max(union({hf(x)}, { hg(x)})) <= (gf(x) - hf(x)) + (gg(x) - hg(x))
        fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)})) - finite_set_max(union({hf(x)}, { hg(x)}))}(x) = finite_set_max(union({gf(x)}, { gg(x)})) - finite_set_max(union({hf(x)}, { hg(x)}))
        fn(x I) R {(gf(x) - hf(x)) + (gg(x) - hg(x))}(x) = (gf(x) - hf(x)) + (gg(x) - hg(x))
        fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)})) - finite_set_max(union({hf(x)}, { hg(x)}))}(x) <= fn(x I) R {(gf(x) - hf(x)) + (gg(x) - hg(x))}(x)
    by thm piecewise_constant_integral_order_laws(I, fn(x I) R {(gf(x) - hf(x)) + (gg(x) - hg(x))}, fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)})) - finite_set_max(union({hf(x)}, { hg(x)}))}, (sgf - shf) + (sgg - shg), sg - sh)
    sg - sh <= (sgf - shf) + (sgg - shg)
    sgf - shf < epsilon_f
    sgg - shg < epsilon_g
    (sgf - shf) + (sgg - shg) < epsilon_f + epsilon_g
    sg - sh < epsilon_f + epsilon_g
    witness exist h0, k0 fn(x I) R, sh0, sk0 R st {$has_darboux_approximation(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}, h0, k0, sh0, sk0, epsilon_f + epsilon_g)} from fn(x I) R {finite_set_max(union({hf(x)}, { hg(x)}))}, fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)}))}, sh, sg:
        $is_piecewise_constant_on(I, fn(x I) R {finite_set_max(union({hf(x)}, { hg(x)}))})
        $is_piecewise_constant_on(I, fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)}))})
        $minorizes_on(I, fn(x I) R {finite_set_max(union({hf(x)}, { hg(x)}))}, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
        $majorizes_on(I, fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)}))}, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
        $has_piecewise_constant_integral(I, fn(x I) R {finite_set_max(union({hf(x)}, { hg(x)}))}, sh)
        $has_piecewise_constant_integral(I, fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)}))}, sg)
        sg - sh < epsilon_f + epsilon_g
        $has_darboux_approximation(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}, fn(x I) R {finite_set_max(union({hf(x)}, { hg(x)}))}, fn(x I) R {finite_set_max(union({gf(x)}, { gg(x)}))}, sh, sg, epsilon_f + epsilon_g)

thm riemann_integrable_nonnegative_bounded_has_clamped_darboux_approximation:
    ? forall I power_set(R), f fn(x I) R, M, epsilon R_pos:
        $is_riemann_integrable_on(I, f)
        $is_nonnegative_on(I, f)
        $chap9::is_function_bounded_by(I, f, M)
        =>:
            exist h, g fn(x I) R, sh, sg R st {$has_darboux_approximation(I, f, h, g, sh, sg, epsilon), $is_nonnegative_on(I, h), $is_nonnegative_on(I, g), $chap9::is_function_bounded_above_by(I, g, M)}
    by thm riemann_integrable_on_bounded_interval(I, f)
    by thm riemann_integrable_has_darboux_approximation(I, f, epsilon)
    obtain h0, g0, sh0, sg0 from exist h1, g1 fn(x I) R, sh1, sg1 R st {$has_darboux_approximation(I, f, h1, g1, sh1, sg1, epsilon)}
    by thm constant_function_is_piecewise_constant(I, 0)
    by thm constant_function_is_piecewise_constant(I, M)
    by thm piecewise_constant_algebra(I, h0, fn(x I) R {0})
    $is_piecewise_constant_on(I, fn(x I) R {finite_set_max(union({h0(x)}, { 0}))})
    by thm piecewise_constant_algebra(I, g0, fn(x I) R {M})
    $is_piecewise_constant_on(I, fn(x I) R {finite_set_min(union({g0(x)}, { M}))})
    by thm piecewise_constant_on_bounded_interval_has_piecewise_constant_integral(I, fn(x I) R {finite_set_max(union({h0(x)}, { 0}))})
    obtain sh from exist s R st {$has_piecewise_constant_integral(I, fn(x I) R {finite_set_max(union({h0(x)}, { 0}))}, s)}
    by thm piecewise_constant_on_bounded_interval_has_piecewise_constant_integral(I, fn(x I) R {finite_set_min(union({g0(x)}, { M}))})
    obtain sg from exist s R st {$has_piecewise_constant_integral(I, fn(x I) R {finite_set_min(union({g0(x)}, { M}))}, s)}
    claim:
        ? $minorizes_on(I, fn(x I) R {finite_set_max(union({h0(x)}, { 0}))}, f)
        claim:
            ? forall x I:
                fn(x I) R {finite_set_max(union({h0(x)}, { 0}))}(x) <= f(x)
            h0(x) <= f(x)
            0 <= f(x)
            by cases:
                ? h0(x) >= 0 or h0(x) < 0
                case h0(x) >= 0:
                    by thm max_of_ge(h0(x), 0)
                    finite_set_max(union({h0(x)}, { 0})) = h0(x)
                    finite_set_max(union({h0(x)}, { 0})) <= f(x)
                case h0(x) < 0:
                    h0(x) <= 0
                    by thm max_of_le(h0(x), 0)
                    finite_set_max(union({h0(x)}, { 0})) = 0
                    finite_set_max(union({h0(x)}, { 0})) <= f(x)
            fn(x I) R {finite_set_max(union({h0(x)}, { 0}))}(x) = finite_set_max(union({h0(x)}, { 0}))
            fn(x I) R {finite_set_max(union({h0(x)}, { 0}))}(x) <= f(x)
        $minorizes_on(I, fn(x I) R {finite_set_max(union({h0(x)}, { 0}))}, f)
    claim:
        ? $majorizes_on(I, fn(x I) R {finite_set_min(union({g0(x)}, { M}))}, f)
        claim:
            ? forall x I:
                fn(x I) R {finite_set_min(union({g0(x)}, { M}))}(x) >= f(x)
            f(x) <= g0(x)
            abs(f(x)) <= M
            f(x) <= M
            by cases:
                ? g0(x) <= M or g0(x) > M
                case g0(x) <= M:
                    by thm min_of_le(g0(x), M)
                    finite_set_min(union({g0(x)}, { M})) = g0(x)
                    f(x) <= finite_set_min(union({g0(x)}, { M}))
                case g0(x) > M:
                    M <= g0(x)
                    by thm min_of_ge(g0(x), M)
                    finite_set_min(union({g0(x)}, { M})) = M
                    f(x) <= finite_set_min(union({g0(x)}, { M}))
            fn(x I) R {finite_set_min(union({g0(x)}, { M}))}(x) = finite_set_min(union({g0(x)}, { M}))
            fn(x I) R {finite_set_min(union({g0(x)}, { M}))}(x) >= f(x)
        $majorizes_on(I, fn(x I) R {finite_set_min(union({g0(x)}, { M}))}, f)
    claim:
        ? $is_nonnegative_on(I, fn(x I) R {finite_set_max(union({h0(x)}, { 0}))})
        forall x I:
            0 <= finite_set_max(union({h0(x)}, { 0}))
            fn(x I) R {finite_set_max(union({h0(x)}, { 0}))}(x) = finite_set_max(union({h0(x)}, { 0}))
            fn(x I) R {finite_set_max(union({h0(x)}, { 0}))}(x) >= 0
        $is_nonnegative_on(I, fn(x I) R {finite_set_max(union({h0(x)}, { 0}))})
    claim:
        ? $is_nonnegative_on(I, fn(x I) R {finite_set_min(union({g0(x)}, { M}))})
        forall x I:
            f(x) >= 0
            f(x) <= finite_set_min(union({g0(x)}, { M}))
            fn(x I) R {finite_set_min(union({g0(x)}, { M}))}(x) = finite_set_min(union({g0(x)}, { M}))
            fn(x I) R {finite_set_min(union({g0(x)}, { M}))}(x) >= 0
        $is_nonnegative_on(I, fn(x I) R {finite_set_min(union({g0(x)}, { M}))})
    claim:
        ? forall x I:
            fn(x I) R {finite_set_min(union({g0(x)}, { M}))}(x) <= M
        finite_set_min(union({g0(x)}, { M})) <= M
        fn(x I) R {finite_set_min(union({g0(x)}, { M}))}(x) = finite_set_min(union({g0(x)}, { M}))
        fn(x I) R {finite_set_min(union({g0(x)}, { M}))}(x) <= M
    by thm piecewise_constant_integral_laws(I, g0, h0, sg0, sh0, 1)
    $has_piecewise_constant_integral(I, fn(x I) R {g0(x) - h0(x)}, sg0 - sh0)
    by thm piecewise_constant_integral_laws(I, fn(x I) R {finite_set_min(union({g0(x)}, { M}))}, fn(x I) R {finite_set_max(union({h0(x)}, { 0}))}, sg, sh, 1)
    $has_piecewise_constant_integral(I, fn(x I) R {finite_set_min(union({g0(x)}, { M})) - finite_set_max(union({h0(x)}, { 0}))}, sg - sh)
    claim:
        ? $is_nonnegative_on(I, fn(x I) R {g0(x) - h0(x)})
        forall x I:
            h0(x) <= f(x)
            f(x) <= g0(x)
            0 <= g0(x) - h0(x)
            fn(x I) R {g0(x) - h0(x)}(x) = g0(x) - h0(x)
            fn(x I) R {g0(x) - h0(x)}(x) >= 0
        $is_nonnegative_on(I, fn(x I) R {g0(x) - h0(x)})
    claim:
        ? forall x I:
            fn(x I) R {finite_set_min(union({g0(x)}, { M})) - finite_set_max(union({h0(x)}, { 0}))}(x) <= fn(x I) R {g0(x) - h0(x)}(x)
        finite_set_min(union({g0(x)}, { M})) <= g0(x)
        h0(x) <= finite_set_max(union({h0(x)}, { 0}))
        finite_set_min(union({g0(x)}, { M})) - finite_set_max(union({h0(x)}, { 0})) <= g0(x) - h0(x)
        fn(x I) R {finite_set_min(union({g0(x)}, { M})) - finite_set_max(union({h0(x)}, { 0}))}(x) = finite_set_min(union({g0(x)}, { M})) - finite_set_max(union({h0(x)}, { 0}))
        fn(x I) R {g0(x) - h0(x)}(x) = g0(x) - h0(x)
        fn(x I) R {finite_set_min(union({g0(x)}, { M})) - finite_set_max(union({h0(x)}, { 0}))}(x) <= fn(x I) R {g0(x) - h0(x)}(x)
    by thm piecewise_constant_integral_order_laws(I, fn(x I) R {g0(x) - h0(x)}, fn(x I) R {finite_set_min(union({g0(x)}, { M})) - finite_set_max(union({h0(x)}, { 0}))}, sg0 - sh0, sg - sh)
    sg - sh <= sg0 - sh0
    sg0 - sh0 < epsilon
    sg - sh < epsilon
    witness exist h1, g1 fn(x I) R, sh1, sg1 R st {$has_darboux_approximation(I, f, h1, g1, sh1, sg1, epsilon), $is_nonnegative_on(I, h1), $is_nonnegative_on(I, g1), $chap9::is_function_bounded_above_by(I, g1, M)} from fn(x I) R {finite_set_max(union({h0(x)}, { 0}))}, fn(x I) R {finite_set_min(union({g0(x)}, { M}))}, sh, sg:
        $has_darboux_approximation(I, f, fn(x I) R {finite_set_max(union({h0(x)}, { 0}))}, fn(x I) R {finite_set_min(union({g0(x)}, { M}))}, sh, sg, epsilon)
        $is_nonnegative_on(I, fn(x I) R {finite_set_max(union({h0(x)}, { 0}))})
        $is_nonnegative_on(I, fn(x I) R {finite_set_min(union({g0(x)}, { M}))})
        $chap9::is_function_bounded_above_by(I, fn(x I) R {finite_set_min(union({g0(x)}, { M}))}, M)

"""
Remark 11.3.5.  The lower and upper integrals play the same role for integrals
that liminf and limsup play for sequence limits: equality produces the actual
limit-like value.
"""

"""
Remark 11.3.6.  Unbounded functions are not Riemann integrable in this
chapter; integrals of unbounded functions are treated as improper or later
Lebesgue-style integrals.
"""

# A finite family of possible constant values has a choice function; this
# packages the heights attached to a partition.
prop is_constant_selector_for_partition(I power_set(R), P finite_set, f fn(x I) R, c fn(J P) R):
    forall J P:
        $has_constant_value_on_subset(I, J, f, c(J))

thm piecewise_constant_partition_has_constant_selector:
    ? forall I power_set(R), P finite_set, f fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        =>:
            exist c fn(J P) R st {$is_constant_selector_for_partition(I, P, f, c)}
    have fn constant_value_set(J P) power_set(R) = {c R: $has_constant_value_on_subset(I, J, f, c)}
    claim:
        ? forall A fn_range(constant_value_set):
            $is_nonempty_set(A)
        have by preimage J from A $in fn_range(constant_value_set)
        A = constant_value_set(J)
        J $in power_set(R)
        $is_constant_on_subset(I, J, f)
        obtain c from exist c R st {$has_constant_value_on_subset(I, J, f, c)}
        constant_value_set(J) = {c R: $has_constant_value_on_subset(I, J, f, c)}
        c $in constant_value_set(J)
        c $in A
        witness $is_nonempty_set(A) from c:
            c $in A
    claim:
        ? exist f fn(A fn_range(constant_value_set)) big_union(fn_range(constant_value_set)) st {forall! A fn_range(constant_value_set) => {f(A) $in A}}
        by axiom_of_choice: set fn_range(constant_value_set)
    obtain choose_constant from exist f fn(A fn_range(constant_value_set)) big_union(fn_range(constant_value_set)) st {forall! A fn_range(constant_value_set) => {f(A) $in A}}
    claim:
        ? forall J P:
            choose_constant(constant_value_set(J)) $in R
        choose_constant(constant_value_set(J)) $in constant_value_set(J)
        constant_value_set(J) $in power_set(R)
        choose_constant(constant_value_set(J)) $in R
    have fn c(J P) R = choose_constant(constant_value_set(J))
    witness exist c0 fn(J P) R st {$is_constant_selector_for_partition(I, P, f, c0)} from c:
        forall J P:
            c(J) = choose_constant(constant_value_set(J))
            choose_constant(constant_value_set(J)) $in constant_value_set(J)
            c(J) $in constant_value_set(J)
            $has_constant_value_on_subset(I, J, f, c(J))
        $is_constant_selector_for_partition(I, P, f, c)
    exist c fn(J P) R st {$is_constant_selector_for_partition(I, P, f, c)}

"""
Lemma 11.3.7.  A piecewise constant function is Riemann integrable, and its
Riemann integral equals its piecewise constant integral.
"""

thm piecewise_constant_on_bounded_interval_is_bounded:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $is_piecewise_constant_on(I, f)
        =>:
            $chap9::is_bounded_function_on(I, f)
    # Choose the finite list of constant heights and bound each value by the
    # sum of their absolute values plus one.
    obtain P from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f)}
    by thm piecewise_constant_partition_has_constant_selector(I, P, f)
    obtain c from exist c fn(J P) R st {$is_constant_selector_for_partition(I, P, f, c)}
    have fn h(J P) R = abs(c(J))
    claim:
        ? forall J P:
            h(J) >= 0
        h(J) = abs(c(J))
        abs(c(J)) >= 0
        h(J) >= 0
    finite_set_sum(P, fn(J P) R {0}) <= finite_set_sum(P, h)
    finite_set_sum(P, fn(J P) R {0}) = 0
    finite_set_sum(P, h) >= 0
    finite_set_sum(P, h) + 1 > 0
    finite_set_sum(P, h) + 1 $in R_pos
    have M R_pos = finite_set_sum(P, h) + 1
    witness exist M0 R_pos st {$chap9::is_function_bounded_by(I, f, M0)} from M:
        claim:
            ? forall x I:
                abs(f(x)) <= M
            obtain J from exist! J P st {J $in power_set(R), x $in J}
            J $in P
            $has_constant_value_on_subset(I, J, f, c(J))
            f(x) = c(J)
            h(J) = abs(c(J))
            abs(f(x)) = abs(c(J)) = h(J)
            abs(f(x)) <= h(J)
            h(J) <= finite_set_sum(P, h)
            abs(f(x)) <= finite_set_sum(P, h)
            finite_set_sum(P, h) <= finite_set_sum(P, h) + 1
            abs(f(x)) <= finite_set_sum(P, h) + 1
            M = finite_set_sum(P, h) + 1
            abs(f(x)) <= M
        $chap9::is_function_bounded_by(I, f, M)
    $chap9::is_bounded_function_on(I, f)

thm piecewise_constant_functions_are_riemann_integrable:
    ? forall I power_set(R), f fn(x I) R, s R:
        $has_piecewise_constant_integral(I, f, s)
        =>:
            $is_riemann_integrable_on(I, f)
            integral_on(I, f) = s
    # Source handling: the function itself is both a piecewise-constant
    # majorant and a minorant.  The two Darboux extrema are consequently
    # squeezed to its displayed piecewise-constant value.
    $is_piecewise_constant_on(I, f)
    obtain P from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f)}
    $is_partition_of_bounded_interval(I, P)
    $is_bounded_interval(I)
    by thm piecewise_constant_on_bounded_interval_is_bounded(I, f)
    $chap9::is_bounded_function_on(I, f)
    $has_upper_riemann_integral(I, f, upper_riemann_integral(I, f))
    $has_lower_riemann_integral(I, f, lower_riemann_integral(I, f))
    claim:
        ? $is_upper_riemann_integral_candidate_value(I, f, s)
        witness exist g fn(x I) R st {$is_piecewise_constant_on(I, g), $majorizes_on(I, g, f), $has_piecewise_constant_integral(I, g, s)} from f:
            $is_piecewise_constant_on(I, f)
            claim:
                ? $majorizes_on(I, f, f)
                forall x I:
                    f(x) >= f(x)
                $majorizes_on(I, f, f)
            $majorizes_on(I, f, f)
            $has_piecewise_constant_integral(I, f, s)
        $is_upper_riemann_integral_candidate_value(I, f, s)
    by thm upper_riemann_integral_le_candidate_value(I, f, upper_riemann_integral(I, f), s)
    upper_riemann_integral(I, f) <= s
    claim:
        ? $is_lower_riemann_integral_candidate_value(I, f, s)
        witness exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_integral(I, h, s)} from f:
            $is_piecewise_constant_on(I, f)
            claim:
                ? $minorizes_on(I, f, f)
                forall x I:
                    f(x) <= f(x)
                $minorizes_on(I, f, f)
            $minorizes_on(I, f, f)
            $has_piecewise_constant_integral(I, f, s)
        $is_lower_riemann_integral_candidate_value(I, f, s)
    by thm lower_riemann_integral_candidate_value_le_integral(I, f, lower_riemann_integral(I, f), s)
    s <= lower_riemann_integral(I, f)
    obtain M from exist M R_pos st {$chap9::is_function_bounded_by(I, f, M)}
    claim:
        ? forall x I:
            -M <= f(x)
            f(x) <= M
        abs(f(x)) <= M
        0 - abs(f(x)) <= f(x)
        0 - M <= 0 - abs(f(x))
        0 - M = -M
        -M <= f(x)
        f(x) <= abs(f(x))
        abs(f(x)) <= M
        f(x) <= M
    by thm upper_lower_riemann_integral_bounds(I, f, M)
    lower_riemann_integral(I, f) <= upper_riemann_integral(I, f)
    s <= lower_riemann_integral(I, f) <= upper_riemann_integral(I, f)
    s <= upper_riemann_integral(I, f)
    upper_riemann_integral(I, f) = s
    lower_riemann_integral(I, f) <= upper_riemann_integral(I, f) = s
    lower_riemann_integral(I, f) <= s
    lower_riemann_integral(I, f) = s
    upper_riemann_integral(I, f) = lower_riemann_integral(I, f)
    $is_riemann_integrable_on(I, f)
    by thm integral_on_has_riemann_integral(I, f)
    $has_riemann_integral(I, f, integral_on(I, f))
    by thm has_riemann_integral_value_eq_upper(I, f, integral_on(I, f))
    integral_on(I, f) = upper_riemann_integral(I, f)
    upper_riemann_integral(I, f) = s
    integral_on(I, f) = s

thm piecewise_constant_on_bounded_interval_has_piecewise_constant_integral:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $is_piecewise_constant_on(I, f)
        =>:
            exist s R st {$has_piecewise_constant_integral(I, f, s)}
    # Source handling: choose the partition witnessing piecewise constancy and
    # use its finite sum as the partition-free value.
    obtain P from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f)}
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, P, f)
    by thm piecewise_constant_integral_with_partition_has_value(I, P, f)
    have pc_s R = piecewise_constant_integral_with_partition(I, P, f)
    $has_piecewise_constant_integral_with_partition(I, P, f, pc_s)
    claim:
        ? exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, f), $has_piecewise_constant_integral_with_partition(I, P0, f, pc_s)}
        witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, f), $has_piecewise_constant_integral_with_partition(I, P0, f, pc_s)} from P:
            $is_piecewise_constant_with_partition(I, P, f)
            $has_piecewise_constant_integral_with_partition(I, P, f, pc_s)
    claim:
        ? $has_piecewise_constant_integral(I, f, pc_s)
        $is_piecewise_constant_on(I, f)
        exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, f), $has_piecewise_constant_integral_with_partition(I, P0, f, pc_s)}
    witness exist s R st {$has_piecewise_constant_integral(I, f, s)} from pc_s:
        $has_piecewise_constant_integral(I, f, pc_s)

thm piecewise_constant_on_bounded_interval_is_riemann_integrable:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $is_piecewise_constant_on(I, f)
        =>:
            $is_riemann_integrable_on(I, f)
    # Source handling: choose the partition witnessing piecewise constancy,
    # form the finite piecewise-constant integral over that partition, and
    # apply Lemma 11.3.7.
    by thm piecewise_constant_on_bounded_interval_has_piecewise_constant_integral(I, f)
    obtain s from exist s R st {$has_piecewise_constant_integral(I, f, s)}
    by thm piecewise_constant_functions_are_riemann_integrable(I, f, s)
    $is_riemann_integrable_on(I, f)

"""
Remark 11.3.8.  From now on, the Riemann integral supersedes the temporary
piecewise constant integral.  On a point or on the empty set, every function
has integral zero.
"""

prop is_empty_interval(I power_set(R)):
    I = {}

prop is_singleton_interval(I power_set(R)):
    exist a R st {I = {a}}

prop is_point_or_empty_interval(I power_set(R)):
    $is_empty_interval(I) or $is_singleton_interval(I)

thm function_on_empty_interval_has_piecewise_constant_integral_zero:
    ? forall I power_set(R), f fn(x I) R:
        $is_empty_interval(I)
        $is_bounded_interval(I)
        =>:
            $has_piecewise_constant_integral(I, f, 0)
    # Source handling: on the empty interval every value statement is
    # vacuous, and the interval length is zero.
    I = {}
    by thm empty_bounded_interval_length_value(I)
    interval_length(I) = 0
    claim:
        ? $has_constant_value_on_subset(I, I, f, 0)
        I $subset I
        claim:
            ? forall x I:
                f(x) = 0
            by contra:
                ? f(x) = 0
                x $in I
                x $in {}
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from x
                impossible $is_nonempty_set({})
    claim:
        ? $is_piecewise_constant_with_partition(I, {I}, f)
        by thm one_piece_partition_of_bounded_interval(I)
        $is_partition_of_bounded_interval(I, {I})
        claim:
            ? forall J {I}:
                J $in power_set(R)
                $is_constant_on_subset(I, J, f)
            J = I
            J $in power_set(R)
            witness exist c R st {$has_constant_value_on_subset(I, J, f, c)} from 0:
                $has_constant_value_on_subset(I, I, f, 0)
                $has_constant_value_on_subset(I, J, f, 0)
            $is_constant_on_subset(I, J, f)
        $is_piecewise_constant_with_partition(I, {I}, f)
    claim:
        ? $has_piecewise_constant_integral_piece_contribution(I, I, f, 0)
        witness exist c R st {$has_constant_value_on_subset(I, I, f, c), 0 = c * interval_length(I)} from 0:
            $has_constant_value_on_subset(I, I, f, 0)
            0 * interval_length(I) = 0
            0 = 0 * interval_length(I)
        $has_piecewise_constant_integral_piece_contribution(I, I, f, 0)
    by thm one_piece_piecewise_constant_integral_with_partition_value(I, f, 0)
    $has_piecewise_constant_integral_with_partition(I, {I}, f, 0)
    by thm piecewise_constant_with_partition_is_piecewise_constant(I, {I}, f)
    claim:
        ? exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f), $has_piecewise_constant_integral_with_partition(I, P, f, 0)}
        witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f), $has_piecewise_constant_integral_with_partition(I, P, f, 0)} from {I}:
            $is_piecewise_constant_with_partition(I, {I}, f)
            $has_piecewise_constant_integral_with_partition(I, {I}, f, 0)
    $has_piecewise_constant_integral(I, f, 0)

thm function_on_singleton_interval_has_piecewise_constant_integral_zero:
    ? forall I power_set(R), f fn(x I) R:
        $is_singleton_interval(I)
        $is_bounded_interval(I)
        =>:
            $has_piecewise_constant_integral(I, f, 0)
    # Source handling: on a singleton, every value equals the value at the
    # unique point, while the singleton length is zero.
    obtain a from exist a R st {I = {a}}
    I = {a}
    a $in {a}
    a $in I
    by thm singleton_interval_length_value(a)
    interval_length({a}) = 0
    interval_length(I) = 0
    claim:
        ? $has_constant_value_on_subset(I, I, f, f(a))
        I $subset I
        forall x I:
            x $in {a}
            x = a
            f(x) = f(a)
    claim:
        ? $is_piecewise_constant_with_partition(I, {I}, f)
        by thm one_piece_partition_of_bounded_interval(I)
        $is_partition_of_bounded_interval(I, {I})
        claim:
            ? forall J {I}:
                J $in power_set(R)
                $is_constant_on_subset(I, J, f)
            J = I
            J $in power_set(R)
            witness exist c R st {$has_constant_value_on_subset(I, J, f, c)} from f(a):
                $has_constant_value_on_subset(I, I, f, f(a))
                $has_constant_value_on_subset(I, J, f, f(a))
            $is_constant_on_subset(I, J, f)
        $is_piecewise_constant_with_partition(I, {I}, f)
    claim:
        ? $has_piecewise_constant_integral_piece_contribution(I, I, f, 0)
        witness exist c R st {$has_constant_value_on_subset(I, I, f, c), 0 = c * interval_length(I)} from f(a):
            $has_constant_value_on_subset(I, I, f, f(a))
            f(a) * interval_length(I) = f(a) * 0 = 0
            0 = f(a) * interval_length(I)
        $has_piecewise_constant_integral_piece_contribution(I, I, f, 0)
    by thm one_piece_piecewise_constant_integral_with_partition_value(I, f, 0)
    $has_piecewise_constant_integral_with_partition(I, {I}, f, 0)
    by thm piecewise_constant_with_partition_is_piecewise_constant(I, {I}, f)
    claim:
        ? exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f), $has_piecewise_constant_integral_with_partition(I, P, f, 0)}
        witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f), $has_piecewise_constant_integral_with_partition(I, P, f, 0)} from {I}:
            $is_piecewise_constant_with_partition(I, {I}, f)
            $has_piecewise_constant_integral_with_partition(I, {I}, f, 0)
    $has_piecewise_constant_integral(I, f, 0)

thm point_or_empty_interval_integral_zero:
    ? forall I power_set(R), f fn(x I) R:
        $is_point_or_empty_interval(I)
        $is_bounded_interval(I)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $is_riemann_integrable_on(I, f)
            integral_on(I, f) = 0
    # Source handling: Tao cites Lemma 11.3.7 because functions on a point or
    # empty set are automatically piecewise constant.
    by cases:
        ? $has_piecewise_constant_integral(I, f, 0)
        case $is_empty_interval(I):
            by thm function_on_empty_interval_has_piecewise_constant_integral_zero(I, f)
        case $is_singleton_interval(I):
            by thm function_on_singleton_interval_has_piecewise_constant_integral_zero(I, f)
    by thm piecewise_constant_functions_are_riemann_integrable(I, f, 0)
    $is_riemann_integrable_on(I, f)
    integral_on(I, f) = 0

"""
Definition 11.3.9 (Riemann sums).  For a partition `P`, `U(f,P)` sums the
supremum of `f` on every non-empty piece times the piece length; `L(f,P)` uses
the infimum.
"""

# Source-facing Riemann-sum values are represented by the relations below.
# Their finite contribution families are constructed explicitly, so the value
# sets do not need an unverified global selector function.

have fn function_values_on_subset(I power_set(R), J power_set(R), f fn(x I) R: J $subset I) power_set(R) = fn_range(fn(x J) R {f(x)})

# The value set is a genuine object, while these two theorems are its public
# membership API. Later majorant/minorant arguments should use them instead
# of depending on an imported `have fn` equation unfolding at the call site.
thm function_value_on_subset_member:
    ? forall I power_set(R), J power_set(R), f fn(x I) R, x J:
        J $subset I
        =>:
            f(x) $in function_values_on_subset(I, J, f)
    x $in I
    function_values_on_subset(I, J, f) = fn_range(fn(z J) R {f(z)})
    fn(z J) R {f(z)}(x) = f(x)
    fn(z J) R {f(z)}(x) $in fn_range(fn(z J) R {f(z)})
    f(x) $in fn_range(fn(z J) R {f(z)})
    f(x) $in function_values_on_subset(I, J, f)

thm function_values_on_subset_member_has_preimage:
    ? forall I power_set(R), J power_set(R), f fn(x I) R, y R:
        J $subset I
        y $in function_values_on_subset(I, J, f)
        =>:
            exist x J st {y = f(x)}
    function_values_on_subset(I, J, f) = fn_range(fn(z J) R {f(z)})
    y $in fn_range(fn(z J) R {f(z)})
    have by preimage x from y $in fn_range(fn(z J) R {f(z)})
    y = fn(z J) R {f(z)}(x)
    fn(z J) R {f(z)}(x) = f(x)
    y = f(x)
    witness exist x0 J st {y = f(x0)} from x:
        y = f(x)

prop has_empty_riemann_sum_piece_contribution(J power_set(R), t R):
    not $is_nonempty_set(J)
    t = 0

prop has_nonempty_upper_riemann_sum_piece_contribution(I power_set(R), J power_set(R), f fn(x I) R, t R):
    $is_bounded_interval(J)
    J $subset I
    $is_nonempty_set(J)
    exist s R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s), t = s * interval_length(J)}

prop has_nonempty_lower_riemann_sum_piece_contribution(I power_set(R), J power_set(R), f fn(x I) R, t R):
    $is_bounded_interval(J)
    J $subset I
    $is_nonempty_set(J)
    exist s R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s), t = s * interval_length(J)}

prop has_upper_riemann_sum_piece_contribution(I power_set(R), J power_set(R), f fn(x I) R, t R):
    $has_empty_riemann_sum_piece_contribution(J, t) or $has_nonempty_upper_riemann_sum_piece_contribution(I, J, f, t)

prop has_lower_riemann_sum_piece_contribution(I power_set(R), J power_set(R), f fn(x I) R, t R):
    $has_empty_riemann_sum_piece_contribution(J, t) or $has_nonempty_lower_riemann_sum_piece_contribution(I, J, f, t)

thm bounded_piece_function_values_have_upper_bound:
    ? forall I power_set(R), J power_set(R), f fn(x I) R:
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        =>:
            $chap5::has_upper_bound(function_values_on_subset(I, J, f))
    obtain M from exist M R_pos st {$chap9::is_function_bounded_by(I, f, M)}
    claim:
        ? $chap9::is_bounded_function_on(J, fn(x J) R {f(x)})
        claim:
            ? $chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M)
            forall x J:
                x $in I
                fn(x J) R {f(x)}(x) = f(x)
                abs(f(x)) <= M
                abs(fn(x J) R {f(x)}(x)) <= M
            $chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M)
        witness exist M0 R_pos st {$chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M0)} from M:
            $chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M)
        $chap9::is_bounded_function_on(J, fn(x J) R {f(x)})
    by thm chap9::bounded_function_implies_bounded_range(J, fn(x J) R {f(x)})
    $chap9::is_bounded_real_set(fn_range(fn(x J) R {f(x)}))
    function_values_on_subset(I, J, f) = fn_range(fn(x J) R {f(x)})
    $chap9::is_bounded_real_set(function_values_on_subset(I, J, f))
    by thm chap9::bounded_real_set_has_upper_bound(function_values_on_subset(I, J, f))
    $chap5::has_upper_bound(function_values_on_subset(I, J, f))

thm nonempty_piece_function_values_has_least_upper_bound:
    ? forall I power_set(R), J power_set(R), f fn(x I) R:
        J $subset I
        $is_nonempty_set(J)
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist s R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s)}
    have x J
    x $in I
    function_values_on_subset(I, J, f) = fn_range(fn(x J) R {f(x)})
    fn(x J) R {f(x)}(x) = f(x)
    fn(x J) R {f(x)}(x) $in fn_range(fn(x J) R {f(x)})
    f(x) $in fn_range(fn(x J) R {f(x)})
    f(x) $in function_values_on_subset(I, J, f)
    witness $is_nonempty_set(function_values_on_subset(I, J, f)) from f(x):
        f(x) $in function_values_on_subset(I, J, f)
    by thm bounded_piece_function_values_have_upper_bound(I, J, f)
    $chap5::has_upper_bound(function_values_on_subset(I, J, f))
    by thm chap5::least_upper_bound_existence(function_values_on_subset(I, J, f))
    obtain s from exist s R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s)}
    witness exist s0 R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s0)} from s:
        $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s)

thm bounded_piece_function_values_have_lower_bound:
    ? forall I power_set(R), J power_set(R), f fn(x I) R:
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist B R st {$is_lower_bound_of_real_set(function_values_on_subset(I, J, f), B)}
    obtain M from exist M R_pos st {$chap9::is_function_bounded_by(I, f, M)}
    claim:
        ? $chap9::is_bounded_function_on(J, fn(x J) R {f(x)})
        claim:
            ? $chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M)
            forall x J:
                x $in I
                fn(x J) R {f(x)}(x) = f(x)
                abs(f(x)) <= M
                abs(fn(x J) R {f(x)}(x)) <= M
            $chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M)
        witness exist M0 R_pos st {$chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M0)} from M:
            $chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M)
        $chap9::is_bounded_function_on(J, fn(x J) R {f(x)})
    by thm chap9::bounded_function_implies_bounded_range(J, fn(x J) R {f(x)})
    $chap9::is_bounded_real_set(fn_range(fn(x J) R {f(x)}))
    function_values_on_subset(I, J, f) = fn_range(fn(x J) R {f(x)})
    $chap9::is_bounded_real_set(function_values_on_subset(I, J, f))
    obtain B from exist B R_pos st {function_values_on_subset(I, J, f) $subset '[-B, B]}
    witness exist B0 R st {$is_lower_bound_of_real_set(function_values_on_subset(I, J, f), B0)} from -B:
        claim:
            ? $is_lower_bound_of_real_set(function_values_on_subset(I, J, f), -B)
            forall y function_values_on_subset(I, J, f):
                function_values_on_subset(I, J, f) $subset '[-B, B]
                y $in '[-B, B]
                -B <= y
            $is_lower_bound_of_real_set(function_values_on_subset(I, J, f), -B)
        $is_lower_bound_of_real_set(function_values_on_subset(I, J, f), -B)

thm nonempty_piece_function_values_has_infimum:
    ? forall I power_set(R), J power_set(R), f fn(x I) R:
        J $subset I
        $is_nonempty_set(J)
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist s R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s)}
    have x J
    x $in I
    function_values_on_subset(I, J, f) = fn_range(fn(x J) R {f(x)})
    fn(x J) R {f(x)}(x) = f(x)
    fn(x J) R {f(x)}(x) $in fn_range(fn(x J) R {f(x)})
    f(x) $in fn_range(fn(x J) R {f(x)})
    f(x) $in function_values_on_subset(I, J, f)
    by thm bounded_piece_function_values_have_lower_bound(I, J, f)
    obtain B from exist B R st {$is_lower_bound_of_real_set(function_values_on_subset(I, J, f), B)}
    by thm lower_bounded_real_set_with_member_has_infimum(function_values_on_subset(I, J, f), B, f(x))
    obtain s from exist s R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s)}
    witness exist s0 R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s0)} from s:
        $is_infimum_of_real_set(function_values_on_subset(I, J, f), s)

# The supremum of the values on a partition piece is a first-class value. The
# empty convention is zero, because no point of I can be assigned to an empty
# piece when this value is used to build a step function.
prop has_empty_upper_riemann_piece_height(J power_set(R), s R):
    not $is_nonempty_set(J)
    s = 0

prop has_nonempty_upper_riemann_piece_height(I power_set(R), J power_set(R), f fn(x I) R, s R):
    $is_bounded_interval(J)
    J $subset I
    $is_nonempty_set(J)
    $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s)

prop has_upper_riemann_piece_height(I power_set(R), J power_set(R), f fn(x I) R, s R):
    $has_empty_upper_riemann_piece_height(J, s) or $has_nonempty_upper_riemann_piece_height(I, J, f, s)

thm upper_riemann_piece_height_value_unique:
    ? forall I power_set(R), J power_set(R), f fn(x I) R, s1, s2 R:
        $has_upper_riemann_piece_height(I, J, f, s1)
        $has_upper_riemann_piece_height(I, J, f, s2)
        =>:
            s1 = s2
    $has_empty_upper_riemann_piece_height(J, s1) or $has_nonempty_upper_riemann_piece_height(I, J, f, s1)
    $has_empty_upper_riemann_piece_height(J, s2) or $has_nonempty_upper_riemann_piece_height(I, J, f, s2)
    by cases:
        ? s1 = s2
        case $has_empty_upper_riemann_piece_height(J, s1):
            s1 = 0
            by cases:
                ? s1 = s2
                case $has_empty_upper_riemann_piece_height(J, s2):
                    s2 = 0
                    s1 = s2
                case $has_nonempty_upper_riemann_piece_height(I, J, f, s2):
                    not $is_nonempty_set(J)
                    $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)
        case $has_nonempty_upper_riemann_piece_height(I, J, f, s1):
            $is_nonempty_set(J)
            by cases:
                ? s1 = s2
                case $has_empty_upper_riemann_piece_height(J, s2):
                    not $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)
                case $has_nonempty_upper_riemann_piece_height(I, J, f, s2):
                    $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s1)
                    $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s2)
                    by thm chap5::least_upper_bound_unique(function_values_on_subset(I, J, f), s1, s2)
                    s1 = s2

have fn upper_riemann_piece_height by exist!:
    ? forall I power_set(R), J power_set(R), f fn(x I) R:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist! s R st {$has_upper_riemann_piece_height(I, J, f, s)}
    by cases:
        ? exist s R st {$has_upper_riemann_piece_height(I, J, f, s)}
        case $is_nonempty_set(J):
            by thm nonempty_piece_function_values_has_least_upper_bound(I, J, f)
            obtain s from exist s R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s)}
            witness exist s0 R st {$has_upper_riemann_piece_height(I, J, f, s0)} from s:
                $is_bounded_interval(J)
                J $subset I
                $is_nonempty_set(J)
                $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s)
                $has_nonempty_upper_riemann_piece_height(I, J, f, s)
                $has_upper_riemann_piece_height(I, J, f, s)
        case not $is_nonempty_set(J):
            witness exist s0 R st {$has_upper_riemann_piece_height(I, J, f, s0)} from 0:
                not $is_nonempty_set(J)
                0 = 0
                $has_empty_upper_riemann_piece_height(J, 0)
                $has_upper_riemann_piece_height(I, J, f, 0)
    claim:
        ? forall s1, s2 R:
            $has_upper_riemann_piece_height(I, J, f, s1)
            $has_upper_riemann_piece_height(I, J, f, s2)
            =>:
                s1 = s2
        by thm upper_riemann_piece_height_value_unique(I, J, f, s1, s2)
    exist! s0 R st {$has_upper_riemann_piece_height(I, J, f, s0)}

thm upper_riemann_piece_height_has_value:
    ? forall I power_set(R), J power_set(R), f fn(x I) R:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        =>:
            $has_upper_riemann_piece_height(I, J, f, upper_riemann_piece_height(I, J, f))
    have s R = upper_riemann_piece_height(I, J, f)
    $has_upper_riemann_piece_height(I, J, f, s)
    s = upper_riemann_piece_height(I, J, f)
    $has_upper_riemann_piece_height(I, J, f, upper_riemann_piece_height(I, J, f))

prop has_empty_lower_riemann_piece_height(J power_set(R), s R):
    not $is_nonempty_set(J)
    s = 0

prop has_nonempty_lower_riemann_piece_height(I power_set(R), J power_set(R), f fn(x I) R, s R):
    $is_bounded_interval(J)
    J $subset I
    $is_nonempty_set(J)
    $is_infimum_of_real_set(function_values_on_subset(I, J, f), s)

prop has_lower_riemann_piece_height(I power_set(R), J power_set(R), f fn(x I) R, s R):
    $has_empty_lower_riemann_piece_height(J, s) or $has_nonempty_lower_riemann_piece_height(I, J, f, s)

thm lower_riemann_piece_height_value_unique:
    ? forall I power_set(R), J power_set(R), f fn(x I) R, s1, s2 R:
        $has_lower_riemann_piece_height(I, J, f, s1)
        $has_lower_riemann_piece_height(I, J, f, s2)
        =>:
            s1 = s2
    $has_empty_lower_riemann_piece_height(J, s1) or $has_nonempty_lower_riemann_piece_height(I, J, f, s1)
    $has_empty_lower_riemann_piece_height(J, s2) or $has_nonempty_lower_riemann_piece_height(I, J, f, s2)
    by cases:
        ? s1 = s2
        case $has_empty_lower_riemann_piece_height(J, s1):
            s1 = 0
            by cases:
                ? s1 = s2
                case $has_empty_lower_riemann_piece_height(J, s2):
                    s2 = 0
                    s1 = s2
                case $has_nonempty_lower_riemann_piece_height(I, J, f, s2):
                    not $is_nonempty_set(J)
                    $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)
        case $has_nonempty_lower_riemann_piece_height(I, J, f, s1):
            $is_nonempty_set(J)
            by cases:
                ? s1 = s2
                case $has_empty_lower_riemann_piece_height(J, s2):
                    not $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)
                case $has_nonempty_lower_riemann_piece_height(I, J, f, s2):
                    $is_infimum_of_real_set(function_values_on_subset(I, J, f), s1)
                    $is_infimum_of_real_set(function_values_on_subset(I, J, f), s2)
                    by thm infimum_of_real_set_value_unique(function_values_on_subset(I, J, f), s1, s2)
                    s1 = s2

have fn lower_riemann_piece_height by exist!:
    ? forall I power_set(R), J power_set(R), f fn(x I) R:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist! s R st {$has_lower_riemann_piece_height(I, J, f, s)}
    by cases:
        ? exist s R st {$has_lower_riemann_piece_height(I, J, f, s)}
        case $is_nonempty_set(J):
            by thm nonempty_piece_function_values_has_infimum(I, J, f)
            obtain s from exist s R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s)}
            witness exist s0 R st {$has_lower_riemann_piece_height(I, J, f, s0)} from s:
                $is_bounded_interval(J)
                J $subset I
                $is_nonempty_set(J)
                $is_infimum_of_real_set(function_values_on_subset(I, J, f), s)
                $has_nonempty_lower_riemann_piece_height(I, J, f, s)
                $has_lower_riemann_piece_height(I, J, f, s)
        case not $is_nonempty_set(J):
            witness exist s0 R st {$has_lower_riemann_piece_height(I, J, f, s0)} from 0:
                not $is_nonempty_set(J)
                0 = 0
                $has_empty_lower_riemann_piece_height(J, 0)
                $has_lower_riemann_piece_height(I, J, f, 0)
    claim:
        ? forall s1, s2 R:
            $has_lower_riemann_piece_height(I, J, f, s1)
            $has_lower_riemann_piece_height(I, J, f, s2)
            =>:
                s1 = s2
        by thm lower_riemann_piece_height_value_unique(I, J, f, s1, s2)
    exist! s0 R st {$has_lower_riemann_piece_height(I, J, f, s0)}

thm lower_riemann_piece_height_has_value:
    ? forall I power_set(R), J power_set(R), f fn(x I) R:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        =>:
            $has_lower_riemann_piece_height(I, J, f, lower_riemann_piece_height(I, J, f))
    have s R = lower_riemann_piece_height(I, J, f)
    $has_lower_riemann_piece_height(I, J, f, s)
    s = lower_riemann_piece_height(I, J, f)
    $has_lower_riemann_piece_height(I, J, f, lower_riemann_piece_height(I, J, f))

have fn upper_riemann_partition_step_function(I power_set(R), P power_set(power_set(R)), f fn(t I) R: $is_finite_set(P), $is_partition_of_bounded_interval(I, P), $chap9::is_bounded_function_on(I, f)) fn(y I) R = fn(z I) R {upper_riemann_piece_height(I, partition_piece_containing(I, P, z), f)}

have fn lower_riemann_partition_step_function(I power_set(R), P power_set(power_set(R)), f fn(t I) R: $is_finite_set(P), $is_partition_of_bounded_interval(I, P), $chap9::is_bounded_function_on(I, f)) fn(y I) R = fn(z I) R {lower_riemann_piece_height(I, partition_piece_containing(I, P, z), f)}

thm upper_riemann_partition_step_function_has_value:
    ? forall I power_set(R), P power_set(power_set(R)), f fn(x I) R, x I:
        $is_finite_set(P)
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            upper_riemann_partition_step_function(I, P, f)(x) = upper_riemann_piece_height(I, partition_piece_containing(I, P, x), f)
    upper_riemann_partition_step_function(I, P, f) = fn(y I) R {upper_riemann_piece_height(I, partition_piece_containing(I, P, y), f)}
    upper_riemann_partition_step_function(I, P, f)(x) = fn(y I) R {upper_riemann_piece_height(I, partition_piece_containing(I, P, y), f)}(x)
    fn(y I) R {upper_riemann_piece_height(I, partition_piece_containing(I, P, y), f)}(x) = upper_riemann_piece_height(I, partition_piece_containing(I, P, x), f)
    upper_riemann_partition_step_function(I, P, f)(x) = upper_riemann_piece_height(I, partition_piece_containing(I, P, x), f)

thm lower_riemann_partition_step_function_has_value:
    ? forall I power_set(R), P power_set(power_set(R)), f fn(x I) R, x I:
        $is_finite_set(P)
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            lower_riemann_partition_step_function(I, P, f)(x) = lower_riemann_piece_height(I, partition_piece_containing(I, P, x), f)
    lower_riemann_partition_step_function(I, P, f) = fn(y I) R {lower_riemann_piece_height(I, partition_piece_containing(I, P, y), f)}
    lower_riemann_partition_step_function(I, P, f)(x) = fn(y I) R {lower_riemann_piece_height(I, partition_piece_containing(I, P, y), f)}(x)
    fn(y I) R {lower_riemann_piece_height(I, partition_piece_containing(I, P, y), f)}(x) = lower_riemann_piece_height(I, partition_piece_containing(I, P, x), f)
    lower_riemann_partition_step_function(I, P, f)(x) = lower_riemann_piece_height(I, partition_piece_containing(I, P, x), f)

thm upper_riemann_partition_step_function_is_piecewise_constant:
    ? forall I power_set(R), P power_set(power_set(R)), f fn(x I) R:
        $is_finite_set(P)
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $is_piecewise_constant_with_partition(I, P, upper_riemann_partition_step_function(I, P, f))
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, upper_riemann_partition_step_function(I, P, f))
        $is_partition_of_bounded_interval(I, P)
        J $in power_set(R)
        J $subset I
        witness exist c R st {$has_constant_value_on_subset(I, J, upper_riemann_partition_step_function(I, P, f), c)} from upper_riemann_piece_height(I, J, f):
            J $subset I
            claim:
                ? forall x J:
                    upper_riemann_partition_step_function(I, P, f)(x) = upper_riemann_piece_height(I, J, f)
                x $in I
                by thm partition_piece_containing_eq_given_piece(I, P, x, J)
                partition_piece_containing(I, P, x) = J
                by thm upper_riemann_partition_step_function_has_value(I, P, f, x)
                upper_riemann_partition_step_function(I, P, f)(x) = upper_riemann_piece_height(I, partition_piece_containing(I, P, x), f)
                upper_riemann_partition_step_function(I, P, f)(x) = upper_riemann_piece_height(I, J, f)
            $has_constant_value_on_subset(I, J, upper_riemann_partition_step_function(I, P, f), upper_riemann_piece_height(I, J, f))
        $is_constant_on_subset(I, J, upper_riemann_partition_step_function(I, P, f))
    $is_piecewise_constant_with_partition(I, P, upper_riemann_partition_step_function(I, P, f))

thm upper_riemann_partition_step_function_majorizes:
    ? forall I power_set(R), P power_set(power_set(R)), f fn(x I) R:
        $is_finite_set(P)
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $majorizes_on(I, upper_riemann_partition_step_function(I, P, f), f)
    claim:
        ? forall x I:
            f(x) <= upper_riemann_partition_step_function(I, P, f)(x)
        by thm partition_piece_containing_has_value(I, P, x)
        have J power_set(R) = partition_piece_containing(I, P, x)
        J $in P
        x $in J
        $is_partition_of_bounded_interval(I, P)
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset I
        by thm upper_riemann_piece_height_has_value(I, J, f)
        $has_upper_riemann_piece_height(I, J, f, upper_riemann_piece_height(I, J, f))
        $has_empty_upper_riemann_piece_height(J, upper_riemann_piece_height(I, J, f)) or $has_nonempty_upper_riemann_piece_height(I, J, f, upper_riemann_piece_height(I, J, f))
        by cases:
            ? f(x) <= upper_riemann_partition_step_function(I, P, f)(x)
            case $has_empty_upper_riemann_piece_height(J, upper_riemann_piece_height(I, J, f)):
                not $is_nonempty_set(J)
                witness $is_nonempty_set(J) from x:
                    x $in J
                impossible $is_nonempty_set(J)
            case $has_nonempty_upper_riemann_piece_height(I, J, f, upper_riemann_piece_height(I, J, f)):
                $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), upper_riemann_piece_height(I, J, f))
                by thm function_value_on_subset_member(I, J, f, x)
                f(x) $in function_values_on_subset(I, J, f)
                f(x) <= upper_riemann_piece_height(I, J, f)
                by thm upper_riemann_partition_step_function_has_value(I, P, f, x)
                upper_riemann_partition_step_function(I, P, f)(x) = upper_riemann_piece_height(I, partition_piece_containing(I, P, x), f)
                partition_piece_containing(I, P, x) = J
                upper_riemann_partition_step_function(I, P, f)(x) = upper_riemann_piece_height(I, J, f)
                f(x) <= upper_riemann_partition_step_function(I, P, f)(x)
    $majorizes_on(I, upper_riemann_partition_step_function(I, P, f), f)

thm lower_riemann_partition_step_function_is_piecewise_constant:
    ? forall I power_set(R), P power_set(power_set(R)), f fn(x I) R:
        $is_finite_set(P)
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $is_piecewise_constant_with_partition(I, P, lower_riemann_partition_step_function(I, P, f))
    claim:
        ? forall J P:
            J $in power_set(R)
            $is_constant_on_subset(I, J, lower_riemann_partition_step_function(I, P, f))
        $is_partition_of_bounded_interval(I, P)
        J $in power_set(R)
        J $subset I
        witness exist c R st {$has_constant_value_on_subset(I, J, lower_riemann_partition_step_function(I, P, f), c)} from lower_riemann_piece_height(I, J, f):
            J $subset I
            claim:
                ? forall x J:
                    lower_riemann_partition_step_function(I, P, f)(x) = lower_riemann_piece_height(I, J, f)
                x $in I
                by thm partition_piece_containing_eq_given_piece(I, P, x, J)
                partition_piece_containing(I, P, x) = J
                by thm lower_riemann_partition_step_function_has_value(I, P, f, x)
                lower_riemann_partition_step_function(I, P, f)(x) = lower_riemann_piece_height(I, partition_piece_containing(I, P, x), f)
                lower_riemann_partition_step_function(I, P, f)(x) = lower_riemann_piece_height(I, J, f)
            $has_constant_value_on_subset(I, J, lower_riemann_partition_step_function(I, P, f), lower_riemann_piece_height(I, J, f))
        $is_constant_on_subset(I, J, lower_riemann_partition_step_function(I, P, f))
    $is_piecewise_constant_with_partition(I, P, lower_riemann_partition_step_function(I, P, f))

thm lower_riemann_partition_step_function_minorizes:
    ? forall I power_set(R), P power_set(power_set(R)), f fn(x I) R:
        $is_finite_set(P)
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $minorizes_on(I, lower_riemann_partition_step_function(I, P, f), f)
    claim:
        ? forall x I:
            lower_riemann_partition_step_function(I, P, f)(x) <= f(x)
        by thm partition_piece_containing_has_value(I, P, x)
        have J power_set(R) = partition_piece_containing(I, P, x)
        J $in P
        x $in J
        $is_partition_of_bounded_interval(I, P)
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset I
        by thm lower_riemann_piece_height_has_value(I, J, f)
        $has_lower_riemann_piece_height(I, J, f, lower_riemann_piece_height(I, J, f))
        $has_empty_lower_riemann_piece_height(J, lower_riemann_piece_height(I, J, f)) or $has_nonempty_lower_riemann_piece_height(I, J, f, lower_riemann_piece_height(I, J, f))
        by cases:
            ? lower_riemann_partition_step_function(I, P, f)(x) <= f(x)
            case $has_empty_lower_riemann_piece_height(J, lower_riemann_piece_height(I, J, f)):
                not $is_nonempty_set(J)
                witness $is_nonempty_set(J) from x:
                    x $in J
                impossible $is_nonempty_set(J)
            case $has_nonempty_lower_riemann_piece_height(I, J, f, lower_riemann_piece_height(I, J, f)):
                $is_infimum_of_real_set(function_values_on_subset(I, J, f), lower_riemann_piece_height(I, J, f))
                by thm function_value_on_subset_member(I, J, f, x)
                f(x) $in function_values_on_subset(I, J, f)
                lower_riemann_piece_height(I, J, f) <= f(x)
                by thm lower_riemann_partition_step_function_has_value(I, P, f, x)
                lower_riemann_partition_step_function(I, P, f)(x) = lower_riemann_piece_height(I, partition_piece_containing(I, P, x), f)
                partition_piece_containing(I, P, x) = J
                lower_riemann_partition_step_function(I, P, f)(x) = lower_riemann_piece_height(I, J, f)
                lower_riemann_partition_step_function(I, P, f)(x) <= f(x)
    $minorizes_on(I, lower_riemann_partition_step_function(I, P, f), f)

thm upper_riemann_sum_piece_contribution_exists:
    ? forall I power_set(R), P finite_set, J P, f fn(x I) R:
        P $in power_set(power_set(R))
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist t R st {$has_upper_riemann_sum_piece_contribution(I, J, f, t)}
    P $in power_set(power_set(R))
    $is_partition_of_bounded_interval(I, P)
    J $in power_set(R)
    $is_bounded_interval(J)
    J $subset I
    by cases:
        ? exist t R st {$has_upper_riemann_sum_piece_contribution(I, J, f, t)}
        case $is_nonempty_set(J):
            by thm nonempty_piece_function_values_has_least_upper_bound(I, J, f)
            obtain upper from exist s R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s)}
            witness exist t0 R st {$has_upper_riemann_sum_piece_contribution(I, J, f, t0)} from upper * interval_length(J):
                $is_bounded_interval(J)
                J $subset I
                $is_nonempty_set(J)
                witness exist s R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s), upper * interval_length(J) = s * interval_length(J)} from upper:
                    $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), upper)
                    upper * interval_length(J) = upper * interval_length(J)
                exist s R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s), upper * interval_length(J) = s * interval_length(J)}
                $has_nonempty_upper_riemann_sum_piece_contribution(I, J, f, upper * interval_length(J))
                $has_upper_riemann_sum_piece_contribution(I, J, f, upper * interval_length(J))
        case not $is_nonempty_set(J):
            witness exist t0 R st {$has_upper_riemann_sum_piece_contribution(I, J, f, t0)} from 0:
                not $is_nonempty_set(J)
                0 = 0
                $has_empty_riemann_sum_piece_contribution(J, 0)
                $has_upper_riemann_sum_piece_contribution(I, J, f, 0)

thm lower_riemann_sum_piece_contribution_exists:
    ? forall I power_set(R), P finite_set, J P, f fn(x I) R:
        P $in power_set(power_set(R))
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist t R st {$has_lower_riemann_sum_piece_contribution(I, J, f, t)}
    P $in power_set(power_set(R))
    $is_partition_of_bounded_interval(I, P)
    J $in power_set(R)
    $is_bounded_interval(J)
    J $subset I
    by cases:
        ? exist t R st {$has_lower_riemann_sum_piece_contribution(I, J, f, t)}
        case $is_nonempty_set(J):
            by thm nonempty_piece_function_values_has_infimum(I, J, f)
            obtain lower from exist s R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s)}
            witness exist t0 R st {$has_lower_riemann_sum_piece_contribution(I, J, f, t0)} from lower * interval_length(J):
                $is_bounded_interval(J)
                J $subset I
                $is_nonempty_set(J)
                witness exist s R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s), lower * interval_length(J) = s * interval_length(J)} from lower:
                    $is_infimum_of_real_set(function_values_on_subset(I, J, f), lower)
                    lower * interval_length(J) = lower * interval_length(J)
                exist s R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s), lower * interval_length(J) = s * interval_length(J)}
                $has_nonempty_lower_riemann_sum_piece_contribution(I, J, f, lower * interval_length(J))
                $has_lower_riemann_sum_piece_contribution(I, J, f, lower * interval_length(J))
        case not $is_nonempty_set(J):
            witness exist t0 R st {$has_lower_riemann_sum_piece_contribution(I, J, f, t0)} from 0:
                not $is_nonempty_set(J)
                0 = 0
                $has_empty_riemann_sum_piece_contribution(J, 0)
                $has_lower_riemann_sum_piece_contribution(I, J, f, 0)

# The two relations above are specifications, while each piece contribution is
# a mathematical value.  The uniqueness facts expose that distinction before
# the canonical value APIs below select those values.

thm upper_riemann_sum_piece_contribution_unique:
    ? forall I power_set(R), J power_set(R), f fn(x I) R, t1, t2 R:
        $has_upper_riemann_sum_piece_contribution(I, J, f, t1)
        $has_upper_riemann_sum_piece_contribution(I, J, f, t2)
        =>:
            t1 = t2
    $has_empty_riemann_sum_piece_contribution(J, t1) or $has_nonempty_upper_riemann_sum_piece_contribution(I, J, f, t1)
    $has_empty_riemann_sum_piece_contribution(J, t2) or $has_nonempty_upper_riemann_sum_piece_contribution(I, J, f, t2)
    by cases:
        ? t1 = t2
        case $has_empty_riemann_sum_piece_contribution(J, t1):
            t1 = 0
            by cases:
                ? t1 = t2
                case $has_empty_riemann_sum_piece_contribution(J, t2):
                    t2 = 0
                    t1 = t2
                case $has_nonempty_upper_riemann_sum_piece_contribution(I, J, f, t2):
                    not $is_nonempty_set(J)
                    $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)
        case $has_nonempty_upper_riemann_sum_piece_contribution(I, J, f, t1):
            $is_nonempty_set(J)
            by cases:
                ? t1 = t2
                case $has_empty_riemann_sum_piece_contribution(J, t2):
                    not $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)
                case $has_nonempty_upper_riemann_sum_piece_contribution(I, J, f, t2):
                    obtain s1 from exist s R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s), t1 = s * interval_length(J)}
                    obtain s2 from exist s R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s), t2 = s * interval_length(J)}
                    by thm chap5::least_upper_bound_unique(function_values_on_subset(I, J, f), s1, s2)
                    s1 = s2
                    t1 = s1 * interval_length(J)
                    t2 = s2 * interval_length(J)
                    t1 = t2

thm lower_riemann_sum_piece_contribution_unique:
    ? forall I power_set(R), J power_set(R), f fn(x I) R, t1, t2 R:
        $has_lower_riemann_sum_piece_contribution(I, J, f, t1)
        $has_lower_riemann_sum_piece_contribution(I, J, f, t2)
        =>:
            t1 = t2
    $has_empty_riemann_sum_piece_contribution(J, t1) or $has_nonempty_lower_riemann_sum_piece_contribution(I, J, f, t1)
    $has_empty_riemann_sum_piece_contribution(J, t2) or $has_nonempty_lower_riemann_sum_piece_contribution(I, J, f, t2)
    by cases:
        ? t1 = t2
        case $has_empty_riemann_sum_piece_contribution(J, t1):
            t1 = 0
            by cases:
                ? t1 = t2
                case $has_empty_riemann_sum_piece_contribution(J, t2):
                    t2 = 0
                    t1 = t2
                case $has_nonempty_lower_riemann_sum_piece_contribution(I, J, f, t2):
                    not $is_nonempty_set(J)
                    $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)
        case $has_nonempty_lower_riemann_sum_piece_contribution(I, J, f, t1):
            $is_nonempty_set(J)
            by cases:
                ? t1 = t2
                case $has_empty_riemann_sum_piece_contribution(J, t2):
                    not $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)
                case $has_nonempty_lower_riemann_sum_piece_contribution(I, J, f, t2):
                    obtain s1 from exist s R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s), t1 = s * interval_length(J)}
                    obtain s2 from exist s R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s), t2 = s * interval_length(J)}
                    by thm infimum_of_real_set_value_unique(function_values_on_subset(I, J, f), s1, s2)
                    s1 = s2
                    t1 = s1 * interval_length(J)
                    t2 = s2 * interval_length(J)
                    t1 = t2

have fn upper_riemann_sum_piece by exist!:
    ? forall I power_set(R), J power_set(R), f fn(x I) R:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist! t R st {$has_upper_riemann_sum_piece_contribution(I, J, f, t)}
    by cases:
        ? exist t R st {$has_upper_riemann_sum_piece_contribution(I, J, f, t)}
        case $is_nonempty_set(J):
            by thm nonempty_piece_function_values_has_least_upper_bound(I, J, f)
            obtain upper from exist s R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s)}
            claim:
                ? exist t R st {$has_upper_riemann_sum_piece_contribution(I, J, f, t)}
                witness exist t0 R st {$has_upper_riemann_sum_piece_contribution(I, J, f, t0)} from upper * interval_length(J):
                    $is_bounded_interval(J)
                    J $subset I
                    $is_nonempty_set(J)
                    witness exist s R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s), upper * interval_length(J) = s * interval_length(J)} from upper:
                        $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), upper)
                        upper * interval_length(J) = upper * interval_length(J)
                    exist s R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s), upper * interval_length(J) = s * interval_length(J)}
                    $has_nonempty_upper_riemann_sum_piece_contribution(I, J, f, upper * interval_length(J))
                    $has_upper_riemann_sum_piece_contribution(I, J, f, upper * interval_length(J))
            claim:
                ? forall t1, t2 R:
                    $has_upper_riemann_sum_piece_contribution(I, J, f, t1)
                    $has_upper_riemann_sum_piece_contribution(I, J, f, t2)
                    =>:
                        t1 = t2
                by thm upper_riemann_sum_piece_contribution_unique(I, J, f, t1, t2)
            exist! t0 R st {$has_upper_riemann_sum_piece_contribution(I, J, f, t0)}
        case not $is_nonempty_set(J):
            claim:
                ? exist t R st {$has_upper_riemann_sum_piece_contribution(I, J, f, t)}
                witness exist t0 R st {$has_upper_riemann_sum_piece_contribution(I, J, f, t0)} from 0:
                    not $is_nonempty_set(J)
                    0 = 0
                    $has_empty_riemann_sum_piece_contribution(J, 0)
                    $has_upper_riemann_sum_piece_contribution(I, J, f, 0)
            claim:
                ? forall t1, t2 R:
                    $has_upper_riemann_sum_piece_contribution(I, J, f, t1)
                    $has_upper_riemann_sum_piece_contribution(I, J, f, t2)
                    =>:
                        t1 = t2
                by thm upper_riemann_sum_piece_contribution_unique(I, J, f, t1, t2)
            exist! t0 R st {$has_upper_riemann_sum_piece_contribution(I, J, f, t0)}

have fn lower_riemann_sum_piece by exist!:
    ? forall I power_set(R), J power_set(R), f fn(x I) R:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist! t R st {$has_lower_riemann_sum_piece_contribution(I, J, f, t)}
    by cases:
        ? exist t R st {$has_lower_riemann_sum_piece_contribution(I, J, f, t)}
        case $is_nonempty_set(J):
            by thm nonempty_piece_function_values_has_infimum(I, J, f)
            obtain lower from exist s R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s)}
            claim:
                ? exist t R st {$has_lower_riemann_sum_piece_contribution(I, J, f, t)}
                witness exist t0 R st {$has_lower_riemann_sum_piece_contribution(I, J, f, t0)} from lower * interval_length(J):
                    $is_bounded_interval(J)
                    J $subset I
                    $is_nonempty_set(J)
                    witness exist s R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s), lower * interval_length(J) = s * interval_length(J)} from lower:
                        $is_infimum_of_real_set(function_values_on_subset(I, J, f), lower)
                        lower * interval_length(J) = lower * interval_length(J)
                    exist s R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s), lower * interval_length(J) = s * interval_length(J)}
                    $has_nonempty_lower_riemann_sum_piece_contribution(I, J, f, lower * interval_length(J))
                    $has_lower_riemann_sum_piece_contribution(I, J, f, lower * interval_length(J))
            claim:
                ? forall t1, t2 R:
                    $has_lower_riemann_sum_piece_contribution(I, J, f, t1)
                    $has_lower_riemann_sum_piece_contribution(I, J, f, t2)
                    =>:
                        t1 = t2
                by thm lower_riemann_sum_piece_contribution_unique(I, J, f, t1, t2)
            exist! t0 R st {$has_lower_riemann_sum_piece_contribution(I, J, f, t0)}
        case not $is_nonempty_set(J):
            claim:
                ? exist t R st {$has_lower_riemann_sum_piece_contribution(I, J, f, t)}
                witness exist t0 R st {$has_lower_riemann_sum_piece_contribution(I, J, f, t0)} from 0:
                    not $is_nonempty_set(J)
                    0 = 0
                    $has_empty_riemann_sum_piece_contribution(J, 0)
                    $has_lower_riemann_sum_piece_contribution(I, J, f, 0)
            claim:
                ? forall t1, t2 R:
                    $has_lower_riemann_sum_piece_contribution(I, J, f, t1)
                    $has_lower_riemann_sum_piece_contribution(I, J, f, t2)
                    =>:
                        t1 = t2
                by thm lower_riemann_sum_piece_contribution_unique(I, J, f, t1, t2)
            exist! t0 R st {$has_lower_riemann_sum_piece_contribution(I, J, f, t0)}

thm upper_riemann_sum_piece_has_value:
    ? forall I power_set(R), J power_set(R), f fn(x I) R:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        =>:
            $has_upper_riemann_sum_piece_contribution(I, J, f, upper_riemann_sum_piece(I, J, f))
    have t R = upper_riemann_sum_piece(I, J, f)
    $has_upper_riemann_sum_piece_contribution(I, J, f, t)
    t = upper_riemann_sum_piece(I, J, f)
    $has_upper_riemann_sum_piece_contribution(I, J, f, upper_riemann_sum_piece(I, J, f))

thm lower_riemann_sum_piece_has_value:
    ? forall I power_set(R), J power_set(R), f fn(x I) R:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        =>:
            $has_lower_riemann_sum_piece_contribution(I, J, f, lower_riemann_sum_piece(I, J, f))
    have t R = lower_riemann_sum_piece(I, J, f)
    $has_lower_riemann_sum_piece_contribution(I, J, f, t)
    t = lower_riemann_sum_piece(I, J, f)
    $has_lower_riemann_sum_piece_contribution(I, J, f, lower_riemann_sum_piece(I, J, f))

thm upper_riemann_sum_piece_is_height_times_length:
    ? forall I power_set(R), J power_set(R), f fn(x I) R:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        =>:
            upper_riemann_sum_piece(I, J, f) = upper_riemann_piece_height(I, J, f) * interval_length(J)
    by thm upper_riemann_sum_piece_has_value(I, J, f)
    $has_upper_riemann_sum_piece_contribution(I, J, f, upper_riemann_sum_piece(I, J, f))
    by thm upper_riemann_piece_height_has_value(I, J, f)
    $has_upper_riemann_piece_height(I, J, f, upper_riemann_piece_height(I, J, f))
    by cases:
        ? upper_riemann_sum_piece(I, J, f) = upper_riemann_piece_height(I, J, f) * interval_length(J)
        case $is_nonempty_set(J):
            $has_empty_upper_riemann_sum_piece_contribution(J, upper_riemann_sum_piece(I, J, f)) or $has_nonempty_upper_riemann_sum_piece_contribution(I, J, f, upper_riemann_sum_piece(I, J, f))
            $has_empty_upper_riemann_piece_height(J, upper_riemann_piece_height(I, J, f)) or $has_nonempty_upper_riemann_piece_height(I, J, f, upper_riemann_piece_height(I, J, f))
            by cases:
                ? upper_riemann_sum_piece(I, J, f) = upper_riemann_piece_height(I, J, f) * interval_length(J)
                case $has_empty_upper_riemann_sum_piece_contribution(J, upper_riemann_sum_piece(I, J, f)):
                    not $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)
                case $has_nonempty_upper_riemann_sum_piece_contribution(I, J, f, upper_riemann_sum_piece(I, J, f)):
                    obtain s from exist s R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s), upper_riemann_sum_piece(I, J, f) = s * interval_length(J)}
                    by cases:
                        ? upper_riemann_sum_piece(I, J, f) = upper_riemann_piece_height(I, J, f) * interval_length(J)
                        case $has_empty_upper_riemann_piece_height(J, upper_riemann_piece_height(I, J, f)):
                            not $is_nonempty_set(J)
                            impossible $is_nonempty_set(J)
                        case $has_nonempty_upper_riemann_piece_height(I, J, f, upper_riemann_piece_height(I, J, f)):
                            $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), upper_riemann_piece_height(I, J, f))
                            by thm chap5::least_upper_bound_unique(function_values_on_subset(I, J, f), s, upper_riemann_piece_height(I, J, f))
                            s = upper_riemann_piece_height(I, J, f)
                            upper_riemann_sum_piece(I, J, f) = s * interval_length(J) = upper_riemann_piece_height(I, J, f) * interval_length(J)
        case not $is_nonempty_set(J):
            $has_empty_upper_riemann_sum_piece_contribution(J, upper_riemann_sum_piece(I, J, f)) or $has_nonempty_upper_riemann_sum_piece_contribution(I, J, f, upper_riemann_sum_piece(I, J, f))
            $has_empty_upper_riemann_piece_height(J, upper_riemann_piece_height(I, J, f)) or $has_nonempty_upper_riemann_piece_height(I, J, f, upper_riemann_piece_height(I, J, f))
            by cases:
                ? upper_riemann_sum_piece(I, J, f) = upper_riemann_piece_height(I, J, f) * interval_length(J)
                case $has_empty_upper_riemann_sum_piece_contribution(J, upper_riemann_sum_piece(I, J, f)):
                    upper_riemann_sum_piece(I, J, f) = 0
                    by cases:
                        ? upper_riemann_sum_piece(I, J, f) = upper_riemann_piece_height(I, J, f) * interval_length(J)
                        case $has_empty_upper_riemann_piece_height(J, upper_riemann_piece_height(I, J, f)):
                            upper_riemann_piece_height(I, J, f) = 0
                            upper_riemann_sum_piece(I, J, f) = 0 = 0 * interval_length(J) = upper_riemann_piece_height(I, J, f) * interval_length(J)
                        case $has_nonempty_upper_riemann_piece_height(I, J, f, upper_riemann_piece_height(I, J, f)):
                            $is_nonempty_set(J)
                            impossible $is_nonempty_set(J)
                case $has_nonempty_upper_riemann_sum_piece_contribution(I, J, f, upper_riemann_sum_piece(I, J, f)):
                    $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)

thm lower_riemann_sum_piece_is_height_times_length:
    ? forall I power_set(R), J power_set(R), f fn(x I) R:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        =>:
            lower_riemann_sum_piece(I, J, f) = lower_riemann_piece_height(I, J, f) * interval_length(J)
    by thm lower_riemann_sum_piece_has_value(I, J, f)
    $has_lower_riemann_sum_piece_contribution(I, J, f, lower_riemann_sum_piece(I, J, f))
    by thm lower_riemann_piece_height_has_value(I, J, f)
    $has_lower_riemann_piece_height(I, J, f, lower_riemann_piece_height(I, J, f))
    by cases:
        ? lower_riemann_sum_piece(I, J, f) = lower_riemann_piece_height(I, J, f) * interval_length(J)
        case $is_nonempty_set(J):
            $has_empty_riemann_sum_piece_contribution(J, lower_riemann_sum_piece(I, J, f)) or $has_nonempty_lower_riemann_sum_piece_contribution(I, J, f, lower_riemann_sum_piece(I, J, f))
            $has_empty_lower_riemann_piece_height(J, lower_riemann_piece_height(I, J, f)) or $has_nonempty_lower_riemann_piece_height(I, J, f, lower_riemann_piece_height(I, J, f))
            by cases:
                ? lower_riemann_sum_piece(I, J, f) = lower_riemann_piece_height(I, J, f) * interval_length(J)
                case $has_empty_riemann_sum_piece_contribution(J, lower_riemann_sum_piece(I, J, f)):
                    not $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)
                case $has_nonempty_lower_riemann_sum_piece_contribution(I, J, f, lower_riemann_sum_piece(I, J, f)):
                    obtain s from exist s R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s), lower_riemann_sum_piece(I, J, f) = s * interval_length(J)}
                    by cases:
                        ? lower_riemann_sum_piece(I, J, f) = lower_riemann_piece_height(I, J, f) * interval_length(J)
                        case $has_empty_lower_riemann_piece_height(J, lower_riemann_piece_height(I, J, f)):
                            not $is_nonempty_set(J)
                            impossible $is_nonempty_set(J)
                        case $has_nonempty_lower_riemann_piece_height(I, J, f, lower_riemann_piece_height(I, J, f)):
                            $is_infimum_of_real_set(function_values_on_subset(I, J, f), lower_riemann_piece_height(I, J, f))
                            by thm infimum_of_real_set_value_unique(function_values_on_subset(I, J, f), s, lower_riemann_piece_height(I, J, f))
                            s = lower_riemann_piece_height(I, J, f)
                            lower_riemann_sum_piece(I, J, f) = s * interval_length(J) = lower_riemann_piece_height(I, J, f) * interval_length(J)
        case not $is_nonempty_set(J):
            $has_empty_riemann_sum_piece_contribution(J, lower_riemann_sum_piece(I, J, f)) or $has_nonempty_lower_riemann_sum_piece_contribution(I, J, f, lower_riemann_sum_piece(I, J, f))
            $has_empty_lower_riemann_piece_height(J, lower_riemann_piece_height(I, J, f)) or $has_nonempty_lower_riemann_piece_height(I, J, f, lower_riemann_piece_height(I, J, f))
            by cases:
                ? lower_riemann_sum_piece(I, J, f) = lower_riemann_piece_height(I, J, f) * interval_length(J)
                case $has_empty_riemann_sum_piece_contribution(J, lower_riemann_sum_piece(I, J, f)):
                    lower_riemann_sum_piece(I, J, f) = 0
                    by cases:
                        ? lower_riemann_sum_piece(I, J, f) = lower_riemann_piece_height(I, J, f) * interval_length(J)
                        case $has_empty_lower_riemann_piece_height(J, lower_riemann_piece_height(I, J, f)):
                            lower_riemann_piece_height(I, J, f) = 0
                            lower_riemann_sum_piece(I, J, f) = 0 = 0 * interval_length(J) = lower_riemann_piece_height(I, J, f) * interval_length(J)
                        case $has_nonempty_lower_riemann_piece_height(I, J, f, lower_riemann_piece_height(I, J, f)):
                            $is_nonempty_set(J)
                            impossible $is_nonempty_set(J)
                case $has_nonempty_lower_riemann_sum_piece_contribution(I, J, f, lower_riemann_sum_piece(I, J, f)):
                    $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)

# The canonical upper/lower step functions turn the old per-piece Riemann
# contribution into the ordinary rectangle contribution of that step function.
# This is the precise bridge between the two previously parallel APIs.
thm upper_riemann_partition_step_function_piece_contribution:
    ? forall I power_set(R), P finite_set, J P, f fn(x I) R:
        P $in power_set(power_set(R))
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f)) = upper_riemann_sum_piece(I, J, f)
    $is_partition_of_bounded_interval(I, P)
    J $in power_set(R)
    $is_bounded_interval(J)
    J $subset I
    claim:
        ? $has_constant_value_on_subset(I, J, upper_riemann_partition_step_function(I, P, f), upper_riemann_piece_height(I, J, f))
        claim:
            ? forall x J:
                upper_riemann_partition_step_function(I, P, f)(x) = upper_riemann_piece_height(I, J, f)
            x $in I
            by thm partition_piece_containing_eq_given_piece(I, P, x, J)
            partition_piece_containing(I, P, x) = J
            by thm upper_riemann_partition_step_function_has_value(I, P, f, x)
            upper_riemann_partition_step_function(I, P, f)(x) = upper_riemann_piece_height(I, partition_piece_containing(I, P, x), f)
            upper_riemann_partition_step_function(I, P, f)(x) = upper_riemann_piece_height(I, J, f)
        $has_constant_value_on_subset(I, J, upper_riemann_partition_step_function(I, P, f), upper_riemann_piece_height(I, J, f))
    claim:
        ? $has_piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f), upper_riemann_piece_height(I, J, f) * interval_length(J))
        witness exist c R st {$has_constant_value_on_subset(I, J, upper_riemann_partition_step_function(I, P, f), c), upper_riemann_piece_height(I, J, f) * interval_length(J) = c * interval_length(J)} from upper_riemann_piece_height(I, J, f):
            $has_constant_value_on_subset(I, J, upper_riemann_partition_step_function(I, P, f), upper_riemann_piece_height(I, J, f))
            upper_riemann_piece_height(I, J, f) * interval_length(J) = upper_riemann_piece_height(I, J, f) * interval_length(J)
        $has_piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f), upper_riemann_piece_height(I, J, f) * interval_length(J))
    by thm piecewise_constant_integral_piece_contribution_has_value(I, J, upper_riemann_partition_step_function(I, P, f), upper_riemann_piece_height(I, J, f) * interval_length(J))
    piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f)) = upper_riemann_piece_height(I, J, f) * interval_length(J)
    by thm upper_riemann_sum_piece_is_height_times_length(I, J, f)
    upper_riemann_sum_piece(I, J, f) = upper_riemann_piece_height(I, J, f) * interval_length(J)
    piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f)) = upper_riemann_sum_piece(I, J, f)

thm lower_riemann_partition_step_function_piece_contribution:
    ? forall I power_set(R), P finite_set, J P, f fn(x I) R:
        P $in power_set(power_set(R))
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f)) = lower_riemann_sum_piece(I, J, f)
    $is_partition_of_bounded_interval(I, P)
    J $in power_set(R)
    $is_bounded_interval(J)
    J $subset I
    claim:
        ? $has_constant_value_on_subset(I, J, lower_riemann_partition_step_function(I, P, f), lower_riemann_piece_height(I, J, f))
        claim:
            ? forall x J:
                lower_riemann_partition_step_function(I, P, f)(x) = lower_riemann_piece_height(I, J, f)
            x $in I
            by thm partition_piece_containing_eq_given_piece(I, P, x, J)
            partition_piece_containing(I, P, x) = J
            by thm lower_riemann_partition_step_function_has_value(I, P, f, x)
            lower_riemann_partition_step_function(I, P, f)(x) = lower_riemann_piece_height(I, partition_piece_containing(I, P, x), f)
            lower_riemann_partition_step_function(I, P, f)(x) = lower_riemann_piece_height(I, J, f)
        $has_constant_value_on_subset(I, J, lower_riemann_partition_step_function(I, P, f), lower_riemann_piece_height(I, J, f))
    claim:
        ? $has_piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f), lower_riemann_piece_height(I, J, f) * interval_length(J))
        witness exist c R st {$has_constant_value_on_subset(I, J, lower_riemann_partition_step_function(I, P, f), c), lower_riemann_piece_height(I, J, f) * interval_length(J) = c * interval_length(J)} from lower_riemann_piece_height(I, J, f):
            $has_constant_value_on_subset(I, J, lower_riemann_partition_step_function(I, P, f), lower_riemann_piece_height(I, J, f))
            lower_riemann_piece_height(I, J, f) * interval_length(J) = lower_riemann_piece_height(I, J, f) * interval_length(J)
        $has_piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f), lower_riemann_piece_height(I, J, f) * interval_length(J))
    by thm piecewise_constant_integral_piece_contribution_has_value(I, J, lower_riemann_partition_step_function(I, P, f), lower_riemann_piece_height(I, J, f) * interval_length(J))
    piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f)) = lower_riemann_piece_height(I, J, f) * interval_length(J)
    by thm lower_riemann_sum_piece_is_height_times_length(I, J, f)
    lower_riemann_sum_piece(I, J, f) = lower_riemann_piece_height(I, J, f) * interval_length(J)
    piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f)) = lower_riemann_sum_piece(I, J, f)

# A constant majorant on one piece bounds the supremum rectangle for that
# piece. This is the local order step before any finite partition sum.
thm constant_majorant_bounds_upper_riemann_sum_piece:
    ? forall I power_set(R), J power_set(R), f, g fn(x I) R, c R:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        $has_constant_value_on_subset(I, J, g, c)
        $majorizes_on(I, g, f)
        =>:
            upper_riemann_sum_piece(I, J, f) <= c * interval_length(J)
    by thm upper_riemann_sum_piece_has_value(I, J, f)
    $has_upper_riemann_sum_piece_contribution(I, J, f, upper_riemann_sum_piece(I, J, f))
    by cases:
        ? upper_riemann_sum_piece(I, J, f) <= c * interval_length(J)
        case $is_nonempty_set(J):
            obtain s from exist s R st {$chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s), upper_riemann_sum_piece(I, J, f) = s * interval_length(J)}
            claim:
                ? $chap5::is_upper_bound(function_values_on_subset(I, J, f), c)
                claim:
                    ? forall y function_values_on_subset(I, J, f):
                        y <= c
                    by thm function_values_on_subset_member_has_preimage(I, J, f, y)
                    obtain x from exist x J st {y = f(x)}
                    x $in I
                    y = f(x)
                    f(x) <= g(x)
                    g(x) = c
                    y <= c
                $chap5::is_upper_bound(function_values_on_subset(I, J, f), c)
            $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), s)
            s <= c
            by thm interval_length_nonnegative(J)
            interval_length(J) >= 0
            s * interval_length(J) <= c * interval_length(J)
            upper_riemann_sum_piece(I, J, f) = s * interval_length(J) <= c * interval_length(J)
        case not $is_nonempty_set(J):
            $has_empty_riemann_sum_piece_contribution(J, upper_riemann_sum_piece(I, J, f)) or $has_nonempty_upper_riemann_sum_piece_contribution(I, J, f, upper_riemann_sum_piece(I, J, f))
            by cases:
                ? upper_riemann_sum_piece(I, J, f) <= c * interval_length(J)
                case $has_empty_riemann_sum_piece_contribution(J, upper_riemann_sum_piece(I, J, f)):
                    upper_riemann_sum_piece(I, J, f) = 0
                    by thm empty_bounded_interval_length_value(J)
                    interval_length(J) = 0
                    upper_riemann_sum_piece(I, J, f) = 0 <= c * 0 = c * interval_length(J)
                case $has_nonempty_upper_riemann_sum_piece_contribution(I, J, f, upper_riemann_sum_piece(I, J, f)):
                    $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)

# The lower-sum counterpart uses the same value-set API with an infimum and a
# constant minorant.
thm constant_minorant_bounds_lower_riemann_sum_piece:
    ? forall I power_set(R), J power_set(R), f, h fn(x I) R, c R:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        $has_constant_value_on_subset(I, J, h, c)
        $minorizes_on(I, h, f)
        =>:
            c * interval_length(J) <= lower_riemann_sum_piece(I, J, f)
    by thm lower_riemann_sum_piece_has_value(I, J, f)
    $has_lower_riemann_sum_piece_contribution(I, J, f, lower_riemann_sum_piece(I, J, f))
    by cases:
        ? c * interval_length(J) <= lower_riemann_sum_piece(I, J, f)
        case $is_nonempty_set(J):
            obtain s from exist s R st {$is_infimum_of_real_set(function_values_on_subset(I, J, f), s), lower_riemann_sum_piece(I, J, f) = s * interval_length(J)}
            claim:
                ? $is_lower_bound_of_real_set(function_values_on_subset(I, J, f), c)
                claim:
                    ? forall y function_values_on_subset(I, J, f):
                        c <= y
                    by thm function_values_on_subset_member_has_preimage(I, J, f, y)
                    obtain x from exist x J st {y = f(x)}
                    x $in I
                    y = f(x)
                    h(x) <= f(x)
                    h(x) = c
                    c <= y
                $is_lower_bound_of_real_set(function_values_on_subset(I, J, f), c)
            $is_infimum_of_real_set(function_values_on_subset(I, J, f), s)
            c <= s
            by thm interval_length_nonnegative(J)
            interval_length(J) >= 0
            c * interval_length(J) <= s * interval_length(J)
            c * interval_length(J) <= s * interval_length(J) = lower_riemann_sum_piece(I, J, f)
        case not $is_nonempty_set(J):
            $has_empty_riemann_sum_piece_contribution(J, lower_riemann_sum_piece(I, J, f)) or $has_nonempty_lower_riemann_sum_piece_contribution(I, J, f, lower_riemann_sum_piece(I, J, f))
            by cases:
                ? c * interval_length(J) <= lower_riemann_sum_piece(I, J, f)
                case $has_empty_riemann_sum_piece_contribution(J, lower_riemann_sum_piece(I, J, f)):
                    lower_riemann_sum_piece(I, J, f) = 0
                    by thm empty_bounded_interval_length_value(J)
                    interval_length(J) = 0
                    c * interval_length(J) = c * 0 = 0 <= lower_riemann_sum_piece(I, J, f)
                case $has_nonempty_lower_riemann_sum_piece_contribution(I, J, f, lower_riemann_sum_piece(I, J, f)):
                    $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)

prop is_upper_riemann_sum_contribution_family(I power_set(R), P finite_set, f fn(x I) R, c fn(J P) R):
    forall J P:
        $has_upper_riemann_sum_piece_contribution(I, J, f, c(J))

prop is_lower_riemann_sum_contribution_family(I power_set(R), P finite_set, f fn(x I) R, c fn(J P) R):
    forall J P:
        $has_lower_riemann_sum_piece_contribution(I, J, f, c(J))

prop has_upper_riemann_sum(I power_set(R), P finite_set, f fn(x I) R, U R):
    P $in power_set(power_set(R))
    $is_partition_of_bounded_interval(I, P)
    $chap9::is_bounded_function_on(I, f)
    exist c fn(J P) R st {$is_upper_riemann_sum_contribution_family(I, P, f, c), U = finite_set_sum(P, c)}

prop has_lower_riemann_sum(I power_set(R), P finite_set, f fn(x I) R, L R):
    P $in power_set(power_set(R))
    $is_partition_of_bounded_interval(I, P)
    $chap9::is_bounded_function_on(I, f)
    exist c fn(J P) R st {$is_lower_riemann_sum_contribution_family(I, P, f, c), L = finite_set_sum(P, c)}

thm upper_riemann_sum_exists:
    ? forall I power_set(R), P finite_set, f fn(x I) R:
        P $in power_set(power_set(R))
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist U R st {$has_upper_riemann_sum(I, P, f, U)}
    have fn upper_piece_value_set(J P) power_set(R) = {t R: $has_upper_riemann_sum_piece_contribution(I, J, f, t)}
    claim:
        ? forall A fn_range(upper_piece_value_set):
            $is_nonempty_set(A)
        have by preimage J from A $in fn_range(upper_piece_value_set)
        A = upper_piece_value_set(J)
        by thm upper_riemann_sum_piece_contribution_exists(I, P, J, f)
        obtain t from exist t R st {$has_upper_riemann_sum_piece_contribution(I, J, f, t)}
        upper_piece_value_set(J) = {t R: $has_upper_riemann_sum_piece_contribution(I, J, f, t)}
        t $in upper_piece_value_set(J)
        t $in A
        witness $is_nonempty_set(A) from t:
            t $in A
    claim:
        ? exist f fn(A fn_range(upper_piece_value_set)) big_union(fn_range(upper_piece_value_set)) st {forall! A fn_range(upper_piece_value_set) => {f(A) $in A}}
        by axiom_of_choice: set fn_range(upper_piece_value_set)
    obtain choose_upper from exist f fn(A fn_range(upper_piece_value_set)) big_union(fn_range(upper_piece_value_set)) st {forall! A fn_range(upper_piece_value_set) => {f(A) $in A}}
    claim:
        ? forall J P:
            choose_upper(upper_piece_value_set(J)) $in R
        choose_upper(upper_piece_value_set(J)) $in upper_piece_value_set(J)
        upper_piece_value_set(J) $in power_set(R)
        choose_upper(upper_piece_value_set(J)) $in R
    have fn c(J P) R = choose_upper(upper_piece_value_set(J))
    witness exist U0 R st {$has_upper_riemann_sum(I, P, f, U0)} from finite_set_sum(P, c):
        P $in power_set(power_set(R))
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        witness exist c0 fn(J P) R st {$is_upper_riemann_sum_contribution_family(I, P, f, c0), finite_set_sum(P, c) = finite_set_sum(P, c0)} from c:
            forall J P:
                c(J) = choose_upper(upper_piece_value_set(J))
                choose_upper(upper_piece_value_set(J)) $in upper_piece_value_set(J)
                c(J) $in upper_piece_value_set(J)
                $has_upper_riemann_sum_piece_contribution(I, J, f, c(J))
            $is_upper_riemann_sum_contribution_family(I, P, f, c)
            finite_set_sum(P, c) = finite_set_sum(P, c)
        exist c0 fn(J P) R st {$is_upper_riemann_sum_contribution_family(I, P, f, c0), finite_set_sum(P, c) = finite_set_sum(P, c0)}
        $has_upper_riemann_sum(I, P, f, finite_set_sum(P, c))

thm lower_riemann_sum_exists:
    ? forall I power_set(R), P finite_set, f fn(x I) R:
        P $in power_set(power_set(R))
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist L R st {$has_lower_riemann_sum(I, P, f, L)}
    have fn lower_piece_value_set(J P) power_set(R) = {t R: $has_lower_riemann_sum_piece_contribution(I, J, f, t)}
    claim:
        ? forall A fn_range(lower_piece_value_set):
            $is_nonempty_set(A)
        have by preimage J from A $in fn_range(lower_piece_value_set)
        A = lower_piece_value_set(J)
        by thm lower_riemann_sum_piece_contribution_exists(I, P, J, f)
        obtain t from exist t R st {$has_lower_riemann_sum_piece_contribution(I, J, f, t)}
        lower_piece_value_set(J) = {t R: $has_lower_riemann_sum_piece_contribution(I, J, f, t)}
        t $in lower_piece_value_set(J)
        t $in A
        witness $is_nonempty_set(A) from t:
            t $in A
    claim:
        ? exist f fn(A fn_range(lower_piece_value_set)) big_union(fn_range(lower_piece_value_set)) st {forall! A fn_range(lower_piece_value_set) => {f(A) $in A}}
        by axiom_of_choice: set fn_range(lower_piece_value_set)
    obtain choose_lower from exist f fn(A fn_range(lower_piece_value_set)) big_union(fn_range(lower_piece_value_set)) st {forall! A fn_range(lower_piece_value_set) => {f(A) $in A}}
    claim:
        ? forall J P:
            choose_lower(lower_piece_value_set(J)) $in R
        choose_lower(lower_piece_value_set(J)) $in lower_piece_value_set(J)
        lower_piece_value_set(J) $in power_set(R)
        choose_lower(lower_piece_value_set(J)) $in R
    have fn c(J P) R = choose_lower(lower_piece_value_set(J))
    witness exist L0 R st {$has_lower_riemann_sum(I, P, f, L0)} from finite_set_sum(P, c):
        P $in power_set(power_set(R))
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        witness exist c0 fn(J P) R st {$is_lower_riemann_sum_contribution_family(I, P, f, c0), finite_set_sum(P, c) = finite_set_sum(P, c0)} from c:
            forall J P:
                c(J) = choose_lower(lower_piece_value_set(J))
                choose_lower(lower_piece_value_set(J)) $in lower_piece_value_set(J)
                c(J) $in lower_piece_value_set(J)
                $has_lower_riemann_sum_piece_contribution(I, J, f, c(J))
            $is_lower_riemann_sum_contribution_family(I, P, f, c)
            finite_set_sum(P, c) = finite_set_sum(P, c)
        exist c0 fn(J P) R st {$is_lower_riemann_sum_contribution_family(I, P, f, c0), finite_set_sum(P, c) = finite_set_sum(P, c0)}
        $has_lower_riemann_sum(I, P, f, finite_set_sum(P, c))

thm upper_riemann_sum_contribution_family_unique:
    ? forall I power_set(R), P finite_set, f fn(x I) R, c1, c2 fn(J P) R:
        $is_upper_riemann_sum_contribution_family(I, P, f, c1)
        $is_upper_riemann_sum_contribution_family(I, P, f, c2)
        =>:
            c1 = c2
    claim:
        ? forall J P:
            c1(J) = c2(J)
        $has_upper_riemann_sum_piece_contribution(I, J, f, c1(J))
        $has_upper_riemann_sum_piece_contribution(I, J, f, c2(J))
        by thm upper_riemann_sum_piece_contribution_unique(I, J, f, c1(J), c2(J))
        c1(J) = c2(J)
    claim:
        ? $fn_eq(c1, c2)
        forall J P:
            c1(J) = c2(J)
        $fn_eq(c1, c2)
    c1 = c2

thm lower_riemann_sum_contribution_family_unique:
    ? forall I power_set(R), P finite_set, f fn(x I) R, c1, c2 fn(J P) R:
        $is_lower_riemann_sum_contribution_family(I, P, f, c1)
        $is_lower_riemann_sum_contribution_family(I, P, f, c2)
        =>:
            c1 = c2
    claim:
        ? forall J P:
            c1(J) = c2(J)
        $has_lower_riemann_sum_piece_contribution(I, J, f, c1(J))
        $has_lower_riemann_sum_piece_contribution(I, J, f, c2(J))
        by thm lower_riemann_sum_piece_contribution_unique(I, J, f, c1(J), c2(J))
        c1(J) = c2(J)
    claim:
        ? $fn_eq(c1, c2)
        forall J P:
            c1(J) = c2(J)
        $fn_eq(c1, c2)
    c1 = c2

thm upper_riemann_sum_value_unique:
    ? forall I power_set(R), P finite_set, f fn(x I) R, U1, U2 R:
        $has_upper_riemann_sum(I, P, f, U1)
        $has_upper_riemann_sum(I, P, f, U2)
        =>:
            U1 = U2
    obtain c1 from exist c fn(J P) R st {$is_upper_riemann_sum_contribution_family(I, P, f, c), U1 = finite_set_sum(P, c)}
    obtain c2 from exist c fn(J P) R st {$is_upper_riemann_sum_contribution_family(I, P, f, c), U2 = finite_set_sum(P, c)}
    by thm upper_riemann_sum_contribution_family_unique(I, P, f, c1, c2)
    c1 = c2
    finite_set_sum(P, c1) = finite_set_sum(P, c2)
    U1 = finite_set_sum(P, c1)
    U2 = finite_set_sum(P, c2)
    U1 = U2

thm lower_riemann_sum_value_unique:
    ? forall I power_set(R), P finite_set, f fn(x I) R, L1, L2 R:
        $has_lower_riemann_sum(I, P, f, L1)
        $has_lower_riemann_sum(I, P, f, L2)
        =>:
            L1 = L2
    obtain c1 from exist c fn(J P) R st {$is_lower_riemann_sum_contribution_family(I, P, f, c), L1 = finite_set_sum(P, c)}
    obtain c2 from exist c fn(J P) R st {$is_lower_riemann_sum_contribution_family(I, P, f, c), L2 = finite_set_sum(P, c)}
    by thm lower_riemann_sum_contribution_family_unique(I, P, f, c1, c2)
    c1 = c2
    finite_set_sum(P, c1) = finite_set_sum(P, c2)
    L1 = finite_set_sum(P, c1)
    L2 = finite_set_sum(P, c2)
    L1 = L2

have fn upper_riemann_sum by exist!:
    ? forall I power_set(R), P power_set(power_set(R)), f fn(x I) R:
        $is_finite_set(P)
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist! U R st {$has_upper_riemann_sum(I, P, f, U)}
    by thm upper_riemann_sum_exists(I, P, f)
    obtain U from exist U R st {$has_upper_riemann_sum(I, P, f, U)}
    claim:
        ? exist U0 R st {$has_upper_riemann_sum(I, P, f, U0)}
        witness exist U0 R st {$has_upper_riemann_sum(I, P, f, U0)} from U:
            $has_upper_riemann_sum(I, P, f, U)
    claim:
        ? forall U1, U2 R:
            $has_upper_riemann_sum(I, P, f, U1)
            $has_upper_riemann_sum(I, P, f, U2)
            =>:
                U1 = U2
        by thm upper_riemann_sum_value_unique(I, P, f, U1, U2)
    exist! U0 R st {$has_upper_riemann_sum(I, P, f, U0)}

have fn lower_riemann_sum by exist!:
    ? forall I power_set(R), P power_set(power_set(R)), f fn(x I) R:
        $is_finite_set(P)
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist! L R st {$has_lower_riemann_sum(I, P, f, L)}
    by thm lower_riemann_sum_exists(I, P, f)
    obtain L from exist L R st {$has_lower_riemann_sum(I, P, f, L)}
    claim:
        ? exist L0 R st {$has_lower_riemann_sum(I, P, f, L0)}
        witness exist L0 R st {$has_lower_riemann_sum(I, P, f, L0)} from L:
            $has_lower_riemann_sum(I, P, f, L)
    claim:
        ? forall L1, L2 R:
            $has_lower_riemann_sum(I, P, f, L1)
            $has_lower_riemann_sum(I, P, f, L2)
            =>:
                L1 = L2
        by thm lower_riemann_sum_value_unique(I, P, f, L1, L2)
    exist! L0 R st {$has_lower_riemann_sum(I, P, f, L0)}

thm upper_riemann_sum_has_value:
    ? forall I power_set(R), P power_set(power_set(R)), f fn(x I) R:
        $is_finite_set(P)
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $has_upper_riemann_sum(I, P, f, upper_riemann_sum(I, P, f))
    have U R = upper_riemann_sum(I, P, f)
    $has_upper_riemann_sum(I, P, f, U)
    U = upper_riemann_sum(I, P, f)
    $has_upper_riemann_sum(I, P, f, upper_riemann_sum(I, P, f))

thm lower_riemann_sum_has_value:
    ? forall I power_set(R), P power_set(power_set(R)), f fn(x I) R:
        $is_finite_set(P)
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $has_lower_riemann_sum(I, P, f, lower_riemann_sum(I, P, f))
    have L R = lower_riemann_sum(I, P, f)
    $has_lower_riemann_sum(I, P, f, L)
    L = lower_riemann_sum(I, P, f)
    $has_lower_riemann_sum(I, P, f, lower_riemann_sum(I, P, f))

thm upper_riemann_partition_step_function_has_integral_equal_upper_riemann_sum:
    ? forall I power_set(R), P finite_set, f fn(x I) R, U R:
        P $in power_set(power_set(R))
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        $has_upper_riemann_sum(I, P, f, U)
        =>:
            $has_piecewise_constant_integral_with_partition(I, P, upper_riemann_partition_step_function(I, P, f), U)
    by thm upper_riemann_partition_step_function_is_piecewise_constant(I, P, f)
    $is_piecewise_constant_with_partition(I, P, upper_riemann_partition_step_function(I, P, f))
    obtain c from exist c fn(J P) R st {$is_upper_riemann_sum_contribution_family(I, P, f, c), U = finite_set_sum(P, c)}
    claim:
        ? $fn_eq(c, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f))})
        claim:
            ? forall J P:
                c(J) = fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f))}(J)
            $has_upper_riemann_sum_piece_contribution(I, J, f, c(J))
            by thm upper_riemann_sum_piece_has_value(I, J, f)
            $has_upper_riemann_sum_piece_contribution(I, J, f, upper_riemann_sum_piece(I, J, f))
            by thm upper_riemann_sum_piece_contribution_unique(I, J, f, c(J), upper_riemann_sum_piece(I, J, f))
            c(J) = upper_riemann_sum_piece(I, J, f)
            by thm upper_riemann_partition_step_function_piece_contribution(I, P, J, f)
            piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f)) = upper_riemann_sum_piece(I, J, f)
            fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f))}(J) = piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f))
            c(J) = fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f))}(J)
        $fn_eq(c, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f))})
    c = fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f))}
    U = finite_set_sum(P, c)
    U = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f))})
    piecewise_constant_integral_with_partition(I, P, upper_riemann_partition_step_function(I, P, f)) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, upper_riemann_partition_step_function(I, P, f))})
    U = piecewise_constant_integral_with_partition(I, P, upper_riemann_partition_step_function(I, P, f))
    $has_piecewise_constant_integral_with_partition(I, P, upper_riemann_partition_step_function(I, P, f), U)

thm lower_riemann_partition_step_function_has_integral_equal_lower_riemann_sum:
    ? forall I power_set(R), P finite_set, f fn(x I) R, L R:
        P $in power_set(power_set(R))
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        $has_lower_riemann_sum(I, P, f, L)
        =>:
            $has_piecewise_constant_integral_with_partition(I, P, lower_riemann_partition_step_function(I, P, f), L)
    by thm lower_riemann_partition_step_function_is_piecewise_constant(I, P, f)
    $is_piecewise_constant_with_partition(I, P, lower_riemann_partition_step_function(I, P, f))
    obtain c from exist c fn(J P) R st {$is_lower_riemann_sum_contribution_family(I, P, f, c), L = finite_set_sum(P, c)}
    claim:
        ? $fn_eq(c, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f))})
        claim:
            ? forall J P:
                c(J) = fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f))}(J)
            $has_lower_riemann_sum_piece_contribution(I, J, f, c(J))
            by thm lower_riemann_sum_piece_has_value(I, J, f)
            $has_lower_riemann_sum_piece_contribution(I, J, f, lower_riemann_sum_piece(I, J, f))
            by thm lower_riemann_sum_piece_contribution_unique(I, J, f, c(J), lower_riemann_sum_piece(I, J, f))
            c(J) = lower_riemann_sum_piece(I, J, f)
            by thm lower_riemann_partition_step_function_piece_contribution(I, P, J, f)
            piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f)) = lower_riemann_sum_piece(I, J, f)
            fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f))}(J) = piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f))
            c(J) = fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f))}(J)
        $fn_eq(c, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f))})
    c = fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f))}
    L = finite_set_sum(P, c)
    L = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f))})
    piecewise_constant_integral_with_partition(I, P, lower_riemann_partition_step_function(I, P, f)) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, lower_riemann_partition_step_function(I, P, f))})
    L = piecewise_constant_integral_with_partition(I, P, lower_riemann_partition_step_function(I, P, f))
    $has_piecewise_constant_integral_with_partition(I, P, lower_riemann_partition_step_function(I, P, f), L)

# Finite-sum version of the preceding local majorant comparison. It stays at
# the fixed-partition layer, so the global Darboux envelope never has to
# reimplement a finite induction.
thm piecewise_constant_majorant_with_partition_bounds_upper_riemann_sum:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R, sg, U R:
        $is_piecewise_constant_with_partition(I, P, g)
        $chap9::is_bounded_function_on(I, f)
        $majorizes_on(I, g, f)
        $has_piecewise_constant_integral_with_partition(I, P, g, sg)
        $has_upper_riemann_sum(I, P, f, U)
        =>:
            U <= sg
    $is_partition_of_bounded_interval(I, P)
    obtain u from exist c fn(J P) R st {$is_upper_riemann_sum_contribution_family(I, P, f, c), U = finite_set_sum(P, c)}
    $is_upper_riemann_sum_contribution_family(I, P, f, u)
    U = finite_set_sum(P, u)
    claim:
        ? forall J P:
            u(J) <= piecewise_constant_integral_piece_contribution(I, J, g)
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset I
        $is_constant_on_subset(I, J, g)
        obtain c from exist c R st {$has_constant_value_on_subset(I, J, g, c)}
        $has_upper_riemann_sum_piece_contribution(I, J, f, u(J))
        by thm upper_riemann_sum_piece_has_value(I, J, f)
        $has_upper_riemann_sum_piece_contribution(I, J, f, upper_riemann_sum_piece(I, J, f))
        by thm upper_riemann_sum_piece_contribution_unique(I, J, f, u(J), upper_riemann_sum_piece(I, J, f))
        u(J) = upper_riemann_sum_piece(I, J, f)
        by thm constant_majorant_bounds_upper_riemann_sum_piece(I, J, f, g, c)
        upper_riemann_sum_piece(I, J, f) <= c * interval_length(J)
        claim:
            ? $has_piecewise_constant_integral_piece_contribution(I, J, g, c * interval_length(J))
            witness exist c0 R st {$has_constant_value_on_subset(I, J, g, c0), c * interval_length(J) = c0 * interval_length(J)} from c:
                $has_constant_value_on_subset(I, J, g, c)
                c * interval_length(J) = c * interval_length(J)
            $has_piecewise_constant_integral_piece_contribution(I, J, g, c * interval_length(J))
        by thm piecewise_constant_integral_piece_contribution_has_value(I, J, g, c * interval_length(J))
        piecewise_constant_integral_piece_contribution(I, J, g) = c * interval_length(J)
        u(J) = upper_riemann_sum_piece(I, J, f) <= c * interval_length(J) = piecewise_constant_integral_piece_contribution(I, J, g)
    by thm finite_set_sum_monotone_from_pointwise_order(P, u, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, g)})
    finite_set_sum(P, u) <= finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, g)})
    sg = piecewise_constant_integral_with_partition(I, P, g)
    piecewise_constant_integral_with_partition(I, P, g) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, g)})
    U = finite_set_sum(P, u) <= finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, g)}) = piecewise_constant_integral_with_partition(I, P, g) = sg

thm piecewise_constant_minorant_with_partition_bounds_lower_riemann_sum:
    ? forall I power_set(R), P finite_set, f, h fn(x I) R, sh, L R:
        $is_piecewise_constant_with_partition(I, P, h)
        $chap9::is_bounded_function_on(I, f)
        $minorizes_on(I, h, f)
        $has_piecewise_constant_integral_with_partition(I, P, h, sh)
        $has_lower_riemann_sum(I, P, f, L)
        =>:
            sh <= L
    $is_partition_of_bounded_interval(I, P)
    obtain l from exist c fn(J P) R st {$is_lower_riemann_sum_contribution_family(I, P, f, c), L = finite_set_sum(P, c)}
    $is_lower_riemann_sum_contribution_family(I, P, f, l)
    L = finite_set_sum(P, l)
    claim:
        ? forall J P:
            piecewise_constant_integral_piece_contribution(I, J, h) <= l(J)
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset I
        $is_constant_on_subset(I, J, h)
        obtain c from exist c R st {$has_constant_value_on_subset(I, J, h, c)}
        $has_lower_riemann_sum_piece_contribution(I, J, f, l(J))
        by thm lower_riemann_sum_piece_has_value(I, J, f)
        $has_lower_riemann_sum_piece_contribution(I, J, f, lower_riemann_sum_piece(I, J, f))
        by thm lower_riemann_sum_piece_contribution_unique(I, J, f, l(J), lower_riemann_sum_piece(I, J, f))
        l(J) = lower_riemann_sum_piece(I, J, f)
        by thm constant_minorant_bounds_lower_riemann_sum_piece(I, J, f, h, c)
        c * interval_length(J) <= lower_riemann_sum_piece(I, J, f)
        claim:
            ? $has_piecewise_constant_integral_piece_contribution(I, J, h, c * interval_length(J))
            witness exist c0 R st {$has_constant_value_on_subset(I, J, h, c0), c * interval_length(J) = c0 * interval_length(J)} from c:
                $has_constant_value_on_subset(I, J, h, c)
                c * interval_length(J) = c * interval_length(J)
            $has_piecewise_constant_integral_piece_contribution(I, J, h, c * interval_length(J))
        by thm piecewise_constant_integral_piece_contribution_has_value(I, J, h, c * interval_length(J))
        piecewise_constant_integral_piece_contribution(I, J, h) = c * interval_length(J)
        piecewise_constant_integral_piece_contribution(I, J, h) = c * interval_length(J) <= lower_riemann_sum_piece(I, J, f) = l(J)
    by thm finite_set_sum_monotone_from_pointwise_order(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, h)}, l)
    finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, h)}) <= finite_set_sum(P, l)
    sh = piecewise_constant_integral_with_partition(I, P, h)
    piecewise_constant_integral_with_partition(I, P, h) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, h)})
    sh = piecewise_constant_integral_with_partition(I, P, h) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, h)}) <= finite_set_sum(P, l) = L

# Each Riemann sum is now literally the integral of its canonical Darboux
# step function.  These two transports are the forward inclusions needed for
# the global extrema in Proposition 11.3.12.
thm upper_riemann_sum_is_upper_riemann_integral_candidate:
    ? forall I power_set(R), P finite_set, f fn(x I) R, U R:
        P $in power_set(power_set(R))
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        $has_upper_riemann_sum(I, P, f, U)
        =>:
            $is_upper_riemann_integral_candidate_value(I, f, U)
    by thm upper_riemann_partition_step_function_is_piecewise_constant(I, P, f)
    $is_piecewise_constant_with_partition(I, P, upper_riemann_partition_step_function(I, P, f))
    by thm piecewise_constant_with_partition_is_piecewise_constant(I, P, upper_riemann_partition_step_function(I, P, f))
    $is_piecewise_constant_on(I, upper_riemann_partition_step_function(I, P, f))
    by thm upper_riemann_partition_step_function_majorizes(I, P, f)
    $majorizes_on(I, upper_riemann_partition_step_function(I, P, f), f)
    by thm upper_riemann_partition_step_function_has_integral_equal_upper_riemann_sum(I, P, f, U)
    $has_piecewise_constant_integral_with_partition(I, P, upper_riemann_partition_step_function(I, P, f), U)
    claim:
        ? $has_piecewise_constant_integral(I, upper_riemann_partition_step_function(I, P, f), U)
        witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, upper_riemann_partition_step_function(I, P, f)), $has_piecewise_constant_integral_with_partition(I, P0, upper_riemann_partition_step_function(I, P, f), U)} from P:
            $is_piecewise_constant_with_partition(I, P, upper_riemann_partition_step_function(I, P, f))
            $has_piecewise_constant_integral_with_partition(I, P, upper_riemann_partition_step_function(I, P, f), U)
        $has_piecewise_constant_integral(I, upper_riemann_partition_step_function(I, P, f), U)
    witness exist g fn(x I) R st {$is_piecewise_constant_on(I, g), $majorizes_on(I, g, f), $has_piecewise_constant_integral(I, g, U)} from upper_riemann_partition_step_function(I, P, f):
        $is_piecewise_constant_on(I, upper_riemann_partition_step_function(I, P, f))
        $majorizes_on(I, upper_riemann_partition_step_function(I, P, f), f)
        $has_piecewise_constant_integral(I, upper_riemann_partition_step_function(I, P, f), U)
    $is_upper_riemann_integral_candidate_value(I, f, U)

thm lower_riemann_sum_is_lower_riemann_integral_candidate:
    ? forall I power_set(R), P finite_set, f fn(x I) R, L R:
        P $in power_set(power_set(R))
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        $has_lower_riemann_sum(I, P, f, L)
        =>:
            $is_lower_riemann_integral_candidate_value(I, f, L)
    by thm lower_riemann_partition_step_function_is_piecewise_constant(I, P, f)
    $is_piecewise_constant_with_partition(I, P, lower_riemann_partition_step_function(I, P, f))
    by thm piecewise_constant_with_partition_is_piecewise_constant(I, P, lower_riemann_partition_step_function(I, P, f))
    $is_piecewise_constant_on(I, lower_riemann_partition_step_function(I, P, f))
    by thm lower_riemann_partition_step_function_minorizes(I, P, f)
    $minorizes_on(I, lower_riemann_partition_step_function(I, P, f), f)
    by thm lower_riemann_partition_step_function_has_integral_equal_lower_riemann_sum(I, P, f, L)
    $has_piecewise_constant_integral_with_partition(I, P, lower_riemann_partition_step_function(I, P, f), L)
    claim:
        ? $has_piecewise_constant_integral(I, lower_riemann_partition_step_function(I, P, f), L)
        witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, lower_riemann_partition_step_function(I, P, f)), $has_piecewise_constant_integral_with_partition(I, P0, lower_riemann_partition_step_function(I, P, f), L)} from P:
            $is_piecewise_constant_with_partition(I, P, lower_riemann_partition_step_function(I, P, f))
            $has_piecewise_constant_integral_with_partition(I, P, lower_riemann_partition_step_function(I, P, f), L)
        $has_piecewise_constant_integral(I, lower_riemann_partition_step_function(I, P, f), L)
    witness exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_integral(I, h, L)} from lower_riemann_partition_step_function(I, P, f):
        $is_piecewise_constant_on(I, lower_riemann_partition_step_function(I, P, f))
        $minorizes_on(I, lower_riemann_partition_step_function(I, P, f), f)
        $has_piecewise_constant_integral(I, lower_riemann_partition_step_function(I, P, f), L)
    $is_lower_riemann_integral_candidate_value(I, f, L)

# These value-set interfaces are proof packages for Proposition 11.3.12, not
# additional source definitions.

prop is_upper_riemann_sum_value(I power_set(R), f fn(x I) R, U R):
    exist P finite_set st {$has_upper_riemann_sum(I, P, f, U)}

prop is_lower_riemann_sum_value(I power_set(R), f fn(x I) R, L R):
    exist P finite_set st {$has_lower_riemann_sum(I, P, f, L)}

have fn upper_riemann_sum_values(I power_set(R), f fn(x I) R) power_set(R) = {U R: $is_upper_riemann_sum_value(I, f, U)}

have fn lower_riemann_sum_values(I power_set(R), f fn(x I) R) power_set(R) = {L R: $is_lower_riemann_sum_value(I, f, L)}

thm upper_riemann_sum_value_member:
    ? forall I power_set(R), f fn(x I) R, U R:
        $is_upper_riemann_sum_value(I, f, U)
        =>:
            U $in upper_riemann_sum_values(I, f)
    upper_riemann_sum_values(I, f) = {U R: $is_upper_riemann_sum_value(I, f, U)}
    U $in {U R: $is_upper_riemann_sum_value(I, f, U)}
    U $in upper_riemann_sum_values(I, f)

thm upper_riemann_sum_value_from_member:
    ? forall I power_set(R), f fn(x I) R, U R:
        U $in upper_riemann_sum_values(I, f)
        =>:
            $is_upper_riemann_sum_value(I, f, U)
    upper_riemann_sum_values(I, f) = {U R: $is_upper_riemann_sum_value(I, f, U)}
    U $in {U R: $is_upper_riemann_sum_value(I, f, U)}
    $is_upper_riemann_sum_value(I, f, U)

thm lower_riemann_sum_value_member:
    ? forall I power_set(R), f fn(x I) R, L R:
        $is_lower_riemann_sum_value(I, f, L)
        =>:
            L $in lower_riemann_sum_values(I, f)
    lower_riemann_sum_values(I, f) = {L R: $is_lower_riemann_sum_value(I, f, L)}
    L $in {L R: $is_lower_riemann_sum_value(I, f, L)}
    L $in lower_riemann_sum_values(I, f)

thm lower_riemann_sum_value_from_member:
    ? forall I power_set(R), f fn(x I) R, L R:
        L $in lower_riemann_sum_values(I, f)
        =>:
            $is_lower_riemann_sum_value(I, f, L)
    lower_riemann_sum_values(I, f) = {L R: $is_lower_riemann_sum_value(I, f, L)}
    L $in {L R: $is_lower_riemann_sum_value(I, f, L)}
    $is_lower_riemann_sum_value(I, f, L)


"""
Remark 11.3.10.  Empty pieces are excluded from the displayed Riemann sums
because the supremum or infimum over the empty set would be infinite.
"""

"""
Lemma 11.3.11.  A piecewise constant majorant has integral at least the upper
Riemann sum for the same partition; a piecewise constant minorant has integral
at most the lower Riemann sum.
"""

thm piecewise_constant_majorant_minorant_compare_riemann_sums:
    ? forall I power_set(R), P finite_set, f, g, h fn(x I) R, sg, sh, U, L R:
        $is_partition_of_bounded_interval(I, P)
        $chap9::is_bounded_function_on(I, f)
        $is_piecewise_constant_with_partition(I, P, g)
        $is_piecewise_constant_with_partition(I, P, h)
        $majorizes_on(I, g, f)
        $minorizes_on(I, h, f)
        $has_piecewise_constant_integral(I, g, sg)
        $has_piecewise_constant_integral(I, h, sh)
        $has_upper_riemann_sum(I, P, f, U)
        $has_lower_riemann_sum(I, P, f, L)
        =>:
            sg >= U
            sh <= L
    # Source handling: Tao proves this in Exercise 11.3.4.
    # The preceding fixed-partition theorems perform the piecewise
    # supremum/infimum comparisons and finite-sum monotonicity. The only
    # remaining step is to identify the partition-free step integrals with
    # their values on this displayed partition.
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, P, g)
    by thm piecewise_constant_integral_with_partition_has_value(I, P, g)
    have sgP R = piecewise_constant_integral_with_partition(I, P, g)
    $has_piecewise_constant_integral_with_partition(I, P, g, sgP)
    claim:
        ? $has_piecewise_constant_integral(I, g, sgP)
        by thm piecewise_constant_with_partition_is_piecewise_constant(I, P, g)
        witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, g), $has_piecewise_constant_integral_with_partition(I, P0, g, sgP)} from P:
            $is_piecewise_constant_with_partition(I, P, g)
            $has_piecewise_constant_integral_with_partition(I, P, g, sgP)
        $has_piecewise_constant_integral(I, g, sgP)
    by thm piecewise_constant_integral_value_unique(I, g, sg, sgP)
    sg = sgP
    by thm piecewise_constant_majorant_with_partition_bounds_upper_riemann_sum(I, P, f, g, sgP, U)
    U <= sgP
    sg >= U
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, P, h)
    by thm piecewise_constant_integral_with_partition_has_value(I, P, h)
    have shP R = piecewise_constant_integral_with_partition(I, P, h)
    $has_piecewise_constant_integral_with_partition(I, P, h, shP)
    claim:
        ? $has_piecewise_constant_integral(I, h, shP)
        by thm piecewise_constant_with_partition_is_piecewise_constant(I, P, h)
        witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, h), $has_piecewise_constant_integral_with_partition(I, P0, h, shP)} from P:
            $is_piecewise_constant_with_partition(I, P, h)
            $has_piecewise_constant_integral_with_partition(I, P, h, shP)
        $has_piecewise_constant_integral(I, h, shP)
    by thm piecewise_constant_integral_value_unique(I, h, sh, shP)
    sh = shP
    by thm piecewise_constant_minorant_with_partition_bounds_lower_riemann_sum(I, P, f, h, shP, L)
    shP <= L
    sh <= L

thm piecewise_constant_majorant_integral_bounds_upper_riemann_sum:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R, sg, U R:
        $is_piecewise_constant_with_partition(I, P, g)
        $chap9::is_bounded_function_on(I, f)
        $majorizes_on(I, g, f)
        $has_piecewise_constant_integral(I, g, sg)
        $has_upper_riemann_sum(I, P, f, U)
        =>:
            U <= sg
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, P, g)
    by thm piecewise_constant_integral_with_partition_has_value(I, P, g)
    have sgP R = piecewise_constant_integral_with_partition(I, P, g)
    $has_piecewise_constant_integral_with_partition(I, P, g, sgP)
    claim:
        ? $has_piecewise_constant_integral(I, g, sgP)
        by thm piecewise_constant_with_partition_is_piecewise_constant(I, P, g)
        witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, g), $has_piecewise_constant_integral_with_partition(I, P0, g, sgP)} from P:
            $is_piecewise_constant_with_partition(I, P, g)
            $has_piecewise_constant_integral_with_partition(I, P, g, sgP)
        $has_piecewise_constant_integral(I, g, sgP)
    by thm piecewise_constant_integral_value_unique(I, g, sg, sgP)
    sg = sgP
    by thm piecewise_constant_majorant_with_partition_bounds_upper_riemann_sum(I, P, f, g, sgP, U)
    U <= sgP
    U <= sg

thm piecewise_constant_minorant_integral_bounds_lower_riemann_sum:
    ? forall I power_set(R), P finite_set, f, h fn(x I) R, sh, L R:
        $is_piecewise_constant_with_partition(I, P, h)
        $chap9::is_bounded_function_on(I, f)
        $minorizes_on(I, h, f)
        $has_piecewise_constant_integral(I, h, sh)
        $has_lower_riemann_sum(I, P, f, L)
        =>:
            sh <= L
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, P, h)
    by thm piecewise_constant_integral_with_partition_has_value(I, P, h)
    have shP R = piecewise_constant_integral_with_partition(I, P, h)
    $has_piecewise_constant_integral_with_partition(I, P, h, shP)
    claim:
        ? $has_piecewise_constant_integral(I, h, shP)
        by thm piecewise_constant_with_partition_is_piecewise_constant(I, P, h)
        witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, h), $has_piecewise_constant_integral_with_partition(I, P0, h, shP)} from P:
            $is_piecewise_constant_with_partition(I, P, h)
            $has_piecewise_constant_integral_with_partition(I, P, h, shP)
        $has_piecewise_constant_integral(I, h, shP)
    by thm piecewise_constant_integral_value_unique(I, h, sh, shP)
    sh = shP
    by thm piecewise_constant_minorant_with_partition_bounds_lower_riemann_sum(I, P, f, h, shP, L)
    shP <= L
    sh <= L

thm upper_riemann_integral_candidate_has_no_smaller_upper_sum:
    ? forall I power_set(R), f fn(x I) R, sg R:
        $chap9::is_bounded_function_on(I, f)
        $is_upper_riemann_integral_candidate_value(I, f, sg)
        =>:
            exist P finite_set, U R st {$has_upper_riemann_sum(I, P, f, U), U <= sg}
    obtain g from exist g fn(x I) R st {$is_piecewise_constant_on(I, g), $majorizes_on(I, g, f), $has_piecewise_constant_integral(I, g, sg)}
    obtain P from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, g)}
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, P, g)
    P $in power_set(power_set(R))
    by thm upper_riemann_sum_exists(I, P, f)
    obtain U from exist U R st {$has_upper_riemann_sum(I, P, f, U)}
    by thm piecewise_constant_majorant_integral_bounds_upper_riemann_sum(I, P, f, g, sg, U)
    U <= sg
    witness exist P0 finite_set, U0 R st {$has_upper_riemann_sum(I, P0, f, U0), U0 <= sg} from P, U:
        $has_upper_riemann_sum(I, P, f, U)
        U <= sg

thm lower_riemann_integral_candidate_has_no_larger_lower_sum:
    ? forall I power_set(R), f fn(x I) R, sh R:
        $chap9::is_bounded_function_on(I, f)
        $is_lower_riemann_integral_candidate_value(I, f, sh)
        =>:
            exist P finite_set, L R st {$has_lower_riemann_sum(I, P, f, L), sh <= L}
    obtain h from exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_integral(I, h, sh)}
    obtain P from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, h)}
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, P, h)
    P $in power_set(power_set(R))
    by thm lower_riemann_sum_exists(I, P, f)
    obtain L from exist L R st {$has_lower_riemann_sum(I, P, f, L)}
    by thm piecewise_constant_minorant_integral_bounds_lower_riemann_sum(I, P, f, h, sh, L)
    sh <= L
    witness exist P0 finite_set, L0 R st {$has_lower_riemann_sum(I, P0, f, L0), sh <= L0} from P, L:
        $has_lower_riemann_sum(I, P, f, L)
        sh <= L

"""
Proposition 11.3.12.  The upper Riemann integral is the infimum of upper
Riemann sums over partitions, and the lower Riemann integral is the supremum of
lower Riemann sums.
"""

thm upper_integral_equals_infimum_of_riemann_sums:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $has_infimum_of_real_set(upper_riemann_sum_values(I, f))
            $is_infimum_of_real_set(upper_riemann_sum_values(I, f), upper_riemann_integral(I, f))
    # Source handling: the canonical upper step function makes every upper
    # sum a Darboux candidate. Conversely, every Darboux majorant supplies a
    # partition whose upper sum lies below its integral.
    $has_upper_riemann_integral(I, f, upper_riemann_integral(I, f))
    claim:
        ? $is_lower_bound_of_real_set(upper_riemann_sum_values(I, f), upper_riemann_integral(I, f))
        claim:
            ? forall U upper_riemann_sum_values(I, f):
                upper_riemann_integral(I, f) <= U
            by thm upper_riemann_sum_value_from_member(I, f, U)
            obtain P from exist P finite_set st {$has_upper_riemann_sum(I, P, f, U)}
            by thm upper_riemann_sum_is_upper_riemann_integral_candidate(I, P, f, U)
            $is_upper_riemann_integral_candidate_value(I, f, U)
            by thm upper_riemann_integral_le_candidate_value(I, f, upper_riemann_integral(I, f), U)
            upper_riemann_integral(I, f) <= U
        $is_lower_bound_of_real_set(upper_riemann_sum_values(I, f), upper_riemann_integral(I, f))
    claim:
        ? $is_infimum_of_real_set(upper_riemann_sum_values(I, f), upper_riemann_integral(I, f))
        $is_lower_bound_of_real_set(upper_riemann_sum_values(I, f), upper_riemann_integral(I, f))
        claim:
            ? forall M R:
                $is_lower_bound_of_real_set(upper_riemann_sum_values(I, f), M)
                =>:
                    M <= upper_riemann_integral(I, f)
            claim:
                ? $is_lower_bound_of_real_set(upper_riemann_integral_candidate_values(I, f), M)
                claim:
                    ? forall sg upper_riemann_integral_candidate_values(I, f):
                        M <= sg
                    by thm upper_riemann_integral_candidate_value_from_member(I, f, sg)
                    $is_upper_riemann_integral_candidate_value(I, f, sg)
                    by thm upper_riemann_integral_candidate_has_no_smaller_upper_sum(I, f, sg)
                    obtain P, U from exist P finite_set, U R st {$has_upper_riemann_sum(I, P, f, U), U <= sg}
                    claim:
                        ? $is_upper_riemann_sum_value(I, f, U)
                        witness exist P0 finite_set st {$has_upper_riemann_sum(I, P0, f, U)} from P:
                            $has_upper_riemann_sum(I, P, f, U)
                        $is_upper_riemann_sum_value(I, f, U)
                    by thm upper_riemann_sum_value_member(I, f, U)
                    U $in upper_riemann_sum_values(I, f)
                    M <= U
                    U <= sg
                    M <= sg
                $is_lower_bound_of_real_set(upper_riemann_integral_candidate_values(I, f), M)
            by thm lower_bound_le_upper_riemann_integral(I, f, upper_riemann_integral(I, f), M)
            M <= upper_riemann_integral(I, f)
        $is_infimum_of_real_set(upper_riemann_sum_values(I, f), upper_riemann_integral(I, f))
    witness exist s R st {$is_infimum_of_real_set(upper_riemann_sum_values(I, f), s)} from upper_riemann_integral(I, f):
        $is_infimum_of_real_set(upper_riemann_sum_values(I, f), upper_riemann_integral(I, f))
    $has_infimum_of_real_set(upper_riemann_sum_values(I, f))
    $is_infimum_of_real_set(upper_riemann_sum_values(I, f), upper_riemann_integral(I, f))

thm lower_integral_equals_supremum_of_riemann_sums:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $has_least_upper_bound(lower_riemann_sum_values(I, f))
            $is_least_upper_bound(lower_riemann_sum_values(I, f), lower_riemann_integral(I, f))
    # Source handling: the lower argument is the order-dual of the upper one.
    $has_lower_riemann_integral(I, f, lower_riemann_integral(I, f))
    claim:
        ? $is_upper_bound_of_real_set(lower_riemann_sum_values(I, f), lower_riemann_integral(I, f))
        claim:
            ? forall L lower_riemann_sum_values(I, f):
                L <= lower_riemann_integral(I, f)
            by thm lower_riemann_sum_value_from_member(I, f, L)
            obtain P from exist P finite_set st {$has_lower_riemann_sum(I, P, f, L)}
            by thm lower_riemann_sum_is_lower_riemann_integral_candidate(I, P, f, L)
            $is_lower_riemann_integral_candidate_value(I, f, L)
            by thm lower_riemann_integral_candidate_value_le_integral(I, f, lower_riemann_integral(I, f), L)
            L <= lower_riemann_integral(I, f)
        $is_upper_bound_of_real_set(lower_riemann_sum_values(I, f), lower_riemann_integral(I, f))
    claim:
        ? $is_least_upper_bound(lower_riemann_sum_values(I, f), lower_riemann_integral(I, f))
        $is_upper_bound_of_real_set(lower_riemann_sum_values(I, f), lower_riemann_integral(I, f))
        claim:
            ? forall M R:
                $is_upper_bound_of_real_set(lower_riemann_sum_values(I, f), M)
                =>:
                    lower_riemann_integral(I, f) <= M
            claim:
                ? $is_upper_bound_of_real_set(lower_riemann_integral_candidate_values(I, f), M)
                claim:
                    ? forall sh lower_riemann_integral_candidate_values(I, f):
                        sh <= M
                    by thm lower_riemann_integral_candidate_value_from_member(I, f, sh)
                    $is_lower_riemann_integral_candidate_value(I, f, sh)
                    by thm lower_riemann_integral_candidate_has_no_larger_lower_sum(I, f, sh)
                    obtain P, L from exist P finite_set, L R st {$has_lower_riemann_sum(I, P, f, L), sh <= L}
                    claim:
                        ? $is_lower_riemann_sum_value(I, f, L)
                        witness exist P0 finite_set st {$has_lower_riemann_sum(I, P0, f, L)} from P:
                            $has_lower_riemann_sum(I, P, f, L)
                        $is_lower_riemann_sum_value(I, f, L)
                    by thm lower_riemann_sum_value_member(I, f, L)
                    L $in lower_riemann_sum_values(I, f)
                    L <= M
                    sh <= L
                    sh <= M
                $is_upper_bound_of_real_set(lower_riemann_integral_candidate_values(I, f), M)
            by thm lower_riemann_integral_le_upper_bound(I, f, lower_riemann_integral(I, f), M)
            lower_riemann_integral(I, f) <= M
        $is_least_upper_bound(lower_riemann_sum_values(I, f), lower_riemann_integral(I, f))
    witness exist s R st {$is_least_upper_bound(lower_riemann_sum_values(I, f), s)} from lower_riemann_integral(I, f):
        $is_least_upper_bound(lower_riemann_sum_values(I, f), lower_riemann_integral(I, f))
    $has_least_upper_bound(lower_riemann_sum_values(I, f))
    $is_least_upper_bound(lower_riemann_sum_values(I, f), lower_riemann_integral(I, f))


# 11.4 Basic properties of the Riemann integral

"""
Theorem 11.4.1 (Laws of Riemann integration).  Riemann integrable functions
are closed under addition, scalar multiplication, and subtraction; the integral
is positive, monotone, correct on constants, compatible with extension by zero,
and additive over partitions into two intervals.
"""

thm riemann_integral_addition_law:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_riemann_integrable_on(I, f)
        $is_riemann_integrable_on(I, g)
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {f(x) + g(x)})
            integral_on(I, fn(x I) R {f(x) + g(x)}) = integral_on(I, f) + integral_on(I, g)
    # Source handling: this is Theorem 11.4.1(a).  The two one-sided
    # estimates just above are the ordinary Darboux proof with independently
    # chosen upper and lower step approximations.
    by thm riemann_integrable_sum_by_darboux_approximation(I, f, g)
    $is_riemann_integrable_on(I, fn(x I) R {f(x) + g(x)})
    by thm upper_riemann_integral_sum_le(I, f, g)
    upper_riemann_integral(I, fn(x I) R {f(x) + g(x)}) <= upper_riemann_integral(I, f) + upper_riemann_integral(I, g)
    by thm lower_riemann_integral_sum_le(I, f, g)
    lower_riemann_integral(I, f) + lower_riemann_integral(I, g) <= lower_riemann_integral(I, fn(x I) R {f(x) + g(x)})
    by thm riemann_integrable_upper_eq_lower(I, f)
    by thm riemann_integrable_upper_eq_lower(I, g)
    by thm riemann_integrable_upper_eq_lower(I, fn(x I) R {f(x) + g(x)})
    upper_riemann_integral(I, f) = lower_riemann_integral(I, f)
    upper_riemann_integral(I, g) = lower_riemann_integral(I, g)
    upper_riemann_integral(I, fn(x I) R {f(x) + g(x)}) = lower_riemann_integral(I, fn(x I) R {f(x) + g(x)})
    upper_riemann_integral(I, f) + upper_riemann_integral(I, g) <= upper_riemann_integral(I, fn(x I) R {f(x) + g(x)})
    upper_riemann_integral(I, fn(x I) R {f(x) + g(x)}) = upper_riemann_integral(I, f) + upper_riemann_integral(I, g)
    by thm integral_on_has_riemann_integral(I, f)
    by thm integral_on_has_riemann_integral(I, g)
    by thm integral_on_has_riemann_integral(I, fn(x I) R {f(x) + g(x)})
    $has_riemann_integral(I, f, integral_on(I, f))
    $has_riemann_integral(I, g, integral_on(I, g))
    $has_riemann_integral(I, fn(x I) R {f(x) + g(x)}, integral_on(I, fn(x I) R {f(x) + g(x)}))
    by thm has_riemann_integral_value_eq_upper(I, f, integral_on(I, f))
    by thm has_riemann_integral_value_eq_upper(I, g, integral_on(I, g))
    by thm has_riemann_integral_value_eq_upper(I, fn(x I) R {f(x) + g(x)}, integral_on(I, fn(x I) R {f(x) + g(x)}))
    integral_on(I, f) = upper_riemann_integral(I, f)
    integral_on(I, g) = upper_riemann_integral(I, g)
    integral_on(I, fn(x I) R {f(x) + g(x)}) = upper_riemann_integral(I, fn(x I) R {f(x) + g(x)})
    integral_on(I, fn(x I) R {f(x) + g(x)}) = integral_on(I, f) + integral_on(I, g)

thm riemann_integral_scalar_multiplication_law:
    ? forall I power_set(R), f fn(x I) R, c R:
        $is_riemann_integrable_on(I, f)
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {c * f(x)})
            integral_on(I, fn(x I) R {c * f(x)}) = c * integral_on(I, f)
    # Source handling: this is Theorem 11.4.1(b).  Scaling a Darboux pair
    # preserves the two directions for a nonnegative scalar and exchanges
    # them for a negative scalar.
    by thm riemann_integrable_scalar_by_darboux_approximation(I, f, c)
    $is_riemann_integrable_on(I, fn(x I) R {c * f(x)})
    by thm riemann_integrable_upper_eq_lower(I, f)
    by thm riemann_integrable_upper_eq_lower(I, fn(x I) R {c * f(x)})
    upper_riemann_integral(I, f) = lower_riemann_integral(I, f)
    upper_riemann_integral(I, fn(x I) R {c * f(x)}) = lower_riemann_integral(I, fn(x I) R {c * f(x)})
    by cases:
        ? c = 0 or c > 0 or c < 0
        case c = 0:
            by thm upper_riemann_integral_has_candidate_within(I, f, 1)
            obtain su from exist s R st {$is_upper_riemann_integral_candidate_value(I, f, s), s < upper_riemann_integral(I, f) + 1}
            by thm upper_riemann_integral_candidate_scalar_nonnegative(I, f, c, su)
            by thm upper_riemann_integral_le_candidate_value(I, fn(x I) R {c * f(x)}, upper_riemann_integral(I, fn(x I) R {c * f(x)}), c * su)
            upper_riemann_integral(I, fn(x I) R {c * f(x)}) <= c * su
            c * su = 0
            upper_riemann_integral(I, fn(x I) R {c * f(x)}) <= 0
            by thm lower_riemann_integral_has_candidate_within(I, f, 1)
            obtain sl from exist s R st {$is_lower_riemann_integral_candidate_value(I, f, s), lower_riemann_integral(I, f) - 1 < s}
            by thm lower_riemann_integral_candidate_scalar_nonnegative(I, f, c, sl)
            by thm lower_riemann_integral_candidate_value_le_integral(I, fn(x I) R {c * f(x)}, lower_riemann_integral(I, fn(x I) R {c * f(x)}), c * sl)
            c * sl <= lower_riemann_integral(I, fn(x I) R {c * f(x)})
            c * sl = 0
            0 <= lower_riemann_integral(I, fn(x I) R {c * f(x)})
            upper_riemann_integral(I, fn(x I) R {c * f(x)}) = 0
            c * upper_riemann_integral(I, f) = 0
            upper_riemann_integral(I, fn(x I) R {c * f(x)}) = c * upper_riemann_integral(I, f)
        case c > 0:
            claim:
                ? upper_riemann_integral(I, fn(x I) R {c * f(x)}) <= c * upper_riemann_integral(I, f)
                by contra:
                    ? upper_riemann_integral(I, fn(x I) R {c * f(x)}) <= c * upper_riemann_integral(I, f)
                    upper_riemann_integral(I, fn(x I) R {c * f(x)}) > c * upper_riemann_integral(I, f)
                    upper_riemann_integral(I, fn(x I) R {c * f(x)}) - c * upper_riemann_integral(I, f) > 0
                    (upper_riemann_integral(I, fn(x I) R {c * f(x)}) - c * upper_riemann_integral(I, f)) / 2 > 0
                    have epsilon R_pos = (upper_riemann_integral(I, fn(x I) R {c * f(x)}) - c * upper_riemann_integral(I, f)) / 2
                    epsilon / (c + 1) > 0
                    have delta R_pos = epsilon / (c + 1)
                    by thm upper_riemann_integral_has_candidate_within(I, f, delta)
                    obtain s from exist s0 R st {$is_upper_riemann_integral_candidate_value(I, f, s0), s0 < upper_riemann_integral(I, f) + delta}
                    by thm upper_riemann_integral_candidate_scalar_nonnegative(I, f, c, s)
                    by thm upper_riemann_integral_le_candidate_value(I, fn(x I) R {c * f(x)}, upper_riemann_integral(I, fn(x I) R {c * f(x)}), c * s)
                    upper_riemann_integral(I, fn(x I) R {c * f(x)}) <= c * s
                    s < upper_riemann_integral(I, f) + delta
                    c * s < c * (upper_riemann_integral(I, f) + delta)
                    c * (upper_riemann_integral(I, f) + delta) = c * upper_riemann_integral(I, f) + c * delta
                    c <= c + 1
                    c * delta <= (c + 1) * delta
                    delta = epsilon / (c + 1)
                    (c + 1) * delta = epsilon
                    c * upper_riemann_integral(I, f) + c * delta <= c * upper_riemann_integral(I, f) + epsilon
                    c * upper_riemann_integral(I, f) + epsilon < upper_riemann_integral(I, fn(x I) R {c * f(x)})
                    impossible upper_riemann_integral(I, fn(x I) R {c * f(x)}) <= c * s
                upper_riemann_integral(I, fn(x I) R {c * f(x)}) <= c * upper_riemann_integral(I, f)
            claim:
                ? c * upper_riemann_integral(I, f) <= upper_riemann_integral(I, fn(x I) R {c * f(x)})
                by contra:
                    ? c * upper_riemann_integral(I, f) <= upper_riemann_integral(I, fn(x I) R {c * f(x)})
                    c * upper_riemann_integral(I, f) > upper_riemann_integral(I, fn(x I) R {c * f(x)})
                    c * upper_riemann_integral(I, f) - upper_riemann_integral(I, fn(x I) R {c * f(x)}) > 0
                    (c * upper_riemann_integral(I, f) - upper_riemann_integral(I, fn(x I) R {c * f(x)})) / 2 > 0
                    have epsilon R_pos = (c * upper_riemann_integral(I, f) - upper_riemann_integral(I, fn(x I) R {c * f(x)})) / 2
                    epsilon / (c + 1) > 0
                    have delta R_pos = epsilon / (c + 1)
                    by thm lower_riemann_integral_has_candidate_within(I, f, delta)
                    obtain s from exist s0 R st {$is_lower_riemann_integral_candidate_value(I, f, s0), lower_riemann_integral(I, f) - delta < s0}
                    by thm lower_riemann_integral_candidate_scalar_nonnegative(I, f, c, s)
                    by thm lower_riemann_integral_candidate_value_le_integral(I, fn(x I) R {c * f(x)}, lower_riemann_integral(I, fn(x I) R {c * f(x)}), c * s)
                    c * s <= lower_riemann_integral(I, fn(x I) R {c * f(x)})
                    lower_riemann_integral(I, f) - delta < s
                    c * (lower_riemann_integral(I, f) - delta) < c * s
                    c * (lower_riemann_integral(I, f) - delta) = c * lower_riemann_integral(I, f) - c * delta
                    c <= c + 1
                    c * delta <= (c + 1) * delta
                    delta = epsilon / (c + 1)
                    (c + 1) * delta = epsilon
                    c * upper_riemann_integral(I, f) - epsilon <= c * lower_riemann_integral(I, f) - c * delta
                    c * upper_riemann_integral(I, f) - epsilon < lower_riemann_integral(I, fn(x I) R {c * f(x)})
                    lower_riemann_integral(I, fn(x I) R {c * f(x)}) = upper_riemann_integral(I, fn(x I) R {c * f(x)})
                    c * upper_riemann_integral(I, f) - epsilon < upper_riemann_integral(I, fn(x I) R {c * f(x)})
                    upper_riemann_integral(I, fn(x I) R {c * f(x)}) < c * upper_riemann_integral(I, f) - epsilon
                    impossible c * upper_riemann_integral(I, f) - epsilon < upper_riemann_integral(I, fn(x I) R {c * f(x)})
                c * upper_riemann_integral(I, f) <= upper_riemann_integral(I, fn(x I) R {c * f(x)})
            upper_riemann_integral(I, fn(x I) R {c * f(x)}) = c * upper_riemann_integral(I, f)
        case c < 0:
            claim:
                ? upper_riemann_integral(I, fn(x I) R {c * f(x)}) <= c * upper_riemann_integral(I, f)
                by contra:
                    ? upper_riemann_integral(I, fn(x I) R {c * f(x)}) <= c * upper_riemann_integral(I, f)
                    upper_riemann_integral(I, fn(x I) R {c * f(x)}) > c * upper_riemann_integral(I, f)
                    upper_riemann_integral(I, fn(x I) R {c * f(x)}) - c * upper_riemann_integral(I, f) > 0
                    (upper_riemann_integral(I, fn(x I) R {c * f(x)}) - c * upper_riemann_integral(I, f)) / 2 > 0
                    have epsilon R_pos = (upper_riemann_integral(I, fn(x I) R {c * f(x)}) - c * upper_riemann_integral(I, f)) / 2
                    epsilon / (abs(c) + 1) > 0
                    have delta R_pos = epsilon / (abs(c) + 1)
                    by thm lower_riemann_integral_has_candidate_within(I, f, delta)
                    obtain s from exist s0 R st {$is_lower_riemann_integral_candidate_value(I, f, s0), lower_riemann_integral(I, f) - delta < s0}
                    by thm upper_riemann_integral_candidate_scalar_negative(I, f, c, s)
                    by thm upper_riemann_integral_le_candidate_value(I, fn(x I) R {c * f(x)}, upper_riemann_integral(I, fn(x I) R {c * f(x)}), c * s)
                    upper_riemann_integral(I, fn(x I) R {c * f(x)}) <= c * s
                    lower_riemann_integral(I, f) - delta < s
                    c * s < c * (lower_riemann_integral(I, f) - delta)
                    abs(c) = -c
                    c * (lower_riemann_integral(I, f) - delta) = c * lower_riemann_integral(I, f) + abs(c) * delta
                    abs(c) <= abs(c) + 1
                    abs(c) * delta <= (abs(c) + 1) * delta
                    delta = epsilon / (abs(c) + 1)
                    (abs(c) + 1) * delta = epsilon
                    c * upper_riemann_integral(I, f) + abs(c) * delta <= c * upper_riemann_integral(I, f) + epsilon
                    c * upper_riemann_integral(I, f) + epsilon < upper_riemann_integral(I, fn(x I) R {c * f(x)})
                    impossible upper_riemann_integral(I, fn(x I) R {c * f(x)}) <= c * s
                upper_riemann_integral(I, fn(x I) R {c * f(x)}) <= c * upper_riemann_integral(I, f)
            claim:
                ? c * upper_riemann_integral(I, f) <= upper_riemann_integral(I, fn(x I) R {c * f(x)})
                by contra:
                    ? c * upper_riemann_integral(I, f) <= upper_riemann_integral(I, fn(x I) R {c * f(x)})
                    c * upper_riemann_integral(I, f) > upper_riemann_integral(I, fn(x I) R {c * f(x)})
                    c * upper_riemann_integral(I, f) - upper_riemann_integral(I, fn(x I) R {c * f(x)}) > 0
                    (c * upper_riemann_integral(I, f) - upper_riemann_integral(I, fn(x I) R {c * f(x)})) / 2 > 0
                    have epsilon R_pos = (c * upper_riemann_integral(I, f) - upper_riemann_integral(I, fn(x I) R {c * f(x)})) / 2
                    epsilon / (abs(c) + 1) > 0
                    have delta R_pos = epsilon / (abs(c) + 1)
                    by thm upper_riemann_integral_has_candidate_within(I, f, delta)
                    obtain s from exist s0 R st {$is_upper_riemann_integral_candidate_value(I, f, s0), s0 < upper_riemann_integral(I, f) + delta}
                    by thm lower_riemann_integral_candidate_scalar_negative(I, f, c, s)
                    by thm lower_riemann_integral_candidate_value_le_integral(I, fn(x I) R {c * f(x)}, lower_riemann_integral(I, fn(x I) R {c * f(x)}), c * s)
                    c * s <= lower_riemann_integral(I, fn(x I) R {c * f(x)})
                    s < upper_riemann_integral(I, f) + delta
                    c * (upper_riemann_integral(I, f) + delta) < c * s
                    abs(c) = -c
                    c * (upper_riemann_integral(I, f) + delta) = c * upper_riemann_integral(I, f) - abs(c) * delta
                    abs(c) <= abs(c) + 1
                    abs(c) * delta <= (abs(c) + 1) * delta
                    delta = epsilon / (abs(c) + 1)
                    (abs(c) + 1) * delta = epsilon
                    c * upper_riemann_integral(I, f) - epsilon <= c * upper_riemann_integral(I, f) - abs(c) * delta
                    c * upper_riemann_integral(I, f) - epsilon < lower_riemann_integral(I, fn(x I) R {c * f(x)})
                    lower_riemann_integral(I, fn(x I) R {c * f(x)}) = upper_riemann_integral(I, fn(x I) R {c * f(x)})
                    c * upper_riemann_integral(I, f) - epsilon < upper_riemann_integral(I, fn(x I) R {c * f(x)})
                    upper_riemann_integral(I, fn(x I) R {c * f(x)}) < c * upper_riemann_integral(I, f) - epsilon
                    impossible c * upper_riemann_integral(I, f) - epsilon < upper_riemann_integral(I, fn(x I) R {c * f(x)})
                c * upper_riemann_integral(I, f) <= upper_riemann_integral(I, fn(x I) R {c * f(x)})
            upper_riemann_integral(I, fn(x I) R {c * f(x)}) = c * upper_riemann_integral(I, f)
    by thm integral_on_has_riemann_integral(I, f)
    by thm integral_on_has_riemann_integral(I, fn(x I) R {c * f(x)})
    by thm has_riemann_integral_value_eq_upper(I, f, integral_on(I, f))
    by thm has_riemann_integral_value_eq_upper(I, fn(x I) R {c * f(x)}, integral_on(I, fn(x I) R {c * f(x)}))
    integral_on(I, f) = upper_riemann_integral(I, f)
    integral_on(I, fn(x I) R {c * f(x)}) = upper_riemann_integral(I, fn(x I) R {c * f(x)})
    integral_on(I, fn(x I) R {c * f(x)}) = c * integral_on(I, f)

thm riemann_integral_respects_pointwise_equality:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_riemann_integrable_on(I, f)
        forall x I:
            g(x) = f(x)
        =>:
            $is_riemann_integrable_on(I, g)
            integral_on(I, g) = integral_on(I, f)
    # Source handling: Tao freely identifies functions that agree at every
    # point of the interval.  Litex first records this as equality of the
    # function objects, then transports the Riemann predicates and selector.
    $fn_eq(f, g)
    f = g
    $is_riemann_integrable_on(I, g)
    integral_on(I, g) = integral_on(I, f)

thm riemann_integral_subtraction_law:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_riemann_integrable_on(I, f)
        $is_riemann_integrable_on(I, g)
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {f(x) - g(x)})
            integral_on(I, fn(x I) R {f(x) - g(x)}) = integral_on(I, f) - integral_on(I, g)
    # Source handling: this is Theorem 11.4.1(c).
    by thm riemann_integral_scalar_multiplication_law(I, g, -1)
    $is_riemann_integrable_on(I, fn(x I) R {-1 * g(x)})
    integral_on(I, fn(x I) R {-1 * g(x)}) = -1 * integral_on(I, g)
    by thm riemann_integral_addition_law(I, f, fn(x I) R {-1 * g(x)})
    $is_riemann_integrable_on(I, fn(x I) R {f(x) + (-1 * g(x))})
    integral_on(I, fn(x I) R {f(x) + (-1 * g(x))}) = integral_on(I, f) + integral_on(I, fn(x I) R {-1 * g(x)})
    claim:
        ? forall x I:
            fn(x I) R {f(x) - g(x)}(x) = fn(x I) R {f(x) + (-1 * g(x))}(x)
        fn(x I) R {f(x) - g(x)}(x) = f(x) - g(x)
        fn(x I) R {f(x) + (-1 * g(x))}(x) = f(x) + (-1 * g(x))
        f(x) - g(x) = f(x) + (-1 * g(x))
        fn(x I) R {f(x) - g(x)}(x) = fn(x I) R {f(x) + (-1 * g(x))}(x)
    by thm riemann_integral_respects_pointwise_equality(I, fn(x I) R {f(x) + (-1 * g(x))}, fn(x I) R {f(x) - g(x)})
    $is_riemann_integrable_on(I, fn(x I) R {f(x) - g(x)})
    integral_on(I, fn(x I) R {f(x) - g(x)}) = integral_on(I, fn(x I) R {f(x) + (-1 * g(x))})
    integral_on(I, f) + integral_on(I, fn(x I) R {-1 * g(x)}) = integral_on(I, f) + (-1 * integral_on(I, g))
    integral_on(I, f) + (-1 * integral_on(I, g)) = integral_on(I, f) - integral_on(I, g)
    integral_on(I, fn(x I) R {f(x) + (-1 * g(x))}) = integral_on(I, f) - integral_on(I, g)
    integral_on(I, fn(x I) R {f(x) - g(x)}) = integral_on(I, f) - integral_on(I, g)

thm riemann_integral_nonnegative_law:
    ? forall I power_set(R), f fn(x I) R:
        $is_riemann_integrable_on(I, f)
        $is_nonnegative_on(I, f)
        =>:
            integral_on(I, f) >= 0
    # Source handling: this is Theorem 11.4.1(d).  The zero function is a
    # piecewise-constant minorant, so its value zero lies below the lower
    # integral.  Integrability identifies the lower and upper integrals.
    by thm riemann_integrable_on_bounded_interval(I, f)
    by thm riemann_integrable_on_bounded_function(I, f)
    $has_lower_riemann_integral(I, f, lower_riemann_integral(I, f))
    by thm constant_function_is_piecewise_constant(I, 0)
    by thm piecewise_constant_integral_of_constant(I, 0)
    0 * interval_length(I) = 0
    $has_piecewise_constant_integral(I, fn(x I) R {0}, 0)
    claim:
        ? $minorizes_on(I, fn(x I) R {0}, f)
        forall x I:
            fn(x I) R {0}(x) = 0
            f(x) >= 0
            fn(x I) R {0}(x) <= f(x)
        $minorizes_on(I, fn(x I) R {0}, f)
    claim:
        ? $is_lower_riemann_integral_candidate_value(I, f, 0)
        witness exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_integral(I, h, 0)} from fn(x I) R {0}:
            $is_piecewise_constant_on(I, fn(x I) R {0})
            $minorizes_on(I, fn(x I) R {0}, f)
            $has_piecewise_constant_integral(I, fn(x I) R {0}, 0)
        $is_lower_riemann_integral_candidate_value(I, f, 0)
    by thm lower_riemann_integral_candidate_value_le_integral(I, f, lower_riemann_integral(I, f), 0)
    0 <= lower_riemann_integral(I, f)
    by thm riemann_integrable_upper_eq_lower(I, f)
    upper_riemann_integral(I, f) = lower_riemann_integral(I, f)
    0 <= upper_riemann_integral(I, f)
    by thm integral_on_has_riemann_integral(I, f)
    integral_on(I, f) = upper_riemann_integral(I, f)
    integral_on(I, f) >= 0

thm riemann_integral_monotone_law:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_riemann_integrable_on(I, f)
        $is_riemann_integrable_on(I, g)
        forall x I:
            g(x) <= f(x)
        =>:
            integral_on(I, g) <= integral_on(I, f)
    # Source handling: this is Theorem 11.4.1(e).
    by thm riemann_integral_subtraction_law(I, f, g)
    $is_riemann_integrable_on(I, fn(x I) R {f(x) - g(x)})
    integral_on(I, fn(x I) R {f(x) - g(x)}) = integral_on(I, f) - integral_on(I, g)
    claim:
        ? $is_nonnegative_on(I, fn(x I) R {f(x) - g(x)})
        forall x I:
            g(x) <= f(x)
            fn(x I) R {f(x) - g(x)}(x) = f(x) - g(x)
            f(x) - g(x) >= 0
            fn(x I) R {f(x) - g(x)}(x) >= 0
        $is_nonnegative_on(I, fn(x I) R {f(x) - g(x)})
    by thm riemann_integral_nonnegative_law(I, fn(x I) R {f(x) - g(x)})
    integral_on(I, fn(x I) R {f(x) - g(x)}) >= 0
    integral_on(I, f) - integral_on(I, g) >= 0
    integral_on(I, g) <= integral_on(I, f)

thm riemann_integral_of_constant:
    ? forall I power_set(R), c R:
        $is_bounded_interval(I)
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {c})
            integral_on(I, fn(x I) R {c}) = c * interval_length(I)
    # Source handling: this is Theorem 11.4.1(f), inherited from the
    # piecewise-constant integral.
    by thm piecewise_constant_integral_of_constant(I, c)
    $has_piecewise_constant_integral(I, fn(x I) R {c}, c * interval_length(I))
    by thm piecewise_constant_functions_are_riemann_integrable(I, fn(x I) R {c}, c * interval_length(I))
    $is_riemann_integrable_on(I, fn(x I) R {c})
    integral_on(I, fn(x I) R {c}) = c * interval_length(I)

thm riemann_integral_of_zero_function:
    ? forall I power_set(R):
        $is_bounded_interval(I)
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {0})
            integral_on(I, fn(x I) R {0}) = 0
    # Source handling: this is the zero special case of Theorem 11.4.1(f).
    by thm riemann_integral_of_constant(I, 0)
    $is_riemann_integrable_on(I, fn(x I) R {0})
    integral_on(I, fn(x I) R {0}) = 0 * interval_length(I)
    0 * interval_length(I) = 0

# Bridge for Tao's displayed case-defined extension: `F=f` on `I` and `F=0`
# outside `I`.
prop is_extension_by_zero(J power_set(R), I power_set(R), f fn(x I) R, F fn(x J) R):
    I $subset J
    forall x I:
        F(x) = f(x)
    forall x J:
        not x $in I
        =>:
            F(x) = 0

thm riemann_integral_extension_by_zero:
    ? forall I, J power_set(R), f fn(x I) R, F fn(x J) R:
        $is_bounded_interval(I)
        $is_bounded_interval(J)
        I $subset J
        $is_riemann_integrable_on(I, f)
        $is_extension_by_zero(J, I, f, F)
        =>:
            $is_riemann_integrable_on(J, F)
            integral_on(J, F) = integral_on(I, f)
    # Source handling: the source states Theorem 11.4.1(g) and leaves its proof
    # to Exercise 11.4.1.  The trust records only that source-deferred part.
    # proof_debt: compare upper and lower approximations after extending
    # outside `I` by zero.
    trust:
        $is_riemann_integrable_on(J, F)
        integral_on(J, F) = integral_on(I, f)

thm riemann_integral_additive_over_two_piece_partition:
    ? forall I power_set(R), P finite_set, J, K power_set(R), f fn(x I) R:
        $is_partition_of_bounded_interval(I, P)
        J != K
        J $in P
        K $in P
        forall H P:
            H = J or H = K
        J $subset I
        K $subset I
        $is_riemann_integrable_on(I, f)
        =>:
            $is_riemann_integrable_on(J, fn(x J) R {f(x)})
            $is_riemann_integrable_on(K, fn(x K) R {f(x)})
            integral_on(I, f) = integral_on(J, fn(x J) R {f(x)}) + integral_on(K, fn(x K) R {f(x)})
    # Source handling: the source states Theorem 11.4.1(h) and leaves its proof
    # to Exercise 11.4.1.  The finite set `P` is the source partition into
    # exactly `J` and `K`; the trust records only the deferred gluing proof.
    # proof_debt: compare upper/lower sums over the two subinterval pieces.
    trust:
        $is_riemann_integrable_on(J, fn(x J) R {f(x)})
        $is_riemann_integrable_on(K, fn(x K) R {f(x)})
        integral_on(I, f) = integral_on(J, fn(x J) R {f(x)}) + integral_on(K, fn(x K) R {f(x)})

"""
Remark 11.4.2.  Tao often writes the restricted integral over `J` using the
same symbol `f`, even when `f` was originally defined on a larger interval.
"""

"""
Theorem 11.4.3 (Max and min preserve integrability).  The pointwise maximum
and minimum of two Riemann integrable functions are Riemann integrable.
"""

thm max_of_ge:
    ? forall a, b R:
        a >= b
        =>:
            finite_set_max(union({a}, { b})) = a
    a <= finite_set_max(union({a}, { b}))
    b <= a
    finite_set_max(union({a}, { b})) <= a
    finite_set_max(union({a}, { b})) = a

thm max_of_le:
    ? forall a, b R:
        a <= b
        =>:
            finite_set_max(union({a}, { b})) = b
    a <= b
    b <= finite_set_max(union({a}, { b}))
    finite_set_max(union({a}, { b})) <= b
    finite_set_max(union({a}, { b})) = b

thm min_of_le:
    ? forall a, b R:
        a <= b
        =>:
            finite_set_min(union({a}, { b})) = a
    finite_set_min(union({a}, { b})) <= a
    a <= b
    a <= finite_set_min(union({a}, { b}))
    finite_set_min(union({a}, { b})) = a

thm min_of_ge:
    ? forall a, b R:
        a >= b
        =>:
            finite_set_min(union({a}, { b})) = b
    finite_set_min(union({a}, { b})) <= b
    b <= a
    b <= finite_set_min(union({a}, { b}))
    finite_set_min(union({a}, { b})) = b

thm min_eq_neg_max_neg:
    ? forall a, b R:
        finite_set_min(union({a}, { b})) = -1 * finite_set_max(union({-1 * a}, { -1 * b}))
    by cases:
        ? finite_set_min(union({a}, { b})) = -1 * finite_set_max(union({-1 * a}, { -1 * b}))
        case a <= b:
            by thm min_of_le(a, b)
            -1 * a >= -1 * b
            by thm max_of_ge(-1 * a, -1 * b)
            finite_set_max(union({-1 * a}, { -1 * b})) = -1 * a
            -1 * finite_set_max(union({-1 * a}, { -1 * b})) = -1 * (-1 * a)
            -1 * (-1 * a) = a
            finite_set_min(union({a}, { b})) = a
            finite_set_min(union({a}, { b})) = -1 * finite_set_max(union({-1 * a}, { -1 * b}))
        case a > b:
            b <= a
            by thm min_of_ge(a, b)
            finite_set_min(union({a}, { b})) = b
            -1 * a <= -1 * b
            by thm max_of_le(-1 * a, -1 * b)
            finite_set_max(union({-1 * a}, { -1 * b})) = -1 * b
            -1 * finite_set_max(union({-1 * a}, { -1 * b})) = -1 * (-1 * b)
            -1 * (-1 * b) = b
            finite_set_min(union({a}, { b})) = -1 * finite_set_max(union({-1 * a}, { -1 * b}))

thm riemann_integrable_max_by_darboux_squeeze:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_riemann_integrable_on(I, f)
        $is_riemann_integrable_on(I, g)
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
    # Source handling: approximate both functions by step-function brackets.
    # The maximum of the two lower brackets remains below `max(f,g)`, while
    # the maximum of the upper brackets remains above it.
    by thm riemann_integrable_on_bounded_interval(I, f)
    by thm riemann_integrable_on_bounded_function(I, f)
    by thm riemann_integrable_on_bounded_function(I, g)
    by thm max_of_bounded_functions_is_bounded(I, f, g)
    claim:
        ? forall epsilon R_pos:
            exist h, k fn(x I) R, sh, sk R st {$has_darboux_approximation(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}, h, k, sh, sk, epsilon)}
        epsilon / 2 > 0
        have delta R_pos = epsilon / 2
        by thm riemann_integrable_has_darboux_approximation(I, f, delta)
        obtain hf, gf, shf, sgf from exist h0, g0 fn(x I) R, sh0, sg0 R st {$has_darboux_approximation(I, f, h0, g0, sh0, sg0, delta)}
        by thm riemann_integrable_has_darboux_approximation(I, g, delta)
        obtain hg, gg, shg, sgg from exist h0, g0 fn(x I) R, sh0, sg0 R st {$has_darboux_approximation(I, g, h0, g0, sh0, sg0, delta)}
        by thm darboux_approximations_max(I, f, g, hf, gf, hg, gg, shf, sgf, shg, sgg, delta, delta)
        obtain h, k, sh, sk from exist h0, k0 fn(x I) R, sh0, sk0 R st {$has_darboux_approximation(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}, h0, k0, sh0, sk0, delta + delta)}
        delta = epsilon / 2
        delta + delta = epsilon
        witness exist h0, k0 fn(x I) R, sh0, sk0 R st {$has_darboux_approximation(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}, h0, k0, sh0, sk0, epsilon)} from h, k, sh, sk:
            $has_darboux_approximation(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))}, h, k, sh, sk, epsilon)
    by thm arbitrary_darboux_approximations_imply_riemann_integrable(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
    $is_riemann_integrable_on(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})

thm riemann_integrable_min_by_darboux_squeeze:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_riemann_integrable_on(I, f)
        $is_riemann_integrable_on(I, g)
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))})
    # Source handling: this is the analogous minimum case in Theorem 11.4.3.
    # It can be proved by the same Darboux squeeze, or by applying the maximum
    # case to `-f` and `-g` and using `finite_set_min(union({a}, {b})) = -finite_set_max(union({-a}, {-b}))`.
    by thm riemann_integral_scalar_multiplication_law(I, f, -1)
    $is_riemann_integrable_on(I, fn(x I) R {-1 * f(x)})
    by thm riemann_integral_scalar_multiplication_law(I, g, -1)
    $is_riemann_integrable_on(I, fn(x I) R {-1 * g(x)})
    by thm riemann_integrable_max_by_darboux_squeeze(I, fn(x I) R {-1 * f(x)}, fn(x I) R {-1 * g(x)})
    $is_riemann_integrable_on(I, fn(x I) R {finite_set_max(union({-1 * f(x)}, { -1 * g(x)}))})
    by thm riemann_integral_scalar_multiplication_law(I, fn(x I) R {finite_set_max(union({-1 * f(x)}, { -1 * g(x)}))}, -1)
    $is_riemann_integrable_on(I, fn(x I) R {-1 * finite_set_max(union({-1 * f(x)}, { -1 * g(x)}))})
    claim:
        ? forall x I:
            fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))}(x) = fn(x I) R {-1 * finite_set_max(union({-1 * f(x)}, { -1 * g(x)}))}(x)
        by thm min_eq_neg_max_neg(f(x), g(x))
        fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))}(x) = finite_set_min(union({f(x)}, { g(x)}))
        fn(x I) R {-1 * finite_set_max(union({-1 * f(x)}, { -1 * g(x)}))}(x) = -1 * finite_set_max(union({-1 * f(x)}, { -1 * g(x)}))
        finite_set_min(union({f(x)}, { g(x)})) = -1 * finite_set_max(union({-1 * f(x)}, { -1 * g(x)}))
        fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))}(x) = fn(x I) R {-1 * finite_set_max(union({-1 * f(x)}, { -1 * g(x)}))}(x)
    by thm riemann_integral_respects_pointwise_equality(I, fn(x I) R {-1 * finite_set_max(union({-1 * f(x)}, { -1 * g(x)}))}, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))})
    $is_riemann_integrable_on(I, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))})

thm max_min_preserve_riemann_integrability:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_riemann_integrable_on(I, f)
        $is_riemann_integrable_on(I, g)
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {finite_set_max(union({f(x)}, { g(x)}))})
            $is_riemann_integrable_on(I, fn(x I) R {finite_set_min(union({f(x)}, { g(x)}))})
    # Source handling: Tao proves `max` by squeezing between piecewise
    # constant majorants and minorants, and says the `min` case is similar.
    by thm riemann_integrable_max_by_darboux_squeeze(I, f, g)
    by thm riemann_integrable_min_by_darboux_squeeze(I, f, g)

"""
Corollary 11.4.4.  Positive parts, negative parts, and absolute values of
Riemann integrable functions are Riemann integrable.
"""

thm max_with_zero_of_nonnegative:
    ? forall t R:
        t >= 0
        =>:
            finite_set_max(union({t}, { 0})) = t
    t <= finite_set_max(union({t}, { 0}))
    0 <= t
    finite_set_max(union({t}, { 0})) <= t
    finite_set_max(union({t}, { 0})) = t

thm min_with_zero_of_nonnegative:
    ? forall t R:
        t >= 0
        =>:
            finite_set_min(union({t}, { 0})) = 0
    finite_set_min(union({t}, { 0})) <= 0
    0 <= t
    0 <= finite_set_min(union({t}, { 0}))
    finite_set_min(union({t}, { 0})) = 0

thm max_with_zero_of_negative:
    ? forall t R:
        t < 0
        =>:
            finite_set_max(union({t}, { 0})) = 0
    0 <= finite_set_max(union({t}, { 0}))
    t <= 0
    finite_set_max(union({t}, { 0})) <= 0
    finite_set_max(union({t}, { 0})) = 0

thm min_with_zero_of_negative:
    ? forall t R:
        t < 0
        =>:
            finite_set_min(union({t}, { 0})) = t
    finite_set_min(union({t}, { 0})) <= t
    t <= 0
    t <= finite_set_min(union({t}, { 0}))
    finite_set_min(union({t}, { 0})) = t

thm absolute_value_as_positive_minus_negative_part:
    ? forall t R:
        abs(t) = finite_set_max(union({t}, { 0})) - finite_set_min(union({t}, { 0}))
    # Source handling: this is the pointwise identity behind Tao's notation
    # `|f| = f_+ - f_-`.
    by cases:
        ? abs(t) = finite_set_max(union({t}, { 0})) - finite_set_min(union({t}, { 0}))
        case t >= 0:
            by thm max_with_zero_of_nonnegative(t)
            by thm min_with_zero_of_nonnegative(t)
            abs(t) = t
            finite_set_max(union({t}, { 0})) = t
            finite_set_min(union({t}, { 0})) = 0
            finite_set_max(union({t}, { 0})) - finite_set_min(union({t}, { 0})) = t - 0
            t - 0 = t
            abs(t) = finite_set_max(union({t}, { 0})) - finite_set_min(union({t}, { 0}))
        case t < 0:
            by thm max_with_zero_of_negative(t)
            by thm min_with_zero_of_negative(t)
            abs(t) = -1 * t
            finite_set_max(union({t}, { 0})) = 0
            finite_set_min(union({t}, { 0})) = t
            finite_set_max(union({t}, { 0})) - finite_set_min(union({t}, { 0})) = 0 - t
            0 - t = -1 * t
            abs(t) = finite_set_max(union({t}, { 0})) - finite_set_min(union({t}, { 0}))

thm absolute_value_preserves_riemann_integrability:
    ? forall I power_set(R), f fn(x I) R:
        $is_riemann_integrable_on(I, f)
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {finite_set_max(union({f(x)}, { 0}))})
            $is_riemann_integrable_on(I, fn(x I) R {finite_set_min(union({f(x)}, { 0}))})
            $is_riemann_integrable_on(I, fn(x I) R {abs(f(x))})
    # Source handling: Tao applies Theorem 11.4.3 with the zero function and
    # then writes `|f| = f_+ - f_-`.
    by thm riemann_integrable_on_bounded_interval(I, f)
    by thm riemann_integral_of_zero_function(I)
    by thm max_min_preserve_riemann_integrability(I, f, fn(x I) R {0})
    $is_riemann_integrable_on(I, fn(x I) R {finite_set_max(union({f(x)}, { 0}))})
    $is_riemann_integrable_on(I, fn(x I) R {finite_set_min(union({f(x)}, { 0}))})
    by thm riemann_integral_subtraction_law(I, fn(x I) R {finite_set_max(union({f(x)}, { 0}))}, fn(x I) R {finite_set_min(union({f(x)}, { 0}))})
    $is_riemann_integrable_on(I, fn(x I) R {finite_set_max(union({f(x)}, { 0})) - finite_set_min(union({f(x)}, { 0}))})
    claim:
        ? forall x I:
            fn(x I) R {abs(f(x))}(x) = fn(x I) R {finite_set_max(union({f(x)}, { 0})) - finite_set_min(union({f(x)}, { 0}))}(x)
        by thm absolute_value_as_positive_minus_negative_part(f(x))
        fn(x I) R {abs(f(x))}(x) = abs(f(x))
        fn(x I) R {finite_set_max(union({f(x)}, { 0})) - finite_set_min(union({f(x)}, { 0}))}(x) = finite_set_max(union({f(x)}, { 0})) - finite_set_min(union({f(x)}, { 0}))
        abs(f(x)) = finite_set_max(union({f(x)}, { 0})) - finite_set_min(union({f(x)}, { 0}))
        fn(x I) R {abs(f(x))}(x) = fn(x I) R {finite_set_max(union({f(x)}, { 0})) - finite_set_min(union({f(x)}, { 0}))}(x)
    by thm riemann_integral_respects_pointwise_equality(I, fn(x I) R {finite_set_max(union({f(x)}, { 0})) - finite_set_min(union({f(x)}, { 0}))}, fn(x I) R {abs(f(x))})
    $is_riemann_integrable_on(I, fn(x I) R {abs(f(x))})

"""
Theorem 11.4.5.  The product of two Riemann integrable functions is Riemann
integrable.
"""

thm absolute_value_function_is_nonnegative:
    ? forall I power_set(R), f fn(x I) R:
        $is_nonnegative_on(I, fn(x I) R {abs(f(x))})
    # Source handling: absolute values are pointwise non-negative.
    forall x I:
        fn(x I) R {abs(f(x))}(x) = abs(f(x))
        abs(f(x)) >= 0
        fn(x I) R {abs(f(x))}(x) >= 0
    $is_nonnegative_on(I, fn(x I) R {abs(f(x))})

thm nonnegative_bounded_product_is_bounded:
    ? forall I power_set(R), f, g fn(x I) R, Mf, Mg R_pos:
        $is_nonnegative_on(I, f)
        $is_nonnegative_on(I, g)
        $chap9::is_function_bounded_by(I, f, Mf)
        $chap9::is_function_bounded_by(I, g, Mg)
        =>:
            $chap9::is_bounded_function_on(I, fn(x I) R {f(x) * g(x)})
    Mf * Mg + 1 > 0
    witness exist B R_pos st {$chap9::is_function_bounded_by(I, fn(x I) R {f(x) * g(x)}, B)} from Mf * Mg + 1:
        forall x I:
            0 <= f(x)
            0 <= g(x)
            abs(f(x)) <= Mf
            abs(g(x)) <= Mg
            f(x) <= abs(f(x))
            g(x) <= abs(g(x))
            f(x) <= Mf
            g(x) <= Mg
            0 <= f(x) * g(x)
            abs(f(x) * g(x)) = f(x) * g(x)
            f(x) * g(x) <= Mf * Mg
            Mf * Mg <= Mf * Mg + 1
            abs(f(x) * g(x)) <= Mf * Mg + 1
            fn(x I) R {f(x) * g(x)}(x) = f(x) * g(x)
            abs(fn(x I) R {f(x) * g(x)}(x)) = abs(f(x) * g(x))
            B = Mf * Mg + 1
            abs(fn(x I) R {f(x) * g(x)}(x)) <= B
        $chap9::is_function_bounded_by(I, fn(x I) R {f(x) * g(x)}, B)
    $chap9::is_bounded_function_on(I, fn(x I) R {f(x) * g(x)})

thm riemann_integrable_nonnegative_product_has_darboux_approximation:
    ? forall I power_set(R), f, g fn(x I) R, epsilon R_pos:
        $is_riemann_integrable_on(I, f)
        $is_riemann_integrable_on(I, g)
        $is_nonnegative_on(I, f)
        $is_nonnegative_on(I, g)
        =>:
            exist h, k fn(x I) R, sh, sk R st {$has_darboux_approximation(I, fn(x I) R {f(x) * g(x)}, h, k, sh, sk, epsilon)}
    by thm riemann_integrable_on_bounded_function(I, f)
    obtain Mf from exist M R_pos st {$chap9::is_function_bounded_by(I, f, M)}
    by thm riemann_integrable_on_bounded_function(I, g)
    obtain Mg from exist M R_pos st {$chap9::is_function_bounded_by(I, g, M)}
    Mf + Mg + 1 > 0
    epsilon / (Mf + Mg + 1) > 0
    have delta R_pos = epsilon / (Mf + Mg + 1)
    by thm riemann_integrable_nonnegative_bounded_has_clamped_darboux_approximation(I, f, Mf, delta)
    obtain lf, uf, slf, suf from exist h, k fn(x I) R, sh, sk R st {$has_darboux_approximation(I, f, h, k, sh, sk, delta), $is_nonnegative_on(I, h), $is_nonnegative_on(I, k), $chap9::is_function_bounded_above_by(I, k, Mf)}
    by thm riemann_integrable_nonnegative_bounded_has_clamped_darboux_approximation(I, g, Mg, delta)
    obtain lg, ug, slg, sug from exist h, k fn(x I) R, sh, sk R st {$has_darboux_approximation(I, g, h, k, sh, sk, delta), $is_nonnegative_on(I, h), $is_nonnegative_on(I, k), $chap9::is_function_bounded_above_by(I, k, Mg)}
    by thm riemann_integrable_on_bounded_interval(I, f)
    by thm piecewise_constant_algebra(I, lf, lg)
    $is_piecewise_constant_on(I, fn(x I) R {lf(x) * lg(x)})
    by thm piecewise_constant_algebra(I, uf, ug)
    $is_piecewise_constant_on(I, fn(x I) R {uf(x) * ug(x)})
    by thm piecewise_constant_on_bounded_interval_has_piecewise_constant_integral(I, fn(x I) R {lf(x) * lg(x)})
    obtain sl from exist s R st {$has_piecewise_constant_integral(I, fn(x I) R {lf(x) * lg(x)}, s)}
    by thm piecewise_constant_on_bounded_interval_has_piecewise_constant_integral(I, fn(x I) R {uf(x) * ug(x)})
    obtain su from exist s R st {$has_piecewise_constant_integral(I, fn(x I) R {uf(x) * ug(x)}, s)}
    claim:
        ? $minorizes_on(I, fn(x I) R {lf(x) * lg(x)}, fn(x I) R {f(x) * g(x)})
        forall x I:
            0 <= lf(x)
            0 <= lg(x)
            lf(x) <= f(x)
            lg(x) <= g(x)
            lf(x) * lg(x) <= f(x) * lg(x)
            f(x) * lg(x) <= f(x) * g(x)
            lf(x) * lg(x) <= f(x) * g(x)
            fn(x I) R {lf(x) * lg(x)}(x) = lf(x) * lg(x)
            fn(x I) R {f(x) * g(x)}(x) = f(x) * g(x)
            fn(x I) R {lf(x) * lg(x)}(x) <= fn(x I) R {f(x) * g(x)}(x)
        $minorizes_on(I, fn(x I) R {lf(x) * lg(x)}, fn(x I) R {f(x) * g(x)})
    claim:
        ? $majorizes_on(I, fn(x I) R {uf(x) * ug(x)}, fn(x I) R {f(x) * g(x)})
        forall x I:
            0 <= uf(x)
            0 <= ug(x)
            f(x) <= uf(x)
            g(x) <= ug(x)
            f(x) * g(x) <= uf(x) * g(x)
            uf(x) * g(x) <= uf(x) * ug(x)
            f(x) * g(x) <= uf(x) * ug(x)
            fn(x I) R {uf(x) * ug(x)}(x) = uf(x) * ug(x)
            fn(x I) R {f(x) * g(x)}(x) = f(x) * g(x)
            fn(x I) R {uf(x) * ug(x)}(x) >= fn(x I) R {f(x) * g(x)}(x)
        $majorizes_on(I, fn(x I) R {uf(x) * ug(x)}, fn(x I) R {f(x) * g(x)})
    by thm piecewise_constant_integral_laws(I, uf, lf, suf, slf, 1)
    $has_piecewise_constant_integral(I, fn(x I) R {uf(x) - lf(x)}, suf - slf)
    by thm piecewise_constant_integral_laws(I, ug, lg, sug, slg, 1)
    $has_piecewise_constant_integral(I, fn(x I) R {ug(x) - lg(x)}, sug - slg)
    by thm piecewise_constant_integral_laws(I, fn(x I) R {uf(x) - lf(x)}, fn(x I) R {ug(x) - lg(x)}, suf - slf, sug - slg, Mg)
    $has_piecewise_constant_integral(I, fn(x I) R {Mg * (uf(x) - lf(x))}, Mg * (suf - slf))
    by thm piecewise_constant_integral_laws(I, fn(x I) R {ug(x) - lg(x)}, fn(x I) R {uf(x) - lf(x)}, sug - slg, suf - slf, Mf)
    $has_piecewise_constant_integral(I, fn(x I) R {Mf * (ug(x) - lg(x))}, Mf * (sug - slg))
    by thm piecewise_constant_integral_laws(I, fn(x I) R {Mg * (uf(x) - lf(x))}, fn(x I) R {Mf * (ug(x) - lg(x))}, Mg * (suf - slf), Mf * (sug - slg), 1)
    $has_piecewise_constant_integral(I, fn(x I) R {Mg * (uf(x) - lf(x)) + Mf * (ug(x) - lg(x))}, Mg * (suf - slf) + Mf * (sug - slg))
    claim:
        ? $is_nonnegative_on(I, fn(x I) R {Mg * (uf(x) - lf(x)) + Mf * (ug(x) - lg(x))})
        forall x I:
            lf(x) <= f(x)
            f(x) <= uf(x)
            lg(x) <= g(x)
            g(x) <= ug(x)
            0 <= uf(x) - lf(x)
            0 <= ug(x) - lg(x)
            0 <= Mg * (uf(x) - lf(x))
            0 <= Mf * (ug(x) - lg(x))
            0 <= Mg * (uf(x) - lf(x)) + Mf * (ug(x) - lg(x))
            fn(x I) R {Mg * (uf(x) - lf(x)) + Mf * (ug(x) - lg(x))}(x) = Mg * (uf(x) - lf(x)) + Mf * (ug(x) - lg(x))
            fn(x I) R {Mg * (uf(x) - lf(x)) + Mf * (ug(x) - lg(x))}(x) >= 0
        $is_nonnegative_on(I, fn(x I) R {Mg * (uf(x) - lf(x)) + Mf * (ug(x) - lg(x))})
    by thm piecewise_constant_integral_laws(I, fn(x I) R {uf(x) * ug(x)}, fn(x I) R {lf(x) * lg(x)}, su, sl, 1)
    $has_piecewise_constant_integral(I, fn(x I) R {uf(x) * ug(x) - lf(x) * lg(x)}, su - sl)
    claim:
        ? forall x I:
            fn(x I) R {uf(x) * ug(x) - lf(x) * lg(x)}(x) <= fn(x I) R {Mg * (uf(x) - lf(x)) + Mf * (ug(x) - lg(x))}(x)
        lf(x) <= f(x)
        f(x) <= uf(x)
        f(x) <= Mf
        uf(x) <= Mf
        lg(x) <= g(x)
        g(x) <= ug(x)
        ug(x) <= Mg
        0 <= uf(x) - lf(x)
        0 <= ug(x) - lg(x)
        uf(x) * ug(x) - lf(x) * lg(x) = ug(x) * (uf(x) - lf(x)) + lf(x) * (ug(x) - lg(x))
        ug(x) * (uf(x) - lf(x)) <= Mg * (uf(x) - lf(x))
        lf(x) * (ug(x) - lg(x)) <= Mf * (ug(x) - lg(x))
        uf(x) * ug(x) - lf(x) * lg(x) <= Mg * (uf(x) - lf(x)) + Mf * (ug(x) - lg(x))
        fn(x I) R {uf(x) * ug(x) - lf(x) * lg(x)}(x) = uf(x) * ug(x) - lf(x) * lg(x)
        fn(x I) R {Mg * (uf(x) - lf(x)) + Mf * (ug(x) - lg(x))}(x) = Mg * (uf(x) - lf(x)) + Mf * (ug(x) - lg(x))
        fn(x I) R {uf(x) * ug(x) - lf(x) * lg(x)}(x) <= fn(x I) R {Mg * (uf(x) - lf(x)) + Mf * (ug(x) - lg(x))}(x)
    by thm piecewise_constant_integral_order_laws(I, fn(x I) R {Mg * (uf(x) - lf(x)) + Mf * (ug(x) - lg(x))}, fn(x I) R {uf(x) * ug(x) - lf(x) * lg(x)}, Mg * (suf - slf) + Mf * (sug - slg), su - sl)
    su - sl <= Mg * (suf - slf) + Mf * (sug - slg)
    by thm piecewise_constant_minorant_integral_le_majorant_integral(I, f, uf, lf, suf, slf)
    slf <= suf
    by thm piecewise_constant_minorant_integral_le_majorant_integral(I, g, ug, lg, sug, slg)
    slg <= sug
    suf - slf < delta
    sug - slg < delta
    0 <= suf - slf
    0 <= sug - slg
    Mg * (suf - slf) < Mg * delta
    Mf * (sug - slg) < Mf * delta
    Mg * (suf - slf) + Mf * (sug - slg) < Mg * delta + Mf * delta
    Mg * delta + Mf * delta = (Mf + Mg) * delta
    (Mf + Mg) * delta < (Mf + Mg + 1) * delta
    delta = epsilon / (Mf + Mg + 1)
    (Mf + Mg + 1) * delta = epsilon
    Mg * (suf - slf) + Mf * (sug - slg) < epsilon
    su - sl < epsilon
    witness exist h, k fn(x I) R, sh, sk R st {$has_darboux_approximation(I, fn(x I) R {f(x) * g(x)}, h, k, sh, sk, epsilon)} from fn(x I) R {lf(x) * lg(x)}, fn(x I) R {uf(x) * ug(x)}, sl, su:
        $has_darboux_approximation(I, fn(x I) R {f(x) * g(x)}, fn(x I) R {lf(x) * lg(x)}, fn(x I) R {uf(x) * ug(x)}, sl, su, epsilon)

thm nonnegative_products_preserve_riemann_integrability_by_darboux_squeeze:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_riemann_integrable_on(I, f)
        $is_riemann_integrable_on(I, g)
        $is_nonnegative_on(I, f)
        $is_nonnegative_on(I, g)
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {f(x) * g(x)})
    # Source handling: Tao proves the non-negative product case by a Darboux
    # squeeze before reducing the general product to positive and negative parts.
    by thm riemann_integrable_on_bounded_interval(I, f)
    $is_bounded_interval(I)
    by thm riemann_integrable_on_bounded_function(I, f)
    obtain Mf from exist M R_pos st {$chap9::is_function_bounded_by(I, f, M)}
    by thm riemann_integrable_on_bounded_function(I, g)
    obtain Mg from exist M R_pos st {$chap9::is_function_bounded_by(I, g, M)}
    by thm nonnegative_bounded_product_is_bounded(I, f, g, Mf, Mg)
    $chap9::is_bounded_function_on(I, fn(x I) R {f(x) * g(x)})
    claim:
        ? forall epsilon R_pos:
            exist h, k fn(x I) R, sh, sk R st {$has_darboux_approximation(I, fn(x I) R {f(x) * g(x)}, h, k, sh, sk, epsilon)}
        by thm riemann_integrable_nonnegative_product_has_darboux_approximation(I, f, g, epsilon)
        exist h, k fn(x I) R, sh, sk R st {$has_darboux_approximation(I, fn(x I) R {f(x) * g(x)}, h, k, sh, sk, epsilon)}
    by thm arbitrary_darboux_approximations_imply_riemann_integrable(I, fn(x I) R {f(x) * g(x)})
    $is_riemann_integrable_on(I, fn(x I) R {f(x) * g(x)})

thm square_equals_absolute_value_product:
    ? forall t R:
        t * t = abs(t) * abs(t)
    # Source handling: this is the pointwise bridge from a square to the
    # product of the non-negative absolute value with itself.
    by cases:
        ? t * t = abs(t) * abs(t)
        case t >= 0:
            abs(t) = t
            t * t = abs(t) * abs(t)
        case t < 0:
            abs(t) = -1 * t
            abs(t) * abs(t) = (-1 * t) * (-1 * t)
            (-1 * t) * (-1 * t) = t * t
            t * t = abs(t) * abs(t)

thm squares_preserve_riemann_integrability:
    ? forall I power_set(R), f fn(x I) R:
        $is_riemann_integrable_on(I, f)
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {f(x) * f(x)})
    # Source handling: reduce `f^2` to `|f| |f|`, then apply the
    # non-negative product case.
    by thm absolute_value_preserves_riemann_integrability(I, f)
    $is_riemann_integrable_on(I, fn(x I) R {abs(f(x))})
    by thm absolute_value_function_is_nonnegative(I, f)
    $is_nonnegative_on(I, fn(x I) R {abs(f(x))})
    by thm nonnegative_products_preserve_riemann_integrability_by_darboux_squeeze(I, fn(x I) R {abs(f(x))}, fn(x I) R {abs(f(x))})
    $is_riemann_integrable_on(I, fn(x I) R {abs(f(x)) * abs(f(x))})
    claim:
        ? forall x I:
            fn(x I) R {f(x) * f(x)}(x) = fn(x I) R {abs(f(x)) * abs(f(x))}(x)
        by thm square_equals_absolute_value_product(f(x))
        fn(x I) R {f(x) * f(x)}(x) = f(x) * f(x)
        fn(x I) R {abs(f(x)) * abs(f(x))}(x) = abs(f(x)) * abs(f(x))
        f(x) * f(x) = abs(f(x)) * abs(f(x))
        fn(x I) R {f(x) * f(x)}(x) = fn(x I) R {abs(f(x)) * abs(f(x))}(x)
    by thm riemann_integral_respects_pointwise_equality(I, fn(x I) R {abs(f(x)) * abs(f(x))}, fn(x I) R {f(x) * f(x)})
    $is_riemann_integrable_on(I, fn(x I) R {f(x) * f(x)})

have fn product_polarization_value(a, b R) R = (1 / 4) * (((a + b) * (a + b)) - ((a - b) * (a - b)))

thm product_polarization_identity:
    ? forall a, b R:
        a * b = product_polarization_value(a, b)
    # Source handling: this is the elementary identity
    # `(a+b)^2-(a-b)^2 = 4ab`.

thm product_polarization_value_preserves_riemann_integrability_from_square_difference:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_riemann_integrable_on(I, fn(x I) R {((f(x) + g(x)) * (f(x) + g(x))) - ((f(x) - g(x)) * (f(x) - g(x)))})
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {product_polarization_value(f(x), g(x))})
    # Source handling: this is the final linear step in the polarization
    # route: multiply the square difference by `1/4` and identify the result
    # with `product_polarization_value`.
    by thm riemann_integral_scalar_multiplication_law(I, fn(x I) R {((f(x) + g(x)) * (f(x) + g(x))) - ((f(x) - g(x)) * (f(x) - g(x)))}, 1 / 4)
    $is_riemann_integrable_on(I, fn(x I) R {(1 / 4) * (((f(x) + g(x)) * (f(x) + g(x))) - ((f(x) - g(x)) * (f(x) - g(x))))})
    claim:
        ? forall x I:
            fn(x I) R {product_polarization_value(f(x), g(x))}(x) = fn(x I) R {(1 / 4) * (((f(x) + g(x)) * (f(x) + g(x))) - ((f(x) - g(x)) * (f(x) - g(x))))}(x)
        fn(x I) R {product_polarization_value(f(x), g(x))}(x) = product_polarization_value(f(x), g(x))
        fn(x I) R {(1 / 4) * (((f(x) + g(x)) * (f(x) + g(x))) - ((f(x) - g(x)) * (f(x) - g(x))))}(x) = (1 / 4) * (((f(x) + g(x)) * (f(x) + g(x))) - ((f(x) - g(x)) * (f(x) - g(x))))
        product_polarization_value(f(x), g(x)) = (1 / 4) * (((f(x) + g(x)) * (f(x) + g(x))) - ((f(x) - g(x)) * (f(x) - g(x))))
        fn(x I) R {product_polarization_value(f(x), g(x))}(x) = fn(x I) R {(1 / 4) * (((f(x) + g(x)) * (f(x) + g(x))) - ((f(x) - g(x)) * (f(x) - g(x))))}(x)
    by thm riemann_integral_respects_pointwise_equality(I, fn(x I) R {(1 / 4) * (((f(x) + g(x)) * (f(x) + g(x))) - ((f(x) - g(x)) * (f(x) - g(x))))}, fn(x I) R {product_polarization_value(f(x), g(x))})
    $is_riemann_integrable_on(I, fn(x I) R {product_polarization_value(f(x), g(x))})

thm products_preserve_riemann_integrability:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_riemann_integrable_on(I, f)
        $is_riemann_integrable_on(I, g)
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {f(x) * g(x)})
    # Source handling: Tao's proof reduces the result to a bounded
    # non-negative product estimate.  The checked Litex route packages that
    # estimate above, proves squares using absolute values from Corollary
    # 11.4.4, and then uses the polarization identity.
    by thm riemann_integral_addition_law(I, f, g)
    $is_riemann_integrable_on(I, fn(x I) R {f(x) + g(x)})
    by thm riemann_integral_subtraction_law(I, f, g)
    $is_riemann_integrable_on(I, fn(x I) R {f(x) - g(x)})
    by thm squares_preserve_riemann_integrability(I, fn(x I) R {f(x) + g(x)})
    $is_riemann_integrable_on(I, fn(x I) R {(f(x) + g(x)) * (f(x) + g(x))})
    by thm squares_preserve_riemann_integrability(I, fn(x I) R {f(x) - g(x)})
    $is_riemann_integrable_on(I, fn(x I) R {(f(x) - g(x)) * (f(x) - g(x))})
    by thm riemann_integral_subtraction_law(I, fn(x I) R {(f(x) + g(x)) * (f(x) + g(x))}, fn(x I) R {(f(x) - g(x)) * (f(x) - g(x))})
    $is_riemann_integrable_on(I, fn(x I) R {((f(x) + g(x)) * (f(x) + g(x))) - ((f(x) - g(x)) * (f(x) - g(x)))})
    by thm product_polarization_value_preserves_riemann_integrability_from_square_difference(I, f, g)
    $is_riemann_integrable_on(I, fn(x I) R {product_polarization_value(f(x), g(x))})
    claim:
        ? forall x I:
            fn(x I) R {f(x) * g(x)}(x) = fn(x I) R {product_polarization_value(f(x), g(x))}(x)
        by thm product_polarization_identity(f(x), g(x))
        fn(x I) R {f(x) * g(x)}(x) = f(x) * g(x)
        fn(x I) R {product_polarization_value(f(x), g(x))}(x) = product_polarization_value(f(x), g(x))
        f(x) * g(x) = product_polarization_value(f(x), g(x))
        fn(x I) R {f(x) * g(x)}(x) = fn(x I) R {product_polarization_value(f(x), g(x))}(x)
    by thm riemann_integral_respects_pointwise_equality(I, fn(x I) R {product_polarization_value(f(x), g(x))}, fn(x I) R {f(x) * g(x)})
    $is_riemann_integrable_on(I, fn(x I) R {f(x) * g(x)})


# 11.5 Riemann integrability of continuous functions

"""
Theorem 11.5.1.  A uniformly continuous function on a bounded interval is
Riemann integrable.
"""

# Bridge/proof package for Tao's Darboux proof of Theorem 11.5.1: the source
# partitions the interval into pieces whose oscillation is small, then compares
# upper and lower sums.
prop has_partition_piece_oscillation_at_most(I power_set(R), J power_set(R), f fn(x I) R, epsilon R_pos):
    J $subset I
    forall x, y J:
        abs(f(x) - f(y)) <= epsilon

prop is_small_oscillation_partition(I power_set(R), P finite_set, f fn(x I) R, epsilon R_pos):
    $is_partition_of_bounded_interval(I, P)
    forall J P:
        J $in power_set(R)
        $has_partition_piece_oscillation_at_most(I, J, f, epsilon)

prop has_small_oscillation_partition(I power_set(R), f fn(x I) R, epsilon R_pos):
    exist P finite_set st {$is_small_oscillation_partition(I, P, f, epsilon)}

thm nonempty_upper_riemann_piece_height_is_lub:
    ? forall I, J power_set(R), f fn(x I) R:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        $is_nonempty_set(J)
        =>:
            $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), upper_riemann_piece_height(I, J, f))
    by thm upper_riemann_piece_height_has_value(I, J, f)
    $has_empty_upper_riemann_piece_height(J, upper_riemann_piece_height(I, J, f)) or $has_nonempty_upper_riemann_piece_height(I, J, f, upper_riemann_piece_height(I, J, f))
    by cases:
        ? $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), upper_riemann_piece_height(I, J, f))
        case $has_empty_upper_riemann_piece_height(J, upper_riemann_piece_height(I, J, f)):
            not $is_nonempty_set(J)
            by contra:
                ? $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), upper_riemann_piece_height(I, J, f))
                impossible $is_nonempty_set(J)
        case $has_nonempty_upper_riemann_piece_height(I, J, f, upper_riemann_piece_height(I, J, f)):
            $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), upper_riemann_piece_height(I, J, f))

thm nonempty_lower_riemann_piece_height_is_infimum:
    ? forall I, J power_set(R), f fn(x I) R:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        $is_nonempty_set(J)
        =>:
            $is_infimum_of_real_set(function_values_on_subset(I, J, f), lower_riemann_piece_height(I, J, f))
    by thm lower_riemann_piece_height_has_value(I, J, f)
    $has_empty_lower_riemann_piece_height(J, lower_riemann_piece_height(I, J, f)) or $has_nonempty_lower_riemann_piece_height(I, J, f, lower_riemann_piece_height(I, J, f))
    by cases:
        ? $is_infimum_of_real_set(function_values_on_subset(I, J, f), lower_riemann_piece_height(I, J, f))
        case $has_empty_lower_riemann_piece_height(J, lower_riemann_piece_height(I, J, f)):
            not $is_nonempty_set(J)
            by contra:
                ? $is_infimum_of_real_set(function_values_on_subset(I, J, f), lower_riemann_piece_height(I, J, f))
                impossible $is_nonempty_set(J)
        case $has_nonempty_lower_riemann_piece_height(I, J, f, lower_riemann_piece_height(I, J, f)):
            $is_infimum_of_real_set(function_values_on_subset(I, J, f), lower_riemann_piece_height(I, J, f))

thm riemann_piece_height_gap_bounded_by_oscillation:
    ? forall I, J power_set(R), f fn(x I) R, epsilon R_pos:
        $is_bounded_interval(J)
        J $subset I
        $chap9::is_bounded_function_on(I, f)
        $has_partition_piece_oscillation_at_most(I, J, f, epsilon)
        =>:
            upper_riemann_piece_height(I, J, f) - lower_riemann_piece_height(I, J, f) <= epsilon
    by cases:
        ? upper_riemann_piece_height(I, J, f) - lower_riemann_piece_height(I, J, f) <= epsilon
        case $is_nonempty_set(J):
            by thm nonempty_upper_riemann_piece_height_is_lub(I, J, f)
            by thm nonempty_lower_riemann_piece_height_is_infimum(I, J, f)
            $chap5::is_least_upper_bound(function_values_on_subset(I, J, f), upper_riemann_piece_height(I, J, f))
            $is_infimum_of_real_set(function_values_on_subset(I, J, f), lower_riemann_piece_height(I, J, f))
            claim:
                ? $chap5::is_upper_bound(function_values_on_subset(I, J, f), lower_riemann_piece_height(I, J, f) + epsilon)
                claim:
                    ? forall y function_values_on_subset(I, J, f):
                        y <= lower_riemann_piece_height(I, J, f) + epsilon
                    by thm function_values_on_subset_member_has_preimage(I, J, f, y)
                    obtain x from exist x J st {y = f(x)}
                    claim:
                        ? $is_lower_bound_of_real_set(function_values_on_subset(I, J, f), y - epsilon)
                        claim:
                            ? forall z function_values_on_subset(I, J, f):
                                y - epsilon <= z
                            by thm function_values_on_subset_member_has_preimage(I, J, f, z)
                            obtain w from exist w J st {z = f(w)}
                            abs(f(x) - f(w)) <= epsilon
                            f(x) - f(w) <= abs(f(x) - f(w))
                            f(x) - f(w) <= epsilon
                            (f(x) - f(w)) + f(w) <= epsilon + f(w)
                            (f(x) - f(w)) + f(w) = f(x)
                            f(x) <= epsilon + f(w)
                            f(x) - epsilon <= epsilon + f(w) - epsilon
                            epsilon + f(w) - epsilon = f(w)
                            f(x) - epsilon <= f(w)
                            y - epsilon = f(x) - epsilon
                            f(w) = z
                            y - epsilon = f(x) - epsilon <= f(w) = z
                        $is_lower_bound_of_real_set(function_values_on_subset(I, J, f), y - epsilon)
                    forall M R:
                        $is_lower_bound_of_real_set(function_values_on_subset(I, J, f), M)
                        =>:
                            M <= lower_riemann_piece_height(I, J, f)
                    y - epsilon <= lower_riemann_piece_height(I, J, f)
                    y - epsilon + epsilon <= lower_riemann_piece_height(I, J, f) + epsilon
                    y - epsilon + epsilon = y
                    y <= lower_riemann_piece_height(I, J, f) + epsilon
                function_values_on_subset(I, J, f) $subset R
                $chap5::is_upper_bound(function_values_on_subset(I, J, f), lower_riemann_piece_height(I, J, f) + epsilon)
            forall B R:
                $chap5::is_upper_bound(function_values_on_subset(I, J, f), B)
                =>:
                    upper_riemann_piece_height(I, J, f) <= B
            upper_riemann_piece_height(I, J, f) <= lower_riemann_piece_height(I, J, f) + epsilon
            upper_riemann_piece_height(I, J, f) - lower_riemann_piece_height(I, J, f) <= epsilon
        case not $is_nonempty_set(J):
            by thm upper_riemann_piece_height_has_value(I, J, f)
            by thm lower_riemann_piece_height_has_value(I, J, f)
            $has_empty_upper_riemann_piece_height(J, upper_riemann_piece_height(I, J, f)) or $has_nonempty_upper_riemann_piece_height(I, J, f, upper_riemann_piece_height(I, J, f))
            $has_empty_lower_riemann_piece_height(J, lower_riemann_piece_height(I, J, f)) or $has_nonempty_lower_riemann_piece_height(I, J, f, lower_riemann_piece_height(I, J, f))
            by cases:
                ? upper_riemann_piece_height(I, J, f) = 0
                case $has_empty_upper_riemann_piece_height(J, upper_riemann_piece_height(I, J, f)):
                    upper_riemann_piece_height(I, J, f) = 0
                case $has_nonempty_upper_riemann_piece_height(I, J, f, upper_riemann_piece_height(I, J, f)):
                    $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)
            by cases:
                ? lower_riemann_piece_height(I, J, f) = 0
                case $has_empty_lower_riemann_piece_height(J, lower_riemann_piece_height(I, J, f)):
                    lower_riemann_piece_height(I, J, f) = 0
                case $has_nonempty_lower_riemann_piece_height(I, J, f, lower_riemann_piece_height(I, J, f)):
                    $is_nonempty_set(J)
                    impossible $is_nonempty_set(J)
            upper_riemann_piece_height(I, J, f) - lower_riemann_piece_height(I, J, f) = 0
            epsilon > 0
            upper_riemann_piece_height(I, J, f) - lower_riemann_piece_height(I, J, f) <= epsilon

thm small_oscillation_partition_step_integral_gap:
    ? forall I power_set(R), P finite_set, f fn(x I) R, U, L R, delta R_pos:
        $is_small_oscillation_partition(I, P, f, delta)
        $chap9::is_bounded_function_on(I, f)
        $has_upper_riemann_sum(I, P, f, U)
        $has_lower_riemann_sum(I, P, f, L)
        =>:
            U - L <= delta * interval_length(I)
    $is_partition_of_bounded_interval(I, P)
    by thm partition_is_set_of_real_subsets(I, P)
    P $in power_set(power_set(R))
    by thm upper_riemann_partition_step_function_has_integral_equal_upper_riemann_sum(I, P, f, U)
    by thm lower_riemann_partition_step_function_has_integral_equal_lower_riemann_sum(I, P, f, L)
    $has_piecewise_constant_integral_with_partition(I, P, upper_riemann_partition_step_function(I, P, f), U)
    $has_piecewise_constant_integral_with_partition(I, P, lower_riemann_partition_step_function(I, P, f), L)
    claim:
        ? $has_piecewise_constant_integral_with_partition(I, {I}, fn(x I) R {delta}, delta * interval_length(I))
        by thm constant_function_is_piecewise_constant_with_one_piece_partition(I, delta)
        claim:
            ? $has_constant_value_on_subset(I, I, fn(x I) R {delta}, delta)
            I $subset I
            forall x I:
                fn(x I) R {delta}(x) = delta
        claim:
            ? $has_piecewise_constant_integral_piece_contribution(I, I, fn(x I) R {delta}, delta * interval_length(I))
            witness exist c0 R st {$has_constant_value_on_subset(I, I, fn(x I) R {delta}, c0), delta * interval_length(I) = c0 * interval_length(I)} from delta:
                $has_constant_value_on_subset(I, I, fn(x I) R {delta}, delta)
                delta * interval_length(I) = delta * interval_length(I)
        by thm one_piece_piecewise_constant_integral_with_partition_value(I, fn(x I) R {delta}, delta * interval_length(I))
        $has_piecewise_constant_integral_with_partition(I, {I}, fn(x I) R {delta}, delta * interval_length(I))
    claim:
        ? $is_finer_partition_than(I, P, {I})
        by thm one_piece_partition_of_bounded_interval(I)
        claim:
            ? forall J P:
                exist K {I} st {J $in power_set(R), K $in power_set(R), J $subset K}
            J $in power_set(R)
            J $subset I
            witness exist K {I} st {J $in power_set(R), K $in power_set(R), J $subset K} from I:
                I $in power_set(R)
                J $subset I
        $is_finer_partition_than(I, P, {I})
    by thm piecewise_constant_integral_transports_to_finer_partition(I, {I}, P, fn(x I) R {delta}, delta * interval_length(I))
    $has_piecewise_constant_integral_with_partition(I, P, fn(x I) R {delta}, delta * interval_length(I))
    by thm piecewise_constant_integral_with_same_partition_add(I, P, lower_riemann_partition_step_function(I, P, f), fn(x I) R {delta}, L, delta * interval_length(I))
    $has_piecewise_constant_integral_with_partition(I, P, fn(x I) R {lower_riemann_partition_step_function(I, P, f)(x) + delta}, L + delta * interval_length(I))
    claim:
        ? forall x I:
            upper_riemann_partition_step_function(I, P, f)(x) <= lower_riemann_partition_step_function(I, P, f)(x) + delta
        have J power_set(R) = partition_piece_containing(I, P, x)
        by thm partition_piece_containing_has_value(I, P, x)
        J $in P
        J $in power_set(R)
        J $subset I
        $has_partition_piece_oscillation_at_most(I, J, f, delta)
        by thm riemann_piece_height_gap_bounded_by_oscillation(I, J, f, delta)
        upper_riemann_piece_height(I, J, f) - lower_riemann_piece_height(I, J, f) <= delta
        (upper_riemann_piece_height(I, J, f) - lower_riemann_piece_height(I, J, f)) + lower_riemann_piece_height(I, J, f) <= delta + lower_riemann_piece_height(I, J, f)
        (upper_riemann_piece_height(I, J, f) - lower_riemann_piece_height(I, J, f)) + lower_riemann_piece_height(I, J, f) = upper_riemann_piece_height(I, J, f)
        delta + lower_riemann_piece_height(I, J, f) = lower_riemann_piece_height(I, J, f) + delta
        upper_riemann_piece_height(I, J, f) <= lower_riemann_piece_height(I, J, f) + delta
        by thm upper_riemann_partition_step_function_has_value(I, P, f, x)
        by thm lower_riemann_partition_step_function_has_value(I, P, f, x)
        upper_riemann_partition_step_function(I, P, f)(x) = upper_riemann_piece_height(I, J, f)
        lower_riemann_partition_step_function(I, P, f)(x) = lower_riemann_piece_height(I, J, f)
        lower_riemann_piece_height(I, J, f) + delta = lower_riemann_partition_step_function(I, P, f)(x) + delta
        upper_riemann_partition_step_function(I, P, f)(x) = upper_riemann_piece_height(I, J, f) <= lower_riemann_piece_height(I, J, f) + delta = lower_riemann_partition_step_function(I, P, f)(x) + delta
    by thm piecewise_constant_integral_with_same_partition_monotone(I, P, fn(x I) R {lower_riemann_partition_step_function(I, P, f)(x) + delta}, upper_riemann_partition_step_function(I, P, f), L + delta * interval_length(I), U)
    U <= L + delta * interval_length(I)
    U - L <= (L + delta * interval_length(I)) - L
    (L + delta * interval_length(I)) - L = delta * interval_length(I)
    U - L <= delta * interval_length(I)

thm uniformly_continuous_on_bounded_interval_is_bounded:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_uniformly_continuous_on(I, f)
        =>:
            $chap9::is_bounded_function_on(I, f)
    # Source handling: Chapter 9 proves the bounded-image result for every
    # bounded subset; take that subset to be the whole interval.
    by thm bounded_intervals_are_bounded_connected(I)
    $chap9::is_bounded_real_set(I)
    by thm chap9::uniformly_continuous_maps_bounded_sets_to_bounded_sets(I, f, I)
    $chap9::function_image_of_subset_is_bounded(I, f, I)
    obtain M from exist M R_pos st {$chap9::is_subset_image_bounded_by(I, f, I, M)}
    witness exist M0 R_pos st {$chap9::is_function_bounded_by(I, f, M0)} from M:
        I $subset I
        forall x I:
            abs(f(x)) <= M
        $chap9::is_function_bounded_by(I, f, M)
    $chap9::is_bounded_function_on(I, f)

thm uniformly_continuous_on_bounded_interval_has_small_oscillation_partitions:
    ? forall I power_set(R), f fn(x I) R, epsilon R_pos:
        $is_bounded_interval(I)
        $chap9::is_uniformly_continuous_on(I, f)
        =>:
            $has_small_oscillation_partition(I, f, epsilon)
    # Source handling: the proof of Theorem 11.5.1 chooses `delta`, asks for a
    # sufficiently fine finite partition, and leaves the endpoint-form
    # construction as a "How?" step.  The trust keeps that source gap visible.
    # proof_debt: construct the equal-length finite partition and prove the
    # piecewise diameter estimate in all endpoint conventions.
    trust $has_small_oscillation_partition(I, f, epsilon)

thm darbouxs_criterion_from_small_oscillation_partitions:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_bounded_function_on(I, f)
        forall epsilon R_pos:
            $has_small_oscillation_partition(I, f, epsilon)
        =>:
            $is_riemann_integrable_on(I, f)
    # For target error `epsilon`, use piece oscillation
    # `delta = epsilon / (interval_length(I) + 1)`.  The canonical upper and
    # lower partition step functions are then a Darboux approximation whose
    # integral gap is strictly below `epsilon`.
    claim:
        ? forall epsilon R_pos:
            exist h, g fn(x I) R, sh, sg R st {$has_darboux_approximation(I, f, h, g, sh, sg, epsilon)}
        by thm interval_length_nonnegative(I)
        interval_length(I) >= 0
        interval_length(I) + 1 > 0
        epsilon / (interval_length(I) + 1) > 0
        have delta R_pos = epsilon / (interval_length(I) + 1)
        obtain P from exist P finite_set st {$is_small_oscillation_partition(I, P, f, delta)}
        $is_partition_of_bounded_interval(I, P)
        by thm partition_is_set_of_real_subsets(I, P)
        P $in power_set(power_set(R))
        by thm upper_riemann_sum_has_value(I, P, f)
        by thm lower_riemann_sum_has_value(I, P, f)
        have U R = upper_riemann_sum(I, P, f)
        have L R = lower_riemann_sum(I, P, f)
        $has_upper_riemann_sum(I, P, f, U)
        $has_lower_riemann_sum(I, P, f, L)
        by thm small_oscillation_partition_step_integral_gap(I, P, f, U, L, delta)
        U - L <= delta * interval_length(I)
        delta = epsilon / (interval_length(I) + 1)
        interval_length(I) < interval_length(I) + 1
        epsilon / (interval_length(I) + 1) * interval_length(I) < epsilon / (interval_length(I) + 1) * (interval_length(I) + 1)
        epsilon / (interval_length(I) + 1) * (interval_length(I) + 1) = epsilon
        delta * interval_length(I) < epsilon
        U - L < epsilon

        by thm upper_riemann_partition_step_function_is_piecewise_constant(I, P, f)
        by thm lower_riemann_partition_step_function_is_piecewise_constant(I, P, f)
        by thm piecewise_constant_with_partition_is_piecewise_constant(I, P, upper_riemann_partition_step_function(I, P, f))
        by thm piecewise_constant_with_partition_is_piecewise_constant(I, P, lower_riemann_partition_step_function(I, P, f))
        $is_piecewise_constant_on(I, upper_riemann_partition_step_function(I, P, f))
        $is_piecewise_constant_on(I, lower_riemann_partition_step_function(I, P, f))
        by thm upper_riemann_partition_step_function_majorizes(I, P, f)
        by thm lower_riemann_partition_step_function_minorizes(I, P, f)
        by thm upper_riemann_partition_step_function_has_integral_equal_upper_riemann_sum(I, P, f, U)
        by thm lower_riemann_partition_step_function_has_integral_equal_lower_riemann_sum(I, P, f, L)
        claim:
            ? $has_piecewise_constant_integral(I, upper_riemann_partition_step_function(I, P, f), U)
            witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, upper_riemann_partition_step_function(I, P, f)), $has_piecewise_constant_integral_with_partition(I, P0, upper_riemann_partition_step_function(I, P, f), U)} from P:
                $is_piecewise_constant_with_partition(I, P, upper_riemann_partition_step_function(I, P, f))
                $has_piecewise_constant_integral_with_partition(I, P, upper_riemann_partition_step_function(I, P, f), U)
        claim:
            ? $has_piecewise_constant_integral(I, lower_riemann_partition_step_function(I, P, f), L)
            witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, lower_riemann_partition_step_function(I, P, f)), $has_piecewise_constant_integral_with_partition(I, P0, lower_riemann_partition_step_function(I, P, f), L)} from P:
                $is_piecewise_constant_with_partition(I, P, lower_riemann_partition_step_function(I, P, f))
                $has_piecewise_constant_integral_with_partition(I, P, lower_riemann_partition_step_function(I, P, f), L)
        witness exist h, g fn(x I) R, sh, sg R st {$has_darboux_approximation(I, f, h, g, sh, sg, epsilon)} from lower_riemann_partition_step_function(I, P, f), upper_riemann_partition_step_function(I, P, f), L, U:
            $is_piecewise_constant_on(I, lower_riemann_partition_step_function(I, P, f))
            $is_piecewise_constant_on(I, upper_riemann_partition_step_function(I, P, f))
            $minorizes_on(I, lower_riemann_partition_step_function(I, P, f), f)
            $majorizes_on(I, upper_riemann_partition_step_function(I, P, f), f)
            $has_piecewise_constant_integral(I, lower_riemann_partition_step_function(I, P, f), L)
            $has_piecewise_constant_integral(I, upper_riemann_partition_step_function(I, P, f), U)
            U - L < epsilon
            $has_darboux_approximation(I, f, lower_riemann_partition_step_function(I, P, f), upper_riemann_partition_step_function(I, P, f), L, U, epsilon)
    by thm arbitrary_darboux_approximations_imply_riemann_integrable(I, f)
    $is_riemann_integrable_on(I, f)

thm uniformly_continuous_bounded_interval_riemann_integrable:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_uniformly_continuous_on(I, f)
        =>:
            $is_riemann_integrable_on(I, f)
    # Source handling: Tao partitions the interval into small equal-length
    # pieces, uses uniform continuity to make each oscillation small, and then
    # applies finite additivity of length.
    by thm uniformly_continuous_on_bounded_interval_is_bounded(I, f)
    $chap9::is_bounded_function_on(I, f)
    claim:
        ? forall epsilon R_pos:
            $has_small_oscillation_partition(I, f, epsilon)
        by thm uniformly_continuous_on_bounded_interval_has_small_oscillation_partitions(I, f, epsilon)
    by thm darbouxs_criterion_from_small_oscillation_partitions(I, f)
    $is_riemann_integrable_on(I, f)

"""
Corollary 11.5.2.  A continuous function on a closed interval `[a,b]` is
Riemann integrable.
"""

thm continuous_closed_interval_uniformly_continuous:
    ? forall a, b R, f fn(x '[a, b]) R:
        a < b
        $chap9::is_continuous_on('[a, b], f)
        =>:
            $chap9::is_uniformly_continuous_on('[a, b], f)
    # Source handling: this is Theorem 9.9.16, retained locally so the
    # Chapter 11 proof follows the source sequence without duplicating its
    # compactness argument.
    by thm chap9::continuous_closed_interval_uniformly_continuous(a, b, f)
    $chap9::is_uniformly_continuous_on('[a, b], f)

thm continuous_closed_interval_riemann_integrable:
    ? forall a, b R, f fn(x '[a, b]) R:
        a < b
        $chap9::is_continuous_on('[a, b], f)
        =>:
            $is_riemann_integrable_on('[a, b], f)
    # Source handling: Tao combines Theorem 11.5.1 with Theorem 9.9.16, the
    # uniform-continuity theorem for continuous functions on closed bounded
    # intervals.
    by thm non_degenerate_interval_forms_are_bounded_intervals(a, b)
    $is_bounded_interval('[a, b])
    by thm chap9::continuous_closed_interval_uniformly_continuous(a, b, f)
    $chap9::is_uniformly_continuous_on('[a, b], f)
    by thm uniformly_continuous_bounded_interval_riemann_integrable('[a, b], f)
    $is_riemann_integrable_on('[a, b], f)

"""
Proposition 11.5.3.  A continuous and bounded function on any bounded interval
is Riemann integrable.
"""

# Domain bridge/proof package for Tao's endpoint-trimming proof: the closed
# core is integrated by Corollary 11.5.2, while the omitted tails are controlled
# by boundedness.
prop is_closed_interval_trim_with_tail_length_at_most(I power_set(R), J power_set(R), eta R_pos):
    $is_bounded_interval(I)
    J $subset I
    $is_bounded_interval(J)
    exist a, b R st {a < b, J = '[a, b]}
    interval_length(I) - interval_length(J) <= eta

prop has_integrable_closed_interval_trim(I power_set(R), f fn(x I) R, eta R_pos):
    exist J power_set(R) st {J $subset I, $is_closed_interval_trim_with_tail_length_at_most(I, J, eta), $is_riemann_integrable_on(J, fn(x J) R {f(x)})}

thm continuous_bounded_interval_has_integrable_closed_trims:
    ? forall I power_set(R), f fn(x I) R, eta R_pos:
        $is_bounded_interval(I)
        $chap9::is_continuous_on(I, f)
        =>:
            $has_integrable_closed_interval_trim(I, f, eta)
    # Source handling: Proposition 11.5.3 gives the closed-trim argument but
    # compresses the endpoint choices and their restriction properties.  The
    # trust keeps precisely that unexpanded source step visible.
    # proof_debt: construct the endpoint trim for all four endpoint
    # conventions and prove the restricted function is continuous.
    trust $has_integrable_closed_interval_trim(I, f, eta)

thm darbouxs_criterion_from_integrable_closed_trims_and_bounded_tails:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_bounded_function_on(I, f)
        forall eta R_pos:
            $has_integrable_closed_interval_trim(I, f, eta)
        =>:
            $is_riemann_integrable_on(I, f)
    # Source handling: Proposition 11.5.3 gives the endpoint-tail estimate but
    # does not expand the Darboux gluing calculation for all interval forms.
    # The trust keeps precisely that compressed source step visible.
    # proof_debt: compare the upper/lower Darboux sums after adjoining the
    # finitely many tail pieces and bound their contribution by `M * eta`.
    trust $is_riemann_integrable_on(I, f)

thm bounded_continuous_bounded_interval_riemann_integrable:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_continuous_on(I, f)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $is_riemann_integrable_on(I, f)
    # Source handling: Tao trims an open or half-open interval to a closed
    # subinterval, applies Corollary 11.5.2 there, and controls the two short
    # tails by boundedness.
    claim:
        ? forall eta R_pos:
            $has_integrable_closed_interval_trim(I, f, eta)
        by thm continuous_bounded_interval_has_integrable_closed_trims(I, f, eta)
    by thm darbouxs_criterion_from_integrable_closed_trims_and_bounded_tails(I, f)
    $is_riemann_integrable_on(I, f)

"""
Definition 11.5.4.  A function is piecewise continuous if some partition makes
each restriction to a piece continuous.
"""

prop is_piecewise_continuous_with_partition(I power_set(R), P finite_set, f fn(x I) R):
    $is_partition_of_bounded_interval(I, P)
    forall J P:
        J $in power_set(R)
        J $subset I
        =>:
            $chap9::is_continuous_on(J, fn(x J) R {f(x)})

prop is_piecewise_continuous_on(I power_set(R), f fn(x I) R):
    exist P finite_set st {$is_piecewise_continuous_with_partition(I, P, f)}

thm piecewise_continuous_with_partition_is_piecewise_continuous:
    ? forall I power_set(R), P finite_set, f fn(x I) R:
        $is_piecewise_continuous_with_partition(I, P, f)
        =>:
            $is_piecewise_continuous_on(I, f)
    # Source handling: this is Definition 11.5.4 with the displayed partition
    # as witness.
    witness exist P0 finite_set st {$is_piecewise_continuous_with_partition(I, P0, f)} from P:
        $is_piecewise_continuous_with_partition(I, P, f)
    $is_piecewise_continuous_on(I, f)

"""
Example 11.5.5.  A function on `[1,3]` equal to `x^2` on `[1,2)`, `7` at
`2`, and `x^3` on `(2,3]` is not continuous globally but is continuous on the
three partition pieces.
"""

have fn example_11_5_5_function(x '[1, 3]) R by cases:
    case x < 2: x^2
    case x = 2: 7
    case x > 2: x^3

thm example_11_5_5_not_continuous_on_closed_interval:
    ? forall:
        not $chap9::is_continuous_on('[1, 3], example_11_5_5_function)
    # Source handling: the left-hand values approach `4` at `2`, while the
    # function value is `7`.  Given the continuity radius `delta`, take a
    # point `2 - finite_set_min(union({delta / 2}, { 1 / 2}))` in the left-hand piece.  Its value
    # stays at least `3` away from `7`, contradicting epsilon `1`.
    by contra:
        ? not $chap9::is_continuous_on('[1, 3], example_11_5_5_function)
        $chap9::is_continuous_on('[1, 3], example_11_5_5_function)
        2 $in '[1, 3]
        $chap9::is_continuous_at('[1, 3], example_11_5_5_function, 2)
        example_11_5_5_function(2) = 7
        $chap9::has_function_limit('[1, 3], example_11_5_5_function, 2, 7)
        1 $in R_pos
        $chap9::is_locally_epsilon_close_to('[1, 3], example_11_5_5_function, 2, 7, 1)
        obtain delta from exist delta R_pos st {$chap9::is_delta_neighborhood_close_to('[1, 3], example_11_5_5_function, 2, 7, 1, delta)}
        have h R_pos = finite_set_min(union({delta / 2}, { 1 / 2}))
        finite_set_min(union({delta / 2}, { 1 / 2})) <= 1 / 2
        h = finite_set_min(union({delta / 2}, { 1 / 2}))
        h <= 1 / 2
        -1 * h >= -1 * (1 / 2)
        2 + (-1 * h) >= 2 + (-1 * (1 / 2))
        2 - h = 2 + (-1 * h)
        2 + (-1 * (1 / 2)) = 3 / 2
        2 - h >= 3 / 2
        3 / 2 >= 1
        2 - h >= 3 / 2 >= 1
        2 - h >= 1
        2 - h <= 2
        2 - h <= 3
        2 - h $in '[1, 3]
        finite_set_min(union({delta / 2}, { 1 / 2})) <= delta / 2
        h <= delta / 2
        delta / 2 < delta
        h <= delta / 2 < delta
        (2 - h) - 2 = -h
        abs((2 - h) - 2) = abs(-h)
        abs(-h) = abs(h)
        abs(h) = h
        abs(-h) = h
        abs((2 - h) - 2) = h
        abs((2 - h) - 2) < delta
        abs(example_11_5_5_function(2 - h) - 7) <= 1
        h > 0
        2 - h < 2
        example_11_5_5_function(2 - h) = (2 - h)^2
        abs(example_11_5_5_function(2 - h) - 7) = abs((2 - h)^2 - 7)
        (2 - h)^2 <= 2^2
        2^2 = 4
        (2 - h)^2 <= 4
        (2 - h)^2 - 7 <= 4 - 7
        (2 - h)^2 - 7 <= -3
        -1 * ((2 - h)^2 - 7) >= -1 * (-3)
        -1 * (-3) = 3
        -((2 - h)^2 - 7) = -1 * ((2 - h)^2 - 7)
        -((2 - h)^2 - 7) >= 3
        abs((2 - h)^2 - 7) = -((2 - h)^2 - 7)
        abs((2 - h)^2 - 7) >= 3
        3 <= abs((2 - h)^2 - 7) <= 1
        3 <= 1
        impossible 3 <= 1

thm example_11_5_5_partition_pieces_are_distinct:
    ? forall:
        '[1, 2) != {2}
        '[1, 2) != '(2, 3]
        {2} != '(2, 3]
    # Source handling: these endpoint checks let Litex treat the displayed
    # three pieces as a concrete finite partition.
    by contra:
        ? '[1, 2) != {2}
        '[1, 2) = {2}
        1 $in '[1, 2)
        1 $in {2}
        1 = 2
        impossible 1 = 2
    by contra:
        ? '[1, 2) != '(2, 3]
        '[1, 2) = '(2, 3]
        1 $in '[1, 2)
        1 $in '(2, 3]
        2 < 1
        impossible 2 < 1
    by contra:
        ? {2} != '(2, 3]
        {2} = '(2, 3]
        2 $in {2}
        2 $in '(2, 3]
        2 < 2
        impossible 2 < 2

by thm example_11_5_5_partition_pieces_are_distinct()

have example_11_5_5_partition_set finite_set = {'[1, 2), {2}, '(2, 3]}

thm example_11_5_5_partition_piece_clauses:
    ? forall J example_11_5_5_partition_set:
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset '[1, 3]
    # Source handling: this is the displayed three-piece partition in Example
    # 11.5.5.
    by enumerate finite_set:
        ? forall K example_11_5_5_partition_set:
            K = '[1, 2) or K = {2} or K = '(2, 3]
    by cases:
        ? J $in power_set(R)
        ? $is_bounded_interval(J)
        ? J $subset '[1, 3]
        case J = '[1, 2):
            by thm non_degenerate_interval_forms_are_bounded_intervals(1, 2)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 3]
                forall x J:
                    x $in '[1, 2)
                    1 <= x
                    x < 2
                    x < 2 < 3
                    x < 3
                    x <= 3
                    x $in '[1, 3]
                J $subset '[1, 3]
        case J = {2}:
            by thm singleton_interval_is_bounded(2)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 3]
                forall x J:
                    x = 2
                    1 <= x
                    x <= 3
                    x $in '[1, 3]
                J $subset '[1, 3]
        case J = '(2, 3]:
            by thm non_degenerate_interval_forms_are_bounded_intervals(2, 3)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 3]
                forall x J:
                    x $in '(2, 3]
                    2 < x
                    x <= 3
                    1 < 2 < x
                    1 < x
                    1 <= x
                    x $in '[1, 3]
                J $subset '[1, 3]

thm example_11_5_5_partition_pieces_have_unique_membership:
    ? forall x '[1, 3], J1, J2 example_11_5_5_partition_set:
        J1 $in power_set(R)
        J2 $in power_set(R)
        x $in J1
        x $in J2
        =>:
            J1 = J2
    # Enumerate the three displayed pieces and prove their pointwise
    # disjointness explicitly instead.
    by enumerate finite_set:
        ? forall J example_11_5_5_partition_set:
            J = '[1, 2) or J = {2} or J = '(2, 3]
    by cases:
        ? J1 = J2
        case J1 = '[1, 2):
            by cases:
                ? J1 = J2
                case J2 = '[1, 2):
                    J1 = '[1, 2)
                    J2 = '[1, 2)
                    J1 = J2
                case J2 = {2}:
                    x $in J1
                    x $in J2
                    x < 2
                    x = 2
                    impossible 2 < 2
                case J2 = '(2, 3]:
                    x $in J1
                    x $in J2
                    x < 2
                    x > 2
                    impossible 2 < 2
        case J1 = {2}:
            by cases:
                ? J1 = J2
                case J2 = '[1, 2):
                    x $in J1
                    x $in J2
                    x = 2
                    x < 2
                    impossible 2 < 2
                case J2 = {2}:
                    J1 = {2}
                    J2 = {2}
                    J1 = J2
                case J2 = '(2, 3]:
                    x $in J1
                    x $in J2
                    x = 2
                    x > 2
                    impossible 2 < 2
        case J1 = '(2, 3]:
            by cases:
                ? J1 = J2
                case J2 = '[1, 2):
                    x $in J1
                    x $in J2
                    x > 2
                    x < 2
                    impossible 2 < 2
                case J2 = {2}:
                    x $in J1
                    x $in J2
                    x > 2
                    x = 2
                    impossible 2 < 2
                case J2 = '(2, 3]:
                    J1 = '(2, 3]
                    J2 = '(2, 3]
                    J1 = J2

thm example_11_5_5_partition_unique_cover:
    ? forall x '[1, 3]:
        exist! J example_11_5_5_partition_set st {J $in power_set(R), x $in J}
    claim:
        ? forall y '[1, 3]:
            exist J example_11_5_5_partition_set st {J $in power_set(R), y $in J}
        by cases:
            ? exist J example_11_5_5_partition_set st {J $in power_set(R), y $in J}
            case y < 2:
                claim:
                    ? '[1, 2) $in example_11_5_5_partition_set
                    '[1, 2) $in {'[1, 2), {2}, '(2, 3]}
                    example_11_5_5_partition_set = {'[1, 2), {2}, '(2, 3]}
                    '[1, 2) $in example_11_5_5_partition_set
                witness exist J example_11_5_5_partition_set st {J $in power_set(R), y $in J} from '[1, 2):
                    '[1, 2) $in example_11_5_5_partition_set
                    '[1, 2) $in power_set(R)
                    y $in '[1, 2)
            case y = 2:
                claim:
                    ? {2} $in example_11_5_5_partition_set
                    {2} $in {'[1, 2), {2}, '(2, 3]}
                    example_11_5_5_partition_set = {'[1, 2), {2}, '(2, 3]}
                    {2} $in example_11_5_5_partition_set
                witness exist J example_11_5_5_partition_set st {J $in power_set(R), y $in J} from {2}:
                    {2} $in example_11_5_5_partition_set
                    {2} $in power_set(R)
                    y $in {2}
            case y > 2:
                claim:
                    ? '(2, 3] $in example_11_5_5_partition_set
                    '(2, 3] $in {'[1, 2), {2}, '(2, 3]}
                    example_11_5_5_partition_set = {'[1, 2), {2}, '(2, 3]}
                    '(2, 3] $in example_11_5_5_partition_set
                witness exist J example_11_5_5_partition_set st {J $in power_set(R), y $in J} from '(2, 3]:
                    '(2, 3] $in example_11_5_5_partition_set
                    '(2, 3] $in power_set(R)
                    y $in '(2, 3]
    claim:
        ? forall y '[1, 3], J1, J2 example_11_5_5_partition_set:
            J1 $in power_set(R)
            J2 $in power_set(R)
            y $in J1
            y $in J2
            =>:
                J1 = J2
        by thm example_11_5_5_partition_pieces_have_unique_membership(y, J1, J2)
    forall y '[1, 3]:
        exist! J example_11_5_5_partition_set st {J $in power_set(R), y $in J}

thm example_11_5_5_displayed_partition:
    ? forall:
        $is_partition_of_bounded_interval('[1, 3], example_11_5_5_partition_set)
    by thm non_degenerate_interval_forms_are_bounded_intervals(1, 3)
    claim:
        ? forall J example_11_5_5_partition_set:
            J $in power_set(R)
            $is_bounded_interval(J)
            J $subset '[1, 3]
        by thm example_11_5_5_partition_piece_clauses(J)
    claim:
        ? forall x '[1, 3]:
            exist! J example_11_5_5_partition_set st {J $in power_set(R), x $in J}
        by thm example_11_5_5_partition_unique_cover(x)
    $is_partition_of_bounded_interval('[1, 3], example_11_5_5_partition_set)

thm example_11_5_5_square_piece_continuous:
    ? forall:
        '[1, 2) $subset '[1, 3]
        =>:
            $chap9::is_continuous_on('[1, 2), fn(x '[1, 2)) R {example_11_5_5_function(x)})
    # Source handling: on `[1,2)` the displayed function agrees with the
    # polynomial `x^2`, and the arithmetic continuity rules apply on the
    # restricted domain.
    by thm chap9::identity_function_continuous('[1, 2))
    $chap9::is_continuous_on('[1, 2), fn(x '[1, 2)) R {x})
    by thm chap9::continuity_closed_under_arithmetic('[1, 2), fn(x '[1, 2)) R {x}, fn(x '[1, 2)) R {x})
    $chap9::is_continuous_on('[1, 2), fn(x '[1, 2)) R {x * x})
    fn(x '[1, 2)) R {x * x} = fn(x '[1, 2)) R {x^2}
    $chap9::is_continuous_on('[1, 2), fn(x '[1, 2)) R {x^2})
    claim:
        ? forall x '[1, 2):
            fn(x '[1, 2)) R {example_11_5_5_function(x)}(x) = fn(x '[1, 2)) R {x^2}(x)
        x < 2
        example_11_5_5_function(x) = x^2
        fn(x '[1, 2)) R {example_11_5_5_function(x)}(x) = example_11_5_5_function(x)
        fn(x '[1, 2)) R {x^2}(x) = x^2
        fn(x '[1, 2)) R {example_11_5_5_function(x)}(x) = fn(x '[1, 2)) R {x^2}(x)
    fn(x '[1, 2)) R {example_11_5_5_function(x)} = fn(x '[1, 2)) R {x^2}
    $chap9::is_continuous_on('[1, 2), fn(x '[1, 2)) R {example_11_5_5_function(x)})

thm example_11_5_5_singleton_piece_continuous:
    ? forall:
        {2} $subset '[1, 3]
        =>:
            $chap9::is_continuous_on({2}, fn(x {2}) R {example_11_5_5_function(x)})
    # Source handling: the restriction to `{2}` is the constant function with
    # value `7`, so it is continuous by the constant-function proof.
    by thm chap9::constant_function_continuous({2}, 7)
    $chap9::is_continuous_on({2}, fn(x {2}) R {7})
    claim:
        ? forall x {2}:
            fn(x {2}) R {example_11_5_5_function(x)}(x) = fn(x {2}) R {7}(x)
        x = 2
        example_11_5_5_function(x) = 7
        fn(x {2}) R {example_11_5_5_function(x)}(x) = example_11_5_5_function(x)
        fn(x {2}) R {7}(x) = 7
        fn(x {2}) R {example_11_5_5_function(x)}(x) = fn(x {2}) R {7}(x)
    fn(x {2}) R {example_11_5_5_function(x)} = fn(x {2}) R {7}
    $chap9::is_continuous_on({2}, fn(x {2}) R {example_11_5_5_function(x)})

thm example_11_5_5_cube_piece_continuous:
    ? forall:
        '(2, 3] $subset '[1, 3]
        =>:
            $chap9::is_continuous_on('(2, 3], fn(x '(2, 3]) R {example_11_5_5_function(x)})
    # Source handling: on `(2,3]` the displayed function agrees with the
    # polynomial `x^3`, and the arithmetic continuity rules apply on the
    # restricted domain.
    by thm chap9::identity_function_continuous('(2, 3])
    $chap9::is_continuous_on('(2, 3], fn(x '(2, 3]) R {x})
    by thm chap9::continuity_closed_under_arithmetic('(2, 3], fn(x '(2, 3]) R {x}, fn(x '(2, 3]) R {x})
    $chap9::is_continuous_on('(2, 3], fn(x '(2, 3]) R {x * x})
    fn(x '(2, 3]) R {x * x} = fn(x '(2, 3]) R {x^2}
    $chap9::is_continuous_on('(2, 3], fn(x '(2, 3]) R {x^2})
    by thm chap9::continuity_closed_under_arithmetic('(2, 3], fn(x '(2, 3]) R {x^2}, fn(x '(2, 3]) R {x})
    $chap9::is_continuous_on('(2, 3], fn(x '(2, 3]) R {x^2 * x})
    fn(x '(2, 3]) R {x^2 * x} = fn(x '(2, 3]) R {x^3}
    $chap9::is_continuous_on('(2, 3], fn(x '(2, 3]) R {x^3})
    claim:
        ? forall x '(2, 3]:
            fn(x '(2, 3]) R {example_11_5_5_function(x)}(x) = fn(x '(2, 3]) R {x^3}(x)
        x > 2
        example_11_5_5_function(x) = x^3
        fn(x '(2, 3]) R {example_11_5_5_function(x)}(x) = example_11_5_5_function(x)
        fn(x '(2, 3]) R {x^3}(x) = x^3
        fn(x '(2, 3]) R {example_11_5_5_function(x)}(x) = fn(x '(2, 3]) R {x^3}(x)
    fn(x '(2, 3]) R {example_11_5_5_function(x)} = fn(x '(2, 3]) R {x^3}
    $chap9::is_continuous_on('(2, 3], fn(x '(2, 3]) R {example_11_5_5_function(x)})

thm example_11_5_5_partition_piece_continuity:
    ? forall J example_11_5_5_partition_set:
        J $in power_set(R)
        J $subset '[1, 3]
        =>:
            $chap9::is_continuous_on(J, fn(x J) R {example_11_5_5_function(x)})
    # Source handling: the three concrete continuity facts above handle
    # `[1,2)`, `{2}`, and `(2,3]` after enumerating the displayed partition.
    by enumerate finite_set:
        ? forall K example_11_5_5_partition_set:
            K = '[1, 2) or K = {2} or K = '(2, 3]
    claim:
        ? forall x J:
            x $in '[1, 3]
        x $in J
        J $subset '[1, 3]
        x $in '[1, 3]
    by cases:
        ? $chap9::is_continuous_on(J, fn(x J) R {example_11_5_5_function(x)})
        case J = '[1, 2):
            by thm example_11_5_5_square_piece_continuous()
            fn(x J) R {example_11_5_5_function(x)} = fn(x '[1, 2)) R {example_11_5_5_function(x)}
            $chap9::is_continuous_on(J, fn(x J) R {example_11_5_5_function(x)})
        case J = {2}:
            by thm example_11_5_5_singleton_piece_continuous()
            fn(x J) R {example_11_5_5_function(x)} = fn(x {2}) R {example_11_5_5_function(x)}
            $chap9::is_continuous_on(J, fn(x J) R {example_11_5_5_function(x)})
        case J = '(2, 3]:
            by thm example_11_5_5_cube_piece_continuous()
            fn(x J) R {example_11_5_5_function(x)} = fn(x '(2, 3]) R {example_11_5_5_function(x)}
            $chap9::is_continuous_on(J, fn(x J) R {example_11_5_5_function(x)})

thm example_11_5_5_piecewise_continuous_with_displayed_partition:
    ? forall:
        $is_piecewise_continuous_with_partition('[1, 3], example_11_5_5_partition_set, example_11_5_5_function)
    # Source handling: the displayed partition isolates the polynomial pieces
    # and the isolated jump value at `2`.
    by thm example_11_5_5_displayed_partition()
    claim:
        ? forall J example_11_5_5_partition_set:
            J $in power_set(R)
            J $subset '[1, 3]
            =>:
                $chap9::is_continuous_on(J, fn(x J) R {example_11_5_5_function(x)})
        by thm example_11_5_5_partition_piece_continuity(J)
        $chap9::is_continuous_on(J, fn(x J) R {example_11_5_5_function(x)})
    $is_piecewise_continuous_with_partition('[1, 3], example_11_5_5_partition_set, example_11_5_5_function)

thm example_11_5_5_piecewise_continuous:
    ? forall:
        $is_piecewise_continuous_on('[1, 3], example_11_5_5_function)
    by thm example_11_5_5_piecewise_continuous_with_displayed_partition()
    by thm piecewise_continuous_with_partition_is_piecewise_continuous('[1, 3], example_11_5_5_partition_set, example_11_5_5_function)

"""
Proposition 11.5.6.  A bounded piecewise continuous function on a bounded
interval is Riemann integrable.
"""

# Proof package for the finite-partition additivity step used in Exercise
# 11.5.1 and again for piecewise monotone functions in Exercise 11.6.2.
thm riemann_integrable_from_partition_piece_integrability:
    ? forall I power_set(R), P finite_set, f fn(x I) R:
        $is_partition_of_bounded_interval(I, P)
        forall J P:
            J $in power_set(R)
            J $subset I
            $is_riemann_integrable_on(J, fn(x J) R {f(x)})
        =>:
            $is_riemann_integrable_on(I, f)
    # Source handling: Proposition 11.5.6 leaves this finite-gluing proof to
    # Exercise 11.5.1.  The trust records exactly that source-deferred
    # induction rather than presenting the proposition as checked.
    # proof_debt: formalize induction over finite interval partitions and
    # compare the restricted piece integrals with the whole-domain Darboux
    # upper and lower sums.
    trust $is_riemann_integrable_on(I, f)

thm bounded_piecewise_continuous_riemann_integrable:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $is_piecewise_continuous_on(I, f)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $is_riemann_integrable_on(I, f)
    # Source handling: Tao proves this in Exercise 11.5.1 using additivity over
    # partition pieces.
    obtain P from exist P finite_set st {$is_piecewise_continuous_with_partition(I, P, f)}
    obtain M from exist M R_pos st {$chap9::is_function_bounded_by(I, f, M)}
    claim:
        ? forall J P:
            J $in power_set(R)
            J $subset I
            $is_riemann_integrable_on(J, fn(x J) R {f(x)})
        J $in power_set(R)
        J $subset I
        $is_bounded_interval(J)
        $chap9::is_continuous_on(J, fn(x J) R {f(x)})
        claim:
            ? $chap9::is_bounded_function_on(J, fn(x J) R {f(x)})
            claim:
                ? $chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M)
                forall x J:
                    x $in I
                    fn(x J) R {f(x)}(x) = f(x)
                    abs(f(x)) <= M
                    abs(fn(x J) R {f(x)}(x)) <= M
                $chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M)
            witness exist M0 R_pos st {$chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M0)} from M:
                $chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M)
            $chap9::is_bounded_function_on(J, fn(x J) R {f(x)})
        by thm bounded_continuous_bounded_interval_riemann_integrable(J, fn(x J) R {f(x)})
        $is_riemann_integrable_on(J, fn(x J) R {f(x)})
    $is_partition_of_bounded_interval(I, P)
    by thm riemann_integrable_from_partition_piece_integrability(I, P, f)
    $is_riemann_integrable_on(I, f)


# 11.6 Riemann integrability of monotone functions

"""
Proposition 11.6.1.  A monotone function on a closed bounded interval is
Riemann integrable.
"""

thm monotone_closed_interval_riemann_integrable:
    ? forall a, b R, f fn(x '[a, b]) R:
        a < b
        $chap9::is_monotone_on('[a, b], f)
        =>:
            $is_riemann_integrable_on('[a, b], f)
    # Source handling: Proposition 11.6.1 gives the equal-partition and
    # telescoping route, but compresses the partition construction, extrema
    # evaluation, and limiting step.  The trust keeps those source gaps visible.
    # proof_debt: prove boundedness of monotone functions on closed intervals,
    # construct equal partitions, and formalize the telescoping estimate.
    trust $is_riemann_integrable_on('[a, b], f)

"""
Remark 11.6.2.  Some monotone functions are not piecewise continuous, so this
result is not just a corollary of piecewise-continuity integrability.
"""

"""
Corollary 11.6.3.  A bounded monotone function on any bounded interval is
Riemann integrable.
"""

thm bounded_monotone_bounded_interval_riemann_integrable:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_monotone_on(I, f)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $is_riemann_integrable_on(I, f)
    # Source handling: Corollary 11.6.3 leaves this trimming argument to
    # Exercise 11.6.1.  The trust records exactly that source-deferred proof.
    # proof_debt: trim to closed subintervals and control endpoint tails using
    # boundedness.
    trust $is_riemann_integrable_on(I, f)

"""
Exercise 11.6.2.  A function is piecewise monotone if some finite partition of
the interval makes each restricted piece monotone.  A bounded piecewise
monotone function is Riemann integrable by applying Corollary 11.6.3 to each
piece and then adding the finitely many piece integrals.
"""

prop is_piecewise_monotone_with_partition(I power_set(R), P finite_set, f fn(x I) R):
    $is_partition_of_bounded_interval(I, P)
    forall J P:
        J $in power_set(R)
        J $subset I
        $chap9::is_monotone_on(J, fn(x J) R {f(x)})

prop is_piecewise_monotone_on(I power_set(R), f fn(x I) R):
    exist P finite_set st {$is_piecewise_monotone_with_partition(I, P, f)}

thm piecewise_monotone_with_partition_is_piecewise_monotone:
    ? forall I power_set(R), P finite_set, f fn(x I) R:
        $is_piecewise_monotone_with_partition(I, P, f)
        =>:
            $is_piecewise_monotone_on(I, f)
    # Source handling: this is the definition with the displayed partition as
    # witness.
    witness exist P0 finite_set st {$is_piecewise_monotone_with_partition(I, P0, f)} from P:
        $is_piecewise_monotone_with_partition(I, P, f)
    $is_piecewise_monotone_on(I, f)

thm bounded_piecewise_monotone_with_partition_riemann_integrable:
    ? forall I power_set(R), P finite_set, f fn(x I) R:
        $is_bounded_interval(I)
        $is_piecewise_monotone_with_partition(I, P, f)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $is_riemann_integrable_on(I, f)
    # Source handling: the given partition reduces the claim to finitely many
    # bounded monotone restrictions.  Corollary 11.6.3 handles each piece; the
    # preceding partition theorem combines the pieces.
    obtain M from exist M R_pos st {$chap9::is_function_bounded_by(I, f, M)}
    claim:
        ? forall J P:
            J $in power_set(R)
            J $subset I
            $is_riemann_integrable_on(J, fn(x J) R {f(x)})
        J $in power_set(R)
        J $subset I
        $is_bounded_interval(J)
        $chap9::is_monotone_on(J, fn(x J) R {f(x)})
        claim:
            ? $chap9::is_bounded_function_on(J, fn(x J) R {f(x)})
            claim:
                ? $chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M)
                forall x J:
                    x $in I
                    fn(x J) R {f(x)}(x) = f(x)
                    abs(f(x)) <= M
                    abs(fn(x J) R {f(x)}(x)) <= M
                $chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M)
            witness exist M0 R_pos st {$chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M0)} from M:
                $chap9::is_function_bounded_by(J, fn(x J) R {f(x)}, M)
            $chap9::is_bounded_function_on(J, fn(x J) R {f(x)})
        by thm bounded_monotone_bounded_interval_riemann_integrable(J, fn(x J) R {f(x)})
        $is_riemann_integrable_on(J, fn(x J) R {f(x)})
    by thm riemann_integrable_from_partition_piece_integrability(I, P, f)
    $is_riemann_integrable_on(I, f)

thm bounded_piecewise_monotone_riemann_integrable:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $is_piecewise_monotone_on(I, f)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $is_riemann_integrable_on(I, f)
    # Source handling: choose the partition from the definition, prove
    # integrability with that partition, and forget the witness.
    obtain P from exist P finite_set st {$is_piecewise_monotone_with_partition(I, P, f)}
    by thm bounded_piecewise_monotone_with_partition_riemann_integrable(I, P, f)
    $is_riemann_integrable_on(I, f)

prop is_tail_close_to_value(a fn(k N_pos) R, L R, epsilon R_pos, N0 N_pos):
    forall k N_pos:
        k >= N0
        =>:
            abs(a(k) - L) <= epsilon

prop has_sequence_limit_value(a fn(k N_pos) R, L R):
    forall epsilon R_pos:
        exist N0 N_pos st {$is_tail_close_to_value(a, L, epsilon, N0)}

have fn zero_indexed_partial_sum(a fn(n N) R, k N) R by induc k from 0:
    case k = 0: a(0)
    case k > 0: zero_indexed_partial_sum(a, k - 1) + a(k)

have fn one_indexed_partial_sum(a fn(n N_pos) R, k N) R by induc k from 0:
    case k = 0: 0
    case k > 0: one_indexed_partial_sum(a, k - 1) + a(k)

thm one_indexed_partial_sum_successor:
    ? forall a fn(n N_pos) R, k N_pos:
        one_indexed_partial_sum(a, k) = one_indexed_partial_sum(a, k - 1) + a(k)

thm one_indexed_partial_sum_matches_chapter7:
    ? forall a fn(n N_pos) R, k N:
        one_indexed_partial_sum(a, k) = chap7::partial_sum(a, k)
    by induc k from 0:
        ? one_indexed_partial_sum(a, k) = chap7::partial_sum(a, k)
        ? from k = 0:
            one_indexed_partial_sum(a, 0) = 0 = chap7::partial_sum(a, 0)
        ? induc:
            by thm one_indexed_partial_sum_successor(a, k + 1)
            by thm chap7::partial_sum_successor(a, k + 1)
            one_indexed_partial_sum(a, k + 1) = one_indexed_partial_sum(a, k) + a(k + 1) = chap7::partial_sum(a, k) + a(k + 1) = chap7::partial_sum(a, k + 1)

prop has_series_sum_from_zero(a fn(n N) R, S R):
    $has_sequence_limit_value(fn(k N_pos) R {zero_indexed_partial_sum(a, k)}, S)

prop has_series_sum_from_one(a fn(n N_pos) R, S R):
    $has_sequence_limit_value(fn(k N_pos) R {one_indexed_partial_sum(a, k)}, S)

thm chapter7_series_sum_implies_chapter11_series_sum_from_one:
    ? forall a fn(n N_pos) R, S R:
        $chap7::has_series_sum(a, S)
        =>:
            $has_series_sum_from_one(a, S)
    claim:
        ? $has_sequence_limit_value(fn(k N_pos) R {one_indexed_partial_sum(a, k)}, S)
        claim:
            ? forall epsilon R_pos:
                exist N0 N_pos st {$is_tail_close_to_value(fn(k N_pos) R {one_indexed_partial_sum(a, k)}, S, epsilon, N0)}
            obtain N0 from exist N0 N_pos st {$chap7::is_tail_close_to(fn(k N_pos) R {chap7::partial_sum(a, k)}, S, epsilon, N0)}
            witness exist N1 N_pos st {$is_tail_close_to_value(fn(k N_pos) R {one_indexed_partial_sum(a, k)}, S, epsilon, N1)} from N0:
                claim:
                    ? forall k N_pos:
                        k >= N0
                        =>:
                            abs(fn(j N_pos) R {one_indexed_partial_sum(a, j)}(k) - S) <= epsilon
                    fn(j N_pos) R {one_indexed_partial_sum(a, j)}(k) = one_indexed_partial_sum(a, k)
                    by thm one_indexed_partial_sum_matches_chapter7(a, k)
                    fn(j N_pos) R {chap7::partial_sum(a, j)}(k) = chap7::partial_sum(a, k)
                    abs(fn(j N_pos) R {chap7::partial_sum(a, j)}(k) - S) <= epsilon
                    abs(fn(j N_pos) R {one_indexed_partial_sum(a, j)}(k) - S) <= epsilon
    by def $has_series_sum_from_one(a, S)

thm chapter11_series_sum_from_one_implies_chapter7_series_sum:
    ? forall a fn(n N_pos) R, S R:
        $has_series_sum_from_one(a, S)
        =>:
            $chap7::has_series_sum(a, S)
    claim:
        ? $chap7::has_limit(fn(k N_pos) R {chap7::partial_sum(a, k)}, S)
        claim:
            ? forall epsilon R_pos:
                exist N0 N_pos st {$chap7::is_tail_close_to(fn(k N_pos) R {chap7::partial_sum(a, k)}, S, epsilon, N0)}
            obtain N0 from exist N0 N_pos st {$is_tail_close_to_value(fn(k N_pos) R {one_indexed_partial_sum(a, k)}, S, epsilon, N0)}
            witness exist N1 N_pos st {$chap7::is_tail_close_to(fn(k N_pos) R {chap7::partial_sum(a, k)}, S, epsilon, N1)} from N0:
                claim:
                    ? forall k N_pos:
                        k >= N0
                        =>:
                            abs(fn(j N_pos) R {chap7::partial_sum(a, j)}(k) - S) <= epsilon
                    fn(j N_pos) R {chap7::partial_sum(a, j)}(k) = chap7::partial_sum(a, k)
                    by thm one_indexed_partial_sum_matches_chapter7(a, k)
                    fn(j N_pos) R {one_indexed_partial_sum(a, j)}(k) = one_indexed_partial_sum(a, k)
                    abs(fn(j N_pos) R {one_indexed_partial_sum(a, j)}(k) - S) <= epsilon
                    abs(fn(j N_pos) R {chap7::partial_sum(a, j)}(k) - S) = abs(chap7::partial_sum(a, k) - S) = abs(one_indexed_partial_sum(a, k) - S) = abs(fn(j N_pos) R {one_indexed_partial_sum(a, j)}(k) - S) <= epsilon
    by def $chap7::has_series_sum(a, S)

thm nonpositive_p_series_terms_at_least_one:
    ? forall p R, n N_pos:
        p <= 0
        =>:
            1 / n^p >= 1
    p = 0 or p < 0
    by cases:
        ? 1 / n^p >= 1
        case p = 0:
            n^p = n^0 = 1
            1 / n^p = 1 / 1 = 1
        case p < 0:
            n = 1 or n > 1
            by cases:
                ? 1 / n^p >= 1
                case n = 1:
                    n^p = 1^p = 1
                    1 / n^p = 1 / 1 = 1
                case n > 1:
                    n $in R_pos
                    by thm chap6::real_power_exponent_strict_mono_above_one(n, 0, p)
                    n^0 > n^p
                    n^0 = 1
                    n^p < 1
                    by thm chap6::real_power_positive(n, p)
                    n^p > 0
                    n^p / n^p < 1 / n^p
                    n^p / n^p = 1
                    1 < 1 / n^p

prop is_closed_interval_integral_value_on_nonnegative_ray_endpoint(f fn(x '[0,)) R, T '[0,), s R):
    $has_riemann_integral('[0, T], fn(x '[0, T]) R {f(x)}, s)

prop is_closed_interval_integral_value_on_nonnegative_ray(f fn(x '[0,)) R, s R):
    exist T '[0,) st {$is_closed_interval_integral_value_on_nonnegative_ray_endpoint(f, T, s)}

have fn closed_interval_integral_values_on_nonnegative_ray(f fn(x '[0,)) R) power_set(R) = {s R: $is_closed_interval_integral_value_on_nonnegative_ray(f, s)}

prop has_finite_integral_supremum_on_nonnegative_ray(f fn(x '[0,)) R):
    $has_least_upper_bound(closed_interval_integral_values_on_nonnegative_ray(f))

"""
Proposition 11.6.4 (Integral test).  A non-negative monotone decreasing
function on `[0,infty)` gives a convergent series exactly when the supremum of
its finite interval integrals is finite.
"""

thm integral_test_series_implies_finite_integral_supremum:
    ? forall f fn(x '[0,)) R, S R:
        $chap9::is_monotone_decreasing_on('[0,), f)
        $is_nonnegative_on('[0,), f)
        $has_series_sum_from_zero(fn(n N) R {f(n)}, S)
        =>:
            $has_finite_integral_supremum_on_nonnegative_ray(f)
    # Source handling: Proposition 11.6.4 leaves both directions of the
    # integral test to Exercise 11.6.3.  This trust records the source-deferred
    # series-to-integral direction.
    # proof_debt: formalize the finite sum/integral comparison and the
    # monotone convergence criterion for partial sums.
    trust $has_finite_integral_supremum_on_nonnegative_ray(f)

thm integral_test_finite_integral_supremum_implies_series:
    ? forall f fn(x '[0,)) R:
        $chap9::is_monotone_decreasing_on('[0,), f)
        $is_nonnegative_on('[0,), f)
        $has_finite_integral_supremum_on_nonnegative_ray(f)
        =>:
            exist S R st {$has_series_sum_from_zero(fn(n N) R {f(n)}, S)}
    # Source handling: Proposition 11.6.4 leaves both directions of the
    # integral test to Exercise 11.6.3.  This trust records the source-deferred
    # integral-to-series direction.
    # proof_debt: use the same rectangle comparison to bound partial sums.
    trust exist S R st {$has_series_sum_from_zero(fn(n N) R {f(n)}, S)}

"""
Corollary 11.6.5.  The p-series `sum 1/n^p` converges absolutely for `p>1` and
diverges for `p<=1`.
"""

thm p_series_test_by_integral_test:
    ? forall p R:
        p > 1
        =>:
            exist S R st {$has_series_sum_from_one(fn(n N_pos) R {1 / n^p}, S)}
    # Source handling: Tao proves this in Exercise 11.6.5 using the integral
    # test.  Chapter 7 already exposes the same p-series convergence theorem;
    # this chapter checks only the bridge to its local partial-sum notation.
    p > 0
    p $in R_pos
    by thm chap7::p_series_converges_when_exponent_gt_one(p)
    claim:
        ? forall n N_pos:
            chap7::p_series_terms(p)(n) = fn(j N_pos) R {1 / j^p}(n)
        chap7::p_series_terms(p)(n) = 1 / n^p
        fn(j N_pos) R {1 / j^p}(n) = 1 / n^p
    by thm chap7::series_convergence_extensional(chap7::p_series_terms(p), fn(n N_pos) R {1 / n^p})
    $chap7::is_convergent_series(fn(n N_pos) R {1 / n^p})
    obtain S from exist S R st {$chap7::has_series_sum(fn(n N_pos) R {1 / n^p}, S)}
    by thm chapter7_series_sum_implies_chapter11_series_sum_from_one(fn(n N_pos) R {1 / n^p}, S)
    witness exist S0 R st {$has_series_sum_from_one(fn(n N_pos) R {1 / n^p}, S0)} from S

thm p_series_diverges_when_p_le_one:
    ? forall p R:
        p <= 1
        =>:
            not exist S R st {$has_series_sum_from_one(fn(n N_pos) R {1 / n^p}, S)}
    # Source handling: for positive exponents, reuse Chapter 7's p-series
    # divergence interface.  For non-positive exponents, the terms stay at
    # least one, so Chapter 7's checked zero test rules out convergence.
    by contra:
        ? not exist S R st {$has_series_sum_from_one(fn(n N_pos) R {1 / n^p}, S)}
        obtain S from exist S R st {$has_series_sum_from_one(fn(n N_pos) R {1 / n^p}, S)}
        by thm chapter11_series_sum_from_one_implies_chapter7_series_sum(fn(n N_pos) R {1 / n^p}, S)
        $chap7::is_convergent_series(fn(n N_pos) R {1 / n^p})
        claim:
            ? not $chap7::is_convergent_series(fn(n N_pos) R {1 / n^p})
            p > 0 or p <= 0
            by cases:
                ? not $chap7::is_convergent_series(fn(n N_pos) R {1 / n^p})
                case p > 0:
                    p $in R_pos
                    by thm chap7::p_series_diverges_when_exponent_le_one(p)
                    by contra:
                        ? not $chap7::is_convergent_series(fn(n N_pos) R {1 / n^p})
                        claim:
                            ? forall n N_pos:
                                fn(j N_pos) R {1 / j^p}(n) = chap7::p_series_terms(p)(n)
                            fn(j N_pos) R {1 / j^p}(n) = 1 / n^p
                            chap7::p_series_terms(p)(n) = 1 / n^p
                        by thm chap7::series_convergence_extensional(fn(n N_pos) R {1 / n^p}, chap7::p_series_terms(p))
                        impossible not $chap7::is_convergent_series(chap7::p_series_terms(p))
                case p <= 0:
                    by contra:
                        ? not $chap7::is_convergent_series(fn(n N_pos) R {1 / n^p})
                        by thm chap7::series_zero_test(fn(n N_pos) R {1 / n^p})
                        obtain n0 from exist n0 N_pos st {$chap7::is_tail_close_to(fn(n N_pos) R {1 / n^p}, 0, 1 / 2, n0)}
                        fn(n N_pos) R {1 / n^p}(n0) = 1 / n0^p
                        abs(fn(n N_pos) R {1 / n^p}(n0) - 0) <= 1 / 2
                        by thm nonpositive_p_series_terms_at_least_one(p, n0)
                        1 / n0^p >= 1
                        1 / n0^p > 0
                        abs(fn(n N_pos) R {1 / n^p}(n0) - 0) = abs(1 / n0^p) = 1 / n0^p >= 1 > 1 / 2
                        impossible abs(fn(n N_pos) R {1 / n^p}(n0) - 0) <= 1 / 2
        impossible not $chap7::is_convergent_series(fn(n N_pos) R {1 / n^p})


# 11.7 A non-Riemann integrable function

"""
Proposition 11.7.1.  The rational-indicator function on `[0,1]` is bounded but
not Riemann integrable: every non-trivial interval contains rationals and
irrationals, so all upper sums are `1` and all lower sums are `0`.
"""

have fn dirichlet_rational_indicator_on_unit(x '[0, 1]) R by cases:
    case x $in Q: 1
    case not x $in Q: 0

thm real_point_is_rational_or_irrational:
    ? forall x R:
        x $in Q or x $in set_minus(R, Q)
    # Background set interface: an ordinary real is either rational or in the
    # complement of the rationals inside `R`.
    by cases:
        ? x $in Q or x $in set_minus(R, Q)
        case x $in Q:
            x $in Q or x $in set_minus(R, Q)
        case not x $in Q:
            x $in set_minus(R, Q)
            x $in Q or x $in set_minus(R, Q)

thm dirichlet_rational_indicator_bounded:
    ? forall:
        $chap9::is_bounded_function_on('[0, 1], dirichlet_rational_indicator_on_unit)
    # The indicator only takes the values `0` and `1`, so `1` is a uniform
    # bound on `[0,1]`.
    witness exist M R_pos st {$chap9::is_function_bounded_by('[0, 1], dirichlet_rational_indicator_on_unit, M)} from 1:
        1 $in R_pos
        claim:
            ? forall x '[0, 1]:
                abs(dirichlet_rational_indicator_on_unit(x)) <= 1
            by thm real_point_is_rational_or_irrational(x)
            by cases:
                ? abs(dirichlet_rational_indicator_on_unit(x)) <= 1
                case x $in Q:
                    dirichlet_rational_indicator_on_unit(x) = 1
                    abs(dirichlet_rational_indicator_on_unit(x)) = abs(1)
                    abs(1) = 1
                    abs(dirichlet_rational_indicator_on_unit(x)) <= 1
                case x $in set_minus(R, Q):
                    dirichlet_rational_indicator_on_unit(x) = 0
                    abs(dirichlet_rational_indicator_on_unit(x)) = abs(0)
                    abs(0) = 0
                    0 <= 1
                    abs(dirichlet_rational_indicator_on_unit(x)) <= 1
        $chap9::is_function_bounded_by('[0, 1], dirichlet_rational_indicator_on_unit, 1)
    $chap9::is_bounded_function_on('[0, 1], dirichlet_rational_indicator_on_unit)

thm positive_length_bounded_interval_has_rational_and_irrational_points:
    ? forall J power_set(R):
        $is_bounded_interval(J)
        interval_length(J) > 0
        =>:
            exist q Q st {q $in J}
            exist z set_minus(R, Q) st {z $in J}
    # A positive interval length forces strict endpoint order. Density then
    # supplies both kinds of points strictly between those endpoints, hence in
    # every open/closed endpoint form at once.
    obtain a, b from exist a, b R st {$has_interval_endpoints(J, a, b)}
    by thm interval_endpoint_case_has_total_length(J, a, b)
    $has_interval_length(J, finite_set_max(union({b - a}, { 0})))
    $has_interval_length(J, interval_length(J))
    by thm interval_length_value_unique(J, interval_length(J), finite_set_max(union({b - a}, { 0})))
    interval_length(J) = finite_set_max(union({b - a}, { 0}))
    claim:
        ? a < b
        by contra:
            ? a < b
            b <= a
            by thm max_positive_part_zero_when_nonpositive(a, b)
            finite_set_max(union({b - a}, { 0})) = 0
            interval_length(J) = 0
            impossible interval_length(J) > 0
    by thm chap5::rational_density_of_reals(a, b)
    obtain q from exist q Q st {a < q < b}
    by thm strict_between_interval_endpoints_is_member(J, a, b, q)
    q $in J
    witness exist q0 Q st {q0 $in J} from q:
        q $in J
    by thm chap9::irrational_density_of_reals(a, b)
    obtain z from exist z set_minus(R, Q) st {a < z < b}
    by thm strict_between_interval_endpoints_is_member(J, a, b, z)
    z $in J
    witness exist z0 set_minus(R, Q) st {z0 $in J} from z:
        z $in J

thm dirichlet_rational_indicator_between_zero_and_one:
    ? forall x '[0, 1]:
        0 <= dirichlet_rational_indicator_on_unit(x) <= 1
    by thm real_point_is_rational_or_irrational(x)
    by cases:
        ? 0 <= dirichlet_rational_indicator_on_unit(x) <= 1
        case x $in Q:
            dirichlet_rational_indicator_on_unit(x) = 1
            0 <= dirichlet_rational_indicator_on_unit(x) <= 1
        case x $in set_minus(R, Q):
            not x $in Q
            dirichlet_rational_indicator_on_unit(x) = 0
            0 <= dirichlet_rational_indicator_on_unit(x) <= 1

thm dirichlet_upper_piece_height_on_positive_length:
    ? forall J power_set(R):
        $is_bounded_interval(J)
        J $subset '[0, 1]
        interval_length(J) > 0
        =>:
            upper_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit) = 1
    by thm dirichlet_rational_indicator_bounded()
    by thm upper_riemann_piece_height_has_value('[0, 1], J, dirichlet_rational_indicator_on_unit)
    $has_upper_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit, upper_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit))
    by thm positive_length_bounded_interval_has_rational_and_irrational_points(J)
    obtain q from exist q Q st {q $in J}
    witness $is_nonempty_set(J) from q:
        q $in J
    $has_nonempty_upper_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit, upper_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit))
    $chap5::is_least_upper_bound(function_values_on_subset('[0, 1], J, dirichlet_rational_indicator_on_unit), upper_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit))
    claim:
        ? $chap5::is_upper_bound(function_values_on_subset('[0, 1], J, dirichlet_rational_indicator_on_unit), 1)
        claim:
            ? forall y function_values_on_subset('[0, 1], J, dirichlet_rational_indicator_on_unit):
                y <= 1
            by thm function_values_on_subset_member_has_preimage('[0, 1], J, dirichlet_rational_indicator_on_unit, y)
            obtain x from exist x J st {y = dirichlet_rational_indicator_on_unit(x)}
            x $in '[0, 1]
            by thm dirichlet_rational_indicator_between_zero_and_one(x)
            y = dirichlet_rational_indicator_on_unit(x) <= 1
        $chap5::is_upper_bound(function_values_on_subset('[0, 1], J, dirichlet_rational_indicator_on_unit), 1)
    upper_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit) <= 1
    q $in '[0, 1]
    dirichlet_rational_indicator_on_unit(q) = 1
    by thm function_value_on_subset_member('[0, 1], J, dirichlet_rational_indicator_on_unit, q)
    dirichlet_rational_indicator_on_unit(q) $in function_values_on_subset('[0, 1], J, dirichlet_rational_indicator_on_unit)
    1 $in function_values_on_subset('[0, 1], J, dirichlet_rational_indicator_on_unit)
    $chap5::is_upper_bound(function_values_on_subset('[0, 1], J, dirichlet_rational_indicator_on_unit), upper_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit))
    1 <= upper_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit)
    upper_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit) = 1

thm dirichlet_lower_piece_height_on_positive_length:
    ? forall J power_set(R):
        $is_bounded_interval(J)
        J $subset '[0, 1]
        interval_length(J) > 0
        =>:
            lower_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit) = 0
    by thm dirichlet_rational_indicator_bounded()
    by thm lower_riemann_piece_height_has_value('[0, 1], J, dirichlet_rational_indicator_on_unit)
    $has_lower_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit, lower_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit))
    by thm positive_length_bounded_interval_has_rational_and_irrational_points(J)
    obtain z from exist z set_minus(R, Q) st {z $in J}
    witness $is_nonempty_set(J) from z:
        z $in J
    $has_nonempty_lower_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit, lower_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit))
    $is_infimum_of_real_set(function_values_on_subset('[0, 1], J, dirichlet_rational_indicator_on_unit), lower_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit))
    claim:
        ? $is_lower_bound_of_real_set(function_values_on_subset('[0, 1], J, dirichlet_rational_indicator_on_unit), 0)
        claim:
            ? forall y function_values_on_subset('[0, 1], J, dirichlet_rational_indicator_on_unit):
                0 <= y
            by thm function_values_on_subset_member_has_preimage('[0, 1], J, dirichlet_rational_indicator_on_unit, y)
            obtain x from exist x J st {y = dirichlet_rational_indicator_on_unit(x)}
            x $in '[0, 1]
            by thm dirichlet_rational_indicator_between_zero_and_one(x)
            0 <= dirichlet_rational_indicator_on_unit(x) = y
        $is_lower_bound_of_real_set(function_values_on_subset('[0, 1], J, dirichlet_rational_indicator_on_unit), 0)
    0 <= lower_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit)
    z $in '[0, 1]
    not z $in Q
    dirichlet_rational_indicator_on_unit(z) = 0
    by thm function_value_on_subset_member('[0, 1], J, dirichlet_rational_indicator_on_unit, z)
    dirichlet_rational_indicator_on_unit(z) $in function_values_on_subset('[0, 1], J, dirichlet_rational_indicator_on_unit)
    0 $in function_values_on_subset('[0, 1], J, dirichlet_rational_indicator_on_unit)
    $is_lower_bound_of_real_set(function_values_on_subset('[0, 1], J, dirichlet_rational_indicator_on_unit), lower_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit))
    lower_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit) <= 0
    lower_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit) = 0

thm dirichlet_upper_riemann_sum_piece_equals_length:
    ? forall J power_set(R):
        $is_bounded_interval(J)
        J $subset '[0, 1]
        =>:
            upper_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit) = interval_length(J)
    by thm dirichlet_rational_indicator_bounded()
    by thm upper_riemann_sum_piece_is_height_times_length('[0, 1], J, dirichlet_rational_indicator_on_unit)
    upper_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit) = upper_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit) * interval_length(J)
    by thm interval_length_nonnegative(J)
    by cases:
        ? upper_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit) = interval_length(J)
        case interval_length(J) > 0:
            by thm dirichlet_upper_piece_height_on_positive_length(J)
            upper_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit) = 1
            upper_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit) = 1 * interval_length(J) = interval_length(J)
        case interval_length(J) = 0:
            upper_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit) = upper_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit) * 0 = 0 = interval_length(J)

thm dirichlet_lower_riemann_sum_piece_equals_zero:
    ? forall J power_set(R):
        $is_bounded_interval(J)
        J $subset '[0, 1]
        =>:
            lower_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit) = 0
    by thm dirichlet_rational_indicator_bounded()
    by thm lower_riemann_sum_piece_is_height_times_length('[0, 1], J, dirichlet_rational_indicator_on_unit)
    lower_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit) = lower_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit) * interval_length(J)
    by thm interval_length_nonnegative(J)
    by cases:
        ? lower_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit) = 0
        case interval_length(J) > 0:
            by thm dirichlet_lower_piece_height_on_positive_length(J)
            lower_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit) = 0
            lower_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit) = 0 * interval_length(J) = 0
        case interval_length(J) = 0:
            lower_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit) = lower_riemann_piece_height('[0, 1], J, dirichlet_rational_indicator_on_unit) * 0 = 0

thm dirichlet_upper_riemann_sum_on_partition_equals_one:
    ? forall P power_set(power_set(R)):
        $is_finite_set(P)
        $is_partition_of_bounded_interval('[0, 1], P)
        =>:
            upper_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit) = 1
    by thm dirichlet_rational_indicator_bounded()
    by thm upper_riemann_sum_has_value('[0, 1], P, dirichlet_rational_indicator_on_unit)
    obtain c from exist c fn(J P) R st {$is_upper_riemann_sum_contribution_family('[0, 1], P, dirichlet_rational_indicator_on_unit, c), upper_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit) = finite_set_sum(P, c)}
    claim:
        ? $fn_eq(c, fn(J P) R {interval_length(J)})
        claim:
            ? forall J P:
                c(J) = fn(K P) R {interval_length(K)}(J)
            J $in power_set(R)
            $is_bounded_interval(J)
            J $subset '[0, 1]
            $has_upper_riemann_sum_piece_contribution('[0, 1], J, dirichlet_rational_indicator_on_unit, c(J))
            by thm upper_riemann_sum_piece_has_value('[0, 1], J, dirichlet_rational_indicator_on_unit)
            $has_upper_riemann_sum_piece_contribution('[0, 1], J, dirichlet_rational_indicator_on_unit, upper_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit))
            by thm upper_riemann_sum_piece_contribution_unique('[0, 1], J, dirichlet_rational_indicator_on_unit, c(J), upper_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit))
            c(J) = upper_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit)
            by thm dirichlet_upper_riemann_sum_piece_equals_length(J)
            upper_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit) = interval_length(J)
            fn(K P) R {interval_length(K)}(J) = interval_length(J)
            c(J) = fn(K P) R {interval_length(K)}(J)
        $fn_eq(c, fn(J P) R {interval_length(J)})
    c = fn(J P) R {interval_length(J)}
    upper_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit) = finite_set_sum(P, c) = finite_set_sum(P, fn(J P) R {interval_length(J)})
    by thm interval_length_is_finitely_additive_over_partition('[0, 1], P)
    interval_length('[0, 1]) = finite_set_sum(P, fn(J P) R {interval_length(J)})
    by thm non_degenerate_interval_forms_length_value(0, 1)
    interval_length('[0, 1]) = 1 - 0 = 1
    upper_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit) = 1

thm dirichlet_lower_riemann_sum_on_partition_equals_zero:
    ? forall P power_set(power_set(R)):
        $is_finite_set(P)
        $is_partition_of_bounded_interval('[0, 1], P)
        =>:
            lower_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit) = 0
    by thm dirichlet_rational_indicator_bounded()
    by thm lower_riemann_sum_has_value('[0, 1], P, dirichlet_rational_indicator_on_unit)
    obtain c from exist c fn(J P) R st {$is_lower_riemann_sum_contribution_family('[0, 1], P, dirichlet_rational_indicator_on_unit, c), lower_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit) = finite_set_sum(P, c)}
    claim:
        ? $fn_eq(c, fn(J P) R {0})
        claim:
            ? forall J P:
                c(J) = fn(K P) R {0}(J)
            J $in power_set(R)
            $is_bounded_interval(J)
            J $subset '[0, 1]
            $has_lower_riemann_sum_piece_contribution('[0, 1], J, dirichlet_rational_indicator_on_unit, c(J))
            by thm lower_riemann_sum_piece_has_value('[0, 1], J, dirichlet_rational_indicator_on_unit)
            $has_lower_riemann_sum_piece_contribution('[0, 1], J, dirichlet_rational_indicator_on_unit, lower_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit))
            by thm lower_riemann_sum_piece_contribution_unique('[0, 1], J, dirichlet_rational_indicator_on_unit, c(J), lower_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit))
            c(J) = lower_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit)
            by thm dirichlet_lower_riemann_sum_piece_equals_zero(J)
            lower_riemann_sum_piece('[0, 1], J, dirichlet_rational_indicator_on_unit) = 0
            fn(K P) R {0}(J) = 0
            c(J) = fn(K P) R {0}(J)
        $fn_eq(c, fn(J P) R {0})
    c = fn(J P) R {0}
    lower_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit) = finite_set_sum(P, c) = finite_set_sum(P, fn(J P) R {0})
    finite_set_sum(P, fn(J P) R {0}) = 0
    lower_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit) = 0

thm dirichlet_rational_indicator_upper_integral_value:
    ? forall:
        $is_bounded_interval('[0, 1])
        $chap9::is_bounded_function_on('[0, 1], dirichlet_rational_indicator_on_unit)
        =>:
            upper_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit) = 1
    # Every positive-length partition piece contains a rational point, hence
    # has upper height one. Zero-length pieces contribute zero. Therefore every
    # upper sum is one, and its infimum is one.
    by thm upper_integral_equals_infimum_of_riemann_sums('[0, 1], dirichlet_rational_indicator_on_unit)
    $is_infimum_of_real_set(upper_riemann_sum_values('[0, 1], dirichlet_rational_indicator_on_unit), upper_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit))
    claim:
        ? forall U upper_riemann_sum_values('[0, 1], dirichlet_rational_indicator_on_unit):
            U = 1
        by thm upper_riemann_sum_value_from_member('[0, 1], dirichlet_rational_indicator_on_unit, U)
        obtain P from exist P finite_set st {$has_upper_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit, U)}
        P $in power_set(power_set(R))
        by thm upper_riemann_sum_has_value('[0, 1], P, dirichlet_rational_indicator_on_unit)
        by thm upper_riemann_sum_value_unique('[0, 1], P, dirichlet_rational_indicator_on_unit, U, upper_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit))
        U = upper_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit)
        by thm dirichlet_upper_riemann_sum_on_partition_equals_one(P)
        upper_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit) = 1
        U = 1
    claim:
        ? $is_lower_bound_of_real_set(upper_riemann_sum_values('[0, 1], dirichlet_rational_indicator_on_unit), 1)
        claim:
            ? forall U upper_riemann_sum_values('[0, 1], dirichlet_rational_indicator_on_unit):
                1 <= U
            U = 1
            1 <= U
        $is_lower_bound_of_real_set(upper_riemann_sum_values('[0, 1], dirichlet_rational_indicator_on_unit), 1)
    1 <= upper_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit)
    by thm one_piece_partition_of_bounded_interval('[0, 1])
    $is_partition_of_bounded_interval('[0, 1], {'[0, 1]})
    by thm upper_riemann_sum_has_value('[0, 1], {'[0, 1]}, dirichlet_rational_indicator_on_unit)
    by thm dirichlet_upper_riemann_sum_on_partition_equals_one({'[0, 1]})
    upper_riemann_sum('[0, 1], {'[0, 1]}, dirichlet_rational_indicator_on_unit) = 1
    $has_upper_riemann_sum('[0, 1], {'[0, 1]}, dirichlet_rational_indicator_on_unit, 1)
    claim:
        ? $is_upper_riemann_sum_value('[0, 1], dirichlet_rational_indicator_on_unit, 1)
        witness exist P finite_set st {$has_upper_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit, 1)} from {'[0, 1]}:
            $has_upper_riemann_sum('[0, 1], {'[0, 1]}, dirichlet_rational_indicator_on_unit, 1)
    by thm upper_riemann_sum_value_member('[0, 1], dirichlet_rational_indicator_on_unit, 1)
    1 $in upper_riemann_sum_values('[0, 1], dirichlet_rational_indicator_on_unit)
    $is_lower_bound_of_real_set(upper_riemann_sum_values('[0, 1], dirichlet_rational_indicator_on_unit), upper_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit))
    upper_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit) <= 1
    upper_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit) = 1

thm dirichlet_rational_indicator_lower_integral_value:
    ? forall:
        $is_bounded_interval('[0, 1])
        $chap9::is_bounded_function_on('[0, 1], dirichlet_rational_indicator_on_unit)
        =>:
            lower_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit) = 0
    # Every positive-length partition piece contains an irrational point,
    # hence has lower height zero. Zero-length pieces also contribute zero, so
    # every lower sum and therefore its supremum is zero.
    by thm lower_integral_equals_supremum_of_riemann_sums('[0, 1], dirichlet_rational_indicator_on_unit)
    $is_least_upper_bound(lower_riemann_sum_values('[0, 1], dirichlet_rational_indicator_on_unit), lower_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit))
    claim:
        ? forall L lower_riemann_sum_values('[0, 1], dirichlet_rational_indicator_on_unit):
            L = 0
        by thm lower_riemann_sum_value_from_member('[0, 1], dirichlet_rational_indicator_on_unit, L)
        obtain P from exist P finite_set st {$has_lower_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit, L)}
        P $in power_set(power_set(R))
        by thm lower_riemann_sum_has_value('[0, 1], P, dirichlet_rational_indicator_on_unit)
        by thm lower_riemann_sum_value_unique('[0, 1], P, dirichlet_rational_indicator_on_unit, L, lower_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit))
        L = lower_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit)
        by thm dirichlet_lower_riemann_sum_on_partition_equals_zero(P)
        lower_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit) = 0
        L = 0
    claim:
        ? $is_upper_bound_of_real_set(lower_riemann_sum_values('[0, 1], dirichlet_rational_indicator_on_unit), 0)
        claim:
            ? forall L lower_riemann_sum_values('[0, 1], dirichlet_rational_indicator_on_unit):
                L <= 0
            L = 0
            L <= 0
        $is_upper_bound_of_real_set(lower_riemann_sum_values('[0, 1], dirichlet_rational_indicator_on_unit), 0)
    lower_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit) <= 0
    by thm one_piece_partition_of_bounded_interval('[0, 1])
    $is_partition_of_bounded_interval('[0, 1], {'[0, 1]})
    by thm lower_riemann_sum_has_value('[0, 1], {'[0, 1]}, dirichlet_rational_indicator_on_unit)
    by thm dirichlet_lower_riemann_sum_on_partition_equals_zero({'[0, 1]})
    lower_riemann_sum('[0, 1], {'[0, 1]}, dirichlet_rational_indicator_on_unit) = 0
    $has_lower_riemann_sum('[0, 1], {'[0, 1]}, dirichlet_rational_indicator_on_unit, 0)
    claim:
        ? $is_lower_riemann_sum_value('[0, 1], dirichlet_rational_indicator_on_unit, 0)
        witness exist P finite_set st {$has_lower_riemann_sum('[0, 1], P, dirichlet_rational_indicator_on_unit, 0)} from {'[0, 1]}:
            $has_lower_riemann_sum('[0, 1], {'[0, 1]}, dirichlet_rational_indicator_on_unit, 0)
    by thm lower_riemann_sum_value_member('[0, 1], dirichlet_rational_indicator_on_unit, 0)
    0 $in lower_riemann_sum_values('[0, 1], dirichlet_rational_indicator_on_unit)
    $is_upper_bound_of_real_set(lower_riemann_sum_values('[0, 1], dirichlet_rational_indicator_on_unit), lower_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit))
    0 <= lower_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit)
    lower_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit) = 0

thm dirichlet_rational_indicator_upper_lower_integrals_separated:
    ? forall:
        $is_bounded_interval('[0, 1])
        $chap9::is_bounded_function_on('[0, 1], dirichlet_rational_indicator_on_unit)
        =>:
            upper_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit) != lower_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit)
    # Once the Darboux values are known, the two integrals are separated by
    # `1 != 0`.
    by thm dirichlet_rational_indicator_upper_integral_value()
    by thm dirichlet_rational_indicator_lower_integral_value()
    upper_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit) = 1
    lower_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit) = 0
    by contra:
        ? upper_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit) != lower_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit)
        upper_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit) = lower_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit)
        1 = 0
        impossible 1 = 0

thm dirichlet_rational_indicator_bounded_not_riemann_integrable:
    ? forall:
        $chap9::is_bounded_function_on('[0, 1], dirichlet_rational_indicator_on_unit)
        not $is_riemann_integrable_on('[0, 1], dirichlet_rational_indicator_on_unit)
    # Source handling: Tao's density argument gives upper integral `1` and
    # lower integral `0`; the checked part below is the contradiction with the
    # definition of Riemann integrability.
    by thm non_degenerate_interval_forms_are_bounded_intervals(0, 1)
    by thm dirichlet_rational_indicator_bounded()
    $chap9::is_bounded_function_on('[0, 1], dirichlet_rational_indicator_on_unit)
    by contra:
        ? not $is_riemann_integrable_on('[0, 1], dirichlet_rational_indicator_on_unit)
        $is_riemann_integrable_on('[0, 1], dirichlet_rational_indicator_on_unit)
        by thm dirichlet_rational_indicator_upper_lower_integrals_separated()
        upper_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit) != lower_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit)
        by thm riemann_integrable_upper_eq_lower('[0, 1], dirichlet_rational_indicator_on_unit)
        upper_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit) = lower_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit)
        impossible upper_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit) != lower_riemann_integral('[0, 1], dirichlet_rational_indicator_on_unit)

"""
Remark 11.7.2.  Non-integrable bounded functions are possible, but the common
classes developed above are integrable.  The chapter next introduces
Riemann-Stieltjes integration as another generalization.
"""

# 11.8 The Riemann-Stieltjes integral

"""
Definition 11.8.1 (alpha-length).  For a function `alpha` defined on a domain
containing an interval, the alpha-length of a non-degenerate interval with
endpoints `a<b` is `alpha(b)-alpha(a)`, and singleton or empty intervals have
alpha-length zero.
"""

# Source-facing selector for Tao's `alpha[I]`.  This chapter uses
# `alpha : R -> R` as a domain bridge; the source's more general ambient
# domain is tracked in the alignment audit.

prop has_alpha_interval_length(alpha fn(x R) R, I power_set(R), l R):
    $is_bounded_interval(I)
    forall a, b R:
        $has_interval_endpoints(I, a, b)
        a < b
        =>:
            l = alpha(b) - alpha(a)
    forall a, b R:
        $has_interval_endpoints(I, a, b)
        b <= a
        =>:
            l = 0

thm alpha_interval_length_exists_unique:
    ? forall alpha fn(x R) R, I power_set(R):
        $is_bounded_interval(I)
        =>:
            exist! l R st {$has_alpha_interval_length(alpha, I, l)}
    obtain a, b from exist a, b R st {$has_interval_endpoints(I, a, b)}
    a < b or not a < b
    by cases:
        ? exist! l R st {$has_alpha_interval_length(alpha, I, l)}
        case a < b:
            have x R = (a + b) / 2
            a < x < b
            by thm strict_between_interval_endpoints_is_member(I, a, b, x)
            x $in I
            witness $is_nonempty_set(I) from x
            claim:
                ? $has_alpha_interval_length(alpha, I, alpha(b) - alpha(a))
                claim:
                    ? forall c, d R:
                        $has_interval_endpoints(I, c, d)
                        c < d
                        =>:
                            alpha(b) - alpha(a) = alpha(d) - alpha(c)
                    by thm nonempty_interval_endpoint_representation_unique(I, a, b, c, d)
                    alpha(b) - alpha(a) = alpha(d) - alpha(c)
                claim:
                    ? forall c, d R:
                        $has_interval_endpoints(I, c, d)
                        d <= c
                        =>:
                            alpha(b) - alpha(a) = 0
                    by contra:
                        ? alpha(b) - alpha(a) = 0
                        by thm nonempty_interval_endpoint_representation_unique(I, a, b, c, d)
                        d = b
                        c = a
                        impossible d <= c
                by def $has_alpha_interval_length(alpha, I, alpha(b) - alpha(a))
            claim:
                ? forall l1, l2 R:
                    $has_alpha_interval_length(alpha, I, l1)
                    $has_alpha_interval_length(alpha, I, l2)
                    =>:
                        l1 = l2
                l1 = alpha(b) - alpha(a)
                l2 = alpha(b) - alpha(a)
                l1 = l2
            exist! l R st {$has_alpha_interval_length(alpha, I, l)}
        case not a < b:
            b <= a
            claim:
                ? $has_alpha_interval_length(alpha, I, 0)
                claim:
                    ? forall c, d R:
                        $has_interval_endpoints(I, c, d)
                        c < d
                        =>:
                            0 = alpha(d) - alpha(c)
                    by contra:
                        ? 0 = alpha(d) - alpha(c)
                        have x R = (2 * c + d) / 3
                        have y R = (c + 2 * d) / 3
                        c < x < y < d
                        by thm strict_between_interval_endpoints_is_member(I, c, d, x)
                        by thm strict_between_interval_endpoints_is_member(I, c, d, y)
                        by thm interval_endpoint_member_is_between(I, a, b, x)
                        by thm interval_endpoint_member_is_between(I, a, b, y)
                        a <= x <= b <= a
                        a <= y <= b <= a
                        x = a
                        y = a
                        impossible x < y
                claim:
                    ? forall c, d R:
                        $has_interval_endpoints(I, c, d)
                        d <= c
                        =>:
                            0 = 0
                    0 = 0
                by def $has_alpha_interval_length(alpha, I, 0)
            claim:
                ? forall l1, l2 R:
                    $has_alpha_interval_length(alpha, I, l1)
                    $has_alpha_interval_length(alpha, I, l2)
                    =>:
                        l1 = l2
                l1 = 0
                l2 = 0
                l1 = l2
            exist! l R st {$has_alpha_interval_length(alpha, I, l)}

# Definition 11.8.1 introduces a selected value, not only a candidate
# relation. The selector is defined from the checked existence and uniqueness
# theorem above.
have fn alpha_interval_length by exist!:
    ? forall alpha fn(x R) R, I power_set(R):
        $is_bounded_interval(I)
        =>:
            exist! l R st {$has_alpha_interval_length(alpha, I, l)}
    by thm alpha_interval_length_exists_unique(alpha, I)

thm alpha_interval_length_has_value:
    ? forall alpha fn(x R) R, I power_set(R):
        $is_bounded_interval(I)
        =>:
            $has_alpha_interval_length(alpha, I, alpha_interval_length(alpha, I))
    $has_alpha_interval_length(alpha, I, alpha_interval_length(alpha, I))

"""
Example 11.8.2.  For `alpha(x)=x^2`, the alpha-length of `[2,3]` is `5`,
while the alpha-length of `(-3,-2)` is `-5`; points and the empty set have
alpha-length zero.
"""

have fn square_alpha(x R) R = x^2

thm example_11_8_2_alpha_lengths:
    ? forall:
        alpha_interval_length(square_alpha, '[2, 3]) = 5
        alpha_interval_length(square_alpha, '(-3, -2)) = -5
        alpha_interval_length(square_alpha, {2}) = 0
        alpha_interval_length(square_alpha, {}) = 0
    # Source handling: these are direct evaluations of Definition 11.8.1.
    2 < 3
    alpha_interval_length(square_alpha, '[2, 3]) = square_alpha(3) - square_alpha(2)
    square_alpha(3) = 3^2
    square_alpha(2) = 2^2
    alpha_interval_length(square_alpha, '[2, 3]) = 3^2 - 2^2
    3^2 - 2^2 = 5

    -3 < -2
    alpha_interval_length(square_alpha, '(-3, -2)) = square_alpha(-2) - square_alpha(-3)
    square_alpha(-2) = (-2)^2
    square_alpha(-3) = (-3)^2
    alpha_interval_length(square_alpha, '(-3, -2)) = (-2)^2 - (-3)^2
    (-2)^2 - (-3)^2 = -5

    alpha_interval_length(square_alpha, {2}) = 0
    alpha_interval_length(square_alpha, {}) = 0

"""
Example 11.8.3.  If `alpha(x)=x`, then alpha-length is ordinary interval
length for all bounded intervals.
"""

have fn identity_alpha(x R) R = x

thm real_order_split_lt_or_ge:
    ? forall a, b R:
        a < b or b <= a
    # Background order interface: the real order is linear.
    by cases:
        ? a < b or b <= a
        case a < b:
            a < b or b <= a
        case not a < b:
            b <= a
            a < b or b <= a

thm monotone_alpha_interval_length_nonnegative:
    ? forall I power_set(R), alpha fn(x R) R:
        $is_bounded_interval(I)
        $chap9::is_monotone_increasing_on(R, alpha)
        =>:
            0 <= alpha_interval_length(alpha, I)
    # On a non-degenerate endpoint interval, monotonicity gives
    # `alpha(a) <= alpha(b)`; degenerate endpoint forms have alpha-length zero.
    obtain a, b from exist a, b R st {$has_interval_endpoints(I, a, b)}
    I = '[a, b] or I = '[a, b) or I = '(a, b] or I = '(a, b)
    by thm real_order_split_lt_or_ge(a, b)
    by cases:
        ? 0 <= alpha_interval_length(alpha, I)
        case a < b:
            alpha(a) <= alpha(b)
            0 <= alpha(b) - alpha(a)
            by cases:
                ? 0 <= alpha_interval_length(alpha, I)
                case I = '[a, b]:
                    alpha_interval_length(alpha, I) = alpha_interval_length(alpha, '[a, b])
                    alpha_interval_length(alpha, '[a, b]) = alpha(b) - alpha(a)
                    0 <= alpha_interval_length(alpha, I)
                case I = '[a, b):
                    alpha_interval_length(alpha, I) = alpha_interval_length(alpha, '[a, b))
                    alpha_interval_length(alpha, '[a, b)) = alpha(b) - alpha(a)
                    0 <= alpha_interval_length(alpha, I)
                case I = '(a, b]:
                    alpha_interval_length(alpha, I) = alpha_interval_length(alpha, '(a, b])
                    alpha_interval_length(alpha, '(a, b]) = alpha(b) - alpha(a)
                    0 <= alpha_interval_length(alpha, I)
                case I = '(a, b):
                    alpha_interval_length(alpha, I) = alpha_interval_length(alpha, '(a, b))
                    alpha_interval_length(alpha, '(a, b)) = alpha(b) - alpha(a)
                    0 <= alpha_interval_length(alpha, I)
        case b <= a:
            by cases:
                ? 0 <= alpha_interval_length(alpha, I)
                case I = '[a, b]:
                    alpha_interval_length(alpha, I) = alpha_interval_length(alpha, '[a, b])
                    alpha_interval_length(alpha, '[a, b]) = 0
                    0 <= alpha_interval_length(alpha, I)
                case I = '[a, b):
                    alpha_interval_length(alpha, I) = alpha_interval_length(alpha, '[a, b))
                    alpha_interval_length(alpha, '[a, b)) = 0
                    0 <= alpha_interval_length(alpha, I)
                case I = '(a, b]:
                    alpha_interval_length(alpha, I) = alpha_interval_length(alpha, '(a, b])
                    alpha_interval_length(alpha, '(a, b]) = 0
                    0 <= alpha_interval_length(alpha, I)
                case I = '(a, b):
                    alpha_interval_length(alpha, I) = alpha_interval_length(alpha, '(a, b))
                    alpha_interval_length(alpha, '(a, b)) = 0
                    0 <= alpha_interval_length(alpha, I)

thm identity_alpha_endpoint_lengths_match_interval_lengths:
    ? forall a, b R:
        alpha_interval_length(identity_alpha, '[a, b]) = interval_length('[a, b])
        alpha_interval_length(identity_alpha, '[a, b)) = interval_length('[a, b))
        alpha_interval_length(identity_alpha, '(a, b]) = interval_length('(a, b])
        alpha_interval_length(identity_alpha, '(a, b)) = interval_length('(a, b))
    # The identity alpha makes the endpoint difference `alpha(b)-alpha(a)`
    # exactly the ordinary endpoint difference.
    claim:
        ? alpha_interval_length(identity_alpha, '[a, b]) = interval_length('[a, b])
        by thm real_order_split_lt_or_ge(a, b)
        by cases:
            ? alpha_interval_length(identity_alpha, '[a, b]) = interval_length('[a, b])
            case a < b:
                by thm non_degenerate_interval_forms_length_value(a, b)
                alpha_interval_length(identity_alpha, '[a, b]) = identity_alpha(b) - identity_alpha(a)
                identity_alpha(b) = b
                identity_alpha(a) = a
                identity_alpha(b) - identity_alpha(a) = b - a
                interval_length('[a, b]) = b - a
                alpha_interval_length(identity_alpha, '[a, b]) = interval_length('[a, b])
            case b <= a:
                by thm interval_endpoint_forms_zero_length_value_when_nonpositive(a, b)
                alpha_interval_length(identity_alpha, '[a, b]) = 0
                interval_length('[a, b]) = 0
                alpha_interval_length(identity_alpha, '[a, b]) = interval_length('[a, b])
    claim:
        ? alpha_interval_length(identity_alpha, '[a, b)) = interval_length('[a, b))
        by thm real_order_split_lt_or_ge(a, b)
        by cases:
            ? alpha_interval_length(identity_alpha, '[a, b)) = interval_length('[a, b))
            case a < b:
                by thm non_degenerate_interval_forms_length_value(a, b)
                alpha_interval_length(identity_alpha, '[a, b)) = identity_alpha(b) - identity_alpha(a)
                identity_alpha(b) = b
                identity_alpha(a) = a
                identity_alpha(b) - identity_alpha(a) = b - a
                interval_length('[a, b)) = b - a
                alpha_interval_length(identity_alpha, '[a, b)) = interval_length('[a, b))
            case b <= a:
                by thm interval_endpoint_forms_zero_length_value_when_nonpositive(a, b)
                alpha_interval_length(identity_alpha, '[a, b)) = 0
                interval_length('[a, b)) = 0
                alpha_interval_length(identity_alpha, '[a, b)) = interval_length('[a, b))
    claim:
        ? alpha_interval_length(identity_alpha, '(a, b]) = interval_length('(a, b])
        by thm real_order_split_lt_or_ge(a, b)
        by cases:
            ? alpha_interval_length(identity_alpha, '(a, b]) = interval_length('(a, b])
            case a < b:
                by thm non_degenerate_interval_forms_length_value(a, b)
                alpha_interval_length(identity_alpha, '(a, b]) = identity_alpha(b) - identity_alpha(a)
                identity_alpha(b) = b
                identity_alpha(a) = a
                identity_alpha(b) - identity_alpha(a) = b - a
                interval_length('(a, b]) = b - a
                alpha_interval_length(identity_alpha, '(a, b]) = interval_length('(a, b])
            case b <= a:
                by thm interval_endpoint_forms_zero_length_value_when_nonpositive(a, b)
                alpha_interval_length(identity_alpha, '(a, b]) = 0
                interval_length('(a, b]) = 0
                alpha_interval_length(identity_alpha, '(a, b]) = interval_length('(a, b])
    claim:
        ? alpha_interval_length(identity_alpha, '(a, b)) = interval_length('(a, b))
        by thm real_order_split_lt_or_ge(a, b)
        by cases:
            ? alpha_interval_length(identity_alpha, '(a, b)) = interval_length('(a, b))
            case a < b:
                by thm non_degenerate_interval_forms_length_value(a, b)
                alpha_interval_length(identity_alpha, '(a, b)) = identity_alpha(b) - identity_alpha(a)
                identity_alpha(b) = b
                identity_alpha(a) = a
                identity_alpha(b) - identity_alpha(a) = b - a
                interval_length('(a, b)) = b - a
                alpha_interval_length(identity_alpha, '(a, b)) = interval_length('(a, b))
            case b <= a:
                by thm interval_endpoint_forms_zero_length_value_when_nonpositive(a, b)
                alpha_interval_length(identity_alpha, '(a, b)) = 0
                interval_length('(a, b)) = 0
                alpha_interval_length(identity_alpha, '(a, b)) = interval_length('(a, b))

thm identity_alpha_length_is_interval_length:
    ? forall I power_set(R):
        $is_bounded_interval(I)
        =>:
            alpha_interval_length(identity_alpha, I) = interval_length(I)
    # Source handling: Tao marks this as `(why?)`; it is the case
    # `alpha(b)-alpha(a)=b-a`.
    obtain a, b from exist a, b R st {$has_interval_endpoints(I, a, b)}
    I = '[a, b] or I = '[a, b) or I = '(a, b] or I = '(a, b)
    by thm identity_alpha_endpoint_lengths_match_interval_lengths(a, b)
    by cases:
        ? alpha_interval_length(identity_alpha, I) = interval_length(I)
        case I = '[a, b]:
            alpha_interval_length(identity_alpha, I) = alpha_interval_length(identity_alpha, '[a, b])
            interval_length(I) = interval_length('[a, b])
            alpha_interval_length(identity_alpha, '[a, b]) = interval_length('[a, b])
            alpha_interval_length(identity_alpha, I) = interval_length(I)
        case I = '[a, b):
            alpha_interval_length(identity_alpha, I) = alpha_interval_length(identity_alpha, '[a, b))
            interval_length(I) = interval_length('[a, b))
            alpha_interval_length(identity_alpha, '[a, b)) = interval_length('[a, b))
            alpha_interval_length(identity_alpha, I) = interval_length(I)
        case I = '(a, b]:
            alpha_interval_length(identity_alpha, I) = alpha_interval_length(identity_alpha, '(a, b])
            interval_length(I) = interval_length('(a, b])
            alpha_interval_length(identity_alpha, '(a, b]) = interval_length('(a, b])
            alpha_interval_length(identity_alpha, I) = interval_length(I)
        case I = '(a, b):
            alpha_interval_length(identity_alpha, I) = alpha_interval_length(identity_alpha, '(a, b))
            interval_length(I) = interval_length('(a, b))
            alpha_interval_length(identity_alpha, '(a, b)) = interval_length('(a, b))
            alpha_interval_length(identity_alpha, I) = interval_length(I)

"""
Lemma 11.8.4.  Alpha-length is finitely additive over partitions.
"""

# Alpha-length has the same endpoint-piece splitting law as ordinary length;
# its numerical step is the telescoping identity
# `(alpha(c)-alpha(a)) = (alpha(b)-alpha(a)) + (alpha(c)-alpha(b))`.
thm alpha_interval_length_adds_across_bounded_difference:
    ? forall I, J power_set(R), alpha fn(x R) R:
        $is_bounded_interval(I)
        $is_bounded_interval(J)
        J $subset I
        $is_bounded_interval(set_minus(I, J))
        =>:
            alpha_interval_length(alpha, I) = alpha_interval_length(alpha, J) + alpha_interval_length(alpha, set_minus(I, J))
    # Source handling: Lemma 11.8.4 leaves its finite-additivity proof to
    # Exercise 11.8.1.  The trust records the source-deferred alpha-length
    # splitting step used by the otherwise checked partition induction.
    # proof_debt: classify the compatible endpoint forms of the removed piece
    # and the bounded remainder, then telescope their alpha-endpoint values.
    trust alpha_interval_length(alpha, I) = alpha_interval_length(alpha, J) + alpha_interval_length(alpha, set_minus(I, J))

thm alpha_length_is_finitely_additive_over_partition:
    ? forall I power_set(R), P finite_set, alpha fn(x R) R:
        $is_partition_of_bounded_interval(I, P)
        =>:
            P $in power_set(power_set(R))
            alpha_interval_length(alpha, I) = finite_set_sum(P, fn(J P) R {alpha_interval_length(alpha, J)})
    claim:
        ? P $subset power_set(R)
        forall J P:
            J $in power_set(R)
    P $in power_set(power_set(R))
    alpha_interval_length(alpha, {}) = 0
    claim:
        ? forall I0, J0 power_set(R):
            $is_bounded_interval(I0)
            $is_bounded_interval(J0)
            J0 $subset I0
            $is_bounded_interval(set_minus(I0, J0))
            =>:
                alpha_interval_length(alpha, I0) = alpha_interval_length(alpha, J0) + alpha_interval_length(alpha, set_minus(I0, J0))
        by thm alpha_interval_length_adds_across_bounded_difference(I0, J0, alpha)
    by thm interval_weight_is_finitely_additive_over_partition(fn(J power_set(R): $is_bounded_interval(J)) R {alpha_interval_length(alpha, J)}, I, P)
    alpha_interval_length(alpha, I) = finite_set_sum(P, fn(J P) R {alpha_interval_length(alpha, J)})

# The alpha-length version of the refinement-fiber bridge has the same
# partition structure as ordinary length. Its only numerical dependency is
# the source-facing finite alpha-additivity theorem above.
thm alpha_length_reindexes_over_refinement_fiber:
    ? forall I, Pfine, Pcoarse power_set(power_set(R)), F fn(L Pcoarse) power_set(power_set(R)), K Pcoarse, alpha fn(x R) R:
        $is_finite_set(Pfine)
        $is_finite_set(Pcoarse)
        $is_finer_partition_than(I, Pfine, Pcoarse)
        forall L Pcoarse:
            F(L) = refinement_fiber(Pfine, L)
        =>:
            alpha_interval_length(alpha, K) = finite_set_sum(F(K), fn(J F(K)) R {alpha_interval_length(alpha, J)})
    by thm refinement_fiber_family_is_finite_unique_cover(I, Pfine, Pcoarse, F)
    $is_finite_unique_cover_of(Pfine, nonempty_refinement_support(Pfine), Pcoarse, F)
    $is_finite_indexed_subfamily(Pfine, nonempty_refinement_support(Pfine), Pcoarse, F)
    $is_finite_set(F(K))
    F(K) = refinement_fiber(Pfine, K)
    by thm refinement_fiber_has_value(Pfine, K)
    $is_refinement_fiber(Pfine, K, refinement_fiber(Pfine, K))
    $is_refinement_fiber(Pfine, K, F(K))
    by thm refinement_fiber_partitions_coarse_piece(I, Pfine, Pcoarse, F(K), K)
    $is_partition_of_bounded_interval(K, F(K))
    by thm alpha_length_is_finitely_additive_over_partition(K, F(K), alpha)
    alpha_interval_length(alpha, K) = finite_set_sum(F(K), fn(J F(K)) R {alpha_interval_length(alpha, J)})

"""
Definition 11.8.5 (Piecewise constant Riemann-Stieltjes integral).  Replace the
ordinary length in the piecewise constant integral by alpha-length.
"""

prop has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I power_set(R), J power_set(R), alpha fn(x R) R, f fn(x I) R, t R):
    $is_bounded_interval(J)
    $is_constant_on_subset(I, J, f)
    exist c R st {$has_constant_value_on_subset(I, J, f, c), t = c * alpha_interval_length(alpha, J)}

thm empty_bounded_interval_alpha_length_value:
    ? forall alpha fn(x R) R, J power_set(R):
        $is_bounded_interval(J)
        not $is_nonempty_set(J)
        =>:
            alpha_interval_length(alpha, J) = 0
    # An empty bounded interval is literally the empty set, whose alpha-length
    # is fixed by the source-facing alpha-length selector.
    by extension J = {}:
        claim:
            ? forall x J:
                x $in {}
            by contra:
                ? x $in {}
                not $is_nonempty_set(J)
                witness $is_nonempty_set(J) from x:
                    x $in J
                impossible $is_nonempty_set(J)
        claim:
            ? forall x {}:
                x $in J
            by contra:
                ? x $in J
                x $in {}
                impossible x $in {}
    alpha_interval_length(alpha, {}) = 0
    J = {}
    alpha_interval_length(alpha, J) = alpha_interval_length(alpha, {}) = 0

thm piecewise_constant_riemann_stieltjes_integral_piece_contribution_monotone:
    ? forall I power_set(R), J power_set(R), alpha fn(x R) R, f, g fn(x I) R, sf, sg R:
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, sf)
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, g, sg)
        $chap9::is_monotone_increasing_on(R, alpha)
        forall x I:
            g(x) <= f(x)
        =>:
            sg <= sf
    # Compare the two constant heights at a point of a nonempty piece; a
    # monotone integrator gives the non-negative alpha-length weight. Empty
    # pieces have zero alpha-length and hence zero contribution on both sides.
    $is_bounded_interval(J)
    obtain cf from exist c R st {$has_constant_value_on_subset(I, J, f, c), sf = c * alpha_interval_length(alpha, J)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, J, g, c), sg = c * alpha_interval_length(alpha, J)}
    J $subset I
    sf = cf * alpha_interval_length(alpha, J)
    sg = cg * alpha_interval_length(alpha, J)
    by cases:
        ? sg <= sf
        case $is_nonempty_set(J):
            have x J
            x $in I
            g(x) <= f(x)
            g(x) = cg
            f(x) = cf
            cg <= cf
            by thm monotone_alpha_interval_length_nonnegative(J, alpha)
            0 <= alpha_interval_length(alpha, J)
            cg * alpha_interval_length(alpha, J) <= cf * alpha_interval_length(alpha, J)
            sg = cg * alpha_interval_length(alpha, J) <= cf * alpha_interval_length(alpha, J) = sf
        case not $is_nonempty_set(J):
            by thm empty_bounded_interval_alpha_length_value(alpha, J)
            alpha_interval_length(alpha, J) = 0
            sg = cg * alpha_interval_length(alpha, J) = cg * 0 = 0
            sf = cf * alpha_interval_length(alpha, J) = cf * 0 = 0
            sg <= sf

thm piecewise_constant_riemann_stieltjes_piece_contribution_unique:
    ? forall I, J power_set(R), alpha fn(x R) R, f fn(x I) R, t1, t2 R:
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, t1)
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, t2)
        =>:
            t1 = t2
    # A nonempty piece fixes its constant height.  On an empty piece every
    # height gives the same zero alpha-rectangle.
    obtain c1 from exist c R st {$has_constant_value_on_subset(I, J, f, c), t1 = c * alpha_interval_length(alpha, J)}
    obtain c2 from exist c R st {$has_constant_value_on_subset(I, J, f, c), t2 = c * alpha_interval_length(alpha, J)}
    $has_constant_value_on_subset(I, J, f, c1)
    $has_constant_value_on_subset(I, J, f, c2)
    t1 = c1 * alpha_interval_length(alpha, J)
    t2 = c2 * alpha_interval_length(alpha, J)
    by cases:
        ? t1 = t2
        case $is_nonempty_set(J):
            by thm nonempty_constant_value_unique(I, J, f, c1, c2)
            c1 = c2
            t1 = c1 * alpha_interval_length(alpha, J) = c2 * alpha_interval_length(alpha, J) = t2
        case not $is_nonempty_set(J):
            by thm empty_bounded_interval_alpha_length_value(alpha, J)
            t1 = c1 * alpha_interval_length(alpha, J) = c1 * 0 = 0
            t2 = c2 * alpha_interval_length(alpha, J) = c2 * 0 = 0
            t1 = t2

have fn piecewise_constant_riemann_stieltjes_integral_piece_contribution by exist!:
    ? forall I, J power_set(R), alpha fn(x R) R, f fn(x I) R:
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        =>:
            exist! t R st {$has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, t)}
    obtain cv from exist c R st {$has_constant_value_on_subset(I, J, f, c)}
    witness exist t R st {$has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, t)} from cv * alpha_interval_length(alpha, J):
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        witness exist c R st {$has_constant_value_on_subset(I, J, f, c), cv * alpha_interval_length(alpha, J) = c * alpha_interval_length(alpha, J)} from cv:
            $has_constant_value_on_subset(I, J, f, cv)
            cv * alpha_interval_length(alpha, J) = cv * alpha_interval_length(alpha, J)
        exist c R st {$has_constant_value_on_subset(I, J, f, c), cv * alpha_interval_length(alpha, J) = c * alpha_interval_length(alpha, J)}
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, cv * alpha_interval_length(alpha, J))
    claim:
        ? forall t1, t2 R:
            $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, t1)
            $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, t2)
            =>:
                t1 = t2
        by thm piecewise_constant_riemann_stieltjes_piece_contribution_unique(I, J, alpha, f, t1, t2)
    exist! t R st {$has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, t)}

thm piecewise_constant_riemann_stieltjes_piece_contribution_has_value:
    ? forall I, J power_set(R), alpha fn(x R) R, f fn(x I) R, t R:
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, t)
        =>:
            piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f) = t
    $is_bounded_interval(J)
    $is_constant_on_subset(I, J, f)
    $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f))
    by thm piecewise_constant_riemann_stieltjes_piece_contribution_unique(I, J, alpha, f, piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f), t)
    piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f) = t

# A constant alpha-rectangle distributes over any partition carrying the
# corresponding alpha-length equality. Refinement fibers are a later caller.
thm constant_stieltjes_rectangle_reindexes_over_partition:
    ? forall I, K power_set(R), F finite_set, alpha fn(x R) R, f fn(x I) R, c R:
        $is_bounded_interval(K)
        $has_constant_value_on_subset(I, K, f, c)
        $is_partition_of_bounded_interval(K, F)
        alpha_interval_length(alpha, K) = finite_set_sum(F, fn(J F) R {alpha_interval_length(alpha, J)})
        =>:
            piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f) = finite_set_sum(F, fn(J F) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})
    claim:
        ? $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f, c * alpha_interval_length(alpha, K))
        witness exist c0 R st {$has_constant_value_on_subset(I, K, f, c0), c * alpha_interval_length(alpha, K) = c0 * alpha_interval_length(alpha, K)} from c:
            $has_constant_value_on_subset(I, K, f, c)
            c * alpha_interval_length(alpha, K) = c * alpha_interval_length(alpha, K)
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f, c * alpha_interval_length(alpha, K))
    by thm piecewise_constant_riemann_stieltjes_piece_contribution_has_value(I, K, alpha, f, c * alpha_interval_length(alpha, K))
    piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f) = c * alpha_interval_length(alpha, K)
    claim:
        ? forall J F:
            piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f) = c * alpha_interval_length(alpha, J)
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset K
        claim:
            ? $has_constant_value_on_subset(I, J, f, c)
            J $subset K
            K $subset I
            J $subset I
            forall x J:
                x $in K
                f(x) = c
            $has_constant_value_on_subset(I, J, f, c)
        claim:
            ? $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, c * alpha_interval_length(alpha, J))
            witness exist c0 R st {$has_constant_value_on_subset(I, J, f, c0), c * alpha_interval_length(alpha, J) = c0 * alpha_interval_length(alpha, J)} from c:
                $has_constant_value_on_subset(I, J, f, c)
                c * alpha_interval_length(alpha, J) = c * alpha_interval_length(alpha, J)
            $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, c * alpha_interval_length(alpha, J))
        by thm piecewise_constant_riemann_stieltjes_piece_contribution_has_value(I, J, alpha, f, c * alpha_interval_length(alpha, J))
        piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f) = c * alpha_interval_length(alpha, J)
    claim:
        ? $fn_eq(fn(J F) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)}, fn(J F) R {c * alpha_interval_length(alpha, J)})
        forall J F:
            piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f) = c * alpha_interval_length(alpha, J)
            fn(J F) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)}(J) = piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)
            fn(J F) R {c * alpha_interval_length(alpha, J)}(J) = c * alpha_interval_length(alpha, J)
            fn(J F) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)}(J) = fn(J F) R {c * alpha_interval_length(alpha, J)}(J)
        $fn_eq(fn(J F) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)}, fn(J F) R {c * alpha_interval_length(alpha, J)})
    fn(J F) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)} = fn(J F) R {c * alpha_interval_length(alpha, J)}
    finite_set_sum(F, fn(J F) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)}) = finite_set_sum(F, fn(J F) R {c * alpha_interval_length(alpha, J)})
    by thm chap7::finite_set_sum_scalar_mul(F, fn(J F) R {alpha_interval_length(alpha, J)}, c)
    finite_set_sum(F, fn(J F) R {c * alpha_interval_length(alpha, J)}) = c * finite_set_sum(F, fn(J F) R {alpha_interval_length(alpha, J)})
    piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f) = c * alpha_interval_length(alpha, K) = c * finite_set_sum(F, fn(J F) R {alpha_interval_length(alpha, J)}) = finite_set_sum(F, fn(J F) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})

prop is_piecewise_constant_riemann_stieltjes_contribution_family(I power_set(R), P finite_set, alpha fn(x R) R, f fn(x I) R, c fn(J P) R):
    forall J P:
        J $in power_set(R)
        =>:
            $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, c(J))

prop has_piecewise_constant_riemann_stieltjes_integral_with_partition(I power_set(R), P finite_set, alpha fn(x R) R, f fn(x I) R, s R):
    P $in power_set(power_set(R))
    $is_piecewise_constant_with_partition(I, P, f)
    exist c fn(J P) R st {$is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, alpha, f, c), s = finite_set_sum(P, c)}

have fn piecewise_constant_riemann_stieltjes_integral_with_partition(I power_set(R), P power_set(power_set(R)), alpha fn(x R) R, f fn(x I) R: $is_finite_set(P), $is_piecewise_constant_with_partition(I, P, f)) R = finite_set_sum(P, fn(J P) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})

thm piecewise_constant_riemann_stieltjes_contribution_family_unique:
    ? forall I power_set(R), P finite_set, alpha fn(x R) R, f fn(x I) R, c1, c2 fn(J P) R:
        P $in power_set(power_set(R))
        $is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, alpha, f, c1)
        $is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, alpha, f, c2)
        =>:
            c1 = c2
    claim:
        ? forall J P:
            c1(J) = c2(J)
        J $in power_set(R)
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, c1(J))
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, c2(J))
        by thm piecewise_constant_riemann_stieltjes_piece_contribution_unique(I, J, alpha, f, c1(J), c2(J))
        c1(J) = c2(J)
    claim:
        ? $fn_eq(c1, c2)
        forall J P:
            c1(J) = c2(J)
        $fn_eq(c1, c2)
    c1 = c2

thm piecewise_constant_riemann_stieltjes_integral_with_partition_value_unique:
    ? forall I power_set(R), P finite_set, alpha fn(x R) R, f fn(x I) R, s1, s2 R:
        $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f, s1)
        $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f, s2)
        =>:
            s1 = s2
    P $in power_set(power_set(R))
    obtain c1 from exist c fn(J P) R st {$is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, alpha, f, c), s1 = finite_set_sum(P, c)}
    obtain c2 from exist c fn(J P) R st {$is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, alpha, f, c), s2 = finite_set_sum(P, c)}
    by thm piecewise_constant_riemann_stieltjes_contribution_family_unique(I, P, alpha, f, c1, c2)
    c1 = c2
    finite_set_sum(P, c1) = finite_set_sum(P, c2)
    s1 = finite_set_sum(P, c1)
    s2 = finite_set_sum(P, c2)
    s1 = s2

thm piecewise_constant_riemann_stieltjes_integral_with_partition_has_value:
    ? forall I power_set(R), P power_set(power_set(R)), alpha fn(x R) R, f fn(x I) R:
        $is_finite_set(P)
        $is_piecewise_constant_with_partition(I, P, f)
        =>:
            $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f, piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f))
    claim:
        ? $is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, alpha, f, fn(J P) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})
        forall J P:
            J $in power_set(R)
            =>:
                $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, fn(J P) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)}(J))
        $is_partition_of_bounded_interval(I, P)
        J $in power_set(R)
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f))
        fn(J P) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)}(J) = piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, fn(J P) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)}(J))
    piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f) = finite_set_sum(P, fn(J P) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})
    witness exist c fn(J P) R st {$is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, alpha, f, c), piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f) = finite_set_sum(P, c)} from fn(J P) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)}:
        $is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, alpha, f, fn(J P) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})
        piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f) = finite_set_sum(P, fn(J P) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})
    $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f, piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f))

thm piecewise_constant_riemann_stieltjes_integral_with_same_partition_monotone:
    ? forall I power_set(R), P finite_set, alpha fn(x R) R, f, g fn(x I) R, sf, sg R:
        $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f, sf)
        $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, g, sg)
        $chap9::is_monotone_increasing_on(R, alpha)
        forall x I:
            g(x) <= f(x)
        =>:
            sg <= sf
    P $in power_set(power_set(R))
    $is_piecewise_constant_with_partition(I, P, f)
    $is_piecewise_constant_with_partition(I, P, g)
    obtain cf from exist c fn(J P) R st {$is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, alpha, f, c), sf = finite_set_sum(P, c)}
    obtain cg from exist c fn(J P) R st {$is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, alpha, g, c), sg = finite_set_sum(P, c)}
    claim:
        ? forall J P:
            cg(J) <= cf(J)
        $is_partition_of_bounded_interval(I, P)
        J $in power_set(R)
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, cf(J))
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, g, cg(J))
        by thm piecewise_constant_riemann_stieltjes_integral_piece_contribution_monotone(I, J, alpha, f, g, cf(J), cg(J))
        cg(J) <= cf(J)
    by thm finite_set_sum_monotone_from_pointwise_order(P, cg, cf)
    finite_set_sum(P, cg) <= finite_set_sum(P, cf)
    sg = finite_set_sum(P, cg)
    sf = finite_set_sum(P, cf)
    sg <= sf

thm piecewise_constant_riemann_stieltjes_partition_sum_ignores_empty_pieces:
    ? forall I power_set(R), P finite_set, alpha fn(x R) R, f fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        =>:
            finite_set_sum(P, fn(J P) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)}) = finite_set_sum(nonempty_refinement_support(P), fn(J nonempty_refinement_support(P)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})
    claim:
        ? nonempty_refinement_support(P) $subset P
        forall J nonempty_refinement_support(P):
            J $in P
    claim:
        ? forall J P:
            not J $in nonempty_refinement_support(P)
            =>:
                piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f) = 0
        by contra:
            ? not $is_nonempty_set(J)
            $is_nonempty_set(J)
            J $in {X P: $is_nonempty_set(X)}
            J $in nonempty_refinement_support(P)
            impossible not J $in nonempty_refinement_support(P)
        $is_partition_of_bounded_interval(I, P)
        J $in power_set(R)
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        obtain c from exist c R st {$has_constant_value_on_subset(I, J, f, c)}
        by thm empty_bounded_interval_alpha_length_value(alpha, J)
        alpha_interval_length(alpha, J) = 0
        witness exist c0 R st {$has_constant_value_on_subset(I, J, f, c0), 0 = c0 * alpha_interval_length(alpha, J)} from c:
            $has_constant_value_on_subset(I, J, f, c)
            0 = c * 0 = c * alpha_interval_length(alpha, J)
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, 0)
        by thm piecewise_constant_riemann_stieltjes_piece_contribution_has_value(I, J, alpha, f, 0)
        piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f) = 0
    by thm finite_set_sum_ignores_zero_outside_subset(P, P, nonempty_refinement_support(P), fn(J P) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})
    finite_set_sum(P, fn(J P) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)}) = finite_set_sum(nonempty_refinement_support(P), fn(J nonempty_refinement_support(P)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})

thm piecewise_constant_riemann_stieltjes_integral_with_partition_reindexes_over_refinement:
    ? forall I power_set(R), Pcoarse, Pfine finite_set, alpha fn(x R) R, f fn(x I) R:
        $is_piecewise_constant_with_partition(I, Pcoarse, f)
        $is_finer_partition_than(I, Pfine, Pcoarse)
        =>:
            piecewise_constant_riemann_stieltjes_integral_with_partition(I, Pcoarse, alpha, f) = piecewise_constant_riemann_stieltjes_integral_with_partition(I, Pfine, alpha, f)
    by thm piecewise_constant_refines(I, Pcoarse, Pfine, f)
    $is_piecewise_constant_with_partition(I, Pfine, f)
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, Pcoarse, f)
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, Pfine, f)
    have fn F(K Pcoarse) power_set(power_set(R)) = refinement_fiber(Pfine, K)
    claim:
        ? forall K Pcoarse:
            F(K) = refinement_fiber(Pfine, K)
        F(K) = refinement_fiber(Pfine, K)
    claim:
        ? forall K Pcoarse:
            piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f) = finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})
        $is_partition_of_bounded_interval(I, Pcoarse)
        K $in power_set(R)
        $is_bounded_interval(K)
        K $subset I
        $is_constant_on_subset(I, K, f)
        obtain c from exist c R st {$has_constant_value_on_subset(I, K, f, c)}
        $has_constant_value_on_subset(I, K, f, c)
        by thm alpha_length_reindexes_over_refinement_fiber(I, Pfine, Pcoarse, F, K, alpha)
        alpha_interval_length(alpha, K) = finite_set_sum(F(K), fn(J F(K)) R {alpha_interval_length(alpha, J)})
        by thm refinement_fiber_partitions_coarse_piece(I, Pfine, Pcoarse, F(K), K)
        $is_partition_of_bounded_interval(K, F(K))
        by thm constant_stieltjes_rectangle_reindexes_over_partition(I, K, F(K), alpha, f, c)
        piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f) = finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})
    claim:
        ? $fn_eq(fn(K Pcoarse) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f)}, fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})})
        forall K Pcoarse:
            piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f) = finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})
            fn(K Pcoarse) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f)}(K) = piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f)
            fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})}(K) = finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})
            fn(K Pcoarse) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f)}(K) = fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})}(K)
        $fn_eq(fn(K Pcoarse) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f)}, fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})})
    fn(K Pcoarse) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f)} = fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})}
    piecewise_constant_riemann_stieltjes_integral_with_partition(I, Pcoarse, alpha, f) = finite_set_sum(Pcoarse, fn(K Pcoarse) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f)})
    finite_set_sum(Pcoarse, fn(K Pcoarse) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, K, alpha, f)}) = finite_set_sum(Pcoarse, fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})})
    by thm refinement_fiber_cover_reindexes_ambient_sum(I, Pfine, Pcoarse, F, fn(J Pfine) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})
    finite_set_sum(nonempty_refinement_support(Pfine), fn(J nonempty_refinement_support(Pfine)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)}) = finite_set_sum(Pcoarse, fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})})
    by thm piecewise_constant_riemann_stieltjes_partition_sum_ignores_empty_pieces(I, Pfine, alpha, f)
    finite_set_sum(Pfine, fn(J Pfine) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)}) = finite_set_sum(nonempty_refinement_support(Pfine), fn(J nonempty_refinement_support(Pfine)) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})
    piecewise_constant_riemann_stieltjes_integral_with_partition(I, Pfine, alpha, f) = finite_set_sum(Pfine, fn(J Pfine) R {piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f)})
    piecewise_constant_riemann_stieltjes_integral_with_partition(I, Pcoarse, alpha, f) = piecewise_constant_riemann_stieltjes_integral_with_partition(I, Pfine, alpha, f)

prop has_piecewise_constant_riemann_stieltjes_integral(I power_set(R), alpha fn(x R) R, f fn(x I) R, s R):
    $is_piecewise_constant_on(I, f)
    exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f), $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f, s)}

thm piecewise_constant_riemann_stieltjes_integral_independent_of_partition:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R, P, Qpart finite_set, sP, sQ R:
        $is_piecewise_constant_with_partition(I, P, f)
        $is_piecewise_constant_with_partition(I, Qpart, f)
        $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f, sP)
        $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, Qpart, alpha, f, sQ)
        =>:
            sP = sQ
    # This is the alpha-length counterpart of Proposition 11.2.13: transport
    # both finite sums to their common refinement.
    $is_partition_of_bounded_interval(I, P)
    $is_partition_of_bounded_interval(I, Qpart)
    by thm partition_is_set_of_real_subsets(I, P)
    by thm partition_is_set_of_real_subsets(I, Qpart)
    have Rf finite_set = common_refinement(I, P, Qpart)
    $is_common_refinement_of_partitions(I, P, Qpart, Rf)
    by thm common_refinement_is_partition_and_finer(I, P, Qpart, Rf)
    $is_finer_partition_than(I, Rf, P)
    $is_finer_partition_than(I, Rf, Qpart)
    by thm piecewise_constant_riemann_stieltjes_integral_with_partition_reindexes_over_refinement(I, P, Rf, alpha, f)
    piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f) = piecewise_constant_riemann_stieltjes_integral_with_partition(I, Rf, alpha, f)
    by thm piecewise_constant_riemann_stieltjes_integral_with_partition_reindexes_over_refinement(I, Qpart, Rf, alpha, f)
    piecewise_constant_riemann_stieltjes_integral_with_partition(I, Qpart, alpha, f) = piecewise_constant_riemann_stieltjes_integral_with_partition(I, Rf, alpha, f)
    by thm piecewise_constant_riemann_stieltjes_integral_with_partition_has_value(I, P, alpha, f)
    $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f, piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f))
    by thm piecewise_constant_riemann_stieltjes_integral_with_partition_value_unique(I, P, alpha, f, sP, piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f))
    sP = piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f)
    by thm piecewise_constant_riemann_stieltjes_integral_with_partition_has_value(I, Qpart, alpha, f)
    $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, Qpart, alpha, f, piecewise_constant_riemann_stieltjes_integral_with_partition(I, Qpart, alpha, f))
    by thm piecewise_constant_riemann_stieltjes_integral_with_partition_value_unique(I, Qpart, alpha, f, sQ, piecewise_constant_riemann_stieltjes_integral_with_partition(I, Qpart, alpha, f))
    sQ = piecewise_constant_riemann_stieltjes_integral_with_partition(I, Qpart, alpha, f)
    sP = piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f) = piecewise_constant_riemann_stieltjes_integral_with_partition(I, Rf, alpha, f) = piecewise_constant_riemann_stieltjes_integral_with_partition(I, Qpart, alpha, f) = sQ

thm piecewise_constant_riemann_stieltjes_integral_value_unique:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R, s1, s2 R:
        $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, f, s1)
        $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, f, s2)
        =>:
            s1 = s2
    obtain P from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f), $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f, s1)}
    obtain Qpart from exist Qpart finite_set st {$is_piecewise_constant_with_partition(I, Qpart, f), $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, Qpart, alpha, f, s2)}
    by thm piecewise_constant_riemann_stieltjes_integral_independent_of_partition(I, alpha, f, P, Qpart, s1, s2)
    s1 = s2

have fn piecewise_constant_riemann_stieltjes_integral by exist!:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R:
        $is_piecewise_constant_on(I, f)
        =>:
            exist! s R st {$has_piecewise_constant_riemann_stieltjes_integral(I, alpha, f, s)}
    obtain P from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f)}
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, P, f)
    by thm piecewise_constant_riemann_stieltjes_integral_with_partition_has_value(I, P, alpha, f)
    have s R = piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f)
    claim:
        ? exist s0 R st {$has_piecewise_constant_riemann_stieltjes_integral(I, alpha, f, s0)}
        witness exist s0 R st {$has_piecewise_constant_riemann_stieltjes_integral(I, alpha, f, s0)} from s:
            witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, f), $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P0, alpha, f, s)} from P:
                $is_piecewise_constant_with_partition(I, P, f)
                $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, f, s)
            $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, f, s)
    claim:
        ? forall s1, s2 R:
            $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, f, s1)
            $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, f, s2)
            =>:
                s1 = s2
        by thm piecewise_constant_riemann_stieltjes_integral_value_unique(I, alpha, f, s1, s2)
    exist! s0 R st {$has_piecewise_constant_riemann_stieltjes_integral(I, alpha, f, s)}

thm piecewise_constant_riemann_stieltjes_integral_has_value:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R:
        $is_piecewise_constant_on(I, f)
        =>:
            $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, f, piecewise_constant_riemann_stieltjes_integral(I, alpha, f))
    have s R = piecewise_constant_riemann_stieltjes_integral(I, alpha, f)
    $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, f, s)
    s = piecewise_constant_riemann_stieltjes_integral(I, alpha, f)
    $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, f, piecewise_constant_riemann_stieltjes_integral(I, alpha, f))

thm one_piece_piecewise_constant_riemann_stieltjes_integral_with_partition_value:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R, t R:
        $is_piecewise_constant_with_partition(I, {I}, f)
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, I, alpha, f, t)
        =>:
            $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, {I}, alpha, f, t)
    # On the one-piece partition, the Stieltjes sum is its only rectangle.
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, {I}, f)
    {I} $in power_set(power_set(R))
    claim:
        ? $is_piecewise_constant_riemann_stieltjes_contribution_family(I, {I}, alpha, f, fn(J {I}) R {t})
        claim:
            ? forall J {I}:
                J $in power_set(R)
                =>:
                    $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, fn(J {I}) R {t}(J))
            J = I
            fn(J {I}) R {t}(J) = t
            $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, I, alpha, f, t)
            $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, alpha, f, fn(J {I}) R {t}(J))
        $is_piecewise_constant_riemann_stieltjes_contribution_family(I, {I}, alpha, f, fn(J {I}) R {t})
    finite_set_sum({I}, fn(J {I}) R {t}) = t
    witness exist c fn(J {I}) R st {$is_piecewise_constant_riemann_stieltjes_contribution_family(I, {I}, alpha, f, c), t = finite_set_sum({I}, c)} from fn(J {I}) R {t}:
        $is_piecewise_constant_riemann_stieltjes_contribution_family(I, {I}, alpha, f, fn(J {I}) R {t})
        t = finite_set_sum({I}, fn(J {I}) R {t})
    $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, {I}, alpha, f, t)

thm piecewise_constant_riemann_stieltjes_integral_of_constant:
    ? forall I power_set(R), alpha fn(x R) R, c R:
        $is_bounded_interval(I)
        =>:
            $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, fn(x I) R {c}, c * alpha_interval_length(alpha, I))
    # The one-piece partition contributes the height `c` times alpha-length.
    by thm constant_function_is_piecewise_constant_with_one_piece_partition(I, c)
    by thm constant_function_is_piecewise_constant(I, c)
    claim:
        ? $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, I, alpha, fn(x I) R {c}, c * alpha_interval_length(alpha, I))
        claim:
            ? $has_constant_value_on_subset(I, I, fn(x I) R {c}, c)
            I $subset I
            forall x I:
                fn(x I) R {c}(x) = c
        witness exist c0 R st {$has_constant_value_on_subset(I, I, fn(x I) R {c}, c0), c * alpha_interval_length(alpha, I) = c0 * alpha_interval_length(alpha, I)} from c:
            $has_constant_value_on_subset(I, I, fn(x I) R {c}, c)
            c * alpha_interval_length(alpha, I) = c * alpha_interval_length(alpha, I)
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, I, alpha, fn(x I) R {c}, c * alpha_interval_length(alpha, I))
    by thm one_piece_piecewise_constant_riemann_stieltjes_integral_with_partition_value(I, alpha, fn(x I) R {c}, c * alpha_interval_length(alpha, I))
    $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, {I}, alpha, fn(x I) R {c}, c * alpha_interval_length(alpha, I))
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {c}), $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, fn(x I) R {c}, c * alpha_interval_length(alpha, I))} from {I}:
        $is_piecewise_constant_with_partition(I, {I}, fn(x I) R {c})
        $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, {I}, alpha, fn(x I) R {c}, c * alpha_interval_length(alpha, I))
    $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, fn(x I) R {c}, c * alpha_interval_length(alpha, I))

thm identity_alpha_piecewise_constant_contribution_from_ordinary:
    ? forall I, J power_set(R), f fn(x I) R, t R:
        $has_piecewise_constant_integral_piece_contribution(I, J, f, t)
        =>:
            $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, identity_alpha, f, t)
    # For identity alpha, the Stieltjes piece contribution is the ordinary
    # rectangle contribution because the two interval lengths agree.
    $is_bounded_interval(J)
    $is_constant_on_subset(I, J, f)
    obtain c from exist c R st {$has_constant_value_on_subset(I, J, f, c), t = c * interval_length(J)}
    $has_constant_value_on_subset(I, J, f, c)
    t = c * interval_length(J)
    by thm identity_alpha_length_is_interval_length(J)
    alpha_interval_length(identity_alpha, J) = interval_length(J)
    c * alpha_interval_length(identity_alpha, J) = c * interval_length(J)
    t = c * interval_length(J) = c * alpha_interval_length(identity_alpha, J)
    witness exist c0 R st {$has_constant_value_on_subset(I, J, f, c0), t = c0 * alpha_interval_length(identity_alpha, J)} from c:
        $has_constant_value_on_subset(I, J, f, c)
        t = c * alpha_interval_length(identity_alpha, J)
    $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, identity_alpha, f, t)

thm identity_alpha_piecewise_constant_contribution_to_ordinary:
    ? forall I, J power_set(R), f fn(x I) R, t R:
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, identity_alpha, f, t)
        =>:
            $has_piecewise_constant_integral_piece_contribution(I, J, f, t)
    # The reverse identity-alpha conversion unfolds the Stieltjes rectangle
    # witness and replaces its alpha-length by the ordinary interval length.
    $is_bounded_interval(J)
    $is_constant_on_subset(I, J, f)
    obtain c from exist c R st {$has_constant_value_on_subset(I, J, f, c), t = c * alpha_interval_length(identity_alpha, J)}
    $has_constant_value_on_subset(I, J, f, c)
    t = c * alpha_interval_length(identity_alpha, J)
    by thm identity_alpha_length_is_interval_length(J)
    alpha_interval_length(identity_alpha, J) = interval_length(J)
    t = c * interval_length(J)
    witness exist c0 R st {$has_constant_value_on_subset(I, J, f, c0), t = c0 * interval_length(J)} from c:
        $has_constant_value_on_subset(I, J, f, c)
        t = c * interval_length(J)
    $has_piecewise_constant_integral_piece_contribution(I, J, f, t)

"""
Example 11.8.6.  For `alpha(x)=x^2` and a function taking value `4` on
`[1,2)` and `2` on `[2,3]`, the piecewise constant Riemann-Stieltjes integral
is `4*(4-1)+2*(9-4)=22`.
"""

prop is_example_11_8_6_function(f fn(x '[1, 3]) R):
    forall x '[1, 3]:
        x < 2
        =>:
            f(x) = 4
    forall x '[1, 3]:
        x >= 2
        =>:
            f(x) = 2

thm example_11_8_6_partition_pieces_are_distinct:
    ? forall:
        '[1, 2) != '[2, 3]
    # The shared endpoint belongs to the right-closed piece but not to the
    # left half-open piece.
    by contra:
        ? '[1, 2) != '[2, 3]
        '[1, 2) = '[2, 3]
        2 $in '[2, 3]
        2 $in '[1, 2)
        2 < 2
        impossible 2 < 2

by thm example_11_8_6_partition_pieces_are_distinct()

have example_11_8_6_partition_set finite_set = {'[1, 2), '[2, 3]}

thm example_11_8_6_partition_piece_clauses:
    ? forall J example_11_8_6_partition_set:
        J $in power_set(R)
        $is_bounded_interval(J)
        J $subset '[1, 3]
    # Source handling: this is the displayed two-piece split in Example 11.8.6.
    by enumerate finite_set:
        ? forall K example_11_8_6_partition_set:
            K = '[1, 2) or K = '[2, 3]
    by cases:
        ? J $in power_set(R)
        ? $is_bounded_interval(J)
        ? J $subset '[1, 3]
        case J = '[1, 2):
            by thm non_degenerate_interval_forms_are_bounded_intervals(1, 2)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 3]
                forall x J:
                    x $in '[1, 2)
                    1 <= x
                    x < 2
                    x < 2 < 3
                    x < 3
                    x <= 3
                    x $in '[1, 3]
                J $subset '[1, 3]
        case J = '[2, 3]:
            by thm non_degenerate_interval_forms_are_bounded_intervals(2, 3)
            J $in power_set(R)
            $is_bounded_interval(J)
            claim:
                ? J $subset '[1, 3]
                forall x J:
                    x $in '[2, 3]
                    2 <= x
                    x <= 3
                    1 < 2 <= x
                    1 <= x
                    x $in '[1, 3]
                J $subset '[1, 3]

thm example_11_8_6_partition_pieces_have_unique_membership:
    ? forall x '[1, 3], J1, J2 example_11_8_6_partition_set:
        J1 $in power_set(R)
        J2 $in power_set(R)
        x $in J1
        x $in J2
        =>:
            J1 = J2
    by enumerate finite_set:
        ? forall J example_11_8_6_partition_set:
            J = '[1, 2) or J = '[2, 3]
    by cases:
        ? J1 = J2
        case J1 = '[1, 2):
            by cases:
                ? J1 = J2
                case J2 = '[1, 2):
                    J1 = '[1, 2)
                    J2 = '[1, 2)
                    J1 = J2
                case J2 = '[2, 3]:
                    x $in J1
                    x $in J2
                    x < 2
                    x >= 2
                    impossible 2 < 2
        case J1 = '[2, 3]:
            by cases:
                ? J1 = J2
                case J2 = '[1, 2):
                    x $in J1
                    x $in J2
                    x >= 2
                    x < 2
                    impossible 2 < 2
                case J2 = '[2, 3]:
                    J1 = '[2, 3]
                    J2 = '[2, 3]
                    J1 = J2

thm example_11_8_6_partition_unique_cover:
    ? forall x '[1, 3]:
        exist! J example_11_8_6_partition_set st {J $in power_set(R), x $in J}
    claim:
        ? exist J example_11_8_6_partition_set st {J $in power_set(R), x $in J}
        by cases:
            ? exist J example_11_8_6_partition_set st {J $in power_set(R), x $in J}
            case x < 2:
                claim:
                    ? '[1, 2) $in example_11_8_6_partition_set
                    '[1, 2) $in {'[1, 2), '[2, 3]}
                    example_11_8_6_partition_set = {'[1, 2), '[2, 3]}
                    '[1, 2) $in example_11_8_6_partition_set
                witness exist J example_11_8_6_partition_set st {J $in power_set(R), x $in J} from '[1, 2):
                    '[1, 2) $in example_11_8_6_partition_set
                    '[1, 2) $in power_set(R)
                    x $in '[1, 2)
            case x >= 2:
                claim:
                    ? '[2, 3] $in example_11_8_6_partition_set
                    '[2, 3] $in {'[1, 2), '[2, 3]}
                    example_11_8_6_partition_set = {'[1, 2), '[2, 3]}
                    '[2, 3] $in example_11_8_6_partition_set
                witness exist J example_11_8_6_partition_set st {J $in power_set(R), x $in J} from '[2, 3]:
                    '[2, 3] $in example_11_8_6_partition_set
                    '[2, 3] $in power_set(R)
                    x $in '[2, 3]
    claim:
        ? forall J1, J2 example_11_8_6_partition_set:
            J1 $in power_set(R)
            J2 $in power_set(R)
            x $in J1
            x $in J2
            =>:
                J1 = J2
        by thm example_11_8_6_partition_pieces_have_unique_membership(x, J1, J2)
    exist! J example_11_8_6_partition_set st {J $in power_set(R), x $in J}

thm example_11_8_6_displayed_partition_piecewise_constant:
    ? forall f fn(x '[1, 3]) R:
        $is_example_11_8_6_function(f)
        =>:
            $is_piecewise_constant_with_partition('[1, 3], example_11_8_6_partition_set, f)
    # The displayed split separates the two constant regions of the function.
    claim:
        ? $is_partition_of_bounded_interval('[1, 3], example_11_8_6_partition_set)
        by thm non_degenerate_interval_forms_are_bounded_intervals(1, 3)
        claim:
            ? forall J example_11_8_6_partition_set:
                J $in power_set(R)
                $is_bounded_interval(J)
                J $subset '[1, 3]
            by thm example_11_8_6_partition_piece_clauses(J)
        claim:
            ? forall x '[1, 3]:
                exist! J example_11_8_6_partition_set st {J $in power_set(R), x $in J}
            by thm example_11_8_6_partition_unique_cover(x)
        $is_partition_of_bounded_interval('[1, 3], example_11_8_6_partition_set)
    claim:
        ? forall J example_11_8_6_partition_set:
            J $in power_set(R)
            $is_constant_on_subset('[1, 3], J, f)
        # Source handling: this is the same two-piece split in Example 11.8.6.
        by enumerate finite_set:
            ? forall K example_11_8_6_partition_set:
                K = '[1, 2) or K = '[2, 3]
        by cases:
            ? J $in power_set(R)
            ? $is_constant_on_subset('[1, 3], J, f)
            case J = '[1, 2):
                by thm non_degenerate_interval_forms_are_bounded_intervals(1, 2)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 3]
                    forall x J:
                        x $in '[1, 2)
                        1 <= x
                        x < 2
                        x < 2 < 3
                        x < 3
                        x <= 3
                        x $in '[1, 3]
                    J $subset '[1, 3]
                witness exist c R st {$has_constant_value_on_subset('[1, 3], J, f, c)} from 4:
                    J $subset '[1, 3]
                    forall x J:
                        x $in '[1, 3]
                        x $in '[1, 2)
                        x < 2
                        f(x) = 4
                    $has_constant_value_on_subset('[1, 3], J, f, 4)
            case J = '[2, 3]:
                by thm non_degenerate_interval_forms_are_bounded_intervals(2, 3)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 3]
                    forall x J:
                        x $in '[2, 3]
                        2 <= x
                        x <= 3
                        1 < 2 <= x
                        1 <= x
                        x $in '[1, 3]
                    J $subset '[1, 3]
                witness exist c R st {$has_constant_value_on_subset('[1, 3], J, f, c)} from 2:
                    J $subset '[1, 3]
                    forall x J:
                        x $in '[1, 3]
                        x $in '[2, 3]
                        x >= 2
                        f(x) = 2
                    $has_constant_value_on_subset('[1, 3], J, f, 2)
    $is_piecewise_constant_with_partition('[1, 3], example_11_8_6_partition_set, f)

thm square_alpha_lengths_for_example_11_8_6:
    ? forall:
        alpha_interval_length(square_alpha, '[1, 2)) = 3
        alpha_interval_length(square_alpha, '[2, 3]) = 5
    # These are the two alpha-lengths used in the displayed Stieltjes sum.
    1 < 2
    alpha_interval_length(square_alpha, '[1, 2)) = square_alpha(2) - square_alpha(1)
    square_alpha(2) = 2^2
    square_alpha(1) = 1^2
    alpha_interval_length(square_alpha, '[1, 2)) = 2^2 - 1^2
    2^2 - 1^2 = 3
    2 < 3
    alpha_interval_length(square_alpha, '[2, 3]) = square_alpha(3) - square_alpha(2)
    square_alpha(3) = 3^2
    square_alpha(2) = 2^2
    alpha_interval_length(square_alpha, '[2, 3]) = 3^2 - 2^2
    3^2 - 2^2 = 5

thm example_11_8_6_stieltjes_piece_contribution_has_values:
    ? forall f fn(x '[1, 3]) R:
        $is_example_11_8_6_function(f)
        =>:
            $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution('[1, 3], '[1, 2), square_alpha, f, 12)
            $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution('[1, 3], '[2, 3], square_alpha, f, 10)
    # The alpha-lengths are `2^2-1^2=3` and `3^2-2^2=5`.
    claim:
        ? '[1, 2) $subset '[1, 3]
        forall x '[1, 2):
            x $in '[1, 2)
            1 <= x
            x < 2
            x < 2 < 3
            x < 3
            x <= 3
            x $in '[1, 3]
        '[1, 2) $subset '[1, 3]
    claim:
        ? $has_constant_value_on_subset('[1, 3], '[1, 2), f, 4)
        '[1, 2) $subset '[1, 3]
        forall x '[1, 2):
            x $in '[1, 3]
            x $in '[1, 2)
            x < 2
            f(x) = 4
    claim:
        ? $is_constant_on_subset('[1, 3], '[1, 2), f)
        witness exist c R st {$has_constant_value_on_subset('[1, 3], '[1, 2), f, c)} from 4:
            $has_constant_value_on_subset('[1, 3], '[1, 2), f, 4)
    by thm non_degenerate_interval_forms_are_bounded_intervals(1, 2)
    by thm square_alpha_lengths_for_example_11_8_6()
    alpha_interval_length(square_alpha, '[1, 2)) = 3
    claim:
        ? $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution('[1, 3], '[1, 2), square_alpha, f, 12)
        witness exist c R st {$has_constant_value_on_subset('[1, 3], '[1, 2), f, c), 12 = c * alpha_interval_length(square_alpha, '[1, 2))} from 4:
            $has_constant_value_on_subset('[1, 3], '[1, 2), f, 4)
            4 * alpha_interval_length(square_alpha, '[1, 2)) = 4 * 3 = 12
            12 = 4 * alpha_interval_length(square_alpha, '[1, 2))
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution('[1, 3], '[1, 2), square_alpha, f, 12)

    claim:
        ? '[2, 3] $subset '[1, 3]
        forall x '[2, 3]:
            x $in '[2, 3]
            2 <= x
            x <= 3
            1 < 2 <= x
            1 <= x
            x $in '[1, 3]
        '[2, 3] $subset '[1, 3]
    claim:
        ? $has_constant_value_on_subset('[1, 3], '[2, 3], f, 2)
        '[2, 3] $subset '[1, 3]
        forall x '[2, 3]:
            x $in '[1, 3]
            x $in '[2, 3]
            x >= 2
            f(x) = 2
    claim:
        ? $is_constant_on_subset('[1, 3], '[2, 3], f)
        witness exist c R st {$has_constant_value_on_subset('[1, 3], '[2, 3], f, c)} from 2:
            $has_constant_value_on_subset('[1, 3], '[2, 3], f, 2)
    by thm non_degenerate_interval_forms_are_bounded_intervals(2, 3)
    by thm square_alpha_lengths_for_example_11_8_6()
    alpha_interval_length(square_alpha, '[2, 3]) = 5
    claim:
        ? $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution('[1, 3], '[2, 3], square_alpha, f, 10)
        witness exist c R st {$has_constant_value_on_subset('[1, 3], '[2, 3], f, c), 10 = c * alpha_interval_length(square_alpha, '[2, 3])} from 2:
            $has_constant_value_on_subset('[1, 3], '[2, 3], f, 2)
            2 * alpha_interval_length(square_alpha, '[2, 3]) = 2 * 5 = 10
            10 = 2 * alpha_interval_length(square_alpha, '[2, 3])
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution('[1, 3], '[2, 3], square_alpha, f, 10)

have fn example_11_8_6_displayed_stieltjes_contribution(J {'[1, 2), '[2, 3]}) R by cases:
    case J = '[1, 2): 12
    case J = '[2, 3]: 10

thm example_11_8_6_displayed_stieltjes_contribution_family:
    ? forall f fn(x '[1, 3]) R:
        $is_example_11_8_6_function(f)
        =>:
            $is_piecewise_constant_riemann_stieltjes_contribution_family('[1, 3], {'[1, 2), '[2, 3]}, square_alpha, f, example_11_8_6_displayed_stieltjes_contribution)
    by thm example_11_8_6_stieltjes_piece_contribution_has_values(f)
    claim:
        ? forall J {'[1, 2), '[2, 3]}:
            J $in power_set(R)
            =>:
                $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution('[1, 3], J, square_alpha, f, example_11_8_6_displayed_stieltjes_contribution(J))
        J = '[1, 2) or J = '[2, 3]
        by cases:
            ? $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution('[1, 3], J, square_alpha, f, example_11_8_6_displayed_stieltjes_contribution(J))
            case J = '[1, 2):
                example_11_8_6_displayed_stieltjes_contribution(J) = example_11_8_6_displayed_stieltjes_contribution('[1, 2))
                example_11_8_6_displayed_stieltjes_contribution('[1, 2)) = 12
                $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution('[1, 3], '[1, 2), square_alpha, f, 12)
                $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution('[1, 3], J, square_alpha, f, example_11_8_6_displayed_stieltjes_contribution(J))
            case J = '[2, 3]:
                example_11_8_6_displayed_stieltjes_contribution(J) = example_11_8_6_displayed_stieltjes_contribution('[2, 3])
                example_11_8_6_displayed_stieltjes_contribution('[2, 3]) = 10
                $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution('[1, 3], '[2, 3], square_alpha, f, 10)
                $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution('[1, 3], J, square_alpha, f, example_11_8_6_displayed_stieltjes_contribution(J))
    $is_piecewise_constant_riemann_stieltjes_contribution_family('[1, 3], {'[1, 2), '[2, 3]}, square_alpha, f, example_11_8_6_displayed_stieltjes_contribution)

thm example_11_8_6_piecewise_constant_stieltjes_integral:
    ? forall f fn(x '[1, 3]) R:
        $is_example_11_8_6_function(f)
        =>:
            $has_piecewise_constant_riemann_stieltjes_integral_with_partition('[1, 3], {'[1, 2), '[2, 3]}, square_alpha, f, 22)
    # Source handling: Tao computes the two rectangle contributions directly.
    by thm example_11_8_6_displayed_partition_piecewise_constant(f)
    example_11_8_6_partition_set = {'[1, 2), '[2, 3]}
    $is_piecewise_constant_with_partition('[1, 3], {'[1, 2), '[2, 3]}, f)
    by thm piecewise_constant_partition_is_set_of_real_subsets('[1, 3], {'[1, 2), '[2, 3]}, f)
    by thm example_11_8_6_displayed_stieltjes_contribution_family(f)
    example_11_8_6_displayed_stieltjes_contribution('[1, 2)) = 12
    example_11_8_6_displayed_stieltjes_contribution('[2, 3]) = 10
    finite_set_sum({'[1, 2), '[2, 3]}, example_11_8_6_displayed_stieltjes_contribution) = 12 + 10
    12 + 10 = 22
    witness exist c fn(J {'[1, 2), '[2, 3]}) R st {$is_piecewise_constant_riemann_stieltjes_contribution_family('[1, 3], {'[1, 2), '[2, 3]}, square_alpha, f, c), 22 = finite_set_sum({'[1, 2), '[2, 3]}, c)} from example_11_8_6_displayed_stieltjes_contribution:
        $is_piecewise_constant_riemann_stieltjes_contribution_family('[1, 3], {'[1, 2), '[2, 3]}, square_alpha, f, example_11_8_6_displayed_stieltjes_contribution)
        22 = finite_set_sum({'[1, 2), '[2, 3]}, example_11_8_6_displayed_stieltjes_contribution)
    $has_piecewise_constant_riemann_stieltjes_integral_with_partition('[1, 3], {'[1, 2), '[2, 3]}, square_alpha, f, 22)

"""
Example 11.8.7.  With `alpha(x)=x`, the piecewise constant
Riemann-Stieltjes integral agrees with the ordinary piecewise constant
integral.
"""

thm identity_alpha_piecewise_constant_stieltjes_matches_ordinary:
    ? forall I power_set(R), P finite_set, f fn(x I) R, s R:
        $has_piecewise_constant_integral_with_partition(I, P, f, s)
        =>:
            $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, identity_alpha, f, s)
    # Source handling: Tao marks this as `(why?)`; it follows from
    # identity-alpha length equaling ordinary length.
    P $in power_set(power_set(R))
    $is_piecewise_constant_with_partition(I, P, f)
    have fn identity_stieltjes_contribution(J P) R = piecewise_constant_integral_piece_contribution(I, J, f)
    claim:
        ? $is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, identity_alpha, f, identity_stieltjes_contribution)
        claim:
            ? forall J P:
                J $in power_set(R)
                =>:
                    $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, identity_alpha, f, identity_stieltjes_contribution(J))
            $is_partition_of_bounded_interval(I, P)
            J $in power_set(R)
            $is_bounded_interval(J)
            $is_constant_on_subset(I, J, f)
            $has_piecewise_constant_integral_piece_contribution(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f))
            by thm identity_alpha_piecewise_constant_contribution_from_ordinary(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f))
            identity_stieltjes_contribution(J) = piecewise_constant_integral_piece_contribution(I, J, f)
            $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, identity_alpha, f, identity_stieltjes_contribution(J))
        $is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, identity_alpha, f, identity_stieltjes_contribution)
    piecewise_constant_integral_with_partition(I, P, f) = finite_set_sum(P, identity_stieltjes_contribution)
    s = piecewise_constant_integral_with_partition(I, P, f)
    s = finite_set_sum(P, identity_stieltjes_contribution)
    witness exist c fn(J P) R st {$is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, identity_alpha, f, c), s = finite_set_sum(P, c)} from identity_stieltjes_contribution:
        $is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, identity_alpha, f, identity_stieltjes_contribution)
        s = finite_set_sum(P, identity_stieltjes_contribution)
    $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, identity_alpha, f, s)

thm identity_alpha_piecewise_constant_ordinary_matches_stieltjes:
    ? forall I power_set(R), P finite_set, f fn(x I) R, s R:
        $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, identity_alpha, f, s)
        =>:
            $has_piecewise_constant_integral_with_partition(I, P, f, s)
    # Source handling: for identity alpha, every Stieltjes contribution has the
    # same constant value times the ordinary interval length.
    P $in power_set(power_set(R))
    $is_piecewise_constant_with_partition(I, P, f)
    obtain c from exist c fn(J P) R st {$is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, identity_alpha, f, c), s = finite_set_sum(P, c)}
    $is_piecewise_constant_riemann_stieltjes_contribution_family(I, P, identity_alpha, f, c)
    s = finite_set_sum(P, c)
    claim:
        ? forall J P:
            J $in power_set(R)
            =>:
                $has_piecewise_constant_integral_piece_contribution(I, J, f, c(J))
        $is_partition_of_bounded_interval(I, P)
        J $in power_set(R)
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        $has_piecewise_constant_riemann_stieltjes_integral_piece_contribution(I, J, identity_alpha, f, c(J))
        by thm identity_alpha_piecewise_constant_contribution_to_ordinary(I, J, f, c(J))
        $has_piecewise_constant_integral_piece_contribution(I, J, f, c(J))
    claim:
        ? forall J P:
            J $in power_set(R)
            =>:
                piecewise_constant_integral_piece_contribution(I, J, f) = c(J)
        $is_partition_of_bounded_interval(I, P)
        J $in power_set(R)
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        $has_piecewise_constant_integral_piece_contribution(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f))
        $has_piecewise_constant_integral_piece_contribution(I, J, f, c(J))
        by thm piecewise_constant_integral_piece_contribution_unique(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f), c(J))
    claim:
        ? $fn_eq(fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)}, c)
        forall K P:
            $is_partition_of_bounded_interval(I, P)
            K $in power_set(R)
            fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)}(K) = piecewise_constant_integral_piece_contribution(I, K, f)
            piecewise_constant_integral_piece_contribution(I, K, f) = c(K)
            fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)}(K) = c(K)
        $fn_eq(fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)}, c)
    fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)} = c
    piecewise_constant_integral_with_partition(I, P, f) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)}) = finite_set_sum(P, c)
    piecewise_constant_integral_with_partition(I, P, f) = finite_set_sum(P, c)
    s = piecewise_constant_integral_with_partition(I, P, f)
    $has_piecewise_constant_integral_with_partition(I, P, f, s)

thm identity_alpha_piecewise_constant_stieltjes_integral_from_ordinary:
    ? forall I power_set(R), f fn(x I) R, s R:
        $has_piecewise_constant_integral(I, f, s)
        =>:
            $has_piecewise_constant_riemann_stieltjes_integral(I, identity_alpha, f, s)
    # Source handling: choose the partition witnessing the ordinary piecewise
    # constant integral and reuse the identity-alpha contribution family.
    $is_piecewise_constant_on(I, f)
    obtain P from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f), $has_piecewise_constant_integral_with_partition(I, P, f, s)}
    by thm identity_alpha_piecewise_constant_stieltjes_matches_ordinary(I, P, f, s)
    $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, identity_alpha, f, s)
    witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, f), $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P0, identity_alpha, f, s)} from P:
        $is_piecewise_constant_with_partition(I, P, f)
        $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, identity_alpha, f, s)
    $has_piecewise_constant_riemann_stieltjes_integral(I, identity_alpha, f, s)

thm identity_alpha_piecewise_constant_ordinary_from_stieltjes_integral:
    ? forall I power_set(R), f fn(x I) R, s R:
        $has_piecewise_constant_riemann_stieltjes_integral(I, identity_alpha, f, s)
        =>:
            $has_piecewise_constant_integral(I, f, s)
    # Source handling: the witnessing Stieltjes partition has the same value
    # for the ordinary piecewise constant integral when alpha is the identity.
    $is_piecewise_constant_on(I, f)
    obtain P from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f), $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, identity_alpha, f, s)}
    by thm identity_alpha_piecewise_constant_ordinary_matches_stieltjes(I, P, f, s)
    $has_piecewise_constant_integral_with_partition(I, P, f, s)
    witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, f), $has_piecewise_constant_integral_with_partition(I, P0, f, s)} from P:
        $is_piecewise_constant_with_partition(I, P, f)
        $has_piecewise_constant_integral_with_partition(I, P, f, s)
    $has_piecewise_constant_integral(I, f, s)

"""
Riemann-Stieltjes integral.  With monotone increasing `alpha`, define upper and
lower Riemann-Stieltjes integrals exactly as before, using alpha-lengths; the
function is integrable when the two values match.
"""

prop is_upper_riemann_stieltjes_integral_candidate_value(I power_set(R), alpha fn(x R) R, f fn(x I) R, s R):
    exist g fn(x I) R st {$is_piecewise_constant_on(I, g), $majorizes_on(I, g, f), $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, g, s)}

prop is_lower_riemann_stieltjes_integral_candidate_value(I power_set(R), alpha fn(x R) R, f fn(x I) R, s R):
    exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, h, s)}

thm identity_alpha_upper_riemann_candidate_from_ordinary:
    ? forall I power_set(R), f fn(x I) R, s R:
        $is_upper_riemann_integral_candidate_value(I, f, s)
        =>:
            $is_upper_riemann_stieltjes_integral_candidate_value(I, identity_alpha, f, s)
    # Source handling: an ordinary piecewise-constant majorant has the same
    # candidate value for Stieltjes integration with the identity alpha.
    obtain g from exist g fn(x I) R st {$is_piecewise_constant_on(I, g), $majorizes_on(I, g, f), $has_piecewise_constant_integral(I, g, s)}
    $is_piecewise_constant_on(I, g)
    $majorizes_on(I, g, f)
    $has_piecewise_constant_integral(I, g, s)
    by thm identity_alpha_piecewise_constant_stieltjes_integral_from_ordinary(I, g, s)
    $has_piecewise_constant_riemann_stieltjes_integral(I, identity_alpha, g, s)
    witness exist g0 fn(x I) R st {$is_piecewise_constant_on(I, g0), $majorizes_on(I, g0, f), $has_piecewise_constant_riemann_stieltjes_integral(I, identity_alpha, g0, s)} from g:
        $is_piecewise_constant_on(I, g)
        $majorizes_on(I, g, f)
        $has_piecewise_constant_riemann_stieltjes_integral(I, identity_alpha, g, s)
    $is_upper_riemann_stieltjes_integral_candidate_value(I, identity_alpha, f, s)

thm identity_alpha_upper_riemann_candidate_to_ordinary:
    ? forall I power_set(R), f fn(x I) R, s R:
        $is_upper_riemann_stieltjes_integral_candidate_value(I, identity_alpha, f, s)
        =>:
            $is_upper_riemann_integral_candidate_value(I, f, s)
    # Source handling: the identity-alpha Stieltjes majorant contributes the
    # same ordinary piecewise-constant integral value.
    obtain g from exist g fn(x I) R st {$is_piecewise_constant_on(I, g), $majorizes_on(I, g, f), $has_piecewise_constant_riemann_stieltjes_integral(I, identity_alpha, g, s)}
    $is_piecewise_constant_on(I, g)
    $majorizes_on(I, g, f)
    $has_piecewise_constant_riemann_stieltjes_integral(I, identity_alpha, g, s)
    by thm identity_alpha_piecewise_constant_ordinary_from_stieltjes_integral(I, g, s)
    $has_piecewise_constant_integral(I, g, s)
    witness exist g0 fn(x I) R st {$is_piecewise_constant_on(I, g0), $majorizes_on(I, g0, f), $has_piecewise_constant_integral(I, g0, s)} from g:
        $is_piecewise_constant_on(I, g)
        $majorizes_on(I, g, f)
        $has_piecewise_constant_integral(I, g, s)
    $is_upper_riemann_integral_candidate_value(I, f, s)

thm identity_alpha_lower_riemann_candidate_from_ordinary:
    ? forall I power_set(R), f fn(x I) R, s R:
        $is_lower_riemann_integral_candidate_value(I, f, s)
        =>:
            $is_lower_riemann_stieltjes_integral_candidate_value(I, identity_alpha, f, s)
    # Source handling: an ordinary piecewise-constant minorant has the same
    # candidate value for identity-alpha Stieltjes integration.
    obtain h from exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_integral(I, h, s)}
    $is_piecewise_constant_on(I, h)
    $minorizes_on(I, h, f)
    $has_piecewise_constant_integral(I, h, s)
    by thm identity_alpha_piecewise_constant_stieltjes_integral_from_ordinary(I, h, s)
    $has_piecewise_constant_riemann_stieltjes_integral(I, identity_alpha, h, s)
    witness exist h0 fn(x I) R st {$is_piecewise_constant_on(I, h0), $minorizes_on(I, h0, f), $has_piecewise_constant_riemann_stieltjes_integral(I, identity_alpha, h0, s)} from h:
        $is_piecewise_constant_on(I, h)
        $minorizes_on(I, h, f)
        $has_piecewise_constant_riemann_stieltjes_integral(I, identity_alpha, h, s)
    $is_lower_riemann_stieltjes_integral_candidate_value(I, identity_alpha, f, s)

thm identity_alpha_lower_riemann_candidate_to_ordinary:
    ? forall I power_set(R), f fn(x I) R, s R:
        $is_lower_riemann_stieltjes_integral_candidate_value(I, identity_alpha, f, s)
        =>:
            $is_lower_riemann_integral_candidate_value(I, f, s)
    # Source handling: the identity-alpha Stieltjes minorant has the same
    # ordinary piecewise-constant integral value.
    obtain h from exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_riemann_stieltjes_integral(I, identity_alpha, h, s)}
    $is_piecewise_constant_on(I, h)
    $minorizes_on(I, h, f)
    $has_piecewise_constant_riemann_stieltjes_integral(I, identity_alpha, h, s)
    by thm identity_alpha_piecewise_constant_ordinary_from_stieltjes_integral(I, h, s)
    $has_piecewise_constant_integral(I, h, s)
    witness exist h0 fn(x I) R st {$is_piecewise_constant_on(I, h0), $minorizes_on(I, h0, f), $has_piecewise_constant_integral(I, h0, s)} from h:
        $is_piecewise_constant_on(I, h)
        $minorizes_on(I, h, f)
        $has_piecewise_constant_integral(I, h, s)
    $is_lower_riemann_integral_candidate_value(I, f, s)

have fn upper_riemann_stieltjes_integral_candidate_values(I power_set(R), alpha fn(x R) R, f fn(x I) R) power_set(R) = {s R: $is_upper_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)}

have fn lower_riemann_stieltjes_integral_candidate_values(I power_set(R), alpha fn(x R) R, f fn(x I) R) power_set(R) = {s R: $is_lower_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)}

thm upper_riemann_stieltjes_integral_candidate_value_member:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R, s R:
        $is_upper_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)
        =>:
            s $in upper_riemann_stieltjes_integral_candidate_values(I, alpha, f)
    upper_riemann_stieltjes_integral_candidate_values(I, alpha, f) = {s R: $is_upper_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)}
    s $in {s R: $is_upper_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)}
    s $in upper_riemann_stieltjes_integral_candidate_values(I, alpha, f)

thm upper_riemann_stieltjes_integral_candidate_value_from_member:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R, s R:
        s $in upper_riemann_stieltjes_integral_candidate_values(I, alpha, f)
        =>:
            $is_upper_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)
    upper_riemann_stieltjes_integral_candidate_values(I, alpha, f) = {s R: $is_upper_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)}
    s $in {s R: $is_upper_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)}
    $is_upper_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)

thm lower_riemann_stieltjes_integral_candidate_value_member:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R, s R:
        $is_lower_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)
        =>:
            s $in lower_riemann_stieltjes_integral_candidate_values(I, alpha, f)
    lower_riemann_stieltjes_integral_candidate_values(I, alpha, f) = {s R: $is_lower_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)}
    s $in {s R: $is_lower_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)}
    s $in lower_riemann_stieltjes_integral_candidate_values(I, alpha, f)

thm lower_riemann_stieltjes_integral_candidate_value_from_member:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R, s R:
        s $in lower_riemann_stieltjes_integral_candidate_values(I, alpha, f)
        =>:
            $is_lower_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)
    lower_riemann_stieltjes_integral_candidate_values(I, alpha, f) = {s R: $is_lower_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)}
    s $in {s R: $is_lower_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)}
    $is_lower_riemann_stieltjes_integral_candidate_value(I, alpha, f, s)

thm piecewise_constant_stieltjes_minorant_integral_le_majorant_integral:
    ? forall I power_set(R), alpha fn(x R) R, f, g, h fn(x I) R, sg, sh R:
        $is_bounded_interval(I)
        $chap9::is_monotone_increasing_on(R, alpha)
        $majorizes_on(I, g, f)
        $minorizes_on(I, h, f)
        $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, g, sg)
        $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, h, sh)
        =>:
            sh <= sg
    # A common refinement makes `g-h` constant on each piece.  Monotonicity
    # of alpha makes every alpha-length nonnegative, so the finite weighted
    # sum preserves the pointwise order.
    obtain Pg from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, g), $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, g, sg)}
    obtain Ph from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, h), $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, P, alpha, h, sh)}
    $is_partition_of_bounded_interval(I, Pg)
    $is_partition_of_bounded_interval(I, Ph)
    by thm partition_is_set_of_real_subsets(I, Pg)
    by thm partition_is_set_of_real_subsets(I, Ph)
    have Rf finite_set = common_refinement(I, Pg, Ph)
    $is_common_refinement_of_partitions(I, Pg, Ph, Rf)
    by thm common_refinement_is_partition_and_finer(I, Pg, Ph, Rf)
    $is_finer_partition_than(I, Rf, Pg)
    $is_finer_partition_than(I, Rf, Ph)
    by thm piecewise_constant_refines(I, Pg, Rf, g)
    by thm piecewise_constant_refines(I, Ph, Rf, h)
    $is_piecewise_constant_with_partition(I, Rf, g)
    $is_piecewise_constant_with_partition(I, Rf, h)
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, Rf, g)
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, Rf, h)
    by thm piecewise_constant_riemann_stieltjes_integral_with_partition_has_value(I, Rf, alpha, g)
    have sgRf R = piecewise_constant_riemann_stieltjes_integral_with_partition(I, Rf, alpha, g)
    $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, Rf, alpha, g, sgRf)
    by thm piecewise_constant_riemann_stieltjes_integral_independent_of_partition(I, alpha, g, Pg, Rf, sg, sgRf)
    sg = sgRf
    by thm piecewise_constant_riemann_stieltjes_integral_with_partition_has_value(I, Rf, alpha, h)
    have shRf R = piecewise_constant_riemann_stieltjes_integral_with_partition(I, Rf, alpha, h)
    $has_piecewise_constant_riemann_stieltjes_integral_with_partition(I, Rf, alpha, h, shRf)
    by thm piecewise_constant_riemann_stieltjes_integral_independent_of_partition(I, alpha, h, Ph, Rf, sh, shRf)
    sh = shRf
    claim:
        ? forall x I:
            h(x) <= g(x)
        h(x) <= f(x)
        f(x) <= g(x)
        h(x) <= g(x)
    by thm piecewise_constant_riemann_stieltjes_integral_with_same_partition_monotone(I, Rf, alpha, g, h, sgRf, shRf)
    shRf <= sgRf
    sh <= sg

thm identity_alpha_is_monotone_increasing:
    ? forall:
        $chap9::is_monotone_increasing_on(R, identity_alpha)
    # Source handling: the identity function preserves the order of real
    # inputs, so it is an admissible Stieltjes integrator.
    claim:
        ? forall x, y R:
            x < y
            =>:
                identity_alpha(x) <= identity_alpha(y)
        identity_alpha(x) = x
        identity_alpha(y) = y
        x <= y
        identity_alpha(x) <= identity_alpha(y)
    $chap9::is_monotone_increasing_on(R, identity_alpha)

thm identity_alpha_upper_riemann_candidate_value_sets_match:
    ? forall I power_set(R), f fn(x I) R:
        upper_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f) = upper_riemann_integral_candidate_values(I, f)
    # Source handling: the preceding two candidate-value transports give the
    # same upper candidates before either infimum is selected.
    by extension upper_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f) = upper_riemann_integral_candidate_values(I, f):
        claim:
            ? forall s upper_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f):
                s $in upper_riemann_integral_candidate_values(I, f)
            $is_upper_riemann_stieltjes_integral_candidate_value(I, identity_alpha, f, s)
            by thm identity_alpha_upper_riemann_candidate_to_ordinary(I, f, s)
            $is_upper_riemann_integral_candidate_value(I, f, s)
            s $in upper_riemann_integral_candidate_values(I, f)
        claim:
            ? forall s upper_riemann_integral_candidate_values(I, f):
                s $in upper_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f)
            $is_upper_riemann_integral_candidate_value(I, f, s)
            by thm identity_alpha_upper_riemann_candidate_from_ordinary(I, f, s)
            $is_upper_riemann_stieltjes_integral_candidate_value(I, identity_alpha, f, s)
            s $in upper_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f)

thm identity_alpha_lower_riemann_candidate_value_sets_match:
    ? forall I power_set(R), f fn(x I) R:
        lower_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f) = lower_riemann_integral_candidate_values(I, f)
    # Source handling: the same argument identifies the lower candidate sets.
    by extension lower_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f) = lower_riemann_integral_candidate_values(I, f):
        claim:
            ? forall s lower_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f):
                s $in lower_riemann_integral_candidate_values(I, f)
            $is_lower_riemann_stieltjes_integral_candidate_value(I, identity_alpha, f, s)
            by thm identity_alpha_lower_riemann_candidate_to_ordinary(I, f, s)
            $is_lower_riemann_integral_candidate_value(I, f, s)
            s $in lower_riemann_integral_candidate_values(I, f)
        claim:
            ? forall s lower_riemann_integral_candidate_values(I, f):
                s $in lower_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f)
            $is_lower_riemann_integral_candidate_value(I, f, s)
            by thm identity_alpha_lower_riemann_candidate_from_ordinary(I, f, s)
            $is_lower_riemann_stieltjes_integral_candidate_value(I, identity_alpha, f, s)
            s $in lower_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f)

prop has_upper_riemann_stieltjes_integral(I power_set(R), alpha fn(x R) R, f fn(x I) R, U R):
    $is_bounded_interval(I)
    $chap9::is_monotone_increasing_on(R, alpha)
    $chap9::is_bounded_function_on(I, f)
    $has_infimum_of_real_set(upper_riemann_stieltjes_integral_candidate_values(I, alpha, f))
    $is_infimum_of_real_set(upper_riemann_stieltjes_integral_candidate_values(I, alpha, f), U)

prop has_lower_riemann_stieltjes_integral(I power_set(R), alpha fn(x R) R, f fn(x I) R, L R):
    $is_bounded_interval(I)
    $chap9::is_monotone_increasing_on(R, alpha)
    $chap9::is_bounded_function_on(I, f)
    $has_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f))
    $is_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L)

thm upper_riemann_stieltjes_integral_value_unique:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R, U1, U2 R:
        $has_upper_riemann_stieltjes_integral(I, alpha, f, U1)
        $has_upper_riemann_stieltjes_integral(I, alpha, f, U2)
        =>:
            U1 = U2
    $is_infimum_of_real_set(upper_riemann_stieltjes_integral_candidate_values(I, alpha, f), U1)
    $is_infimum_of_real_set(upper_riemann_stieltjes_integral_candidate_values(I, alpha, f), U2)
    by thm infimum_of_real_set_value_unique(upper_riemann_stieltjes_integral_candidate_values(I, alpha, f), U1, U2)
    U1 = U2

thm lower_riemann_stieltjes_integral_value_unique:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R, L1, L2 R:
        $has_lower_riemann_stieltjes_integral(I, alpha, f, L1)
        $has_lower_riemann_stieltjes_integral(I, alpha, f, L2)
        =>:
            L1 = L2
    $is_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L1)
    $is_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L2)
    by thm least_upper_bound_unique(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L1, L2)
    L1 = L2

thm lower_riemann_stieltjes_integral_candidate_values_have_least_upper_bound:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_monotone_increasing_on(R, alpha)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $has_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f))
    # Constant alpha-weighted majorants and minorants reduce completeness of
    # the lower candidate set to Chapter 5.
    obtain M from exist M R_pos st {$chap9::is_function_bounded_by(I, f, M)}
    by thm constant_function_is_piecewise_constant(I, M)
    by thm piecewise_constant_riemann_stieltjes_integral_of_constant(I, alpha, M)
    claim:
        ? $is_upper_bound_of_real_set(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), M * alpha_interval_length(alpha, I))
        claim:
            ? forall sh lower_riemann_stieltjes_integral_candidate_values(I, alpha, f):
                sh <= M * alpha_interval_length(alpha, I)
            by thm lower_riemann_stieltjes_integral_candidate_value_from_member(I, alpha, f, sh)
            obtain h from exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, h, sh)}
            claim:
                ? $majorizes_on(I, fn(x I) R {M}, f)
                forall x I:
                    f(x) <= abs(f(x))
                    abs(f(x)) <= M
                    f(x) <= M
                    fn(x I) R {M}(x) = M
                    fn(x I) R {M}(x) >= f(x)
                $majorizes_on(I, fn(x I) R {M}, f)
            by thm piecewise_constant_stieltjes_minorant_integral_le_majorant_integral(I, alpha, f, fn(x I) R {M}, h, M * alpha_interval_length(alpha, I), sh)
            sh <= M * alpha_interval_length(alpha, I)
        $is_upper_bound_of_real_set(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), M * alpha_interval_length(alpha, I))
    claim:
        ? $is_nonempty_set(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f))
        claim:
            ? $is_lower_riemann_stieltjes_integral_candidate_value(I, alpha, f, -M * alpha_interval_length(alpha, I))
            by thm constant_function_is_piecewise_constant(I, -M)
            by thm piecewise_constant_riemann_stieltjes_integral_of_constant(I, alpha, -M)
            witness exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, h, -M * alpha_interval_length(alpha, I))} from fn(x I) R {-M}:
                $is_piecewise_constant_on(I, fn(x I) R {-M})
                claim:
                    ? $minorizes_on(I, fn(x I) R {-M}, f)
                    forall x I:
                        abs(f(x)) <= M
                        0 - abs(f(x)) <= f(x)
                        0 - M <= 0 - abs(f(x))
                        0 - M = -M
                        -M <= 0 - abs(f(x)) <= f(x)
                        -M <= f(x)
                        fn(x I) R {-M}(x) = -M
                        fn(x I) R {-M}(x) <= f(x)
                    $minorizes_on(I, fn(x I) R {-M}, f)
                $minorizes_on(I, fn(x I) R {-M}, f)
                $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, fn(x I) R {-M}, -M * alpha_interval_length(alpha, I))
            $is_lower_riemann_stieltjes_integral_candidate_value(I, alpha, f, -M * alpha_interval_length(alpha, I))
        by thm lower_riemann_stieltjes_integral_candidate_value_member(I, alpha, f, -M * alpha_interval_length(alpha, I))
        -M * alpha_interval_length(alpha, I) $in lower_riemann_stieltjes_integral_candidate_values(I, alpha, f)
        witness $is_nonempty_set(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f)) from -M * alpha_interval_length(alpha, I)
    claim:
        ? $chap5::has_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f))
        witness exist B R st {$chap5::is_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), B)} from M * alpha_interval_length(alpha, I):
            $is_upper_bound_of_real_set(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), M * alpha_interval_length(alpha, I))
            $chap5::is_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), M * alpha_interval_length(alpha, I))
        $chap5::has_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f))
    by thm chap5::least_upper_bound_existence(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f))
    $chap5::has_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f))
    obtain L from exist L R st {$chap5::is_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L)}
    claim:
        ? $is_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L)
        claim:
            ? $is_upper_bound_of_real_set(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L)
            claim:
                ? forall s lower_riemann_stieltjes_integral_candidate_values(I, alpha, f):
                    s <= L
                $chap5::is_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L)
                s <= L
            $is_upper_bound_of_real_set(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L)
        claim:
            ? forall B R:
                $is_upper_bound_of_real_set(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), B)
                =>:
                    L <= B
            $chap5::is_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L)
            $is_upper_bound_of_real_set(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), B)
            $chap5::is_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), B)
            L <= B
        $is_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L)
    witness exist L0 R st {$is_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L0)} from L:
        $is_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L)
    $has_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f))

thm upper_riemann_stieltjes_integral_candidate_values_have_infimum:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_monotone_increasing_on(R, alpha)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $has_infimum_of_real_set(upper_riemann_stieltjes_integral_candidate_values(I, alpha, f))
    # The opposite constant minorant is a lower bound for every upper
    # candidate, so the reflected Chapter 5 argument gives an infimum.
    obtain M from exist M R_pos st {$chap9::is_function_bounded_by(I, f, M)}
    by thm constant_function_is_piecewise_constant(I, M)
    by thm piecewise_constant_riemann_stieltjes_integral_of_constant(I, alpha, M)
    claim:
        ? $is_upper_riemann_stieltjes_integral_candidate_value(I, alpha, f, M * alpha_interval_length(alpha, I))
        witness exist g fn(x I) R st {$is_piecewise_constant_on(I, g), $majorizes_on(I, g, f), $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, g, M * alpha_interval_length(alpha, I))} from fn(x I) R {M}:
            $is_piecewise_constant_on(I, fn(x I) R {M})
            claim:
                ? $majorizes_on(I, fn(x I) R {M}, f)
                forall x I:
                    f(x) <= abs(f(x))
                    abs(f(x)) <= M
                    f(x) <= M
                    fn(x I) R {M}(x) = M
                    fn(x I) R {M}(x) >= f(x)
                $majorizes_on(I, fn(x I) R {M}, f)
            $majorizes_on(I, fn(x I) R {M}, f)
            $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, fn(x I) R {M}, M * alpha_interval_length(alpha, I))
        $is_upper_riemann_stieltjes_integral_candidate_value(I, alpha, f, M * alpha_interval_length(alpha, I))
    by thm upper_riemann_stieltjes_integral_candidate_value_member(I, alpha, f, M * alpha_interval_length(alpha, I))
    M * alpha_interval_length(alpha, I) $in upper_riemann_stieltjes_integral_candidate_values(I, alpha, f)
    claim:
        ? $is_lower_bound_of_real_set(upper_riemann_stieltjes_integral_candidate_values(I, alpha, f), -M * alpha_interval_length(alpha, I))
        claim:
            ? forall sg upper_riemann_stieltjes_integral_candidate_values(I, alpha, f):
                -M * alpha_interval_length(alpha, I) <= sg
            by thm upper_riemann_stieltjes_integral_candidate_value_from_member(I, alpha, f, sg)
            obtain g from exist g fn(x I) R st {$is_piecewise_constant_on(I, g), $majorizes_on(I, g, f), $has_piecewise_constant_riemann_stieltjes_integral(I, alpha, g, sg)}
            by thm constant_function_is_piecewise_constant(I, -M)
            by thm piecewise_constant_riemann_stieltjes_integral_of_constant(I, alpha, -M)
            claim:
                ? $minorizes_on(I, fn(x I) R {-M}, f)
                forall x I:
                    abs(f(x)) <= M
                    0 - abs(f(x)) <= f(x)
                    0 - M <= 0 - abs(f(x))
                    0 - M = -M
                    -M <= 0 - abs(f(x)) <= f(x)
                    -M <= f(x)
                    fn(x I) R {-M}(x) = -M
                    fn(x I) R {-M}(x) <= f(x)
                $minorizes_on(I, fn(x I) R {-M}, f)
            by thm piecewise_constant_stieltjes_minorant_integral_le_majorant_integral(I, alpha, f, g, fn(x I) R {-M}, sg, -M * alpha_interval_length(alpha, I))
            -M * alpha_interval_length(alpha, I) <= sg
        $is_lower_bound_of_real_set(upper_riemann_stieltjes_integral_candidate_values(I, alpha, f), -M * alpha_interval_length(alpha, I))
    by thm lower_bounded_real_set_with_member_has_infimum(upper_riemann_stieltjes_integral_candidate_values(I, alpha, f), -M * alpha_interval_length(alpha, I), M * alpha_interval_length(alpha, I))
    $has_infimum_of_real_set(upper_riemann_stieltjes_integral_candidate_values(I, alpha, f))

have fn upper_riemann_stieltjes_integral by exist!:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_monotone_increasing_on(R, alpha)
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist! U R st {$has_upper_riemann_stieltjes_integral(I, alpha, f, U)}
    # Source handling: this packages the upper Riemann-Stieltjes infimum.
    # Existence is the same completeness argument as for the ordinary upper
    # Riemann integral; uniqueness is infimum uniqueness.
    claim:
        ? exist U R st {$has_upper_riemann_stieltjes_integral(I, alpha, f, U)}
        by thm upper_riemann_stieltjes_integral_candidate_values_have_infimum(I, alpha, f)
        obtain U from exist U R st {$is_infimum_of_real_set(upper_riemann_stieltjes_integral_candidate_values(I, alpha, f), U)}
        witness exist U0 R st {$has_upper_riemann_stieltjes_integral(I, alpha, f, U0)} from U:
            $is_bounded_interval(I)
            $chap9::is_monotone_increasing_on(R, alpha)
            $chap9::is_bounded_function_on(I, f)
            $has_infimum_of_real_set(upper_riemann_stieltjes_integral_candidate_values(I, alpha, f))
            $is_infimum_of_real_set(upper_riemann_stieltjes_integral_candidate_values(I, alpha, f), U)
        $has_upper_riemann_stieltjes_integral(I, alpha, f, U)
    claim:
        ? forall U1, U2 R:
            $has_upper_riemann_stieltjes_integral(I, alpha, f, U1)
            $has_upper_riemann_stieltjes_integral(I, alpha, f, U2)
            =>:
                U1 = U2
        by thm upper_riemann_stieltjes_integral_value_unique(I, alpha, f, U1, U2)
    exist! U R st {$has_upper_riemann_stieltjes_integral(I, alpha, f, U)}

have fn lower_riemann_stieltjes_integral by exist!:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_monotone_increasing_on(R, alpha)
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist! L R st {$has_lower_riemann_stieltjes_integral(I, alpha, f, L)}
    # Source handling: this packages the lower Riemann-Stieltjes supremum.
    # Existence is the same completeness argument as for the ordinary lower
    # Riemann integral; uniqueness is supremum uniqueness.
    claim:
        ? exist L R st {$has_lower_riemann_stieltjes_integral(I, alpha, f, L)}
        by thm lower_riemann_stieltjes_integral_candidate_values_have_least_upper_bound(I, alpha, f)
        obtain L from exist L R st {$is_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L)}
        witness exist L0 R st {$has_lower_riemann_stieltjes_integral(I, alpha, f, L0)} from L:
            $is_bounded_interval(I)
            $chap9::is_monotone_increasing_on(R, alpha)
            $chap9::is_bounded_function_on(I, f)
            $has_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f))
            $is_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, alpha, f), L)
        $has_lower_riemann_stieltjes_integral(I, alpha, f, L)
    claim:
        ? forall L1, L2 R:
            $has_lower_riemann_stieltjes_integral(I, alpha, f, L1)
            $has_lower_riemann_stieltjes_integral(I, alpha, f, L2)
            =>:
                L1 = L2
        by thm lower_riemann_stieltjes_integral_value_unique(I, alpha, f, L1, L2)
    exist! L R st {$has_lower_riemann_stieltjes_integral(I, alpha, f, L)}

prop is_riemann_stieltjes_integrable_on(I power_set(R), alpha fn(x R) R, f fn(x I) R):
    $is_bounded_interval(I)
    $chap9::is_monotone_increasing_on(R, alpha)
    $chap9::is_bounded_function_on(I, f)
    upper_riemann_stieltjes_integral(I, alpha, f) = lower_riemann_stieltjes_integral(I, alpha, f)

prop has_riemann_stieltjes_integral(I power_set(R), alpha fn(x R) R, f fn(x I) R, s R):
    $is_riemann_stieltjes_integrable_on(I, alpha, f)
    s = upper_riemann_stieltjes_integral(I, alpha, f)

thm riemann_stieltjes_integrable_on_bounded_interval:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R:
        $is_riemann_stieltjes_integrable_on(I, alpha, f)
        =>:
            $is_bounded_interval(I)

thm riemann_stieltjes_integrable_monotone_alpha:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R:
        $is_riemann_stieltjes_integrable_on(I, alpha, f)
        =>:
            $chap9::is_monotone_increasing_on(R, alpha)

thm riemann_stieltjes_integrable_on_bounded_function:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R:
        $is_riemann_stieltjes_integrable_on(I, alpha, f)
        =>:
            $chap9::is_bounded_function_on(I, f)

thm riemann_stieltjes_integrable_upper_eq_lower:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R:
        $is_riemann_stieltjes_integrable_on(I, alpha, f)
        =>:
            upper_riemann_stieltjes_integral(I, alpha, f) = lower_riemann_stieltjes_integral(I, alpha, f)

thm has_riemann_stieltjes_integral_implies_integrable:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R, s R:
        $has_riemann_stieltjes_integral(I, alpha, f, s)
        =>:
            $is_riemann_stieltjes_integrable_on(I, alpha, f)

thm has_riemann_stieltjes_integral_value_eq_upper:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R, s R:
        $has_riemann_stieltjes_integral(I, alpha, f, s)
        =>:
            s = upper_riemann_stieltjes_integral(I, alpha, f)

thm riemann_stieltjes_integral_value_unique:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R, s1, s2 R:
        $has_riemann_stieltjes_integral(I, alpha, f, s1)
        $has_riemann_stieltjes_integral(I, alpha, f, s2)
        =>:
            s1 = s2
    s1 = upper_riemann_stieltjes_integral(I, alpha, f)
    s2 = upper_riemann_stieltjes_integral(I, alpha, f)
    s1 = s2

have fn stieltjes_integral_on by exist!:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R:
        $is_riemann_stieltjes_integrable_on(I, alpha, f)
        =>:
            exist! s R st {$has_riemann_stieltjes_integral(I, alpha, f, s)}
    # Source handling: this is the selector for the common upper/lower
    # Riemann-Stieltjes value.
    witness exist s R st {$has_riemann_stieltjes_integral(I, alpha, f, s)} from upper_riemann_stieltjes_integral(I, alpha, f):
        $has_riemann_stieltjes_integral(I, alpha, f, upper_riemann_stieltjes_integral(I, alpha, f))
    claim:
        ? forall s1, s2 R:
            $has_riemann_stieltjes_integral(I, alpha, f, s1)
            $has_riemann_stieltjes_integral(I, alpha, f, s2)
            =>:
                s1 = s2
        by thm riemann_stieltjes_integral_value_unique(I, alpha, f, s1, s2)
    exist! s R st {$has_riemann_stieltjes_integral(I, alpha, f, s)}

thm stieltjes_integral_on_has_riemann_stieltjes_integral:
    ? forall I power_set(R), alpha fn(x R) R, f fn(x I) R:
        $is_riemann_stieltjes_integrable_on(I, alpha, f)
        =>:
            $has_riemann_stieltjes_integral(I, alpha, f, stieltjes_integral_on(I, alpha, f))

thm identity_alpha_stieltjes_matches_riemann:
    ? forall I power_set(R), f fn(x I) R:
        $is_riemann_integrable_on(I, f)
        =>:
            $is_riemann_stieltjes_integrable_on(I, identity_alpha, f)
            stieltjes_integral_on(I, identity_alpha, f) = integral_on(I, f)
    # Source handling: Tao observes that Riemann-Stieltjes integration with
    # identity alpha is the ordinary Riemann integral.
    by thm riemann_integrable_on_bounded_interval(I, f)
    $is_bounded_interval(I)
    by thm riemann_integrable_on_bounded_function(I, f)
    $chap9::is_bounded_function_on(I, f)
    by thm identity_alpha_is_monotone_increasing()
    $chap9::is_monotone_increasing_on(R, identity_alpha)
    $has_upper_riemann_integral(I, f, upper_riemann_integral(I, f))
    $has_lower_riemann_integral(I, f, lower_riemann_integral(I, f))
    by thm identity_alpha_upper_riemann_candidate_value_sets_match(I, f)
    upper_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f) = upper_riemann_integral_candidate_values(I, f)
    claim:
        ? $has_upper_riemann_stieltjes_integral(I, identity_alpha, f, upper_riemann_integral(I, f))
        $has_infimum_of_real_set(upper_riemann_integral_candidate_values(I, f))
        $has_infimum_of_real_set(upper_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f))
        $is_infimum_of_real_set(upper_riemann_integral_candidate_values(I, f), upper_riemann_integral(I, f))
        $is_infimum_of_real_set(upper_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f), upper_riemann_integral(I, f))
        $has_upper_riemann_stieltjes_integral(I, identity_alpha, f, upper_riemann_integral(I, f))
    $has_upper_riemann_stieltjes_integral(I, identity_alpha, f, upper_riemann_integral(I, f))
    $has_upper_riemann_stieltjes_integral(I, identity_alpha, f, upper_riemann_stieltjes_integral(I, identity_alpha, f))
    by thm upper_riemann_stieltjes_integral_value_unique(I, identity_alpha, f, upper_riemann_stieltjes_integral(I, identity_alpha, f), upper_riemann_integral(I, f))
    upper_riemann_stieltjes_integral(I, identity_alpha, f) = upper_riemann_integral(I, f)

    by thm identity_alpha_lower_riemann_candidate_value_sets_match(I, f)
    lower_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f) = lower_riemann_integral_candidate_values(I, f)
    claim:
        ? $has_lower_riemann_stieltjes_integral(I, identity_alpha, f, lower_riemann_integral(I, f))
        $has_least_upper_bound(lower_riemann_integral_candidate_values(I, f))
        $has_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f))
        $is_least_upper_bound(lower_riemann_integral_candidate_values(I, f), lower_riemann_integral(I, f))
        $is_least_upper_bound(lower_riemann_stieltjes_integral_candidate_values(I, identity_alpha, f), lower_riemann_integral(I, f))
        $has_lower_riemann_stieltjes_integral(I, identity_alpha, f, lower_riemann_integral(I, f))
    $has_lower_riemann_stieltjes_integral(I, identity_alpha, f, lower_riemann_integral(I, f))
    $has_lower_riemann_stieltjes_integral(I, identity_alpha, f, lower_riemann_stieltjes_integral(I, identity_alpha, f))
    by thm lower_riemann_stieltjes_integral_value_unique(I, identity_alpha, f, lower_riemann_stieltjes_integral(I, identity_alpha, f), lower_riemann_integral(I, f))
    lower_riemann_stieltjes_integral(I, identity_alpha, f) = lower_riemann_integral(I, f)

    by thm riemann_integrable_upper_eq_lower(I, f)
    upper_riemann_integral(I, f) = lower_riemann_integral(I, f)
    upper_riemann_stieltjes_integral(I, identity_alpha, f) = lower_riemann_stieltjes_integral(I, identity_alpha, f)
    $is_riemann_stieltjes_integrable_on(I, identity_alpha, f)
    by thm stieltjes_integral_on_has_riemann_stieltjes_integral(I, identity_alpha, f)
    $has_riemann_stieltjes_integral(I, identity_alpha, f, stieltjes_integral_on(I, identity_alpha, f))
    by thm has_riemann_stieltjes_integral_value_eq_upper(I, identity_alpha, f, stieltjes_integral_on(I, identity_alpha, f))
    stieltjes_integral_on(I, identity_alpha, f) = upper_riemann_stieltjes_integral(I, identity_alpha, f)
    by thm integral_on_has_riemann_integral(I, f)
    $has_riemann_integral(I, f, integral_on(I, f))
    by thm has_riemann_integral_value_eq_upper(I, f, integral_on(I, f))
    integral_on(I, f) = upper_riemann_integral(I, f)
    stieltjes_integral_on(I, identity_alpha, f) = integral_on(I, f)


# 11.9 The two fundamental theorems of calculus

"""
Theorem 11.9.1 (First Fundamental Theorem of Calculus).  If `f` is Riemann
integrable on `[a,b]`, define `F(x)` to be the integral of `f` from `a` to
`x`.  Then `F` is continuous on `[a,b]`; at every point where `f` is
continuous, `F` is differentiable and `F'(x)=f(x)`.
"""

thm closed_initial_subinterval_subset_parent:
    ? forall a, b R, x '[a, b]:
        a < b
        =>:
            '[a, x] $subset '[a, b]
    claim:
        ? forall t '[a, x]:
            t $in '[a, b]
        a <= t <= x
        a <= x <= b
        t <= x <= b
        t $in '[a, b]
    '[a, x] $subset '[a, b]

thm closed_initial_restriction_is_riemann_integrable:
    ? forall a, b R, f fn(t '[a, b]) R, x '[a, b]:
        a < b
        $is_riemann_integrable_on('[a, b], f)
        =>:
            $is_riemann_integrable_on('[a, x], fn(y '[a, x]) R {f(y)})
    by thm interval_endpoint_forms_are_bounded_intervals(a, b)
    by thm interval_endpoint_forms_are_bounded_intervals(a, x)
    by thm interval_endpoint_forms_are_bounded_intervals(x, b)
    by thm closed_initial_subinterval_subset_parent(a, b, x)
    claim:
        ? forall t '(x, b]:
            t $in '[a, b]
        x < t <= b
        a <= x < t
        a <= t <= b
        t $in '[a, b]
    '(x, b] $subset '[a, b]
    claim:
        ? '[a, x] != '(x, b]
        by contra:
            ? '[a, x] != '(x, b]
            '[a, x] = '(x, b]
            a $in '[a, x]
            a $in '(x, b]
            x < a <= x
            impossible x < x
    '[a, x] $in union({'[a, x]}, {'(x, b]})
    '(x, b] $in union({'[a, x]}, {'(x, b]})
    claim:
        ? forall H union({'[a, x]}, {'(x, b]}):
            H = '[a, x] or H = '(x, b]
        H $in {'[a, x]} or H $in {'(x, b]}
        by cases:
            ? H = '[a, x] or H = '(x, b]
            case H $in {'[a, x]}:
                H = '[a, x]
            case H $in {'(x, b]}:
                H = '(x, b]
    claim:
        ? forall t '[a, b], H union({'[a, x]}, {'(x, b]}):
            t $in H
            t <= x
            =>:
                H = '[a, x]
        H = '[a, x] or H = '(x, b]
        by cases:
            ? H = '[a, x]
            case H = '[a, x]:
                H = '[a, x]
            case H = '(x, b]:
                t $in '(x, b]
                x < t <= x
                impossible x < x
    claim:
        ? forall t '[a, b], H union({'[a, x]}, {'(x, b]}):
            t $in H
            t > x
            =>:
                H = '(x, b]
        H = '[a, x] or H = '(x, b]
        by cases:
            ? H = '(x, b]
            case H = '[a, x]:
                t $in '[a, x]
                x < t <= x
                impossible x < x
            case H = '(x, b]:
                H = '(x, b]
    claim:
        ? $is_partition_of_bounded_interval('[a, b], union({'[a, x]}, {'(x, b]}))
        claim:
            ? forall H union({'[a, x]}, {'(x, b]}):
                H $in power_set(R)
            H = '[a, x] or H = '(x, b]
            by cases:
                ? H $in power_set(R)
                case H = '[a, x]:
                    H = '[a, x]
                    H $in power_set(R)
                case H = '(x, b]:
                    H = '(x, b]
                    H $in power_set(R)
        claim:
            ? forall H union({'[a, x]}, {'(x, b]}):
                $is_bounded_interval(H)
            H = '[a, x] or H = '(x, b]
            by cases:
                ? $is_bounded_interval(H)
                case H = '[a, x]:
                    H = '[a, x]
                    $is_bounded_interval(H)
                case H = '(x, b]:
                    H = '(x, b]
                    $is_bounded_interval(H)
        claim:
            ? forall H union({'[a, x]}, {'(x, b]}):
                H $subset '[a, b]
            H = '[a, x] or H = '(x, b]
            by cases:
                ? H $subset '[a, b]
                case H = '[a, x]:
                    H = '[a, x]
                    H $subset '[a, b]
                case H = '(x, b]:
                    H = '(x, b]
                    H $subset '[a, b]
        claim:
            ? forall t '[a, b]:
                exist H union({'[a, x]}, {'(x, b]}) st {H $in power_set(R), t $in H}
            t <= x or t > x
            by cases:
                ? exist H union({'[a, x]}, {'(x, b]}) st {H $in power_set(R), t $in H}
                case t <= x:
                    witness exist H union({'[a, x]}, {'(x, b]}) st {H $in power_set(R), t $in H} from '[a, x]:
                        '[a, x] $in union({'[a, x]}, {'(x, b]})
                        '[a, x] $in power_set(R)
                        a <= t <= x
                        t $in '[a, x]
                case t > x:
                    witness exist H union({'[a, x]}, {'(x, b]}) st {H $in power_set(R), t $in H} from '(x, b]:
                        '(x, b] $in union({'[a, x]}, {'(x, b]})
                        '(x, b] $in power_set(R)
                        x < t <= b
                        t $in '(x, b]
        claim:
            ? forall t '[a, b], H1, H2 union({'[a, x]}, {'(x, b]}):
                H1 $in power_set(R)
                H2 $in power_set(R)
                t $in H1
                t $in H2
                =>:
                    H1 = H2
            t <= x or t > x
            by cases:
                ? H1 = H2
                case t <= x:
                    H1 = '[a, x]
                    H2 = '[a, x]
                    H1 = H2
                case t > x:
                    H1 = '(x, b]
                    H2 = '(x, b]
                    H1 = H2
        forall t '[a, b]:
            exist! H union({'[a, x]}, {'(x, b]}) st {H $in power_set(R), t $in H}
        by def $is_partition_of_bounded_interval('[a, b], union({'[a, x]}, {'(x, b]}))
    by thm riemann_integral_additive_over_two_piece_partition('[a, b], union({'[a, x]}, {'(x, b]}), '[a, x], '(x, b], f)

# Source handling: Theorem 11.9.1 defines the left-endpoint integral directly.
# The restriction, its subinterval integrability, and the selected integral
# value are all checked here.
have fn integral_from_left_endpoint by exist!:
    ? forall a, b R, f fn(t '[a, b]) R, x '[a, b]:
        a < b
        $is_riemann_integrable_on('[a, b], f)
        =>:
            exist! s R st {$has_riemann_integral('[a, x], fn(y '[a, x]) R {f(y)}, s)}
    by thm closed_initial_restriction_is_riemann_integrable(a, b, f, x)
    witness exist s R st {$has_riemann_integral('[a, x], fn(y '[a, x]) R {f(y)}, s)} from integral_on('[a, x], fn(y '[a, x]) R {f(y)}):
        by thm integral_on_has_riemann_integral('[a, x], fn(y '[a, x]) R {f(y)})
    claim:
        ? forall s1, s2 R:
            $has_riemann_integral('[a, x], fn(y '[a, x]) R {f(y)}, s1)
            $has_riemann_integral('[a, x], fn(y '[a, x]) R {f(y)}, s2)
            =>:
                s1 = s2
        by thm riemann_integral_value_unique('[a, x], fn(y '[a, x]) R {f(y)}, s1, s2)
    exist! s R st {$has_riemann_integral('[a, x], fn(y '[a, x]) R {f(y)}, s)}

thm integral_from_left_endpoint_has_value:
    ? forall a, b R, f fn(t '[a, b]) R, x '[a, b]:
        a < b
        $is_riemann_integrable_on('[a, b], f)
        =>:
            $has_riemann_integral('[a, x], fn(y '[a, x]) R {f(y)}, integral_from_left_endpoint(a, b, f, x))

prop is_integral_function_from_left_endpoint(a, b R, f fn(t '[a, b]) R, F fn(x '[a, b]) R):
    forall x '[a, b]:
        $has_riemann_integral('[a, x], fn(y '[a, x]) R {f(y)}, F(x))

thm selected_left_endpoint_integral_is_integral_function:
    ? forall a, b R, f fn(t '[a, b]) R:
        a < b
        $is_riemann_integrable_on('[a, b], f)
        =>:
            $is_integral_function_from_left_endpoint(a, b, f, fn(x '[a, b]) R {integral_from_left_endpoint(a, b, f, x)})
    claim:
        ? forall x '[a, b]:
            $has_riemann_integral('[a, x], fn(y '[a, x]) R {f(y)}, fn(z '[a, b]) R {integral_from_left_endpoint(a, b, f, z)}(x))
        fn(z '[a, b]) R {integral_from_left_endpoint(a, b, f, z)}(x) = integral_from_left_endpoint(a, b, f, x)
        by thm integral_from_left_endpoint_has_value(a, b, f, x)
    by def $is_integral_function_from_left_endpoint(a, b, f, fn(x '[a, b]) R {integral_from_left_endpoint(a, b, f, x)})

thm first_fundamental_theorem_integral_function_continuous:
    ? forall a, b R, f fn(x '[a, b]) R, F fn(x '[a, b]) R:
        a < b
        $is_riemann_integrable_on('[a, b], f)
        $is_integral_function_from_left_endpoint(a, b, f, F)
        =>:
            $chap9::is_continuous_on('[a, b], F)
    # Source handling: the proof of Theorem 11.9.1 bounds `F(y)-F(x)` by
    # `M|y-x|`, but leaves the changing-interval additivity and restriction
    # transports implicit.  The trust keeps those source gaps visible.
    # proof_debt: formalize interval additivity and boundedness of integrable
    # functions.
    trust $chap9::is_continuous_on('[a, b], F)

thm first_fundamental_theorem_integral_function_derivative_at_continuity_point:
    ? forall a, b R, f fn(x '[a, b]) R, F fn(x '[a, b]) R, x0 '[a, b]:
        a < b
        $is_riemann_integrable_on('[a, b], f)
        $is_integral_function_from_left_endpoint(a, b, f, F)
        $chap9::is_continuous_at('[a, b], f, x0)
        =>:
            $chap10::has_derivative_at('[a, b], F, x0, f(x0))
    # Source handling: the proof of Theorem 11.9.1 compares the average
    # integral over `[x0,y]` with `f(x0)`, while compressing the
    # changing-interval quotient squeeze.  The trust keeps that gap visible.
    # proof_debt: formalize the squeeze estimate for the difference quotient.
    trust $chap10::has_derivative_at('[a, b], F, x0, f(x0))

thm first_fundamental_theorem_of_calculus:
    ? forall a, b R, f fn(x '[a, b]) R, F fn(x '[a, b]) R, x0 '[a, b]:
        a < b
        $is_riemann_integrable_on('[a, b], f)
        $is_integral_function_from_left_endpoint(a, b, f, F)
        $chap9::is_continuous_at('[a, b], f, x0)
        =>:
            $chap9::is_continuous_on('[a, b], F)
            $chap10::has_derivative_at('[a, b], F, x0, f(x0))
    # Source handling: this is the combined source-facing statement of
    # Theorem 11.9.1.  The two preceding theorems keep Tao's continuity and
    # chap10::derivative proof routes as separate proof packages.
    by thm first_fundamental_theorem_integral_function_continuous(a, b, f, F)
    $chap9::is_continuous_on('[a, b], F)
    by thm first_fundamental_theorem_integral_function_derivative_at_continuity_point(a, b, f, F, x0)
    $chap10::has_derivative_at('[a, b], F, x0, f(x0))

"""
Example 11.9.2.  The monotone function from Exercise 9.8.5 gives an integral
function that is continuous everywhere, differentiable at the continuity points
of the integrand, and non-differentiable at its rational discontinuities.
"""

# The source function itself comes from an earlier exercise, so this chapter
# records only the integral-function behavior.

"""
Definition 11.9.3 (Antiderivatives).  An antiderivative of `f` on `I` is a
differentiable function `F` whose chap10::derivative at every point is `f`.
"""

prop is_antiderivative_of(I power_set(R), f fn(x I) R, F fn(x I) R):
    forall x I:
        $chap10::has_derivative_at(I, F, x, f(x))

prop differs_by_constant_on(I power_set(R), F, G fn(x I) R, C R):
    forall x I:
        F(x) = G(x) + C

"""
Theorem 11.9.4 (Second Fundamental Theorem of Calculus).  If `F` is an
antiderivative of a Riemann integrable function `f` on `[a,b]`, then the
integral of `f` is `F(b)-F(a)`.
"""

thm antiderivative_boundary_difference_between_riemann_integral_bounds:
    ? forall a, b R, f fn(x '[a, b]) R, F fn(x '[a, b]) R:
        a < b
        $is_riemann_integrable_on('[a, b], f)
        $is_antiderivative_of('[a, b], f, F)
        =>:
            lower_riemann_integral('[a, b], f) <= F(b) - F(a)
            F(b) - F(a) <= upper_riemann_integral('[a, b], f)
    # Source handling: Theorem 11.9.4 gives the Riemann-sum and mean-value
    # route, but leaves one inequality analogous and compresses the per-piece
    # endpoint bookkeeping.  The trust keeps those source gaps visible.
    # proof_debt: formalize the Riemann-sum comparison, alpha-length notation
    # for `F[J]`, and the mean-value theorem application on each piece.
    trust:
        lower_riemann_integral('[a, b], f) <= F(b) - F(a)
        F(b) - F(a) <= upper_riemann_integral('[a, b], f)

thm second_fundamental_theorem_of_calculus:
    ? forall a, b R, f fn(x '[a, b]) R, F fn(x '[a, b]) R:
        a < b
        $is_riemann_integrable_on('[a, b], f)
        $is_antiderivative_of('[a, b], f, F)
        =>:
            integral_on('[a, b], f) = F(b) - F(a)
    by thm antiderivative_boundary_difference_between_riemann_integral_bounds(a, b, f, F)
    lower_riemann_integral('[a, b], f) <= F(b) - F(a)
    F(b) - F(a) <= upper_riemann_integral('[a, b], f)
    by thm riemann_integrable_upper_eq_lower('[a, b], f)
    upper_riemann_integral('[a, b], f) = lower_riemann_integral('[a, b], f)
    upper_riemann_integral('[a, b], f) = lower_riemann_integral('[a, b], f) <= F(b) - F(a)
    upper_riemann_integral('[a, b], f) <= F(b) - F(a)
    F(b) - F(a) = upper_riemann_integral('[a, b], f)
    by thm integral_on_has_riemann_integral('[a, b], f)
    $has_riemann_integral('[a, b], f, integral_on('[a, b], f))
    by thm has_riemann_integral_value_eq_upper('[a, b], f, integral_on('[a, b], f))
    integral_on('[a, b], f) = upper_riemann_integral('[a, b], f)
    integral_on('[a, b], f) = F(b) - F(a)

"""
Lemma 11.9.5.  Any two antiderivatives of the same function on a bounded
interval differ by a constant.
"""

thm antiderivatives_differ_by_constant:
    ? forall I power_set(R), f fn(x I) R, F, G fn(x I) R:
        $is_bounded_interval(I)
        $is_antiderivative_of(I, f, F)
        $is_antiderivative_of(I, f, G)
        =>:
            exist C R st {$differs_by_constant_on(I, F, G, C)}
    # Source handling: Tao proves this in Exercise 11.9.2 using the mean-value
    # theorem applied to `F-G`.
    # The closed subinterval between any two points of I lies in I.  On it,
    # F-G has derivative zero, so the checked Chapter 10 zero-derivative
    # theorem gives equal endpoint values.
    by thm bounded_intervals_are_bounded_connected(I)
    $is_connected_subset_of_R(I)
    have fn difference_function(x I) R = F(x) - G(x)
    claim:
        ? forall x I:
            $chap10::has_derivative_at(I, difference_function, x, 0)
        $chap10::has_derivative_at(I, F, x, f(x))
        $chap10::has_derivative_at(I, G, x, f(x))
        by thm chap10::derivative_difference_rule(I, F, G, x, f(x), f(x))
        $chap10::has_derivative_at(I, fn(y I) R {F(y) - G(y)}, x, f(x) - f(x))
        f(x) - f(x) = 0
        difference_function = fn(y I) R {F(y) - G(y)}
        $chap10::has_derivative_at(I, difference_function, x, 0)
    by cases:
        ? exist C R st {$differs_by_constant_on(I, F, G, C)}
        case $is_nonempty_set(I):
            have x0 I
            have C R = F(x0) - G(x0)
            witness exist C0 R st {$differs_by_constant_on(I, F, G, C0)} from C:
                claim:
                    ? forall x I:
                        F(x) = G(x) + C
                    x < x0 or x = x0 or x > x0
                    by cases:
                        ? F(x) = G(x) + C
                        case x < x0:
                            '[x, x0] $subset I
                            have fn restricted_difference(y '[x, x0]) R = difference_function(y)
                            claim:
                                ? $chap10::has_derivative_function_on('[x, x0], restricted_difference, fn(y '[x, x0]) R {0})
                                claim:
                                    ? forall y '[x, x0]:
                                        $chap9::is_limit_point_of_set('[x, x0], y)
                                        =>:
                                            $chap10::has_derivative_at('[x, x0], restricted_difference, y, 0)
                                    y $in I
                                    by thm chap10::derivative_restrict_domain(I, '[x, x0], difference_function, y, 0)
                                    $chap10::has_derivative_at('[x, x0], fn(z '[x, x0]) R {difference_function(z)}, y, 0)
                                    restricted_difference = fn(z '[x, x0]) R {difference_function(z)}
                                    $chap10::has_derivative_at('[x, x0], restricted_difference, y, 0)
                                $chap10::has_derivative_function_on('[x, x0], restricted_difference, fn(y '[x, x0]) R {0})
                            by thm chap10::zero_derivative_constant(x, x0, restricted_difference, fn(y '[x, x0]) R {0})
                            $chap10::is_constant_on('[x, x0], restricted_difference)
                            restricted_difference(x) = restricted_difference(x0)
                            restricted_difference(x) = difference_function(x)
                            restricted_difference(x0) = difference_function(x0)
                            difference_function(x) = difference_function(x0)
                            difference_function(x) = F(x) - G(x)
                            difference_function(x0) = F(x0) - G(x0)
                            F(x) - G(x) = F(x0) - G(x0)
                            C = F(x0) - G(x0)
                            F(x) = G(x) + C
                        case x = x0:
                            C = F(x0) - G(x0)
                            F(x) = F(x0)
                            G(x) = G(x0)
                            F(x) = G(x) + C
                        case x > x0:
                            '[x0, x] $subset I
                            have fn restricted_difference(y '[x0, x]) R = difference_function(y)
                            claim:
                                ? $chap10::has_derivative_function_on('[x0, x], restricted_difference, fn(y '[x0, x]) R {0})
                                claim:
                                    ? forall y '[x0, x]:
                                        $chap9::is_limit_point_of_set('[x0, x], y)
                                        =>:
                                            $chap10::has_derivative_at('[x0, x], restricted_difference, y, 0)
                                    y $in I
                                    by thm chap10::derivative_restrict_domain(I, '[x0, x], difference_function, y, 0)
                                    $chap10::has_derivative_at('[x0, x], fn(z '[x0, x]) R {difference_function(z)}, y, 0)
                                    restricted_difference = fn(z '[x0, x]) R {difference_function(z)}
                                    $chap10::has_derivative_at('[x0, x], restricted_difference, y, 0)
                                $chap10::has_derivative_function_on('[x0, x], restricted_difference, fn(y '[x0, x]) R {0})
                            by thm chap10::zero_derivative_constant(x0, x, restricted_difference, fn(y '[x0, x]) R {0})
                            $chap10::is_constant_on('[x0, x], restricted_difference)
                            restricted_difference(x0) = restricted_difference(x)
                            restricted_difference(x0) = difference_function(x0)
                            restricted_difference(x) = difference_function(x)
                            difference_function(x) = difference_function(x0)
                            difference_function(x) = F(x) - G(x)
                            difference_function(x0) = F(x0) - G(x0)
                            F(x) - G(x) = F(x0) - G(x0)
                            C = F(x0) - G(x0)
                            F(x) = G(x) + C
                $differs_by_constant_on(I, F, G, C)
        case not $is_nonempty_set(I):
            witness exist C R st {$differs_by_constant_on(I, F, G, C)} from 0:
                claim:
                    ? forall x I:
                        F(x) = G(x) + 0
                    by contra:
                        ? F(x) = G(x) + 0
                        witness $is_nonempty_set(I) from x
                        impossible not $is_nonempty_set(I)
                $differs_by_constant_on(I, F, G, 0)


# 11.10 Consequences of the fundamental theorems

"""
Proposition 11.10.1 (Integration by parts).  If `F` and `G` are differentiable
and their derivatives are Riemann integrable, then the integral of `F*G'`
equals the boundary term minus the integral of `F'*G`.
"""

thm derivative_values_imply_continuous_on_closed_interval_local:
    ? forall a, b R, F, dF fn(x '[a, b]) R:
        a < b
        forall x '[a, b]:
            $chap10::has_derivative_at('[a, b], F, x, dF(x))
        =>:
            $chap9::is_continuous_on('[a, b], F)
    # Source handling: this is Corollary 10.1.12 specialized to a concrete
    # chap10::derivative-value function on `[a,b]`.
    claim:
        ? $chap10::is_differentiable_on('[a, b], F)
        claim:
            ? forall x0 '[a, b]:
                $chap10::is_differentiable_at('[a, b], F, x0)
            witness exist L R st {$chap10::has_derivative_at('[a, b], F, x0, L)} from dF(x0):
                $chap10::has_derivative_at('[a, b], F, x0, dF(x0))
            $chap10::is_differentiable_at('[a, b], F, x0)
        $chap10::is_differentiable_on('[a, b], F)
    by thm chap10::differentiable_on_implies_continuous_on('[a, b], F)
    $chap9::is_continuous_on('[a, b], F)

thm integration_by_parts_product_terms_integrable:
    ? forall a, b R, F, G, dF, dG fn(x '[a, b]) R:
        a < b
        forall x '[a, b]:
            $chap10::has_derivative_at('[a, b], F, x, dF(x))
            $chap10::has_derivative_at('[a, b], G, x, dG(x))
        $is_riemann_integrable_on('[a, b], dF)
        $is_riemann_integrable_on('[a, b], dG)
        =>:
            $is_riemann_integrable_on('[a, b], F)
            $is_riemann_integrable_on('[a, b], G)
            $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {F(x) * dG(x)})
            $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x)})
    # Source handling: differentiability gives continuity of `F` and `G`;
    # Corollary 11.5.2 gives their Riemann integrability, and Theorem 11.4.5
    # gives integrability of the two products with `dG` and `dF`.
    by thm derivative_values_imply_continuous_on_closed_interval_local(a, b, F, dF)
    $chap9::is_continuous_on('[a, b], F)
    by thm derivative_values_imply_continuous_on_closed_interval_local(a, b, G, dG)
    $chap9::is_continuous_on('[a, b], G)
    by thm continuous_closed_interval_riemann_integrable(a, b, F)
    $is_riemann_integrable_on('[a, b], F)
    by thm continuous_closed_interval_riemann_integrable(a, b, G)
    $is_riemann_integrable_on('[a, b], G)
    by thm products_preserve_riemann_integrability('[a, b], F, dG)
    $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {F(x) * dG(x)})
    by thm products_preserve_riemann_integrability('[a, b], dF, G)
    $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x)})

thm integration_by_parts_product_derivative_integral_identity:
    ? forall a, b R, F, G, dF, dG fn(x '[a, b]) R:
        a < b
        forall x '[a, b]:
            $chap10::has_derivative_at('[a, b], F, x, dF(x))
            $chap10::has_derivative_at('[a, b], G, x, dG(x))
        $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {F(x) * dG(x)})
        $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x)})
        =>:
            integral_on('[a, b], fn(x '[a, b]) R {F(x) * dG(x)}) + integral_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x)}) = F(b) * G(b) - F(a) * G(a)
    # Source handling: apply the product rule to `F*G`, integrate its
    # chap10::derivative with Theorem 11.9.4, and use linearity to split
    # `(FG)' = F'G + FG'`.
    have fn product_derivative(x '[a, b]) R = dF(x) * G(x) + F(x) * dG(x)
    claim:
        ? $is_antiderivative_of('[a, b], product_derivative, fn(x '[a, b]) R {F(x) * G(x)})
        claim:
            ? forall x '[a, b]:
                $chap10::has_derivative_at('[a, b], fn(x '[a, b]) R {F(x) * G(x)}, x, product_derivative(x))
            by thm chap10::derivative_product_rule('[a, b], F, G, x, dF(x), dG(x))
            $chap10::has_derivative_at('[a, b], fn(x '[a, b]) R {F(x) * G(x)}, x, dF(x) * G(x) + F(x) * dG(x))
            product_derivative(x) = dF(x) * G(x) + F(x) * dG(x)
            $chap10::has_derivative_at('[a, b], fn(x '[a, b]) R {F(x) * G(x)}, x, product_derivative(x))
        $is_antiderivative_of('[a, b], product_derivative, fn(x '[a, b]) R {F(x) * G(x)})
    by thm riemann_integral_addition_law('[a, b], fn(x '[a, b]) R {dF(x) * G(x)}, fn(x '[a, b]) R {F(x) * dG(x)})
    $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x) + F(x) * dG(x)})
    integral_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x) + F(x) * dG(x)}) = integral_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x)}) + integral_on('[a, b], fn(x '[a, b]) R {F(x) * dG(x)})
    claim:
        ? $fn_eq(product_derivative, fn(x '[a, b]) R {dF(x) * G(x) + F(x) * dG(x)})
        forall x '[a, b]:
            product_derivative(x) = dF(x) * G(x) + F(x) * dG(x)
            fn(x '[a, b]) R {dF(x) * G(x) + F(x) * dG(x)}(x) = dF(x) * G(x) + F(x) * dG(x)
            product_derivative(x) = fn(x '[a, b]) R {dF(x) * G(x) + F(x) * dG(x)}(x)
        $fn_eq(product_derivative, fn(x '[a, b]) R {dF(x) * G(x) + F(x) * dG(x)})
    product_derivative = fn(x '[a, b]) R {dF(x) * G(x) + F(x) * dG(x)}
    $is_riemann_integrable_on('[a, b], product_derivative)
    integral_on('[a, b], product_derivative) = integral_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x) + F(x) * dG(x)})
    by thm second_fundamental_theorem_of_calculus(a, b, product_derivative, fn(x '[a, b]) R {F(x) * G(x)})
    integral_on('[a, b], product_derivative) = F(b) * G(b) - F(a) * G(a)
    integral_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x) + F(x) * dG(x)}) = F(b) * G(b) - F(a) * G(a)
    integral_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x)}) + integral_on('[a, b], fn(x '[a, b]) R {F(x) * dG(x)}) = F(b) * G(b) - F(a) * G(a)
    integral_on('[a, b], fn(x '[a, b]) R {F(x) * dG(x)}) + integral_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x)}) = F(b) * G(b) - F(a) * G(a)

thm integration_by_parts:
    ? forall a, b R, F, G, dF, dG fn(x '[a, b]) R:
        a < b
        forall x '[a, b]:
            $chap10::has_derivative_at('[a, b], F, x, dF(x))
            $chap10::has_derivative_at('[a, b], G, x, dG(x))
        $is_riemann_integrable_on('[a, b], dF)
        $is_riemann_integrable_on('[a, b], dG)
        =>:
            $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {F(x) * dG(x)})
            $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x)})
            integral_on('[a, b], fn(x '[a, b]) R {F(x) * dG(x)}) = F(b) * G(b) - F(a) * G(a) - integral_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x)})
    # Source handling: Tao proves this in Exercise 11.10.1 from the product
    # rule and the second fundamental theorem of calculus.  The long calculus
    # and integrability facts are isolated in the two preceding interfaces; the
    # final step is algebra.
    by thm integration_by_parts_product_terms_integrable(a, b, F, G, dF, dG)
    $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {F(x) * dG(x)})
    $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x)})
    by thm integration_by_parts_product_derivative_integral_identity(a, b, F, G, dF, dG)
    integral_on('[a, b], fn(x '[a, b]) R {F(x) * dG(x)}) + integral_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x)}) = F(b) * G(b) - F(a) * G(a)
    integral_on('[a, b], fn(x '[a, b]) R {F(x) * dG(x)}) = F(b) * G(b) - F(a) * G(a) - integral_on('[a, b], fn(x '[a, b]) R {dF(x) * G(x)})

"""
Theorem 11.10.2.  When monotone `alpha` is differentiable and `alpha'` is
Riemann integrable, the Riemann-Stieltjes integral of a piecewise constant
function equals the Riemann integral of `f*alpha'`.
"""

thm stieltjes_piecewise_constant_as_riemann_integral:
    ? forall a, b R, alpha fn(x R) R, dalpha, f fn(x '[a, b]) R:
        a < b
        $chap9::is_monotone_increasing_on(R, alpha)
        forall x '[a, b]:
            $chap10::has_derivative_at('[a, b], fn(t '[a, b]) R {alpha(t)}, x, dalpha(x))
        $is_riemann_integrable_on('[a, b], dalpha)
        $is_piecewise_constant_on('[a, b], f)
        =>:
            $is_riemann_stieltjes_integrable_on('[a, b], alpha, f)
            $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {f(x) * dalpha(x)})
            stieltjes_integral_on('[a, b], alpha, f) = integral_on('[a, b], fn(x '[a, b]) R {f(x) * dalpha(x)})
    by thm non_degenerate_interval_forms_are_bounded_intervals(a, b)
    $is_bounded_interval('[a, b])
    by thm piecewise_constant_on_bounded_interval_is_bounded('[a, b], f)
    $chap9::is_bounded_function_on('[a, b], f)
    have s R = piecewise_constant_riemann_stieltjes_integral('[a, b], alpha, f)
    by thm piecewise_constant_riemann_stieltjes_integral_has_value('[a, b], alpha, f)
    $has_piecewise_constant_riemann_stieltjes_integral('[a, b], alpha, f, s)
    $has_upper_riemann_stieltjes_integral('[a, b], alpha, f, upper_riemann_stieltjes_integral('[a, b], alpha, f))
    $has_lower_riemann_stieltjes_integral('[a, b], alpha, f, lower_riemann_stieltjes_integral('[a, b], alpha, f))
    claim:
        ? $is_upper_riemann_stieltjes_integral_candidate_value('[a, b], alpha, f, s)
        witness exist g fn(x '[a, b]) R st {$is_piecewise_constant_on('[a, b], g), $majorizes_on('[a, b], g, f), $has_piecewise_constant_riemann_stieltjes_integral('[a, b], alpha, g, s)} from f:
            $is_piecewise_constant_on('[a, b], f)
            claim:
                ? $majorizes_on('[a, b], f, f)
                forall x '[a, b]:
                    f(x) >= f(x)
            $has_piecewise_constant_riemann_stieltjes_integral('[a, b], alpha, f, s)
    by thm upper_riemann_stieltjes_integral_candidate_value_member('[a, b], alpha, f, s)
    s $in upper_riemann_stieltjes_integral_candidate_values('[a, b], alpha, f)
    upper_riemann_stieltjes_integral('[a, b], alpha, f) <= s
    claim:
        ? $is_lower_riemann_stieltjes_integral_candidate_value('[a, b], alpha, f, s)
        witness exist h fn(x '[a, b]) R st {$is_piecewise_constant_on('[a, b], h), $minorizes_on('[a, b], h, f), $has_piecewise_constant_riemann_stieltjes_integral('[a, b], alpha, h, s)} from f:
            $is_piecewise_constant_on('[a, b], f)
            claim:
                ? $minorizes_on('[a, b], f, f)
                forall x '[a, b]:
                    f(x) <= f(x)
            $has_piecewise_constant_riemann_stieltjes_integral('[a, b], alpha, f, s)
    by thm lower_riemann_stieltjes_integral_candidate_value_member('[a, b], alpha, f, s)
    s $in lower_riemann_stieltjes_integral_candidate_values('[a, b], alpha, f)
    s <= lower_riemann_stieltjes_integral('[a, b], alpha, f)
    claim:
        ? $is_upper_bound_of_real_set(lower_riemann_stieltjes_integral_candidate_values('[a, b], alpha, f), upper_riemann_stieltjes_integral('[a, b], alpha, f))
        claim:
            ? forall sh lower_riemann_stieltjes_integral_candidate_values('[a, b], alpha, f):
                sh <= upper_riemann_stieltjes_integral('[a, b], alpha, f)
            by thm lower_riemann_stieltjes_integral_candidate_value_from_member('[a, b], alpha, f, sh)
            obtain h from exist h fn(x '[a, b]) R st {$is_piecewise_constant_on('[a, b], h), $minorizes_on('[a, b], h, f), $has_piecewise_constant_riemann_stieltjes_integral('[a, b], alpha, h, sh)}
            claim:
                ? $is_lower_bound_of_real_set(upper_riemann_stieltjes_integral_candidate_values('[a, b], alpha, f), sh)
                claim:
                    ? forall sg upper_riemann_stieltjes_integral_candidate_values('[a, b], alpha, f):
                        sh <= sg
                    by thm upper_riemann_stieltjes_integral_candidate_value_from_member('[a, b], alpha, f, sg)
                    obtain g from exist g fn(x '[a, b]) R st {$is_piecewise_constant_on('[a, b], g), $majorizes_on('[a, b], g, f), $has_piecewise_constant_riemann_stieltjes_integral('[a, b], alpha, g, sg)}
                    by thm piecewise_constant_stieltjes_minorant_integral_le_majorant_integral('[a, b], alpha, f, g, h, sg, sh)
            sh <= upper_riemann_stieltjes_integral('[a, b], alpha, f)
    lower_riemann_stieltjes_integral('[a, b], alpha, f) <= upper_riemann_stieltjes_integral('[a, b], alpha, f)
    upper_riemann_stieltjes_integral('[a, b], alpha, f) <= s <= lower_riemann_stieltjes_integral('[a, b], alpha, f)
    upper_riemann_stieltjes_integral('[a, b], alpha, f) <= lower_riemann_stieltjes_integral('[a, b], alpha, f)
    upper_riemann_stieltjes_integral('[a, b], alpha, f) = lower_riemann_stieltjes_integral('[a, b], alpha, f)
    by def $is_riemann_stieltjes_integrable_on('[a, b], alpha, f)
    $is_riemann_stieltjes_integrable_on('[a, b], alpha, f)
    by thm piecewise_constant_on_bounded_interval_is_riemann_integrable('[a, b], f)
    $is_riemann_integrable_on('[a, b], f)
    by thm products_preserve_riemann_integrability('[a, b], f, dalpha)
    $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {f(x) * dalpha(x)})
    # Source handling: Theorem 11.10.2 gives the finite piecewise calculation
    # and invokes the second FTC on every piece, but suppresses the formal
    # regrouping and endpoint transports.  The trust keeps that gap visible.
    # proof_debt: formalize finite additivity over arbitrary piecewise-constant
    # partitions and the per-piece second-FTC rewrite.
    trust stieltjes_integral_on('[a, b], alpha, f) = integral_on('[a, b], fn(x '[a, b]) R {f(x) * dalpha(x)})

"""
Corollary 11.10.3.  The same identity holds for every Riemann-Stieltjes
integrable `f`: `integral f d alpha = integral f alpha' dx`.
"""

thm stieltjes_to_riemann_integrability_by_piecewise_approximation:
    ? forall a, b R, alpha fn(x R) R, dalpha, f fn(x '[a, b]) R:
        a < b
        $chap9::is_monotone_increasing_on(R, alpha)
        forall x '[a, b]:
            $chap10::has_derivative_at('[a, b], fn(t '[a, b]) R {alpha(t)}, x, dalpha(x))
        $is_riemann_integrable_on('[a, b], dalpha)
        $is_riemann_stieltjes_integrable_on('[a, b], alpha, f)
        =>:
            $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {f(x) * dalpha(x)})
    # Source handling: Corollary 11.10.3 gives the piecewise upper/lower
    # approximation route, but compresses the transfer from the displayed
    # inequalities to ordinary Riemann integrability.  The trust keeps that
    # source gap visible.
    # proof_debt: carry the Darboux squeeze through the product with
    # non-negative `alpha'`.
    trust $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {f(x) * dalpha(x)})

thm stieltjes_to_riemann_identity_by_piecewise_approximation:
    ? forall a, b R, alpha fn(x R) R, dalpha, f fn(x '[a, b]) R:
        a < b
        $chap9::is_monotone_increasing_on(R, alpha)
        forall x '[a, b]:
            $chap10::has_derivative_at('[a, b], fn(t '[a, b]) R {alpha(t)}, x, dalpha(x))
        $is_riemann_integrable_on('[a, b], dalpha)
        $is_riemann_stieltjes_integrable_on('[a, b], alpha, f)
        $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {f(x) * dalpha(x)})
        =>:
            stieltjes_integral_on('[a, b], alpha, f) = integral_on('[a, b], fn(x '[a, b]) R {f(x) * dalpha(x)})
    # Source handling: Corollary 11.10.3 gives the final epsilon squeeze, but
    # compresses the two envelope transports needed to compare the selected
    # integrals.  The trust keeps that source gap visible.
    # proof_debt: formalize the upper/lower Riemann-Stieltjes squeeze and use
    # non-negativity of `alpha'`.
    trust stieltjes_integral_on('[a, b], alpha, f) = integral_on('[a, b], fn(x '[a, b]) R {f(x) * dalpha(x)})

thm stieltjes_integral_as_riemann_integral:
    ? forall a, b R, alpha fn(x R) R, dalpha, f fn(x '[a, b]) R:
        a < b
        $chap9::is_monotone_increasing_on(R, alpha)
        forall x '[a, b]:
            $chap10::has_derivative_at('[a, b], fn(t '[a, b]) R {alpha(t)}, x, dalpha(x))
        $is_riemann_integrable_on('[a, b], dalpha)
        $is_riemann_stieltjes_integrable_on('[a, b], alpha, f)
        =>:
            $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {f(x) * dalpha(x)})
            stieltjes_integral_on('[a, b], alpha, f) = integral_on('[a, b], fn(x '[a, b]) R {f(x) * dalpha(x)})
    by thm stieltjes_to_riemann_integrability_by_piecewise_approximation(a, b, alpha, dalpha, f)
    by thm stieltjes_to_riemann_identity_by_piecewise_approximation(a, b, alpha, dalpha, f)

"""
Remark 11.10.4.  Informally, `d alpha` can be replaced by `alpha'(x) dx` when
`alpha` is differentiable, but Stieltjes integration still makes sense for
non-differentiable monotone `alpha`.
"""

thm derivative_values_imply_continuous_on_closed_interval:
    ? forall a, b R, phi fn(x R) R, dphi fn(x '[a, b]) R:
        a < b
        forall x '[a, b]:
            $chap10::has_derivative_at('[a, b], fn(t '[a, b]) R {phi(t)}, x, dphi(x))
        =>:
            $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {phi(x)})
    # Source handling: this is the Chapter 10 differentiability-implies-
    # continuity theorem specialized to the restricted function on `[a,b]`;
    # the local theorem above carries the single remaining Chapter 10 debt.
    by thm derivative_values_imply_continuous_on_closed_interval_local(a, b, fn(t '[a, b]) R {phi(t)}, dphi)
    $chap9::is_continuous_on('[a, b], fn(t '[a, b]) R {phi(t)})
    fn(t '[a, b]) R {phi(t)} = fn(x '[a, b]) R {phi(x)}
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {phi(x)})

prop maps_closed_interval_to_closed_interval(a, b, u, v R, phi fn(x R) R):
    a <= b
    u <= v
    forall x '[a, b]:
        phi(x) $in '[u, v]
    forall y '[u, v]:
        exist x '[a, b] st {phi(x) = y}

prop is_composition_on_closed_interval(a, b, u, v R, phi fn(x R) R, f fn(y '[u, v]) R, h fn(x '[a, b]) R):
    forall x '[a, b]:
        phi(x) $in '[u, v]
        h(x) = f(phi(x))

"""
Lemma 11.10.5 (Change of variables formula I).  For continuous monotone
increasing `phi`, composition with `phi` preserves piecewise constancy and the
Stieltjes integral with respect to `phi` equals the ordinary integral over the
image interval.
"""

thm change_of_variables_piecewise_constant:
    ? forall a, b, u, v R, phi fn(x R) R, f fn(y '[u, v]) R, h fn(x '[a, b]) R:
        a < b
        u = phi(a)
        v = phi(b)
        $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {phi(x)})
        $chap9::is_monotone_increasing_on(R, phi)
        $maps_closed_interval_to_closed_interval(a, b, u, v, phi)
        $is_piecewise_constant_on('[u, v], f)
        $is_composition_on_closed_interval(a, b, u, v, phi, f, h)
        =>:
            $is_piecewise_constant_on('[a, b], h)
            $is_riemann_integrable_on('[u, v], f)
            $is_riemann_stieltjes_integrable_on('[a, b], phi, h)
            stieltjes_integral_on('[a, b], phi, h) = integral_on('[u, v], f)
    # Source handling: Lemma 11.10.5 gives only a proof sketch and leaves its
    # marked "why?" gaps to Exercise 11.10.2.  This trust records the
    # source-deferred preimage-partition step.
    # proof_debt: build the preimage partition and prove its interval pieces.
    trust $is_piecewise_constant_on('[a, b], h)
    by thm interval_endpoint_forms_are_bounded_intervals(u, v)
    $is_bounded_interval('[u, v])
    by thm piecewise_constant_on_bounded_interval_is_riemann_integrable('[u, v], f)
    $is_riemann_integrable_on('[u, v], f)
    # Source handling: Lemma 11.10.5 leaves the marked finite-sum and
    # image-length gaps to Exercise 11.10.2.  This trust records exactly those
    # source-deferred conclusions.
    # proof_debt: prove `phi[phi^{-1}(J)]` has the same length as `J` and sum
    # over the preimage partition.
    trust:
        $is_riemann_stieltjes_integrable_on('[a, b], phi, h)
        stieltjes_integral_on('[a, b], phi, h) = integral_on('[u, v], f)

# Proof-package bridges for Proposition 11.10.6.  Tao's main statement is
# `change_of_variables_stieltjes` below; these two theorems split the Darboux
# approximation proof into integrability and identity substeps for the verifier.

thm change_of_variables_stieltjes_integrability_by_piecewise_approximation:
    ? forall a, b, u, v R, phi fn(x R) R, f fn(y '[u, v]) R, h fn(x '[a, b]) R:
        a < b
        u = phi(a)
        v = phi(b)
        $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {phi(x)})
        $chap9::is_monotone_increasing_on(R, phi)
        $maps_closed_interval_to_closed_interval(a, b, u, v, phi)
        $is_riemann_integrable_on('[u, v], f)
        $is_composition_on_closed_interval(a, b, u, v, phi, f, h)
        =>:
            $is_riemann_stieltjes_integrable_on('[a, b], phi, h)
    # Source handling: Proposition 11.10.6 gives the transferred
    # majorant/minorant squeeze, but compresses the pullback and envelope
    # transports.  The trust keeps that source gap visible.
    # proof_debt: formalize the transferred Darboux squeeze.
    trust $is_riemann_stieltjes_integrable_on('[a, b], phi, h)

thm change_of_variables_stieltjes_identity_by_piecewise_approximation:
    ? forall a, b, u, v R, phi fn(x R) R, f fn(y '[u, v]) R, h fn(x '[a, b]) R:
        a < b
        u = phi(a)
        v = phi(b)
        $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {phi(x)})
        $chap9::is_monotone_increasing_on(R, phi)
        $maps_closed_interval_to_closed_interval(a, b, u, v, phi)
        $is_riemann_integrable_on('[u, v], f)
        $is_composition_on_closed_interval(a, b, u, v, phi, f, h)
        $is_riemann_stieltjes_integrable_on('[a, b], phi, h)
        =>:
            stieltjes_integral_on('[a, b], phi, h) = integral_on('[u, v], f)
    # Source handling: Proposition 11.10.6 gives the final epsilon squeeze,
    # but compresses the comparison between the selected Stieltjes value and
    # the transferred piecewise integrals.  The trust keeps that gap visible.
    # proof_debt: carry the equality from Lemma 11.10.5 through the
    # upper/lower approximation limit.
    trust stieltjes_integral_on('[a, b], phi, h) = integral_on('[u, v], f)

"""
Proposition 11.10.6 (Change of variables formula II).  The preceding
piecewise-constant change-of-variables identity extends to Riemann integrable
functions by upper/lower approximation.
"""

thm change_of_variables_stieltjes:
    ? forall a, b, u, v R, phi fn(x R) R, f fn(y '[u, v]) R, h fn(x '[a, b]) R:
        a < b
        u = phi(a)
        v = phi(b)
        $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {phi(x)})
        $chap9::is_monotone_increasing_on(R, phi)
        $maps_closed_interval_to_closed_interval(a, b, u, v, phi)
        $is_riemann_integrable_on('[u, v], f)
        $is_composition_on_closed_interval(a, b, u, v, phi, f, h)
        =>:
            $is_riemann_stieltjes_integrable_on('[a, b], phi, h)
            stieltjes_integral_on('[a, b], phi, h) = integral_on('[u, v], f)
    by thm change_of_variables_stieltjes_integrability_by_piecewise_approximation(a, b, u, v, phi, f, h)
    by thm change_of_variables_stieltjes_identity_by_piecewise_approximation(a, b, u, v, phi, f, h)

"""
Proposition 11.10.7 (Change of variables formula III).  If `phi` is
differentiable and monotone increasing, then the familiar Riemann integral
change-of-variables formula follows from Proposition 11.10.6 and Corollary
11.10.3.
"""

thm change_of_variables_riemann:
    ? forall a, b, u, v R, phi fn(x R) R, dphi fn(x '[a, b]) R, f fn(y '[u, v]) R, h fn(x '[a, b]) R:
        a < b
        u = phi(a)
        v = phi(b)
        $chap9::is_monotone_increasing_on(R, phi)
        forall x '[a, b]:
            $chap10::has_derivative_at('[a, b], fn(t '[a, b]) R {phi(t)}, x, dphi(x))
        $is_riemann_integrable_on('[a, b], dphi)
        $maps_closed_interval_to_closed_interval(a, b, u, v, phi)
        $is_riemann_integrable_on('[u, v], f)
        $is_composition_on_closed_interval(a, b, u, v, phi, f, h)
        =>:
            $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {h(x) * dphi(x)})
            integral_on('[a, b], fn(x '[a, b]) R {h(x) * dphi(x)}) = integral_on('[u, v], f)
    # Source handling: Tao combines the Stieltjes change-of-variables formula
    # with the conversion `dphi = phi'(x) dx`.
    by thm derivative_values_imply_continuous_on_closed_interval(a, b, phi, dphi)
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {phi(x)})
    by thm change_of_variables_stieltjes(a, b, u, v, phi, f, h)
    $is_riemann_stieltjes_integrable_on('[a, b], phi, h)
    stieltjes_integral_on('[a, b], phi, h) = integral_on('[u, v], f)
    by thm stieltjes_integral_as_riemann_integral(a, b, phi, dphi, h)
    $is_riemann_integrable_on('[a, b], fn(x '[a, b]) R {h(x) * dphi(x)})
    stieltjes_integral_on('[a, b], phi, h) = integral_on('[a, b], fn(x '[a, b]) R {h(x) * dphi(x)})
    integral_on('[a, b], fn(x '[a, b]) R {h(x) * dphi(x)}) = stieltjes_integral_on('[a, b], phi, h)
    integral_on('[a, b], fn(x '[a, b]) R {h(x) * dphi(x)}) = integral_on('[u, v], f)
