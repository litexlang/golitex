    forall y '[1, 4]:
        exist! J example_11_2_12_refined_partition_set st {J $in power_set(R), y $in J}

thm example_11_2_12_displayed_partition_piecewise_constant:
    ? forall f fn(x '[1, 4]) R:
        $is_example_11_2_12_function(f)
        =>:
            $is_piecewise_constant_with_partition('[1, 4], example_11_2_12_partition_set, f)
    # Source handling: the displayed partition separates the three regions on
    # which `f` has the fixed values `2`, `4`, and `6`.
    claim:
        ? $is_partition_of_bounded_interval('[1, 4], example_11_2_12_partition_set)
        by thm non_degenerate_interval_forms_are_bounded_intervals(1, 4)
        claim:
            ? forall J example_11_2_12_partition_set:
                J $in power_set(R)
                $is_bounded_interval(J)
                J $subset '[1, 4]
            by thm example_11_2_12_displayed_partition_piece_clauses(J)
        claim:
            ? forall x '[1, 4]:
                exist! J example_11_2_12_partition_set st {J $in power_set(R), x $in J}
            by thm example_11_2_12_displayed_partition_unique_cover(x)
        $is_partition_of_bounded_interval('[1, 4], example_11_2_12_partition_set)
    claim:
        ? forall J example_11_2_12_partition_set:
            $is_constant_on_subset('[1, 4], J, f)
        # Source handling: this is the three-piece case split in Example
        # 11.2.12.
        by enumerate finite_set:
            ? forall K example_11_2_12_partition_set:
                K = '[1, 3) or K = {3} or K = '(3, 4]
        by cases:
            ? $is_constant_on_subset('[1, 4], J, f)
            case J = '[1, 3):
                by thm non_degenerate_interval_forms_are_bounded_intervals(1, 3)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 3)
                        1 <= x
                        x < 3
                        x < 3 < 4
                        x < 4
                        x <= 4
                        x $in '[1, 4]
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 2:
                    J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 4]
                        x $in '[1, 3)
                        x < 3
                        f(x) = 2
                    $has_constant_value_on_subset('[1, 4], J, f, 2)
            case J = {3}:
                by thm singleton_interval_is_bounded(3)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    forall x J:
                        x = 3
                        1 <= x
                        x <= 4
                        x $in '[1, 4]
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 4:
                    J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 4]
                        x = 3
                        f(x) = 4
                    $has_constant_value_on_subset('[1, 4], J, f, 4)
            case J = '(3, 4]:
                by thm non_degenerate_interval_forms_are_bounded_intervals(3, 4)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    forall x J:
                        x $in '(3, 4]
                        3 < x
                        x <= 4
                        1 < 3 < x
                        1 < x
                        1 <= x
                        x $in '[1, 4]
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 6:
                    J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 4]
                        x $in '(3, 4]
                        3 < x
                        x > 3
                        f(x) = 6
                    $has_constant_value_on_subset('[1, 4], J, f, 6)
    $is_piecewise_constant_with_partition('[1, 4], example_11_2_12_partition_set, f)

thm example_11_2_12_refined_partition_piecewise_constant:
    ? forall f fn(x '[1, 4]) R:
        $is_example_11_2_12_function(f)
        =>:
            $is_piecewise_constant_with_partition('[1, 4], example_11_2_12_refined_partition_set, f)
    # Source handling: the refined partition only splits the first constant
    # region and adds an empty piece, so it preserves the same piecewise
    # constant values.
    claim:
        ? $is_partition_of_bounded_interval('[1, 4], example_11_2_12_refined_partition_set)
        by thm non_degenerate_interval_forms_are_bounded_intervals(1, 4)
        claim:
            ? forall J example_11_2_12_refined_partition_set:
                J $in power_set(R)
                $is_bounded_interval(J)
                J $subset '[1, 4]
            by thm example_11_2_12_refined_partition_piece_clauses(J)
        claim:
            ? forall x '[1, 4]:
                exist! J example_11_2_12_refined_partition_set st {J $in power_set(R), x $in J}
            by thm example_11_2_12_refined_partition_unique_cover(x)
        $is_partition_of_bounded_interval('[1, 4], example_11_2_12_refined_partition_set)
    claim:
        ? forall J example_11_2_12_refined_partition_set:
            $is_constant_on_subset('[1, 4], J, f)
        # Source handling: this is the refined five-piece case split in
        # Example 11.2.12.
        by enumerate finite_set:
            ? forall K example_11_2_12_refined_partition_set:
                K = '[1, 2) or K = '[2, 3) or K = {3} or K = '(3, 4] or K = {}
        by cases:
            ? $is_constant_on_subset('[1, 4], J, f)
            case J = '[1, 2):
                by thm non_degenerate_interval_forms_are_bounded_intervals(1, 2)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 2)
                        1 <= x
                        x < 2
                        x < 2 < 4
                        x < 4
                        x <= 4
                        x $in '[1, 4]
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 2:
                    J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 4]
                        x $in '[1, 2)
                        x < 2
                        x < 2 < 3
                        x < 3
                        f(x) = 2
                    $has_constant_value_on_subset('[1, 4], J, f, 2)
            case J = '[2, 3):
                by thm non_degenerate_interval_forms_are_bounded_intervals(2, 3)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    forall x J:
                        x $in '[2, 3)
                        2 <= x
                        x < 3
                        1 < 2 <= x
                        1 <= x
                        x < 3 < 4
                        x < 4
                        x <= 4
                        x $in '[1, 4]
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 2:
                    J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 4]
                        x $in '[2, 3)
                        x < 3
                        f(x) = 2
                    $has_constant_value_on_subset('[1, 4], J, f, 2)
            case J = {3}:
                by thm singleton_interval_is_bounded(3)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    forall x J:
                        x = 3
                        1 <= x
                        x <= 4
                        x $in '[1, 4]
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 4:
                    J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 4]
                        x = 3
                        f(x) = 4
                    $has_constant_value_on_subset('[1, 4], J, f, 4)
            case J = '(3, 4]:
                by thm non_degenerate_interval_forms_are_bounded_intervals(3, 4)
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    forall x J:
                        x $in '(3, 4]
                        3 < x
                        x <= 4
                        1 < 3 < x
                        1 < x
                        1 <= x
                        x $in '[1, 4]
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 6:
                    J $subset '[1, 4]
                    forall x J:
                        x $in '[1, 4]
                        x $in '(3, 4]
                        3 < x
                        x > 3
                        f(x) = 6
                    $has_constant_value_on_subset('[1, 4], J, f, 6)
            case J = {}:
                by thm empty_interval_is_bounded()
                J $in power_set(R)
                claim:
                    ? J $subset '[1, 4]
                    claim:
                        ? forall x J:
                            x $in '[1, 4]
                        by contra:
                            ? x $in '[1, 4]
                            x $in J
                            x $in {}
                            not $is_nonempty_set({})
                            witness $is_nonempty_set({}) from x
                            impossible $is_nonempty_set({})
                    J $subset '[1, 4]
                witness exist c R st {$has_constant_value_on_subset('[1, 4], J, f, c)} from 0:
                    J $subset '[1, 4]
                    claim:
                        ? forall x J:
                            f(x) = 0
                        by contra:
                            ? f(x) = 0
                            x $in J
                            x $in {}
                            not $is_nonempty_set({})
                            witness $is_nonempty_set({}) from x
                            impossible $is_nonempty_set({})
                    $has_constant_value_on_subset('[1, 4], J, f, 0)
    $is_piecewise_constant_with_partition('[1, 4], example_11_2_12_refined_partition_set, f)

thm example_11_2_12_piece_contribution_has_values:
    ? forall f fn(x '[1, 4]) R:
        $is_example_11_2_12_function(f)
        =>:
            $has_piecewise_constant_integral_piece_contribution('[1, 4], '[1, 3), f, 4)
            $has_piecewise_constant_integral_piece_contribution('[1, 4], {3}, f, 0)
            $has_piecewise_constant_integral_piece_contribution('[1, 4], '(3, 4], f, 6)
            $has_piecewise_constant_integral_piece_contribution('[1, 4], '[1, 2), f, 2)
            $has_piecewise_constant_integral_piece_contribution('[1, 4], '[2, 3), f, 2)
            $has_piecewise_constant_integral_piece_contribution('[1, 4], {}, f, 0)
    # Source handling: this performs the rectangle-value calculation on each
    # concrete piece used in Example 11.2.12.
    claim:
        ? '[1, 3) $subset '[1, 4]
        forall x '[1, 3):
            x $in '[1, 3)
            1 <= x
            x < 3
            x < 3 < 4
            x < 4
            x <= 4
            x $in '[1, 4]
        '[1, 3) $subset '[1, 4]
    claim:
        ? $has_constant_value_on_subset('[1, 4], '[1, 3), f, 2)
        '[1, 3) $subset '[1, 4]
        forall x '[1, 3):
            x $in '[1, 4]
            x $in '[1, 3)
            x < 3
            f(x) = 2
    claim:
        ? $is_constant_on_subset('[1, 4], '[1, 3), f)
        witness exist c R st {$has_constant_value_on_subset('[1, 4], '[1, 3), f, c)} from 2:
            $has_constant_value_on_subset('[1, 4], '[1, 3), f, 2)
    by thm non_degenerate_interval_forms_are_bounded_intervals(1, 3)
    by thm non_degenerate_interval_forms_length_value(1, 3)
    interval_length('[1, 3)) = 3 - 1 = 2
    claim:
        ? $has_piecewise_constant_integral_piece_contribution('[1, 4], '[1, 3), f, 4)
        witness exist c R st {$has_constant_value_on_subset('[1, 4], '[1, 3), f, c), 4 = c * interval_length('[1, 3))} from 2:
            $has_constant_value_on_subset('[1, 4], '[1, 3), f, 2)
            2 * interval_length('[1, 3)) = 2 * 2 = 4
            4 = 2 * interval_length('[1, 3))
        $has_piecewise_constant_integral_piece_contribution('[1, 4], '[1, 3), f, 4)

    claim:
        ? {3} $subset '[1, 4]
        forall x {3}:
            x = 3
            1 <= x
            x <= 4
            x $in '[1, 4]
        {3} $subset '[1, 4]
    claim:
        ? $has_constant_value_on_subset('[1, 4], {3}, f, 4)
        {3} $subset '[1, 4]
        forall x {3}:
            x $in '[1, 4]
            x = 3
            f(x) = 4
    claim:
        ? $is_constant_on_subset('[1, 4], {3}, f)
        witness exist c R st {$has_constant_value_on_subset('[1, 4], {3}, f, c)} from 4:
            $has_constant_value_on_subset('[1, 4], {3}, f, 4)
    by thm singleton_interval_is_bounded(3)
    by thm singleton_interval_length_value(3)
    claim:
        ? $has_piecewise_constant_integral_piece_contribution('[1, 4], {3}, f, 0)
        witness exist c R st {$has_constant_value_on_subset('[1, 4], {3}, f, c), 0 = c * interval_length({3})} from 4:
            $has_constant_value_on_subset('[1, 4], {3}, f, 4)
            4 * interval_length({3}) = 4 * 0 = 0
            0 = 4 * interval_length({3})
        $has_piecewise_constant_integral_piece_contribution('[1, 4], {3}, f, 0)

    claim:
        ? '(3, 4] $subset '[1, 4]
        forall x '(3, 4]:
            x $in '(3, 4]
            3 < x
            x <= 4
            1 < 3 < x
            1 < x
            1 <= x
            x $in '[1, 4]
        '(3, 4] $subset '[1, 4]
    claim:
        ? $has_constant_value_on_subset('[1, 4], '(3, 4], f, 6)
        '(3, 4] $subset '[1, 4]
        forall x '(3, 4]:
            x $in '[1, 4]
            x $in '(3, 4]
            3 < x
            x > 3
            f(x) = 6
    claim:
        ? $is_constant_on_subset('[1, 4], '(3, 4], f)
        witness exist c R st {$has_constant_value_on_subset('[1, 4], '(3, 4], f, c)} from 6:
            $has_constant_value_on_subset('[1, 4], '(3, 4], f, 6)
    by thm non_degenerate_interval_forms_are_bounded_intervals(3, 4)
    by thm non_degenerate_interval_forms_length_value(3, 4)
    interval_length('(3, 4]) = 4 - 3 = 1
    claim:
        ? $has_piecewise_constant_integral_piece_contribution('[1, 4], '(3, 4], f, 6)
        witness exist c R st {$has_constant_value_on_subset('[1, 4], '(3, 4], f, c), 6 = c * interval_length('(3, 4])} from 6:
            $has_constant_value_on_subset('[1, 4], '(3, 4], f, 6)
            6 * interval_length('(3, 4]) = 6 * 1 = 6
            6 = 6 * interval_length('(3, 4])
        $has_piecewise_constant_integral_piece_contribution('[1, 4], '(3, 4], f, 6)

    claim:
        ? '[1, 2) $subset '[1, 4]
        forall x '[1, 2):
            x $in '[1, 2)
            1 <= x
            x < 2
            x < 2 < 4
            x < 4
            x <= 4
            x $in '[1, 4]
        '[1, 2) $subset '[1, 4]
    claim:
        ? $has_constant_value_on_subset('[1, 4], '[1, 2), f, 2)
        '[1, 2) $subset '[1, 4]
        forall x '[1, 2):
            x $in '[1, 4]
            x $in '[1, 2)
            x < 2
            x < 2 < 3
            x < 3
            f(x) = 2
    claim:
        ? $is_constant_on_subset('[1, 4], '[1, 2), f)
        witness exist c R st {$has_constant_value_on_subset('[1, 4], '[1, 2), f, c)} from 2:
            $has_constant_value_on_subset('[1, 4], '[1, 2), f, 2)
    by thm non_degenerate_interval_forms_are_bounded_intervals(1, 2)
    by thm non_degenerate_interval_forms_length_value(1, 2)
    interval_length('[1, 2)) = 2 - 1 = 1
    claim:
        ? $has_piecewise_constant_integral_piece_contribution('[1, 4], '[1, 2), f, 2)
        witness exist c R st {$has_constant_value_on_subset('[1, 4], '[1, 2), f, c), 2 = c * interval_length('[1, 2))} from 2:
            $has_constant_value_on_subset('[1, 4], '[1, 2), f, 2)
            2 * interval_length('[1, 2)) = 2 * 1 = 2
            2 = 2 * interval_length('[1, 2))
        $has_piecewise_constant_integral_piece_contribution('[1, 4], '[1, 2), f, 2)

    claim:
        ? '[2, 3) $subset '[1, 4]
        forall x '[2, 3):
            x $in '[2, 3)
            2 <= x
            x < 3
            1 < 2 <= x
            1 <= x
            x < 3 < 4
            x < 4
            x <= 4
            x $in '[1, 4]
        '[2, 3) $subset '[1, 4]
    claim:
        ? $has_constant_value_on_subset('[1, 4], '[2, 3), f, 2)
        '[2, 3) $subset '[1, 4]
        forall x '[2, 3):
            x $in '[1, 4]
            x $in '[2, 3)
            x < 3
            f(x) = 2
    claim:
        ? $is_constant_on_subset('[1, 4], '[2, 3), f)
        witness exist c R st {$has_constant_value_on_subset('[1, 4], '[2, 3), f, c)} from 2:
            $has_constant_value_on_subset('[1, 4], '[2, 3), f, 2)
    by thm non_degenerate_interval_forms_are_bounded_intervals(2, 3)
    by thm non_degenerate_interval_forms_length_value(2, 3)
    interval_length('[2, 3)) = 3 - 2 = 1
    claim:
        ? $has_piecewise_constant_integral_piece_contribution('[1, 4], '[2, 3), f, 2)
        witness exist c R st {$has_constant_value_on_subset('[1, 4], '[2, 3), f, c), 2 = c * interval_length('[2, 3))} from 2:
            $has_constant_value_on_subset('[1, 4], '[2, 3), f, 2)
            2 * interval_length('[2, 3)) = 2 * 1 = 2
            2 = 2 * interval_length('[2, 3))
        $has_piecewise_constant_integral_piece_contribution('[1, 4], '[2, 3), f, 2)

    claim:
        ? {} $subset '[1, 4]
        claim:
            ? forall x {}:
                x $in '[1, 4]
            by contra:
                ? x $in '[1, 4]
                x $in {}
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from x
                impossible $is_nonempty_set({})
        {} $subset '[1, 4]
    claim:
        ? $has_constant_value_on_subset('[1, 4], {}, f, 0)
        {} $subset '[1, 4]
        claim:
            ? forall x {}:
                f(x) = 0
            by contra:
                ? f(x) = 0
                x $in {}
                not $is_nonempty_set({})
                witness $is_nonempty_set({}) from x
                impossible $is_nonempty_set({})
    claim:
        ? $is_constant_on_subset('[1, 4], {}, f)
        witness exist c R st {$has_constant_value_on_subset('[1, 4], {}, f, c)} from 0:
            $has_constant_value_on_subset('[1, 4], {}, f, 0)
    by thm empty_interval_is_bounded()
    by thm empty_interval_length_value()
    claim:
        ? $has_piecewise_constant_integral_piece_contribution('[1, 4], {}, f, 0)
        witness exist c R st {$has_constant_value_on_subset('[1, 4], {}, f, c), 0 = c * interval_length({})} from 0:
            $has_constant_value_on_subset('[1, 4], {}, f, 0)
            0 * interval_length({}) = 0
            0 = 0 * interval_length({})
        $has_piecewise_constant_integral_piece_contribution('[1, 4], {}, f, 0)

thm example_11_2_12_piecewise_constant_integral:
    ? forall f fn(x '[1, 4]) R:
        $is_example_11_2_12_function(f)
        =>:
            $has_piecewise_constant_integral_with_partition('[1, 4], example_11_2_12_partition_set, f, 10)
            $has_piecewise_constant_integral_with_partition('[1, 4], example_11_2_12_refined_partition_set, f, 10)
    # Source handling: Tao computes `2*2 + 4*0 + 6*1 = 10` and repeats the
    # computation after refinement.
    by thm example_11_2_12_displayed_partition_piecewise_constant(f)
    by thm example_11_2_12_refined_partition_piecewise_constant(f)
    by thm piecewise_constant_partition_is_set_of_real_subsets('[1, 4], example_11_2_12_partition_set, f)
    by thm piecewise_constant_partition_is_set_of_real_subsets('[1, 4], example_11_2_12_refined_partition_set, f)
    by thm example_11_2_12_piece_contribution_has_values(f)
    by thm piecewise_constant_integral_piece_contribution_has_value('[1, 4], '[1, 3), f, 4)
    by thm piecewise_constant_integral_piece_contribution_has_value('[1, 4], {3}, f, 0)
    by thm piecewise_constant_integral_piece_contribution_has_value('[1, 4], '(3, 4], f, 6)
    by thm piecewise_constant_integral_piece_contribution_has_value('[1, 4], '[1, 2), f, 2)
    by thm piecewise_constant_integral_piece_contribution_has_value('[1, 4], '[2, 3), f, 2)
    by thm piecewise_constant_integral_piece_contribution_has_value('[1, 4], {}, f, 0)
    piecewise_constant_integral_with_partition('[1, 4], example_11_2_12_partition_set, f) = finite_set_sum(example_11_2_12_partition_set, fn(J example_11_2_12_partition_set) R {piecewise_constant_integral_piece_contribution('[1, 4], J, f)})
    finite_set_sum(example_11_2_12_partition_set, fn(J example_11_2_12_partition_set) R {piecewise_constant_integral_piece_contribution('[1, 4], J, f)}) = 4 + 0 + 6
    4 + 0 + 6 = 10
    piecewise_constant_integral_with_partition('[1, 4], example_11_2_12_partition_set, f) = 10
    piecewise_constant_integral_with_partition('[1, 4], example_11_2_12_refined_partition_set, f) = finite_set_sum(example_11_2_12_refined_partition_set, fn(J example_11_2_12_refined_partition_set) R {piecewise_constant_integral_piece_contribution('[1, 4], J, f)})
    finite_set_sum(example_11_2_12_refined_partition_set, fn(J example_11_2_12_refined_partition_set) R {piecewise_constant_integral_piece_contribution('[1, 4], J, f)}) = 2 + 2 + 0 + 6 + 0
    2 + 2 + 0 + 6 + 0 = 10
    piecewise_constant_integral_with_partition('[1, 4], example_11_2_12_refined_partition_set, f) = 10
    $has_piecewise_constant_integral_with_partition('[1, 4], example_11_2_12_partition_set, f, 10)
    $has_piecewise_constant_integral_with_partition('[1, 4], example_11_2_12_refined_partition_set, f, 10)

# In a partition sum, an empty piece contributes zero. The finite-sum theorem
# above therefore restricts the rectangle sum to the nonempty pieces without
# choosing an owner for empty pieces.
thm piecewise_constant_partition_sum_ignores_empty_pieces:
    ? forall I power_set(R), P finite_set, f fn(x I) R:
        $is_piecewise_constant_with_partition(I, P, f)
        =>:
            finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)}) = finite_set_sum(nonempty_refinement_support(P), fn(J nonempty_refinement_support(P)) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    claim:
        ? nonempty_refinement_support(P) $subset P
        forall J nonempty_refinement_support(P):
            J $in P
    claim:
        ? forall J P:
            not J $in nonempty_refinement_support(P)
            =>:
                piecewise_constant_integral_piece_contribution(I, J, f) = 0
        by contra:
            ? not $is_nonempty_set(J)
            $is_nonempty_set(J)
            J $in {X P: $is_nonempty_set(X)}
            J $in nonempty_refinement_support(P)
            impossible not J $in nonempty_refinement_support(P)
        $is_partition_of_bounded_interval(I, P)
        J $in power_set(R)
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        obtain c from exist c R st {$has_constant_value_on_subset(I, J, f, c)}
        by thm empty_bounded_interval_length_value(J)
        interval_length(J) = 0
        witness exist c0 R st {$has_constant_value_on_subset(I, J, f, c0), 0 = c0 * interval_length(J)} from c:
            $has_constant_value_on_subset(I, J, f, c)
            0 = c * 0 = c * interval_length(J)
        $has_piecewise_constant_integral_piece_contribution(I, J, f, 0)
        by thm piecewise_constant_integral_piece_contribution_has_value(I, J, f, 0)
        piecewise_constant_integral_piece_contribution(I, J, f) = 0
    by thm finite_set_sum_ignores_zero_outside_subset(P, P, nonempty_refinement_support(P), fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)}) = finite_set_sum(nonempty_refinement_support(P), fn(J nonempty_refinement_support(P)) R {piecewise_constant_integral_piece_contribution(I, J, f)})

# Refining a partition does not change its finite rectangle sum.  The proof
# has the source's three distinct moves: discard empty fine pieces, regroup
# the remaining ones by coarse owner, and split each constant coarse rectangle
# using finite additivity of length.
thm piecewise_constant_integral_with_partition_reindexes_over_refinement:
    ? forall I power_set(R), Pcoarse, Pfine finite_set, f fn(x I) R:
        $is_piecewise_constant_with_partition(I, Pcoarse, f)
        $is_finer_partition_than(I, Pfine, Pcoarse)
        =>:
            piecewise_constant_integral_with_partition(I, Pcoarse, f) = piecewise_constant_integral_with_partition(I, Pfine, f)
    by thm piecewise_constant_refines(I, Pcoarse, Pfine, f)
    $is_piecewise_constant_with_partition(I, Pfine, f)
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, Pcoarse, f)
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, Pfine, f)
    have fn F(K Pcoarse) power_set(power_set(R)) = refinement_fiber(Pfine, K)
    claim:
        ? forall K Pcoarse:
            F(K) = refinement_fiber(Pfine, K)
        F(K) = refinement_fiber(Pfine, K)
    claim:
        ? forall K Pcoarse:
            piecewise_constant_integral_piece_contribution(I, K, f) = finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_integral_piece_contribution(I, J, f)})
        $is_partition_of_bounded_interval(I, Pcoarse)
        K $in power_set(R)
        $is_bounded_interval(K)
        K $subset I
        $is_constant_on_subset(I, K, f)
        obtain c from exist c R st {$has_constant_value_on_subset(I, K, f, c)}
        $has_constant_value_on_subset(I, K, f, c)
        by thm interval_length_reindexes_over_refinement_fiber(I, Pfine, Pcoarse, F, K)
        interval_length(K) = finite_set_sum(F(K), fn(J F(K)) R {interval_length(J)})
        by thm refinement_fiber_partitions_coarse_piece(I, Pfine, Pcoarse, F(K), K)
        $is_partition_of_bounded_interval(K, F(K))
        by thm constant_rectangle_reindexes_over_partition(I, K, F(K), f, c)
        piecewise_constant_integral_piece_contribution(I, K, f) = finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    claim:
        ? $fn_eq(fn(K Pcoarse) R {piecewise_constant_integral_piece_contribution(I, K, f)}, fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_integral_piece_contribution(I, J, f)})})
        forall K Pcoarse:
            piecewise_constant_integral_piece_contribution(I, K, f) = finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_integral_piece_contribution(I, J, f)})
            fn(K Pcoarse) R {piecewise_constant_integral_piece_contribution(I, K, f)}(K) = piecewise_constant_integral_piece_contribution(I, K, f)
            fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_integral_piece_contribution(I, J, f)})}(K) = finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_integral_piece_contribution(I, J, f)})
            fn(K Pcoarse) R {piecewise_constant_integral_piece_contribution(I, K, f)}(K) = fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_integral_piece_contribution(I, J, f)})}(K)
        $fn_eq(fn(K Pcoarse) R {piecewise_constant_integral_piece_contribution(I, K, f)}, fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_integral_piece_contribution(I, J, f)})})
    fn(K Pcoarse) R {piecewise_constant_integral_piece_contribution(I, K, f)} = fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_integral_piece_contribution(I, J, f)})}
    piecewise_constant_integral_with_partition(I, Pcoarse, f) = finite_set_sum(Pcoarse, fn(K Pcoarse) R {piecewise_constant_integral_piece_contribution(I, K, f)})
    finite_set_sum(Pcoarse, fn(K Pcoarse) R {piecewise_constant_integral_piece_contribution(I, K, f)}) = finite_set_sum(Pcoarse, fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_integral_piece_contribution(I, J, f)})})
    by thm refinement_fiber_cover_reindexes_ambient_sum(I, Pfine, Pcoarse, F, fn(J Pfine) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    finite_set_sum(nonempty_refinement_support(Pfine), fn(J nonempty_refinement_support(Pfine)) R {piecewise_constant_integral_piece_contribution(I, J, f)}) = finite_set_sum(Pcoarse, fn(K Pcoarse) R {finite_set_sum(F(K), fn(J F(K)) R {piecewise_constant_integral_piece_contribution(I, J, f)})})
    by thm piecewise_constant_partition_sum_ignores_empty_pieces(I, Pfine, f)
    finite_set_sum(Pfine, fn(J Pfine) R {piecewise_constant_integral_piece_contribution(I, J, f)}) = finite_set_sum(nonempty_refinement_support(Pfine), fn(J nonempty_refinement_support(Pfine)) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    piecewise_constant_integral_with_partition(I, Pfine, f) = finite_set_sum(Pfine, fn(J Pfine) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    piecewise_constant_integral_with_partition(I, Pcoarse, f) = piecewise_constant_integral_with_partition(I, Pfine, f)

"""
Proposition 11.2.13.  The piecewise constant integral does not depend on which
partition is used, as long as the function is piecewise constant for both
partitions.
"""

thm piecewise_constant_integral_independent_of_partition:
    ? forall I power_set(R), f fn(x I) R, P, Qpart finite_set, sP, sQ R:
        $is_piecewise_constant_with_partition(I, P, f)
        $is_piecewise_constant_with_partition(I, Qpart, f)
        $has_piecewise_constant_integral_with_partition(I, P, f, sP)
        $has_piecewise_constant_integral_with_partition(I, Qpart, f, sQ)
        =>:
            sP = sQ
    # Source handling: Tao proves this in Exercise 11.2.3 by moving both
    # partitions to their common refinement and using finite additivity of
    # length.
    $is_partition_of_bounded_interval(I, P)
    $is_partition_of_bounded_interval(I, Qpart)
    by thm partition_is_set_of_real_subsets(I, P)
    by thm partition_is_set_of_real_subsets(I, Qpart)
    have Rf finite_set = common_refinement(I, P, Qpart)
    $is_common_refinement_of_partitions(I, P, Qpart, Rf)
    by thm common_refinement_is_partition_and_finer(I, P, Qpart, Rf)
    $is_finer_partition_than(I, Rf, P)
    $is_finer_partition_than(I, Rf, Qpart)
    by thm piecewise_constant_integral_with_partition_reindexes_over_refinement(I, P, Rf, f)
    piecewise_constant_integral_with_partition(I, P, f) = piecewise_constant_integral_with_partition(I, Rf, f)
    by thm piecewise_constant_integral_with_partition_reindexes_over_refinement(I, Qpart, Rf, f)
    piecewise_constant_integral_with_partition(I, Qpart, f) = piecewise_constant_integral_with_partition(I, Rf, f)
    sP = piecewise_constant_integral_with_partition(I, P, f)
    sQ = piecewise_constant_integral_with_partition(I, Qpart, f)
    sP = piecewise_constant_integral_with_partition(I, P, f) = piecewise_constant_integral_with_partition(I, Rf, f) = piecewise_constant_integral_with_partition(I, Qpart, f) = sQ

thm piecewise_constant_integral_transports_to_finer_partition:
    ? forall I power_set(R), Pcoarse, Pfine finite_set, f fn(x I) R, s R:
        $has_piecewise_constant_integral_with_partition(I, Pcoarse, f, s)
        $is_finer_partition_than(I, Pfine, Pcoarse)
        =>:
            $has_piecewise_constant_integral_with_partition(I, Pfine, f, s)
    # Source handling: refinement preserves the finite rectangle sum through
    # the same explicit support-removal, regrouping, and rectangle-splitting
    # theorem used by Proposition 11.2.13.
    $is_piecewise_constant_with_partition(I, Pcoarse, f)
    $is_partition_of_bounded_interval(I, Pfine)
    by thm piecewise_constant_refines(I, Pcoarse, Pfine, f)
    $is_piecewise_constant_with_partition(I, Pfine, f)
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, Pfine, f)
    by thm piecewise_constant_integral_with_partition_has_value(I, Pfine, f)
    have sfine R = piecewise_constant_integral_with_partition(I, Pfine, f)
    $has_piecewise_constant_integral_with_partition(I, Pfine, f, sfine)
    by thm piecewise_constant_integral_with_partition_reindexes_over_refinement(I, Pcoarse, Pfine, f)
    piecewise_constant_integral_with_partition(I, Pcoarse, f) = piecewise_constant_integral_with_partition(I, Pfine, f)
    s = piecewise_constant_integral_with_partition(I, Pcoarse, f)
    s = piecewise_constant_integral_with_partition(I, Pcoarse, f) = piecewise_constant_integral_with_partition(I, Pfine, f) = sfine
    $has_piecewise_constant_integral_with_partition(I, Pfine, f, s)

"""
Definition 11.2.14 (Piecewise constant integral II).  The partition-free
piecewise constant integral is the common value from Proposition 11.2.13.
"""

prop has_piecewise_constant_integral(I power_set(R), f fn(x I) R, s R):
    $is_piecewise_constant_on(I, f)
    exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f), $has_piecewise_constant_integral_with_partition(I, P, f, s)}

thm piecewise_constant_integral_value_unique:
    ? forall I power_set(R), f fn(x I) R, s1, s2 R:
        $has_piecewise_constant_integral(I, f, s1)
        $has_piecewise_constant_integral(I, f, s2)
        =>:
            s1 = s2
    # Source handling: Definition 11.2.14 makes the partition-free value the
    # common value from Proposition 11.2.13.
    obtain P from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f), $has_piecewise_constant_integral_with_partition(I, P, f, s1)}
    obtain P2 from exist P2 finite_set st {$is_piecewise_constant_with_partition(I, P2, f), $has_piecewise_constant_integral_with_partition(I, P2, f, s2)}
    by thm piecewise_constant_integral_independent_of_partition(I, f, P, P2, s1, s2)
    s1 = s2

have fn piecewise_constant_integral by exist!:
    ? forall I power_set(R), f fn(x I) R:
        $is_piecewise_constant_on(I, f)
        =>:
            exist! s R st {$has_piecewise_constant_integral(I, f, s)}
    # Source handling: Definition 11.2.14 selects the common finite-rectangle
    # value after Proposition 11.2.13 has established partition independence.
    obtain P from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f)}
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, P, f)
    by thm piecewise_constant_integral_with_partition_has_value(I, P, f)
    have s R = piecewise_constant_integral_with_partition(I, P, f)
    claim:
        ? exist s0 R st {$has_piecewise_constant_integral(I, f, s0)}
        witness exist s0 R st {$has_piecewise_constant_integral(I, f, s0)} from s:
            witness exist P0 finite_set st {$is_piecewise_constant_with_partition(I, P0, f), $has_piecewise_constant_integral_with_partition(I, P0, f, s)} from P:
                $is_piecewise_constant_with_partition(I, P, f)
                $has_piecewise_constant_integral_with_partition(I, P, f, s)
            $has_piecewise_constant_integral(I, f, s)
    claim:
        ? forall s1, s2 R:
            $has_piecewise_constant_integral(I, f, s1)
            $has_piecewise_constant_integral(I, f, s2)
            =>:
                s1 = s2
        by thm piecewise_constant_integral_value_unique(I, f, s1, s2)
    exist! s0 R st {$has_piecewise_constant_integral(I, f, s0)}

"""
Example 11.2.15.  The function from Example 11.2.12 has partition-free
piecewise constant integral `10` on `[1,4]`.
"""

thm example_11_2_15_piecewise_constant_integral:
    ? forall f fn(x '[1, 4]) R:
        $is_example_11_2_12_function(f)
        =>:
            $has_piecewise_constant_integral('[1, 4], f, 10)
    # Source handling: this folds Example 11.2.12 through the
    # partition-independence definition.
    by thm example_11_2_12_displayed_partition_piecewise_constant(f)
    by thm example_11_2_12_piecewise_constant_integral(f)
    by thm piecewise_constant_with_partition_is_piecewise_constant('[1, 4], example_11_2_12_partition_set, f)
    witness exist P finite_set st {$is_piecewise_constant_with_partition('[1, 4], P, f), $has_piecewise_constant_integral_with_partition('[1, 4], P, f, 10)} from example_11_2_12_partition_set:
        $is_piecewise_constant_with_partition('[1, 4], example_11_2_12_partition_set, f)
        $has_piecewise_constant_integral_with_partition('[1, 4], example_11_2_12_partition_set, f, 10)
    $has_piecewise_constant_integral('[1, 4], f, 10)

"""
Theorem 11.2.16 (Laws of integration).  The piecewise constant integral is
linear, positive on non-negative functions, monotone, correct on constants,
compatible with extension by zero, and additive over a two-piece partition.
"""

prop is_nonnegative_on(X power_set(R), f fn(x X) R):
    forall x X:
        f(x) >= 0

thm piecewise_constant_integral_piece_contribution_nonnegative:
    ? forall I power_set(R), J power_set(R), f fn(x I) R, t R:
        $has_piecewise_constant_integral_piece_contribution(I, J, f, t)
        $is_nonnegative_on(I, f)
        =>:
            t >= 0
    # Source handling: a non-empty piece has a non-negative constant height
    # and non-negative length; an empty piece has contribution zero.
    $is_bounded_interval(J)
    obtain c from exist c R st {$has_constant_value_on_subset(I, J, f, c), t = c * interval_length(J)}
    J $subset I
    $has_constant_value_on_subset(I, J, f, c)
    t = c * interval_length(J)
    by cases:
        ? t >= 0
        case $is_nonempty_set(J):
            have x J
            x $in I
            f(x) >= 0
            f(x) = c
            c >= 0
            by thm interval_length_nonnegative(J)
            interval_length(J) >= 0
            c * interval_length(J) >= 0
            t >= 0
        case not $is_nonempty_set(J):
            by thm empty_bounded_interval_length_value(J)
            interval_length(J) = 0
            t = c * interval_length(J) = c * 0 = 0
            t >= 0

thm piecewise_constant_integral_piece_contribution_monotone:
    ? forall I power_set(R), J power_set(R), f, g fn(x I) R, sf, sg R:
        $has_piecewise_constant_integral_piece_contribution(I, J, f, sf)
        $has_piecewise_constant_integral_piece_contribution(I, J, g, sg)
        forall x I:
            g(x) <= f(x)
        =>:
            sg <= sf
    # Source handling: on a non-empty piece, compare the two constant heights
    # at one point and multiply by the non-negative interval length.  Empty
    # pieces contribute zero to both sums.
    $is_bounded_interval(J)
    obtain cf from exist c R st {$has_constant_value_on_subset(I, J, f, c), sf = c * interval_length(J)}
    obtain cg from exist c R st {$has_constant_value_on_subset(I, J, g, c), sg = c * interval_length(J)}
    J $subset I
    $has_constant_value_on_subset(I, J, f, cf)
    $has_constant_value_on_subset(I, J, g, cg)
    sf = cf * interval_length(J)
    sg = cg * interval_length(J)
    by cases:
        ? sg <= sf
        case $is_nonempty_set(J):
            have x J
            x $in I
            g(x) <= f(x)
            g(x) = cg
            f(x) = cf
            cg <= cf
            by thm interval_length_nonnegative(J)
            interval_length(J) >= 0
            cg * interval_length(J) <= cf * interval_length(J)
            sg = cg * interval_length(J) <= cf * interval_length(J) = sf
        case not $is_nonempty_set(J):
            by thm empty_bounded_interval_length_value(J)
            interval_length(J) = 0
            sg = cg * interval_length(J) = cg * 0 = 0
            sf = cf * interval_length(J) = cf * 0 = 0
            sg <= sf

thm piecewise_constant_integral_with_same_partition_add:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R, sf, sg R:
        $has_piecewise_constant_integral_with_partition(I, P, f, sf)
        $has_piecewise_constant_integral_with_partition(I, P, g, sg)
        =>:
            $has_piecewise_constant_integral_with_partition(I, P, fn(x I) R {f(x) + g(x)}, sf + sg)
    # Source handling: before taking a common refinement, linearity is the
    # finite-sum identity on one partition shared by both functions.
    P $in power_set(power_set(R))
    $is_piecewise_constant_with_partition(I, P, f)
    $is_piecewise_constant_with_partition(I, P, g)
    sf = piecewise_constant_integral_with_partition(I, P, f)
    sg = piecewise_constant_integral_with_partition(I, P, g)
    by thm piecewise_constant_same_partition_add(I, P, f, g)
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) + g(x)})
    claim:
        ? forall J P:
            piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {f(x) + g(x)}) = piecewise_constant_integral_piece_contribution(I, J, f) + piecewise_constant_integral_piece_contribution(I, J, g)
        $is_partition_of_bounded_interval(I, P)
        J $in power_set(R)
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        $has_piecewise_constant_integral_piece_contribution(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f))
        $has_piecewise_constant_integral_piece_contribution(I, J, g, piecewise_constant_integral_piece_contribution(I, J, g))
        by thm piecewise_constant_integral_piece_contribution_add(I, J, f, g, piecewise_constant_integral_piece_contribution(I, J, f), piecewise_constant_integral_piece_contribution(I, J, g))
        $has_piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {f(x) + g(x)}, piecewise_constant_integral_piece_contribution(I, J, f) + piecewise_constant_integral_piece_contribution(I, J, g))
        by thm piecewise_constant_integral_piece_contribution_has_value(I, J, fn(x I) R {f(x) + g(x)}, piecewise_constant_integral_piece_contribution(I, J, f) + piecewise_constant_integral_piece_contribution(I, J, g))
    claim:
        ? $fn_eq(fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {f(x) + g(x)})}, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f) + piecewise_constant_integral_piece_contribution(I, J, g)})
        forall K P:
            fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {f(x) + g(x)})}(K) = piecewise_constant_integral_piece_contribution(I, K, fn(x I) R {f(x) + g(x)})
            fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f) + piecewise_constant_integral_piece_contribution(I, J, g)}(K) = piecewise_constant_integral_piece_contribution(I, K, f) + piecewise_constant_integral_piece_contribution(I, K, g)
            piecewise_constant_integral_piece_contribution(I, K, fn(x I) R {f(x) + g(x)}) = piecewise_constant_integral_piece_contribution(I, K, f) + piecewise_constant_integral_piece_contribution(I, K, g)
            fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {f(x) + g(x)})}(K) = fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f) + piecewise_constant_integral_piece_contribution(I, J, g)}(K)
        $fn_eq(fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {f(x) + g(x)})}, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f) + piecewise_constant_integral_piece_contribution(I, J, g)})
    fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {f(x) + g(x)})} = fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f) + piecewise_constant_integral_piece_contribution(I, J, g)}
    piecewise_constant_integral_with_partition(I, P, fn(x I) R {f(x) + g(x)}) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {f(x) + g(x)})})
    finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {f(x) + g(x)})}) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f) + piecewise_constant_integral_piece_contribution(I, J, g)})
    finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f) + piecewise_constant_integral_piece_contribution(I, J, g)}) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)}) + finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, g)})
    piecewise_constant_integral_with_partition(I, P, f) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    piecewise_constant_integral_with_partition(I, P, g) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, g)})
    sf + sg = piecewise_constant_integral_with_partition(I, P, f) + piecewise_constant_integral_with_partition(I, P, g) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)}) + finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, g)}) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {f(x) + g(x)})}) = piecewise_constant_integral_with_partition(I, P, fn(x I) R {f(x) + g(x)})
    $has_piecewise_constant_integral_with_partition(I, P, fn(x I) R {f(x) + g(x)}, sf + sg)

thm piecewise_constant_integral_with_same_partition_scalar_mul:
    ? forall I power_set(R), P finite_set, f fn(x I) R, sf, c R:
        $has_piecewise_constant_integral_with_partition(I, P, f, sf)
        =>:
            $has_piecewise_constant_integral_with_partition(I, P, fn(x I) R {c * f(x)}, c * sf)
    # Source handling: scalar multiplication factors through every rectangle
    # contribution and then through the finite sum on the fixed partition.
    P $in power_set(power_set(R))
    $is_piecewise_constant_with_partition(I, P, f)
    sf = piecewise_constant_integral_with_partition(I, P, f)
    by thm piecewise_constant_same_partition_scalar_mul(I, P, f, c)
    $is_piecewise_constant_with_partition(I, P, fn(x I) R {c * f(x)})
    claim:
        ? forall J P:
            piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {c * f(x)}) = c * piecewise_constant_integral_piece_contribution(I, J, f)
        $is_partition_of_bounded_interval(I, P)
        J $in power_set(R)
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        $has_piecewise_constant_integral_piece_contribution(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f))
        by thm piecewise_constant_integral_piece_contribution_scalar_mul(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f), c)
        $has_piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {c * f(x)}, c * piecewise_constant_integral_piece_contribution(I, J, f))
        by thm piecewise_constant_integral_piece_contribution_has_value(I, J, fn(x I) R {c * f(x)}, c * piecewise_constant_integral_piece_contribution(I, J, f))
    claim:
        ? $fn_eq(fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {c * f(x)})}, fn(J P) R {c * piecewise_constant_integral_piece_contribution(I, J, f)})
        forall K P:
            fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {c * f(x)})}(K) = piecewise_constant_integral_piece_contribution(I, K, fn(x I) R {c * f(x)})
            fn(J P) R {c * piecewise_constant_integral_piece_contribution(I, J, f)}(K) = c * piecewise_constant_integral_piece_contribution(I, K, f)
            piecewise_constant_integral_piece_contribution(I, K, fn(x I) R {c * f(x)}) = c * piecewise_constant_integral_piece_contribution(I, K, f)
            fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {c * f(x)})}(K) = fn(J P) R {c * piecewise_constant_integral_piece_contribution(I, J, f)}(K)
        $fn_eq(fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {c * f(x)})}, fn(J P) R {c * piecewise_constant_integral_piece_contribution(I, J, f)})
    fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {c * f(x)})} = fn(J P) R {c * piecewise_constant_integral_piece_contribution(I, J, f)}
    piecewise_constant_integral_with_partition(I, P, fn(x I) R {c * f(x)}) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {c * f(x)})})
    finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {c * f(x)})}) = finite_set_sum(P, fn(J P) R {c * piecewise_constant_integral_piece_contribution(I, J, f)})
    finite_set_sum(P, fn(J P) R {c * piecewise_constant_integral_piece_contribution(I, J, f)}) = c * finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    piecewise_constant_integral_with_partition(I, P, f) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    c * sf = c * piecewise_constant_integral_with_partition(I, P, f) = c * finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)}) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, fn(x I) R {c * f(x)})}) = piecewise_constant_integral_with_partition(I, P, fn(x I) R {c * f(x)})
    $has_piecewise_constant_integral_with_partition(I, P, fn(x I) R {c * f(x)}, c * sf)

thm finite_set_sum_nonnegative_from_pointwise_nonnegative:
    ? forall P finite_set, h fn(x P) R:
        forall x P:
            h(x) >= 0
        =>:
            finite_set_sum(P, h) >= 0
    # Source handling: this is the finite-sum positivity step needed when a
    # non-negative piecewise-constant function is evaluated on one partition.
    claim:
        ? forall x P:
            fn(x P) R {0}(x) <= h(x)
        fn(x P) R {0}(x) = 0
        0 <= h(x)
        fn(x P) R {0}(x) <= h(x)
    finite_set_sum(P, fn(x P) R {0}) <= finite_set_sum(P, h)
    finite_set_sum(P, fn(x P) R {0}) = 0
    finite_set_sum(P, h) >= 0

thm finite_set_sum_monotone_from_pointwise_order:
    ? forall P finite_set, h, k fn(x P) R:
        forall x P:
            h(x) <= k(x)
        =>:
            finite_set_sum(P, h) <= finite_set_sum(P, k)
    # Source handling: this packages finite-set sum monotonicity for the
    # partition-contribution comparisons used by Theorem 11.2.16.
    finite_set_sum(P, h) <= finite_set_sum(P, k)

thm piecewise_constant_integral_with_same_partition_monotone:
    ? forall I power_set(R), P finite_set, f, g fn(x I) R, sf, sg R:
        $has_piecewise_constant_integral_with_partition(I, P, f, sf)
        $has_piecewise_constant_integral_with_partition(I, P, g, sg)
        forall x I:
            g(x) <= f(x)
        =>:
            sg <= sf
    # Source handling: compare the two rectangle contributions on each common
    # partition piece, then use finite-set sum monotonicity.
    P $in power_set(power_set(R))
    $is_piecewise_constant_with_partition(I, P, f)
    $is_piecewise_constant_with_partition(I, P, g)
    sf = piecewise_constant_integral_with_partition(I, P, f)
    sg = piecewise_constant_integral_with_partition(I, P, g)
    claim:
        ? forall J P:
            piecewise_constant_integral_piece_contribution(I, J, g) <= piecewise_constant_integral_piece_contribution(I, J, f)
        $is_partition_of_bounded_interval(I, P)
        J $in power_set(R)
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        $is_constant_on_subset(I, J, g)
        by thm piecewise_constant_integral_piece_contribution_has_value(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f))
        by thm piecewise_constant_integral_piece_contribution_has_value(I, J, g, piecewise_constant_integral_piece_contribution(I, J, g))
        $has_piecewise_constant_integral_piece_contribution(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f))
        $has_piecewise_constant_integral_piece_contribution(I, J, g, piecewise_constant_integral_piece_contribution(I, J, g))
        by thm piecewise_constant_integral_piece_contribution_monotone(I, J, f, g, piecewise_constant_integral_piece_contribution(I, J, f), piecewise_constant_integral_piece_contribution(I, J, g))
        piecewise_constant_integral_piece_contribution(I, J, g) <= piecewise_constant_integral_piece_contribution(I, J, f)
    finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, g)}) <= finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    piecewise_constant_integral_with_partition(I, P, f) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    piecewise_constant_integral_with_partition(I, P, g) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, g)})
    sg <= sf

thm piecewise_constant_integral_laws:
    ? forall I power_set(R), f, g fn(x I) R, sf, sg, c R:
        $has_piecewise_constant_integral(I, f, sf)
        $has_piecewise_constant_integral(I, g, sg)
        =>:
            $has_piecewise_constant_integral(I, fn(x I) R {f(x) + g(x)}, sf + sg)
            $has_piecewise_constant_integral(I, fn(x I) R {c * f(x)}, c * sf)
            $has_piecewise_constant_integral(I, fn(x I) R {f(x) - g(x)}, sf - sg)
    # Source handling: move both displayed partitions to their common
    # refinement, apply the fixed-partition rectangle identities, and fold
    # the resulting witness back into Definition 11.2.14.
    obtain Pf from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f), $has_piecewise_constant_integral_with_partition(I, P, f, sf)}
    obtain Pg from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, g), $has_piecewise_constant_integral_with_partition(I, P, g, sg)}
    $is_partition_of_bounded_interval(I, Pf)
    $is_partition_of_bounded_interval(I, Pg)
    by thm partition_is_set_of_real_subsets(I, Pf)
    by thm partition_is_set_of_real_subsets(I, Pg)
    have Rf finite_set = common_refinement(I, Pf, Pg)
    $is_common_refinement_of_partitions(I, Pf, Pg, Rf)
    by thm common_refinement_is_partition_and_finer(I, Pf, Pg, Rf)
    $is_finer_partition_than(I, Rf, Pf)
    $is_finer_partition_than(I, Rf, Pg)
    by thm piecewise_constant_integral_transports_to_finer_partition(I, Pf, Rf, f, sf)
    by thm piecewise_constant_integral_transports_to_finer_partition(I, Pg, Rf, g, sg)
    $has_piecewise_constant_integral_with_partition(I, Rf, f, sf)
    $has_piecewise_constant_integral_with_partition(I, Rf, g, sg)

    by thm piecewise_constant_integral_with_same_partition_add(I, Rf, f, g, sf, sg)
    $has_piecewise_constant_integral_with_partition(I, Rf, fn(x I) R {f(x) + g(x)}, sf + sg)
    by thm piecewise_constant_with_partition_is_piecewise_constant(I, Rf, fn(x I) R {f(x) + g(x)})
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) + g(x)}), $has_piecewise_constant_integral_with_partition(I, P, fn(x I) R {f(x) + g(x)}, sf + sg)} from Rf:
        $is_piecewise_constant_with_partition(I, Rf, fn(x I) R {f(x) + g(x)})
        $has_piecewise_constant_integral_with_partition(I, Rf, fn(x I) R {f(x) + g(x)}, sf + sg)
    $has_piecewise_constant_integral(I, fn(x I) R {f(x) + g(x)}, sf + sg)

    by thm piecewise_constant_integral_with_same_partition_scalar_mul(I, Pf, f, sf, c)
    $has_piecewise_constant_integral_with_partition(I, Pf, fn(x I) R {c * f(x)}, c * sf)
    by thm piecewise_constant_with_partition_is_piecewise_constant(I, Pf, fn(x I) R {c * f(x)})
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {c * f(x)}), $has_piecewise_constant_integral_with_partition(I, P, fn(x I) R {c * f(x)}, c * sf)} from Pf:
        $is_piecewise_constant_with_partition(I, Pf, fn(x I) R {c * f(x)})
        $has_piecewise_constant_integral_with_partition(I, Pf, fn(x I) R {c * f(x)}, c * sf)
    $has_piecewise_constant_integral(I, fn(x I) R {c * f(x)}, c * sf)

    by thm piecewise_constant_integral_with_same_partition_scalar_mul(I, Rf, g, sg, -1)
    $has_piecewise_constant_integral_with_partition(I, Rf, fn(x I) R {-1 * g(x)}, -1 * sg)
    by thm piecewise_constant_integral_with_same_partition_add(I, Rf, f, fn(x I) R {-1 * g(x)}, sf, -1 * sg)
    $has_piecewise_constant_integral_with_partition(I, Rf, fn(x I) R {f(x) + (-1 * g(x))}, sf + (-1 * sg))
    claim:
        ? fn(x I) R {f(x) - g(x)} = fn(x I) R {f(x) + (-1 * g(x))}
        forall x I:
            fn(x I) R {f(x) - g(x)}(x) = f(x) - g(x)
            fn(x I) R {f(x) + (-1 * g(x))}(x) = f(x) + (-1 * g(x))
            f(x) - g(x) = f(x) + (-1 * g(x))
            fn(x I) R {f(x) - g(x)}(x) = fn(x I) R {f(x) + (-1 * g(x))}(x)
        $fn_eq(fn(x I) R {f(x) - g(x)}, fn(x I) R {f(x) + (-1 * g(x))})
        fn(x I) R {f(x) - g(x)} = fn(x I) R {f(x) + (-1 * g(x))}
    $has_piecewise_constant_integral_with_partition(I, Rf, fn(x I) R {f(x) - g(x)}, sf + (-1 * sg))
    sf + (-1 * sg) = sf - sg
    $has_piecewise_constant_integral_with_partition(I, Rf, fn(x I) R {f(x) - g(x)}, sf - sg)
    by thm piecewise_constant_with_partition_is_piecewise_constant(I, Rf, fn(x I) R {f(x) - g(x)})
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {f(x) - g(x)}), $has_piecewise_constant_integral_with_partition(I, P, fn(x I) R {f(x) - g(x)}, sf - sg)} from Rf:
        $is_piecewise_constant_with_partition(I, Rf, fn(x I) R {f(x) - g(x)})
        $has_piecewise_constant_integral_with_partition(I, Rf, fn(x I) R {f(x) - g(x)}, sf - sg)
    $has_piecewise_constant_integral(I, fn(x I) R {f(x) - g(x)}, sf - sg)

thm piecewise_constant_integral_nonnegative_law:
    ? forall I power_set(R), f fn(x I) R, sf R:
        $has_piecewise_constant_integral(I, f, sf)
        $is_nonnegative_on(I, f)
        =>:
            sf >= 0
    # Source handling: choose the partition defining `sf`; every rectangle
    # contribution is non-negative, so its finite sum is non-negative.
    obtain P from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f), $has_piecewise_constant_integral_with_partition(I, P, f, sf)}
    by thm piecewise_constant_partition_is_set_of_real_subsets(I, P, f)
    sf = piecewise_constant_integral_with_partition(I, P, f)
    claim:
        ? forall J P:
            piecewise_constant_integral_piece_contribution(I, J, f) >= 0
        $is_partition_of_bounded_interval(I, P)
        J $in power_set(R)
        $is_bounded_interval(J)
        $is_constant_on_subset(I, J, f)
        by thm piecewise_constant_integral_piece_contribution_has_value(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f))
        $has_piecewise_constant_integral_piece_contribution(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f))
        by thm piecewise_constant_integral_piece_contribution_nonnegative(I, J, f, piecewise_constant_integral_piece_contribution(I, J, f))
        piecewise_constant_integral_piece_contribution(I, J, f) >= 0
    claim:
        ? forall K P:
            fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)}(K) >= 0
        fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)}(K) = piecewise_constant_integral_piece_contribution(I, K, f)
        piecewise_constant_integral_piece_contribution(I, K, f) >= 0
        fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)}(K) >= 0
    by thm finite_set_sum_nonnegative_from_pointwise_nonnegative(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)}) >= 0
    piecewise_constant_integral_with_partition(I, P, f) = finite_set_sum(P, fn(J P) R {piecewise_constant_integral_piece_contribution(I, J, f)})
    sf >= 0

thm piecewise_constant_integral_order_laws:
    ? forall I power_set(R), f, g fn(x I) R, sf, sg R:
        $has_piecewise_constant_integral(I, f, sf)
        $has_piecewise_constant_integral(I, g, sg)
        $is_nonnegative_on(I, f)
        forall x I:
            g(x) <= f(x)
        =>:
            sf >= 0
            sg <= sf
    # Source handling: these are the positivity and monotonicity clauses of
    # Theorem 11.2.16.
    by thm piecewise_constant_integral_nonnegative_law(I, f, sf)
    sf >= 0
    obtain Pf from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, f), $has_piecewise_constant_integral_with_partition(I, P, f, sf)}
    obtain Pg from exist P finite_set st {$is_piecewise_constant_with_partition(I, P, g), $has_piecewise_constant_integral_with_partition(I, P, g, sg)}
    $is_partition_of_bounded_interval(I, Pf)
    $is_partition_of_bounded_interval(I, Pg)
    by thm partition_is_set_of_real_subsets(I, Pf)
    by thm partition_is_set_of_real_subsets(I, Pg)
    have Rf finite_set = common_refinement(I, Pf, Pg)
    $is_common_refinement_of_partitions(I, Pf, Pg, Rf)
    by thm common_refinement_is_partition_and_finer(I, Pf, Pg, Rf)
    $is_finer_partition_than(I, Rf, Pf)
    $is_finer_partition_than(I, Rf, Pg)
    by thm piecewise_constant_integral_transports_to_finer_partition(I, Pf, Rf, f, sf)
    by thm piecewise_constant_integral_transports_to_finer_partition(I, Pg, Rf, g, sg)
    $has_piecewise_constant_integral_with_partition(I, Rf, f, sf)
    $has_piecewise_constant_integral_with_partition(I, Rf, g, sg)
    by thm piecewise_constant_integral_with_same_partition_monotone(I, Rf, f, g, sf, sg)
    sg <= sf

thm piecewise_constant_integral_of_constant:
    ? forall I power_set(R), c R:
        $is_bounded_interval(I)
        =>:
            $has_piecewise_constant_integral(I, fn(x I) R {c}, c * interval_length(I))
    # Source handling: this is Theorem 11.2.16(f).
    # The one-piece partition gives a single rectangle of height `c` and base
    # `interval_length(I)`.
    by thm constant_function_is_piecewise_constant_with_one_piece_partition(I, c)
    by thm constant_function_is_piecewise_constant(I, c)
    claim:
        ? $has_constant_value_on_subset(I, I, fn(x I) R {c}, c)
        I $subset I
        forall x I:
            fn(x I) R {c}(x) = c
    claim:
        ? $has_piecewise_constant_integral_piece_contribution(I, I, fn(x I) R {c}, c * interval_length(I))
        witness exist c0 R st {$has_constant_value_on_subset(I, I, fn(x I) R {c}, c0), c * interval_length(I) = c0 * interval_length(I)} from c:
            $has_constant_value_on_subset(I, I, fn(x I) R {c}, c)
            c * interval_length(I) = c * interval_length(I)
        $has_piecewise_constant_integral_piece_contribution(I, I, fn(x I) R {c}, c * interval_length(I))
    by thm one_piece_piecewise_constant_integral_with_partition_value(I, fn(x I) R {c}, c * interval_length(I))
    $has_piecewise_constant_integral_with_partition(I, {I}, fn(x I) R {c}, c * interval_length(I))
    witness exist P finite_set st {$is_piecewise_constant_with_partition(I, P, fn(x I) R {c}), $has_piecewise_constant_integral_with_partition(I, P, fn(x I) R {c}, c * interval_length(I))} from {I}:
        $is_piecewise_constant_with_partition(I, {I}, fn(x I) R {c})
        $has_piecewise_constant_integral_with_partition(I, {I}, fn(x I) R {c}, c * interval_length(I))
    $has_piecewise_constant_integral(I, fn(x I) R {c}, c * interval_length(I))


# 11.3 Upper and lower Riemann integrals

"""
Definition 11.3.1 (Majorization of functions).  A function majorizes another
if it is pointwise greater; it minorizes another if it is pointwise smaller.
"""

prop majorizes_on(I power_set(R), g, f fn(x I) R):
    forall x I:
        g(x) >= f(x)

prop minorizes_on(I power_set(R), g, f fn(x I) R):
    forall x I:
        g(x) <= f(x)

prop is_lower_bound_of_real_set(E power_set(R), M R):
    forall x E:
        M <= x

prop is_infimum_of_real_set(E power_set(R), s R):
    $is_lower_bound_of_real_set(E, s)
    forall M R:
        $is_lower_bound_of_real_set(E, M)
        =>:
            M <= s

prop has_infimum_of_real_set(E power_set(R)):
    exist s R st {$is_infimum_of_real_set(E, s)}

prop is_upper_bound_of_real_set(E power_set(R), M R):
    forall x E:
        x <= M

# Short source-facing spelling used in the order comparisons below.
prop is_upper_bound(E power_set(R), M R):
    $is_upper_bound_of_real_set(E, M)

prop is_least_upper_bound(E power_set(R), s R):
    $is_upper_bound_of_real_set(E, s)
    forall M R:
        $is_upper_bound_of_real_set(E, M)
        =>:
            s <= M

prop has_least_upper_bound(E power_set(R)):
    exist s R st {$is_least_upper_bound(E, s)}

thm infimum_of_real_set_value_unique:
    ? forall E power_set(R), s1, s2 R:
        $is_infimum_of_real_set(E, s1)
        $is_infimum_of_real_set(E, s2)
        =>:
            s1 = s2
    $is_lower_bound_of_real_set(E, s1)
    $is_lower_bound_of_real_set(E, s2)
    forall M R:
        $is_lower_bound_of_real_set(E, M)
        =>:
            M <= s1
    s2 <= s1
    forall M R:
        $is_lower_bound_of_real_set(E, M)
        =>:
            M <= s2
    s1 <= s2
    s1 = s2

thm least_upper_bound_unique:
    ? forall E power_set(R), s1, s2 R:
        $is_least_upper_bound(E, s1)
        $is_least_upper_bound(E, s2)
        =>:
            s1 = s2
    $is_upper_bound_of_real_set(E, s1)
    $is_upper_bound_of_real_set(E, s2)
    forall M R:
        $is_upper_bound_of_real_set(E, M)
        =>:
            s1 <= M
    s1 <= s2
    forall M R:
        $is_upper_bound_of_real_set(E, M)
        =>:
            s2 <= M
    s2 <= s1
    s1 = s2

"""
Definition 11.3.2 (Upper and lower Riemann integrals).  The upper integral is
the infimum of piecewise constant majorant integrals; the lower integral is the
supremum of piecewise constant minorant integrals.
"""

prop is_upper_riemann_integral_candidate_value(I power_set(R), f fn(x I) R, s R):
    exist g fn(x I) R st {$is_piecewise_constant_on(I, g), $majorizes_on(I, g, f), $has_piecewise_constant_integral(I, g, s)}

prop is_lower_riemann_integral_candidate_value(I power_set(R), f fn(x I) R, s R):
    exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_integral(I, h, s)}

have fn upper_riemann_integral_candidate_values(I power_set(R), f fn(x I) R) power_set(R) = {s R: $is_upper_riemann_integral_candidate_value(I, f, s)}

have fn lower_riemann_integral_candidate_values(I power_set(R), f fn(x I) R) power_set(R) = {s R: $is_lower_riemann_integral_candidate_value(I, f, s)}

thm upper_riemann_integral_candidate_value_member:
    ? forall I power_set(R), f fn(x I) R, s R:
        $is_upper_riemann_integral_candidate_value(I, f, s)
        =>:
            s $in upper_riemann_integral_candidate_values(I, f)
    upper_riemann_integral_candidate_values(I, f) = {s R: $is_upper_riemann_integral_candidate_value(I, f, s)}
    s $in {s R: $is_upper_riemann_integral_candidate_value(I, f, s)}
    s $in upper_riemann_integral_candidate_values(I, f)

thm upper_riemann_integral_candidate_value_from_member:
    ? forall I power_set(R), f fn(x I) R, s R:
        s $in upper_riemann_integral_candidate_values(I, f)
        =>:
            $is_upper_riemann_integral_candidate_value(I, f, s)
    upper_riemann_integral_candidate_values(I, f) = {s R: $is_upper_riemann_integral_candidate_value(I, f, s)}
    s $in {s R: $is_upper_riemann_integral_candidate_value(I, f, s)}
    $is_upper_riemann_integral_candidate_value(I, f, s)

thm lower_riemann_integral_candidate_value_member:
    ? forall I power_set(R), f fn(x I) R, s R:
        $is_lower_riemann_integral_candidate_value(I, f, s)
        =>:
            s $in lower_riemann_integral_candidate_values(I, f)
    lower_riemann_integral_candidate_values(I, f) = {s R: $is_lower_riemann_integral_candidate_value(I, f, s)}
    s $in {s R: $is_lower_riemann_integral_candidate_value(I, f, s)}
    s $in lower_riemann_integral_candidate_values(I, f)

thm lower_riemann_integral_candidate_value_from_member:
    ? forall I power_set(R), f fn(x I) R, s R:
        s $in lower_riemann_integral_candidate_values(I, f)
        =>:
            $is_lower_riemann_integral_candidate_value(I, f, s)
    lower_riemann_integral_candidate_values(I, f) = {s R: $is_lower_riemann_integral_candidate_value(I, f, s)}
    s $in {s R: $is_lower_riemann_integral_candidate_value(I, f, s)}
    $is_lower_riemann_integral_candidate_value(I, f, s)

prop has_upper_riemann_integral(I power_set(R), f fn(x I) R, U R):
    $is_bounded_interval(I)
    $chap9::is_bounded_function_on(I, f)
    $has_infimum_of_real_set(upper_riemann_integral_candidate_values(I, f))
    $is_infimum_of_real_set(upper_riemann_integral_candidate_values(I, f), U)

prop has_lower_riemann_integral(I power_set(R), f fn(x I) R, L R):
    $is_bounded_interval(I)
    $chap9::is_bounded_function_on(I, f)
    $has_least_upper_bound(lower_riemann_integral_candidate_values(I, f))
    $is_least_upper_bound(lower_riemann_integral_candidate_values(I, f), L)

thm upper_riemann_integral_value_unique:
    ? forall I power_set(R), f fn(x I) R, U1, U2 R:
        $has_upper_riemann_integral(I, f, U1)
        $has_upper_riemann_integral(I, f, U2)
        =>:
            U1 = U2
    $is_infimum_of_real_set(upper_riemann_integral_candidate_values(I, f), U1)
    $is_infimum_of_real_set(upper_riemann_integral_candidate_values(I, f), U2)
    by thm infimum_of_real_set_value_unique(upper_riemann_integral_candidate_values(I, f), U1, U2)
    U1 = U2

thm lower_riemann_integral_value_unique:
    ? forall I power_set(R), f fn(x I) R, L1, L2 R:
        $has_lower_riemann_integral(I, f, L1)
        $has_lower_riemann_integral(I, f, L2)
        =>:
            L1 = L2
    $is_least_upper_bound(lower_riemann_integral_candidate_values(I, f), L1)
    $is_least_upper_bound(lower_riemann_integral_candidate_values(I, f), L2)
    by thm least_upper_bound_unique(lower_riemann_integral_candidate_values(I, f), L1, L2)
    L1 = L2

thm piecewise_constant_minorant_integral_le_majorant_integral:
    ? forall I power_set(R), f, g, h fn(x I) R, sg, sh R:
        $is_bounded_interval(I)
        $majorizes_on(I, g, f)
        $minorizes_on(I, h, f)
        $has_piecewise_constant_integral(I, g, sg)
        $has_piecewise_constant_integral(I, h, sh)
        =>:
            sh <= sg
    by thm piecewise_constant_integral_laws(I, g, h, sg, sh, 1)
    $has_piecewise_constant_integral(I, fn(x I) R {g(x) - h(x)}, sg - sh)
    by thm piecewise_constant_integral_of_constant(I, 0)
    $has_piecewise_constant_integral(I, fn(x I) R {0}, 0 * interval_length(I))
    claim:
        ? $is_nonnegative_on(I, fn(x I) R {g(x) - h(x)})
        forall x I:
            h(x) <= f(x)
            f(x) <= g(x)
            h(x) <= g(x)
            0 <= g(x) - h(x)
            fn(x I) R {g(x) - h(x)}(x) = g(x) - h(x)
            fn(x I) R {g(x) - h(x)}(x) >= 0
        $is_nonnegative_on(I, fn(x I) R {g(x) - h(x)})
    claim:
        ? forall x I:
            0 <= g(x) - h(x)
        fn(x I) R {0}(x) = 0
        0 <= fn(x I) R {g(x) - h(x)}(x)
        fn(x I) R {g(x) - h(x)}(x) = g(x) - h(x)
        0 <= g(x) - h(x)
    by thm piecewise_constant_integral_order_laws(I, fn(x I) R {g(x) - h(x)}, fn(x I) R {0}, sg - sh, 0 * interval_length(I))
    sg - sh >= 0
    sh <= sg

thm absolute_value_lower_bound:
    ? forall u R:
        0 - abs(u) <= u
    by thm chap9::neg_abs_le_self(u)

thm negated_order_reverses:
    ? forall a, b R:
        a <= b
        =>:
            -b <= -a
    by thm chap9::neg_order_reverse_bridge(b, a)
    0 - b <= 0 - a
    0 - b = -b
    0 - a = -a
    -b <= -a

thm lower_bounded_real_set_with_member_has_infimum:
    ? forall E power_set(R), B R, e E:
        $is_lower_bound_of_real_set(E, B)
        =>:
            $has_infimum_of_real_set(E)
    # Reflect a nonempty lower-bounded set through zero, apply the Chapter 5
    # least-upper-bound theorem, and reflect the bound back.
    have negE power_set(R) = fn_range(fn(x E) R {-x})
    negE = fn_range(fn(x E) R {-x})
    claim:
        ? -e $in negE
        fn(x E) R {-x}(e) = -e
        fn(x E) R {-x}(e) $in fn_range(fn(x E) R {-x})
        -e $in fn_range(fn(x E) R {-x})
        -e $in negE
    claim:
        ? $is_nonempty_set(negE)
        witness $is_nonempty_set(negE) from -e:
            -e $in negE
    claim:
        ? $chap5::has_upper_bound(negE)
        witness exist C R st {$chap5::is_upper_bound(negE, C)} from -B:
            claim:
                ? forall y negE:
                    y <= -B
                negE = fn_range(fn(x E) R {-x})
                y $in fn_range(fn(x E) R {-x})
                have by preimage x from y $in fn_range(fn(x E) R {-x})
                fn(x E) R {-x}(x) = -x
                y = fn(x E) R {-x}(x)
                y = -x
                B <= x
                -x <= -B
                y = -x
                y <= -B
            $chap5::is_upper_bound(negE, -B)
        $chap5::has_upper_bound(negE)
    by thm chap5::least_upper_bound_existence(negE)
    $chap5::has_least_upper_bound(negE)
    obtain L from exist L R st {$chap5::is_least_upper_bound(negE, L)}
    witness exist s R st {$is_infimum_of_real_set(E, s)} from -L:
        claim:
            ? $is_lower_bound_of_real_set(E, s)
            claim:
                ? forall x E:
                    s <= x
                s = -L
                negE = fn_range(fn(x E) R {-x})
                fn(x E) R {-x}(x) = -x
                fn(x E) R {-x}(x) $in fn_range(fn(x E) R {-x})
                -x $in fn_range(fn(x E) R {-x})
                -x $in negE
                $chap5::is_upper_bound(negE, L)
                -x <= L
                -L <= -(-x)
                -(-x) = x
                -L <= x
                s <= x
            $is_lower_bound_of_real_set(E, s)
        claim:
            ? forall C R:
                $is_lower_bound_of_real_set(E, C)
                =>:
                    C <= s
            claim:
                ? $chap5::is_upper_bound(negE, -C)
                claim:
                    ? forall y negE:
                        y <= -C
                    negE = fn_range(fn(x E) R {-x})
                    y $in fn_range(fn(x E) R {-x})
                    have by preimage x from y $in fn_range(fn(x E) R {-x})
                    fn(x E) R {-x}(x) = -x
                    y = fn(x E) R {-x}(x)
                    y = -x
                    C <= x
                    -x <= -C
                    y = -x
                    y <= -C
                $chap5::is_upper_bound(negE, -C)
            $chap5::is_least_upper_bound(negE, L)
            L <= -C
            -(-C) <= -L
            -(-C) = C
            s = -L
            C <= s
        $is_infimum_of_real_set(E, s)
    $has_infimum_of_real_set(E)

thm lower_riemann_integral_candidate_values_have_least_upper_bound:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $has_least_upper_bound(lower_riemann_integral_candidate_values(I, f))
    # A bounded function has a constant majorant.  Every lower candidate is
    # below that majorant's integral, so Chapter 5 completeness applies.
    obtain M from exist M R_pos st {$chap9::is_function_bounded_by(I, f, M)}
    by thm constant_function_is_piecewise_constant(I, M)
    by thm piecewise_constant_integral_of_constant(I, M)
    claim:
        ? $is_upper_bound_of_real_set(lower_riemann_integral_candidate_values(I, f), M * interval_length(I))
        claim:
            ? forall sh lower_riemann_integral_candidate_values(I, f):
                sh <= M * interval_length(I)
            by thm lower_riemann_integral_candidate_value_from_member(I, f, sh)
            obtain h from exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_integral(I, h, sh)}
            claim:
                ? $majorizes_on(I, fn(x I) R {M}, f)
                forall x I:
                    f(x) <= abs(f(x))
                    abs(f(x)) <= M
                    f(x) <= M
                    fn(x I) R {M}(x) = M
                    fn(x I) R {M}(x) >= f(x)
                $majorizes_on(I, fn(x I) R {M}, f)
            by thm piecewise_constant_minorant_integral_le_majorant_integral(I, f, fn(x I) R {M}, h, M * interval_length(I), sh)
            sh <= M * interval_length(I)
        $is_upper_bound_of_real_set(lower_riemann_integral_candidate_values(I, f), M * interval_length(I))
    claim:
        ? $is_nonempty_set(lower_riemann_integral_candidate_values(I, f))
        claim:
            ? $is_lower_riemann_integral_candidate_value(I, f, -M * interval_length(I))
            by thm constant_function_is_piecewise_constant(I, -M)
            by thm piecewise_constant_integral_of_constant(I, -M)
            witness exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_integral(I, h, -M * interval_length(I))} from fn(x I) R {-M}:
                $is_piecewise_constant_on(I, fn(x I) R {-M})
                claim:
                    ? $minorizes_on(I, fn(x I) R {-M}, f)
                    forall x I:
                        abs(f(x)) <= M
                        0 - abs(f(x)) <= f(x)
                        0 - M <= 0 - abs(f(x))
                        0 - M = -M
                        -M <= 0 - abs(f(x)) <= f(x)
                        -M <= f(x)
                        fn(x I) R {-M}(x) = -M
                        fn(x I) R {-M}(x) <= f(x)
                    $minorizes_on(I, fn(x I) R {-M}, f)
                $minorizes_on(I, fn(x I) R {-M}, f)
                $has_piecewise_constant_integral(I, fn(x I) R {-M}, -M * interval_length(I))
            $is_lower_riemann_integral_candidate_value(I, f, -M * interval_length(I))
        by thm lower_riemann_integral_candidate_value_member(I, f, -M * interval_length(I))
        -M * interval_length(I) $in lower_riemann_integral_candidate_values(I, f)
        witness $is_nonempty_set(lower_riemann_integral_candidate_values(I, f)) from -M * interval_length(I)
    claim:
        ? $chap5::has_upper_bound(lower_riemann_integral_candidate_values(I, f))
        witness exist B R st {$chap5::is_upper_bound(lower_riemann_integral_candidate_values(I, f), B)} from M * interval_length(I):
            $is_upper_bound_of_real_set(lower_riemann_integral_candidate_values(I, f), M * interval_length(I))
            $chap5::is_upper_bound(lower_riemann_integral_candidate_values(I, f), M * interval_length(I))
        $chap5::has_upper_bound(lower_riemann_integral_candidate_values(I, f))
    by thm chap5::least_upper_bound_existence(lower_riemann_integral_candidate_values(I, f))
    $chap5::has_least_upper_bound(lower_riemann_integral_candidate_values(I, f))
    obtain L from exist L R st {$chap5::is_least_upper_bound(lower_riemann_integral_candidate_values(I, f), L)}
    claim:
        ? $is_least_upper_bound(lower_riemann_integral_candidate_values(I, f), L)
        claim:
            ? $is_upper_bound_of_real_set(lower_riemann_integral_candidate_values(I, f), L)
            claim:
                ? forall s lower_riemann_integral_candidate_values(I, f):
                    s <= L
                $chap5::is_upper_bound(lower_riemann_integral_candidate_values(I, f), L)
                s <= L
            $is_upper_bound_of_real_set(lower_riemann_integral_candidate_values(I, f), L)
        claim:
            ? forall B R:
                $is_upper_bound_of_real_set(lower_riemann_integral_candidate_values(I, f), B)
                =>:
                    L <= B
            $chap5::is_least_upper_bound(lower_riemann_integral_candidate_values(I, f), L)
            $is_upper_bound_of_real_set(lower_riemann_integral_candidate_values(I, f), B)
            $chap5::is_upper_bound(lower_riemann_integral_candidate_values(I, f), B)
            L <= B
        $is_least_upper_bound(lower_riemann_integral_candidate_values(I, f), L)
    witness exist L0 R st {$is_least_upper_bound(lower_riemann_integral_candidate_values(I, f), L0)} from L:
        $is_least_upper_bound(lower_riemann_integral_candidate_values(I, f), L)
    $has_least_upper_bound(lower_riemann_integral_candidate_values(I, f))

thm upper_riemann_integral_candidate_values_have_infimum:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_bounded_function_on(I, f)
        =>:
            $has_infimum_of_real_set(upper_riemann_integral_candidate_values(I, f))
    # A constant majorant supplies one upper candidate, while the opposite
    # constant is below every upper candidate.  Reflect the latter bound
    # through Chapter 5 completeness to obtain the infimum.
    obtain M from exist M R_pos st {$chap9::is_function_bounded_by(I, f, M)}
    by thm constant_function_is_piecewise_constant(I, M)
    by thm piecewise_constant_integral_of_constant(I, M)
    claim:
        ? $is_upper_riemann_integral_candidate_value(I, f, M * interval_length(I))
        witness exist g fn(x I) R st {$is_piecewise_constant_on(I, g), $majorizes_on(I, g, f), $has_piecewise_constant_integral(I, g, M * interval_length(I))} from fn(x I) R {M}:
            $is_piecewise_constant_on(I, fn(x I) R {M})
            claim:
                ? $majorizes_on(I, fn(x I) R {M}, f)
                forall x I:
                    f(x) <= abs(f(x))
                    abs(f(x)) <= M
                    f(x) <= M
                    fn(x I) R {M}(x) = M
                    fn(x I) R {M}(x) >= f(x)
                $majorizes_on(I, fn(x I) R {M}, f)
            $majorizes_on(I, fn(x I) R {M}, f)
            $has_piecewise_constant_integral(I, fn(x I) R {M}, M * interval_length(I))
        $is_upper_riemann_integral_candidate_value(I, f, M * interval_length(I))
    by thm upper_riemann_integral_candidate_value_member(I, f, M * interval_length(I))
    M * interval_length(I) $in upper_riemann_integral_candidate_values(I, f)
    claim:
        ? $is_lower_bound_of_real_set(upper_riemann_integral_candidate_values(I, f), -M * interval_length(I))
        claim:
            ? forall sg upper_riemann_integral_candidate_values(I, f):
                -M * interval_length(I) <= sg
            by thm upper_riemann_integral_candidate_value_from_member(I, f, sg)
            obtain g from exist g fn(x I) R st {$is_piecewise_constant_on(I, g), $majorizes_on(I, g, f), $has_piecewise_constant_integral(I, g, sg)}
            by thm constant_function_is_piecewise_constant(I, -M)
            by thm piecewise_constant_integral_of_constant(I, -M)
            claim:
                ? $minorizes_on(I, fn(x I) R {-M}, f)
                forall x I:
                    abs(f(x)) <= M
                    0 - abs(f(x)) <= f(x)
                    0 - M <= 0 - abs(f(x))
                    0 - M = -M
                    -M <= 0 - abs(f(x)) <= f(x)
                    -M <= f(x)
                    fn(x I) R {-M}(x) = -M
                    fn(x I) R {-M}(x) <= f(x)
                $minorizes_on(I, fn(x I) R {-M}, f)
            by thm piecewise_constant_minorant_integral_le_majorant_integral(I, f, g, fn(x I) R {-M}, sg, -M * interval_length(I))
            -M * interval_length(I) <= sg
        $is_lower_bound_of_real_set(upper_riemann_integral_candidate_values(I, f), -M * interval_length(I))
    by thm lower_bounded_real_set_with_member_has_infimum(upper_riemann_integral_candidate_values(I, f), -M * interval_length(I), M * interval_length(I))
    $has_infimum_of_real_set(upper_riemann_integral_candidate_values(I, f))

have fn upper_riemann_integral by exist!:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist! U R st {$has_upper_riemann_integral(I, f, U)}
    # Source handling: this packages the infimum definition of the upper
    # Riemann integral.  Uniqueness is the infimum uniqueness argument from
    # the completeness chapter.
    claim:
        ? exist U R st {$has_upper_riemann_integral(I, f, U)}
        by thm upper_riemann_integral_candidate_values_have_infimum(I, f)
        obtain U from exist U R st {$is_infimum_of_real_set(upper_riemann_integral_candidate_values(I, f), U)}
        witness exist U0 R st {$has_upper_riemann_integral(I, f, U0)} from U:
            $is_bounded_interval(I)
            $chap9::is_bounded_function_on(I, f)
            $has_infimum_of_real_set(upper_riemann_integral_candidate_values(I, f))
            $is_infimum_of_real_set(upper_riemann_integral_candidate_values(I, f), U)
        $has_upper_riemann_integral(I, f, U)
    claim:
        ? forall U1, U2 R:
            $has_upper_riemann_integral(I, f, U1)
            $has_upper_riemann_integral(I, f, U2)
            =>:
                U1 = U2
        by thm upper_riemann_integral_value_unique(I, f, U1, U2)
    exist! U R st {$has_upper_riemann_integral(I, f, U)}

have fn lower_riemann_integral by exist!:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist! L R st {$has_lower_riemann_integral(I, f, L)}
    # Source handling: this packages the supremum definition of the lower
    # Riemann integral.  Non-emptiness and the constant-majorant upper bound
    # reduce existence to Chapter 5 completeness; uniqueness is local.
    claim:
        ? exist L R st {$has_lower_riemann_integral(I, f, L)}
        by thm lower_riemann_integral_candidate_values_have_least_upper_bound(I, f)
        obtain L from exist L R st {$is_least_upper_bound(lower_riemann_integral_candidate_values(I, f), L)}
        witness exist L0 R st {$has_lower_riemann_integral(I, f, L0)} from L:
            $is_bounded_interval(I)
            $chap9::is_bounded_function_on(I, f)
            $has_least_upper_bound(lower_riemann_integral_candidate_values(I, f))
            $is_least_upper_bound(lower_riemann_integral_candidate_values(I, f), L)
        $has_lower_riemann_integral(I, f, L)
    claim:
        ? forall L1, L2 R:
            $has_lower_riemann_integral(I, f, L1)
            $has_lower_riemann_integral(I, f, L2)
            =>:
                L1 = L2
        by thm lower_riemann_integral_value_unique(I, f, L1, L2)
    exist! L R st {$has_lower_riemann_integral(I, f, L)}

thm upper_riemann_integral_le_candidate_value:
    ? forall I power_set(R), f fn(x I) R, U, s R:
        $has_upper_riemann_integral(I, f, U)
        $is_upper_riemann_integral_candidate_value(I, f, s)
        =>:
            U <= s
    $is_infimum_of_real_set(upper_riemann_integral_candidate_values(I, f), U)
    $is_lower_bound_of_real_set(upper_riemann_integral_candidate_values(I, f), U)
    by thm upper_riemann_integral_candidate_value_member(I, f, s)
    s $in upper_riemann_integral_candidate_values(I, f)
    U <= s

thm lower_riemann_integral_candidate_value_le_integral:
    ? forall I power_set(R), f fn(x I) R, L, s R:
        $has_lower_riemann_integral(I, f, L)
        $is_lower_riemann_integral_candidate_value(I, f, s)
        =>:
            s <= L
    $is_least_upper_bound(lower_riemann_integral_candidate_values(I, f), L)
    $is_upper_bound(lower_riemann_integral_candidate_values(I, f), L)
    by thm lower_riemann_integral_candidate_value_member(I, f, s)
    s $in lower_riemann_integral_candidate_values(I, f)
    s <= L

thm lower_bound_le_upper_riemann_integral:
    ? forall I power_set(R), f fn(x I) R, U, B R:
        $has_upper_riemann_integral(I, f, U)
        $is_lower_bound_of_real_set(upper_riemann_integral_candidate_values(I, f), B)
        =>:
            B <= U
    $is_infimum_of_real_set(upper_riemann_integral_candidate_values(I, f), U)
    forall M R:
        $is_lower_bound_of_real_set(upper_riemann_integral_candidate_values(I, f), M)
        =>:
            M <= U
    B <= U

thm lower_riemann_integral_le_upper_bound:
    ? forall I power_set(R), f fn(x I) R, L, B R:
        $has_lower_riemann_integral(I, f, L)
        $is_upper_bound(lower_riemann_integral_candidate_values(I, f), B)
        =>:
            L <= B
    $is_least_upper_bound(lower_riemann_integral_candidate_values(I, f), L)
    forall M R:
        $is_upper_bound(lower_riemann_integral_candidate_values(I, f), M)
        =>:
            L <= M
    L <= B

"""
Lemma 11.3.3.  If `-M <= f(x) <= M` on `I`, then the lower and upper integrals
lie between `-M*|I|` and `M*|I|`; in particular the upper integral is at least
the lower integral and both are real.
"""

thm upper_lower_riemann_integral_bounds:
    ? forall I power_set(R), f fn(x I) R, M R_pos:
        $is_bounded_interval(I)
        $chap9::is_bounded_function_on(I, f)
        forall x I:
            -M <= f(x)
            f(x) <= M
        =>:
            -M * interval_length(I) <= lower_riemann_integral(I, f)
            lower_riemann_integral(I, f) <= upper_riemann_integral(I, f)
            upper_riemann_integral(I, f) <= M * interval_length(I)
    # Source handling: Tao compares `f` with the constant majorant `M` and
    # minorant `-M`, then compares arbitrary minorants with arbitrary
    # majorants.
    $has_upper_riemann_integral(I, f, upper_riemann_integral(I, f))
    $has_lower_riemann_integral(I, f, lower_riemann_integral(I, f))
    by thm constant_function_is_piecewise_constant(I, M)
    by thm piecewise_constant_integral_of_constant(I, M)
    claim:
        ? $majorizes_on(I, fn(x I) R {M}, f)
        forall x I:
            f(x) <= M
            fn(x I) R {M}(x) = M
            fn(x I) R {M}(x) >= f(x)
        $majorizes_on(I, fn(x I) R {M}, f)
    claim:
        ? $is_upper_riemann_integral_candidate_value(I, f, M * interval_length(I))
        witness exist g fn(x I) R st {$is_piecewise_constant_on(I, g), $majorizes_on(I, g, f), $has_piecewise_constant_integral(I, g, M * interval_length(I))} from fn(x I) R {M}:
            $is_piecewise_constant_on(I, fn(x I) R {M})
            $majorizes_on(I, fn(x I) R {M}, f)
            $has_piecewise_constant_integral(I, fn(x I) R {M}, M * interval_length(I))
        $is_upper_riemann_integral_candidate_value(I, f, M * interval_length(I))
    by thm upper_riemann_integral_le_candidate_value(I, f, upper_riemann_integral(I, f), M * interval_length(I))
    upper_riemann_integral(I, f) <= M * interval_length(I)

    by thm constant_function_is_piecewise_constant(I, -M)
    by thm piecewise_constant_integral_of_constant(I, -M)
    claim:
        ? $minorizes_on(I, fn(x I) R {-M}, f)
        forall x I:
            -M <= f(x)
            fn(x I) R {-M}(x) = -M
            fn(x I) R {-M}(x) <= f(x)
        $minorizes_on(I, fn(x I) R {-M}, f)
    claim:
        ? $is_lower_riemann_integral_candidate_value(I, f, -M * interval_length(I))
        witness exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_integral(I, h, -M * interval_length(I))} from fn(x I) R {-M}:
            $is_piecewise_constant_on(I, fn(x I) R {-M})
            $minorizes_on(I, fn(x I) R {-M}, f)
            $has_piecewise_constant_integral(I, fn(x I) R {-M}, -M * interval_length(I))
        $is_lower_riemann_integral_candidate_value(I, f, -M * interval_length(I))
    by thm lower_riemann_integral_candidate_value_le_integral(I, f, lower_riemann_integral(I, f), -M * interval_length(I))
    -M * interval_length(I) <= lower_riemann_integral(I, f)

    claim:
        ? $is_upper_bound(lower_riemann_integral_candidate_values(I, f), upper_riemann_integral(I, f))
        claim:
            ? forall sh R:
                sh $in lower_riemann_integral_candidate_values(I, f)
                =>:
                    sh <= upper_riemann_integral(I, f)
            by thm lower_riemann_integral_candidate_value_from_member(I, f, sh)
            obtain h from exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_integral(I, h, sh)}
            claim:
                ? $is_lower_bound_of_real_set(upper_riemann_integral_candidate_values(I, f), sh)
                claim:
                    ? forall sg R:
                        sg $in upper_riemann_integral_candidate_values(I, f)
                        =>:
                            sh <= sg
                    by thm upper_riemann_integral_candidate_value_from_member(I, f, sg)
                    obtain g from exist g fn(x I) R st {$is_piecewise_constant_on(I, g), $majorizes_on(I, g, f), $has_piecewise_constant_integral(I, g, sg)}
                    by thm piecewise_constant_minorant_integral_le_majorant_integral(I, f, g, h, sg, sh)
                    sh <= sg
                $is_lower_bound_of_real_set(upper_riemann_integral_candidate_values(I, f), sh)
            by thm lower_bound_le_upper_riemann_integral(I, f, upper_riemann_integral(I, f), sh)
            sh <= upper_riemann_integral(I, f)
        $is_upper_bound(lower_riemann_integral_candidate_values(I, f), upper_riemann_integral(I, f))
    by thm lower_riemann_integral_le_upper_bound(I, f, lower_riemann_integral(I, f), upper_riemann_integral(I, f))
    lower_riemann_integral(I, f) <= upper_riemann_integral(I, f)

"""
Definition 11.3.4 (Riemann integral).  A bounded function is Riemann integrable
when its lower and upper Riemann integrals agree; the integral is their common
value.
"""

prop is_riemann_integrable_on(I power_set(R), f fn(x I) R):
    $is_bounded_interval(I)
    $chap9::is_bounded_function_on(I, f)
    upper_riemann_integral(I, f) = lower_riemann_integral(I, f)

prop has_riemann_integral(I power_set(R), f fn(x I) R, s R):
    $is_riemann_integrable_on(I, f)
    s = upper_riemann_integral(I, f)

thm riemann_integrable_on_bounded_interval:
    ? forall I power_set(R), f fn(x I) R:
        $is_riemann_integrable_on(I, f)
        =>:
            $is_bounded_interval(I)

thm riemann_integrable_on_bounded_function:
    ? forall I power_set(R), f fn(x I) R:
        $is_riemann_integrable_on(I, f)
        =>:
            $chap9::is_bounded_function_on(I, f)

thm riemann_integrable_upper_eq_lower:
    ? forall I power_set(R), f fn(x I) R:
        $is_riemann_integrable_on(I, f)
        =>:
            upper_riemann_integral(I, f) = lower_riemann_integral(I, f)

thm has_riemann_integral_implies_riemann_integrable:
    ? forall I power_set(R), f fn(x I) R, s R:
        $has_riemann_integral(I, f, s)
        =>:
            $is_riemann_integrable_on(I, f)

thm has_riemann_integral_value_eq_upper:
    ? forall I power_set(R), f fn(x I) R, s R:
        $has_riemann_integral(I, f, s)
        =>:
            s = upper_riemann_integral(I, f)

thm riemann_integral_value_unique:
    ? forall I power_set(R), f fn(x I) R, s1, s2 R:
        $has_riemann_integral(I, f, s1)
        $has_riemann_integral(I, f, s2)
        =>:
            s1 = s2
    s1 = upper_riemann_integral(I, f)
    s2 = upper_riemann_integral(I, f)
    s1 = s2

have fn integral_on by exist!:
    ? forall I power_set(R), f fn(x I) R:
        $is_riemann_integrable_on(I, f)
        =>:
            exist! s R st {$has_riemann_integral(I, f, s)}
    witness exist s R st {$has_riemann_integral(I, f, s)} from upper_riemann_integral(I, f):
        $has_riemann_integral(I, f, upper_riemann_integral(I, f))
    claim:
        ? forall s1, s2 R:
            $has_riemann_integral(I, f, s1)
            $has_riemann_integral(I, f, s2)
            =>:
                s1 = s2
        by thm riemann_integral_value_unique(I, f, s1, s2)
    exist! s R st {$has_riemann_integral(I, f, s)}

thm integral_on_has_riemann_integral:
    ? forall I power_set(R), f fn(x I) R:
        $is_riemann_integrable_on(I, f)
        =>:
            $has_riemann_integral(I, f, integral_on(I, f))

# This is the order-theoretic half of the Darboux epsilon argument: an
# infimum cannot remain at least epsilon below every candidate value.
thm upper_riemann_integral_has_candidate_within:
    ? forall I power_set(R), f fn(x I) R, epsilon R_pos:
        $is_bounded_interval(I)
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist sg R st {$is_upper_riemann_integral_candidate_value(I, f, sg), sg < upper_riemann_integral(I, f) + epsilon}
    prop has_upper_riemann_candidate_within():
        exist sg R st {$is_upper_riemann_integral_candidate_value(I, f, sg), sg < upper_riemann_integral(I, f) + epsilon}

    $has_upper_riemann_integral(I, f, upper_riemann_integral(I, f))
    claim:
        ? $has_upper_riemann_candidate_within()
        by contra:
            ? $has_upper_riemann_candidate_within()
            claim:
                ? $is_lower_bound_of_real_set(upper_riemann_integral_candidate_values(I, f), upper_riemann_integral(I, f) + epsilon)
                claim:
                    ? forall sg upper_riemann_integral_candidate_values(I, f):
                        upper_riemann_integral(I, f) + epsilon <= sg
                    by thm upper_riemann_integral_candidate_value_from_member(I, f, sg)
                    $is_upper_riemann_integral_candidate_value(I, f, sg)
                    by contra:
                        ? upper_riemann_integral(I, f) + epsilon <= sg
                        upper_riemann_integral(I, f) + epsilon > sg
                        sg < upper_riemann_integral(I, f) + epsilon
                        claim:
                            ? $has_upper_riemann_candidate_within()
                            witness exist sg0 R st {$is_upper_riemann_integral_candidate_value(I, f, sg0), sg0 < upper_riemann_integral(I, f) + epsilon} from sg:
                                $is_upper_riemann_integral_candidate_value(I, f, sg)
                                sg < upper_riemann_integral(I, f) + epsilon
                            by def $has_upper_riemann_candidate_within()
                        impossible $has_upper_riemann_candidate_within()
                $is_lower_bound_of_real_set(upper_riemann_integral_candidate_values(I, f), upper_riemann_integral(I, f) + epsilon)
            by thm lower_bound_le_upper_riemann_integral(I, f, upper_riemann_integral(I, f), upper_riemann_integral(I, f) + epsilon)
            upper_riemann_integral(I, f) + epsilon <= upper_riemann_integral(I, f)
            upper_riemann_integral(I, f) < upper_riemann_integral(I, f) + epsilon
            impossible upper_riemann_integral(I, f) + epsilon <= upper_riemann_integral(I, f)
    by def $has_upper_riemann_candidate_within()
    exist sg R st {$is_upper_riemann_integral_candidate_value(I, f, sg), sg < upper_riemann_integral(I, f) + epsilon}

thm lower_riemann_integral_has_candidate_within:
    ? forall I power_set(R), f fn(x I) R, epsilon R_pos:
        $is_bounded_interval(I)
        $chap9::is_bounded_function_on(I, f)
        =>:
            exist sh R st {$is_lower_riemann_integral_candidate_value(I, f, sh), lower_riemann_integral(I, f) - epsilon < sh}
    prop has_lower_riemann_candidate_within():
        exist sh R st {$is_lower_riemann_integral_candidate_value(I, f, sh), lower_riemann_integral(I, f) - epsilon < sh}

    $has_lower_riemann_integral(I, f, lower_riemann_integral(I, f))
    claim:
        ? $has_lower_riemann_candidate_within()
        by contra:
            ? $has_lower_riemann_candidate_within()
            claim:
                ? $is_upper_bound_of_real_set(lower_riemann_integral_candidate_values(I, f), lower_riemann_integral(I, f) - epsilon)
                claim:
                    ? forall sh lower_riemann_integral_candidate_values(I, f):
                        sh <= lower_riemann_integral(I, f) - epsilon
                    by thm lower_riemann_integral_candidate_value_from_member(I, f, sh)
                    $is_lower_riemann_integral_candidate_value(I, f, sh)
                    by contra:
                        ? sh <= lower_riemann_integral(I, f) - epsilon
                        sh > lower_riemann_integral(I, f) - epsilon
                        lower_riemann_integral(I, f) - epsilon < sh
                        claim:
                            ? $has_lower_riemann_candidate_within()
                            witness exist sh0 R st {$is_lower_riemann_integral_candidate_value(I, f, sh0), lower_riemann_integral(I, f) - epsilon < sh0} from sh:
                                $is_lower_riemann_integral_candidate_value(I, f, sh)
                                lower_riemann_integral(I, f) - epsilon < sh
                            by def $has_lower_riemann_candidate_within()
                        impossible $has_lower_riemann_candidate_within()
                $is_upper_bound_of_real_set(lower_riemann_integral_candidate_values(I, f), lower_riemann_integral(I, f) - epsilon)
            by thm lower_riemann_integral_le_upper_bound(I, f, lower_riemann_integral(I, f), lower_riemann_integral(I, f) - epsilon)
            lower_riemann_integral(I, f) <= lower_riemann_integral(I, f) - epsilon
            lower_riemann_integral(I, f) - epsilon < lower_riemann_integral(I, f)
            impossible lower_riemann_integral(I, f) <= lower_riemann_integral(I, f) - epsilon
    by def $has_lower_riemann_candidate_within()
    exist sh R st {$is_lower_riemann_integral_candidate_value(I, f, sh), lower_riemann_integral(I, f) - epsilon < sh}

# A Darboux approximation records a supplied lower and upper step function;
# there is deliberately no selected approximation because later epsilon proofs
# need fresh witnesses at each accuracy.
prop has_darboux_approximation(I power_set(R), f, h, g fn(x I) R, sh, sg R, epsilon R_pos):
    $is_piecewise_constant_on(I, h)
    $is_piecewise_constant_on(I, g)
    $minorizes_on(I, h, f)
    $majorizes_on(I, g, f)
    $has_piecewise_constant_integral(I, h, sh)
    $has_piecewise_constant_integral(I, g, sg)
    sg - sh < epsilon

thm riemann_integrable_has_darboux_approximation:
    ? forall I power_set(R), f fn(x I) R, epsilon R_pos:
        $is_riemann_integrable_on(I, f)
        =>:
            exist h, g fn(x I) R, sh, sg R st {$has_darboux_approximation(I, f, h, g, sh, sg, epsilon)}
    by thm riemann_integrable_on_bounded_interval(I, f)
    by thm riemann_integrable_on_bounded_function(I, f)
    epsilon / 2 > 0
    have delta R_pos = epsilon / 2
    by thm upper_riemann_integral_has_candidate_within(I, f, delta)
    obtain sg from exist sg0 R st {$is_upper_riemann_integral_candidate_value(I, f, sg0), sg0 < upper_riemann_integral(I, f) + delta}
    by thm lower_riemann_integral_has_candidate_within(I, f, delta)
    obtain sh from exist sh0 R st {$is_lower_riemann_integral_candidate_value(I, f, sh0), lower_riemann_integral(I, f) - delta < sh0}
    obtain g from exist g0 fn(x I) R st {$is_piecewise_constant_on(I, g0), $majorizes_on(I, g0, f), $has_piecewise_constant_integral(I, g0, sg)}
    obtain h from exist h0 fn(x I) R st {$is_piecewise_constant_on(I, h0), $minorizes_on(I, h0, f), $has_piecewise_constant_integral(I, h0, sh)}
    by thm riemann_integrable_upper_eq_lower(I, f)
    upper_riemann_integral(I, f) = lower_riemann_integral(I, f)
    delta = epsilon / 2
    sg < upper_riemann_integral(I, f) + delta
    lower_riemann_integral(I, f) - delta < sh
    sg - sh < epsilon
    witness exist h0, g0 fn(x I) R, sh0, sg0 R st {$has_darboux_approximation(I, f, h0, g0, sh0, sg0, epsilon)} from h, g, sh, sg:
        $is_piecewise_constant_on(I, h)
        $is_piecewise_constant_on(I, g)
        $minorizes_on(I, h, f)
        $majorizes_on(I, g, f)
        $has_piecewise_constant_integral(I, h, sh)
        $has_piecewise_constant_integral(I, g, sg)
        sg - sh < epsilon
        $has_darboux_approximation(I, f, h, g, sh, sg, epsilon)

thm arbitrary_darboux_approximations_imply_riemann_integrable:
    ? forall I power_set(R), f fn(x I) R:
        $is_bounded_interval(I)
        $chap9::is_bounded_function_on(I, f)
        forall epsilon R_pos:
            exist h, g fn(x I) R, sh, sg R st {$has_darboux_approximation(I, f, h, g, sh, sg, epsilon)}
        =>:
            $is_riemann_integrable_on(I, f)
    $has_upper_riemann_integral(I, f, upper_riemann_integral(I, f))
    $has_lower_riemann_integral(I, f, lower_riemann_integral(I, f))
    obtain M from exist M R_pos st {$chap9::is_function_bounded_by(I, f, M)}
    claim:
        ? forall x I:
            -M <= f(x)
            f(x) <= M
        abs(f(x)) <= M
        0 - abs(f(x)) <= f(x)
        0 - M <= 0 - abs(f(x))
        0 - M = -M
        -M <= f(x)
        f(x) <= abs(f(x))
        abs(f(x)) <= M
        f(x) <= M
    by thm upper_lower_riemann_integral_bounds(I, f, M)
    lower_riemann_integral(I, f) <= upper_riemann_integral(I, f)
    by contra:
        ? upper_riemann_integral(I, f) = lower_riemann_integral(I, f)
        upper_riemann_integral(I, f) != lower_riemann_integral(I, f)
        lower_riemann_integral(I, f) < upper_riemann_integral(I, f)
        upper_riemann_integral(I, f) - lower_riemann_integral(I, f) > 0
        (upper_riemann_integral(I, f) - lower_riemann_integral(I, f)) / 2 > 0
        have epsilon R_pos = (upper_riemann_integral(I, f) - lower_riemann_integral(I, f)) / 2
        obtain h, g, sh, sg from exist h0, g0 fn(x I) R, sh0, sg0 R st {$has_darboux_approximation(I, f, h0, g0, sh0, sg0, epsilon)}
        $is_piecewise_constant_on(I, h)
        $is_piecewise_constant_on(I, g)
        $minorizes_on(I, h, f)
        $majorizes_on(I, g, f)
        $has_piecewise_constant_integral(I, h, sh)
        $has_piecewise_constant_integral(I, g, sg)
        sg - sh < epsilon
        claim:
            ? $is_upper_riemann_integral_candidate_value(I, f, sg)
            witness exist g0 fn(x I) R st {$is_piecewise_constant_on(I, g0), $majorizes_on(I, g0, f), $has_piecewise_constant_integral(I, g0, sg)} from g:
                $is_piecewise_constant_on(I, g)
                $majorizes_on(I, g, f)
                $has_piecewise_constant_integral(I, g, sg)
            $is_upper_riemann_integral_candidate_value(I, f, sg)
        by thm upper_riemann_integral_le_candidate_value(I, f, upper_riemann_integral(I, f), sg)
        upper_riemann_integral(I, f) <= sg
        claim:
            ? $is_lower_riemann_integral_candidate_value(I, f, sh)
            witness exist h0 fn(x I) R st {$is_piecewise_constant_on(I, h0), $minorizes_on(I, h0, f), $has_piecewise_constant_integral(I, h0, sh)} from h:
                $is_piecewise_constant_on(I, h)
                $minorizes_on(I, h, f)
                $has_piecewise_constant_integral(I, h, sh)
            $is_lower_riemann_integral_candidate_value(I, f, sh)
        by thm lower_riemann_integral_candidate_value_le_integral(I, f, lower_riemann_integral(I, f), sh)
        sh <= lower_riemann_integral(I, f)
        upper_riemann_integral(I, f) - lower_riemann_integral(I, f) <= sg - sh
        epsilon = (upper_riemann_integral(I, f) - lower_riemann_integral(I, f)) / 2
        sg - sh < (upper_riemann_integral(I, f) - lower_riemann_integral(I, f)) / 2
        (upper_riemann_integral(I, f) - lower_riemann_integral(I, f)) / 2 < upper_riemann_integral(I, f) - lower_riemann_integral(I, f)
        impossible upper_riemann_integral(I, f) - lower_riemann_integral(I, f) <= sg - sh
    $is_riemann_integrable_on(I, f)

# Addition acts directly on supplied Darboux witnesses.  This is deliberately
# a theorem about a pair of witnesses, rather than a selector: later closure
# proofs choose fresh pairs at the accuracy required by their epsilon proof.
thm darboux_approximations_add:
    ? forall I power_set(R), f, g, hf, gf, hg, gg fn(x I) R, shf, sgf, shg, sgg, epsilon_f, epsilon_g R_pos:
        $has_darboux_approximation(I, f, hf, gf, shf, sgf, epsilon_f)
        $has_darboux_approximation(I, g, hg, gg, shg, sgg, epsilon_g)
        =>:
            $has_darboux_approximation(I, fn(x I) R {f(x) + g(x)}, fn(x I) R {hf(x) + hg(x)}, fn(x I) R {gf(x) + gg(x)}, shf + shg, sgf + sgg, epsilon_f + epsilon_g)
    by thm piecewise_constant_algebra(I, hf, hg)
    $is_piecewise_constant_on(I, fn(x I) R {hf(x) + hg(x)})
    by thm piecewise_constant_algebra(I, gf, gg)
    $is_piecewise_constant_on(I, fn(x I) R {gf(x) + gg(x)})
    claim:
        ? $minorizes_on(I, fn(x I) R {hf(x) + hg(x)}, fn(x I) R {f(x) + g(x)})
        forall x I:
            hf(x) <= f(x)
            hg(x) <= g(x)
            hf(x) + hg(x) <= f(x) + g(x)
            fn(x I) R {hf(x) + hg(x)}(x) = hf(x) + hg(x)
            fn(x I) R {f(x) + g(x)}(x) = f(x) + g(x)
            fn(x I) R {hf(x) + hg(x)}(x) <= fn(x I) R {f(x) + g(x)}(x)
        $minorizes_on(I, fn(x I) R {hf(x) + hg(x)}, fn(x I) R {f(x) + g(x)})
    claim:
        ? $majorizes_on(I, fn(x I) R {gf(x) + gg(x)}, fn(x I) R {f(x) + g(x)})
        forall x I:
            f(x) <= gf(x)
            g(x) <= gg(x)
            f(x) + g(x) <= gf(x) + gg(x)
            fn(x I) R {gf(x) + gg(x)}(x) = gf(x) + gg(x)
            fn(x I) R {f(x) + g(x)}(x) = f(x) + g(x)
            fn(x I) R {gf(x) + gg(x)}(x) >= fn(x I) R {f(x) + g(x)}(x)
        $majorizes_on(I, fn(x I) R {gf(x) + gg(x)}, fn(x I) R {f(x) + g(x)})
    by thm piecewise_constant_integral_laws(I, hf, hg, shf, shg, 1)
    $has_piecewise_constant_integral(I, fn(x I) R {hf(x) + hg(x)}, shf + shg)
    by thm piecewise_constant_integral_laws(I, gf, gg, sgf, sgg, 1)
    $has_piecewise_constant_integral(I, fn(x I) R {gf(x) + gg(x)}, sgf + sgg)
    sgf - shf < epsilon_f
    sgg - shg < epsilon_g
    (sgf + sgg) - (shf + shg) < epsilon_f + epsilon_g
    $has_darboux_approximation(I, fn(x I) R {f(x) + g(x)}, fn(x I) R {hf(x) + hg(x)}, fn(x I) R {gf(x) + gg(x)}, shf + shg, sgf + sgg, epsilon_f + epsilon_g)

thm sum_of_bounded_functions_is_bounded:
    ? forall I power_set(R), f, g fn(x I) R:
        $chap9::is_bounded_function_on(I, f)
        $chap9::is_bounded_function_on(I, g)
        =>:
            $chap9::is_bounded_function_on(I, fn(x I) R {f(x) + g(x)})
    obtain Mf from exist Mf0 R_pos st {$chap9::is_function_bounded_by(I, f, Mf0)}
    obtain Mg from exist Mg0 R_pos st {$chap9::is_function_bounded_by(I, g, Mg0)}
    Mf + Mg > 0
    witness exist M R_pos st {$chap9::is_function_bounded_by(I, fn(x I) R {f(x) + g(x)}, M)} from Mf + Mg:
        forall x I:
            abs(f(x) + g(x)) <= abs(f(x)) + abs(g(x))
            abs(f(x)) <= Mf
            abs(g(x)) <= Mg
            abs(f(x)) + abs(g(x)) <= Mf + Mg
            fn(x I) R {f(x) + g(x)}(x) = f(x) + g(x)
            abs(fn(x I) R {f(x) + g(x)}(x)) = abs(f(x) + g(x))
            abs(fn(x I) R {f(x) + g(x)}(x)) <= Mf + Mg
            M = Mf + Mg
            abs(fn(x I) R {f(x) + g(x)}(x)) <= M
        $chap9::is_function_bounded_by(I, fn(x I) R {f(x) + g(x)}, M)
    $chap9::is_bounded_function_on(I, fn(x I) R {f(x) + g(x)})

thm riemann_integrable_sum_has_darboux_approximation:
    ? forall I power_set(R), f, g fn(x I) R, epsilon R_pos:
        $is_riemann_integrable_on(I, f)
        $is_riemann_integrable_on(I, g)
        =>:
            exist h, k fn(x I) R, sh, sk R st {$has_darboux_approximation(I, fn(x I) R {f(x) + g(x)}, h, k, sh, sk, epsilon)}
    epsilon / 2 > 0
    have delta R_pos = epsilon / 2
    by thm riemann_integrable_has_darboux_approximation(I, f, delta)
    obtain hf, gf, shf, sgf from exist h0, g0 fn(x I) R, sh0, sg0 R st {$has_darboux_approximation(I, f, h0, g0, sh0, sg0, delta)}
    by thm riemann_integrable_has_darboux_approximation(I, g, delta)
    obtain hg, gg, shg, sgg from exist h0, g0 fn(x I) R, sh0, sg0 R st {$has_darboux_approximation(I, g, h0, g0, sh0, sg0, delta)}
    by thm darboux_approximations_add(I, f, g, hf, gf, hg, gg, shf, sgf, shg, sgg, delta, delta)
    $has_darboux_approximation(I, fn(x I) R {f(x) + g(x)}, fn(x I) R {hf(x) + hg(x)}, fn(x I) R {gf(x) + gg(x)}, shf + shg, sgf + sgg, delta + delta)
    delta = epsilon / 2
    delta + delta = epsilon
    $has_darboux_approximation(I, fn(x I) R {f(x) + g(x)}, fn(x I) R {hf(x) + hg(x)}, fn(x I) R {gf(x) + gg(x)}, shf + shg, sgf + sgg, epsilon)
    witness exist h, k fn(x I) R, sh, sk R st {$has_darboux_approximation(I, fn(x I) R {f(x) + g(x)}, h, k, sh, sk, epsilon)} from fn(x I) R {hf(x) + hg(x)}, fn(x I) R {gf(x) + gg(x)}, shf + shg, sgf + sgg:
        $has_darboux_approximation(I, fn(x I) R {f(x) + g(x)}, fn(x I) R {hf(x) + hg(x)}, fn(x I) R {gf(x) + gg(x)}, shf + shg, sgf + sgg, epsilon)

thm riemann_integrable_sum_by_darboux_approximation:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_riemann_integrable_on(I, f)
        $is_riemann_integrable_on(I, g)
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {f(x) + g(x)})
    by thm riemann_integrable_on_bounded_interval(I, f)
    $is_bounded_interval(I)
    by thm riemann_integrable_on_bounded_function(I, f)
    by thm riemann_integrable_on_bounded_function(I, g)
    by thm sum_of_bounded_functions_is_bounded(I, f, g)
    $chap9::is_bounded_function_on(I, fn(x I) R {f(x) + g(x)})
    claim:
        ? forall epsilon R_pos:
            exist h, k fn(x I) R, sh, sk R st {$has_darboux_approximation(I, fn(x I) R {f(x) + g(x)}, h, k, sh, sk, epsilon)}
        by thm riemann_integrable_sum_has_darboux_approximation(I, f, g, epsilon)
        exist h, k fn(x I) R, sh, sk R st {$has_darboux_approximation(I, fn(x I) R {f(x) + g(x)}, h, k, sh, sk, epsilon)}
    by thm arbitrary_darboux_approximations_imply_riemann_integrable(I, fn(x I) R {f(x) + g(x)})
    $is_riemann_integrable_on(I, fn(x I) R {f(x) + g(x)})

thm upper_riemann_integral_candidates_add:
    ? forall I power_set(R), f, g fn(x I) R, sf, sg R:
        $is_upper_riemann_integral_candidate_value(I, f, sf)
        $is_upper_riemann_integral_candidate_value(I, g, sg)
        =>:
            $is_upper_riemann_integral_candidate_value(I, fn(x I) R {f(x) + g(x)}, sf + sg)
    obtain hf from exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $majorizes_on(I, h, f), $has_piecewise_constant_integral(I, h, sf)}
    obtain hg from exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $majorizes_on(I, h, g), $has_piecewise_constant_integral(I, h, sg)}
    by thm piecewise_constant_algebra(I, hf, hg)
    $is_piecewise_constant_on(I, fn(x I) R {hf(x) + hg(x)})
    claim:
        ? $majorizes_on(I, fn(x I) R {hf(x) + hg(x)}, fn(x I) R {f(x) + g(x)})
        forall x I:
            f(x) <= hf(x)
            g(x) <= hg(x)
            f(x) + g(x) <= hf(x) + hg(x)
            fn(x I) R {hf(x) + hg(x)}(x) = hf(x) + hg(x)
            fn(x I) R {f(x) + g(x)}(x) = f(x) + g(x)
            fn(x I) R {hf(x) + hg(x)}(x) >= fn(x I) R {f(x) + g(x)}(x)
        $majorizes_on(I, fn(x I) R {hf(x) + hg(x)}, fn(x I) R {f(x) + g(x)})
    by thm piecewise_constant_integral_laws(I, hf, hg, sf, sg, 1)
    $has_piecewise_constant_integral(I, fn(x I) R {hf(x) + hg(x)}, sf + sg)
    witness exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $majorizes_on(I, h, fn(x I) R {f(x) + g(x)}), $has_piecewise_constant_integral(I, h, sf + sg)} from fn(x I) R {hf(x) + hg(x)}:
        $is_piecewise_constant_on(I, fn(x I) R {hf(x) + hg(x)})
        $majorizes_on(I, fn(x I) R {hf(x) + hg(x)}, fn(x I) R {f(x) + g(x)})
        $has_piecewise_constant_integral(I, fn(x I) R {hf(x) + hg(x)}, sf + sg)
    $is_upper_riemann_integral_candidate_value(I, fn(x I) R {f(x) + g(x)}, sf + sg)

thm lower_riemann_integral_candidates_add:
    ? forall I power_set(R), f, g fn(x I) R, sf, sg R:
        $is_lower_riemann_integral_candidate_value(I, f, sf)
        $is_lower_riemann_integral_candidate_value(I, g, sg)
        =>:
            $is_lower_riemann_integral_candidate_value(I, fn(x I) R {f(x) + g(x)}, sf + sg)
    obtain hf from exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, f), $has_piecewise_constant_integral(I, h, sf)}
    obtain hg from exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, g), $has_piecewise_constant_integral(I, h, sg)}
    by thm piecewise_constant_algebra(I, hf, hg)
    $is_piecewise_constant_on(I, fn(x I) R {hf(x) + hg(x)})
    claim:
        ? $minorizes_on(I, fn(x I) R {hf(x) + hg(x)}, fn(x I) R {f(x) + g(x)})
        forall x I:
            hf(x) <= f(x)
            hg(x) <= g(x)
            hf(x) + hg(x) <= f(x) + g(x)
            fn(x I) R {hf(x) + hg(x)}(x) = hf(x) + hg(x)
            fn(x I) R {f(x) + g(x)}(x) = f(x) + g(x)
            fn(x I) R {hf(x) + hg(x)}(x) <= fn(x I) R {f(x) + g(x)}(x)
        $minorizes_on(I, fn(x I) R {hf(x) + hg(x)}, fn(x I) R {f(x) + g(x)})
    by thm piecewise_constant_integral_laws(I, hf, hg, sf, sg, 1)
    $has_piecewise_constant_integral(I, fn(x I) R {hf(x) + hg(x)}, sf + sg)
    witness exist h fn(x I) R st {$is_piecewise_constant_on(I, h), $minorizes_on(I, h, fn(x I) R {f(x) + g(x)}), $has_piecewise_constant_integral(I, h, sf + sg)} from fn(x I) R {hf(x) + hg(x)}:
        $is_piecewise_constant_on(I, fn(x I) R {hf(x) + hg(x)})
        $minorizes_on(I, fn(x I) R {hf(x) + hg(x)}, fn(x I) R {f(x) + g(x)})
        $has_piecewise_constant_integral(I, fn(x I) R {hf(x) + hg(x)}, sf + sg)
    $is_lower_riemann_integral_candidate_value(I, fn(x I) R {f(x) + g(x)}, sf + sg)

thm upper_riemann_integral_sum_le:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_riemann_integrable_on(I, f)
        $is_riemann_integrable_on(I, g)
        =>:
            upper_riemann_integral(I, fn(x I) R {f(x) + g(x)}) <= upper_riemann_integral(I, f) + upper_riemann_integral(I, g)
    by thm riemann_integrable_sum_by_darboux_approximation(I, f, g)
    by thm riemann_integrable_on_bounded_interval(I, f)
    by thm riemann_integrable_on_bounded_function(I, f)
    by thm riemann_integrable_on_bounded_function(I, g)
    by thm sum_of_bounded_functions_is_bounded(I, f, g)
    by contra:
        ? upper_riemann_integral(I, fn(x I) R {f(x) + g(x)}) <= upper_riemann_integral(I, f) + upper_riemann_integral(I, g)
        upper_riemann_integral(I, fn(x I) R {f(x) + g(x)}) > upper_riemann_integral(I, f) + upper_riemann_integral(I, g)
        upper_riemann_integral(I, fn(x I) R {f(x) + g(x)}) - (upper_riemann_integral(I, f) + upper_riemann_integral(I, g)) > 0
        (upper_riemann_integral(I, fn(x I) R {f(x) + g(x)}) - (upper_riemann_integral(I, f) + upper_riemann_integral(I, g))) / 3 > 0
        have epsilon R_pos = (upper_riemann_integral(I, fn(x I) R {f(x) + g(x)}) - (upper_riemann_integral(I, f) + upper_riemann_integral(I, g))) / 3
        by thm upper_riemann_integral_has_candidate_within(I, f, epsilon)
        obtain sf from exist s R st {$is_upper_riemann_integral_candidate_value(I, f, s), s < upper_riemann_integral(I, f) + epsilon}
        by thm upper_riemann_integral_has_candidate_within(I, g, epsilon)
        obtain sg from exist s R st {$is_upper_riemann_integral_candidate_value(I, g, s), s < upper_riemann_integral(I, g) + epsilon}
        by thm upper_riemann_integral_candidates_add(I, f, g, sf, sg)
        by thm upper_riemann_integral_le_candidate_value(I, fn(x I) R {f(x) + g(x)}, upper_riemann_integral(I, fn(x I) R {f(x) + g(x)}), sf + sg)
        upper_riemann_integral(I, fn(x I) R {f(x) + g(x)}) <= sf + sg
        sf < upper_riemann_integral(I, f) + epsilon
        sg < upper_riemann_integral(I, g) + epsilon
        sf + sg < upper_riemann_integral(I, f) + upper_riemann_integral(I, g) + epsilon + epsilon
        epsilon = (upper_riemann_integral(I, fn(x I) R {f(x) + g(x)}) - (upper_riemann_integral(I, f) + upper_riemann_integral(I, g))) / 3
        upper_riemann_integral(I, f) + upper_riemann_integral(I, g) + epsilon + epsilon < upper_riemann_integral(I, fn(x I) R {f(x) + g(x)})
        impossible upper_riemann_integral(I, fn(x I) R {f(x) + g(x)}) <= sf + sg
    upper_riemann_integral(I, fn(x I) R {f(x) + g(x)}) <= upper_riemann_integral(I, f) + upper_riemann_integral(I, g)

thm lower_riemann_integral_sum_le:
    ? forall I power_set(R), f, g fn(x I) R:
        $is_riemann_integrable_on(I, f)
        $is_riemann_integrable_on(I, g)
        =>:
            lower_riemann_integral(I, f) + lower_riemann_integral(I, g) <= lower_riemann_integral(I, fn(x I) R {f(x) + g(x)})
    by thm riemann_integrable_sum_by_darboux_approximation(I, f, g)
    by thm riemann_integrable_on_bounded_interval(I, f)
    by thm riemann_integrable_on_bounded_function(I, f)
    by thm riemann_integrable_on_bounded_function(I, g)
    by thm sum_of_bounded_functions_is_bounded(I, f, g)
    by contra:
        ? lower_riemann_integral(I, f) + lower_riemann_integral(I, g) <= lower_riemann_integral(I, fn(x I) R {f(x) + g(x)})
        lower_riemann_integral(I, f) + lower_riemann_integral(I, g) > lower_riemann_integral(I, fn(x I) R {f(x) + g(x)})
        (lower_riemann_integral(I, f) + lower_riemann_integral(I, g)) - lower_riemann_integral(I, fn(x I) R {f(x) + g(x)}) > 0
        ((lower_riemann_integral(I, f) + lower_riemann_integral(I, g)) - lower_riemann_integral(I, fn(x I) R {f(x) + g(x)})) / 3 > 0
        have epsilon R_pos = ((lower_riemann_integral(I, f) + lower_riemann_integral(I, g)) - lower_riemann_integral(I, fn(x I) R {f(x) + g(x)})) / 3
        by thm lower_riemann_integral_has_candidate_within(I, f, epsilon)
        obtain sf from exist s R st {$is_lower_riemann_integral_candidate_value(I, f, s), lower_riemann_integral(I, f) - epsilon < s}
        by thm lower_riemann_integral_has_candidate_within(I, g, epsilon)
        obtain sg from exist s R st {$is_lower_riemann_integral_candidate_value(I, g, s), lower_riemann_integral(I, g) - epsilon < s}
        by thm lower_riemann_integral_candidates_add(I, f, g, sf, sg)
        by thm lower_riemann_integral_candidate_value_le_integral(I, fn(x I) R {f(x) + g(x)}, lower_riemann_integral(I, fn(x I) R {f(x) + g(x)}), sf + sg)
        sf + sg <= lower_riemann_integral(I, fn(x I) R {f(x) + g(x)})
        lower_riemann_integral(I, f) - epsilon < sf
        lower_riemann_integral(I, g) - epsilon < sg
        lower_riemann_integral(I, f) + lower_riemann_integral(I, g) - epsilon - epsilon < sf + sg
        epsilon = ((lower_riemann_integral(I, f) + lower_riemann_integral(I, g)) - lower_riemann_integral(I, fn(x I) R {f(x) + g(x)})) / 3
        lower_riemann_integral(I, fn(x I) R {f(x) + g(x)}) < lower_riemann_integral(I, f) + lower_riemann_integral(I, g) - epsilon - epsilon
        impossible sf + sg <= lower_riemann_integral(I, fn(x I) R {f(x) + g(x)})
    lower_riemann_integral(I, f) + lower_riemann_integral(I, g) <= lower_riemann_integral(I, fn(x I) R {f(x) + g(x)})

thm scalar_of_bounded_function_is_bounded:
    ? forall I power_set(R), f fn(x I) R, c R:
        $chap9::is_bounded_function_on(I, f)
        =>:
            $chap9::is_bounded_function_on(I, fn(x I) R {c * f(x)})
    obtain M from exist M0 R_pos st {$chap9::is_function_bounded_by(I, f, M0)}
    abs(c) * M + 1 > 0
    witness exist B R_pos st {$chap9::is_function_bounded_by(I, fn(x I) R {c * f(x)}, B)} from abs(c) * M + 1:
        forall x I:
            abs(fn(x I) R {c * f(x)}(x)) = abs(c * f(x))
            abs(c * f(x)) = abs(c) * abs(f(x))
            abs(f(x)) <= M
            abs(c) * abs(f(x)) <= abs(c) * M
            abs(c) * M <= abs(c) * M + 1
            abs(fn(x I) R {c * f(x)}(x)) <= abs(c) * M + 1
            B = abs(c) * M + 1
            abs(fn(x I) R {c * f(x)}(x)) <= B
        $chap9::is_function_bounded_by(I, fn(x I) R {c * f(x)}, B)
    $chap9::is_bounded_function_on(I, fn(x I) R {c * f(x)})

thm riemann_integrable_scalar_has_darboux_approximation:
    ? forall I power_set(R), f fn(x I) R, c R, epsilon R_pos:
        $is_riemann_integrable_on(I, f)
        =>:
            exist h, g fn(x I) R, sh, sg R st {$has_darboux_approximation(I, fn(x I) R {c * f(x)}, h, g, sh, sg, epsilon)}
    epsilon / (abs(c) + 1) > 0
    have delta R_pos = epsilon / (abs(c) + 1)
    by thm riemann_integrable_has_darboux_approximation(I, f, delta)
    obtain h, g, sh, sg from exist h0, g0 fn(x I) R, sh0, sg0 R st {$has_darboux_approximation(I, f, h0, g0, sh0, sg0, delta)}
    by cases:
        ? c >= 0 or c < 0
        case c >= 0:
            by thm piecewise_constant_integral_laws(I, h, g, sh, sg, c)
            $has_piecewise_constant_integral(I, fn(x I) R {c * h(x)}, c * sh)
            $has_piecewise_constant_integral(I, fn(x I) R {c * g(x)}, c * sg)
            claim:
                ? $minorizes_on(I, fn(x I) R {c * h(x)}, fn(x I) R {c * f(x)})
                forall x I:
                    h(x) <= f(x)
                    c * h(x) <= c * f(x)
                    fn(x I) R {c * h(x)}(x) = c * h(x)
                    fn(x I) R {c * f(x)}(x) = c * f(x)
                    fn(x I) R {c * h(x)}(x) <= fn(x I) R {c * f(x)}(x)
                $minorizes_on(I, fn(x I) R {c * h(x)}, fn(x I) R {c * f(x)})
            claim:
                ? $majorizes_on(I, fn(x I) R {c * g(x)}, fn(x I) R {c * f(x)})
                forall x I:
                    f(x) <= g(x)
                    c * f(x) <= c * g(x)
                    fn(x I) R {c * g(x)}(x) = c * g(x)
                    fn(x I) R {c * f(x)}(x) = c * f(x)
                    fn(x I) R {c * g(x)}(x) >= fn(x I) R {c * f(x)}(x)
                $majorizes_on(I, fn(x I) R {c * g(x)}, fn(x I) R {c * f(x)})
            sg - sh < delta
            c * (sg - sh) < c * delta
            c <= abs(c) + 1
            c * delta <= (abs(c) + 1) * delta
            delta = epsilon / (abs(c) + 1)
            (abs(c) + 1) * delta = epsilon
            (c * sg) - (c * sh) = c * (sg - sh)
            (c * sg) - (c * sh) < epsilon
            witness exist h0, g0 fn(x I) R, sh0, sg0 R st {$has_darboux_approximation(I, fn(x I) R {c * f(x)}, h0, g0, sh0, sg0, epsilon)} from fn(x I) R {c * h(x)}, fn(x I) R {c * g(x)}, c * sh, c * sg:
                $is_piecewise_constant_on(I, fn(x I) R {c * h(x)})
                $is_piecewise_constant_on(I, fn(x I) R {c * g(x)})
                $minorizes_on(I, fn(x I) R {c * h(x)}, fn(x I) R {c * f(x)})
                $majorizes_on(I, fn(x I) R {c * g(x)}, fn(x I) R {c * f(x)})
                $has_piecewise_constant_integral(I, fn(x I) R {c * h(x)}, c * sh)
                $has_piecewise_constant_integral(I, fn(x I) R {c * g(x)}, c * sg)
                (c * sg) - (c * sh) < epsilon
                $has_darboux_approximation(I, fn(x I) R {c * f(x)}, fn(x I) R {c * h(x)}, fn(x I) R {c * g(x)}, c * sh, c * sg, epsilon)
        case c < 0:
            by thm piecewise_constant_integral_laws(I, h, g, sh, sg, c)
            $has_piecewise_constant_integral(I, fn(x I) R {c * h(x)}, c * sh)
            $has_piecewise_constant_integral(I, fn(x I) R {c * g(x)}, c * sg)
            claim:
                ? $minorizes_on(I, fn(x I) R {c * g(x)}, fn(x I) R {c * f(x)})
                forall x I:
                    f(x) <= g(x)
                    c * g(x) <= c * f(x)
                    fn(x I) R {c * g(x)}(x) = c * g(x)
                    fn(x I) R {c * f(x)}(x) = c * f(x)
                    fn(x I) R {c * g(x)}(x) <= fn(x I) R {c * f(x)}(x)
                $minorizes_on(I, fn(x I) R {c * g(x)}, fn(x I) R {c * f(x)})
            claim:
                ? $majorizes_on(I, fn(x I) R {c * h(x)}, fn(x I) R {c * f(x)})
                forall x I:
                    h(x) <= f(x)
                    c * f(x) <= c * h(x)
                    fn(x I) R {c * h(x)}(x) = c * h(x)
                    fn(x I) R {c * f(x)}(x) = c * f(x)
                    fn(x I) R {c * h(x)}(x) >= fn(x I) R {c * f(x)}(x)
                $majorizes_on(I, fn(x I) R {c * h(x)}, fn(x I) R {c * f(x)})
            abs(c) = -c
            abs(c) > 0
            sg - sh < delta
            abs(c) * (sg - sh) < abs(c) * delta
            abs(c) <= abs(c) + 1
            abs(c) * delta <= (abs(c) + 1) * delta
            delta = epsilon / (abs(c) + 1)
            (abs(c) + 1) * delta = epsilon
            (c * sh) - (c * sg) = abs(c) * (sg - sh)
            (c * sh) - (c * sg) < epsilon
            witness exist h0, g0 fn(x I) R, sh0, sg0 R st {$has_darboux_approximation(I, fn(x I) R {c * f(x)}, h0, g0, sh0, sg0, epsilon)} from fn(x I) R {c * g(x)}, fn(x I) R {c * h(x)}, c * sg, c * sh:
                $is_piecewise_constant_on(I, fn(x I) R {c * g(x)})
                $is_piecewise_constant_on(I, fn(x I) R {c * h(x)})
                $minorizes_on(I, fn(x I) R {c * g(x)}, fn(x I) R {c * f(x)})
                $majorizes_on(I, fn(x I) R {c * h(x)}, fn(x I) R {c * f(x)})
                $has_piecewise_constant_integral(I, fn(x I) R {c * g(x)}, c * sg)
                $has_piecewise_constant_integral(I, fn(x I) R {c * h(x)}, c * sh)
                (c * sh) - (c * sg) < epsilon
                $has_darboux_approximation(I, fn(x I) R {c * f(x)}, fn(x I) R {c * g(x)}, fn(x I) R {c * h(x)}, c * sg, c * sh, epsilon)

thm riemann_integrable_scalar_by_darboux_approximation:
    ? forall I power_set(R), f fn(x I) R, c R:
        $is_riemann_integrable_on(I, f)
        =>:
            $is_riemann_integrable_on(I, fn(x I) R {c * f(x)})
    by thm riemann_integrable_on_bounded_interval(I, f)
    by thm riemann_integrable_on_bounded_function(I, f)
    by thm scalar_of_bounded_function_is_bounded(I, f, c)
    claim:
        ? forall epsilon R_pos:
            exist h, g fn(x I) R, sh, sg R st {$has_darboux_approximation(I, fn(x I) R {c * f(x)}, h, g, sh, sg, epsilon)}
        by thm riemann_integrable_scalar_has_darboux_approximation(I, f, c, epsilon)
        exist h, g fn(x I) R, sh, sg R st {$has_darboux_approximation(I, fn(x I) R {c * f(x)}, h, g, sh, sg, epsilon)}
    by thm arbitrary_darboux_approximations_imply_riemann_integrable(I, fn(x I) R {c * f(x)})
    $is_riemann_integrable_on(I, fn(x I) R {c * f(x)})

thm upper_riemann_integral_candidate_scalar_nonnegative:
    ? forall I power_set(R), f fn(x I) R, c, s R:
        c >= 0
        $is_upper_riemann_integral_candidate_value(I, f, s)
        =>:
            $is_upper_riemann_integral_candidate_value(I, fn(x I) R {c * f(x)}, c * s)
    obtain g from exist g0 fn(x I) R st {$is_piecewise_constant_on(I, g0), $majorizes_on(I, g0, f), $has_piecewise_constant_integral(I, g0, s)}
    by thm piecewise_constant_integral_laws(I, g, g, s, s, c)
    $has_piecewise_constant_integral(I, fn(x I) R {c * g(x)}, c * s)
    claim:
        ? $majorizes_on(I, fn(x I) R {c * g(x)}, fn(x I) R {c * f(x)})
        forall x I:
            f(x) <= g(x)
            c * f(x) <= c * g(x)
            fn(x I) R {c * g(x)}(x) = c * g(x)
            fn(x I) R {c * f(x)}(x) = c * f(x)
            fn(x I) R {c * g(x)}(x) >= fn(x I) R {c * f(x)}(x)
        $majorizes_on(I, fn(x I) R {c * g(x)}, fn(x I) R {c * f(x)})
    witness exist g0 fn(x I) R st {$is_piecewise_constant_on(I, g0), $majorizes_on(I, g0, fn(x I) R {c * f(x)}), $has_piecewise_constant_integral(I, g0, c * s)} from fn(x I) R {c * g(x)}:
        $is_piecewise_constant_on(I, fn(x I) R {c * g(x)})
        $majorizes_on(I, fn(x I) R {c * g(x)}, fn(x I) R {c * f(x)})
        $has_piecewise_constant_integral(I, fn(x I) R {c * g(x)}, c * s)
    $is_upper_riemann_integral_candidate_value(I, fn(x I) R {c * f(x)}, c * s)

thm lower_riemann_integral_candidate_scalar_nonnegative:
    ? forall I power_set(R), f fn(x I) R, c, s R:
        c >= 0
        $is_lower_riemann_integral_candidate_value(I, f, s)
        =>:
            $is_lower_riemann_integral_candidate_value(I, fn(x I) R {c * f(x)}, c * s)
    obtain h from exist h0 fn(x I) R st {$is_piecewise_constant_on(I, h0), $minorizes_on(I, h0, f), $has_piecewise_constant_integral(I, h0, s)}
    by thm piecewise_constant_integral_laws(I, h, h, s, s, c)
    $has_piecewise_constant_integral(I, fn(x I) R {c * h(x)}, c * s)
    claim:
        ? $minorizes_on(I, fn(x I) R {c * h(x)}, fn(x I) R {c * f(x)})
        forall x I:
            h(x) <= f(x)
            c * h(x) <= c * f(x)
            fn(x I) R {c * h(x)}(x) = c * h(x)
            fn(x I) R {c * f(x)}(x) = c * f(x)
            fn(x I) R {c * h(x)}(x) <= fn(x I) R {c * f(x)}(x)
        $minorizes_on(I, fn(x I) R {c * h(x)}, fn(x I) R {c * f(x)})
    witness exist h0 fn(x I) R st {$is_piecewise_constant_on(I, h0), $minorizes_on(I, h0, fn(x I) R {c * f(x)}), $has_piecewise_constant_integral(I, h0, c * s)} from fn(x I) R {c * h(x)}:
        $is_piecewise_constant_on(I, fn(x I) R {c * h(x)})
        $minorizes_on(I, fn(x I) R {c * h(x)}, fn(x I) R {c * f(x)})
        $has_piecewise_constant_integral(I, fn(x I) R {c * h(x)}, c * s)
    $is_lower_riemann_integral_candidate_value(I, fn(x I) R {c * f(x)}, c * s)

thm upper_riemann_integral_candidate_scalar_negative:
    ? forall I power_set(R), f fn(x I) R, c, s R:
        c < 0
        $is_lower_riemann_integral_candidate_value(I, f, s)
        =>:
            $is_upper_riemann_integral_candidate_value(I, fn(x I) R {c * f(x)}, c * s)
    obtain h from exist h0 fn(x I) R st {$is_piecewise_constant_on(I, h0), $minorizes_on(I, h0, f), $has_piecewise_constant_integral(I, h0, s)}
    by thm piecewise_constant_integral_laws(I, h, h, s, s, c)
    $has_piecewise_constant_integral(I, fn(x I) R {c * h(x)}, c * s)
    claim:
        ? $majorizes_on(I, fn(x I) R {c * h(x)}, fn(x I) R {c * f(x)})
        forall x I:
            h(x) <= f(x)
            c * f(x) <= c * h(x)
            fn(x I) R {c * h(x)}(x) = c * h(x)
            fn(x I) R {c * f(x)}(x) = c * f(x)
            fn(x I) R {c * h(x)}(x) >= fn(x I) R {c * f(x)}(x)
        $majorizes_on(I, fn(x I) R {c * h(x)}, fn(x I) R {c * f(x)})
    witness exist g0 fn(x I) R st {$is_piecewise_constant_on(I, g0), $majorizes_on(I, g0, fn(x I) R {c * f(x)}), $has_piecewise_constant_integral(I, g0, c * s)} from fn(x I) R {c * h(x)}:
        $is_piecewise_constant_on(I, fn(x I) R {c * h(x)})
        $majorizes_on(I, fn(x I) R {c * h(x)}, fn(x I) R {c * f(x)})
        $has_piecewise_constant_integral(I, fn(x I) R {c * h(x)}, c * s)
    $is_upper_riemann_integral_candidate_value(I, fn(x I) R {c * f(x)}, c * s)

thm lower_riemann_integral_candidate_scalar_negative:
    ? forall I power_set(R), f fn(x I) R, c, s R:
        c < 0
        $is_upper_riemann_integral_candidate_value(I, f, s)
        =>:
            $is_lower_riemann_integral_candidate_value(I, fn(x I) R {c * f(x)}, c * s)
    obtain g from exist g0 fn(x I) R st {$is_piecewise_constant_on(I, g0), $majorizes_on(I, g0, f), $has_piecewise_constant_integral(I, g0, s)}
    by thm piecewise_constant_integral_laws(I, g, g, s, s, c)
    $has_piecewise_constant_integral(I, fn(x I) R {c * g(x)}, c * s)
    claim:
        ? $minorizes_on(I, fn(x I) R {c * g(x)}, fn(x I) R {c * f(x)})
        forall x I:
            f(x) <= g(x)
            c * g(x) <= c * f(x)
            fn(x I) R {c * g(x)}(x) = c * g(x)
            fn(x I) R {c * f(x)}(x) = c * f(x)
            fn(x I) R {c * g(x)}(x) <= fn(x I) R {c * f(x)}(x)
        $minorizes_on(I, fn(x I) R {c * g(x)}, fn(x I) R {c * f(x)})
    witness exist h0 fn(x I) R st {$is_piecewise_constant_on(I, h0), $minorizes_on(I, h0, fn(x I) R {c * f(x)}), $has_piecewise_constant_integral(I, h0, c * s)} from fn(x I) R {c * g(x)}:
        $is_piecewise_constant_on(I, fn(x I) R {c * g(x)})
        $minorizes_on(I, fn(x I) R {c * g(x)}, fn(x I) R {c * f(x)})
        $has_piecewise_constant_integral(I, fn(x I) R {c * g(x)}, c * s)
