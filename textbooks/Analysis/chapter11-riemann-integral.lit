thm example_11_2_12_displayed_partition_unique_cover:
    ? forall x '[1, 4]:
        exist! J example_11_2_12_partition_set st {J $in power_set(R), x $in J}
    claim:
        ? forall y '[1, 4]:
            exist J example_11_2_12_partition_set st {J $in power_set(R), y $in J}
        by cases:
            ? exist J example_11_2_12_partition_set st {J $in power_set(R), y $in J}
            case y < 3:
                claim:
                    ? '[1, 3) $in example_11_2_12_partition_set
                    '[1, 3) $in {'[1, 3), {3}, '(3, 4]}
                    example_11_2_12_partition_set = {'[1, 3), {3}, '(3, 4]}
                    '[1, 3) $in example_11_2_12_partition_set
                witness exist J example_11_2_12_partition_set st {J $in power_set(R), y $in J} from '[1, 3):
                    '[1, 3) $in example_11_2_12_partition_set
                    '[1, 3) $in power_set(R)
                    y $in '[1, 3)
            case y = 3:
                claim:
                    ? {3} $in example_11_2_12_partition_set
                    {3} $in {'[1, 3), {3}, '(3, 4]}
                    example_11_2_12_partition_set = {'[1, 3), {3}, '(3, 4]}
                    {3} $in example_11_2_12_partition_set
                witness exist J example_11_2_12_partition_set st {J $in power_set(R), y $in J} from {3}:
                    {3} $in example_11_2_12_partition_set
                    {3} $in power_set(R)
                    y $in {3}
            case y > 3:
                claim:
                    ? '(3, 4] $in example_11_2_12_partition_set
                    '(3, 4] $in {'[1, 3), {3}, '(3, 4]}
                    example_11_2_12_partition_set = {'[1, 3), {3}, '(3, 4]}
                    '(3, 4] $in example_11_2_12_partition_set
                witness exist J example_11_2_12_partition_set st {J $in power_set(R), y $in J} from '(3, 4]:
                    '(3, 4] $in example_11_2_12_partition_set
                    '(3, 4] $in power_set(R)
                    y $in '(3, 4]
    claim:
        ? forall y '[1, 4], J1, J2 example_11_2_12_partition_set:
            J1 $in power_set(R)
            J2 $in power_set(R)
            y $in J1
            y $in J2
            =>:
                J1 = J2
        by enumerate finite_set:
            ? forall J example_11_2_12_partition_set:
                J = '[1, 3) or J = {3} or J = '(3, 4]
        by cases:
            ? J1 = J2
            case J1 = '[1, 3):
                by cases:
                    ? J1 = J2
                    case J2 = '[1, 3):
                        J1 = '[1, 3)
                        J2 = '[1, 3)
                        J1 = J2
                    case J2 = {3}:
                        y $in J1
                        y $in J2
                        y < 3
                        y = 3
                        impossible 3 < 3
                    case J2 = '(3, 4]:
                        y $in J1
                        y $in J2
                        y < 3
                        y > 3
                        impossible 3 < 3
            case J1 = {3}:
                by cases:
                    ? J1 = J2
                    case J2 = '[1, 3):
                        y $in J1
                        y $in J2
                        y = 3
                        y < 3
                        impossible 3 < 3
                    case J2 = {3}:
                        J1 = {3}
                        J2 = {3}
                        J1 = J2
                    case J2 = '(3, 4]:
                        y $in J1
                        y $in J2
                        y = 3
                        y > 3
                        impossible 3 < 3
            case J1 = '(3, 4]:
                by cases:
                    ? J1 = J2
                    case J2 = '[1, 3):
                        y $in J1
                        y $in J2
                        y > 3
                        y < 3
                        impossible 3 < 3
                    case J2 = {3}:
                        y $in J1
                        y $in J2
                        y > 3
                        y = 3
                        impossible 3 < 3
                    case J2 = '(3, 4]:
                        J1 = '(3, 4]
                        J2 = '(3, 4]
                        J1 = J2
    forall y '[1, 4]:
        exist! J example_11_2_12_partition_set st {J $in power_set(R), y $in J}

thm example_11_2_12_refined_partition_member_below_two:
    ? forall x '[1, 4], J example_11_2_12_refined_partition_set:
        x < 2
        J $in power_set(R)
        x $in J
        =>:
            J = '[1, 2)
    by enumerate finite_set:
        ? forall K example_11_2_12_refined_partition_set:
            K = '[1, 2) or K = '[2, 3) or K = {3} or K = '(3, 4] or K = {}
    by cases:
        ? J = '[1, 2)
        case J = '[1, 2):
            J = '[1, 2)
        case J = '[2, 3):
            x $in J
            x >= 2
            x < 2
            2 <= x < 2
            impossible 2 < 2
        case J = {3}:
            x $in J
            x = 3
            x < 2
            impossible 3 < 2
        case J = '(3, 4]:
            x $in J
            x > 3
            x < 2
            impossible 3 < 2
        case J = {}:
            x $in J
            x $in {}
            not $is_nonempty_set({})
            witness $is_nonempty_set({}) from x
            impossible $is_nonempty_set({})

