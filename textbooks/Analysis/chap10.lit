# Chapter 10: Differentiation of functions.

trust local import chap9

# 10.1 Basic definitions

"""
Definition 10.1.1 (Differentiability at a point).  A function is differentiable
at x0 on X with derivative L when the difference quotient tends to L as x
approaches x0 through X with x != x0.
"""

prop is_difference_quotient_close_to(X power_set(R), f fn(x X) R, x0 X, L R, epsilon R_pos, delta R_pos):
    forall x X:
        x - x0 != 0
        abs(x - x0) < delta
        =>:
            abs(((f(x) - f(x0)) / (x - x0)) - L) <= epsilon

prop has_derivative_at(X power_set(R), f fn(x X) R, x0 X, L R):
    $is_limit_point_of_set(X, x0)
    forall epsilon R_pos:
        exist delta R_pos st {$is_difference_quotient_close_to(X, f, x0, L, epsilon, delta)}

prop is_differentiable_at(X power_set(R), f fn(x X) R, x0 X):
    exist L R st {$has_derivative_at(X, f, x0, L)}

thm derivative_value_unique:
    ? forall X power_set(R), f fn(x X) R, x0 X, L1, L2 R:
        $has_derivative_at(X, f, x0, L1)
        $has_derivative_at(X, f, x0, L2)
        =>:
            L1 = L2
    by contra:
        ? L1 = L2
        L1 != L2
        L1 - L2 != 0
        abs(L1 - L2) > 0
        abs(L1 - L2) / 3 $in R_pos
        obtain delta1 from exist delta1 R_pos st {$is_difference_quotient_close_to(X, f, x0, L1, abs(L1 - L2) / 3, delta1)}
        obtain delta2 from exist delta2 R_pos st {$is_difference_quotient_close_to(X, f, x0, L2, abs(L1 - L2) / 3, delta2)}
        min(delta1, delta2) $in R_pos
        min(delta1, delta2) / 2 $in R_pos
        $is_epsilon_adherent_to_set(set_minus(X, {x0}), x0, min(delta1, delta2) / 2)
        obtain y from exist y R st {y $in set_minus(X, {x0}), abs(x0 - y) <= min(delta1, delta2) / 2}
        y $in X
        not y $in {x0}
        claim:
            ? y != x0
            by contra:
                ? y != x0
                y = x0
                x0 $in {x0}
                y $in {x0}
                impossible not y $in {x0}
        y - x0 != 0
        abs(x0 - y) <= min(delta1, delta2) / 2
        abs(y - x0) = abs(x0 - y)
        abs(y - x0) <= min(delta1, delta2) / 2
        min(delta1, delta2) / 2 < min(delta1, delta2)
        abs(y - x0) <= min(delta1, delta2) / 2 < min(delta1, delta2)
        abs(y - x0) < min(delta1, delta2)
        min(delta1, delta2) <= delta1
        min(delta1, delta2) <= delta2
        abs(y - x0) < min(delta1, delta2) <= delta1
        abs(y - x0) < delta1
        abs(y - x0) < min(delta1, delta2) <= delta2
        abs(y - x0) < delta2
        abs(((f(y) - f(x0)) / (y - x0)) - L1) <= abs(L1 - L2) / 3
        abs(((f(y) - f(x0)) / (y - x0)) - L2) <= abs(L1 - L2) / 3
        abs(L1 - ((f(y) - f(x0)) / (y - x0))) = abs(((f(y) - f(x0)) / (y - x0)) - L1)
        abs(L1 - ((f(y) - f(x0)) / (y - x0))) <= abs(L1 - L2) / 3
        L1 - L2 = (L1 - ((f(y) - f(x0)) / (y - x0))) + (((f(y) - f(x0)) / (y - x0)) - L2)
        abs(L1 - L2) = abs((L1 - ((f(y) - f(x0)) / (y - x0))) + (((f(y) - f(x0)) / (y - x0)) - L2))
        abs((L1 - ((f(y) - f(x0)) / (y - x0))) + (((f(y) - f(x0)) / (y - x0)) - L2)) <= abs(L1 - ((f(y) - f(x0)) / (y - x0))) + abs(((f(y) - f(x0)) / (y - x0)) - L2)
        abs(L1 - L2) <= abs(L1 - ((f(y) - f(x0)) / (y - x0))) + abs(((f(y) - f(x0)) / (y - x0)) - L2)
        abs(L1 - ((f(y) - f(x0)) / (y - x0))) + abs(((f(y) - f(x0)) / (y - x0)) - L2) <= abs(L1 - L2) / 3 + abs(L1 - L2) / 3
        abs(L1 - L2) <= abs(L1 - ((f(y) - f(x0)) / (y - x0))) + abs(((f(y) - f(x0)) / (y - x0)) - L2) <= abs(L1 - L2) / 3 + abs(L1 - L2) / 3
        abs(L1 - L2) <= abs(L1 - L2) / 3 + abs(L1 - L2) / 3
        abs(L1 - L2) / 3 + abs(L1 - L2) / 3 = 2 * abs(L1 - L2) / 3
        2 / 3 < 1
        (2 / 3) * abs(L1 - L2) < 1 * abs(L1 - L2)
        2 * abs(L1 - L2) / 3 = (2 / 3) * abs(L1 - L2)
        1 * abs(L1 - L2) = abs(L1 - L2)
        2 * abs(L1 - L2) / 3 < abs(L1 - L2)
        abs(L1 - L2) <= 2 * abs(L1 - L2) / 3 < abs(L1 - L2)
        abs(L1 - L2) < abs(L1 - L2)
        impossible abs(L1 - L2) < abs(L1 - L2)

"""
Notation after Definition 10.1.1.  Once differentiability at `x0` is known,
the derivative is a genuine real value, not just an existential predicate.
The relation `has_derivative_at` remains the epsilon-delta definition; the
function `derivative(X, f, x0)` is the unique value selected from it.
"""

have fn derivative by exist!:
    ? forall X power_set(R), f fn(x X) R, x0 X:
        $is_differentiable_at(X, f, x0)
        =>:
            exist! L R st {$has_derivative_at(X, f, x0, L)}
    obtain L from exist L R st {$has_derivative_at(X, f, x0, L)}
    claim:
        ? forall L1, L2 R:
            $has_derivative_at(X, f, x0, L1)
            $has_derivative_at(X, f, x0, L2)
            =>:
                L1 = L2
        by thm derivative_value_unique(X, f, x0, L1, L2)
    exist! L R st {$has_derivative_at(X, f, x0, L)}

forall X power_set(R), f fn(x X) R, x0 X:
    $is_differentiable_at(X, f, x0)
    =>:
        $has_derivative_at(X, f, x0, derivative(X, f, x0))

forall X power_set(R), f fn(x X) R, x0 X, L R:
    $is_differentiable_at(X, f, x0)
    $has_derivative_at(X, f, x0, L)
    =>:
        L = derivative(X, f, x0)

thm has_derivative_at_to_derivative_value:
    ? forall X power_set(R), f fn(x X) R, x0 X, L R:
        $has_derivative_at(X, f, x0, L)
        =>:
            $is_differentiable_at(X, f, x0)
            derivative(X, f, x0) = L
    witness exist L0 R st {$has_derivative_at(X, f, x0, L0)} from L:
        $has_derivative_at(X, f, x0, L)
    $is_differentiable_at(X, f, x0)
    L = derivative(X, f, x0)
    derivative(X, f, x0) = L

"""
Remark 10.1.2. The derivative is not defined at isolated points, because the
difference quotient is a limit over `X - {x0}`.  On intervals this issue mostly
disappears because interval points are limit points.
"""

"""
Example 10.1.3. The square function is differentiable on R, and the derivative
at x0 is 2*x0, because `(x^2 - x0^2)/(x - x0)` simplifies to `x + x0`.
"""

# The later product and difference laws turn the same algebra into reusable
# derivative rules.

have fn square_function(x R) R = x^2

# Difference quotients use punctured real subsets.  A member of
# `set_minus(X, Y)` is a member of `X`, hence is real whenever `X` is a real
# subset.
thm real_set_minus_is_real_set:
    ? forall X, Y power_set(R):
        set_minus(X, Y) $in power_set(R)
    claim:
        ? set_minus(X, Y) $subset R
        claim:
            ? forall z set_minus(X, Y):
                z $in R
            z $in X
            z $in R
        set_minus(X, Y) $subset R
    set_minus(X, Y) $in power_set(R)

thm real_line_points_are_limit_points:
    ? forall x0 R:
        $is_limit_point_of_set(R, x0)
    claim:
        ? forall epsilon R_pos:
            $is_epsilon_adherent_to_set(set_minus(R, {x0}), x0, epsilon)
        {x0} $in power_set(R)
        by thm real_set_minus_is_real_set(R, {x0})
        set_minus(R, {x0}) $in power_set(R)
        witness exist y R st {y $in set_minus(R, {x0}), abs(x0 - y) <= epsilon} from x0 - epsilon / 2:
            epsilon / 2 $in R_pos
            epsilon / 2 > 0
            x0 - epsilon / 2 < x0
            x0 - epsilon / 2 != x0
            not x0 - epsilon / 2 $in {x0}
            x0 - epsilon / 2 $in set_minus(R, {x0})
            x0 - (x0 - epsilon / 2) = epsilon / 2
            abs(epsilon / 2) = epsilon / 2
            abs(x0 - (x0 - epsilon / 2)) = abs(epsilon / 2)
            abs(x0 - (x0 - epsilon / 2)) = epsilon / 2
            epsilon / 2 < epsilon
            epsilon / 2 <= epsilon
            abs(x0 - (x0 - epsilon / 2)) <= epsilon
        $is_epsilon_adherent_to_set(set_minus(R, {x0}), x0, epsilon)
    $is_adherent_point(set_minus(R, {x0}), x0)
    $is_limit_point_of_set(R, x0)

thm square_difference_quotient_factor_cancel:
    ? forall x0, x R:
        x - x0 != 0
        =>:
            (square_function(x) - square_function(x0)) / (x - x0) = x + x0
    square_function(x) = x^2
    square_function(x0) = x0^2
    square_function(x) - square_function(x0) = x^2 - x0^2
    x^2 - x0^2 = (x - x0) * (x + x0)
    (square_function(x) - square_function(x0)) / (x - x0) = ((x - x0) * (x + x0)) / (x - x0)
    ((x - x0) * (x + x0)) / (x - x0) = x + x0

thm square_function_has_derivative_at:
    ? forall x0 R:
        $has_derivative_at(R, square_function, x0, 2 * x0)
    by thm real_line_points_are_limit_points(x0)
    $is_limit_point_of_set(R, x0)
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$is_difference_quotient_close_to(R, square_function, x0, 2 * x0, epsilon, delta)}
        witness exist delta R_pos st {$is_difference_quotient_close_to(R, square_function, x0, 2 * x0, epsilon, delta)} from epsilon:
            claim:
                ? forall x R:
                    x - x0 != 0
                    abs(x - x0) < epsilon
                    =>:
                        abs(((square_function(x) - square_function(x0)) / (x - x0)) - 2 * x0) <= epsilon
                by thm square_difference_quotient_factor_cancel(x0, x)
                (square_function(x) - square_function(x0)) / (x - x0) = x + x0
                ((square_function(x) - square_function(x0)) / (x - x0)) - 2 * x0 = (x + x0) - 2 * x0
                (x + x0) - 2 * x0 = x - x0
                abs(((square_function(x) - square_function(x0)) / (x - x0)) - 2 * x0) = abs(x - x0)
                abs(x - x0) < epsilon
                abs(x - x0) <= epsilon
                abs(((square_function(x) - square_function(x0)) / (x - x0)) - 2 * x0) <= epsilon
            $is_difference_quotient_close_to(R, square_function, x0, 2 * x0, epsilon, delta)
    $has_derivative_at(R, square_function, x0, 2 * x0)

thm square_function_is_differentiable_at:
    ? forall x0 R:
        $is_differentiable_at(R, square_function, x0)
    by thm square_function_has_derivative_at(x0)
    $has_derivative_at(R, square_function, x0, 2 * x0)
    witness exist L R st {$has_derivative_at(R, square_function, x0, L)} from 2 * x0:
        $has_derivative_at(R, square_function, x0, 2 * x0)

thm square_function_derivative_value:
    ? forall x0 R:
        $is_differentiable_at(R, square_function, x0)
        =>:
            derivative(R, square_function, x0) = 2 * x0
    by thm square_function_has_derivative_at(x0)
    $has_derivative_at(R, square_function, x0, 2 * x0)
    2 * x0 = derivative(R, square_function, x0)
    derivative(R, square_function, x0) = 2 * x0

"""
Remark 10.1.4. Equal functions on the whole domain have the same derivative;
equal values at a single point do not determine the derivative.
"""

thm equal_functions_have_equal_derivatives:
    ? forall X power_set(R), f, g fn(x X) R, x0 X, L R:
        forall x X:
            f(x) = g(x)
        $has_derivative_at(X, f, x0, L)
        =>:
            $has_derivative_at(X, g, x0, L)
    # Source handling: this is marked "(why?)"; replace every value of `g`
    # in the difference quotient with the corresponding value of `f`.
    $is_limit_point_of_set(X, x0)
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$is_difference_quotient_close_to(X, g, x0, L, epsilon, delta)}
        obtain delta from exist delta R_pos st {$is_difference_quotient_close_to(X, f, x0, L, epsilon, delta)}
        witness exist eta R_pos st {$is_difference_quotient_close_to(X, g, x0, L, epsilon, eta)} from delta:
            claim:
                ? forall x X:
                    x - x0 != 0
                    abs(x - x0) < delta
                    =>:
                        abs(((g(x) - g(x0)) / (x - x0)) - L) <= epsilon
                f(x) = g(x)
                f(x0) = g(x0)
                g(x) = f(x)
                g(x0) = f(x0)
                g(x) - g(x0) = f(x) - f(x0)
                (g(x) - g(x0)) / (x - x0) = (f(x) - f(x0)) / (x - x0)
                ((g(x) - g(x0)) / (x - x0)) - L = ((f(x) - f(x0)) / (x - x0)) - L
                abs(((g(x) - g(x0)) / (x - x0)) - L) = abs(((f(x) - f(x0)) / (x - x0)) - L)
                abs(((f(x) - f(x0)) / (x - x0)) - L) <= epsilon
                abs(((g(x) - g(x0)) / (x - x0)) - L) <= epsilon
            $is_difference_quotient_close_to(X, g, x0, L, epsilon, delta)
        exist delta R_pos st {$is_difference_quotient_close_to(X, g, x0, L, epsilon, delta)}
    $has_derivative_at(X, g, x0, L)

"""
Remark 10.1.5. Leibniz notation `df/dx` is convenient but can be ambiguous if
the input variable is not really named x.
"""

# The formal derivative predicate avoids the ambiguity by naming the domain,
# function, base point, and derivative value explicitly.

"""
Example 10.1.6. The absolute value function is not differentiable at 0 on R:
the right difference quotient tends to 1 while the left quotient tends to -1.
After restricting the domain to `[0,infty)` or `(-infty,0]`, the one-sided
derivatives at 0 are 1 and -1 respectively.
"""

# The absolute value function has a right-hand difference quotient constantly
# equal to `1` and a left-hand difference quotient constantly equal to `-1`.
# These two quotient computations are the local obstruction to a two-sided
# derivative at zero.

have fn absolute_value_function(x R) R = abs(x)
have fn absolute_value_on_nonnegative_ray(x '[0,)) R = abs(x)
have fn absolute_value_on_nonpositive_ray(x '(,0]) R = abs(x)

thm absolute_value_positive_difference_quotient_at_zero:
    ? forall x R:
        x > 0
        x - 0 != 0
        =>:
            (absolute_value_function(x) - absolute_value_function(0)) / (x - 0) = 1
    x != 0
    absolute_value_function(x) = abs(x)
    abs(x) = x
    absolute_value_function(0) = abs(0)
    abs(0) = 0
    x - 0 = x
    absolute_value_function(x) - absolute_value_function(0) = x - 0
    (absolute_value_function(x) - absolute_value_function(0)) / (x - 0) = (x - 0) / (x - 0)
    (x - 0) / (x - 0) = 1

thm absolute_value_negative_difference_quotient_at_zero:
    ? forall x R:
        x < 0
        x - 0 != 0
        =>:
            (absolute_value_function(x) - absolute_value_function(0)) / (x - 0) = -1
    x != 0
    absolute_value_function(x) = abs(x)
    abs(x) = -x
    absolute_value_function(0) = abs(0)
    abs(0) = 0
    x - 0 = x
    absolute_value_function(x) - absolute_value_function(0) = -x
    (absolute_value_function(x) - absolute_value_function(0)) / (x - 0) = (-x) / x
    (-x) / x = -1

thm absolute_value_nonnegative_ray_difference_quotient_at_zero:
    ? forall x '[0,):
        x - 0 != 0
        =>:
            (absolute_value_on_nonnegative_ray(x) - absolute_value_on_nonnegative_ray(0)) / (x - 0) = 1
    x >= 0
    x - 0 = x
    x != 0
    absolute_value_on_nonnegative_ray(x) = abs(x)
    abs(x) = x
    absolute_value_on_nonnegative_ray(0) = abs(0)
    abs(0) = 0
    absolute_value_on_nonnegative_ray(x) - absolute_value_on_nonnegative_ray(0) = x - 0
    (absolute_value_on_nonnegative_ray(x) - absolute_value_on_nonnegative_ray(0)) / (x - 0) = (x - 0) / (x - 0)
    (x - 0) / (x - 0) = 1

thm absolute_value_nonpositive_ray_difference_quotient_at_zero:
    ? forall x '(,0]:
        x - 0 != 0
        =>:
            (absolute_value_on_nonpositive_ray(x) - absolute_value_on_nonpositive_ray(0)) / (x - 0) = -1
    x <= 0
    x - 0 = x
    x != 0
    absolute_value_on_nonpositive_ray(x) = abs(x)
    abs(x) = -x
    absolute_value_on_nonpositive_ray(0) = abs(0)
    abs(0) = 0
    absolute_value_on_nonpositive_ray(x) - absolute_value_on_nonpositive_ray(0) = -x
    (absolute_value_on_nonpositive_ray(x) - absolute_value_on_nonpositive_ray(0)) / (x - 0) = (-x) / x
    (-x) / x = -1

thm zero_is_limit_point_of_nonnegative_ray:
    ? forall:
        $is_limit_point_of_set('[0,), 0)
    0 $in '[0,)
    {0} $in power_set(R)
    by thm real_set_minus_is_real_set('[0,), {0})
    set_minus('[0,), {0}) $in power_set(R)
    claim:
        ? forall epsilon R_pos:
            $is_epsilon_adherent_to_set(set_minus('[0,), {0}), 0, epsilon)
        witness exist y R st {y $in set_minus('[0,), {0}), abs(0 - y) <= epsilon} from epsilon / 2:
            epsilon / 2 $in R_pos
            epsilon / 2 > 0
            epsilon / 2 >= 0
            epsilon / 2 $in '[0,)
            epsilon / 2 != 0
            not epsilon / 2 $in {0}
            epsilon / 2 $in set_minus('[0,), {0})
            0 - epsilon / 2 = -(epsilon / 2)
            abs(0 - epsilon / 2) = abs(-(epsilon / 2))
            abs(-(epsilon / 2)) = abs(epsilon / 2)
            abs(epsilon / 2) = epsilon / 2
            abs(0 - epsilon / 2) = epsilon / 2
            epsilon / 2 < epsilon
            epsilon / 2 <= epsilon
            abs(0 - epsilon / 2) <= epsilon
        $is_epsilon_adherent_to_set(set_minus('[0,), {0}), 0, epsilon)
    $is_adherent_point(set_minus('[0,), {0}), 0)
    $is_limit_point_of_set('[0,), 0)

thm zero_is_limit_point_of_nonpositive_ray:
    ? forall:
        $is_limit_point_of_set('(,0], 0)
    0 $in '(,0]
    {0} $in power_set(R)
    by thm real_set_minus_is_real_set('(,0], {0})
    set_minus('(,0], {0}) $in power_set(R)
    claim:
        ? forall epsilon R_pos:
            $is_epsilon_adherent_to_set(set_minus('(,0], {0}), 0, epsilon)
        witness exist y R st {y $in set_minus('(,0], {0}), abs(0 - y) <= epsilon} from 0 - epsilon / 2:
            epsilon / 2 $in R_pos
            epsilon / 2 > 0
            0 - epsilon / 2 < 0
            0 - epsilon / 2 <= 0
            0 - epsilon / 2 $in '(,0]
            0 - epsilon / 2 != 0
            not 0 - epsilon / 2 $in {0}
            0 - epsilon / 2 $in set_minus('(,0], {0})
            0 - (0 - epsilon / 2) = epsilon / 2
            abs(epsilon / 2) = epsilon / 2
            abs(0 - (0 - epsilon / 2)) = abs(epsilon / 2)
            abs(0 - (0 - epsilon / 2)) = epsilon / 2
            epsilon / 2 < epsilon
            epsilon / 2 <= epsilon
            abs(0 - (0 - epsilon / 2)) <= epsilon
        $is_epsilon_adherent_to_set(set_minus('(,0], {0}), 0, epsilon)
    $is_adherent_point(set_minus('(,0], {0}), 0)
    $is_limit_point_of_set('(,0], 0)

thm absolute_value_on_nonnegative_ray_has_derivative_at_zero:
    ? forall:
        $has_derivative_at('[0,), absolute_value_on_nonnegative_ray, 0, 1)
    by thm zero_is_limit_point_of_nonnegative_ray()
    $is_limit_point_of_set('[0,), 0)
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$is_difference_quotient_close_to('[0,), absolute_value_on_nonnegative_ray, 0, 1, epsilon, delta)}
        witness exist delta R_pos st {$is_difference_quotient_close_to('[0,), absolute_value_on_nonnegative_ray, 0, 1, epsilon, delta)} from epsilon:
            claim:
                ? forall x '[0,):
                    x - 0 != 0
                    abs(x - 0) < epsilon
                    =>:
                        abs(((absolute_value_on_nonnegative_ray(x) - absolute_value_on_nonnegative_ray(0)) / (x - 0)) - 1) <= epsilon
                by thm absolute_value_nonnegative_ray_difference_quotient_at_zero(x)
                (absolute_value_on_nonnegative_ray(x) - absolute_value_on_nonnegative_ray(0)) / (x - 0) = 1
                ((absolute_value_on_nonnegative_ray(x) - absolute_value_on_nonnegative_ray(0)) / (x - 0)) - 1 = 0
                abs(((absolute_value_on_nonnegative_ray(x) - absolute_value_on_nonnegative_ray(0)) / (x - 0)) - 1) = abs(0)
                abs(0) = 0
                0 <= epsilon
            $is_difference_quotient_close_to('[0,), absolute_value_on_nonnegative_ray, 0, 1, epsilon, delta)
        exist delta R_pos st {$is_difference_quotient_close_to('[0,), absolute_value_on_nonnegative_ray, 0, 1, epsilon, delta)}
    $has_derivative_at('[0,), absolute_value_on_nonnegative_ray, 0, 1)

thm absolute_value_on_nonnegative_ray_derivative_value_at_zero:
    ? forall:
        $is_differentiable_at('[0,), absolute_value_on_nonnegative_ray, 0)
        derivative('[0,), absolute_value_on_nonnegative_ray, 0) = 1
    by thm absolute_value_on_nonnegative_ray_has_derivative_at_zero()
    $has_derivative_at('[0,), absolute_value_on_nonnegative_ray, 0, 1)
    by thm has_derivative_at_to_derivative_value('[0,), absolute_value_on_nonnegative_ray, 0, 1)
    $is_differentiable_at('[0,), absolute_value_on_nonnegative_ray, 0)
    derivative('[0,), absolute_value_on_nonnegative_ray, 0) = 1

thm absolute_value_on_nonpositive_ray_has_derivative_at_zero:
    ? forall:
        $has_derivative_at('(,0], absolute_value_on_nonpositive_ray, 0, -1)
    by thm zero_is_limit_point_of_nonpositive_ray()
    $is_limit_point_of_set('(,0], 0)
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$is_difference_quotient_close_to('(,0], absolute_value_on_nonpositive_ray, 0, -1, epsilon, delta)}
        witness exist delta R_pos st {$is_difference_quotient_close_to('(,0], absolute_value_on_nonpositive_ray, 0, -1, epsilon, delta)} from epsilon:
            claim:
                ? forall x '(,0]:
                    x - 0 != 0
                    abs(x - 0) < epsilon
                    =>:
                        abs(((absolute_value_on_nonpositive_ray(x) - absolute_value_on_nonpositive_ray(0)) / (x - 0)) - (-1)) <= epsilon
                by thm absolute_value_nonpositive_ray_difference_quotient_at_zero(x)
                (absolute_value_on_nonpositive_ray(x) - absolute_value_on_nonpositive_ray(0)) / (x - 0) = -1
                ((absolute_value_on_nonpositive_ray(x) - absolute_value_on_nonpositive_ray(0)) / (x - 0)) - (-1) = 0
                abs(((absolute_value_on_nonpositive_ray(x) - absolute_value_on_nonpositive_ray(0)) / (x - 0)) - (-1)) = abs(0)
                abs(0) = 0
                0 <= epsilon
            $is_difference_quotient_close_to('(,0], absolute_value_on_nonpositive_ray, 0, -1, epsilon, delta)
        exist delta R_pos st {$is_difference_quotient_close_to('(,0], absolute_value_on_nonpositive_ray, 0, -1, epsilon, delta)}
    $has_derivative_at('(,0], absolute_value_on_nonpositive_ray, 0, -1)

thm absolute_value_on_nonpositive_ray_derivative_value_at_zero:
    ? forall:
        $is_differentiable_at('(,0], absolute_value_on_nonpositive_ray, 0)
        derivative('(,0], absolute_value_on_nonpositive_ray, 0) = -1
    by thm absolute_value_on_nonpositive_ray_has_derivative_at_zero()
    $has_derivative_at('(,0], absolute_value_on_nonpositive_ray, 0, -1)
    by thm has_derivative_at_to_derivative_value('(,0], absolute_value_on_nonpositive_ray, 0, -1)
    $is_differentiable_at('(,0], absolute_value_on_nonpositive_ray, 0)
    derivative('(,0], absolute_value_on_nonpositive_ray, 0) = -1

thm absolute_value_not_differentiable_at_zero_on_real_line:
    ? forall:
        not $is_differentiable_at(R, absolute_value_function, 0)
    by contra:
        ? not $is_differentiable_at(R, absolute_value_function, 0)
        $is_differentiable_at(R, absolute_value_function, 0)
        obtain L from exist L R st {$has_derivative_at(R, absolute_value_function, 0, L)}
        $has_derivative_at(R, absolute_value_function, 0, L)
        1 / 2 $in R_pos
        obtain delta from exist delta R_pos st {$is_difference_quotient_close_to(R, absolute_value_function, 0, L, 1 / 2, delta)}
        $is_difference_quotient_close_to(R, absolute_value_function, 0, L, 1 / 2, delta)
        delta / 2 $in R_pos
        delta / 2 > 0
        delta / 2 - 0 = delta / 2
        delta / 2 - 0 != 0
        abs(delta / 2) = delta / 2
        abs(delta / 2 - 0) = abs(delta / 2)
        abs(delta / 2 - 0) = delta / 2
        delta / 2 < delta
        abs(delta / 2 - 0) < delta
        abs(((absolute_value_function(delta / 2) - absolute_value_function(0)) / (delta / 2 - 0)) - L) <= 1 / 2
        by thm absolute_value_positive_difference_quotient_at_zero(delta / 2)
        (absolute_value_function(delta / 2) - absolute_value_function(0)) / (delta / 2 - 0) = 1
        ((absolute_value_function(delta / 2) - absolute_value_function(0)) / (delta / 2 - 0)) - L = 1 - L
        abs(((absolute_value_function(delta / 2) - absolute_value_function(0)) / (delta / 2 - 0)) - L) = abs(1 - L)
        abs(1 - L) <= 1 / 2
        0 - delta / 2 < 0
        (0 - delta / 2) - 0 = 0 - delta / 2
        (0 - delta / 2) - 0 != 0
        abs(0 - delta / 2) = delta / 2
        abs((0 - delta / 2) - 0) = abs(0 - delta / 2)
        abs((0 - delta / 2) - 0) = delta / 2
        abs((0 - delta / 2) - 0) < delta
        by thm absolute_value_negative_difference_quotient_at_zero(0 - delta / 2)
        (absolute_value_function(0 - delta / 2) - absolute_value_function(0)) / ((0 - delta / 2) - 0) = -1
        abs(((absolute_value_function(0 - delta / 2) - absolute_value_function(0)) / ((0 - delta / 2) - 0)) - L) <= 1 / 2
        ((absolute_value_function(0 - delta / 2) - absolute_value_function(0)) / ((0 - delta / 2) - 0)) - L = (-1) - L
        abs(((absolute_value_function(0 - delta / 2) - absolute_value_function(0)) / ((0 - delta / 2) - 0)) - L) = abs((-1) - L)
        abs((-1) - L) <= 1 / 2
        abs(L - (-1)) = abs((-1) - L)
        abs(L - (-1)) <= 1 / 2
        1 - (-1) = 2
        1 - (-1) = (1 - L) + (L - (-1))
        abs(2) = abs((1 - L) + (L - (-1)))
        abs((1 - L) + (L - (-1))) <= abs(1 - L) + abs(L - (-1))
        abs(2) <= abs(1 - L) + abs(L - (-1))
        abs(1 - L) + abs(L - (-1)) <= 1 / 2 + 1 / 2
        1 / 2 + 1 / 2 = 1
        abs(1 - L) + abs(L - (-1)) <= 1
        abs(2) <= abs(1 - L) + abs(L - (-1)) <= 1
        abs(2) <= 1
        abs(2) = 2
        2 <= 1
        impossible 2 <= 1


"""
Proposition 10.1.7 (Newton's approximation).  Differentiability at x0 with
derivative L is equivalent to a first-order linear approximation with error at
most epsilon*|x-x0| near x0.
"""

# Newton's approximation converts the difference quotient limit into a local
# linear estimate for `f(x) - (f(x0) + L*(x-x0))`, treating `x = x0` separately.
# The proof shrinks the derivative witness so the closed-ball Newton estimate
# can use the strict punctured-neighborhood estimate away from `x0`.

prop is_newton_approximation_witness(X power_set(R), f fn(x X) R, x0 X, L R, epsilon R_pos, delta R_pos):
    forall x X:
        abs(x - x0) <= delta
        =>:
            abs(f(x) - (f(x0) + L * (x - x0))) <= epsilon * abs(x - x0)

prop has_newton_approximation_at(X power_set(R), f fn(x X) R, x0 X, L R):
    forall epsilon R_pos:
        exist delta R_pos st {$is_newton_approximation_witness(X, f, x0, L, epsilon, delta)}

thm newton_approximation_forward:
    ? forall X power_set(R), f fn(x X) R, x0 X, L R:
        $has_derivative_at(X, f, x0, L)
        =>:
            $has_newton_approximation_at(X, f, x0, L)
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$is_newton_approximation_witness(X, f, x0, L, epsilon, delta)}
        obtain delta0 from exist delta0 R_pos st {$is_difference_quotient_close_to(X, f, x0, L, epsilon, delta0)}
        delta0 / 2 $in R_pos
        delta0 / 2 < delta0
        witness exist delta R_pos st {$is_newton_approximation_witness(X, f, x0, L, epsilon, delta)} from delta0 / 2:
            claim:
                ? forall x X:
                    abs(x - x0) <= delta0 / 2
                    =>:
                        abs(f(x) - (f(x0) + L * (x - x0))) <= epsilon * abs(x - x0)
                x - x0 = 0 or x - x0 != 0
                by cases:
                    ? abs(f(x) - (f(x0) + L * (x - x0))) <= epsilon * abs(x - x0)
                    case x - x0 = 0:
                        x = x0
                        f(x) = f(x0)
                        L * (x - x0) = L * 0
                        L * 0 = 0
                        f(x0) + L * (x - x0) = f(x0) + 0
                        f(x0) + 0 = f(x0)
                        f(x) - (f(x0) + L * (x - x0)) = f(x0) - f(x0)
                        f(x0) - f(x0) = 0
                        abs(f(x) - (f(x0) + L * (x - x0))) = abs(0)
                        abs(0) = 0
                        abs(x - x0) = abs(0)
                        abs(x - x0) = 0
                        epsilon * abs(x - x0) = epsilon * 0
                        epsilon * 0 = 0
                        abs(f(x) - (f(x0) + L * (x - x0))) <= epsilon * abs(x - x0)
                    case x - x0 != 0:
                        abs(x - x0) <= delta0 / 2 < delta0
                        abs(x - x0) < delta0
                        abs(((f(x) - f(x0)) / (x - x0)) - L) <= epsilon
                        f(x) - (f(x0) + L * (x - x0)) = (((f(x) - f(x0)) / (x - x0)) - L) * (x - x0)
                        abs(f(x) - (f(x0) + L * (x - x0))) = abs((((f(x) - f(x0)) / (x - x0)) - L) * (x - x0))
                        abs((((f(x) - f(x0)) / (x - x0)) - L) * (x - x0)) = abs(((f(x) - f(x0)) / (x - x0)) - L) * abs(x - x0)
                        abs(((f(x) - f(x0)) / (x - x0)) - L) * abs(x - x0) <= epsilon * abs(x - x0)
                        abs(f(x) - (f(x0) + L * (x - x0))) <= epsilon * abs(x - x0)
            $is_newton_approximation_witness(X, f, x0, L, epsilon, delta)
    $has_newton_approximation_at(X, f, x0, L)

thm newton_approximation_reverse:
    ? forall X power_set(R), f fn(x X) R, x0 X, L R:
        $is_limit_point_of_set(X, x0)
        $has_newton_approximation_at(X, f, x0, L)
        =>:
            $has_derivative_at(X, f, x0, L)
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$is_difference_quotient_close_to(X, f, x0, L, epsilon, delta)}
        obtain delta from exist delta R_pos st {$is_newton_approximation_witness(X, f, x0, L, epsilon, delta)}
        witness exist eta R_pos st {$is_difference_quotient_close_to(X, f, x0, L, epsilon, eta)} from delta:
            claim:
                ? forall x X:
                    x - x0 != 0
                    abs(x - x0) < delta
                    =>:
                        abs(((f(x) - f(x0)) / (x - x0)) - L) <= epsilon
                abs(x - x0) <= delta
                abs(f(x) - (f(x0) + L * (x - x0))) <= epsilon * abs(x - x0)
                abs(x - x0) != 0
                abs(x - x0) > 0
                f(x) - (f(x0) + L * (x - x0)) = (((f(x) - f(x0)) / (x - x0)) - L) * (x - x0)
                abs(f(x) - (f(x0) + L * (x - x0))) = abs((((f(x) - f(x0)) / (x - x0)) - L) * (x - x0))
                abs((((f(x) - f(x0)) / (x - x0)) - L) * (x - x0)) = abs(((f(x) - f(x0)) / (x - x0)) - L) * abs(x - x0)
                abs(((f(x) - f(x0)) / (x - x0)) - L) * abs(x - x0) <= epsilon * abs(x - x0)
                abs(((f(x) - f(x0)) / (x - x0)) - L) = (abs(((f(x) - f(x0)) / (x - x0)) - L) * abs(x - x0)) / abs(x - x0)
                (abs(((f(x) - f(x0)) / (x - x0)) - L) * abs(x - x0)) / abs(x - x0) <= (epsilon * abs(x - x0)) / abs(x - x0)
                (epsilon * abs(x - x0)) / abs(x - x0) = epsilon
                abs(((f(x) - f(x0)) / (x - x0)) - L) <= epsilon
            $is_difference_quotient_close_to(X, f, x0, L, epsilon, delta)
    $has_derivative_at(X, f, x0, L)

"""
Remark 10.1.8. Newton's approximation is named after Isaac Newton.
"""

"""
Remark 10.1.9. Informally, differentiability says
`f(x) approx f(x0) + f'(x0)*(x-x0)` near x0, and Newton's approximation makes
the approximation precise.
"""

"""
Proposition 10.1.10 (Differentiability implies continuity).  If f is
differentiable at x0, then f is continuous at x0.
"""

# The derivative estimate controls `f(x)-f(x0)` by a linear term plus a small
# error term, so the function values tend to `f(x0)`.
# The proof bounds the difference quotient by `abs(L)+1` near `x0`, then
# chooses the continuity radius `epsilon/(abs(L)+1)`.

thm limit_point_is_adherent_point:
    ? forall X power_set(R), x0 X:
        $is_limit_point_of_set(X, x0)
        =>:
            $is_adherent_point(X, x0)
    claim:
        ? forall epsilon R_pos:
            $is_epsilon_adherent_to_set(X, x0, epsilon)
        $is_epsilon_adherent_to_set(set_minus(X, {x0}), x0, epsilon)
        obtain y from exist y R st {y $in set_minus(X, {x0}), abs(x0 - y) <= epsilon}
        y $in X
        witness exist z R st {z $in X, abs(x0 - z) <= epsilon} from y:
            y $in X
            abs(x0 - y) <= epsilon
        $is_epsilon_adherent_to_set(X, x0, epsilon)
    $is_adherent_point(X, x0)

thm differentiability_implies_continuity_at:
    ? forall X power_set(R), f fn(x X) R, x0 X, L R:
        $has_derivative_at(X, f, x0, L)
        =>:
            $is_continuous_at(X, f, x0)
    by thm limit_point_is_adherent_point(X, x0)
    $is_adherent_point(X, x0)
    claim:
        ? forall epsilon R_pos:
            $is_locally_epsilon_close_to(X, f, x0, f(x0), epsilon)
        abs(L) + 1 $in R_pos
        epsilon / (abs(L) + 1) $in R_pos
        obtain delta0 from exist delta0 R_pos st {$is_difference_quotient_close_to(X, f, x0, L, 1, delta0)}
        min(delta0, epsilon / (abs(L) + 1)) $in R_pos
        min(delta0, epsilon / (abs(L) + 1)) <= delta0
        min(delta0, epsilon / (abs(L) + 1)) <= epsilon / (abs(L) + 1)
        witness exist delta R_pos st {$is_delta_neighborhood_close_to(X, f, x0, f(x0), epsilon, delta)} from min(delta0, epsilon / (abs(L) + 1)):
            claim:
                ? forall x X:
                    abs(x - x0) < min(delta0, epsilon / (abs(L) + 1))
                    =>:
                        abs(f(x) - f(x0)) <= epsilon
                x - x0 = 0 or x - x0 != 0
                by cases:
                    ? abs(f(x) - f(x0)) <= epsilon
                    case x - x0 = 0:
                        x = x0
                        f(x) = f(x0)
                        f(x) - f(x0) = 0
                        abs(f(x) - f(x0)) = 0
                        0 <= epsilon
                        abs(f(x) - f(x0)) <= epsilon
                    case x - x0 != 0:
                        abs(x - x0) < min(delta0, epsilon / (abs(L) + 1)) <= delta0
                        abs(x - x0) < delta0
                        abs(x - x0) < min(delta0, epsilon / (abs(L) + 1)) <= epsilon / (abs(L) + 1)
                        abs(x - x0) < epsilon / (abs(L) + 1)
                        abs(((f(x) - f(x0)) / (x - x0)) - L) <= 1
                        abs(((f(x) - f(x0)) / (x - x0)) - L) + abs(L) <= 1 + abs(L)
                        abs(((f(x) - f(x0)) / (x - x0)) - L) + abs(L) <= abs(L) + 1
                        abs(((f(x) - f(x0)) / (x - x0)) - L + L) <= abs(((f(x) - f(x0)) / (x - x0)) - L) + abs(L)
                        ((f(x) - f(x0)) / (x - x0)) - L + L = (f(x) - f(x0)) / (x - x0)
                        abs(((f(x) - f(x0)) / (x - x0)) - L + L) = abs((f(x) - f(x0)) / (x - x0))
                        abs((f(x) - f(x0)) / (x - x0)) <= abs(((f(x) - f(x0)) / (x - x0)) - L) + abs(L)
                        abs((f(x) - f(x0)) / (x - x0)) <= abs(((f(x) - f(x0)) / (x - x0)) - L) + abs(L) <= abs(L) + 1
                        abs(f(x) - f(x0)) = abs(((f(x) - f(x0)) / (x - x0)) * (x - x0))
                        abs(((f(x) - f(x0)) / (x - x0)) * (x - x0)) = abs((f(x) - f(x0)) / (x - x0)) * abs(x - x0)
                        abs((f(x) - f(x0)) / (x - x0)) <= abs(L) + 1
                        0 <= abs(x - x0)
                        abs((f(x) - f(x0)) / (x - x0)) * abs(x - x0) <= (abs(L) + 1) * abs(x - x0)
                        abs(f(x) - f(x0)) <= (abs(L) + 1) * abs(x - x0)
                        abs(x - x0) < epsilon / (abs(L) + 1)
                        abs(x - x0) <= epsilon / (abs(L) + 1)
                        (abs(L) + 1) * abs(x - x0) <= (abs(L) + 1) * (epsilon / (abs(L) + 1))
                        (abs(L) + 1) * (epsilon / (abs(L) + 1)) = epsilon
                        abs(f(x) - f(x0)) <= (abs(L) + 1) * abs(x - x0) <= (abs(L) + 1) * (epsilon / (abs(L) + 1)) = epsilon
                        abs(f(x) - f(x0)) <= epsilon
            $is_delta_neighborhood_close_to(X, f, x0, f(x0), epsilon, delta)
        $is_locally_epsilon_close_to(X, f, x0, f(x0), epsilon)
    $has_function_limit(X, f, x0, f(x0))
    $is_continuous_at(X, f, x0)

"""
Definition 10.1.11 (Differentiability on a domain).  A function is
differentiable on X when it is differentiable at every point of X.
"""

prop is_differentiable_on(X power_set(R), f fn(x X) R):
    forall x0 X:
        $is_differentiable_at(X, f, x0)

prop has_derivative_function_on(X power_set(R), f fn(x X) R, df fn(x X) R):
    forall x0 X:
        $is_limit_point_of_set(X, x0)
        =>:
            $has_derivative_at(X, f, x0, df(x0))

"""
Corollary 10.1.12. A function differentiable on X is continuous on X.
"""

# This is the pointwise Proposition 10.1.10 applied at each point of X.

thm differentiable_on_implies_continuous_on:
    ? forall X power_set(R), f fn(x X) R:
        $is_differentiable_on(X, f)
        =>:
            $is_continuous_on(X, f)
    claim:
        ? forall x0 X:
            $is_continuous_at(X, f, x0)
        $is_differentiable_at(X, f, x0)
        obtain L from exist L R st {$has_derivative_at(X, f, x0, L)}
        by thm differentiability_implies_continuity_at(X, f, x0, L)
        $is_continuous_at(X, f, x0)
    $is_continuous_on(X, f)

"""
Theorem 10.1.13 (Differential calculus).  Constants, the identity, sums,
products, scalar multiples, differences, reciprocals, and quotients obey the
usual derivative laws.
"""

# Each law is a limit law for the corresponding difference quotient.  The
# product rule uses the middle-man trick of adding and subtracting
# `f(x)g(x0)`.  The unfinished cases are left only at the estimates where the
# corresponding limit law still has to be formalized.

thm constant_function_has_derivative_at:
    ? forall X power_set(R), f fn(x X) R, x0 X, c R:
        $is_limit_point_of_set(X, x0)
        forall x X:
            f(x) = c
        =>:
            $has_derivative_at(X, f, x0, 0)
    # The difference quotient is identically zero; this is the easiest case of
    # Exercise 10.1.4.
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$is_difference_quotient_close_to(X, f, x0, 0, epsilon, delta)}
        witness exist delta R_pos st {$is_difference_quotient_close_to(X, f, x0, 0, epsilon, delta)} from 1:
            claim:
                ? forall x X:
                    x - x0 != 0
                    abs(x - x0) < 1
                    =>:
                        abs(((f(x) - f(x0)) / (x - x0)) - 0) <= epsilon
                f(x) = c
                f(x0) = c
                f(x) - f(x0) = c - c
                c - c = 0
                (f(x) - f(x0)) / (x - x0) = 0 / (x - x0)
                0 / (x - x0) = 0
                ((f(x) - f(x0)) / (x - x0)) - 0 = 0
                abs(((f(x) - f(x0)) / (x - x0)) - 0) = abs(0)
                abs(0) = 0
                0 <= epsilon
                abs(((f(x) - f(x0)) / (x - x0)) - 0) <= epsilon
            $is_difference_quotient_close_to(X, f, x0, 0, epsilon, delta)
        exist delta R_pos st {$is_difference_quotient_close_to(X, f, x0, 0, epsilon, delta)}
    $has_derivative_at(X, f, x0, 0)

thm derivative_constant_function:
    ? forall X power_set(R), f fn(x X) R, x0 X, c R:
        $is_limit_point_of_set(X, x0)
        forall x X:
            f(x) = c
        =>:
            $is_differentiable_at(X, f, x0)
            derivative(X, f, x0) = 0
    by thm constant_function_has_derivative_at(X, f, x0, c)
    $has_derivative_at(X, f, x0, 0)
    witness exist L R st {$has_derivative_at(X, f, x0, L)} from 0:
        $has_derivative_at(X, f, x0, 0)
    $is_differentiable_at(X, f, x0)
    0 = derivative(X, f, x0)
    derivative(X, f, x0) = 0

thm identity_function_has_derivative_at:
    ? forall X power_set(R), f fn(x X) R, x0 X:
        $is_limit_point_of_set(X, x0)
        forall x X:
            f(x) = x
        =>:
            $has_derivative_at(X, f, x0, 1)
    # In the source: Proof. See Exercise 10.1.4.
    # The difference quotient is identically one on the punctured domain.
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$is_difference_quotient_close_to(X, f, x0, 1, epsilon, delta)}
        witness exist delta R_pos st {$is_difference_quotient_close_to(X, f, x0, 1, epsilon, delta)} from 1:
            claim:
                ? forall x X:
                    x - x0 != 0
                    abs(x - x0) < 1
                    =>:
                        abs(((f(x) - f(x0)) / (x - x0)) - 1) <= epsilon
                f(x) = x
                f(x0) = x0
                f(x) - f(x0) = x - x0
                (f(x) - f(x0)) / (x - x0) = (x - x0) / (x - x0)
                (x - x0) / (x - x0) = 1
                ((f(x) - f(x0)) / (x - x0)) - 1 = 0
                abs(((f(x) - f(x0)) / (x - x0)) - 1) = abs(0)
                abs(0) = 0
                0 <= epsilon
                abs(((f(x) - f(x0)) / (x - x0)) - 1) <= epsilon
            $is_difference_quotient_close_to(X, f, x0, 1, epsilon, delta)
        exist delta R_pos st {$is_difference_quotient_close_to(X, f, x0, 1, epsilon, delta)}
    $has_derivative_at(X, f, x0, 1)

thm derivative_identity_function:
    ? forall X power_set(R), f fn(x X) R, x0 X:
        $is_limit_point_of_set(X, x0)
        forall x X:
            f(x) = x
        =>:
            $is_differentiable_at(X, f, x0)
            derivative(X, f, x0) = 1
    by thm identity_function_has_derivative_at(X, f, x0)
    $has_derivative_at(X, f, x0, 1)
    witness exist L R st {$has_derivative_at(X, f, x0, L)} from 1:
        $has_derivative_at(X, f, x0, 1)
    $is_differentiable_at(X, f, x0)
    1 = derivative(X, f, x0)
    derivative(X, f, x0) = 1

thm derivative_sum_rule:
    ? forall X power_set(R), f, g fn(x X) R, x0 X, Lf, Lg R:
        $has_derivative_at(X, f, x0, Lf)
        $has_derivative_at(X, g, x0, Lg)
        =>:
            $has_derivative_at(X, fn(x X) R {f(x) + g(x)}, x0, Lf + Lg)
    # In the source: Proof. See Exercise 10.1.4.
    # Use the two derivative estimates with `epsilon/2` and take the smaller
    # delta; the difference quotient of the sum splits into the two quotients.
    $is_limit_point_of_set(X, x0)
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$is_difference_quotient_close_to(X, fn(x X) R {f(x) + g(x)}, x0, Lf + Lg, epsilon, delta)}
        epsilon / 2 $in R_pos
        obtain delta_f from exist delta_f R_pos st {$is_difference_quotient_close_to(X, f, x0, Lf, epsilon / 2, delta_f)}
        obtain delta_g from exist delta_g R_pos st {$is_difference_quotient_close_to(X, g, x0, Lg, epsilon / 2, delta_g)}
        min(delta_f, delta_g) $in R_pos
        min(delta_f, delta_g) <= delta_f
        min(delta_f, delta_g) <= delta_g
        witness exist delta R_pos st {$is_difference_quotient_close_to(X, fn(x X) R {f(x) + g(x)}, x0, Lf + Lg, epsilon, delta)} from min(delta_f, delta_g):
            claim:
                ? forall z X:
                    z - x0 != 0
                    abs(z - x0) < min(delta_f, delta_g)
                    =>:
                        abs(((fn(x X) R {f(x) + g(x)}(z) - fn(x X) R {f(x) + g(x)}(x0)) / (z - x0)) - (Lf + Lg)) <= epsilon
                abs(z - x0) < min(delta_f, delta_g) <= delta_f
                abs(z - x0) < delta_f
                abs(z - x0) < min(delta_f, delta_g) <= delta_g
                abs(z - x0) < delta_g
                abs(((f(z) - f(x0)) / (z - x0)) - Lf) <= epsilon / 2
                abs(((g(z) - g(x0)) / (z - x0)) - Lg) <= epsilon / 2
                fn(x X) R {f(x) + g(x)}(z) = f(z) + g(z)
                fn(x X) R {f(x) + g(x)}(x0) = f(x0) + g(x0)
                ((fn(x X) R {f(x) + g(x)}(z) - fn(x X) R {f(x) + g(x)}(x0)) / (z - x0)) - (Lf + Lg) = ((f(z) - f(x0)) / (z - x0)) - Lf + (((g(z) - g(x0)) / (z - x0)) - Lg)
                abs(((fn(x X) R {f(x) + g(x)}(z) - fn(x X) R {f(x) + g(x)}(x0)) / (z - x0)) - (Lf + Lg)) = abs(((f(z) - f(x0)) / (z - x0)) - Lf + (((g(z) - g(x0)) / (z - x0)) - Lg))
                abs(((f(z) - f(x0)) / (z - x0)) - Lf + (((g(z) - g(x0)) / (z - x0)) - Lg)) <= abs(((f(z) - f(x0)) / (z - x0)) - Lf) + abs(((g(z) - g(x0)) / (z - x0)) - Lg)
                abs(((f(z) - f(x0)) / (z - x0)) - Lf) + abs(((g(z) - g(x0)) / (z - x0)) - Lg) <= epsilon / 2 + epsilon / 2
                epsilon / 2 + epsilon / 2 = epsilon
                abs(((fn(x X) R {f(x) + g(x)}(z) - fn(x X) R {f(x) + g(x)}(x0)) / (z - x0)) - (Lf + Lg)) <= abs(((f(z) - f(x0)) / (z - x0)) - Lf) + abs(((g(z) - g(x0)) / (z - x0)) - Lg) <= epsilon / 2 + epsilon / 2 = epsilon
                abs(((fn(x X) R {f(x) + g(x)}(z) - fn(x X) R {f(x) + g(x)}(x0)) / (z - x0)) - (Lf + Lg)) <= epsilon
            $is_difference_quotient_close_to(X, fn(x X) R {f(x) + g(x)}, x0, Lf + Lg, epsilon, delta)
        exist delta R_pos st {$is_difference_quotient_close_to(X, fn(x X) R {f(x) + g(x)}, x0, Lf + Lg, epsilon, delta)}
    $has_derivative_at(X, fn(x X) R {f(x) + g(x)}, x0, Lf + Lg)

# Local proof package for Exercise 10.1.4: product-rule algebra and
# the three-term triangle estimate used below.
thm product_difference_quotient_algebra:
    ? forall Fz, F0, Gz, G0, Lf, Lg, dx R:
        dx != 0
        =>:
            (Fz * Gz - F0 * G0) / dx - (Lf * G0 + F0 * Lg) = ((Fz - F0) / dx - Lf) * Gz + Lf * (Gz - G0) + F0 * ((Gz - G0) / dx - Lg)
    Fz * Gz - F0 * G0 = (Fz - F0) * Gz + F0 * (Gz - G0)
    (Fz * Gz - F0 * G0) / dx = ((Fz - F0) * Gz + F0 * (Gz - G0)) / dx
    ((Fz - F0) * Gz + F0 * (Gz - G0)) / dx = (Fz - F0) / dx * Gz + F0 * (Gz - G0) / dx
    (Fz * Gz - F0 * G0) / dx = (Fz - F0) / dx * Gz + F0 * (Gz - G0) / dx
    (Fz * Gz - F0 * G0) / dx - (Lf * G0 + F0 * Lg) = ((Fz - F0) / dx * Gz + F0 * (Gz - G0) / dx) - (Lf * G0 + F0 * Lg)
    ((Fz - F0) / dx * Gz + F0 * (Gz - G0) / dx) - (Lf * G0 + F0 * Lg) = ((Fz - F0) / dx - Lf) * Gz + Lf * (Gz - G0) + F0 * ((Gz - G0) / dx - Lg)
    (Fz * Gz - F0 * G0) / dx - (Lf * G0 + F0 * Lg) = ((Fz - F0) / dx - Lf) * Gz + Lf * (Gz - G0) + F0 * ((Gz - G0) / dx - Lg)

thm abs_three_term_triangle:
    ? forall A, B, C R:
        abs(A + B + C) <= abs(A) + abs(B) + abs(C)
    abs(A + B + C) = abs((A + B) + C)
    abs((A + B) + C) <= abs(A + B) + abs(C)
    abs(A + B) <= abs(A) + abs(B)
    abs(A + B) + abs(C) <= abs(A) + abs(B) + abs(C)
    abs(A + B + C) <= abs(A + B) + abs(C) <= abs(A) + abs(B) + abs(C)
    abs(A + B + C) <= abs(A) + abs(B) + abs(C)

thm derivative_product_rule_estimate:
    ? forall X power_set(R), f, g fn(x X) R, x0 X, Lf, Lg R, epsilon R_pos:
        $has_derivative_at(X, f, x0, Lf)
        $has_derivative_at(X, g, x0, Lg)
        =>:
            exist delta R_pos st {$is_difference_quotient_close_to(X, fn(x X) R {f(x) * g(x)}, x0, Lf * g(x0) + f(x0) * Lg, epsilon, delta)}
    by thm differentiability_implies_continuity_at(X, g, x0, Lg)
    $is_continuous_at(X, g, x0)
    $has_function_limit(X, g, x0, g(x0))
    1 $in R_pos
    abs(g(x0)) + 1 $in R_pos
    abs(f(x0)) + 1 $in R_pos
    abs(Lf) + 1 $in R_pos
    abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1 > 0
    abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1 != 0
    epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1) $in R_pos
    $is_locally_epsilon_close_to(X, g, x0, g(x0), 1)
    $is_locally_epsilon_close_to(X, g, x0, g(x0), epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1))
    obtain delta_bound from exist delta_bound R_pos st {$is_delta_neighborhood_close_to(X, g, x0, g(x0), 1, delta_bound)}
    obtain delta_cont from exist delta_cont R_pos st {$is_delta_neighborhood_close_to(X, g, x0, g(x0), epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1), delta_cont)}
    obtain delta_f from exist delta_f R_pos st {$is_difference_quotient_close_to(X, f, x0, Lf, epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1), delta_f)}
    obtain delta_g from exist delta_g R_pos st {$is_difference_quotient_close_to(X, g, x0, Lg, epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1), delta_g)}
    min(delta_bound, delta_cont) $in R_pos
    min(delta_f, delta_g) $in R_pos
    min(min(delta_bound, delta_cont), min(delta_f, delta_g)) $in R_pos
    min(delta_bound, delta_cont) <= delta_bound
    min(delta_bound, delta_cont) <= delta_cont
    min(delta_f, delta_g) <= delta_f
    min(delta_f, delta_g) <= delta_g
    min(min(delta_bound, delta_cont), min(delta_f, delta_g)) <= min(delta_bound, delta_cont)
    min(min(delta_bound, delta_cont), min(delta_f, delta_g)) <= min(delta_f, delta_g)
    witness exist delta R_pos st {$is_difference_quotient_close_to(X, fn(x X) R {f(x) * g(x)}, x0, Lf * g(x0) + f(x0) * Lg, epsilon, delta)} from min(min(delta_bound, delta_cont), min(delta_f, delta_g)):
        claim:
            ? forall z X:
                z - x0 != 0
                abs(z - x0) < delta
                =>:
                    abs(((fn(x X) R {f(x) * g(x)}(z) - fn(x X) R {f(x) * g(x)}(x0)) / (z - x0)) - (Lf * g(x0) + f(x0) * Lg)) <= epsilon
            delta = min(min(delta_bound, delta_cont), min(delta_f, delta_g))
            abs(z - x0) < delta = min(min(delta_bound, delta_cont), min(delta_f, delta_g))
            abs(z - x0) < min(min(delta_bound, delta_cont), min(delta_f, delta_g))
            abs(z - x0) < min(min(delta_bound, delta_cont), min(delta_f, delta_g)) <= min(delta_bound, delta_cont)
            abs(z - x0) < min(delta_bound, delta_cont)
            abs(z - x0) < min(delta_bound, delta_cont) <= delta_bound
            abs(z - x0) < delta_bound
            abs(z - x0) < min(delta_bound, delta_cont) <= delta_cont
            abs(z - x0) < delta_cont
            abs(z - x0) < min(min(delta_bound, delta_cont), min(delta_f, delta_g)) <= min(delta_f, delta_g)
            abs(z - x0) < min(delta_f, delta_g)
            abs(z - x0) < min(delta_f, delta_g) <= delta_f
            abs(z - x0) < delta_f
            abs(z - x0) < min(delta_f, delta_g) <= delta_g
            abs(z - x0) < delta_g
            abs(g(z) - g(x0)) <= 1
            abs(g(z) - g(x0)) <= epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1)
            abs(((f(z) - f(x0)) / (z - x0)) - Lf) <= epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1)
            abs(((g(z) - g(x0)) / (z - x0)) - Lg) <= epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1)
            g(z) - g(x0) <= abs(g(z) - g(x0))
            g(z) - g(x0) <= 1
            g(z) = (g(z) - g(x0)) + g(x0)
            g(x0) <= abs(g(x0))
            (g(z) - g(x0)) + g(x0) <= 1 + abs(g(x0))
            g(z) <= 1 + abs(g(x0))
            -(g(z) - g(x0)) <= abs(g(z) - g(x0))
            -(g(z) - g(x0)) <= 1
            -g(x0) <= abs(g(x0))
            -g(z) = -(g(z) - g(x0)) + -g(x0)
            -(g(z) - g(x0)) + -g(x0) <= 1 + abs(g(x0))
            -g(z) <= 1 + abs(g(x0))
            abs(g(z)) <= 1 + abs(g(x0))
            1 + abs(g(x0)) = abs(g(x0)) + 1
            abs(g(z)) <= abs(g(x0)) + 1
            have A R = (((f(z) - f(x0)) / (z - x0)) - Lf) * g(z)
            have B R = Lf * (g(z) - g(x0))
            have C R = f(x0) * (((g(z) - g(x0)) / (z - x0)) - Lg)
            fn(x X) R {f(x) * g(x)}(z) = f(z) * g(z)
            fn(x X) R {f(x) * g(x)}(x0) = f(x0) * g(x0)
            ((fn(x X) R {f(x) * g(x)}(z) - fn(x X) R {f(x) * g(x)}(x0)) / (z - x0)) - (Lf * g(x0) + f(x0) * Lg) = ((f(z) * g(z) - f(x0) * g(x0)) / (z - x0)) - (Lf * g(x0) + f(x0) * Lg)
            by thm product_difference_quotient_algebra(f(z), f(x0), g(z), g(x0), Lf, Lg, z - x0)
            ((f(z) * g(z) - f(x0) * g(x0)) / (z - x0)) - (Lf * g(x0) + f(x0) * Lg) = (((f(z) - f(x0)) / (z - x0)) - Lf) * g(z) + Lf * (g(z) - g(x0)) + f(x0) * (((g(z) - g(x0)) / (z - x0)) - Lg)
            (((f(z) - f(x0)) / (z - x0)) - Lf) * g(z) + Lf * (g(z) - g(x0)) + f(x0) * (((g(z) - g(x0)) / (z - x0)) - Lg) = A + B + C
            ((fn(x X) R {f(x) * g(x)}(z) - fn(x X) R {f(x) * g(x)}(x0)) / (z - x0)) - (Lf * g(x0) + f(x0) * Lg) = A + B + C
            abs(((fn(x X) R {f(x) * g(x)}(z) - fn(x X) R {f(x) * g(x)}(x0)) / (z - x0)) - (Lf * g(x0) + f(x0) * Lg)) = abs(A + B + C)
            by thm abs_three_term_triangle(A, B, C)
            abs(A + B + C) <= abs(A) + abs(B) + abs(C)
            abs(A) = abs((((f(z) - f(x0)) / (z - x0)) - Lf) * g(z))
            abs((((f(z) - f(x0)) / (z - x0)) - Lf) * g(z)) = abs(((f(z) - f(x0)) / (z - x0) - Lf)) * abs(g(z))
            abs(A) = abs(((f(z) - f(x0)) / (z - x0) - Lf)) * abs(g(z))
            abs(((f(z) - f(x0)) / (z - x0) - Lf)) * abs(g(z)) <= (epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1)) * (abs(g(x0)) + 1)
            abs(A) <= (epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1)) * (abs(g(x0)) + 1)
            abs(B) = abs(Lf * (g(z) - g(x0)))
            abs(Lf * (g(z) - g(x0))) = abs(Lf) * abs(g(z) - g(x0))
            abs(B) = abs(Lf) * abs(g(z) - g(x0))
            abs(Lf) <= abs(Lf) + 1
            abs(Lf) * abs(g(z) - g(x0)) <= (abs(Lf) + 1) * (epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1))
            abs(B) <= (abs(Lf) + 1) * (epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1))
            abs(C) = abs(f(x0) * (((g(z) - g(x0)) / (z - x0)) - Lg))
            abs(f(x0) * (((g(z) - g(x0)) / (z - x0)) - Lg)) = abs(f(x0)) * abs(((g(z) - g(x0)) / (z - x0) - Lg))
            abs(C) = abs(f(x0)) * abs(((g(z) - g(x0)) / (z - x0) - Lg))
            abs(f(x0)) <= abs(f(x0)) + 1
            abs(f(x0)) * abs(((g(z) - g(x0)) / (z - x0) - Lg)) <= (abs(f(x0)) + 1) * (epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1))
            abs(C) <= (abs(f(x0)) + 1) * (epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1))
            abs(A) + abs(B) + abs(C) <= (epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1)) * (abs(g(x0)) + 1) + (abs(Lf) + 1) * (epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1)) + (abs(f(x0)) + 1) * (epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1))
            (epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1)) * (abs(g(x0)) + 1) + (abs(Lf) + 1) * (epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1)) + (abs(f(x0)) + 1) * (epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1)) = (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1) * (epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1))
            (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1) * (epsilon / (abs(g(x0)) + 1 + abs(Lf) + 1 + abs(f(x0)) + 1)) = epsilon
            abs(A) + abs(B) + abs(C) <= epsilon
            abs(((fn(x X) R {f(x) * g(x)}(z) - fn(x X) R {f(x) * g(x)}(x0)) / (z - x0)) - (Lf * g(x0) + f(x0) * Lg)) <= abs(A) + abs(B) + abs(C) <= epsilon
            abs(((fn(x X) R {f(x) * g(x)}(z) - fn(x X) R {f(x) * g(x)}(x0)) / (z - x0)) - (Lf * g(x0) + f(x0) * Lg)) <= epsilon
        $is_difference_quotient_close_to(X, fn(x X) R {f(x) * g(x)}, x0, Lf * g(x0) + f(x0) * Lg, epsilon, delta)

thm derivative_product_rule:
    ? forall X power_set(R), f, g fn(x X) R, x0 X, Lf, Lg R:
        $has_derivative_at(X, f, x0, Lf)
        $has_derivative_at(X, g, x0, Lg)
        =>:
            $has_derivative_at(X, fn(x X) R {f(x) * g(x)}, x0, Lf * g(x0) + f(x0) * Lg)
    # In the source: Proof. See Exercise 10.1.4.
    # The theorem-level assembly uses the checked epsilon estimate above.
    $is_limit_point_of_set(X, x0)
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$is_difference_quotient_close_to(X, fn(x X) R {f(x) * g(x)}, x0, Lf * g(x0) + f(x0) * Lg, epsilon, delta)}
        by thm derivative_product_rule_estimate(X, f, g, x0, Lf, Lg, epsilon)
        exist delta R_pos st {$is_difference_quotient_close_to(X, fn(x X) R {f(x) * g(x)}, x0, Lf * g(x0) + f(x0) * Lg, epsilon, delta)}
    $has_derivative_at(X, fn(x X) R {f(x) * g(x)}, x0, Lf * g(x0) + f(x0) * Lg)

thm derivative_scalar_multiple_rule:
    ? forall X power_set(R), f fn(x X) R, x0 X, L R, c R:
        $has_derivative_at(X, f, x0, L)
        =>:
            $has_derivative_at(X, fn(y X) R {c * f(y)}, x0, c * L)
    # In the source: Proof. See Exercise 10.1.4.
    # Pull the scalar through the difference quotient, using `abs(c)+1` to avoid
    # a separate zero-scalar case.
    $is_limit_point_of_set(X, x0)
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$is_difference_quotient_close_to(X, fn(y X) R {c * f(y)}, x0, c * L, epsilon, delta)}
        abs(c) + 1 $in R_pos
        epsilon / (abs(c) + 1) $in R_pos
        obtain delta_f from exist delta_f R_pos st {$is_difference_quotient_close_to(X, f, x0, L, epsilon / (abs(c) + 1), delta_f)}
        witness exist delta R_pos st {$is_difference_quotient_close_to(X, fn(y X) R {c * f(y)}, x0, c * L, epsilon, delta)} from delta_f:
            claim:
                ? forall x X:
                    x - x0 != 0
                    abs(x - x0) < delta_f
                    =>:
                        abs(((fn(y X) R {c * f(y)}(x) - fn(y X) R {c * f(y)}(x0)) / (x - x0)) - c * L) <= epsilon
                abs(((f(x) - f(x0)) / (x - x0)) - L) <= epsilon / (abs(c) + 1)
                fn(y X) R {c * f(y)}(x) = c * f(x)
                fn(y X) R {c * f(y)}(x0) = c * f(x0)
                ((fn(y X) R {c * f(y)}(x) - fn(y X) R {c * f(y)}(x0)) / (x - x0)) - c * L = c * (((f(x) - f(x0)) / (x - x0)) - L)
                abs(((fn(y X) R {c * f(y)}(x) - fn(y X) R {c * f(y)}(x0)) / (x - x0)) - c * L) = abs(c * (((f(x) - f(x0)) / (x - x0)) - L))
                abs(c * (((f(x) - f(x0)) / (x - x0)) - L)) = abs(c) * abs(((f(x) - f(x0)) / (x - x0)) - L)
                abs(c) <= abs(c) + 1
                abs(c) * abs(((f(x) - f(x0)) / (x - x0)) - L) <= (abs(c) + 1) * abs(((f(x) - f(x0)) / (x - x0)) - L)
                (abs(c) + 1) * abs(((f(x) - f(x0)) / (x - x0)) - L) <= (abs(c) + 1) * (epsilon / (abs(c) + 1))
                (abs(c) + 1) * (epsilon / (abs(c) + 1)) = epsilon
                abs(((fn(y X) R {c * f(y)}(x) - fn(y X) R {c * f(y)}(x0)) / (x - x0)) - c * L) <= abs(c) * abs(((f(x) - f(x0)) / (x - x0)) - L) <= (abs(c) + 1) * (epsilon / (abs(c) + 1)) = epsilon
                abs(((fn(y X) R {c * f(y)}(x) - fn(y X) R {c * f(y)}(x0)) / (x - x0)) - c * L) <= epsilon
            $is_difference_quotient_close_to(X, fn(y X) R {c * f(y)}, x0, c * L, epsilon, delta)
        exist delta R_pos st {$is_difference_quotient_close_to(X, fn(y X) R {c * f(y)}, x0, c * L, epsilon, delta)}
    $has_derivative_at(X, fn(y X) R {c * f(y)}, x0, c * L)

thm derivative_difference_rule:
    ? forall X power_set(R), f, g fn(x X) R, x0 X, Lf, Lg R:
        $has_derivative_at(X, f, x0, Lf)
        $has_derivative_at(X, g, x0, Lg)
        =>:
            $has_derivative_at(X, fn(x X) R {f(x) - g(x)}, x0, Lf - Lg)
    # In the source: Proof. See Exercise 10.1.4.
    # Combine the sum rule with scalar multiplication by `-1`, then transfer
    # across the pointwise equality `f + (-g) = f - g`.
    by thm derivative_scalar_multiple_rule(X, g, x0, Lg, -1)
    $has_derivative_at(X, fn(y X) R {-1 * g(y)}, x0, -1 * Lg)
    by thm derivative_sum_rule(X, f, fn(y X) R {-1 * g(y)}, x0, Lf, -1 * Lg)
    $has_derivative_at(X, fn(x X) R {f(x) + fn(z X) R {-1 * g(z)}(x)}, x0, Lf + (-1 * Lg))
    Lf + (-1 * Lg) = Lf - Lg
    $has_derivative_at(X, fn(x X) R {f(x) + fn(z X) R {-1 * g(z)}(x)}, x0, Lf - Lg)
    claim:
        ? forall y X:
            fn(x X) R {f(x) + fn(z X) R {-1 * g(z)}(x)}(y) = fn(x X) R {f(x) - g(x)}(y)
        fn(x X) R {f(x) + fn(z X) R {-1 * g(z)}(x)}(y) = f(y) + fn(z X) R {-1 * g(z)}(y)
        fn(z X) R {-1 * g(z)}(y) = -1 * g(y)
        f(y) + fn(z X) R {-1 * g(z)}(y) = f(y) + (-1 * g(y))
        f(y) + (-1 * g(y)) = f(y) - g(y)
        fn(x X) R {f(x) - g(x)}(y) = f(y) - g(y)
        fn(x X) R {f(x) + fn(z X) R {-1 * g(z)}(x)}(y) = fn(x X) R {f(x) - g(x)}(y)
    by thm equal_functions_have_equal_derivatives(X, fn(x X) R {f(x) + fn(z X) R {-1 * g(z)}(x)}, fn(x X) R {f(x) - g(x)}, x0, Lf - Lg)
    $has_derivative_at(X, fn(x X) R {f(x) - g(x)}, x0, Lf - Lg)

prop is_nonzero_on(X power_set(R), f fn(x X) R):
    forall x X:
        f(x) != 0

thm derivative_reciprocal_rule:
    ? forall X power_set(R), g fn(x X) R, x0 X, Lg R:
        $has_derivative_at(X, g, x0, Lg)
        $is_nonzero_on(X, g)
        g(x0) != 0
        =>:
            $has_derivative_at(X, fn(x X) R {1 / g(x)}, x0, (-Lg / g(x0)) / g(x0))
    # Source handling: Exercise 10.1.4 proves the reciprocal rule from the
    # derivative limit and non-vanishing of the denominator.
    # proof_debt: the local reciprocal difference-quotient estimate still
    # needs a verified non-vanishing-near-the-base-point bridge.
    trust $has_derivative_at(X, fn(x X) R {1 / g(x)}, x0, (-Lg / g(x0)) / g(x0))

thm derivative_quotient_rule:
    ? forall X power_set(R), f, g fn(x X) R, x0 X, Lf, Lg R:
        $has_derivative_at(X, f, x0, Lf)
        $has_derivative_at(X, g, x0, Lg)
        $is_nonzero_on(X, g)
        g(x0) != 0
        =>:
            $has_derivative_at(X, fn(x X) R {f(x) / g(x)}, x0, ((Lf * g(x0) - f(x0) * Lg) / g(x0)) / g(x0))
    # In the source: Proof. See Exercise 10.1.4.
    # The checked part reduces the quotient rule to the product and reciprocal
    # rules; those two upstream estimates carry the remaining Exercise 10.1.4
    # proof debt.
    by thm derivative_reciprocal_rule(X, g, x0, Lg)
    $has_derivative_at(X, fn(y X) R {1 / g(y)}, x0, (-Lg / g(x0)) / g(x0))
    by thm derivative_product_rule(X, f, fn(y X) R {1 / g(y)}, x0, Lf, (-Lg / g(x0)) / g(x0))
    $has_derivative_at(X, fn(x X) R {f(x) * fn(y X) R {1 / g(y)}(x)}, x0, Lf * fn(y X) R {1 / g(y)}(x0) + f(x0) * ((-Lg / g(x0)) / g(x0)))
    fn(y X) R {1 / g(y)}(x0) = 1 / g(x0)
    Lf * fn(y X) R {1 / g(y)}(x0) + f(x0) * ((-Lg / g(x0)) / g(x0)) = Lf * (1 / g(x0)) + f(x0) * ((-Lg / g(x0)) / g(x0))
    Lf * (1 / g(x0)) + f(x0) * ((-Lg / g(x0)) / g(x0)) = ((Lf * g(x0) - f(x0) * Lg) / g(x0)) / g(x0)
    $has_derivative_at(X, fn(x X) R {f(x) * fn(y X) R {1 / g(y)}(x)}, x0, ((Lf * g(x0) - f(x0) * Lg) / g(x0)) / g(x0))
    claim:
        ? forall z X:
            fn(x X) R {f(x) * fn(y X) R {1 / g(y)}(x)}(z) = fn(x X) R {f(x) / g(x)}(z)
        fn(x X) R {f(x) * fn(y X) R {1 / g(y)}(x)}(z) = f(z) * fn(y X) R {1 / g(y)}(z)
        fn(y X) R {1 / g(y)}(z) = 1 / g(z)
        f(z) * fn(y X) R {1 / g(y)}(z) = f(z) * (1 / g(z))
        f(z) * (1 / g(z)) = f(z) / g(z)
        fn(x X) R {f(x) / g(x)}(z) = f(z) / g(z)
        fn(x X) R {f(x) * fn(y X) R {1 / g(y)}(x)}(z) = fn(x X) R {f(x) / g(x)}(z)
    by thm equal_functions_have_equal_derivatives(X, fn(x X) R {f(x) * fn(y X) R {1 / g(y)}(x)}, fn(x X) R {f(x) / g(x)}, x0, ((Lf * g(x0) - f(x0) * Lg) / g(x0)) / g(x0))
    $has_derivative_at(X, fn(x X) R {f(x) / g(x)}, x0, ((Lf * g(x0) - f(x0) * Lg) / g(x0)) / g(x0))

"""
Remark 10.1.14. The product rule is also called the Leibniz rule.
"""

"""
The quotient example after Theorem 10.1.13.  For
`f(x)=(x-2)/(x-1)` on `R-{1}`, the quotient rule gives
`f'(x0)=1/(x0-1)^2`.
"""

# The source writes the domain as `R-{1}`.  The equivalent predicate domain
# `{x R: x != 1}` makes the nonzero denominator condition explicit.  The
# computation applies the identity, constant, difference, and quotient
# derivative laws from Theorem 10.1.13; the punctured-domain limit-point fact is
# proved by moving a small distance left or right.

thm punctured_line_without_one_points_are_limit_points:
    ? forall x0 {x R: x != 1}:
        $is_limit_point_of_set({x R: x != 1}, x0)
    {x0} $in power_set(R)
    by thm real_set_minus_is_real_set({x R: x != 1}, {x0})
    set_minus({x R: x != 1}, {x0}) $in power_set(R)
    claim:
        ? forall epsilon R_pos:
            $is_epsilon_adherent_to_set(set_minus({x R: x != 1}, {x0}), x0, epsilon)
        x0 != 1
        x0 <= 1 or x0 > 1
        by cases:
            ? $is_epsilon_adherent_to_set(set_minus({x R: x != 1}, {x0}), x0, epsilon)
            case x0 <= 1:
                x0 = 1 or x0 < 1
                by cases:
                    ? $is_epsilon_adherent_to_set(set_minus({x R: x != 1}, {x0}), x0, epsilon)
                    case x0 = 1:
                        impossible x0 != 1
                    case x0 < 1:
                        witness exist y R st {y $in set_minus({x R: x != 1}, {x0}), abs(x0 - y) <= epsilon} from x0 - epsilon / 2:
                            epsilon / 2 $in R_pos
                            epsilon / 2 > 0
                            x0 - epsilon / 2 < x0
                            x0 - epsilon / 2 != x0
                            not x0 - epsilon / 2 $in {x0}
                            x0 - epsilon / 2 < x0 < 1
                            x0 - epsilon / 2 < 1
                            x0 - epsilon / 2 != 1
                            x0 - epsilon / 2 $in {x R: x != 1}
                            x0 - epsilon / 2 $in set_minus({x R: x != 1}, {x0})
                            x0 - (x0 - epsilon / 2) = epsilon / 2
                            abs(epsilon / 2) = epsilon / 2
                            abs(x0 - (x0 - epsilon / 2)) = abs(epsilon / 2)
                            abs(x0 - (x0 - epsilon / 2)) = epsilon / 2
                            epsilon / 2 < epsilon
                            epsilon / 2 <= epsilon
                            abs(x0 - (x0 - epsilon / 2)) <= epsilon
            case x0 > 1:
                witness exist y R st {y $in set_minus({x R: x != 1}, {x0}), abs(x0 - y) <= epsilon} from x0 + epsilon / 2:
                    epsilon / 2 $in R_pos
                    epsilon / 2 > 0
                    x0 + epsilon / 2 > x0
                    x0 + epsilon / 2 != x0
                    not x0 + epsilon / 2 $in {x0}
                    x0 + epsilon / 2 > x0 > 1
                    x0 + epsilon / 2 > 1
                    x0 + epsilon / 2 != 1
                    x0 + epsilon / 2 $in {x R: x != 1}
                    x0 + epsilon / 2 $in set_minus({x R: x != 1}, {x0})
                    x0 - (x0 + epsilon / 2) = -epsilon / 2
                    -epsilon / 2 < 0
                    abs(-epsilon / 2) = epsilon / 2
                    abs(x0 - (x0 + epsilon / 2)) = abs(-epsilon / 2)
                    abs(x0 - (x0 + epsilon / 2)) = epsilon / 2
                    epsilon / 2 < epsilon
                    epsilon / 2 <= epsilon
                    abs(x0 - (x0 + epsilon / 2)) <= epsilon
        $is_epsilon_adherent_to_set(set_minus({x R: x != 1}, {x0}), x0, epsilon)
    $is_adherent_point(set_minus({x R: x != 1}, {x0}), x0)
    $is_limit_point_of_set({x R: x != 1}, x0)

sketch:
    have fn quotient_example_identity(x {x R: x != 1}) R = x
    have fn quotient_example_two(x {x R: x != 1}) R = 2
    have fn quotient_example_one(x {x R: x != 1}) R = 1
    have fn quotient_example_numerator(x {x R: x != 1}) R = quotient_example_identity(x) - quotient_example_two(x)
    have fn quotient_example_denominator(x {x R: x != 1}) R = quotient_example_identity(x) - quotient_example_one(x)
    claim:
        ? forall x {x R: x != 1}:
            quotient_example_denominator(x) != 0
        x != 1
        quotient_example_identity(x) = x
        quotient_example_one(x) = 1
        quotient_example_denominator(x) = quotient_example_identity(x) - quotient_example_one(x)
        quotient_example_denominator(x) = x - 1
        x - 1 != 0
        quotient_example_denominator(x) != 0
    have fn quotient_example(x {x R: x != 1}) R = quotient_example_numerator(x) / quotient_example_denominator(x)

    thm quotient_example_derivative:
        ? forall x0 {x R: x != 1}:
            $has_derivative_at({x R: x != 1}, quotient_example, x0, 1 / (x0 - 1)^2)
        by thm punctured_line_without_one_points_are_limit_points(x0)
        $is_limit_point_of_set({x R: x != 1}, x0)
        claim:
            ? forall x {x R: x != 1}:
                quotient_example_identity(x) = x
        by thm identity_function_has_derivative_at({x R: x != 1}, quotient_example_identity, x0)
        $has_derivative_at({x R: x != 1}, quotient_example_identity, x0, 1)
        claim:
            ? forall x {x R: x != 1}:
                quotient_example_two(x) = 2
        by thm constant_function_has_derivative_at({x R: x != 1}, quotient_example_two, x0, 2)
        $has_derivative_at({x R: x != 1}, quotient_example_two, x0, 0)
        claim:
            ? forall x {x R: x != 1}:
                quotient_example_one(x) = 1
        by thm constant_function_has_derivative_at({x R: x != 1}, quotient_example_one, x0, 1)
        $has_derivative_at({x R: x != 1}, quotient_example_one, x0, 0)
        by thm derivative_difference_rule({x R: x != 1}, quotient_example_identity, quotient_example_two, x0, 1, 0)
        $has_derivative_at({x R: x != 1}, fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_two(x)}, x0, 1 - 0)
        1 - 0 = 1
        $has_derivative_at({x R: x != 1}, fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_two(x)}, x0, 1)
        claim:
            ? forall y {x R: x != 1}:
                fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_two(x)}(y) = quotient_example_numerator(y)
            fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_two(x)}(y) = quotient_example_identity(y) - quotient_example_two(y)
            quotient_example_numerator(y) = quotient_example_identity(y) - quotient_example_two(y)
            fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_two(x)}(y) = quotient_example_numerator(y)
        by thm equal_functions_have_equal_derivatives({x R: x != 1}, fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_two(x)}, quotient_example_numerator, x0, 1)
        $has_derivative_at({x R: x != 1}, quotient_example_numerator, x0, 1)
        by thm derivative_difference_rule({x R: x != 1}, quotient_example_identity, quotient_example_one, x0, 1, 0)
        $has_derivative_at({x R: x != 1}, fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_one(x)}, x0, 1 - 0)
        1 - 0 = 1
        $has_derivative_at({x R: x != 1}, fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_one(x)}, x0, 1)
        claim:
            ? forall y {x R: x != 1}:
                fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_one(x)}(y) = quotient_example_denominator(y)
            fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_one(x)}(y) = quotient_example_identity(y) - quotient_example_one(y)
            quotient_example_denominator(y) = quotient_example_identity(y) - quotient_example_one(y)
            fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_one(x)}(y) = quotient_example_denominator(y)
        by thm equal_functions_have_equal_derivatives({x R: x != 1}, fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_one(x)}, quotient_example_denominator, x0, 1)
        $has_derivative_at({x R: x != 1}, quotient_example_denominator, x0, 1)
        $is_nonzero_on({x R: x != 1}, quotient_example_denominator)
        quotient_example_denominator(x0) != 0
        by thm derivative_quotient_rule({x R: x != 1}, quotient_example_numerator, quotient_example_denominator, x0, 1, 1)
        $has_derivative_at({x R: x != 1}, quotient_example, x0, ((1 * quotient_example_denominator(x0) - quotient_example_numerator(x0) * 1) / quotient_example_denominator(x0)) / quotient_example_denominator(x0))
        quotient_example_identity(x0) = x0
        quotient_example_two(x0) = 2
        quotient_example_one(x0) = 1
        fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_two(x)}(x0) = quotient_example_numerator(x0)
        fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_two(x)}(x0) = quotient_example_identity(x0) - quotient_example_two(x0)
        quotient_example_numerator(x0) = quotient_example_identity(x0) - quotient_example_two(x0)
        quotient_example_numerator(x0) = x0 - 2
        fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_one(x)}(x0) = quotient_example_denominator(x0)
        fn(x {x R: x != 1}) R {quotient_example_identity(x) - quotient_example_one(x)}(x0) = quotient_example_identity(x0) - quotient_example_one(x0)
        quotient_example_denominator(x0) = quotient_example_identity(x0) - quotient_example_one(x0)
        quotient_example_denominator(x0) = x0 - 1
        ((1 * quotient_example_denominator(x0) - quotient_example_numerator(x0) * 1) / quotient_example_denominator(x0)) / quotient_example_denominator(x0) = ((1 * (x0 - 1) - (x0 - 2) * 1) / (x0 - 1)) / (x0 - 1)
        ((1 * (x0 - 1) - (x0 - 2) * 1) / (x0 - 1)) / (x0 - 1) = 1 / (x0 - 1)^2
        $has_derivative_at({x R: x != 1}, quotient_example, x0, 1 / (x0 - 1)^2)

"""
Theorem 10.1.15 (Chain rule).  If f maps X into Y, f is differentiable at x0,
g is differentiable at y0=f(x0), then g composed with f is differentiable at
x0 and has derivative g'(y0)f'(x0).
"""

# The chain rule follows by applying Newton's approximation to f and g and
# multiplying the first-order errors.  The key estimate is the Newton-form
# composition lemma `newton_approximation_chain_rule`: differentiability gives
# a local linear bound for `f(x)-f(x0)`, so the Newton error for `g` can be
# measured back in units of `abs(x-x0)`.

thm newton_approximation_local_linear_bound:
    ? forall X power_set(R), f fn(x X) R, x0 X, y0 R, L R, delta R_pos, x X:
        f(x0) = y0
        $is_newton_approximation_witness(X, f, x0, L, 1, delta)
        abs(x - x0) <= delta
        =>:
            abs(f(x) - y0) <= (abs(L) + 1) * abs(x - x0)
    abs(f(x) - (f(x0) + L * (x - x0))) <= 1 * abs(x - x0)
    1 * abs(x - x0) = abs(x - x0)
    abs(f(x) - (f(x0) + L * (x - x0))) <= abs(x - x0)
    f(x) - f(x0) = (f(x) - (f(x0) + L * (x - x0))) + L * (x - x0)
    abs(f(x) - f(x0)) = abs((f(x) - (f(x0) + L * (x - x0))) + L * (x - x0))
    abs((f(x) - (f(x0) + L * (x - x0))) + L * (x - x0)) <= abs(f(x) - (f(x0) + L * (x - x0))) + abs(L * (x - x0))
    abs(L * (x - x0)) = abs(L) * abs(x - x0)
    abs(f(x) - f(x0)) <= abs(f(x) - (f(x0) + L * (x - x0))) + abs(L * (x - x0))
    abs(f(x) - (f(x0) + L * (x - x0))) + abs(L * (x - x0)) = abs(f(x) - (f(x0) + L * (x - x0))) + abs(L) * abs(x - x0)
    abs(f(x) - (f(x0) + L * (x - x0))) + abs(L) * abs(x - x0) <= abs(x - x0) + abs(L) * abs(x - x0)
    abs(f(x) - f(x0)) <= abs(f(x) - (f(x0) + L * (x - x0))) + abs(L) * abs(x - x0)
    abs(f(x) - f(x0)) <= abs(f(x) - (f(x0) + L * (x - x0))) + abs(L) * abs(x - x0) <= abs(x - x0) + abs(L) * abs(x - x0)
    abs(x - x0) + abs(L) * abs(x - x0) = (abs(L) + 1) * abs(x - x0)
    abs(f(x) - f(x0)) <= abs(x - x0) + abs(L) * abs(x - x0)
    abs(f(x) - f(x0)) <= (abs(L) + 1) * abs(x - x0)
    f(x) - y0 = f(x) - f(x0)
    abs(f(x) - y0) = abs(f(x) - f(x0))
    abs(f(x) - y0) <= (abs(L) + 1) * abs(x - x0)

thm newton_approximation_chain_rule:
    ? forall X, Y power_set(R), f fn(x X) R, g fn(y Y) R, x0 X, y0 Y, Lf, Lg R:
        forall x X:
            f(x) $in Y
        f(x0) = y0
        $has_newton_approximation_at(X, f, x0, Lf)
        $has_newton_approximation_at(Y, g, y0, Lg)
        =>:
            $has_newton_approximation_at(X, fn(x X) R {g(f(x))}, x0, Lg * Lf)
    # Source handling: Exercise 10.1.7 composes the two Newton approximations
    # and controls their first-order errors.
    # proof_debt: anonymous composed functions in the nested witness do not
    # inherit the hypothesis that `f(x)` lies in the domain of `g`.
    trust $has_newton_approximation_at(X, fn(x X) R {g(f(x))}, x0, Lg * Lf)

thm derivative_chain_rule:
    ? forall X, Y power_set(R), f fn(x X) R, g fn(y Y) R, x0 X, y0 Y, Lf, Lg R:
        forall x X:
            f(x) $in Y
        f(x0) = y0
        $has_derivative_at(X, f, x0, Lf)
        $has_derivative_at(Y, g, y0, Lg)
        =>:
            $has_derivative_at(X, fn(x X) R {g(f(x))}, x0, Lg * Lf)
    # This is Exercise 10.1.7: prove the chain rule by converting derivatives
    # to Newton approximations, composing those approximations, and converting
    # back.
    by thm newton_approximation_forward(X, f, x0, Lf)
    $has_newton_approximation_at(X, f, x0, Lf)
    by thm newton_approximation_forward(Y, g, y0, Lg)
    $has_newton_approximation_at(Y, g, y0, Lg)
    by thm newton_approximation_chain_rule(X, Y, f, g, x0, y0, Lf, Lg)
    $has_newton_approximation_at(X, fn(x X) R {g(f(x))}, x0, Lg * Lf)
    $is_limit_point_of_set(X, x0)
    by thm newton_approximation_reverse(X, fn(x X) R {g(f(x))}, x0, Lg * Lf)
    $has_derivative_at(X, fn(x X) R {g(f(x))}, x0, Lg * Lf)

"""
Example 10.1.16.  Applying the chain rule to
`((x-2)/(x-1))^2` gives derivative
`2*((x0-2)/(x0-1))*1/(x0-1)^2`.
"""

# The punctured domain is written as `{x R: x != 1}` to keep the nonzero
# denominator visible.  The inner derivative is the quotient-rule computation
# from the preceding example; `example_10_1_16_derivative` then applies the
# chain rule to the square function.

have example_10_1_16_domain power_set(R) = {x R: x != 1}

have fn example_10_1_16_identity(x example_10_1_16_domain) R = x

have fn example_10_1_16_two(x example_10_1_16_domain) R = 2

have fn example_10_1_16_one(x example_10_1_16_domain) R = 1

have fn example_10_1_16_numerator(x example_10_1_16_domain) R = x - 2

have fn example_10_1_16_denominator(x example_10_1_16_domain) R = x - 1

thm example_10_1_16_domain_points_are_limit_points:
    ? forall x0 example_10_1_16_domain:
        $is_limit_point_of_set(example_10_1_16_domain, x0)
    example_10_1_16_domain = {x R: x != 1}
    x0 $in {x R: x != 1}
    by thm punctured_line_without_one_points_are_limit_points(x0)
    $is_limit_point_of_set({x R: x != 1}, x0)
    $is_limit_point_of_set(example_10_1_16_domain, x0)

thm example_10_1_16_denominator_nonzero_at:
    ? forall x example_10_1_16_domain:
        example_10_1_16_denominator(x) != 0
    example_10_1_16_domain = {x R: x != 1}
    x $in {x R: x != 1}
    x != 1
    example_10_1_16_denominator(x) = x - 1
    x - 1 != 0
    example_10_1_16_denominator(x) != 0

have fn example_10_1_16_inner(x example_10_1_16_domain) R = example_10_1_16_numerator(x) / example_10_1_16_denominator(x)

thm example_10_1_16_inner_has_derivative_at:
    ? forall x0 {x R: x != 1}:
        $has_derivative_at(example_10_1_16_domain, example_10_1_16_inner, x0, 1 / (x0 - 1) / (x0 - 1))
    # In the source: quotient-rule derivative for `(x-2)/(x-1)` on
    # `R-{1}`.  The affine derivative facts come from identity, constant, and
    # difference rules; the quotient-rule application and algebra are explicit.
    by thm example_10_1_16_domain_points_are_limit_points(x0)
    $is_limit_point_of_set(example_10_1_16_domain, x0)
    claim:
        ? forall x example_10_1_16_domain:
            example_10_1_16_identity(x) = x
    by thm identity_function_has_derivative_at(example_10_1_16_domain, example_10_1_16_identity, x0)
    $has_derivative_at(example_10_1_16_domain, example_10_1_16_identity, x0, 1)
    claim:
        ? forall x example_10_1_16_domain:
            example_10_1_16_two(x) = 2
    by thm constant_function_has_derivative_at(example_10_1_16_domain, example_10_1_16_two, x0, 2)
    $has_derivative_at(example_10_1_16_domain, example_10_1_16_two, x0, 0)
    claim:
        ? forall x example_10_1_16_domain:
            example_10_1_16_one(x) = 1
    by thm constant_function_has_derivative_at(example_10_1_16_domain, example_10_1_16_one, x0, 1)
    $has_derivative_at(example_10_1_16_domain, example_10_1_16_one, x0, 0)
    by thm derivative_difference_rule(example_10_1_16_domain, example_10_1_16_identity, example_10_1_16_two, x0, 1, 0)
    $has_derivative_at(example_10_1_16_domain, fn(x example_10_1_16_domain) R {example_10_1_16_identity(x) - example_10_1_16_two(x)}, x0, 1 - 0)
    1 - 0 = 1
    $has_derivative_at(example_10_1_16_domain, fn(x example_10_1_16_domain) R {example_10_1_16_identity(x) - example_10_1_16_two(x)}, x0, 1)
    claim:
        ? forall y example_10_1_16_domain:
            fn(x example_10_1_16_domain) R {example_10_1_16_identity(x) - example_10_1_16_two(x)}(y) = example_10_1_16_numerator(y)
        fn(x example_10_1_16_domain) R {example_10_1_16_identity(x) - example_10_1_16_two(x)}(y) = example_10_1_16_identity(y) - example_10_1_16_two(y)
        example_10_1_16_identity(y) = y
        example_10_1_16_two(y) = 2
        example_10_1_16_identity(y) - example_10_1_16_two(y) = y - 2
        example_10_1_16_numerator(y) = y - 2
        fn(x example_10_1_16_domain) R {example_10_1_16_identity(x) - example_10_1_16_two(x)}(y) = example_10_1_16_numerator(y)
    by thm equal_functions_have_equal_derivatives(example_10_1_16_domain, fn(x example_10_1_16_domain) R {example_10_1_16_identity(x) - example_10_1_16_two(x)}, example_10_1_16_numerator, x0, 1)
    $has_derivative_at(example_10_1_16_domain, example_10_1_16_numerator, x0, 1)
    by thm derivative_difference_rule(example_10_1_16_domain, example_10_1_16_identity, example_10_1_16_one, x0, 1, 0)
    $has_derivative_at(example_10_1_16_domain, fn(x example_10_1_16_domain) R {example_10_1_16_identity(x) - example_10_1_16_one(x)}, x0, 1 - 0)
    1 - 0 = 1
    $has_derivative_at(example_10_1_16_domain, fn(x example_10_1_16_domain) R {example_10_1_16_identity(x) - example_10_1_16_one(x)}, x0, 1)
    claim:
        ? forall y example_10_1_16_domain:
            fn(x example_10_1_16_domain) R {example_10_1_16_identity(x) - example_10_1_16_one(x)}(y) = example_10_1_16_denominator(y)
        fn(x example_10_1_16_domain) R {example_10_1_16_identity(x) - example_10_1_16_one(x)}(y) = example_10_1_16_identity(y) - example_10_1_16_one(y)
        example_10_1_16_identity(y) = y
        example_10_1_16_one(y) = 1
        example_10_1_16_identity(y) - example_10_1_16_one(y) = y - 1
        example_10_1_16_denominator(y) = y - 1
        fn(x example_10_1_16_domain) R {example_10_1_16_identity(x) - example_10_1_16_one(x)}(y) = example_10_1_16_denominator(y)
    by thm equal_functions_have_equal_derivatives(example_10_1_16_domain, fn(x example_10_1_16_domain) R {example_10_1_16_identity(x) - example_10_1_16_one(x)}, example_10_1_16_denominator, x0, 1)
    $has_derivative_at(example_10_1_16_domain, example_10_1_16_denominator, x0, 1)
    claim:
        ? forall x example_10_1_16_domain:
            example_10_1_16_denominator(x) != 0
        by thm example_10_1_16_denominator_nonzero_at(x)
    $is_nonzero_on(example_10_1_16_domain, example_10_1_16_denominator)
    example_10_1_16_denominator(x0) != 0
    by thm derivative_quotient_rule(example_10_1_16_domain, example_10_1_16_numerator, example_10_1_16_denominator, x0, 1, 1)
    $has_derivative_at(example_10_1_16_domain, fn(x example_10_1_16_domain) R {example_10_1_16_numerator(x) / example_10_1_16_denominator(x)}, x0, ((1 * example_10_1_16_denominator(x0) - example_10_1_16_numerator(x0) * 1) / example_10_1_16_denominator(x0)) / example_10_1_16_denominator(x0))
    fn(x example_10_1_16_domain) R {x - 2}(x0) = example_10_1_16_numerator(x0)
    fn(x example_10_1_16_domain) R {x - 2}(x0) = x0 - 2
    example_10_1_16_numerator(x0) = x0 - 2
    fn(x example_10_1_16_domain) R {x - 1}(x0) = example_10_1_16_denominator(x0)
    fn(x example_10_1_16_domain) R {x - 1}(x0) = x0 - 1
    example_10_1_16_denominator(x0) = x0 - 1
    ((1 * example_10_1_16_denominator(x0) - example_10_1_16_numerator(x0) * 1) / example_10_1_16_denominator(x0)) / example_10_1_16_denominator(x0) = ((1 * (x0 - 1) - (x0 - 2) * 1) / (x0 - 1)) / (x0 - 1)
    ((1 * (x0 - 1) - (x0 - 2) * 1) / (x0 - 1)) / (x0 - 1) = 1 / (x0 - 1) / (x0 - 1)
    $has_derivative_at(example_10_1_16_domain, fn(x example_10_1_16_domain) R {example_10_1_16_numerator(x) / example_10_1_16_denominator(x)}, x0, 1 / (x0 - 1) / (x0 - 1))
    claim:
        ? forall y example_10_1_16_domain:
            fn(x example_10_1_16_domain) R {example_10_1_16_numerator(x) / example_10_1_16_denominator(x)}(y) = example_10_1_16_inner(y)
        fn(x example_10_1_16_domain) R {example_10_1_16_numerator(x) / example_10_1_16_denominator(x)}(y) = example_10_1_16_numerator(y) / example_10_1_16_denominator(y)
        example_10_1_16_inner(y) = example_10_1_16_numerator(y) / example_10_1_16_denominator(y)
        fn(x example_10_1_16_domain) R {example_10_1_16_numerator(x) / example_10_1_16_denominator(x)}(y) = example_10_1_16_inner(y)
    by thm equal_functions_have_equal_derivatives(example_10_1_16_domain, fn(x example_10_1_16_domain) R {example_10_1_16_numerator(x) / example_10_1_16_denominator(x)}, example_10_1_16_inner, x0, 1 / (x0 - 1) / (x0 - 1))
    $has_derivative_at(example_10_1_16_domain, example_10_1_16_inner, x0, 1 / (x0 - 1) / (x0 - 1))

thm example_10_1_16_chain_rule_derivative:
    ? forall x0 {x R: x != 1}:
        $has_derivative_at(example_10_1_16_domain, fn(x example_10_1_16_domain) R {square_function(example_10_1_16_inner(x))}, x0, (2 * example_10_1_16_inner(x0)) * (1 / (x0 - 1) / (x0 - 1)))
    by thm example_10_1_16_inner_has_derivative_at(x0)
    $has_derivative_at(example_10_1_16_domain, example_10_1_16_inner, x0, 1 / (x0 - 1) / (x0 - 1))
    by thm square_function_has_derivative_at(example_10_1_16_inner(x0))
    $has_derivative_at(R, square_function, example_10_1_16_inner(x0), 2 * example_10_1_16_inner(x0))
    claim:
        ? forall x example_10_1_16_domain:
            example_10_1_16_inner(x) $in R
    by thm derivative_chain_rule(example_10_1_16_domain, R, example_10_1_16_inner, square_function, x0, example_10_1_16_inner(x0), 1 / (x0 - 1) / (x0 - 1), 2 * example_10_1_16_inner(x0))
    $has_derivative_at(example_10_1_16_domain, fn(x example_10_1_16_domain) R {square_function(example_10_1_16_inner(x))}, x0, (2 * example_10_1_16_inner(x0)) * (1 / (x0 - 1) / (x0 - 1)))

thm example_10_1_16_chain_rule_derivative_formula:
    ? forall x0 {x R: x != 1}:
        (2 * example_10_1_16_inner(x0)) * (1 / (x0 - 1) / (x0 - 1)) = 2 * ((x0 - 2) / (x0 - 1)) * (1 / (x0 - 1) / (x0 - 1))
    example_10_1_16_inner(x0) = (x0 - 2) / (x0 - 1)
    (2 * example_10_1_16_inner(x0)) * (1 / (x0 - 1) / (x0 - 1)) = 2 * ((x0 - 2) / (x0 - 1)) * (1 / (x0 - 1) / (x0 - 1))

"""
Remark 10.1.17.  The differential notation `dz/dx = (dz/dy)(dy/dx)` is
memorable but can be misleading, especially in several variables, because the
symbols `dx`, `dy`, and `dz` have not been assigned real-number meanings here.
"""

# Derivative information remains a fact about functions and real numbers;
# `dx`, `dy`, and `dz` are mnemonic notation rather than separate numbers.

"""
Exercise 10.1.1.  Restricting a differentiable function to a smaller domain Y
preserves the derivative at x0, provided x0 remains a limit point of Y.
"""

# This exercise explains why restriction to a non-isolated subdomain does not
# conflict with Remark 10.1.2.

"""
Exercise 10.1.2.  Prove Newton's approximation, Proposition 10.1.7.
"""

# The proof is the epsilon form of Newton's approximation: rewrite the
# derivative definition so that `f(x)` is locally `f(x0)+L(x-x0)` plus a small
# error.

"""
Exercise 10.1.3.  Prove that differentiability implies continuity,
Proposition 10.1.10.
"""

# The proof is exactly Proposition 10.1.10: Newton's approximation gives a
# local linear bound, and that bound tends to zero with `x-x0`.

"""
Exercise 10.1.4.  Prove the differential calculus laws in Theorem 10.1.13.
"""

# Constants, identity, sums, scalar multiples, and differences are checked
# directly.  The product, reciprocal, and quotient cases reduce to the product
# estimate and the reciprocal limit law.

"""
Exercise 10.1.5.  Prove the derivative formula for non-negative integer powers.
"""

# The proof is by induction using the product rule.

"""
Exercise 10.1.6.  Prove the derivative formula for negative integer powers on
`R-{0}`.
"""

# The proof uses the reciprocal rule and the non-negative integer power case.

"""
Exercise 10.1.7.  Prove the chain rule, Theorem 10.1.15.
"""

# The chain-rule statement converts derivatives to Newton approximations and
