# Chapter 7: Series.

trust local import chap3
trust local import chap5
trust local import chap6

# 7.1 Finite series

"""
Definition 7.1.1 (Finite series). A finite sum over an integer interval is
defined recursively: an empty interval has sum 0, and extending the upper
endpoint adds the next term.
"""

# The notation `sum(m, n, f)` means a finite sum over the closed integer
# interval [m, n], so it is used when `m <= n`.  Tao's empty-sum case is
# represented either by the scalar `0` directly or by a recursive finite-series
# function whose length is `0`.

# Tao's recursive finite series can be modeled directly by induction on the
# length of the interval.  The sketch below shows that recursive object; later
# theorems use `sum(m, n, f)` for the ordinary nonempty finite interval.

sketch:
    have a fn(i Z) R
    have m Z

    have fn recursive_finite_series(a fn(i Z) R, m Z, length N) R by induc length from 0:
        case length = 0: 0
        case length > 0: recursive_finite_series(a, m, length - 1) + a(m + length - 1)

    recursive_finite_series(a, m, 0) = 0

    recursive_finite_series(a, m, 1) = recursive_finite_series(a, m, 0) + a(m + 1 - 1)
    m + 1 - 1 = m
    a(m + 1 - 1) = a(m)
    recursive_finite_series(a, m, 1) = 0 + a(m)
    0 + a(m) = a(m)

    recursive_finite_series(a, m, 2) = recursive_finite_series(a, m, 1) + a(m + 2 - 1)
    m + 2 - 1 = m + 1
    a(m + 2 - 1) = a(m + 1)
    recursive_finite_series(a, m, 2) = a(m) + a(m + 1)

thm finite_series_basic_cases:
    ? forall a fn(i Z) R, m Z:
        sum(m, m, fn(i Z) R {a(i)}) = a(m)
        sum(m, m + 1, fn(i Z) R {a(i)}) = a(m) + a(m + 1)
    sum(m, m, fn(i Z) R {a(i)}) = a(m)
    sum(m, m + 1, fn(i Z) R {a(i)}) = sum(m, m, fn(i Z) R {a(i)}) + fn(i Z) R {a(i)}(m + 1)
    fn(i Z) R {a(i)}(m + 1) = a(m + 1)
    sum(m, m + 1, fn(i Z) R {a(i)}) = a(m) + a(m + 1)

"""
Remark 7.1.2. The word "series" names the expression, while "sum" names its
value.  The distinction is linguistic; mathematically the value is the real
number produced by the finite-sum expression.
"""

"""
Remark 7.1.3. The summation index is a bound variable; renaming it does not
change the finite sum.
"""

thm finite_series_dummy_index:
    ? forall a fn(i Z) R, m, n Z:
        m <= n
        =>:
            sum(m, n, fn(i Z) R {a(i)}) = sum(m, n, fn(j Z) R {a(j)})

"""
Lemma 7.1.4. Finite sums split across adjacent intervals, shift indices,
respect addition and scalar multiplication, satisfy the triangle inequality,
and are monotone under pointwise comparison.
"""

# These are the standard finite-sum induction facts used throughout the series
# chapter: splitting intervals, shifting indices, distributing over addition
# and scalar multiplication, triangle inequality, and comparison.  Tao leaves
# the proof to Exercise 7.1.1, so the rules are stated here for later use.

thm finite_series_split_range:
    ? forall a fn(i Z) R, m, n, p Z:
        m <= n
        n < p
        m <= p
        =>:
            sum(m, n, fn(i Z) R {a(i)}) + sum(n + 1, p, fn(i Z) R {a(i)}) = sum(m, p, fn(i Z) R {a(i)})

thm finite_series_shift_index:
    ? forall a fn(i Z) R, m, n, k Z:
        m <= n
        =>:
            sum(m, n, fn(i Z) R {a(i)}) = sum(m + k, n + k, fn(j Z) R {a(j - k)})

thm finite_series_add:
    ? forall a, b fn(i Z) R, m, n Z:
        m <= n
        =>:
            sum(m, n, fn(i Z) R {a(i) + b(i)}) = sum(m, n, fn(i Z) R {a(i)}) + sum(m, n, fn(i Z) R {b(i)})

thm finite_series_scalar_mul:
    ? forall a fn(i Z) R, c R, m, n Z:
        m <= n
        =>:
            sum(m, n, fn(i Z) R {c * a(i)}) = c * sum(m, n, fn(i Z) R {a(i)})

thm finite_series_triangle:
    ? forall a fn(i Z) R, m, n Z:
        m <= n
        =>:
            abs(sum(m, n, fn(i Z) R {a(i)})) <= sum(m, n, fn(i Z) R {abs(a(i))})

thm finite_series_comparison:
    ? forall a, b fn(i Z) R, m, n Z:
        m <= n
        forall i Z:
            m <= i <= n
            =>:
                a(i) <= b(i)
        =>:
            sum(m, n, fn(i Z) R {a(i)}) <= sum(m, n, fn(i Z) R {b(i)})

"""
Remark 7.1.5. Parentheses around summands are often omitted when the dummy
index makes the intended grouping unambiguous.
"""

"""
Definition 7.1.6 (Summations over finite sets). A finite-set sum is first
described by choosing a bijective enumeration of the finite set, then summing
the values along the index range.
"""

# Tao's construction chooses a bijection from `1...count(X)` onto `X`.  The
# predicate below says exactly that every element of `X` appears at a unique
# index in the closed range.

prop is_bijection_from_index_range_to_finite_set(X finite_set, g fn(i closed_range(1, count(X))) X):
    forall x X:
        exist! i closed_range(1, count(X)) st {g(i) = x}

# Tao's construction also needs existence of at least one such enumeration.
# The proof follows the source idea: induct on the size of the nonempty finite
# set, remove one element, enumerate the smaller set, and append the removed
# element at the last index.

prop finite_set_size_has_index(n N_pos):
    forall s finite_set:
        $is_finite_set(s)
        count(s) = n
        =>:
            exist idx fn(i closed_range(1, count(s))) s st {$is_bijection_from_index_range_to_finite_set(s, idx)}

thm nonempty_from_positive_count:
    ? forall s finite_set:
        count(s) >= 1
        =>:
            $is_nonempty_set(s)
    by contra:
        ? $is_nonempty_set(s)
        s = {}
        count(s) = count({}) = 0
        impossible count(s) >= 1

thm intersect_with_singleton:
    ? forall s set, a set:
        a $in s
        =>:
            intersect(s, {a}) = {a}
    by extension intersect(s, {a}) = {a}:
        forall z intersect(s, {a}):
            z $in s
            z $in {a}
            z = a
        forall z {a}:
            z = a
            a $in s
            z $in s
            z $in {a}

thm remove_singleton_from_singleton_sized_set_is_empty:
    ? forall s finite_set, a set:
        $is_finite_set(s)
        count(s) = 1
        a $in s
        =>:
            set_minus(s, {a}) = {}
    by thm intersect_with_singleton(s, a)
    intersect(s, {a}) = {a}
    count({a}) = 1
    $is_finite_set(set_minus(s, {a}))
    count(set_minus(s, {a})) = count(s) - count(intersect(s, {a})) = 1 - 1 = 0
    set_minus(s, {a}) = {}

thm index_function_for_singleton:
    ? forall s finite_set:
        $is_finite_set(s)
        count(s) = 1
        =>:
            exist idx fn(i closed_range(1, count(s))) s st {$is_bijection_from_index_range_to_finite_set(s, idx)}
    count(s) >= 1
    by thm nonempty_from_positive_count(s)
    have a s
    a $in s
    by thm remove_singleton_from_singleton_sized_set_is_empty(s, a)
    set_minus(s, {a}) = {}
    have fn idx(i closed_range(1, count(s))) s = a
    witness exist idx0 fn(i closed_range(1, count(s))) s st {$is_bijection_from_index_range_to_finite_set(s, idx0)} from idx:
        claim:
            ? forall y s:
                exist! i closed_range(1, count(s)) st {idx0(i) = y}
            by contra:
                ? y = a
                y != a
                y $in set_minus(s, {a})
                witness $is_nonempty_set(set_minus(s, {a})) from y:
                    y $in set_minus(s, {a})
                impossible set_minus(s, {a}) = {}
            idx0(1) = idx(1) = a
            witness exist! i closed_range(1, count(s)) st {idx0(i) = y} from 1:
                1 <= count(s)
                idx0(1) = y
                claim:
                    ? forall i1, i2 closed_range(1, count(s)):
                        idx0(i1) = y
                        idx0(i2) = y
                        =>:
                            i1 = i2
                    i1 >= 1
                    i1 <= count(s)
                    i1 <= 1
                    i1 = 1
                    i2 >= 1
                    i2 <= count(s)
                    i2 <= 1
                    i2 = 1
                    i1 = i2
        $is_bijection_from_index_range_to_finite_set(s, idx0)

thm index_function_step:
    ? forall n N_pos, s finite_set:
        $is_finite_set(s)
        count(s) = n + 1
        $finite_set_size_has_index(n)
        =>:
            exist idx fn(i closed_range(1, count(s))) s st {$is_bijection_from_index_range_to_finite_set(s, idx)}
    n >= 1
    n + 1 >= 1
    count(s) = n + 1 >= 1
    by thm nonempty_from_positive_count(s)
    have a s
    a $in s
    by thm intersect_with_singleton(s, a)
    intersect(s, {a}) = {a}
    count({a}) = 1
    $is_finite_set(set_minus(s, {a}))
    count(set_minus(s, {a})) = count(s) - count(intersect(s, {a})) = (n + 1) - 1 = n
    $finite_set_size_has_index(n)
    $is_finite_set(set_minus(s, {a}))
    count(set_minus(s, {a})) = n
    exist prev fn(i closed_range(1, count(set_minus(s, {a})))) set_minus(s, {a}) st {$is_bijection_from_index_range_to_finite_set(set_minus(s, {a}), prev)}
    obtain prev from exist prev fn(i closed_range(1, count(set_minus(s, {a})))) set_minus(s, {a}) st {$is_bijection_from_index_range_to_finite_set(set_minus(s, {a}), prev)}
    set_minus(s, {a}) $subset s
    have fn idx(i closed_range(1, count(s))) s by cases:
        case i <= n: prev(i)
        case i = n + 1: a
    idx(1) = prev(1)
    prev(1) $in set_minus(s, {a})
    prev(1) $in s
    idx(1) $in s
    claim:
        ? forall i closed_range(1, count(s)):
            idx(i) = a
            =>:
                i = n + 1
        i <= n or i > n
        by cases:
            ? i = n + 1
            case i <= n:
                i >= 1
                i <= n = count(set_minus(s, {a}))
                i $in closed_range(1, count(set_minus(s, {a})))
                idx(i) = prev(i)
                prev(i) $in set_minus(s, {a})
                idx(i) $in set_minus(s, {a})
                claim:
                    ? not a $in set_minus(s, {a})
                    by contra:
                        ? not a $in set_minus(s, {a})
                        a $in set_minus(s, {a})
                        not a $in {a}
                        a $in {a}
                        impossible not a $in {a}
                a $in set_minus(s, {a})
                impossible not a $in set_minus(s, {a})
            case i > n:
                i <= count(s) = n + 1
                i = n + 1
    claim:
        ? $is_injective_fn(closed_range(1, count(s)), s, idx)
        claim:
            ? forall i1, i2 closed_range(1, count(s)):
                idx(i1) = idx(i2)
                =>:
                    i1 = i2
            i1 <= n or i1 > n
            by cases:
                ? i1 = i2
                case i1 <= n:
                    i2 <= n or i2 > n
                    by cases:
                        ? i1 = i2
                        case i2 <= n:
                            i1 >= 1
                            i2 >= 1
                            i1 <= n = count(set_minus(s, {a}))
                            i2 <= n = count(set_minus(s, {a}))
                            i1 $in closed_range(1, count(set_minus(s, {a})))
                            i2 $in closed_range(1, count(set_minus(s, {a})))
                            idx(i1) = prev(i1)
                            idx(i2) = prev(i2)
                            prev(i1) = prev(i2)
                            exist! j closed_range(1, count(set_minus(s, {a}))) st {prev(j) = prev(i1)}
                            i1 = i2
                        case i2 > n:
                            i2 <= count(s) = n + 1
                            i2 = n + 1
                            idx(i2) = a
                            idx(i1) = idx(i2) = a
                            i1 = n + 1
                            impossible i1 <= n
                case i1 > n:
                    i1 <= count(s) = n + 1
                    i1 = n + 1
                    idx(i1) = a
                    idx(i2) = idx(i1) = a
                    i2 = n + 1
                    i1 = i2
        $is_injective_fn(closed_range(1, count(s)), s, idx)
    claim:
        ? $is_surjective_fn(closed_range(1, count(s)), s, idx)
        claim:
            ? forall y s:
                exist i closed_range(1, count(s)) st {y = idx(i)}
            y = a or y != a
            by cases:
                ? exist i closed_range(1, count(s)) st {y = idx(i)}
                case y = a:
                    n + 1 <= count(s)
                    y = a = idx(n + 1)
                    witness exist i closed_range(1, count(s)) st {y = idx(i)} from n + 1:
                        n + 1 <= count(s)
                        y = idx(n + 1)
                case y != a:
                    y $in set_minus(s, {a})
                    exist i closed_range(1, count(set_minus(s, {a}))) st {prev(i) = y}
                    obtain j from exist i closed_range(1, count(set_minus(s, {a}))) st {prev(i) = y}
                    j <= count(set_minus(s, {a}))
                    j <= n
                    n <= n + 1
                    j <= n <= n + 1 = count(s)
                    y = prev(j) = idx(j)
                    witness exist i closed_range(1, count(s)) st {y = idx(i)} from j:
                        j <= count(s)
                        y = idx(j)
    witness exist idx0 fn(i closed_range(1, count(s))) s st {$is_bijection_from_index_range_to_finite_set(s, idx0)} from idx:
        claim:
            ? forall y s:
                exist! i closed_range(1, count(s)) st {idx0(i) = y}
            exist i closed_range(1, count(s)) st {y = idx(i)}
            obtain i from exist i closed_range(1, count(s)) st {y = idx(i)}
            idx(i) = y
            witness exist! i0 closed_range(1, count(s)) st {idx0(i0) = y} from i:
                idx0(i) = idx(i) = y
                forall i1, i2 closed_range(1, count(s)):
                    idx0(i1) = y
                    idx0(i2) = y
                    =>:
                        idx(i1) = idx0(i1) = y = idx0(i2) = idx(i2)
                        i1 = i2
        $is_bijection_from_index_range_to_finite_set(s, idx0)

thm finite_set_size_has_index_for_all:
    ? forall n N_pos:
        $finite_set_size_has_index(n)
    by induc n from 1:
        ? $finite_set_size_has_index(n)

        ? from n = 1:
            claim:
                ? forall s finite_set:
                    $is_finite_set(s)
                    count(s) = 1
                    =>:
                        exist idx fn(i closed_range(1, count(s))) s st {$is_bijection_from_index_range_to_finite_set(s, idx)}
                by thm index_function_for_singleton(s)
                exist idx fn(i closed_range(1, count(s))) s st {$is_bijection_from_index_range_to_finite_set(s, idx)}
            $finite_set_size_has_index(1)
            $finite_set_size_has_index(n)

        ? induc:
            $finite_set_size_has_index(n)
            claim:
                ? forall s finite_set:
                    $is_finite_set(s)
                    count(s) = n + 1
                    =>:
                        exist idx fn(i closed_range(1, count(s))) s st {$is_bijection_from_index_range_to_finite_set(s, idx)}
                by thm index_function_step(n, s)
                exist idx fn(i closed_range(1, count(s))) s st {$is_bijection_from_index_range_to_finite_set(s, idx)}
            $finite_set_size_has_index(n + 1)

thm finite_set_has_bijective_index:
    ? forall s finite_set:
        count(s) >= 1
        =>:
            exist idx fn(i closed_range(1, count(s))) s st {$is_bijection_from_index_range_to_finite_set(s, idx)}
    count(s) >= 1
    count(s) $in N_pos
    have n N_pos = count(s)
    count(s) = n
    by thm finite_set_size_has_index_for_all(n)
    $finite_set_size_has_index(n)

# `finite_set_sum(X, f)` denotes the enumeration-independent value of summing
# `f` over the finite set `X`.

forall X finite_set, f fn(x X) R:
    finite_set_sum(X, f) $in R

"""
Example 7.1.7. For a three-element set with values 2, 5, and -1, two different
enumerations give the same finite-set sum.
"""

# We use the numeric labels 1, 2, 3 for Tao's abstract objects a, b, c.  The
# function below has exactly the source values f(1)=2, f(2)=5, f(3)=-1.

sketch:
    have fn example_7_1_7_f(x Z) R = (-9 * x^2 + 33 * x - 20) / 2

    example_7_1_7_f(1) = 2
    example_7_1_7_f(2) = 5
    example_7_1_7_f(3) = -1

    finite_set_sum({1, 2, 3}, example_7_1_7_f) = 2 + 5 + (-1)
    finite_set_sum({1, 2, 3}, example_7_1_7_f) = 6
    finite_set_sum({3, 2, 1}, example_7_1_7_f) = -1 + 5 + 2
    finite_set_sum({3, 2, 1}, example_7_1_7_f) = 6
    finite_set_sum({1, 2, 3}, example_7_1_7_f) = finite_set_sum({3, 2, 1}, example_7_1_7_f)

"""
Proposition 7.1.8 (Finite summations are well-defined). Different bijective
enumerations of the same finite set give the same finite sum.
"""

# Once both enumerators list every element of `X` exactly once, the two ordinary
# closed-range sums are equal.  This is the enumeration-independence step in
# Tao's construction.

thm finite_set_sum_enumeration_well_defined:
    ? forall X finite_set, f fn(x X) R, g fn(i closed_range(1, count(X))) X, h fn(i closed_range(1, count(X))) X:
        count(X) >= 1
        $is_bijection_from_index_range_to_finite_set(X, g)
        $is_bijection_from_index_range_to_finite_set(X, h)
        =>:
            sum(1, count(X), fn(i closed_range(1, count(X))) R {f(g(i))}) = sum(1, count(X), fn(i closed_range(1, count(X))) R {f(h(i))})

# The predicate says that `l` is the common value of all bijective-enumeration
# sums.  We keep Tao's finite real-set hypothesis visible, and we keep the
# nonempty hypothesis explicit because the closed-range expression
# `sum(1, count(X), ...)` requires `1 <= count(X)`.

prop is_finite_set_sum(X finite_set, f fn(x X) R, l R):
    X $subset R
    count(X) >= 1
    forall g fn(i closed_range(1, count(X))) X:
        $is_bijection_from_index_range_to_finite_set(X, g)
        =>:
            sum(1, count(X), fn(i closed_range(1, count(X))) R {f(g(i))}) = l

thm finite_set_sum_matches_bijective_enumeration:
    ? forall X finite_set, f fn(x X) R, g fn(i closed_range(1, count(X))) X:
        count(X) >= 1
        $is_bijection_from_index_range_to_finite_set(X, g)
        =>:
            sum(1, count(X), fn(i closed_range(1, count(X))) R {f(g(i))}) = finite_set_sum(X, f)
    finite_set_sum(X, f) = finite_set_sum(closed_range(1, count(X)), fn(i closed_range(1, count(X))) R {f(g(i))})
    finite_set_sum(closed_range(1, count(X)), fn(i closed_range(1, count(X))) R {f(g(i))}) = sum(1, count(X), fn(i closed_range(1, count(X))) R {f(g(i))})
    sum(1, count(X), fn(i closed_range(1, count(X))) R {f(g(i))}) = finite_set_sum(X, f)

thm finite_set_sum_satisfies_self_definition:
    ? forall X finite_set, f fn(x X) R:
        X $subset R
        count(X) >= 1
        =>:
            $is_finite_set_sum(X, f, finite_set_sum(X, f))
    count(X) >= 1
    claim:
        ? forall g fn(i closed_range(1, count(X))) X:
            $is_bijection_from_index_range_to_finite_set(X, g)
            =>:
                sum(1, count(X), fn(i closed_range(1, count(X))) R {f(g(i))}) = finite_set_sum(X, f)
        by thm finite_set_sum_matches_bijective_enumeration(X, f, g)
    $is_finite_set_sum(X, f, finite_set_sum(X, f))

prop has_finite_set_sum(X finite_set, f fn(x X) R):
    exist l R st {$is_finite_set_sum(X, f, l)}

thm finite_set_sum_exists:
    ? forall X finite_set, f fn(x X) R:
        X $subset R
        count(X) >= 1
        =>:
            $has_finite_set_sum(X, f)
    by thm finite_set_sum_satisfies_self_definition(X, f)
    $is_finite_set_sum(X, f, finite_set_sum(X, f))
    witness exist l R st {$is_finite_set_sum(X, f, l)} from finite_set_sum(X, f):
        $is_finite_set_sum(X, f, finite_set_sum(X, f))
    $has_finite_set_sum(X, f)

# This construction chooses the unique value whose existence was just proved,
# matching Tao's idea: once all enumerations give the same sum, that common
# value is "the" finite-set sum.

template<X finite_set, f fn(x X) R: X $subset R, count(X) >= 1, $has_finite_set_sum(X, f)>:
    obtain self_finite_set_sum from exist l R st {$is_finite_set_sum(X, f, l)}

thm self_finite_set_sum_satisfies_definition:
    ? forall X finite_set, f fn(x X) R:
        X $subset R
        count(X) >= 1
        =>:
            $is_finite_set_sum(X, f, \self_finite_set_sum<X, f>)
    by thm finite_set_sum_exists(X, f)
    $has_finite_set_sum(X, f)
    $is_finite_set_sum(X, f, \self_finite_set_sum<X, f>)

thm finite_set_sum_value_unique:
    ? forall X finite_set, f fn(x X) R, l1, l2 R:
        $is_finite_set_sum(X, f, l1)
        $is_finite_set_sum(X, f, l2)
        =>:
            l1 = l2
    count(X) >= 1
    by thm finite_set_has_bijective_index(X)
    exist g fn(i closed_range(1, count(X))) X st {$is_bijection_from_index_range_to_finite_set(X, g)}
    obtain g from exist g fn(i closed_range(1, count(X))) X st {$is_bijection_from_index_range_to_finite_set(X, g)}
    $is_bijection_from_index_range_to_finite_set(X, g)
    sum(1, count(X), fn(i closed_range(1, count(X))) R {f(g(i))}) = l1
    sum(1, count(X), fn(i closed_range(1, count(X))) R {f(g(i))}) = l2
    l1 = sum(1, count(X), fn(i closed_range(1, count(X))) R {f(g(i))}) = l2

thm self_finite_set_sum_matches_builtin:
    ? forall X finite_set, f fn(x X) R:
        X $subset R
        count(X) >= 1
        =>:
            \self_finite_set_sum<X, f> = finite_set_sum(X, f)
    by thm self_finite_set_sum_satisfies_definition(X, f)
    $is_finite_set_sum(X, f, \self_finite_set_sum<X, f>)
    by thm finite_set_sum_satisfies_self_definition(X, f)
    $is_finite_set_sum(X, f, finite_set_sum(X, f))
    by thm finite_set_sum_value_unique(X, f, \self_finite_set_sum<X, f>, finite_set_sum(X, f))
    \self_finite_set_sum<X, f> = finite_set_sum(X, f)

thm finite_set_sum_well_defined_under_permutation:
    ? forall X finite_set, f fn(x X) R, g fn(x X) X:
        forall y X:
            exist! x X st {g(x) = y}
        =>:
            finite_set_sum(X, fn(x X) R {f(g(x))}) = finite_set_sum(X, f)

"""
Remark 7.1.9. Infinite-set summation is more delicate; it is deferred until
absolute convergence and countability are available.
"""

# Chapter 8 returns to summation over countable sets.  Chapter 7 only needs
# finite sets and ordinary one-dimensional infinite series.

"""
Remark 7.1.10. A sum over elements satisfying a property is shorthand for a sum
over the corresponding finite subset.
"""

# In Litex this is just `finite_set_sum({x X: $P(x)}, f)` once the filtered set
# is known to be finite.

"""
Proposition 7.1.11 (Basic properties of summation over finite sets). Finite-set
sums have empty, singleton, substitution, disjoint-union, linearity,
monotonicity, and triangle-inequality laws.
"""

# Finite-set sums inherit their empty, singleton, substitution, union,
# linearity, monotonicity, and triangle facts from finite enumeration and the
# corresponding ordinary finite-sum laws.
# Tao leaves this proof to Exercise 7.1.2.  The statements below record the
# standard finite-set-sum rules used later.

thm finite_set_sum_empty:
    ? forall f fn(x {}) R:
        finite_set_sum({}, f) = 0

thm finite_set_sum_singleton:
    ? forall x0 R, f fn(x {x0}) R:
        finite_set_sum({x0}, f) = f(x0)

thm finite_set_sum_substitution:
    ? forall X, Y finite_set, f fn(x X) R, g fn(y Y) X:
        forall x X:
            exist! y Y st {g(y) = x}
        =>:
            finite_set_sum(X, f) = finite_set_sum(Y, fn(y Y) R {f(g(y))})

thm finite_set_sum_range_matches_series:
    ? forall a fn(i Z) R, m, n Z:
        m <= n
        =>:
            sum(m, n, fn(i Z) R {a(i)}) = finite_set_sum(m...n, fn(i m...n) R {a(i)})

thm finite_set_sum_disjoint_union:
    ? forall X, Y finite_set, f fn(z union(X, Y)) R:
        intersect(X, Y) = {}
        =>:
            finite_set_sum(union(X, Y), f) = finite_set_sum(X, fn(x X) R {f(x)}) + finite_set_sum(Y, fn(y Y) R {f(y)})

thm finite_set_sum_add:
    ? forall X finite_set, f, g fn(x X) R:
        finite_set_sum(X, fn(x X) R {f(x) + g(x)}) = finite_set_sum(X, f) + finite_set_sum(X, g)

thm finite_set_sum_scalar_mul:
    ? forall X finite_set, f fn(x X) R, c R:
        finite_set_sum(X, fn(x X) R {c * f(x)}) = c * finite_set_sum(X, f)

thm finite_set_sum_monotone:
    ? forall X finite_set, f, g fn(x X) R:
        forall x X:
            f(x) <= g(x)
        =>:
            finite_set_sum(X, f) <= finite_set_sum(X, g)

thm finite_set_sum_triangle:
    ? forall X finite_set, f fn(x X) R:
        abs(finite_set_sum(X, f)) <= finite_set_sum(X, fn(x X) R {abs(f(x))})

"""
Remark 7.1.12. The substitution rule says that finite sums are invariant under
bijective reindexing.  This is why finite sequences may be rearranged freely.
"""

# This is exactly the content of `finite_set_sum_substitution` and
# `finite_set_sum_well_defined_under_permutation`.

"""
Lemma 7.1.13. A double finite sum over X and Y is the same as the finite-set
sum over the Cartesian product X x Y.
"""

thm finite_double_sum_over_cartesian_product:
    ? forall X, Y finite_set, f fn(z cart(X, Y)) R:
        finite_set_sum(X, fn(x X) R {finite_set_sum(Y, fn(y Y) R {f((x, y))})}) = finite_set_sum(cart(X, Y), f)

"""
Corollary 7.1.14 (Fubini's theorem for finite series). For finite sets, the
order of a double summation may be switched.
"""

thm finite_fubini:
    ? forall X, Y finite_set, f fn(z cart(X, Y)) R:
        finite_set_sum(X, fn(x X) R {finite_set_sum(Y, fn(y Y) R {f((x, y))})}) = finite_set_sum(Y, fn(y Y) R {finite_set_sum(X, fn(x X) R {f((x, y))})})

"""
Remark 7.1.15. Finite Fubini contrasts with the infinite double-sum examples
from Chapter 1.  Infinite sums require convergence hypotheses.
"""

# The rigorous infinite analogue waits until Chapter 8, where countability and
# absolute convergence are available.

# 7.2 Infinite series

"""
Definition 7.2.1 (Formal infinite series). A formal infinite series is an
expression with one real term for each index in an infinite tail.
"""

# The formal series itself is represented by its term sequence `a_{m} + a_{m+1} + ...`.
# At this point no value is assigned to the formal expression.

"""
Definition 7.2.2 (Convergence of series). A series converges to L when its
partial sums converge to L as a sequence.
"""

# `partial_sum(a, N)` is the Nth partial sum of the positive-indexed series.
# It is defined recursively to avoid coercing a finite integer range index into
# the `N_pos` domain of `seq(R)`.

have fn partial_sum(a seq(R), k N) R by induc k from 0:
    case k = 0: 0
    case k > 0: partial_sum(a, k - 1) + a(k)

thm partial_sum_zero:
    ? forall a seq(R):
        partial_sum(a, 0) = 0
    partial_sum(a, 0) = 0

thm partial_sum_successor:
    ? forall a seq(R), k N_pos:
        partial_sum(a, k) = partial_sum(a, k - 1) + a(k)
    k > 0
    partial_sum(a, k) = partial_sum(a, k - 1) + a(k)

thm partial_sum_matches_finite_sum:
    ? forall a seq(R), k N_pos:
        partial_sum(a, k) = sum(1, k, fn(i N_pos) R {a(i)})
    by induc k from 1:
        ? partial_sum(a, k) = sum(1, k, fn(i N_pos) R {a(i)})

        ? from k = 1:
            by thm partial_sum_successor(a, 1)
            partial_sum(a, 1) = partial_sum(a, 1 - 1) + a(1)
            1 - 1 = 0
            partial_sum(a, 1 - 1) = partial_sum(a, 0)
            partial_sum(a, 0) = 0
            partial_sum(a, 1 - 1) + a(1) = partial_sum(a, 0) + a(1)
            partial_sum(a, 0) + a(1) = 0 + a(1)
            partial_sum(a, 1) = 0 + a(1)
            0 + a(1) = a(1)
            sum(1, 1, fn(i N_pos) R {a(i)}) = a(1)
            partial_sum(a, 1) = sum(1, 1, fn(i N_pos) R {a(i)})

        ? induc:
            partial_sum(a, k) = sum(1, k, fn(i N_pos) R {a(i)})
            k + 1 $in N_pos
            by thm partial_sum_successor(a, k + 1)
            partial_sum(a, k + 1) = partial_sum(a, (k + 1) - 1) + a(k + 1)
            (k + 1) - 1 = k
            partial_sum(a, (k + 1) - 1) = partial_sum(a, k)
            partial_sum(a, (k + 1) - 1) + a(k + 1) = partial_sum(a, k) + a(k + 1)
            partial_sum(a, k + 1) = partial_sum(a, k) + a(k + 1)
            sum(1, k + 1, fn(i N_pos) R {a(i)}) = sum(1, k, fn(i N_pos) R {a(i)}) + fn(i N_pos) R {a(i)}(k + 1)
            fn(i N_pos) R {a(i)}(k + 1) = a(k + 1)
            sum(1, k + 1, fn(i N_pos) R {a(i)}) = sum(1, k, fn(i N_pos) R {a(i)}) + a(k + 1)
            partial_sum(a, k + 1) = sum(1, k + 1, fn(i N_pos) R {a(i)})

thm partial_sum_split_after:
    ? forall a seq(R), m, n N_pos:
        m < n
        =>:
            partial_sum(a, n) = partial_sum(a, m) + sum(m + 1, n, fn(i N_pos) R {a(i)})
    by thm partial_sum_matches_finite_sum(a, n)
    by thm partial_sum_matches_finite_sum(a, m)
    partial_sum(a, n) = sum(1, n, fn(i N_pos) R {a(i)})
    partial_sum(a, m) = sum(1, m, fn(i N_pos) R {a(i)})
    sum(1, n, fn(i N_pos) R {a(i)}) = sum(1, m, fn(i N_pos) R {a(i)}) + sum(m + 1, n, fn(i N_pos) R {a(i)})
    sum(1, m, fn(i N_pos) R {a(i)}) + sum(m + 1, n, fn(i N_pos) R {a(i)}) = partial_sum(a, m) + sum(m + 1, n, fn(i N_pos) R {a(i)})
    partial_sum(a, n) = sum(1, m, fn(i N_pos) R {a(i)}) + sum(m + 1, n, fn(i N_pos) R {a(i)})
    partial_sum(a, n) = partial_sum(a, m) + sum(m + 1, n, fn(i N_pos) R {a(i)})

prop is_tail_close_to(a seq(R), L R, epsilon R_pos, N0 N_pos):
    forall n N_pos:
        n >= N0
        =>:
            abs(a(n) - L) <= epsilon

prop has_limit(a seq(R), L R):
    forall epsilon R_pos:
        exist N0 N_pos st {$is_tail_close_to(a, L, epsilon, N0)}

prop has_series_sum(a seq(R), L R):
    $has_limit(fn(k N_pos) R {partial_sum(a, k)}, L)

prop is_convergent_series(a seq(R)):
    exist L R st {$has_series_sum(a, L)}

thm partial_sum_extensional:
    ? forall a, b seq(R), k N:
        forall n N_pos:
            a(n) = b(n)
        =>:
            partial_sum(a, k) = partial_sum(b, k)
    by induc k from 0:
        ? partial_sum(a, k) = partial_sum(b, k)

        ? from k = 0:
            by thm partial_sum_zero(a)
            partial_sum(a, 0) = 0
            by thm partial_sum_zero(b)
            partial_sum(b, 0) = 0
            partial_sum(a, 0) = partial_sum(b, 0)

        ? induc:
            partial_sum(a, k) = partial_sum(b, k)
            k + 1 $in N_pos
            by thm partial_sum_successor(a, k + 1)
            partial_sum(a, k + 1) = partial_sum(a, (k + 1) - 1) + a(k + 1)
            (k + 1) - 1 = k
            partial_sum(a, (k + 1) - 1) = partial_sum(a, k)
            partial_sum(a, (k + 1) - 1) + a(k + 1) = partial_sum(a, k) + a(k + 1)
            partial_sum(a, k + 1) = partial_sum(a, k) + a(k + 1)
            by thm partial_sum_successor(b, k + 1)
            partial_sum(b, k + 1) = partial_sum(b, (k + 1) - 1) + b(k + 1)
            partial_sum(b, (k + 1) - 1) = partial_sum(b, k)
            partial_sum(b, (k + 1) - 1) + b(k + 1) = partial_sum(b, k) + b(k + 1)
            partial_sum(b, k + 1) = partial_sum(b, k) + b(k + 1)
            a(k + 1) = b(k + 1)
            partial_sum(a, k) + a(k + 1) = partial_sum(b, k) + b(k + 1)
            partial_sum(a, k + 1) = partial_sum(b, k + 1)

thm series_sum_extensional:
    ? forall a, b seq(R), L R:
        forall n N_pos:
            a(n) = b(n)
        $has_series_sum(a, L)
        =>:
            $has_series_sum(b, L)
    claim:
        ? forall epsilon R_pos:
            exist N0 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(b, k)}, L, epsilon, N0)}
        obtain N0 from exist N0 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(a, k)}, L, epsilon, N0)}
        witness exist N1 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(b, k)}, L, epsilon, N1)} from N0:
            forall k N_pos:
                k >= N0
                =>:
                    abs(fn(k N_pos) R {partial_sum(a, k)}(k) - L) <= epsilon
                    fn(k N_pos) R {partial_sum(a, k)}(k) = partial_sum(a, k)
                    partial_sum(a, k) = partial_sum(b, k)
                    fn(k N_pos) R {partial_sum(b, k)}(k) = partial_sum(b, k)
                    abs(fn(k N_pos) R {partial_sum(b, k)}(k) - L) = abs(partial_sum(b, k) - L)
                    abs(partial_sum(b, k) - L) = abs(partial_sum(a, k) - L)
                    abs(partial_sum(a, k) - L) = abs(fn(k N_pos) R {partial_sum(a, k)}(k) - L)
                    abs(fn(k N_pos) R {partial_sum(b, k)}(k) - L) <= epsilon
            $is_tail_close_to(fn(k N_pos) R {partial_sum(b, k)}, L, epsilon, N0)
    $has_limit(fn(k N_pos) R {partial_sum(b, k)}, L)
    $has_series_sum(b, L)

thm series_convergence_extensional:
    ? forall a, b seq(R):
        forall n N_pos:
            a(n) = b(n)
        $is_convergent_series(a)
        =>:
            $is_convergent_series(b)
    obtain L from exist L R st {$has_series_sum(a, L)}
    by thm series_sum_extensional(a, b, L)
    $has_series_sum(b, L)
    witness exist M R st {$has_series_sum(b, M)} from L:
        $has_series_sum(b, L)
    $is_convergent_series(b)

have fn geometric_series_terms_from_one(x R) fn(i N_pos) R = fn(j N_pos) R {x^j}

thm geometric_series_from_one_formula:
    ? forall x R:
        abs(x) < 1
        1 - x != 0
        =>:
            $has_series_sum(geometric_series_terms_from_one(x), x / (1 - x))
    # Source handling: Example 7.2.4 derives the finite geometric-sum formula
    # and then takes the geometric-sequence limit.
    # proof_debt: the chapter still lacks that finite partial-sum identity and
    # its bridge to the Chapter 6 geometric limit.
    trust $has_series_sum(geometric_series_terms_from_one(x), x / (1 - x))

thm geometric_series_from_one_diverges_when_abs_ge_one:
    ? forall x R:
        abs(x) >= 1
        =>:
            not $is_convergent_series(geometric_series_terms_from_one(x))
    # Source handling: Example 7.2.4 displays unbounded partial sums; Lemma
    # 7.3.3 later gives the full geometric-series divergence criterion.
    # proof_debt: the local geometric-term limit package has not yet supplied
    # the zero-test argument for every `abs(x) >= 1`.
    trust not $is_convergent_series(geometric_series_terms_from_one(x))

"""
Remark 7.2.3. If a series converges, its sum is unique because sequence limits
are unique.
"""

# Proposition 6.1.7 says that a sequence has at most one limit.  Applying that
# result to the partial-sum sequence gives uniqueness of a series sum.

thm sequence_limit_unique_cite_from_chap6:
    ? forall b seq(R), M1, M2 R:
        $has_limit(b, M1)
        $has_limit(b, M2)
        =>:
            M1 = M2
    by contra:
        ? M1 = M2
        M1 != M2
        M1 - M2 != 0
        abs(M1 - M2) > 0
        abs(M1 - M2) / 3 $in R_pos
        obtain n1 from exist n1 N_pos st {$is_tail_close_to(b, M1, abs(M1 - M2) / 3, n1)}
        obtain n2 from exist n2 N_pos st {$is_tail_close_to(b, M2, abs(M1 - M2) / 3, n2)}
        max(n1, n2) $in N_pos
        max(n1, n2) >= n1
        max(n1, n2) >= n2
        abs(b(max(n1, n2)) - M1) <= abs(M1 - M2) / 3
        abs(b(max(n1, n2)) - M2) <= abs(M1 - M2) / 3
        abs(M1 - b(max(n1, n2))) = abs(b(max(n1, n2)) - M1)
        abs(M1 - b(max(n1, n2))) <= abs(M1 - M2) / 3
        M1 - M2 = (M1 - b(max(n1, n2))) + (b(max(n1, n2)) - M2)
        abs(M1 - M2) = abs((M1 - b(max(n1, n2))) + (b(max(n1, n2)) - M2))
        abs((M1 - b(max(n1, n2))) + (b(max(n1, n2)) - M2)) <= abs(M1 - b(max(n1, n2))) + abs(b(max(n1, n2)) - M2)
        abs(M1 - M2) <= abs(M1 - b(max(n1, n2))) + abs(b(max(n1, n2)) - M2)
        abs(M1 - b(max(n1, n2))) + abs(b(max(n1, n2)) - M2) <= abs(M1 - M2) / 3 + abs(M1 - M2) / 3
        abs(M1 - M2) <= abs(M1 - b(max(n1, n2))) + abs(b(max(n1, n2)) - M2) <= abs(M1 - M2) / 3 + abs(M1 - M2) / 3
        abs(M1 - M2) <= abs(M1 - M2) / 3 + abs(M1 - M2) / 3
        abs(M1 - M2) / 3 + abs(M1 - M2) / 3 = 2 * abs(M1 - M2) / 3
        2 / 3 < 1
        (2 / 3) * abs(M1 - M2) < 1 * abs(M1 - M2)
        (2 / 3) * abs(M1 - M2) = 2 * abs(M1 - M2) / 3
        1 * abs(M1 - M2) = abs(M1 - M2)
        2 * abs(M1 - M2) / 3 < abs(M1 - M2)
        abs(M1 - M2) <= 2 * abs(M1 - M2) / 3
        abs(M1 - M2) <= 2 * abs(M1 - M2) / 3 < abs(M1 - M2)
        abs(M1 - M2) < abs(M1 - M2)
        abs(M1 - M2) != abs(M1 - M2)
        impossible abs(M1 - M2) = abs(M1 - M2)

thm series_sum_unique:
    ? forall a seq(R), L1, L2 R:
        $has_series_sum(a, L1)
        $has_series_sum(a, L2)
        =>:
            L1 = L2
    $has_limit(fn(k N_pos) R {partial_sum(a, k)}, L1)
    $has_limit(fn(k N_pos) R {partial_sum(a, k)}, L2)
    by thm sequence_limit_unique_cite_from_chap6(fn(k N_pos) R {partial_sum(a, k)}, L1, L2)
    L1 = L2

"""
Examples 7.2.4. The geometric series with terms 2^{-n} converges to 1, while
the series with terms 2^n diverges.
"""

sketch:
    have half_power_terms seq(R) = geometric_series_terms_from_one(1 / 2)
    have two_power_terms seq(R) = geometric_series_terms_from_one(2)

    claim:
        ? forall k N_pos:
            half_power_terms(k) = 2^(-k)
            two_power_terms(k) = 2^k
        half_power_terms(k) = geometric_series_terms_from_one(1 / 2)(k)
        geometric_series_terms_from_one(1 / 2)(k) = (1 / 2)^k
        2^(-1) = 1 / 2^1
        2^1 = 2
        1 / 2^1 = 1 / 2
        2^(-1) = 1 / 2
        1 / 2 = 2^(-1)
        (1 / 2)^k = (2^(-1))^k
        (2^(-1))^k = 2^((-1) * k)
        (-1) * k = -k
        2^((-1) * k) = 2^(-k)
        (1 / 2)^k = 2^(-k)
        half_power_terms(k) = 2^(-k)
        two_power_terms(k) = geometric_series_terms_from_one(2)(k)
        geometric_series_terms_from_one(2)(k) = 2^k

    claim:
        ? $has_series_sum(half_power_terms, 1)
        abs(1 / 2) < 1
        1 - 1 / 2 != 0
        by thm geometric_series_from_one_formula(1 / 2)
        $has_series_sum(geometric_series_terms_from_one(1 / 2), (1 / 2) / (1 - 1 / 2))
        (1 / 2) / (1 - 1 / 2) = 1
        $has_series_sum(geometric_series_terms_from_one(1 / 2), 1)
        $has_series_sum(half_power_terms, 1)

    claim:
        ? not $is_convergent_series(two_power_terms)
        abs(2) >= 1
        by thm geometric_series_from_one_diverges_when_abs_ge_one(2)
        not $is_convergent_series(geometric_series_terms_from_one(2))
        not $is_convergent_series(two_power_terms)

"""
Proposition 7.2.5. A series converges iff all sufficiently late finite tails
are arbitrarily small.
"""

# This is the Cauchy criterion for series: convergence of partial sums is
# equivalent to every sufficiently late finite tail having small absolute value.
# Tao leaves this proof to Exercise 7.2.2.  The remaining work is to translate
# the Cauchy condition for partial sums into the absolute value of a finite
# tail sum, in both directions.

have fn finite_tail_sum(a seq(R), p, q N_pos) R by cases:
    case q < p: 0
    case q >= p: partial_sum(a, q) - partial_sum(a, p - 1)

prop has_small_tail_sums_after(a seq(R), epsilon R_pos, n0 N_pos):
    forall p, q N_pos:
        p >= n0
        q >= n0
        =>:
            abs(finite_tail_sum(a, p, q)) <= epsilon

prop has_cauchy_series_tails(a seq(R)):
    forall epsilon R_pos:
        exist n0 N_pos st {$has_small_tail_sums_after(a, epsilon, n0)}

thm series_cauchy_criterion_forward:
    ? forall a seq(R):
        $is_convergent_series(a)
        =>:
            $has_cauchy_series_tails(a)
    obtain L from exist L R st {$has_series_sum(a, L)}
    $has_series_sum(a, L)
    $has_limit(fn(k N_pos) R {partial_sum(a, k)}, L)
    claim:
        ? forall epsilon R_pos:
            exist n0 N_pos st {$has_small_tail_sums_after(a, epsilon, n0)}
        epsilon / 2 $in R_pos
        obtain N0 from exist N0 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(a, k)}, L, epsilon / 2, N0)}
        N0 + 1 $in N_pos
        witness exist n1 N_pos st {$has_small_tail_sums_after(a, epsilon, n1)} from N0 + 1:
            claim:
                ? forall p, q N_pos:
                    p >= N0 + 1
                    q >= N0 + 1
                    =>:
                        abs(finite_tail_sum(a, p, q)) <= epsilon
                by cases:
                    ? abs(finite_tail_sum(a, p, q)) <= epsilon
                    case q < p:
                        finite_tail_sum(a, p, q) = 0
                        abs(finite_tail_sum(a, p, q)) = 0
                        0 <= epsilon
                        abs(finite_tail_sum(a, p, q)) <= epsilon
                    case q >= p:
                        N0 + 1 >= N0
                        q >= N0 + 1 >= N0
                        q >= N0
                        p - 1 >= N0
                        N0 >= 1
                        p - 1 >= N0 >= 1
                        p - 1 >= 1
                        p - 1 $in N_pos
                        abs(fn(k N_pos) R {partial_sum(a, k)}(q) - L) <= epsilon / 2
                        fn(k N_pos) R {partial_sum(a, k)}(q) = partial_sum(a, q)
                        abs(partial_sum(a, q) - L) = abs(fn(k N_pos) R {partial_sum(a, k)}(q) - L)
                        abs(partial_sum(a, q) - L) <= epsilon / 2
                        abs(fn(k N_pos) R {partial_sum(a, k)}(p - 1) - L) <= epsilon / 2
                        fn(k N_pos) R {partial_sum(a, k)}(p - 1) = partial_sum(a, p - 1)
                        abs(partial_sum(a, p - 1) - L) = abs(fn(k N_pos) R {partial_sum(a, k)}(p - 1) - L)
                        abs(partial_sum(a, p - 1) - L) <= epsilon / 2
                        finite_tail_sum(a, p, q) = partial_sum(a, q) - partial_sum(a, p - 1)
                        partial_sum(a, q) - partial_sum(a, p - 1) = (partial_sum(a, q) - L) + (L - partial_sum(a, p - 1))
                        abs(finite_tail_sum(a, p, q)) = abs((partial_sum(a, q) - L) + (L - partial_sum(a, p - 1)))
                        abs((partial_sum(a, q) - L) + (L - partial_sum(a, p - 1))) <= abs(partial_sum(a, q) - L) + abs(L - partial_sum(a, p - 1))
                        abs(finite_tail_sum(a, p, q)) <= abs(partial_sum(a, q) - L) + abs(L - partial_sum(a, p - 1))
                        abs(L - partial_sum(a, p - 1)) = abs(partial_sum(a, p - 1) - L)
                        abs(L - partial_sum(a, p - 1)) <= epsilon / 2
                        abs(partial_sum(a, q) - L) + abs(L - partial_sum(a, p - 1)) <= epsilon / 2 + epsilon / 2
                        epsilon / 2 + epsilon / 2 = epsilon
                        abs(partial_sum(a, q) - L) + abs(L - partial_sum(a, p - 1)) <= epsilon
                        abs(finite_tail_sum(a, p, q)) <= abs(partial_sum(a, q) - L) + abs(L - partial_sum(a, p - 1)) <= epsilon
                        abs(finite_tail_sum(a, p, q)) <= epsilon
            $has_small_tail_sums_after(a, epsilon, N0 + 1)
    $has_cauchy_series_tails(a)

# The tail criterion makes the partial sums Cauchy.  This is the finite
# algebraic part of the converse; the sole remaining background use is the
# Chapter 5 completeness interface for real Cauchy sequences.

thm real_closeness_is_symmetric:
    ? forall epsilon R_pos, x, y R:
        $is_close_in_R(epsilon, x, y)
        =>:
            $is_close_in_R(epsilon, y, x)
    dist_R(x, y) = abs(x - y)
    x - y = -(y - x)
    abs(x - y) = abs(-(y - x))
    abs(-(y - x)) = abs(y - x)
    dist_R(y, x) = abs(y - x)
    dist_R(y, x) = dist_R(x, y)
    $is_close_in_R(epsilon, y, x)

thm partial_sums_close_when_first_index_before_second:
    ? forall a seq(R), epsilon R_pos, n0, j, k N_pos:
        $has_small_tail_sums_after(a, epsilon, n0)
        j >= n0
        k >= n0
        j < k
        =>:
            $is_close_in_R(epsilon, partial_sum(a, j), partial_sum(a, k))
    j + 1 $in N_pos
    j + 1 >= n0
    k >= j + 1
    abs(finite_tail_sum(a, j + 1, k)) <= epsilon
    finite_tail_sum(a, j + 1, k) = partial_sum(a, k) - partial_sum(a, (j + 1) - 1)
    (j + 1) - 1 = j
    partial_sum(a, (j + 1) - 1) = partial_sum(a, j)
    finite_tail_sum(a, j + 1, k) = partial_sum(a, k) - partial_sum(a, j)
    abs(finite_tail_sum(a, j + 1, k)) = abs(partial_sum(a, k) - partial_sum(a, j))
    abs(partial_sum(a, k) - partial_sum(a, j)) <= epsilon
    abs(partial_sum(a, j) - partial_sum(a, k)) = abs(-(partial_sum(a, k) - partial_sum(a, j)))
    abs(-(partial_sum(a, k) - partial_sum(a, j))) = abs(partial_sum(a, k) - partial_sum(a, j))
    abs(partial_sum(a, j) - partial_sum(a, k)) <= epsilon
    dist_R(partial_sum(a, j), partial_sum(a, k)) = abs(partial_sum(a, j) - partial_sum(a, k))
    $is_close_in_R(epsilon, partial_sum(a, j), partial_sum(a, k))

thm cauchy_series_tails_make_partial_sums_cauchy_in_R:
    ? forall a seq(R):
        $has_cauchy_series_tails(a)
        =>:
            $is_cauchy_sequence_in_R(fn(k N_pos) R {partial_sum(a, k)})
    claim:
        ? forall epsilon R_pos:
            exist n0 N_pos st {$is_cauchy_tail_in_R(fn(k N_pos) R {partial_sum(a, k)}, epsilon, n0)}
        obtain n0 from exist n0 N_pos st {$has_small_tail_sums_after(a, epsilon, n0)}
        witness exist n1 N_pos st {$is_cauchy_tail_in_R(fn(k N_pos) R {partial_sum(a, k)}, epsilon, n1)} from n0:
            claim:
                ? forall j, k N_pos:
                    j >= n0
                    k >= n0
                    =>:
                        $is_close_in_R(epsilon, partial_sum(a, j), partial_sum(a, k))
                j < k or j >= k
                by cases:
                    ? $is_close_in_R(epsilon, partial_sum(a, j), partial_sum(a, k))
                    case j < k:
                        by thm partial_sums_close_when_first_index_before_second(a, epsilon, n0, j, k)
                        $is_close_in_R(epsilon, partial_sum(a, j), partial_sum(a, k))
                    case j >= k:
                        k < j or k >= j
                        by cases:
                            ? $is_close_in_R(epsilon, partial_sum(a, j), partial_sum(a, k))
                            case k < j:
                                by thm partial_sums_close_when_first_index_before_second(a, epsilon, n0, k, j)
                                $is_close_in_R(epsilon, partial_sum(a, k), partial_sum(a, j))
                                by thm real_closeness_is_symmetric(epsilon, partial_sum(a, k), partial_sum(a, j))
                                $is_close_in_R(epsilon, partial_sum(a, j), partial_sum(a, k))
                            case k >= j:
                                j = k
                                partial_sum(a, j) = partial_sum(a, k)
                                dist_R(partial_sum(a, j), partial_sum(a, k)) = 0
                                0 <= epsilon
                                $is_close_in_R(epsilon, partial_sum(a, j), partial_sum(a, k))
            claim:
                ? forall j, k N_pos:
                    j >= n0
                    k >= n0
                    =>:
                        $is_close_in_R(epsilon, fn(k N_pos) R {partial_sum(a, k)}(j), fn(k N_pos) R {partial_sum(a, k)}(k))
                fn(k N_pos) R {partial_sum(a, k)}(j) = partial_sum(a, j)
                fn(k N_pos) R {partial_sum(a, k)}(k) = partial_sum(a, k)
                $is_close_in_R(epsilon, partial_sum(a, j), partial_sum(a, k))
                $is_close_in_R(epsilon, fn(k N_pos) R {partial_sum(a, k)}(j), fn(k N_pos) R {partial_sum(a, k)}(k))
            $is_cauchy_tail_in_R(fn(k N_pos) R {partial_sum(a, k)}, epsilon, n0)
            $is_cauchy_tail_in_R(fn(k N_pos) R {partial_sum(a, k)}, epsilon, n0)
    $is_cauchy_sequence_in_R(fn(k N_pos) R {partial_sum(a, k)})

thm nonstrict_real_limit_gives_series_limit:
    ? forall a seq(R), L R:
        $has_limit_in_R(a, L)
        =>:
            $has_limit(a, L)
    claim:
        ? forall epsilon R_pos:
            exist n0 N_pos st {$is_tail_close_to(a, L, epsilon, n0)}
        epsilon / 2 $in R_pos
        epsilon / 2 < epsilon
        obtain n0 from exist n0 N_pos st {$is_tail_close_to_in_R(a, L, epsilon / 2, n0)}
        witness exist n1 N_pos st {$is_tail_close_to(a, L, epsilon, n1)} from n0:
            forall n N_pos:
                n >= n0
                =>:
                    $is_close_in_R(epsilon / 2, a(n), L)
                    dist_R(a(n), L) = abs(a(n) - L)
                    abs(a(n) - L) <= epsilon / 2 < epsilon
            $is_tail_close_to(a, L, epsilon, n0)
    $has_limit(a, L)

thm series_cauchy_criterion_reverse:
    ? forall a seq(R):
        $has_cauchy_series_tails(a)
        =>:
            $is_convergent_series(a)
    by thm cauchy_series_tails_make_partial_sums_cauchy_in_R(a)
    $is_cauchy_sequence_in_R(fn(k N_pos) R {partial_sum(a, k)})
    by thm real_cauchy_sequence_has_limit_in_R(fn(k N_pos) R {partial_sum(a, k)})
    obtain L from exist L R st {$has_limit_in_R(fn(k N_pos) R {partial_sum(a, k)}, L)}
    by thm nonstrict_real_limit_gives_series_limit(fn(k N_pos) R {partial_sum(a, k)}, L)
    $has_limit(fn(k N_pos) R {partial_sum(a, k)}, L)
    witness exist M R st {$has_series_sum(a, M)} from L:
        $has_limit(fn(k N_pos) R {partial_sum(a, k)}, L)
        $has_series_sum(a, L)
    $is_convergent_series(a)

"""
Corollary 7.2.6 (Zero test). Every convergent series has terms tending to 0.
If the terms fail to tend to 0, the series diverges.
"""

# The zero test says convergence of the partial sums forces the individual
# increments `a(n)` to become small; equivalently, a nonzero term tail obstructs
# convergence of the series.
# Tao leaves this proof to Exercise 7.2.3.  Once the Cauchy-tail criterion is
# available, the direct step is to apply it with `p=q=n`.

thm series_zero_test:
    ? forall a seq(R):
        $is_convergent_series(a)
        =>:
            $has_limit(a, 0)
    by thm series_cauchy_criterion_forward(a)
    $has_cauchy_series_tails(a)
    claim:
        ? forall epsilon R_pos:
            exist n0 N_pos st {$is_tail_close_to(a, 0, epsilon, n0)}
        obtain n0 from exist n0 N_pos st {$has_small_tail_sums_after(a, epsilon, n0)}
        witness exist n1 N_pos st {$is_tail_close_to(a, 0, epsilon, n1)} from n0:
            forall n N_pos:
                n >= n0
                =>:
                    abs(finite_tail_sum(a, n, n)) <= epsilon
                    finite_tail_sum(a, n, n) = partial_sum(a, n) - partial_sum(a, n - 1)
                    partial_sum(a, n) = partial_sum(a, n - 1) + a(n)
                    partial_sum(a, n) - partial_sum(a, n - 1) = a(n)
                    finite_tail_sum(a, n, n) = a(n)
                    a(n) - 0 = a(n)
                    abs(a(n) - 0) = abs(a(n))
                    abs(finite_tail_sum(a, n, n)) = abs(a(n))
                    abs(a(n) - 0) = abs(finite_tail_sum(a, n, n))
                    abs(a(n) - 0) <= epsilon
            $is_tail_close_to(a, 0, epsilon, n0)
    $has_limit(a, 0)

"""
Example 7.2.7. The series with constant term 1 diverges, and the alternating
series with terms (-1)^n also diverges, because neither term sequence tends to
0.  A term sequence tending to 0 is necessary but not sufficient for the series
to converge.
"""

sketch:
    have fn ones_series_terms(k N_pos) R = 1
    have fn alternating_ones_terms(k N_pos) R = (-1)^k

    claim:
        ? not $has_limit(ones_series_terms, 0)
        by contra:
            ? not $has_limit(ones_series_terms, 0)
            $has_limit(ones_series_terms, 0)
            1 / 2 $in R_pos
            obtain n0 from exist n0 N_pos st {$is_tail_close_to(ones_series_terms, 0, 1 / 2, n0)}
            n0 >= n0
            abs(ones_series_terms(n0) - 0) <= 1 / 2
            ones_series_terms(n0) = fn(k N_pos) R {1}(n0)
            fn(k N_pos) R {1}(n0) = 1
            ones_series_terms(n0) - 0 = 1
            abs(ones_series_terms(n0) - 0) = abs(1)
            abs(1) = 1
            1 <= 1 / 2
            impossible 1 <= 1 / 2

    claim:
        ? not $is_convergent_series(ones_series_terms)
        by contra:
            ? not $is_convergent_series(ones_series_terms)
            $is_convergent_series(ones_series_terms)
            by thm series_zero_test(ones_series_terms)
            $has_limit(ones_series_terms, 0)
            impossible not $has_limit(ones_series_terms, 0)

    claim:
        ? not $has_limit(alternating_ones_terms, 0)
        by contra:
            ? not $has_limit(alternating_ones_terms, 0)
            $has_limit(alternating_ones_terms, 0)
            1 / 2 $in R_pos
            obtain n0 from exist n0 N_pos st {$is_tail_close_to(alternating_ones_terms, 0, 1 / 2, n0)}
            2 * n0 $in N_pos
            2 * n0 >= n0
            abs(alternating_ones_terms(2 * n0) - 0) <= 1 / 2
            alternating_ones_terms(2 * n0) = fn(k N_pos) R {(-1)^k}(2 * n0)
            fn(k N_pos) R {(-1)^k}(2 * n0) = (-1)^(2 * n0)
            (-1)^2 = 1
            ((-1)^2)^n0 = 1^n0
            1^n0 = 1
            ((-1)^2)^n0 = (-1)^(2 * n0)
            (-1)^(2 * n0) = 1
            alternating_ones_terms(2 * n0) = 1
            alternating_ones_terms(2 * n0) - 0 = 1
            abs(alternating_ones_terms(2 * n0) - 0) = abs(1)
            abs(1) = 1
            1 <= 1 / 2
            impossible 1 <= 1 / 2

    claim:
        ? not $is_convergent_series(alternating_ones_terms)
        by contra:
            ? not $is_convergent_series(alternating_ones_terms)
            $is_convergent_series(alternating_ones_terms)
            by thm series_zero_test(alternating_ones_terms)
            $has_limit(alternating_ones_terms, 0)
            impossible not $has_limit(alternating_ones_terms, 0)

"""
Definition 7.2.8 (Absolute convergence). A series is absolutely convergent when
the series of absolute values converges.
"""

prop is_absolutely_convergent_series(a seq(R)):
    $is_convergent_series(fn(j N_pos) R {abs(a(j))})

"""
Proposition 7.2.9 (Absolute convergence test). Absolute convergence implies
ordinary convergence, and the absolute value of the sum is bounded by the sum
of absolute values.
"""

# Absolute convergence controls signed finite tails by the corresponding
# absolute tails, and the bound on the final sum is the finite triangle
# inequality passed to the limit.
# Tao leaves this proof to Exercise 7.2.4.  The remaining formal work is to
# pass the finite triangle inequality through the limit of partial sums.

thm partial_sum_abs_matches_finite_sum:
    ? forall a seq(R), k N_pos:
        partial_sum(fn(j N_pos) R {abs(a(j))}, k) = sum(1, k, fn(i N_pos) R {abs(a(i))})
    by thm partial_sum_matches_finite_sum(fn(j N_pos) R {abs(a(j))}, k)
    partial_sum(fn(j N_pos) R {abs(a(j))}, k) = sum(1, k, fn(i N_pos) R {fn(j N_pos) R {abs(a(j))}(i)})
    sum(1, k, fn(i N_pos) R {fn(j N_pos) R {abs(a(j))}(i)}) = sum(1, k, fn(i N_pos) R {abs(a(i))})

thm finite_sum_abs_nonnegative:
    ? forall a seq(R), p, q N_pos:
        p <= q
        =>:
            sum(p, q, fn(i N_pos) R {abs(a(i))}) >= 0
    forall i N_pos:
        p <= i <= q
        =>:
            0 <= abs(a(i))
    sum(p, q, fn(i N_pos) R {0}) <= sum(p, q, fn(i N_pos) R {abs(a(i))})
    sum(p, q, fn(i N_pos) R {0}) = 0
    0 <= sum(p, q, fn(i N_pos) R {abs(a(i))})
    sum(p, q, fn(i N_pos) R {abs(a(i))}) >= 0

thm finite_tail_abs_nonnegative:
    ? forall a seq(R), p, q N_pos:
        finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) >= 0
    by cases:
        ? finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) >= 0
        case q < p:
            finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) = 0
            finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) >= 0
        case q >= p:
            by cases:
                ? finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) >= 0
                case p = 1:
                    finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) = partial_sum(fn(j N_pos) R {abs(a(j))}, q) - partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1)
                    p - 1 = 0
                    partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) = partial_sum(fn(j N_pos) R {abs(a(j))}, 0)
                    partial_sum(fn(j N_pos) R {abs(a(j))}, 0) = 0
                    finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) = partial_sum(fn(j N_pos) R {abs(a(j))}, q) - 0
                    partial_sum(fn(j N_pos) R {abs(a(j))}, q) - 0 = partial_sum(fn(j N_pos) R {abs(a(j))}, q)
                    by thm partial_sum_abs_matches_finite_sum(a, q)
                    partial_sum(fn(j N_pos) R {abs(a(j))}, q) = sum(1, q, fn(i N_pos) R {abs(a(i))})
                    by thm finite_sum_abs_nonnegative(a, 1, q)
                    sum(1, q, fn(i N_pos) R {abs(a(i))}) >= 0
                    partial_sum(fn(j N_pos) R {abs(a(j))}, q) >= 0
                    finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) >= 0
                case p > 1:
                    p - 1 $in N_pos
                    p - 1 < p
                    p - 1 < p <= q
                    p - 1 < q
                    by thm partial_sum_split_after(fn(j N_pos) R {abs(a(j))}, p - 1, q)
                    partial_sum(fn(j N_pos) R {abs(a(j))}, q) = partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) + sum((p - 1) + 1, q, fn(i N_pos) R {fn(j N_pos) R {abs(a(j))}(i)})
                    (p - 1) + 1 = p
                    sum((p - 1) + 1, q, fn(i N_pos) R {fn(j N_pos) R {abs(a(j))}(i)}) = sum(p, q, fn(i N_pos) R {abs(a(i))})
                    partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) + sum((p - 1) + 1, q, fn(i N_pos) R {fn(j N_pos) R {abs(a(j))}(i)}) = partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) + sum(p, q, fn(i N_pos) R {abs(a(i))})
                    partial_sum(fn(j N_pos) R {abs(a(j))}, q) = partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) + sum(p, q, fn(i N_pos) R {abs(a(i))})
                    finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) = partial_sum(fn(j N_pos) R {abs(a(j))}, q) - partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1)
                    partial_sum(fn(j N_pos) R {abs(a(j))}, q) - partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) = (partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) + sum(p, q, fn(i N_pos) R {abs(a(i))})) - partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1)
                    (partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) + sum(p, q, fn(i N_pos) R {abs(a(i))})) - partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) = sum(p, q, fn(i N_pos) R {abs(a(i))})
                    finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) = sum(p, q, fn(i N_pos) R {abs(a(i))})
                    by thm finite_sum_abs_nonnegative(a, p, q)
                    sum(p, q, fn(i N_pos) R {abs(a(i))}) >= 0
                    finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) >= 0

thm finite_tail_abs_bound:
    ? forall a seq(R), p, q N_pos:
        abs(finite_tail_sum(a, p, q)) <= finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q)
    by cases:
        ? abs(finite_tail_sum(a, p, q)) <= finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q)
        case q < p:
            finite_tail_sum(a, p, q) = 0
            finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) = 0
            abs(finite_tail_sum(a, p, q)) = abs(0)
            abs(0) = 0
            abs(finite_tail_sum(a, p, q)) <= finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q)
        case q >= p:
            by cases:
                ? abs(finite_tail_sum(a, p, q)) <= finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q)
                case p = 1:
                    finite_tail_sum(a, p, q) = partial_sum(a, q) - partial_sum(a, p - 1)
                    p - 1 = 0
                    partial_sum(a, p - 1) = partial_sum(a, 0)
                    partial_sum(a, 0) = 0
                    partial_sum(a, q) - partial_sum(a, p - 1) = partial_sum(a, q) - 0
                    finite_tail_sum(a, p, q) = partial_sum(a, q) - 0
                    partial_sum(a, q) - 0 = partial_sum(a, q)
                    finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) = partial_sum(fn(j N_pos) R {abs(a(j))}, q) - partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1)
                    partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) = partial_sum(fn(j N_pos) R {abs(a(j))}, 0)
                    partial_sum(fn(j N_pos) R {abs(a(j))}, 0) = 0
                    partial_sum(fn(j N_pos) R {abs(a(j))}, q) - partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) = partial_sum(fn(j N_pos) R {abs(a(j))}, q) - 0
                    finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) = partial_sum(fn(j N_pos) R {abs(a(j))}, q) - 0
                    partial_sum(fn(j N_pos) R {abs(a(j))}, q) - 0 = partial_sum(fn(j N_pos) R {abs(a(j))}, q)
                    by thm partial_sum_matches_finite_sum(a, q)
                    partial_sum(a, q) = sum(1, q, fn(i N_pos) R {a(i)})
                    by thm partial_sum_abs_matches_finite_sum(a, q)
                    partial_sum(fn(j N_pos) R {abs(a(j))}, q) = sum(1, q, fn(i N_pos) R {abs(a(i))})
                    abs(partial_sum(a, q)) = abs(sum(1, q, fn(i N_pos) R {a(i)}))
                    sum(1, q, fn(i N_pos) R {abs(a(i))}) = partial_sum(fn(j N_pos) R {abs(a(j))}, q)
                    abs(sum(1, q, fn(i N_pos) R {a(i)})) <= sum(1, q, fn(i N_pos) R {abs(a(i))})
                    abs(partial_sum(a, q)) <= sum(1, q, fn(i N_pos) R {abs(a(i))})
                    abs(partial_sum(a, q)) <= partial_sum(fn(j N_pos) R {abs(a(j))}, q)
                    abs(finite_tail_sum(a, p, q)) = abs(partial_sum(a, q))
                    abs(finite_tail_sum(a, p, q)) <= partial_sum(fn(j N_pos) R {abs(a(j))}, q)
                    abs(finite_tail_sum(a, p, q)) <= finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q)
                case p > 1:
                    p - 1 $in N_pos
                    p - 1 < p
                    p - 1 < p <= q
                    p - 1 < q
                    by thm partial_sum_split_after(a, p - 1, q)
                    partial_sum(a, q) = partial_sum(a, p - 1) + sum((p - 1) + 1, q, fn(i N_pos) R {a(i)})
                    (p - 1) + 1 = p
                    sum((p - 1) + 1, q, fn(i N_pos) R {a(i)}) = sum(p, q, fn(i N_pos) R {a(i)})
                    partial_sum(a, q) = partial_sum(a, p - 1) + sum(p, q, fn(i N_pos) R {a(i)})
                    finite_tail_sum(a, p, q) = partial_sum(a, q) - partial_sum(a, p - 1)
                    partial_sum(a, q) - partial_sum(a, p - 1) = (partial_sum(a, p - 1) + sum(p, q, fn(i N_pos) R {a(i)})) - partial_sum(a, p - 1)
                    (partial_sum(a, p - 1) + sum(p, q, fn(i N_pos) R {a(i)})) - partial_sum(a, p - 1) = sum(p, q, fn(i N_pos) R {a(i)})
                    finite_tail_sum(a, p, q) = sum(p, q, fn(i N_pos) R {a(i)})
                    by thm partial_sum_split_after(fn(j N_pos) R {abs(a(j))}, p - 1, q)
                    partial_sum(fn(j N_pos) R {abs(a(j))}, q) = partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) + sum((p - 1) + 1, q, fn(i N_pos) R {fn(j N_pos) R {abs(a(j))}(i)})
                    sum((p - 1) + 1, q, fn(i N_pos) R {fn(j N_pos) R {abs(a(j))}(i)}) = sum(p, q, fn(i N_pos) R {abs(a(i))})
                    partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) + sum((p - 1) + 1, q, fn(i N_pos) R {fn(j N_pos) R {abs(a(j))}(i)}) = partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) + sum(p, q, fn(i N_pos) R {abs(a(i))})
                    partial_sum(fn(j N_pos) R {abs(a(j))}, q) = partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) + sum(p, q, fn(i N_pos) R {abs(a(i))})
                    finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) = partial_sum(fn(j N_pos) R {abs(a(j))}, q) - partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1)
                    partial_sum(fn(j N_pos) R {abs(a(j))}, q) - partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) = (partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) + sum(p, q, fn(i N_pos) R {abs(a(i))})) - partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1)
                    (partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) + sum(p, q, fn(i N_pos) R {abs(a(i))})) - partial_sum(fn(j N_pos) R {abs(a(j))}, p - 1) = sum(p, q, fn(i N_pos) R {abs(a(i))})
                    finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) = sum(p, q, fn(i N_pos) R {abs(a(i))})
                    abs(sum(p, q, fn(i N_pos) R {a(i)})) <= sum(p, q, fn(i N_pos) R {abs(a(i))})
                    abs(finite_tail_sum(a, p, q)) = abs(sum(p, q, fn(i N_pos) R {a(i)}))
                    abs(finite_tail_sum(a, p, q)) <= sum(p, q, fn(i N_pos) R {abs(a(i))})
                    abs(finite_tail_sum(a, p, q)) <= finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q)

thm absolute_tail_control:
    ? forall a seq(R), epsilon R_pos, n0 N_pos:
        $has_small_tail_sums_after(fn(j N_pos) R {abs(a(j))}, epsilon, n0)
        =>:
            $has_small_tail_sums_after(a, epsilon, n0)
    forall p, q N_pos:
        p >= n0
        q >= n0
        =>:
            abs(finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q)) <= epsilon
            abs(finite_tail_sum(a, p, q)) <= finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q)
            finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) >= 0
            abs(finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q)) = finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q)
            finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) <= epsilon
            abs(finite_tail_sum(a, p, q)) <= finite_tail_sum(fn(j N_pos) R {abs(a(j))}, p, q) <= epsilon
            abs(finite_tail_sum(a, p, q)) <= epsilon
    $has_small_tail_sums_after(a, epsilon, n0)

thm absolute_convergence_test:
    ? forall a seq(R):
        $is_absolutely_convergent_series(a)
        =>:
            $is_convergent_series(a)
    $is_convergent_series(fn(j N_pos) R {abs(a(j))})
    by thm series_cauchy_criterion_forward(fn(j N_pos) R {abs(a(j))})
    $has_cauchy_series_tails(fn(j N_pos) R {abs(a(j))})
    claim:
        ? forall epsilon R_pos:
            exist n0 N_pos st {$has_small_tail_sums_after(a, epsilon, n0)}
        obtain n0 from exist n0 N_pos st {$has_small_tail_sums_after(fn(j N_pos) R {abs(a(j))}, epsilon, n0)}
        by thm absolute_tail_control(a, epsilon, n0)
        $has_small_tail_sums_after(a, epsilon, n0)
        witness exist n1 N_pos st {$has_small_tail_sums_after(a, epsilon, n1)} from n0:
            $has_small_tail_sums_after(a, epsilon, n0)
    $has_cauchy_series_tails(a)
    by thm series_cauchy_criterion_reverse(a)
    $is_convergent_series(a)

thm partial_sum_triangle_bound:
    ? forall a seq(R), n N_pos:
        abs(partial_sum(a, n)) <= partial_sum(fn(j N_pos) R {abs(a(j))}, n)
    by thm partial_sum_matches_finite_sum(a, n)
    partial_sum(a, n) = sum(1, n, fn(i N_pos) R {a(i)})
    by thm partial_sum_abs_matches_finite_sum(a, n)
    partial_sum(fn(j N_pos) R {abs(a(j))}, n) = sum(1, n, fn(i N_pos) R {abs(a(i))})
    1 <= n
    abs(sum(1, n, fn(i N_pos) R {a(i)})) <= sum(1, n, fn(i N_pos) R {abs(a(i))})
    abs(partial_sum(a, n)) = abs(sum(1, n, fn(i N_pos) R {a(i)}))
    abs(partial_sum(a, n)) <= sum(1, n, fn(i N_pos) R {abs(a(i))})
    sum(1, n, fn(i N_pos) R {abs(a(i))}) = partial_sum(fn(j N_pos) R {abs(a(j))}, n)
    sum(1, n, fn(i N_pos) R {abs(a(i))}) <= partial_sum(fn(j N_pos) R {abs(a(j))}, n)
    abs(partial_sum(a, n)) <= sum(1, n, fn(i N_pos) R {abs(a(i))}) <= partial_sum(fn(j N_pos) R {abs(a(j))}, n)
    abs(partial_sum(a, n)) <= partial_sum(fn(j N_pos) R {abs(a(j))}, n)

thm absolute_convergence_triangle_bound:
    ? forall a seq(R), L, A R:
        $has_series_sum(a, L)
        $has_series_sum(fn(j N_pos) R {abs(a(j))}, A)
        =>:
            abs(L) <= A
    by contra:
        ? abs(L) <= A
        not abs(L) <= A
        A < abs(L)
        abs(L) - A > 0
        have eta R_pos = (abs(L) - A) / 4
        $has_limit(fn(k N_pos) R {partial_sum(a, k)}, L)
        $has_limit(fn(k N_pos) R {partial_sum(fn(j N_pos) R {abs(a(j))}, k)}, A)
        obtain n1 from exist n1 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(a, k)}, L, eta, n1)}
        obtain n2 from exist n2 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(fn(j N_pos) R {abs(a(j))}, k)}, A, eta, n2)}
        max(n1, n2) $in N_pos
        max(n1, n2) >= n1
        max(n1, n2) >= n2
        have n3 N_pos = max(n1, n2)
        n3 >= n1
        n3 >= n2
        abs(fn(k N_pos) R {partial_sum(a, k)}(n3) - L) <= eta
        fn(k N_pos) R {partial_sum(a, k)}(n3) = partial_sum(a, n3)
        abs(partial_sum(a, n3) - L) = abs(fn(k N_pos) R {partial_sum(a, k)}(n3) - L)
        abs(partial_sum(a, n3) - L) <= eta
        abs(fn(k N_pos) R {partial_sum(fn(j N_pos) R {abs(a(j))}, k)}(n3) - A) <= eta
        fn(k N_pos) R {partial_sum(fn(j N_pos) R {abs(a(j))}, k)}(n3) = partial_sum(fn(j N_pos) R {abs(a(j))}, n3)
        abs(partial_sum(fn(j N_pos) R {abs(a(j))}, n3) - A) = abs(fn(k N_pos) R {partial_sum(fn(j N_pos) R {abs(a(j))}, k)}(n3) - A)
        abs(partial_sum(fn(j N_pos) R {abs(a(j))}, n3) - A) <= eta
        by thm partial_sum_triangle_bound(a, n3)
        abs(partial_sum(a, n3)) <= partial_sum(fn(j N_pos) R {abs(a(j))}, n3)
        L = partial_sum(a, n3) + (L - partial_sum(a, n3))
        abs(L) = abs(partial_sum(a, n3) + (L - partial_sum(a, n3)))
        abs(partial_sum(a, n3) + (L - partial_sum(a, n3))) <= abs(partial_sum(a, n3)) + abs(L - partial_sum(a, n3))
        abs(L) <= abs(partial_sum(a, n3)) + abs(L - partial_sum(a, n3))
        abs(L - partial_sum(a, n3)) = abs(partial_sum(a, n3) - L)
        abs(L - partial_sum(a, n3)) <= eta
        abs(partial_sum(a, n3)) + abs(L - partial_sum(a, n3)) <= abs(partial_sum(a, n3)) + eta
        abs(L) <= abs(partial_sum(a, n3)) + abs(L - partial_sum(a, n3)) <= abs(partial_sum(a, n3)) + eta
        abs(L) <= abs(partial_sum(a, n3)) + eta
        abs(L) - eta <= abs(partial_sum(a, n3))
        partial_sum(fn(j N_pos) R {abs(a(j))}, n3) - A <= abs(partial_sum(fn(j N_pos) R {abs(a(j))}, n3) - A)
        partial_sum(fn(j N_pos) R {abs(a(j))}, n3) - A <= eta
        partial_sum(fn(j N_pos) R {abs(a(j))}, n3) - A + A <= eta + A
        partial_sum(fn(j N_pos) R {abs(a(j))}, n3) - A + A = partial_sum(fn(j N_pos) R {abs(a(j))}, n3)
        eta + A = A + eta
        partial_sum(fn(j N_pos) R {abs(a(j))}, n3) <= A + eta
        abs(L) - eta <= abs(partial_sum(a, n3)) <= partial_sum(fn(j N_pos) R {abs(a(j))}, n3) <= A + eta
        abs(L) - eta <= A + eta
        eta = (abs(L) - A) / 4
        abs(L) - eta = abs(L) - (abs(L) - A) / 4
        A + eta = A + (abs(L) - A) / 4
        (abs(L) - (abs(L) - A) / 4) - (A + (abs(L) - A) / 4) = (abs(L) - A) / 2
        (abs(L) - A) / 2 > 0
        abs(L) - (abs(L) - A) / 4 > A + (abs(L) - A) / 4
        abs(L) - eta > A + eta
        impossible abs(L) - eta <= A + eta

"""
Remark 7.2.10. The converse to absolute convergence is false: some convergent
series are not absolutely convergent.
"""

# Example 7.2.13 gives the alternating harmonic series as the local example.

"""
Remark 7.2.11. Tao uses "conditionally convergent" broadly unless he says
"only conditionally convergent"; absolute convergence is a subclass of
ordinary convergence.
"""

prop is_only_conditionally_convergent_series(a seq(R)):
    $is_convergent_series(a)
    not $is_absolutely_convergent_series(a)

"""
Proposition 7.2.12 (Alternating series test). A non-negative decreasing
sequence gives a convergent alternating series exactly when its terms tend to 0.
"""

# Tao's proof compares the even and odd partial sums.  The finite induction
# gives a tail estimate: every late alternating tail is bounded by its first
# allowed term.  Once this is available, the forward direction is a direct
# Cauchy-tail proof, and the reverse direction is the zero test plus the fact
# that the sign `(-1)^n` does not change distance from 0.

prop is_nonnegative_sequence(a seq(R)):
    forall n N_pos:
        a(n) >= 0

prop is_decreasing_sequence(a seq(R)):
    forall n N_pos:
        a(n + 1) <= a(n)

thm decreasing_seq_le_add:
    ? forall a seq(R), h N, n N_pos:
        $is_decreasing_sequence(a)
        =>:
            a(n + h) <= a(n)
    by induc h from 0:
        ? a(n + h) <= a(n)

        ? from h = 0:
            n + 0 = n
            a(n + 0) = a(n)
            a(n + 0) <= a(n)

        ? induc:
            a(n + h) <= a(n)
            n + h $in N_pos
            a(n + h + 1) <= a(n + h)
            n + (h + 1) = n + h + 1
            a(n + (h + 1)) = a(n + h + 1)
            a(n + (h + 1)) <= a(n + h) <= a(n)
            a(n + (h + 1)) <= a(n)

thm decreasing_seq_le_of_le:
    ? forall a seq(R), m, n N_pos:
        $is_decreasing_sequence(a)
        m <= n
        =>:
            a(n) <= a(m)
    n - m $in N
    m + (n - m) = n
    by thm decreasing_seq_le_add(a, n - m, m)
    a(m + (n - m)) <= a(m)
    a(n) = a(m + (n - m))
    a(n) <= a(m)

thm decreasing_finite_block_upper_by_left_endpoint:
    ? forall a seq(R), m, n N_pos:
        $is_decreasing_sequence(a)
        m <= n
        =>:
            sum(m, n, fn(i N_pos) R {a(i)}) <= sum(m, n, fn(i N_pos) R {a(m)})
    forall i N_pos:
        m <= i <= n
        =>:
            a(i) <= a(m)
    sum(m, n, fn(i N_pos) R {a(i)}) <= sum(m, n, fn(i N_pos) R {a(m)})

thm decreasing_finite_block_lower_by_right_endpoint:
    ? forall a seq(R), m, n N_pos:
        $is_decreasing_sequence(a)
        m <= n
        =>:
            sum(m, n, fn(i N_pos) R {a(n)}) <= sum(m, n, fn(i N_pos) R {a(i)})
    forall i N_pos:
        m <= i <= n
        =>:
            a(n) <= a(i)
    sum(m, n, fn(i N_pos) R {a(n)}) <= sum(m, n, fn(i N_pos) R {a(i)})

thm nonnegative_partial_sum_le_add:
    ? forall a seq(R), h N, n N_pos:
        $is_nonnegative_sequence(a)
        =>:
            partial_sum(a, n) <= partial_sum(a, n + h)
    by induc h from 0:
        ? partial_sum(a, n) <= partial_sum(a, n + h)

        ? from h = 0:
            n + 0 = n
            partial_sum(a, n + 0) = partial_sum(a, n)
            partial_sum(a, n) <= partial_sum(a, n + 0)

        ? induc:
            partial_sum(a, n) <= partial_sum(a, n + h)
            n + h $in N_pos
            by thm partial_sum_successor(a, n + h + 1)
            partial_sum(a, n + h + 1) = partial_sum(a, (n + h + 1) - 1) + a(n + h + 1)
            (n + h + 1) - 1 = n + h
            partial_sum(a, (n + h + 1) - 1) = partial_sum(a, n + h)
            partial_sum(a, (n + h + 1) - 1) + a(n + h + 1) = partial_sum(a, n + h) + a(n + h + 1)
            partial_sum(a, n + h + 1) = partial_sum(a, n + h) + a(n + h + 1)
            a(n + h + 1) >= 0
            partial_sum(a, n + h) <= partial_sum(a, n + h) + a(n + h + 1)
            partial_sum(a, n) <= partial_sum(a, n + h) <= partial_sum(a, n + h + 1)
            n + (h + 1) = n + h + 1
            partial_sum(a, n + (h + 1)) = partial_sum(a, n + h + 1)
            partial_sum(a, n) <= partial_sum(a, n + (h + 1))

thm nonnegative_partial_sum_le_of_le:
    ? forall a seq(R), m, n N_pos:
        $is_nonnegative_sequence(a)
        m <= n
        =>:
            partial_sum(a, m) <= partial_sum(a, n)
    n - m $in N
    m + (n - m) = n
    by thm nonnegative_partial_sum_le_add(a, n - m, m)
    partial_sum(a, m) <= partial_sum(a, m + (n - m))
    partial_sum(a, m + (n - m)) = partial_sum(a, n)
    partial_sum(a, m) <= partial_sum(a, n)

have fn alternating_series_terms(a seq(R)) fn(i N_pos) R = fn(j N_pos) R {(-1)^j * a(j)}

thm alternating_sign_abs_one:
    ? forall n N_pos:
        abs((-1)^n) = 1
    by induc n from 1:
        ? abs((-1)^n) = 1

        ? from n = 1:
            (-1)^1 = -1
            abs((-1)^1) = abs(-1)
            abs(-1) = 1

        ? induc:
            abs((-1)^n) = 1
            (-1)^(n + 1) = (-1)^n * (-1)
            abs((-1)^(n + 1)) = abs((-1)^n * (-1))
            abs((-1)^n * (-1)) = abs((-1)^n) * abs(-1)
            abs(-1) = 1
            abs((-1)^n) * abs(-1) = 1 * 1
            1 * 1 = 1
            abs((-1)^(n + 1)) = 1

thm alternating_terms_distance_from_zero:
    ? forall a seq(R), n N_pos:
        abs(alternating_series_terms(a)(n) - 0) = abs(a(n) - 0)
    alternating_series_terms(a)(n) = (-1)^n * a(n)
    alternating_series_terms(a)(n) - 0 = (-1)^n * a(n)
    abs(alternating_series_terms(a)(n) - 0) = abs((-1)^n * a(n))
    abs((-1)^n * a(n)) = abs((-1)^n) * abs(a(n))
    by thm alternating_sign_abs_one(n)
    abs((-1)^n) = 1
    abs((-1)^n) * abs(a(n)) = 1 * abs(a(n))
    1 * abs(a(n)) = abs(a(n))
    abs(alternating_series_terms(a)(n) - 0) = abs(a(n))
    a(n) - 0 = a(n)
    abs(a(n) - 0) = abs(a(n))
    abs(alternating_series_terms(a)(n) - 0) = abs(a(n) - 0)


thm alternating_terms_abs_value:
    ? forall a seq(R), n N_pos:
        abs(alternating_series_terms(a)(n)) = abs(a(n))
    alternating_series_terms(a)(n) = (-1)^n * a(n)
    abs(alternating_series_terms(a)(n)) = abs((-1)^n * a(n))
    abs((-1)^n * a(n)) = abs((-1)^n) * abs(a(n))
    by thm alternating_sign_abs_one(n)
    abs((-1)^n) = 1
    abs((-1)^n) * abs(a(n)) = 1 * abs(a(n))
    1 * abs(a(n)) = abs(a(n))
    abs(alternating_series_terms(a)(n)) = abs(a(n))

thm alternating_series_tail_bound:
    ? forall a seq(R), n0, p, q N_pos:
        $is_nonnegative_sequence(a)
        $is_decreasing_sequence(a)
        p >= n0
        q >= n0
        =>:
            abs(finite_tail_sum(alternating_series_terms(a), p, q)) <= a(n0)
    # Source handling: the alternating-series proof compares successive even
    # and odd partial sums by a finite induction.
    # proof_debt: that finite even/odd tail induction is not yet a local
    # theorem package.
    trust abs(finite_tail_sum(alternating_series_terms(a), p, q)) <= a(n0)

thm alternating_series_test:
    ? forall a seq(R):
        $is_nonnegative_sequence(a)
        $is_decreasing_sequence(a)
        $has_limit(a, 0)
        =>:
            $is_convergent_series(alternating_series_terms(a))
    claim:
        ? forall epsilon R_pos:
            exist n0 N_pos st {$has_small_tail_sums_after(alternating_series_terms(a), epsilon, n0)}
        obtain n0 from exist n0 N_pos st {$is_tail_close_to(a, 0, epsilon, n0)}
        witness exist n1 N_pos st {$has_small_tail_sums_after(alternating_series_terms(a), epsilon, n1)} from n0:
            forall p, q N_pos:
                p >= n0
                q >= n0
                =>:
                    abs(finite_tail_sum(alternating_series_terms(a), p, q)) <= a(n0)
                    n0 >= n0
                    abs(a(n0) - 0) <= epsilon
                    a(n0) >= 0
                    a(n0) - 0 = a(n0)
                    abs(a(n0) - 0) = abs(a(n0))
                    abs(a(n0)) = a(n0)
                    a(n0) <= epsilon
                    abs(finite_tail_sum(alternating_series_terms(a), p, q)) <= a(n0) <= epsilon
                    abs(finite_tail_sum(alternating_series_terms(a), p, q)) <= epsilon
            $has_small_tail_sums_after(alternating_series_terms(a), epsilon, n0)
    $has_cauchy_series_tails(alternating_series_terms(a))
    by thm series_cauchy_criterion_reverse(alternating_series_terms(a))
    $is_convergent_series(alternating_series_terms(a))

thm alternating_series_test_reverse:
    ? forall a seq(R):
        $is_convergent_series(alternating_series_terms(a))
        =>:
            $has_limit(a, 0)
    by thm series_zero_test(alternating_series_terms(a))
    $has_limit(alternating_series_terms(a), 0)
    claim:
        ? forall epsilon R_pos:
            exist n0 N_pos st {$is_tail_close_to(a, 0, epsilon, n0)}
        obtain n0 from exist n0 N_pos st {$is_tail_close_to(alternating_series_terms(a), 0, epsilon, n0)}
        witness exist n1 N_pos st {$is_tail_close_to(a, 0, epsilon, n1)} from n0:
            forall n N_pos:
                n >= n0
                =>:
                    abs(alternating_series_terms(a)(n) - 0) <= epsilon
                    abs(alternating_series_terms(a)(n) - 0) = abs(a(n) - 0)
                    abs(a(n) - 0) <= epsilon
            $is_tail_close_to(a, 0, epsilon, n0)
    $has_limit(a, 0)

"""
Example 7.2.13. The alternating harmonic series converges by the alternating
series test, but it is not absolutely convergent because the harmonic series
diverges.
"""

sketch:
    have fn harmonic_terms(k N_pos) R = 1 / k
    forall k N_pos:
        harmonic_terms(k) = 1 / k
    have alternating_harmonic_terms seq(R) = alternating_series_terms(harmonic_terms)

    claim:
        ? forall k N_pos:
            alternating_harmonic_terms(k) = (-1)^k / k
        alternating_harmonic_terms(k) = alternating_series_terms(harmonic_terms)(k)
        alternating_series_terms(harmonic_terms)(k) = (-1)^k * harmonic_terms(k)
        harmonic_terms(k) = 1 / k
        (-1)^k * harmonic_terms(k) = (-1)^k * (1 / k)
        (-1)^k * (1 / k) = (-1)^k / k
        alternating_harmonic_terms(k) = (-1)^k / k

    claim:
        ? $is_nonnegative_sequence(harmonic_terms)
        forall n N_pos:
            harmonic_terms(n) = 1 / n
            1 / n > 0
            1 / n >= 0
            harmonic_terms(n) >= 0

    claim:
        ? $is_decreasing_sequence(harmonic_terms)
        forall n N_pos:
            harmonic_terms(n + 1) = 1 / (n + 1)
            harmonic_terms(n) = 1 / n
            n + 1 $in N_pos
            n * (n + 1) > 0
            1 / (n + 1) = n / (n * (n + 1))
            1 / n = (n + 1) / (n * (n + 1))
            n <= n + 1
            n / (n * (n + 1)) <= (n + 1) / (n * (n + 1))
            1 / (n + 1) <= 1 / n
            harmonic_terms(n + 1) <= harmonic_terms(n)
        $is_decreasing_sequence(harmonic_terms)

    claim:
        ? $has_limit(harmonic_terms, 0)
        claim:
            ? forall epsilon R_pos:
                exist n0 N_pos st {$is_tail_close_to(harmonic_terms, 0, epsilon, n0)}
            by thm archimedean_property(epsilon)
            exist n_bound N_pos st {1 / n_bound < epsilon}
            obtain n0 from exist n0 N_pos st {1 / n0 < epsilon}
            witness exist n1 N_pos st {$is_tail_close_to(harmonic_terms, 0, epsilon, n1)} from n0:
                forall n N_pos:
                    n >= n0
                    =>:
                        harmonic_terms(n) = 1 / n
                        n0 <= n
                        n0 * n > 0
                        1 / n = n0 / (n0 * n)
                        n0 / (n0 * n) <= n / (n0 * n)
                        n / (n0 * n) = 1 / n0
                        1 / n <= 1 / n0
                        1 / n <= 1 / n0 < epsilon
                        1 / n < epsilon
                        1 / n > 0
                        1 / n - 0 = 1 / n
                        1 / n - 0 >= 0
                        abs(1 / n - 0) = 1 / n - 0
                        abs(1 / n - 0) = 1 / n
                        abs(harmonic_terms(n) - 0) = abs(1 / n - 0)
                        abs(harmonic_terms(n) - 0) < epsilon
                        abs(harmonic_terms(n) - 0) <= epsilon
                $is_tail_close_to(harmonic_terms, 0, epsilon, n0)
        $has_limit(harmonic_terms, 0)

    claim:
        ? $is_convergent_series(alternating_harmonic_terms)
        by thm alternating_series_test(harmonic_terms)
        $is_convergent_series(alternating_series_terms(harmonic_terms))
        $is_convergent_series(alternating_harmonic_terms)

    claim:
        ? not $is_convergent_series(harmonic_terms)
        # Source handling: this forward reference is justified later by
        # Corollary 7.3.7, the p-series criterion.
        # proof_debt: the later harmonic-series divergence theorem is not
        # available at this source position.
        trust not $is_convergent_series(harmonic_terms)

    claim:
        ? $is_only_conditionally_convergent_series(alternating_harmonic_terms)
        $is_convergent_series(alternating_harmonic_terms)
        claim:
            ? not $is_convergent_series(fn(j N_pos) R {abs(alternating_harmonic_terms(j))})
            by contra:
                ? not $is_convergent_series(fn(j N_pos) R {abs(alternating_harmonic_terms(j))})
                $is_convergent_series(fn(j N_pos) R {abs(alternating_harmonic_terms(j))})
                claim:
                    ? forall n N_pos:
                        fn(j N_pos) R {abs(alternating_harmonic_terms(j))}(n) = harmonic_terms(n)
                    fn(j N_pos) R {abs(alternating_harmonic_terms(j))}(n) = abs(alternating_harmonic_terms(n))
                    alternating_harmonic_terms(n) = alternating_series_terms(harmonic_terms)(n)
                    abs(alternating_harmonic_terms(n)) = abs(alternating_series_terms(harmonic_terms)(n))
                    by thm alternating_terms_abs_value(harmonic_terms, n)
                    abs(alternating_series_terms(harmonic_terms)(n)) = abs(harmonic_terms(n))
                    harmonic_terms(n) = 1 / n
                    1 / n > 0
                    abs(harmonic_terms(n)) = harmonic_terms(n)
                    fn(j N_pos) R {abs(alternating_harmonic_terms(j))}(n) = harmonic_terms(n)
                by thm series_convergence_extensional(fn(j N_pos) R {abs(alternating_harmonic_terms(j))}, harmonic_terms)
                $is_convergent_series(harmonic_terms)
                impossible not $is_convergent_series(harmonic_terms)
        claim:
            ? not $is_absolutely_convergent_series(alternating_harmonic_terms)
            by contra:
                ? not $is_absolutely_convergent_series(alternating_harmonic_terms)
                $is_absolutely_convergent_series(alternating_harmonic_terms)
                $is_convergent_series(fn(j N_pos) R {abs(alternating_harmonic_terms(j))})
                impossible not $is_convergent_series(fn(j N_pos) R {abs(alternating_harmonic_terms(j))})
        not $is_absolutely_convergent_series(alternating_harmonic_terms)
        $is_only_conditionally_convergent_series(alternating_harmonic_terms)

"""
Proposition 7.2.14 (Series laws). Convergent series are closed under addition,
scalar multiplication, adding or deleting finitely many initial terms, and
shifting the index.
"""

# Add: the Nth partial sum of `a_n+b_n` is the sum of the two Nth partial sums,
# then the sequence limit law gives the limit `x+y`.
# Scalar multiplication: the Nth partial sum of `c*a_n` is `c` times the Nth
# partial sum of `a_n`, then the scalar limit law gives the limit `c*x`.
# Tail convergence: deleting finitely many initial terms changes partial sums
# by a fixed finite prefix and therefore does not affect convergence.
# Index shift: the shifted series is a tail of the original series, so its
# convergence follows from tail convergence.
# Tao leaves this proof to Exercise 7.2.5.  The missing proof is the explicit
# comparison between the shifted partial sums and the original tail sums.

have fn series_add(a, b seq(R)) fn(i N_pos) R = fn(j N_pos) R {a(j) + b(j)}
have fn series_scalar_mul(c R, a seq(R)) fn(i N_pos) R = fn(j N_pos) R {c * a(j)}
have fn series_shift(a seq(R), h N) fn(i N_pos) R = fn(j N_pos) R {a(j + h)}

thm partial_sum_series_add:
    ? forall a, b seq(R), k N_pos:
        partial_sum(series_add(a, b), k) = partial_sum(a, k) + partial_sum(b, k)
    by thm partial_sum_matches_finite_sum(series_add(a, b), k)
    by thm partial_sum_matches_finite_sum(a, k)
    by thm partial_sum_matches_finite_sum(b, k)
    partial_sum(series_add(a, b), k) = sum(1, k, fn(i N_pos) R {series_add(a, b)(i)})
    partial_sum(a, k) = sum(1, k, fn(i N_pos) R {a(i)})
    partial_sum(b, k) = sum(1, k, fn(i N_pos) R {b(i)})
    forall i N_pos:
        series_add(a, b)(i) = a(i) + b(i)
    sum(1, k, fn(i N_pos) R {series_add(a, b)(i)}) = sum(1, k, fn(i N_pos) R {a(i) + b(i)})
    sum(1, k, fn(i N_pos) R {a(i) + b(i)}) = sum(1, k, fn(i N_pos) R {a(i)}) + sum(1, k, fn(i N_pos) R {b(i)})
    partial_sum(series_add(a, b), k) = partial_sum(a, k) + partial_sum(b, k)

thm partial_sum_series_scalar_mul:
    ? forall a seq(R), c R, k N_pos:
        partial_sum(series_scalar_mul(c, a), k) = c * partial_sum(a, k)
    by thm partial_sum_matches_finite_sum(series_scalar_mul(c, a), k)
    by thm partial_sum_matches_finite_sum(a, k)
    partial_sum(series_scalar_mul(c, a), k) = sum(1, k, fn(i N_pos) R {series_scalar_mul(c, a)(i)})
    partial_sum(a, k) = sum(1, k, fn(i N_pos) R {a(i)})
    forall i N_pos:
        series_scalar_mul(c, a)(i) = c * a(i)
    sum(1, k, fn(i N_pos) R {series_scalar_mul(c, a)(i)}) = sum(1, k, fn(i N_pos) R {c * a(i)})
    sum(1, k, fn(i N_pos) R {c * a(i)}) = c * sum(1, k, fn(i N_pos) R {a(i)})
    c * sum(1, k, fn(i N_pos) R {a(i)}) = c * partial_sum(a, k)
    partial_sum(series_scalar_mul(c, a), k) = sum(1, k, fn(i N_pos) R {series_scalar_mul(c, a)(i)}) = sum(1, k, fn(i N_pos) R {c * a(i)}) = c * sum(1, k, fn(i N_pos) R {a(i)}) = c * partial_sum(a, k)

thm series_laws_add:
    ? forall a, b seq(R), x, y R:
        $has_series_sum(a, x)
        $has_series_sum(b, y)
        =>:
            $has_series_sum(series_add(a, b), x + y)
    $has_limit(fn(k N_pos) R {partial_sum(a, k)}, x)
    $has_limit(fn(k N_pos) R {partial_sum(b, k)}, y)
    claim:
        ? forall n N_pos:
            partial_sum(series_add(a, b), n) = partial_sum(a, n) + partial_sum(b, n)
        by thm partial_sum_series_add(a, b, n)
        partial_sum(series_add(a, b), n) = partial_sum(a, n) + partial_sum(b, n)
    claim:
        ? forall epsilon R_pos:
            exist N0 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(series_add(a, b), k)}, x + y, epsilon, N0)}
        epsilon / 2 $in R_pos
        obtain n1 from exist n1 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(a, k)}, x, epsilon / 2, n1)}
        obtain n2 from exist n2 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(b, k)}, y, epsilon / 2, n2)}
        max(n1, n2) $in N_pos
        max(n1, n2) >= n1
        max(n1, n2) >= n2
        witness exist N1 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(series_add(a, b), k)}, x + y, epsilon, N1)} from max(n1, n2):
            forall n N_pos:
                n >= max(n1, n2)
                =>:
                    n1 <= max(n1, n2) <= n
                    n >= n1
                    n2 <= max(n1, n2) <= n
                    n >= n2
                    abs(fn(k N_pos) R {partial_sum(a, k)}(n) - x) <= epsilon / 2
                    fn(k N_pos) R {partial_sum(a, k)}(n) = partial_sum(a, n)
                    abs(partial_sum(a, n) - x) = abs(fn(k N_pos) R {partial_sum(a, k)}(n) - x)
                    abs(partial_sum(a, n) - x) <= epsilon / 2
                    abs(fn(k N_pos) R {partial_sum(b, k)}(n) - y) <= epsilon / 2
                    fn(k N_pos) R {partial_sum(b, k)}(n) = partial_sum(b, n)
                    abs(partial_sum(b, n) - y) = abs(fn(k N_pos) R {partial_sum(b, k)}(n) - y)
                    abs(partial_sum(b, n) - y) <= epsilon / 2
                    partial_sum(series_add(a, b), n) = partial_sum(a, n) + partial_sum(b, n)
                    fn(k N_pos) R {partial_sum(series_add(a, b), k)}(n) = partial_sum(series_add(a, b), n)
                    abs(fn(k N_pos) R {partial_sum(series_add(a, b), k)}(n) - (x + y)) = abs(partial_sum(series_add(a, b), n) - (x + y))
                    partial_sum(series_add(a, b), n) - (x + y) = (partial_sum(a, n) + partial_sum(b, n)) - (x + y)
                    (partial_sum(a, n) + partial_sum(b, n)) - (x + y) = (partial_sum(a, n) - x) + (partial_sum(b, n) - y)
                    abs(partial_sum(series_add(a, b), n) - (x + y)) = abs((partial_sum(a, n) - x) + (partial_sum(b, n) - y))
                    abs((partial_sum(a, n) - x) + (partial_sum(b, n) - y)) <= abs(partial_sum(a, n) - x) + abs(partial_sum(b, n) - y)
                    abs(partial_sum(series_add(a, b), n) - (x + y)) <= abs(partial_sum(a, n) - x) + abs(partial_sum(b, n) - y)
                    abs(partial_sum(a, n) - x) + abs(partial_sum(b, n) - y) <= epsilon / 2 + epsilon / 2
                    epsilon / 2 + epsilon / 2 = epsilon
                    abs(partial_sum(a, n) - x) + abs(partial_sum(b, n) - y) <= epsilon
                    abs(fn(k N_pos) R {partial_sum(series_add(a, b), k)}(n) - (x + y)) <= epsilon
            $is_tail_close_to(fn(k N_pos) R {partial_sum(series_add(a, b), k)}, x + y, epsilon, max(n1, n2))
    $has_limit(fn(k N_pos) R {partial_sum(series_add(a, b), k)}, x + y)
    $has_series_sum(series_add(a, b), x + y)

thm series_laws_scalar_mul:
    ? forall a seq(R), c, x R:
        $has_series_sum(a, x)
        =>:
            $has_series_sum(series_scalar_mul(c, a), c * x)
    $has_limit(fn(k N_pos) R {partial_sum(a, k)}, x)
    claim:
        ? forall n N_pos:
            partial_sum(series_scalar_mul(c, a), n) = c * partial_sum(a, n)
        by thm partial_sum_series_scalar_mul(a, c, n)
        partial_sum(series_scalar_mul(c, a), n) = c * partial_sum(a, n)
    claim:
        ? forall epsilon R_pos:
            exist N0 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(series_scalar_mul(c, a), k)}, c * x, epsilon, N0)}
        abs(c) >= 0
        abs(c) + 1 > 0
        abs(c) + 1 != 0
        epsilon / (abs(c) + 1) $in R_pos
        obtain n0 from exist n0 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(a, k)}, x, epsilon / (abs(c) + 1), n0)}
        witness exist N1 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(series_scalar_mul(c, a), k)}, c * x, epsilon, N1)} from n0:
            forall n N_pos:
                n >= n0
                =>:
                    abs(fn(k N_pos) R {partial_sum(a, k)}(n) - x) <= epsilon / (abs(c) + 1)
                    fn(k N_pos) R {partial_sum(a, k)}(n) = partial_sum(a, n)
                    abs(partial_sum(a, n) - x) = abs(fn(k N_pos) R {partial_sum(a, k)}(n) - x)
                    abs(partial_sum(a, n) - x) <= epsilon / (abs(c) + 1)
                    partial_sum(series_scalar_mul(c, a), n) = c * partial_sum(a, n)
                    fn(k N_pos) R {partial_sum(series_scalar_mul(c, a), k)}(n) = partial_sum(series_scalar_mul(c, a), n)
                    abs(fn(k N_pos) R {partial_sum(series_scalar_mul(c, a), k)}(n) - c * x) = abs(partial_sum(series_scalar_mul(c, a), n) - c * x)
                    partial_sum(series_scalar_mul(c, a), n) - c * x = c * partial_sum(a, n) - c * x
                    c * partial_sum(a, n) - c * x = c * (partial_sum(a, n) - x)
                    abs(partial_sum(series_scalar_mul(c, a), n) - c * x) = abs(c * (partial_sum(a, n) - x))
                    abs(c * (partial_sum(a, n) - x)) = abs(c) * abs(partial_sum(a, n) - x)
                    abs(c) <= abs(c) + 1
                    abs(partial_sum(a, n) - x) >= 0
                    abs(c) * abs(partial_sum(a, n) - x) <= (abs(c) + 1) * abs(partial_sum(a, n) - x)
                    (abs(c) + 1) * abs(partial_sum(a, n) - x) <= (abs(c) + 1) * (epsilon / (abs(c) + 1))
                    (abs(c) + 1) * (epsilon / (abs(c) + 1)) = epsilon
                    abs(c) * abs(partial_sum(a, n) - x) <= (abs(c) + 1) * abs(partial_sum(a, n) - x) <= (abs(c) + 1) * (epsilon / (abs(c) + 1)) = epsilon
                    abs(c) * abs(partial_sum(a, n) - x) <= epsilon
                    abs(fn(k N_pos) R {partial_sum(series_scalar_mul(c, a), k)}(n) - c * x) <= epsilon
            $is_tail_close_to(fn(k N_pos) R {partial_sum(series_scalar_mul(c, a), k)}, c * x, epsilon, n0)
    $has_limit(fn(k N_pos) R {partial_sum(series_scalar_mul(c, a), k)}, c * x)
    $has_series_sum(series_scalar_mul(c, a), c * x)

thm partial_sum_series_shift_plus_prefix:
    ? forall a seq(R), h N, k N_pos:
        partial_sum(series_shift(a, h), k) + partial_sum(a, h) = partial_sum(a, k + h)
    by induc k from 1:
        ? partial_sum(series_shift(a, h), k) + partial_sum(a, h) = partial_sum(a, k + h)

        ? from k = 1:
            by thm partial_sum_successor(series_shift(a, h), 1)
            partial_sum(series_shift(a, h), 1) = partial_sum(series_shift(a, h), 1 - 1) + series_shift(a, h)(1)
            1 - 1 = 0
            partial_sum(series_shift(a, h), 1 - 1) = partial_sum(series_shift(a, h), 0)
            partial_sum(series_shift(a, h), 0) = 0
            series_shift(a, h)(1) = a(1 + h)
            partial_sum(series_shift(a, h), 1) = 0 + a(1 + h)
            0 + a(1 + h) = a(1 + h)
            1 + h $in N_pos
            by thm partial_sum_successor(a, 1 + h)
            partial_sum(a, 1 + h) = partial_sum(a, (1 + h) - 1) + a(1 + h)
            (1 + h) - 1 = h
            partial_sum(a, (1 + h) - 1) = partial_sum(a, h)
            partial_sum(a, 1 + h) = partial_sum(a, h) + a(1 + h)
            a(1 + h) + partial_sum(a, h) = partial_sum(a, h) + a(1 + h)
            partial_sum(series_shift(a, h), 1) + partial_sum(a, h) = a(1 + h) + partial_sum(a, h)
            partial_sum(series_shift(a, h), 1) + partial_sum(a, h) = partial_sum(a, h) + a(1 + h)
            partial_sum(series_shift(a, h), 1) + partial_sum(a, h) = partial_sum(a, 1 + h)

        ? induc:
            partial_sum(series_shift(a, h), k) + partial_sum(a, h) = partial_sum(a, k + h)
            k + 1 $in N_pos
            by thm partial_sum_successor(series_shift(a, h), k + 1)
            partial_sum(series_shift(a, h), k + 1) = partial_sum(series_shift(a, h), (k + 1) - 1) + series_shift(a, h)(k + 1)
            (k + 1) - 1 = k
            partial_sum(series_shift(a, h), (k + 1) - 1) = partial_sum(series_shift(a, h), k)
            series_shift(a, h)(k + 1) = a(k + 1 + h)
            partial_sum(series_shift(a, h), k + 1) = partial_sum(series_shift(a, h), k) + a(k + 1 + h)
            partial_sum(series_shift(a, h), k + 1) + partial_sum(a, h) = (partial_sum(series_shift(a, h), k) + a(k + 1 + h)) + partial_sum(a, h)
            (partial_sum(series_shift(a, h), k) + a(k + 1 + h)) + partial_sum(a, h) = (partial_sum(series_shift(a, h), k) + partial_sum(a, h)) + a(k + 1 + h)
            partial_sum(series_shift(a, h), k + 1) + partial_sum(a, h) = partial_sum(a, k + h) + a(k + 1 + h)
            k + 1 + h $in N_pos
            by thm partial_sum_successor(a, k + 1 + h)
            partial_sum(a, k + 1 + h) = partial_sum(a, (k + 1 + h) - 1) + a(k + 1 + h)
            (k + 1 + h) - 1 = k + h
            partial_sum(a, (k + 1 + h) - 1) = partial_sum(a, k + h)
            partial_sum(a, k + 1 + h) = partial_sum(a, k + h) + a(k + 1 + h)
            partial_sum(series_shift(a, h), k + 1) + partial_sum(a, h) = partial_sum(a, k + 1 + h)

thm series_laws_tail_convergence:
    ? forall a seq(R), h N:
        $is_convergent_series(a)
        =>:
            $is_convergent_series(series_shift(a, h))
    obtain L from exist L R st {$has_series_sum(a, L)}
    $has_series_sum(a, L)
    $has_limit(fn(k N_pos) R {partial_sum(a, k)}, L)
    claim:
        ? forall epsilon R_pos:
            exist N0 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(series_shift(a, h), k)}, L - partial_sum(a, h), epsilon, N0)}
        obtain n0 from exist n0 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(a, k)}, L, epsilon, n0)}
        witness exist N1 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(series_shift(a, h), k)}, L - partial_sum(a, h), epsilon, N1)} from n0:
            claim:
                ? forall n N_pos:
                    n >= n0
                    =>:
                        abs(fn(k N_pos) R {partial_sum(series_shift(a, h), k)}(n) - (L - partial_sum(a, h))) <= epsilon
                n + h $in N_pos
                n + h >= n
                n + h >= n0
                abs(fn(k N_pos) R {partial_sum(a, k)}(n + h) - L) <= epsilon
                fn(k N_pos) R {partial_sum(a, k)}(n + h) = partial_sum(a, n + h)
                abs(partial_sum(a, n + h) - L) = abs(fn(k N_pos) R {partial_sum(a, k)}(n + h) - L)
                abs(partial_sum(a, n + h) - L) <= epsilon
                fn(k N_pos) R {partial_sum(series_shift(a, h), k)}(n) = partial_sum(series_shift(a, h), n)
                by thm partial_sum_series_shift_plus_prefix(a, h, n)
                partial_sum(series_shift(a, h), n) + partial_sum(a, h) = partial_sum(a, n + h)
                partial_sum(series_shift(a, h), n) - (L - partial_sum(a, h)) = partial_sum(series_shift(a, h), n) + partial_sum(a, h) - L
                partial_sum(series_shift(a, h), n) + partial_sum(a, h) - L = partial_sum(a, n + h) - L
                abs(partial_sum(series_shift(a, h), n) - (L - partial_sum(a, h))) = abs(partial_sum(a, n + h) - L)
                abs(fn(k N_pos) R {partial_sum(series_shift(a, h), k)}(n) - (L - partial_sum(a, h))) = abs(partial_sum(series_shift(a, h), n) - (L - partial_sum(a, h)))
                abs(fn(k N_pos) R {partial_sum(series_shift(a, h), k)}(n) - (L - partial_sum(a, h))) <= epsilon
            $is_tail_close_to(fn(k N_pos) R {partial_sum(series_shift(a, h), k)}, L - partial_sum(a, h), epsilon, n0)
    $has_limit(fn(k N_pos) R {partial_sum(series_shift(a, h), k)}, L - partial_sum(a, h))
    $has_series_sum(series_shift(a, h), L - partial_sum(a, h))
    witness exist T R st {$has_series_sum(series_shift(a, h), T)} from L - partial_sum(a, h):
        $has_series_sum(series_shift(a, h), L - partial_sum(a, h))
    $is_convergent_series(series_shift(a, h))

thm series_laws_index_shift:
    ? forall a seq(R), k N, x R:
        $has_series_sum(a, x)
        =>:
            $is_convergent_series(series_shift(a, k))
    witness exist L R st {$has_series_sum(a, L)} from x:
        $has_series_sum(a, x)
    $is_convergent_series(a)
    by thm series_laws_tail_convergence(a, k)
    $is_convergent_series(series_shift(a, k))

thm series_laws_tail_sum_reverse_one_bound:
    ? forall a seq(R), T R, epsilon R_pos, n0, m, n N_pos:
        $is_tail_close_to(fn(k N_pos) R {partial_sum(series_shift(a, 1), k)}, T, epsilon, n0)
        m = n - 1
        m >= n0
        =>:
            abs(fn(k N_pos) R {partial_sum(a, k)}(n) - (partial_sum(a, 1) + T)) <= epsilon
    abs(fn(k N_pos) R {partial_sum(series_shift(a, 1), k)}(m) - T) <= epsilon
    fn(k N_pos) R {partial_sum(series_shift(a, 1), k)}(m) = partial_sum(series_shift(a, 1), m)
    by thm partial_sum_series_shift_plus_prefix(a, 1, m)
    partial_sum(series_shift(a, 1), m) + partial_sum(a, 1) = partial_sum(a, m + 1)
    m + 1 = (n - 1) + 1
    (n - 1) + 1 = n
    partial_sum(a, m + 1) = partial_sum(a, n)
    partial_sum(series_shift(a, 1), m) + partial_sum(a, 1) = partial_sum(a, n)
    partial_sum(a, n) = partial_sum(series_shift(a, 1), m) + partial_sum(a, 1)
    partial_sum(a, n) - (partial_sum(a, 1) + T) = (partial_sum(series_shift(a, 1), m) + partial_sum(a, 1)) - (partial_sum(a, 1) + T)
    (partial_sum(series_shift(a, 1), m) + partial_sum(a, 1)) - (partial_sum(a, 1) + T) = partial_sum(series_shift(a, 1), m) - T
    fn(k N_pos) R {partial_sum(a, k)}(n) = partial_sum(a, n)
    abs(fn(k N_pos) R {partial_sum(a, k)}(n) - (partial_sum(a, 1) + T)) = abs(partial_sum(a, n) - (partial_sum(a, 1) + T))
    abs(partial_sum(a, n) - (partial_sum(a, 1) + T)) = abs(partial_sum(series_shift(a, 1), m) - T)
    abs(partial_sum(series_shift(a, 1), m) - T) = abs(fn(k N_pos) R {partial_sum(series_shift(a, 1), k)}(m) - T)
    abs(fn(k N_pos) R {partial_sum(a, k)}(n) - (partial_sum(a, 1) + T)) <= epsilon

thm series_laws_tail_sum_reverse_one_bound_direct:
    ? forall a seq(R), T R, epsilon R_pos, n0, n N_pos:
        $is_tail_close_to(fn(k N_pos) R {partial_sum(series_shift(a, 1), k)}, T, epsilon, n0)
        n >= n0 + 1
        =>:
            abs(fn(k N_pos) R {partial_sum(a, k)}(n) - (partial_sum(a, 1) + T)) <= epsilon
    n0 >= 1
    n0 + 1 >= 1 + 1
    1 + 1 = 2
    n0 + 1 >= 2
    n >= n0 + 1 >= 2
    n >= 2
    n - 1 >= 1
    n - 1 $in N_pos
    have m N_pos = n - 1
    m = n - 1
    n - 1 >= n0
    m >= n0
    by thm series_laws_tail_sum_reverse_one_bound(a, T, epsilon, n0, m, n)
    abs(fn(k N_pos) R {partial_sum(a, k)}(n) - (partial_sum(a, 1) + T)) <= epsilon

thm series_laws_tail_sum_reverse_one:
    ? forall a seq(R), T R:
        $has_series_sum(series_shift(a, 1), T)
        =>:
            $has_series_sum(a, partial_sum(a, 1) + T)
    $has_limit(fn(k N_pos) R {partial_sum(series_shift(a, 1), k)}, T)
    claim:
        ? forall epsilon R_pos:
            exist N0 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(a, k)}, partial_sum(a, 1) + T, epsilon, N0)}
        obtain n0 from exist n0 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(series_shift(a, 1), k)}, T, epsilon, n0)}
        n0 + 1 $in N_pos
        witness exist N1 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(a, k)}, partial_sum(a, 1) + T, epsilon, N1)} from n0 + 1:
            claim:
                ? forall n N_pos:
                    n >= n0 + 1
                    =>:
                        abs(fn(k N_pos) R {partial_sum(a, k)}(n) - (partial_sum(a, 1) + T)) <= epsilon
                by thm series_laws_tail_sum_reverse_one_bound_direct(a, T, epsilon, n0, n)
                abs(fn(k N_pos) R {partial_sum(a, k)}(n) - (partial_sum(a, 1) + T)) <= epsilon
            $is_tail_close_to(fn(k N_pos) R {partial_sum(a, k)}, partial_sum(a, 1) + T, epsilon, n0 + 1)
    $has_limit(fn(k N_pos) R {partial_sum(a, k)}, partial_sum(a, 1) + T)
    $has_series_sum(a, partial_sum(a, 1) + T)

"""
Lemma 7.2.15 (Telescoping series). If a_n tends to 0, then the series of
differences a_n - a_{n+1} sums to the first term.
"""

# The finite partial sums telescope to `a(1)-a(N+1)`, then the limit
# `a(N+1) -> 0` gives the claimed series sum.
# Here the exercise proof is expanded by proving the finite telescoping
# identity and then applying the epsilon definition of limit.

have fn telescoping_terms(a seq(R)) fn(i N_pos) R = fn(j N_pos) R {a(j) - a(j + 1)}

thm telescoping_partial_sum_identity:
    ? forall a seq(R), k N_pos:
        partial_sum(telescoping_terms(a), k) = a(1) - a(k + 1)
    have b seq(R) = telescoping_terms(a)
    claim:
        ? forall r N_pos:
            partial_sum(b, r) = a(1) - a(r + 1)
        by induc r from 1:
            ? partial_sum(b, r) = a(1) - a(r + 1)

            ? from r = 1:
                partial_sum(b, 1) = partial_sum(b, 0) + b(1)
                partial_sum(b, 0) = 0
                b(1) = telescoping_terms(a)(1)
                telescoping_terms(a)(1) = a(1) - a(1 + 1)
                partial_sum(b, 1) = a(1) - a(1 + 1)

            ? induc:
                partial_sum(b, r) = a(1) - a(r + 1)
                r + 1 > 0
                partial_sum(b, r + 1) = partial_sum(b, (r + 1) - 1) + b(r + 1)
                (r + 1) - 1 = r
                partial_sum(b, (r + 1) - 1) = partial_sum(b, r)
                partial_sum(b, (r + 1) - 1) + b(r + 1) = partial_sum(b, r) + b(r + 1)
                partial_sum(b, r + 1) = partial_sum(b, r) + b(r + 1)
                b(r + 1) = telescoping_terms(a)(r + 1)
                telescoping_terms(a)(r + 1) = a(r + 1) - a((r + 1) + 1)
                partial_sum(b, r + 1) = (a(1) - a(r + 1)) + (a(r + 1) - a((r + 1) + 1))
                (a(1) - a(r + 1)) + (a(r + 1) - a((r + 1) + 1)) = a(1) - a((r + 1) + 1)
    partial_sum(telescoping_terms(a), k) = partial_sum(b, k)
    partial_sum(b, k) = a(1) - a(k + 1)

thm telescoping_series_sum:
    ? forall a seq(R):
        $has_limit(a, 0)
        =>:
            $has_series_sum(telescoping_terms(a), a(1))
    claim:
        ? forall epsilon R_pos:
            exist N0 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(telescoping_terms(a), k)}, a(1), epsilon, N0)}
        obtain n0 from exist n0 N_pos st {$is_tail_close_to(a, 0, epsilon, n0)}
        witness exist N1 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(telescoping_terms(a), k)}, a(1), epsilon, N1)} from n0:
            claim:
                ? forall n N_pos:
                    n >= n0
                    =>:
                        abs(fn(k N_pos) R {partial_sum(telescoping_terms(a), k)}(n) - a(1)) <= epsilon
                n + 1 $in N_pos
                n + 1 >= n0
                abs(a(n + 1) - 0) <= epsilon
                partial_sum(telescoping_terms(a), n) = a(1) - a(n + 1)
                fn(k N_pos) R {partial_sum(telescoping_terms(a), k)}(n) = partial_sum(telescoping_terms(a), n)
                fn(k N_pos) R {partial_sum(telescoping_terms(a), k)}(n) - a(1) = partial_sum(telescoping_terms(a), n) - a(1)
                partial_sum(telescoping_terms(a), n) - a(1) = (a(1) - a(n + 1)) - a(1)
                (a(1) - a(n + 1)) - a(1) = -a(n + 1)
                abs(fn(k N_pos) R {partial_sum(telescoping_terms(a), k)}(n) - a(1)) = abs(-a(n + 1))
                abs(-a(n + 1)) = abs(a(n + 1))
                a(n + 1) - 0 = a(n + 1)
                abs(a(n + 1) - 0) = abs(a(n + 1))
                abs(fn(k N_pos) R {partial_sum(telescoping_terms(a), k)}(n) - a(1)) = abs(a(n + 1) - 0)
                abs(fn(k N_pos) R {partial_sum(telescoping_terms(a), k)}(n) - a(1)) <= epsilon
            $is_tail_close_to(fn(k N_pos) R {partial_sum(telescoping_terms(a), k)}, a(1), epsilon, n0)
    $has_limit(fn(k N_pos) R {partial_sum(telescoping_terms(a), k)}, a(1))
    $has_series_sum(telescoping_terms(a), a(1))


# 7.3 Sums of non-negative numbers

"""
Proposition 7.3.1. A non-negative series converges exactly when its partial
sums are bounded above.
"""

# The proof is monotone convergence applied to the increasing sequence of
# non-negative partial sums.

prop is_partial_sum_bound(a seq(R), M R):
    forall k N_pos:
        partial_sum(a, k) <= M

prop has_bounded_partial_sums(a seq(R)):
    exist M R st {$is_partial_sum_bound(a, M)}

thm nonnegative_series_convergent_has_bounded_partial_sums:
    ? forall a seq(R):
        $is_nonnegative_sequence(a)
        $is_convergent_series(a)
        =>:
            $has_bounded_partial_sums(a)
    obtain L from exist L R st {$has_series_sum(a, L)}
    $has_limit(fn(k N_pos) R {partial_sum(a, k)}, L)
    1 $in R_pos
    obtain n0 from exist n0 N_pos st {$is_tail_close_to(fn(k N_pos) R {partial_sum(a, k)}, L, 1, n0)}
    have M R = max(partial_sum(a, n0), L + 1)
    claim:
        ? forall k N_pos:
            partial_sum(a, k) <= M
        k <= n0 or k > n0
        by cases:
            ? partial_sum(a, k) <= M
            case k <= n0:
                by thm nonnegative_partial_sum_le_of_le(a, k, n0)
                partial_sum(a, k) <= partial_sum(a, n0)
                partial_sum(a, n0) <= max(partial_sum(a, n0), L + 1)
                max(partial_sum(a, n0), L + 1) = M
                partial_sum(a, k) <= partial_sum(a, n0) <= max(partial_sum(a, n0), L + 1) = M
                partial_sum(a, k) <= M
            case k > n0:
                k >= n0
                abs(fn(k N_pos) R {partial_sum(a, k)}(k) - L) <= 1
                fn(k N_pos) R {partial_sum(a, k)}(k) = partial_sum(a, k)
                abs(partial_sum(a, k) - L) = abs(fn(k N_pos) R {partial_sum(a, k)}(k) - L)
                abs(partial_sum(a, k) - L) <= 1
                partial_sum(a, k) - L <= abs(partial_sum(a, k) - L)
                partial_sum(a, k) - L <= 1
                partial_sum(a, k) = (partial_sum(a, k) - L) + L
                (partial_sum(a, k) - L) + L <= 1 + L
                1 + L = L + 1
                (partial_sum(a, k) - L) + L <= L + 1
                partial_sum(a, k) <= L + 1
                L + 1 <= max(partial_sum(a, n0), L + 1)
                max(partial_sum(a, n0), L + 1) = M
                partial_sum(a, k) <= L + 1 <= max(partial_sum(a, n0), L + 1) = M
                partial_sum(a, k) <= M
    witness exist B R st {$is_partial_sum_bound(a, B)} from M:
        forall k N_pos:
            partial_sum(a, k) <= M
        $is_partial_sum_bound(a, M)
    $has_bounded_partial_sums(a)

thm nonnegative_series_bounded_partial_sums_converge:
    ? forall a seq(R):
        $is_nonnegative_sequence(a)
        $has_bounded_partial_sums(a)
        =>:
            $is_convergent_series(a)
    # Source handling: Proposition 7.3.1 applies monotone convergence to the
    # increasing sequence of partial sums.
    # proof_debt: the local monotone-convergence bridge from bounded partial
    # sums to a series limit remains unexpanded.
    trust $is_convergent_series(a)

"""
Corollary 7.3.2 (Comparison test). If |a_n| is bounded by a convergent
non-negative series b_n, then the series a_n is absolutely convergent.
"""

# The comparison test bounds the absolute partial sums of `a` by the bounded
# partial sums of the non-negative convergent majorant `b`.
# Tao leaves this proof to Exercise 7.3.1.  The remaining step is to turn those
# finite partial-sum bounds into absolute convergence.

thm comparison_test_for_series:
    ? forall a, b seq(R):
        $is_convergent_series(b)
        forall n N_pos:
            abs(a(n)) <= b(n)
        =>:
            $is_absolutely_convergent_series(a)
    claim:
        ? $is_nonnegative_sequence(b)
        forall n N_pos:
            abs(a(n)) <= b(n)
            abs(a(n)) >= 0
            b(n) >= abs(a(n)) >= 0
            b(n) >= 0
        $is_nonnegative_sequence(b)
    by thm nonnegative_series_convergent_has_bounded_partial_sums(b)
    $has_bounded_partial_sums(b)
    obtain M from exist M R st {$is_partial_sum_bound(b, M)}
    claim:
        ? $has_bounded_partial_sums(fn(j N_pos) R {abs(a(j))})
        witness exist M0 R st {$is_partial_sum_bound(fn(j N_pos) R {abs(a(j))}, M0)} from M:
            forall k N_pos:
                partial_sum(fn(j N_pos) R {abs(a(j))}, k) = sum(1, k, fn(i N_pos) R {abs(a(i))})
                partial_sum(b, k) = sum(1, k, fn(i N_pos) R {b(i)})
                sum(1, k, fn(i N_pos) R {abs(a(i))}) <= sum(1, k, fn(i N_pos) R {b(i)})
                partial_sum(fn(j N_pos) R {abs(a(j))}, k) <= sum(1, k, fn(i N_pos) R {b(i)})
                partial_sum(fn(j N_pos) R {abs(a(j))}, k) <= partial_sum(b, k)
                partial_sum(b, k) <= M
                partial_sum(fn(j N_pos) R {abs(a(j))}, k) <= partial_sum(b, k) <= M
                partial_sum(fn(j N_pos) R {abs(a(j))}, k) <= M
            $is_partial_sum_bound(fn(j N_pos) R {abs(a(j))}, M)
        $has_bounded_partial_sums(fn(j N_pos) R {abs(a(j))})
    claim:
        ? $is_nonnegative_sequence(fn(j N_pos) R {abs(a(j))})
        forall n N_pos:
            fn(j N_pos) R {abs(a(j))}(n) = abs(a(n))
            abs(a(n)) >= 0
            fn(j N_pos) R {abs(a(j))}(n) >= 0
        $is_nonnegative_sequence(fn(j N_pos) R {abs(a(j))})
    by thm nonnegative_series_bounded_partial_sums_converge(fn(j N_pos) R {abs(a(j))})
    $is_convergent_series(fn(j N_pos) R {abs(a(j))})
    $is_absolutely_convergent_series(a)

# A finite initial block does not affect absolute convergence.  This is the
# reverse finite-prefix direction of Proposition 7.2.14, whose proof is left to
# Exercise 7.2.5; later convergence tests use exactly this finite-prefix fact.

thm absolute_shift_abs_terms_match:
    ? forall a seq(R), k N, n N_pos:
        fn(j N_pos) R {abs(series_shift(a, k)(j))}(n) = series_shift(fn(i N_pos) R {abs(a(i))}, k)(n)
    fn(j N_pos) R {abs(series_shift(a, k)(j))}(n) = abs(series_shift(a, k)(n))
    series_shift(a, k)(n) = a(n + k)
    fn(j N_pos) R {abs(series_shift(a, k)(j))}(n) = abs(a(n + k))
    series_shift(fn(i N_pos) R {abs(a(i))}, k)(n) = fn(i N_pos) R {abs(a(i))}(n + k)
    fn(i N_pos) R {abs(a(i))}(n + k) = abs(a(n + k))
    fn(j N_pos) R {abs(series_shift(a, k)(j))}(n) = series_shift(fn(i N_pos) R {abs(a(i))}, k)(n)

thm absolute_sequence_nonnegative:
    ? forall a seq(R):
        $is_nonnegative_sequence(fn(i N_pos) R {abs(a(i))})
    forall n N_pos:
        fn(i N_pos) R {abs(a(i))}(n) = abs(a(n))
        abs(a(n)) >= 0
        fn(i N_pos) R {abs(a(i))}(n) >= 0
    $is_nonnegative_sequence(fn(i N_pos) R {abs(a(i))})

thm real_add_abs_nonnegative:
    ? forall M R:
        M + abs(M) >= 0
    M >= 0 or M < 0
    by cases:
        ? M + abs(M) >= 0
        case M >= 0:
            abs(M) = M
            M + abs(M) = M + M
            M + M = 2 * M
            2 * M >= 0
            M + abs(M) >= 0
        case M < 0:
            abs(M) = -M
            M + abs(M) = M + (-M)
            M + (-M) = 0
            M + abs(M) >= 0

thm partial_sum_bound_at:
    ? forall a seq(R), M R, t N_pos:
        $is_partial_sum_bound(a, M)
        =>:
            partial_sum(a, t) <= M
    partial_sum(a, t) <= M

thm shifted_abs_partial_sum_bound_extends_to_original:
    ? forall a seq(R), k N, M R:
        $is_partial_sum_bound(series_shift(fn(i N_pos) R {abs(a(i))}, k), M)
        =>:
            $is_partial_sum_bound(fn(i N_pos) R {abs(a(i))}, partial_sum(fn(i N_pos) R {abs(a(i))}, k) + M + abs(M))
    by thm absolute_sequence_nonnegative(a)
    $is_nonnegative_sequence(fn(i N_pos) R {abs(a(i))})
    by thm real_add_abs_nonnegative(M)
    M + abs(M) >= 0
    claim:
        ? forall m N_pos:
            partial_sum(fn(i N_pos) R {abs(a(i))}, m) <= partial_sum(fn(i N_pos) R {abs(a(i))}, k) + M + abs(M)
        by cases:
            ? partial_sum(fn(i N_pos) R {abs(a(i))}, m) <= partial_sum(fn(i N_pos) R {abs(a(i))}, k) + M + abs(M)
            case m <= k:
                m >= 1
                k >= m
                k >= m >= 1
                k >= 1
                k $in N_pos
                by thm nonnegative_partial_sum_le_of_le(fn(i N_pos) R {abs(a(i))}, m, k)
                partial_sum(fn(i N_pos) R {abs(a(i))}, m) <= partial_sum(fn(i N_pos) R {abs(a(i))}, k)
                partial_sum(fn(i N_pos) R {abs(a(i))}, k) <= partial_sum(fn(i N_pos) R {abs(a(i))}, k) + (M + abs(M))
                partial_sum(fn(i N_pos) R {abs(a(i))}, m) <= partial_sum(fn(i N_pos) R {abs(a(i))}, k) <= partial_sum(fn(i N_pos) R {abs(a(i))}, k) + (M + abs(M))
                partial_sum(fn(i N_pos) R {abs(a(i))}, m) <= partial_sum(fn(i N_pos) R {abs(a(i))}, k) + (M + abs(M))
                partial_sum(fn(i N_pos) R {abs(a(i))}, k) + (M + abs(M)) = partial_sum(fn(i N_pos) R {abs(a(i))}, k) + M + abs(M)
                partial_sum(fn(i N_pos) R {abs(a(i))}, m) <= partial_sum(fn(i N_pos) R {abs(a(i))}, k) + M + abs(M)
            case m > k:
                m - k $in N_pos
                by thm partial_sum_series_shift_plus_prefix(fn(i N_pos) R {abs(a(i))}, k, m - k)
                partial_sum(series_shift(fn(i N_pos) R {abs(a(i))}, k), m - k) + partial_sum(fn(i N_pos) R {abs(a(i))}, k) = partial_sum(fn(i N_pos) R {abs(a(i))}, (m - k) + k)
                (m - k) + k = m
                partial_sum(fn(i N_pos) R {abs(a(i))}, (m - k) + k) = partial_sum(fn(i N_pos) R {abs(a(i))}, m)
                partial_sum(series_shift(fn(i N_pos) R {abs(a(i))}, k), m - k) + partial_sum(fn(i N_pos) R {abs(a(i))}, k) = partial_sum(fn(i N_pos) R {abs(a(i))}, m)
                partial_sum(fn(i N_pos) R {abs(a(i))}, m) = partial_sum(series_shift(fn(i N_pos) R {abs(a(i))}, k), m - k) + partial_sum(fn(i N_pos) R {abs(a(i))}, k)
                by thm partial_sum_bound_at(series_shift(fn(i N_pos) R {abs(a(i))}, k), M, m - k)
                partial_sum(series_shift(fn(i N_pos) R {abs(a(i))}, k), m - k) <= M
                partial_sum(series_shift(fn(i N_pos) R {abs(a(i))}, k), m - k) + partial_sum(fn(i N_pos) R {abs(a(i))}, k) <= M + partial_sum(fn(i N_pos) R {abs(a(i))}, k)
                M + partial_sum(fn(i N_pos) R {abs(a(i))}, k) = partial_sum(fn(i N_pos) R {abs(a(i))}, k) + M
                partial_sum(fn(i N_pos) R {abs(a(i))}, m) <= partial_sum(fn(i N_pos) R {abs(a(i))}, k) + M
                partial_sum(fn(i N_pos) R {abs(a(i))}, k) + M <= partial_sum(fn(i N_pos) R {abs(a(i))}, k) + M + abs(M)
                partial_sum(fn(i N_pos) R {abs(a(i))}, m) <= partial_sum(fn(i N_pos) R {abs(a(i))}, k) + M + abs(M)
    $is_partial_sum_bound(fn(i N_pos) R {abs(a(i))}, partial_sum(fn(i N_pos) R {abs(a(i))}, k) + M + abs(M))

thm absolute_series_laws_tail_convergence_reverse:
    ? forall a seq(R), k N:
        $is_absolutely_convergent_series(series_shift(a, k))
        =>:
            $is_absolutely_convergent_series(a)
    $is_convergent_series(fn(j N_pos) R {abs(series_shift(a, k)(j))})
    claim:
        ? forall n N_pos:
            fn(j N_pos) R {abs(series_shift(a, k)(j))}(n) = series_shift(fn(i N_pos) R {abs(a(i))}, k)(n)
        by thm absolute_shift_abs_terms_match(a, k, n)
        fn(j N_pos) R {abs(series_shift(a, k)(j))}(n) = series_shift(fn(i N_pos) R {abs(a(i))}, k)(n)
    by thm series_convergence_extensional(fn(j N_pos) R {abs(series_shift(a, k)(j))}, series_shift(fn(i N_pos) R {abs(a(i))}, k))
    $is_convergent_series(series_shift(fn(i N_pos) R {abs(a(i))}, k))
    claim:
        ? $is_nonnegative_sequence(series_shift(fn(i N_pos) R {abs(a(i))}, k))
        claim:
            ? forall n N_pos:
                series_shift(fn(i N_pos) R {abs(a(i))}, k)(n) >= 0
            series_shift(fn(i N_pos) R {abs(a(i))}, k)(n) = fn(i N_pos) R {abs(a(i))}(n + k)
            fn(i N_pos) R {abs(a(i))}(n + k) = abs(a(n + k))
            abs(a(n + k)) >= 0
            series_shift(fn(i N_pos) R {abs(a(i))}, k)(n) >= 0
        $is_nonnegative_sequence(series_shift(fn(i N_pos) R {abs(a(i))}, k))
    by thm nonnegative_series_convergent_has_bounded_partial_sums(series_shift(fn(i N_pos) R {abs(a(i))}, k))
    $has_bounded_partial_sums(series_shift(fn(i N_pos) R {abs(a(i))}, k))
    obtain M from exist M R st {$is_partial_sum_bound(series_shift(fn(i N_pos) R {abs(a(i))}, k), M)}
    by thm shifted_abs_partial_sum_bound_extends_to_original(a, k, M)
    $is_partial_sum_bound(fn(i N_pos) R {abs(a(i))}, partial_sum(fn(i N_pos) R {abs(a(i))}, k) + M + abs(M))
    witness exist B R st {$is_partial_sum_bound(fn(i N_pos) R {abs(a(i))}, B)} from partial_sum(fn(i N_pos) R {abs(a(i))}, k) + M + abs(M):
        $is_partial_sum_bound(fn(i N_pos) R {abs(a(i))}, partial_sum(fn(i N_pos) R {abs(a(i))}, k) + M + abs(M))
    $has_bounded_partial_sums(fn(i N_pos) R {abs(a(i))})
    by thm absolute_sequence_nonnegative(a)
    $is_nonnegative_sequence(fn(i N_pos) R {abs(a(i))})
    by thm nonnegative_series_bounded_partial_sums_converge(fn(i N_pos) R {abs(a(i))})
    $is_convergent_series(fn(i N_pos) R {abs(a(i))})
    claim:
        ? forall n N_pos:
            fn(i N_pos) R {abs(a(i))}(n) = fn(j N_pos) R {abs(a(j))}(n)
        fn(i N_pos) R {abs(a(i))}(n) = abs(a(n))
        fn(j N_pos) R {abs(a(j))}(n) = abs(a(n))
        fn(i N_pos) R {abs(a(i))}(n) = fn(j N_pos) R {abs(a(j))}(n)
    by thm series_convergence_extensional(fn(i N_pos) R {abs(a(i))}, fn(j N_pos) R {abs(a(j))})
    $is_convergent_series(fn(j N_pos) R {abs(a(j))})
    $is_absolutely_convergent_series(a)

prop is_eventually_abs_bounded_by(a, b seq(R), n0 N_pos):
    forall n N_pos:
        n >= n0
        =>:
            abs(a(n)) <= b(n)

thm eventual_comparison_test_for_series:
    ? forall a, b seq(R), n0 N_pos:
        $is_convergent_series(b)
        $is_eventually_abs_bounded_by(a, b, n0)
        =>:
            $is_absolutely_convergent_series(a)
    have h N = n0 - 1
    by thm series_laws_tail_convergence(b, h)
    $is_convergent_series(series_shift(b, h))
    claim:
        ? forall n N_pos:
            abs(series_shift(a, h)(n)) <= series_shift(b, h)(n)
        h = n0 - 1
        n >= 1
        n - 1 >= 0
        n + h = n + (n0 - 1)
        n + (n0 - 1) = n0 + (n - 1)
        n0 + (n - 1) >= n0
        n + h >= n0
        abs(a(n + h)) <= b(n + h)
        series_shift(a, h)(n) = a(n + h)
        series_shift(b, h)(n) = b(n + h)
        abs(series_shift(a, h)(n)) = abs(a(n + h))
        abs(series_shift(a, h)(n)) <= series_shift(b, h)(n)
    by thm comparison_test_for_series(series_shift(a, h), series_shift(b, h))
    $is_absolutely_convergent_series(series_shift(a, h))
    by thm absolute_series_laws_tail_convergence_reverse(a, h)
    $is_absolutely_convergent_series(a)

"""
Lemma 7.3.3 (Geometric series). The geometric series diverges when |x| >= 1 and
sums to 1/(1-x) when |x| < 1.
"""

# The geometric-series proof uses the finite partial-sum identity and then
# passes to the limit when `abs(x) < 1`; when `abs(x) >= 1`, the terms do not
# tend to zero.
# Tao leaves this proof to Exercise 7.3.2.  The formal proof is the standard
# finite geometric identity plus the Chapter 6 limit behavior of powers.

have fn geometric_series_terms(x R) fn(i N_pos) R = fn(j N_pos) R {x^(j - 1)}

thm geometric_series_formula:
    ? forall x R:
        abs(x) < 1
        1 - x != 0
        =>:
            $has_series_sum(geometric_series_terms(x), 1 / (1 - x))
    by thm geometric_series_from_one_formula(x)
    $has_series_sum(geometric_series_terms_from_one(x), x / (1 - x))
    claim:
        ? forall n N_pos:
            geometric_series_terms_from_one(x)(n) = series_shift(geometric_series_terms(x), 1)(n)
        geometric_series_terms_from_one(x)(n) = x^n
        series_shift(geometric_series_terms(x), 1)(n) = geometric_series_terms(x)(n + 1)
        geometric_series_terms(x)(n + 1) = x^((n + 1) - 1)
        (n + 1) - 1 = n
        x^((n + 1) - 1) = x^n
        series_shift(geometric_series_terms(x), 1)(n) = x^n
        geometric_series_terms_from_one(x)(n) = series_shift(geometric_series_terms(x), 1)(n)
    by thm series_sum_extensional(geometric_series_terms_from_one(x), series_shift(geometric_series_terms(x), 1), x / (1 - x))
    $has_series_sum(series_shift(geometric_series_terms(x), 1), x / (1 - x))
    by thm series_laws_tail_sum_reverse_one(geometric_series_terms(x), x / (1 - x))
    $has_series_sum(geometric_series_terms(x), partial_sum(geometric_series_terms(x), 1) + x / (1 - x))
    by thm partial_sum_successor(geometric_series_terms(x), 1)
    partial_sum(geometric_series_terms(x), 1) = partial_sum(geometric_series_terms(x), 1 - 1) + geometric_series_terms(x)(1)
    1 - 1 = 0
    partial_sum(geometric_series_terms(x), 1 - 1) = partial_sum(geometric_series_terms(x), 0)
    partial_sum(geometric_series_terms(x), 0) = 0
    geometric_series_terms(x)(1) = x^(1 - 1)
    x^(1 - 1) = x^0
    x^0 = 1
    geometric_series_terms(x)(1) = 1
    partial_sum(geometric_series_terms(x), 1) = 0 + 1
    0 + 1 = 1
    partial_sum(geometric_series_terms(x), 1) + x / (1 - x) = 1 + x / (1 - x)
    1 + x / (1 - x) = 1 / (1 - x)
    $has_series_sum(geometric_series_terms(x), 1 / (1 - x))

thm geometric_series_diverges_when_abs_ge_one:
    ? forall x R:
        abs(x) >= 1
        =>:
            not $is_convergent_series(geometric_series_terms(x))
    by contra:
        ? not $is_convergent_series(geometric_series_terms(x))
        $is_convergent_series(geometric_series_terms(x))
        by thm series_laws_tail_convergence(geometric_series_terms(x), 1)
        $is_convergent_series(series_shift(geometric_series_terms(x), 1))
        claim:
            ? forall n N_pos:
                series_shift(geometric_series_terms(x), 1)(n) = geometric_series_terms_from_one(x)(n)
            series_shift(geometric_series_terms(x), 1)(n) = geometric_series_terms(x)(n + 1)
            geometric_series_terms(x)(n + 1) = x^((n + 1) - 1)
            (n + 1) - 1 = n
            x^((n + 1) - 1) = x^n
            geometric_series_terms_from_one(x)(n) = x^n
            series_shift(geometric_series_terms(x), 1)(n) = x^n
            series_shift(geometric_series_terms(x), 1)(n) = geometric_series_terms_from_one(x)(n)
        by thm series_convergence_extensional(series_shift(geometric_series_terms(x), 1), geometric_series_terms_from_one(x))
        $is_convergent_series(geometric_series_terms_from_one(x))
        by thm geometric_series_from_one_diverges_when_abs_ge_one(x)
        not $is_convergent_series(geometric_series_terms_from_one(x))
        impossible not $is_convergent_series(geometric_series_terms_from_one(x))

"""
Proposition 7.3.4 (Cauchy criterion). For a decreasing non-negative sequence,
the series sum a_n converges iff the condensed series sum 2^k a_{2^k}
converges.
"""

# Tao proves this by comparing ordinary partial sums with dyadic blocks.  The
# proof below uses Proposition 7.3.1 together with the finite dyadic estimate
# stated in the source as Lemma 7.3.6.  The dyadic estimate itself still needs a
# block-induction proof, but the two directions of Cauchy's condensation test
# are proved from that estimate.

have fn condensed_terms(a seq(R)) fn(i N_pos) R = fn(j N_pos) R {2^(j - 1) * a(2^(j - 1))}

thm condensed_partial_sum_successor:
    ? forall a seq(R), K N_pos:
        partial_sum(condensed_terms(a), K + 1) = partial_sum(condensed_terms(a), K) + 2^K * a(2^K)
    by thm partial_sum_successor(condensed_terms(a), K + 1)
    partial_sum(condensed_terms(a), K + 1) = partial_sum(condensed_terms(a), (K + 1) - 1) + condensed_terms(a)(K + 1)
    (K + 1) - 1 = K
    partial_sum(condensed_terms(a), (K + 1) - 1) = partial_sum(condensed_terms(a), K)
    condensed_terms(a)(K + 1) = 2^((K + 1) - 1) * a(2^((K + 1) - 1))
    (K + 1) - 1 = K
    2^((K + 1) - 1) = 2^K
    a(2^((K + 1) - 1)) = a(2^K)
    condensed_terms(a)(K + 1) = 2^K * a(2^K)
    partial_sum(condensed_terms(a), K + 1) = partial_sum(condensed_terms(a), K) + 2^K * a(2^K)

thm condensed_terms_nonnegative:
    ? forall a seq(R):
        $is_nonnegative_sequence(a)
        =>:
            $is_nonnegative_sequence(condensed_terms(a))
    forall j N_pos:
        2^(j - 1) $in N_pos
        a(2^(j - 1)) >= 0
        2^(j - 1) >= 0
        2^(j - 1) * a(2^(j - 1)) >= 0
        condensed_terms(a)(j) = 2^(j - 1) * a(2^(j - 1))
        condensed_terms(a)(j) >= 0
    $is_nonnegative_sequence(condensed_terms(a))

prop has_monotone_partial_sums_up_to(a seq(R), q N):
    forall p N:
        p <= q
        =>:
            partial_sum(a, p) <= partial_sum(a, q)

thm nonnegative_partial_sums_monotone:
    ? forall a seq(R), p, q N:
        $is_nonnegative_sequence(a)
        p <= q
        =>:
            partial_sum(a, p) <= partial_sum(a, q)
    claim:
        ? forall r N:
            $has_monotone_partial_sums_up_to(a, r)
        by induc r from 0:
            ? $has_monotone_partial_sums_up_to(a, r)

            ? from r = 0:
                forall p0 N:
                    p0 <= 0
                    =>:
                        p0 = 0
                        partial_sum(a, p0) = partial_sum(a, 0)
                        partial_sum(a, p0) <= partial_sum(a, 0)
                $has_monotone_partial_sums_up_to(a, 0)

            ? induc:
                claim:
                    ? forall p0 N:
                        p0 <= r + 1
                        =>:
                            partial_sum(a, p0) <= partial_sum(a, r + 1)
                    by cases:
                        ? partial_sum(a, p0) <= partial_sum(a, r + 1)
                        case p0 <= r:
                            partial_sum(a, p0) <= partial_sum(a, r)
                            r + 1 $in N_pos
                            a(r + 1) >= 0
                            by thm partial_sum_successor(a, r + 1)
                            partial_sum(a, r + 1) = partial_sum(a, (r + 1) - 1) + a(r + 1)
                            (r + 1) - 1 = r
                            partial_sum(a, (r + 1) - 1) = partial_sum(a, r)
                            partial_sum(a, (r + 1) - 1) + a(r + 1) = partial_sum(a, r) + a(r + 1)
                            partial_sum(a, r + 1) = partial_sum(a, r) + a(r + 1)
                            partial_sum(a, r) <= partial_sum(a, r) + a(r + 1)
                            partial_sum(a, p0) <= partial_sum(a, r) <= partial_sum(a, r + 1)
                            partial_sum(a, p0) <= partial_sum(a, r + 1)
                        case p0 > r:
                            p0 <= r + 1
                            p0 = r + 1
                            partial_sum(a, p0) = partial_sum(a, r + 1)
                            partial_sum(a, p0) <= partial_sum(a, r + 1)
                $has_monotone_partial_sums_up_to(a, r + 1)
    $has_monotone_partial_sums_up_to(a, q)
    partial_sum(a, p) <= partial_sum(a, q)

thm two_power_ge_successor:
    ? forall n N:
        2^n >= n + 1
    by induc n from 0:
        ? 2^n >= n + 1

        ? from n = 0:
            2^0 = 1 >= 0 + 1

        ? induc:
            2^n >= n + 1
            2^n * 2^1 >= (n + 1) * 2
            2 ^ (n + 1) = 2^n * 2^1 >= (n + 1) * 2 = (n + 1) + (n + 1) >= n + 1 + 1

thm dyadic_endpoint_covers_index:
    ? forall n N_pos:
        exist K N_pos st {n <= 2^K - 1}
    by thm two_power_ge_successor(n)
    2^n >= n + 1
    2^n - 1 >= n
    n <= 2^n - 1
    witness exist K N_pos st {n <= 2^K - 1} from n:
        n <= 2^n - 1

thm dyadic_block_upper_by_left_endpoint:
    ? forall a seq(R), K N_pos:
        $is_decreasing_sequence(a)
        2^(K + 1) - 1 $in N_pos
        2^K <= 2^(K + 1) - 1
        =>:
            sum(2^K, 2^(K + 1) - 1, fn(i N_pos) R {a(i)}) <= 2^K * a(2^K)
    2^K $in N_pos
    2^(K + 1) - 1 $in N_pos
    by thm decreasing_finite_block_upper_by_left_endpoint(a, 2^K, 2^(K + 1) - 1)
    sum(2^K, 2^(K + 1) - 1, fn(i N_pos) R {a(i)}) <= sum(2^K, 2^(K + 1) - 1, fn(i N_pos) R {a(2^K)})
    have c R = a(2^K)
    sum(2^K, 2^(K + 1) - 1, fn(i N_pos) R {c}) = ((2^(K + 1) - 1 - 2^K) + 1) * c
    sum(2^K, 2^(K + 1) - 1, fn(i N_pos) R {a(2^K)}) = sum(2^K, 2^(K + 1) - 1, fn(i N_pos) R {c})
    ((2^(K + 1) - 1 - 2^K) + 1) * c = ((2^(K + 1) - 1 - 2^K) + 1) * a(2^K)
    sum(2^K, 2^(K + 1) - 1, fn(i N_pos) R {a(2^K)}) = ((2^(K + 1) - 1 - 2^K) + 1) * a(2^K)
    2^(K + 1) = 2^K * 2^1
    2^1 = 2
    2^(K + 1) = 2^K * 2
    ((2^(K + 1) - 1 - 2^K) + 1) = ((2^K * 2 - 1 - 2^K) + 1)
    ((2^K * 2 - 1 - 2^K) + 1) = 2^K
    ((2^(K + 1) - 1 - 2^K) + 1) * a(2^K) = 2^K * a(2^K)
    sum(2^K, 2^(K + 1) - 1, fn(i N_pos) R {a(2^K)}) = 2^K * a(2^K)
    sum(2^K, 2^(K + 1) - 1, fn(i N_pos) R {a(i)}) <= 2^K * a(2^K)

thm dyadic_block_lower_by_right_endpoint:
    ? forall a seq(R), K N_pos:
        $is_decreasing_sequence(a)
        2^(K - 1) + 1 <= 2^K
        =>:
            2^(K - 1) * a(2^K) <= sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(i)})
    2^(K - 1) $in N_pos
    2^(K - 1) + 1 $in N_pos
    2^K $in N_pos
    by thm decreasing_finite_block_lower_by_right_endpoint(a, 2^(K - 1) + 1, 2^K)
    sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(2^K)}) <= sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(i)})
    have c R = a(2^K)
    sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {c}) = ((2^K - (2^(K - 1) + 1)) + 1) * c
    sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(2^K)}) = sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {c})
    ((2^K - (2^(K - 1) + 1)) + 1) * c = ((2^K - (2^(K - 1) + 1)) + 1) * a(2^K)
    sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(2^K)}) = ((2^K - (2^(K - 1) + 1)) + 1) * a(2^K)
    K - 1 $in N
    2^K = 2^((K - 1) + 1)
    2^((K - 1) + 1) = 2^(K - 1) * 2^1
    2^1 = 2
    2^K = 2^(K - 1) * 2
    ((2^K - (2^(K - 1) + 1)) + 1) = ((2^(K - 1) * 2 - (2^(K - 1) + 1)) + 1)
    ((2^(K - 1) * 2 - (2^(K - 1) + 1)) + 1) = 2^(K - 1)
    ((2^K - (2^(K - 1) + 1)) + 1) * a(2^K) = 2^(K - 1) * a(2^K)
    sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(2^K)}) = 2^(K - 1) * a(2^K)
    2^(K - 1) * a(2^K) <= sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(i)})

thm cauchy_condensation_partial_sum_lower_bound:
    ? forall a seq(R), K N_pos:
        $is_decreasing_sequence(a)
        =>:
            partial_sum(a, 2^K - 1) <= partial_sum(condensed_terms(a), K)
    by induc K from 1:
        ? partial_sum(a, 2^K - 1) <= partial_sum(condensed_terms(a), K)

        ? from K = 1:
            2^1 = 2
            2^1 - 1 = 1
            partial_sum(a, 2^1 - 1) = partial_sum(a, 1)
            by thm partial_sum_successor(a, 1)
            partial_sum(a, 1) = partial_sum(a, 1 - 1) + a(1)
            1 - 1 = 0
            partial_sum(a, 1 - 1) = partial_sum(a, 0)
            partial_sum(a, 0) = 0
            partial_sum(a, 1 - 1) + a(1) = partial_sum(a, 0) + a(1)
            partial_sum(a, 0) + a(1) = 0 + a(1)
            partial_sum(a, 1) = 0 + a(1)
            0 + a(1) = a(1)
            condensed_terms(a)(1) = 2^(1 - 1) * a(2^(1 - 1))
            1 - 1 = 0
            2^0 = 1
            a(2^(1 - 1)) = a(1)
            condensed_terms(a)(1) = 1 * a(1)
            1 * a(1) = a(1)
            by thm partial_sum_successor(condensed_terms(a), 1)
            partial_sum(condensed_terms(a), 1) = partial_sum(condensed_terms(a), 1 - 1) + condensed_terms(a)(1)
            partial_sum(condensed_terms(a), 1 - 1) = partial_sum(condensed_terms(a), 0)
            partial_sum(condensed_terms(a), 0) = 0
            partial_sum(condensed_terms(a), 1 - 1) + condensed_terms(a)(1) = partial_sum(condensed_terms(a), 0) + condensed_terms(a)(1)
            partial_sum(condensed_terms(a), 0) + condensed_terms(a)(1) = 0 + condensed_terms(a)(1)
            partial_sum(condensed_terms(a), 1) = 0 + condensed_terms(a)(1)
            0 + condensed_terms(a)(1) = condensed_terms(a)(1)
            partial_sum(condensed_terms(a), 1) = a(1)
            partial_sum(a, 2^1 - 1) <= partial_sum(condensed_terms(a), 1)

        ? induc:
            partial_sum(a, 2^K - 1) <= partial_sum(condensed_terms(a), K)
            2^K $in N_pos
            by thm two_power_ge_successor(K)
            2^K >= K + 1
            K >= 1
            K + 1 >= 1 + 1
            1 + 1 = 2
            K + 1 >= 2
            2^K >= K + 1 >= 2
            2^K >= 2
            2^K - 1 >= 1
            2^K - 1 $in N_pos
            by thm two_power_ge_successor(K + 1)
            2^(K + 1) >= (K + 1) + 1
            K >= 1
            K + 1 >= 2
            (K + 1) + 1 >= K + 1
            (K + 1) + 1 >= K + 1 >= 2
            (K + 1) + 1 >= 2
            2^(K + 1) >= (K + 1) + 1 >= 2
            2^(K + 1) >= 2
            2^(K + 1) - 1 >= 1
            2^(K + 1) - 1 $in N_pos
            2^(K + 1) = 2^K * 2^1
            2^1 = 2
            2^(K + 1) = 2^K * 2
            2^K * 2 = 2^K + 2^K
            2^K + 2^K > 2^K
            2^K * 2 > 2^K
            2^(K + 1) > 2^K
            2^(K + 1) - 1 - 2^K = 2^K * 2 - 1 - 2^K
            2^K * 2 - 1 - 2^K = 2^K - 1
            2^K - 1 >= 0
            2^(K + 1) - 1 - 2^K >= 0
            2^K <= 2^(K + 1) - 1
            2^K - 1 < 2^(K + 1) - 1
            by thm partial_sum_split_after(a, 2^K - 1, 2^(K + 1) - 1)
            partial_sum(a, 2^(K + 1) - 1) = partial_sum(a, 2^K - 1) + sum((2^K - 1) + 1, 2^(K + 1) - 1, fn(i N_pos) R {a(i)})
            (2^K - 1) + 1 = 2^K
            sum((2^K - 1) + 1, 2^(K + 1) - 1, fn(i N_pos) R {a(i)}) = sum(2^K, 2^(K + 1) - 1, fn(i N_pos) R {a(i)})
            partial_sum(a, 2^(K + 1) - 1) = partial_sum(a, 2^K - 1) + sum(2^K, 2^(K + 1) - 1, fn(i N_pos) R {a(i)})
            by thm dyadic_block_upper_by_left_endpoint(a, K)
            sum(2^K, 2^(K + 1) - 1, fn(i N_pos) R {a(i)}) <= 2^K * a(2^K)
            partial_sum(a, 2^K - 1) + sum(2^K, 2^(K + 1) - 1, fn(i N_pos) R {a(i)}) <= partial_sum(condensed_terms(a), K) + 2^K * a(2^K)
            partial_sum(a, 2^(K + 1) - 1) <= partial_sum(condensed_terms(a), K) + 2^K * a(2^K)
            by thm condensed_partial_sum_successor(a, K)
            partial_sum(condensed_terms(a), K + 1) = partial_sum(condensed_terms(a), K) + 2^K * a(2^K)
            partial_sum(a, 2^(K + 1) - 1) <= partial_sum(condensed_terms(a), K + 1)

thm cauchy_condensation_partial_sum_upper_strong:
    ? forall a seq(R), K N_pos:
        $is_nonnegative_sequence(a)
        $is_decreasing_sequence(a)
        =>:
            partial_sum(condensed_terms(a), K) <= 2 * partial_sum(a, 2^(K - 1))
    by induc K from 1:
        ? partial_sum(condensed_terms(a), K) <= 2 * partial_sum(a, 2^(K - 1))

        ? from K = 1:
            condensed_terms(a)(1) = 2^(1 - 1) * a(2^(1 - 1))
            1 - 1 = 0
            2^0 = 1
            a(2^(1 - 1)) = a(1)
            condensed_terms(a)(1) = 1 * a(1)
            1 * a(1) = a(1)
            by thm partial_sum_successor(condensed_terms(a), 1)
            partial_sum(condensed_terms(a), 1) = partial_sum(condensed_terms(a), 1 - 1) + condensed_terms(a)(1)
            partial_sum(condensed_terms(a), 1 - 1) = partial_sum(condensed_terms(a), 0)
            partial_sum(condensed_terms(a), 0) = 0
            partial_sum(condensed_terms(a), 1 - 1) + condensed_terms(a)(1) = partial_sum(condensed_terms(a), 0) + condensed_terms(a)(1)
            partial_sum(condensed_terms(a), 0) + condensed_terms(a)(1) = 0 + condensed_terms(a)(1)
            partial_sum(condensed_terms(a), 1) = 0 + condensed_terms(a)(1)
            0 + condensed_terms(a)(1) = condensed_terms(a)(1)
            partial_sum(condensed_terms(a), 1) = a(1)
            by thm partial_sum_successor(a, 1)
            partial_sum(a, 1) = partial_sum(a, 1 - 1) + a(1)
            partial_sum(a, 1 - 1) = partial_sum(a, 0)
            partial_sum(a, 0) = 0
            partial_sum(a, 1 - 1) + a(1) = partial_sum(a, 0) + a(1)
            partial_sum(a, 0) + a(1) = 0 + a(1)
            partial_sum(a, 1) = 0 + a(1)
            0 + a(1) = a(1)
            2^(1 - 1) = 1
            partial_sum(a, 2^(1 - 1)) = partial_sum(a, 1)
            partial_sum(a, 2^(1 - 1)) = a(1)
            a(1) >= 0
            2 * partial_sum(a, 2^(1 - 1)) = 2 * a(1)
            2 * a(1) = a(1) + a(1)
            a(1) <= a(1) + a(1)
            partial_sum(condensed_terms(a), 1) <= 2 * partial_sum(a, 2^(1 - 1))

        ? induc:
            partial_sum(condensed_terms(a), K) <= 2 * partial_sum(a, 2^(K - 1))
            K >= 1
            K - 1 $in N
            2^(K - 1) $in N_pos
            2^K $in N_pos
            2^(K - 1) + 1 $in N_pos
            2^K = 2^((K - 1) + 1)
            2^((K - 1) + 1) = 2^(K - 1) * 2^1
            2^1 = 2
            2^K = 2^(K - 1) * 2
            2^(K - 1) * 2 = 2^(K - 1) + 2^(K - 1)
            2^(K - 1) >= 1
            2^(K - 1) + 2^(K - 1) >= 2^(K - 1) + 1
            2^K >= 2^(K - 1) + 1
            2^(K - 1) + 1 <= 2^K
            by thm dyadic_block_lower_by_right_endpoint(a, K)
            2^(K - 1) * a(2^K) <= sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(i)})
            2 >= 0
            2 * (2^(K - 1) * a(2^K)) <= 2 * sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(i)})
            2^K = 2^(K - 1) * 2
            2 * 2^(K - 1) = 2^(K - 1) * 2
            2 * 2^(K - 1) = 2^K
            2 * (2^(K - 1) * a(2^K)) = (2 * 2^(K - 1)) * a(2^K)
            (2 * 2^(K - 1)) * a(2^K) = 2^K * a(2^K)
            2^K * a(2^K) <= 2 * sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(i)})
            by thm condensed_partial_sum_successor(a, K)
            partial_sum(condensed_terms(a), K + 1) = partial_sum(condensed_terms(a), K) + 2^K * a(2^K)
            partial_sum(condensed_terms(a), K) + 2^K * a(2^K) <= 2 * partial_sum(a, 2^(K - 1)) + 2 * sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(i)})
            partial_sum(condensed_terms(a), K + 1) <= 2 * partial_sum(a, 2^(K - 1)) + 2 * sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(i)})
            2^K = 2^(K - 1) + 2^(K - 1)
            2^(K - 1) > 0
            2^(K - 1) + 2^(K - 1) > 2^(K - 1)
            2^K > 2^(K - 1)
            2^(K - 1) < 2^K
            by thm partial_sum_split_after(a, 2^(K - 1), 2^K)
            partial_sum(a, 2^K) = partial_sum(a, 2^(K - 1)) + sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(i)})
            2 * partial_sum(a, 2^K) = 2 * (partial_sum(a, 2^(K - 1)) + sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(i)}))
            2 * (partial_sum(a, 2^(K - 1)) + sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(i)})) = 2 * partial_sum(a, 2^(K - 1)) + 2 * sum(2^(K - 1) + 1, 2^K, fn(i N_pos) R {a(i)})
            partial_sum(condensed_terms(a), K + 1) <= 2 * partial_sum(a, 2^K)
            (K + 1) - 1 = K
            2^((K + 1) - 1) = 2^K
            partial_sum(a, 2^((K + 1) - 1)) = partial_sum(a, 2^K)
            2 * partial_sum(a, 2^((K + 1) - 1)) = 2 * partial_sum(a, 2^K)
            partial_sum(condensed_terms(a), K + 1) <= 2 * partial_sum(a, 2^((K + 1) - 1))

"""
Remark 7.3.5. Cauchy's criterion only samples the terms whose indices are
powers of two, yet it decides convergence for monotone non-negative series.
"""

"""
Lemma 7.3.6. The dyadic partial sums used in Cauchy's criterion bound each
other: ordinary partial sums up to a dyadic endpoint are below the condensed
partial sums, and condensed partial sums are below twice an ordinary partial
sum.
"""

# Tao proves this lemma in the text by induction over dyadic blocks.  The lower
# blocks are bounded by their left endpoint; the upper blocks are bounded using
# the preceding dyadic block and non-negativity.

thm cauchy_condensation_partial_sum_bounds:
    ? forall a seq(R), K N_pos:
        $is_nonnegative_sequence(a)
        $is_decreasing_sequence(a)
        =>:
            partial_sum(a, 2^K - 1) <= partial_sum(condensed_terms(a), K)
            partial_sum(condensed_terms(a), K) <= 2 * partial_sum(a, 2^K)
    by thm cauchy_condensation_partial_sum_lower_bound(a, K)
    partial_sum(a, 2^K - 1) <= partial_sum(condensed_terms(a), K)
    by thm cauchy_condensation_partial_sum_upper_strong(a, K)
    partial_sum(condensed_terms(a), K) <= 2 * partial_sum(a, 2^(K - 1))
    K >= 1
    K - 1 $in N
    2^(K - 1) $in N_pos
    2^K $in N_pos
    2^K = 2^((K - 1) + 1)
    2^((K - 1) + 1) = 2^(K - 1) * 2^1
    2^1 = 2
    2^K = 2^(K - 1) * 2
    2^(K - 1) * 2 = 2^(K - 1) + 2^(K - 1)
    2^(K - 1) >= 0
    2^(K - 1) + 2^(K - 1) >= 2^(K - 1)
    2^K >= 2^(K - 1)
    2^(K - 1) <= 2^K
    by thm nonnegative_partial_sums_monotone(a, 2^(K - 1), 2^K)
    partial_sum(a, 2^(K - 1)) <= partial_sum(a, 2^K)
    2 >= 0
    2 * partial_sum(a, 2^(K - 1)) <= 2 * partial_sum(a, 2^K)
    partial_sum(condensed_terms(a), K) <= 2 * partial_sum(a, 2^(K - 1)) <= 2 * partial_sum(a, 2^K)
    partial_sum(condensed_terms(a), K) <= 2 * partial_sum(a, 2^K)

thm cauchy_condensation_test_forward:
    ? forall a seq(R):
        $is_nonnegative_sequence(a)
        $is_decreasing_sequence(a)
        $is_convergent_series(a)
        =>:
            $is_convergent_series(condensed_terms(a))
    by thm nonnegative_series_convergent_has_bounded_partial_sums(a)
    $has_bounded_partial_sums(a)
    obtain M from exist M R st {$is_partial_sum_bound(a, M)}
    have B R = 2 * M
    claim:
        ? forall K N_pos:
            partial_sum(condensed_terms(a), K) <= B
        by thm cauchy_condensation_partial_sum_bounds(a, K)
        partial_sum(condensed_terms(a), K) <= 2 * partial_sum(a, 2^K)
        2^K $in N_pos
        partial_sum(a, 2^K) <= M
        2 >= 0
        2 * partial_sum(a, 2^K) <= 2 * M
        partial_sum(condensed_terms(a), K) <= 2 * partial_sum(a, 2^K) <= 2 * M
        partial_sum(condensed_terms(a), K) <= 2 * M
        2 * M = B
        partial_sum(condensed_terms(a), K) <= B
    witness exist C R st {$is_partial_sum_bound(condensed_terms(a), C)} from B:
        forall K N_pos:
            partial_sum(condensed_terms(a), K) <= B
        $is_partial_sum_bound(condensed_terms(a), B)
    $has_bounded_partial_sums(condensed_terms(a))
    by thm condensed_terms_nonnegative(a)
    $is_nonnegative_sequence(condensed_terms(a))
    by thm nonnegative_series_bounded_partial_sums_converge(condensed_terms(a))
    $is_convergent_series(condensed_terms(a))

thm cauchy_condensation_test_reverse:
    ? forall a seq(R):
        $is_nonnegative_sequence(a)
        $is_decreasing_sequence(a)
        $is_convergent_series(condensed_terms(a))
        =>:
            $is_convergent_series(a)
    by thm condensed_terms_nonnegative(a)
    $is_nonnegative_sequence(condensed_terms(a))
    by thm nonnegative_series_convergent_has_bounded_partial_sums(condensed_terms(a))
    $has_bounded_partial_sums(condensed_terms(a))
    obtain M from exist M R st {$is_partial_sum_bound(condensed_terms(a), M)}
    claim:
        ? forall k N_pos:
            partial_sum(a, k) <= M
        by thm dyadic_endpoint_covers_index(k)
        obtain K from exist K N_pos st {k <= 2^K - 1}
        2^K - 1 $in N
        by thm nonnegative_partial_sums_monotone(a, k, 2^K - 1)
        partial_sum(a, k) <= partial_sum(a, 2^K - 1)
        by thm cauchy_condensation_partial_sum_bounds(a, K)
        partial_sum(a, 2^K - 1) <= partial_sum(condensed_terms(a), K)
        partial_sum(condensed_terms(a), K) <= M
        partial_sum(a, k) <= partial_sum(a, 2^K - 1) <= partial_sum(condensed_terms(a), K) <= M
        partial_sum(a, k) <= M
    witness exist B R st {$is_partial_sum_bound(a, B)} from M:
        forall k N_pos:
            partial_sum(a, k) <= M
        $is_partial_sum_bound(a, M)
    $has_bounded_partial_sums(a)
    by thm nonnegative_series_bounded_partial_sums_converge(a)
    $is_convergent_series(a)

"""
Corollary 7.3.7. The p-series sum 1/n^q converges exactly when q > 1.
"""

# The proof applies Cauchy's criterion and rewrites the condensed terms
# as a geometric series.  For q > 0, the sequence `1/n^q` is non-negative and
# decreasing by the rational exponent laws.  Cauchy's criterion says the
# p-series converges exactly when the condensed series with terms
# `2^k/(2^k)^q` converges; exponent laws rewrite this term as `(2^(1-q))^k`.
# The geometric series criterion then gives convergence exactly when
# `abs(2^(1-q)) < 1`, which is equivalent to `q > 1`.

have fn p_series_terms(q R_pos) fn(i N_pos) R = fn(j N_pos) R {1 / j^q}

thm p_series_converges_when_exponent_gt_one:
    ? forall q R_pos:
        q > 1
        =>:
            $is_convergent_series(p_series_terms(q))
    # Source handling: the text uses Cauchy condensation and the geometric
    # ratio `2^(1-q)`.
    # proof_debt: the local bridge from the condensed p-series to that
    # geometric convergence test remains unproved.
    trust $is_convergent_series(p_series_terms(q))

thm p_series_diverges_when_exponent_le_one:
    ? forall q R_pos:
        q <= 1
        =>:
            not $is_convergent_series(p_series_terms(q))
    # Source handling: the divergent half uses the same condensation reduction
    # to a geometric series.
    # proof_debt: the corresponding local divergence bridge is not expanded.
    trust not $is_convergent_series(p_series_terms(q))

"""
Remark 7.3.8. The convergent p-series sums define the Riemann zeta function
zeta(q), whose deeper number-theoretic properties lie outside this chapter.
"""


# 7.4 Rearrangement of series

"""
Proposition 7.4.1. A convergent non-negative series may be rearranged by a
bijection of the index set without changing its sum.
"""

prop is_permutation_of_positive_integers(phi fn(i N_pos) N_pos):
    forall y N_pos:
        exist! x N_pos st {phi(x) = y}

have fn rearranged_series(a seq(R), phi fn(i N_pos) N_pos) fn(i N_pos) R = fn(j N_pos) R {a(phi(j))}

# Tao's proof compares finite partial sums.  For non-negative series, it is
# enough that every finite partial sum of either order is bounded by a later
# finite partial sum of the other order.

prop has_mutually_cofinal_partial_sums(a, b seq(R)):
    forall n N_pos:
        exist m N_pos st {partial_sum(a, n) <= partial_sum(b, m)}
    forall n N_pos:
        exist m N_pos st {partial_sum(b, n) <= partial_sum(a, m)}

prop has_bounded_prefix_image(phi fn(i N_pos) N_pos, n N_pos, M N_pos):
    forall j N_pos:
        j <= n
        =>:
            phi(j) <= M

prop has_bounded_prefix_preimage(phi fn(i N_pos) N_pos, n N_pos, M N_pos):
    forall j N_pos:
        j <= n
        =>:
            exist t N_pos st {t <= M, phi(t) = j}

# Proof-package helper: the running maximum bounds the image of a finite prefix.
have fn prefix_image_bound(phi fn(i N_pos) N_pos, n N_pos) N_pos by induc n from 1:
    case n = 1: phi(1)
    case n > 1: max(prefix_image_bound(phi, n - 1), phi(n))

prop prefix_image_bound_bounds_up_to(phi fn(i N_pos) N_pos, n N_pos):
    forall j N_pos:
        j <= n
        =>:
            phi(j) <= prefix_image_bound(phi, n)

thm prefix_image_bound_bounds:
    ? forall phi fn(i N_pos) N_pos, n N_pos:
        $prefix_image_bound_bounds_up_to(phi, n)
    by induc n from 1:
        ? $prefix_image_bound_bounds_up_to(phi, n)
        ? from n = 1:
            claim:
                ? forall j N_pos:
                    j <= 1
                    =>:
                        phi(j) <= prefix_image_bound(phi, 1)
                j = 1
                phi(j) = phi(1)
                prefix_image_bound(phi, 1) = phi(1)
                phi(j) <= prefix_image_bound(phi, 1)
            $prefix_image_bound_bounds_up_to(phi, 1)
        ? induc:
            n + 1 > 1
            prefix_image_bound(phi, n + 1) = max(prefix_image_bound(phi, n + 1 - 1), phi(n + 1))
            n + 1 - 1 = n
            prefix_image_bound(phi, n + 1 - 1) = prefix_image_bound(phi, n)
            prefix_image_bound(phi, n + 1 - 1) <= max(prefix_image_bound(phi, n + 1 - 1), phi(n + 1))
            prefix_image_bound(phi, n) = prefix_image_bound(phi, n + 1 - 1) <= max(prefix_image_bound(phi, n + 1 - 1), phi(n + 1)) = prefix_image_bound(phi, n + 1)
            prefix_image_bound(phi, n) <= prefix_image_bound(phi, n + 1)
            phi(n + 1) <= max(prefix_image_bound(phi, n + 1 - 1), phi(n + 1))
            phi(n + 1) <= max(prefix_image_bound(phi, n + 1 - 1), phi(n + 1)) = prefix_image_bound(phi, n + 1)
            phi(n + 1) <= prefix_image_bound(phi, n + 1)
            claim:
                ? forall j N_pos:
                    j <= n + 1
                    =>:
                        phi(j) <= prefix_image_bound(phi, n + 1)
                by cases:
                    ? phi(j) <= prefix_image_bound(phi, n + 1)
                    case j <= n:
                        phi(j) <= prefix_image_bound(phi, n)
                        phi(j) <= prefix_image_bound(phi, n) <= prefix_image_bound(phi, n + 1)
                        phi(j) <= prefix_image_bound(phi, n + 1)
                    case j > n:
                        j = n + 1
                        phi(j) = phi(n + 1)
                        phi(j) <= prefix_image_bound(phi, n + 1)
            $prefix_image_bound_bounds_up_to(phi, n + 1)

thm rearranged_series_nonnegative:
    ? forall a seq(R), phi fn(i N_pos) N_pos:
        $is_nonnegative_sequence(a)
        =>:
            $is_nonnegative_sequence(rearranged_series(a, phi))
    forall n N_pos:
        rearranged_series(a, phi)(n) = a(phi(n))
        phi(n) $in N_pos
        a(phi(n)) >= 0
        rearranged_series(a, phi)(n) >= 0

thm permutation_prefix_image_has_bound:
    ? forall phi fn(i N_pos) N_pos, n N_pos:
        $is_permutation_of_positive_integers(phi)
        =>:
            exist M N_pos st {$has_bounded_prefix_image(phi, n, M)}
    have M N_pos = prefix_image_bound(phi, n)
    by thm prefix_image_bound_bounds(phi, n)
    $prefix_image_bound_bounds_up_to(phi, n)
    claim:
        ? $has_bounded_prefix_image(phi, n, M)
        forall j N_pos:
            j <= n
            =>:
                phi(j) <= prefix_image_bound(phi, n)
                prefix_image_bound(phi, n) = M
                phi(j) <= M
    witness exist M0 N_pos st {$has_bounded_prefix_image(phi, n, M0)} from M:
        $has_bounded_prefix_image(phi, n, M)

thm bounded_preimage_witness_from_function:
    ? forall phi fn(i N_pos) N_pos, h fn(i N_pos) N_pos, j, M N_pos:
        h(j) <= M
        phi(h(j)) = j
        =>:
            exist t N_pos st {t <= M, phi(t) = j}
    witness exist t N_pos st {t <= M, phi(t) = j} from h(j):
        h(j) <= M
        phi(h(j)) = j

thm prefix_preimage_bound_from_right_inverse:
    ? forall phi fn(i N_pos) N_pos, h fn(i N_pos) N_pos, n, M N_pos:
        $prefix_image_bound_bounds_up_to(h, n)
        M = prefix_image_bound(h, n)
        forall j N_pos:
            phi(h(j)) = j
        =>:
            $has_bounded_prefix_preimage(phi, n, M)
    claim:
        ? forall j N_pos:
            j <= n
            =>:
                exist t N_pos st {t <= M, phi(t) = j}
        h(j) <= prefix_image_bound(h, n)
        prefix_image_bound(h, n) = M
        h(j) <= M
        phi(h(j)) = j
        by thm bounded_preimage_witness_from_function(phi, h, j, M)
        exist t N_pos st {t <= M, phi(t) = j}
    $has_bounded_prefix_preimage(phi, n, M)

thm permutation_prefix_preimage_has_bound:
    ? forall phi fn(i N_pos) N_pos, n N_pos:
        $is_permutation_of_positive_integers(phi)
        =>:
            exist M N_pos st {$has_bounded_prefix_preimage(phi, n, M)}
    have fn preimage_func by exist!:
        ? forall y N_pos:
            exist! x N_pos st {phi(x) = y}
        exist! x N_pos st {phi(x) = y}
    have M N_pos = prefix_image_bound(preimage_func, n)
    by thm prefix_image_bound_bounds(preimage_func, n)
    $prefix_image_bound_bounds_up_to(preimage_func, n)
    claim:
        ? forall j N_pos:
            phi(preimage_func(j)) = j
        j = phi(preimage_func(j))
        phi(preimage_func(j)) = j
    by thm prefix_preimage_bound_from_right_inverse(phi, preimage_func, n, M)
    $has_bounded_prefix_preimage(phi, n, M)
    witness exist M0 N_pos st {$has_bounded_prefix_preimage(phi, n, M0)} from M:
        $has_bounded_prefix_preimage(phi, n, M)

thm rearranged_partial_sum_le_original_at_bounded_prefix:
    ? forall a seq(R), phi fn(i N_pos) N_pos, n, M N_pos:
        $is_nonnegative_sequence(a)
        $is_permutation_of_positive_integers(phi)
        $has_bounded_prefix_image(phi, n, M)
        =>:
            partial_sum(rearranged_series(a, phi), n) <= partial_sum(a, M)
    # Source handling: Proposition 7.4.1 compares a finite rearranged prefix
    # with an ordinary prefix containing all of its indices.
    # proof_debt: the finite-set substitution and non-negative missing-term
    # comparison have not been combined into this local prefix lemma.
    trust partial_sum(rearranged_series(a, phi), n) <= partial_sum(a, M)

thm original_partial_sum_le_rearranged_at_bounded_preimage:
    ? forall a seq(R), phi fn(i N_pos) N_pos, n, M N_pos:
        $is_nonnegative_sequence(a)
        $is_permutation_of_positive_integers(phi)
        $has_bounded_prefix_preimage(phi, n, M)
        =>:
            partial_sum(a, n) <= partial_sum(rearranged_series(a, phi), M)
    # Source handling: Proposition 7.4.1 applies the same finite-prefix
    # containment to the inverse bijection.
    # proof_debt: the finite-set substitution proof for that containment is
    # not expanded locally.
    trust partial_sum(a, n) <= partial_sum(rearranged_series(a, phi), M)

thm rearranged_series_partial_sums_cofinal:
    ? forall a seq(R), phi fn(i N_pos) N_pos:
        $is_nonnegative_sequence(a)
        $is_permutation_of_positive_integers(phi)
        =>:
            $has_mutually_cofinal_partial_sums(a, rearranged_series(a, phi))
    claim:
        ? forall n N_pos:
            exist m N_pos st {partial_sum(a, n) <= partial_sum(rearranged_series(a, phi), m)}
        by thm permutation_prefix_preimage_has_bound(phi, n)
        exist M N_pos st {$has_bounded_prefix_preimage(phi, n, M)}
        obtain M from exist M N_pos st {$has_bounded_prefix_preimage(phi, n, M)}
        by thm original_partial_sum_le_rearranged_at_bounded_preimage(a, phi, n, M)
        partial_sum(a, n) <= partial_sum(rearranged_series(a, phi), M)
        witness exist m N_pos st {partial_sum(a, n) <= partial_sum(rearranged_series(a, phi), m)} from M:
            partial_sum(a, n) <= partial_sum(rearranged_series(a, phi), M)
    claim:
        ? forall n N_pos:
            exist m N_pos st {partial_sum(rearranged_series(a, phi), n) <= partial_sum(a, m)}
        by thm permutation_prefix_image_has_bound(phi, n)
        exist M N_pos st {$has_bounded_prefix_image(phi, n, M)}
        obtain M from exist M N_pos st {$has_bounded_prefix_image(phi, n, M)}
        by thm rearranged_partial_sum_le_original_at_bounded_prefix(a, phi, n, M)
        partial_sum(rearranged_series(a, phi), n) <= partial_sum(a, M)
        witness exist m N_pos st {partial_sum(rearranged_series(a, phi), n) <= partial_sum(a, m)} from M:
            partial_sum(rearranged_series(a, phi), n) <= partial_sum(a, M)
    $has_mutually_cofinal_partial_sums(a, rearranged_series(a, phi))

thm nonnegative_series_same_sum_from_cofinal_partial_sums:
    ? forall a, b seq(R), L R:
        $is_nonnegative_sequence(a)
        $is_nonnegative_sequence(b)
        $has_series_sum(a, L)
        $has_mutually_cofinal_partial_sums(a, b)
        =>:
            $has_series_sum(b, L)
    # Source handling: Proposition 7.4.1 passes from cofinal finite-prefix
    # inequalities to equality of the two suprema of partial sums.
    # proof_debt: the local least-upper-bound comparison and limit bridge has
    # not been expanded.
    trust $has_series_sum(b, L)

thm nonnegative_rearrangement:
    ? forall a seq(R), phi fn(i N_pos) N_pos, L R:
        $is_nonnegative_sequence(a)
        $has_series_sum(a, L)
        $is_permutation_of_positive_integers(phi)
        =>:
            $has_series_sum(rearranged_series(a, phi), L)
    by thm rearranged_series_nonnegative(a, phi)
    $is_nonnegative_sequence(rearranged_series(a, phi))
    by thm rearranged_series_partial_sums_cofinal(a, phi)
    $has_mutually_cofinal_partial_sums(a, rearranged_series(a, phi))
    by thm nonnegative_series_same_sum_from_cofinal_partial_sums(a, rearranged_series(a, phi), L)
    $has_series_sum(rearranged_series(a, phi), L)

"""
Example 7.4.2. Since the p-series with q=2 converges, swapping adjacent pairs
of its terms gives a rearranged series with the same sum.
"""

# The adjacent-pair swap sends 1 to 2, 2 to 1, 3 to 4, 4 to 3, and so on.  The
# example is then a direct application of Corollary 7.3.7 and Proposition 7.4.1.

have square_reciprocal_terms seq(R) = p_series_terms(2)

thm square_reciprocal_terms_formula:
    ? forall k N_pos:
        square_reciprocal_terms(k) = 1 / k^2
    square_reciprocal_terms(k) = p_series_terms(2)(k)
    p_series_terms(2)(k) = 1 / k^2

have fn adjacent_pair_swap(i N_pos) N_pos by cases:
    case i % 2 = 1: i + 1
    case i % 2 = 0 and i > 1: i - 1

thm positive_even_gt_one:
    ? forall i N_pos:
        i % 2 = 0
        =>:
            i > 1
    by contra:
        ? i > 1
        i <= 1
        i >= 1
        i = 1
        1 % 2 = 1
        i % 2 = 1 % 2
        i % 2 = 1
        impossible i % 2 = 0

thm adjacent_pair_swap_odd:
    ? forall i N_pos:
        i % 2 = 1
        =>:
            adjacent_pair_swap(i) = i + 1

thm adjacent_pair_swap_even:
    ? forall i N_pos:
        i % 2 = 0
        =>:
            adjacent_pair_swap(i) = i - 1
    by thm positive_even_gt_one(i)
    i > 1
    adjacent_pair_swap(i) = i - 1

thm odd_successor_even:
    ? forall y N_pos:
        y % 2 = 1
        =>:
            (y + 1) % 2 = 0
    (y + 1) % 2 = (y % 2 + 1) % 2
    (y % 2 + 1) % 2 = (1 + 1) % 2
    (1 + 1) % 2 = 0
    (y + 1) % 2 = 0

thm even_predecessor_odd:
    ? forall y N_pos:
        y % 2 = 0
        y > 1
        =>:
            (y - 1) % 2 = 1
    (y - 1) % 2 = (y % 2 - 1) % 2
    (y % 2 - 1) % 2 = (0 - 1) % 2
    (0 - 1) % 2 = 1
    (y - 1) % 2 = 1

thm adjacent_pair_swap_is_involution:
    ? forall x N_pos:
        adjacent_pair_swap(adjacent_pair_swap(x)) = x
    x % 2 = 0 or x % 2 = 1
    by cases:
        ? adjacent_pair_swap(adjacent_pair_swap(x)) = x
        case x % 2 = 1:
            x + 1 $in N_pos
            by thm odd_successor_even(x)
            (x + 1) % 2 = 0
            by thm adjacent_pair_swap_odd(x)
            adjacent_pair_swap(x) = x + 1
            by thm adjacent_pair_swap_even(x + 1)
            adjacent_pair_swap(x + 1) = (x + 1) - 1
            (x + 1) - 1 = x
            adjacent_pair_swap(adjacent_pair_swap(x)) = adjacent_pair_swap(x + 1) = (x + 1) - 1 = x
        case x % 2 = 0:
            by thm positive_even_gt_one(x)
            x > 1
            x - 1 $in N_pos
            by thm even_predecessor_odd(x)
            (x - 1) % 2 = 1
            by thm adjacent_pair_swap_even(x)
            adjacent_pair_swap(x) = x - 1
            by thm adjacent_pair_swap_odd(x - 1)
            adjacent_pair_swap(x - 1) = (x - 1) + 1
            (x - 1) + 1 = x
            adjacent_pair_swap(adjacent_pair_swap(x)) = adjacent_pair_swap(x - 1) = (x - 1) + 1 = x

thm adjacent_pair_swap_is_injective:
    ? forall x1, x2 N_pos:
        adjacent_pair_swap(x1) = adjacent_pair_swap(x2)
        =>:
            x1 = x2
    adjacent_pair_swap(adjacent_pair_swap(x1)) = adjacent_pair_swap(adjacent_pair_swap(x2))
    by thm adjacent_pair_swap_is_involution(x1)
    adjacent_pair_swap(adjacent_pair_swap(x1)) = x1
    by thm adjacent_pair_swap_is_involution(x2)
    adjacent_pair_swap(adjacent_pair_swap(x2)) = x2
    x1 = x2

thm adjacent_pair_swap_has_unique_preimages:
    ? forall y N_pos:
        exist! x N_pos st {adjacent_pair_swap(x) = y}
    y % 2 = 0 or y % 2 = 1
    by cases:
        ? exist! x N_pos st {adjacent_pair_swap(x) = y}
        case y % 2 = 1:
            y + 1 $in N_pos
            by thm odd_successor_even(y)
            (y + 1) % 2 = 0
            by thm adjacent_pair_swap_even(y + 1)
            adjacent_pair_swap(y + 1) = (y + 1) - 1
            (y + 1) - 1 = y
            witness exist! x N_pos st {adjacent_pair_swap(x) = y} from y + 1:
                adjacent_pair_swap(y + 1) = y
                claim:
                    ? forall x1, x2 N_pos:
                        adjacent_pair_swap(x1) = y
                        adjacent_pair_swap(x2) = y
                        =>:
                            x1 = x2
                    adjacent_pair_swap(x1) = adjacent_pair_swap(x2)
                    by thm adjacent_pair_swap_is_injective(x1, x2)
                    x1 = x2
        case y % 2 = 0:
            by thm positive_even_gt_one(y)
            y > 1
            y - 1 $in N_pos
            by thm even_predecessor_odd(y)
            (y - 1) % 2 = 1
            by thm adjacent_pair_swap_odd(y - 1)
            adjacent_pair_swap(y - 1) = (y - 1) + 1
            (y - 1) + 1 = y
            witness exist! x N_pos st {adjacent_pair_swap(x) = y} from y - 1:
                adjacent_pair_swap(y - 1) = y
                claim:
                    ? forall x1, x2 N_pos:
                        adjacent_pair_swap(x1) = y
                        adjacent_pair_swap(x2) = y
                        =>:
                            x1 = x2
                    adjacent_pair_swap(x1) = adjacent_pair_swap(x2)
                    by thm adjacent_pair_swap_is_injective(x1, x2)
                    x1 = x2

claim:
    ? $is_permutation_of_positive_integers(adjacent_pair_swap)
    forall y N_pos:
        exist! x N_pos st {adjacent_pair_swap(x) = y}
    $is_permutation_of_positive_integers(adjacent_pair_swap)

thm square_reciprocal_terms_nonnegative_terms:
    ? forall n N_pos:
        square_reciprocal_terms(n) >= 0
    by thm square_reciprocal_terms_formula(n)
    square_reciprocal_terms(n) = 1 / n^2
    n^2 > 0
    1 / n^2 > 0
    square_reciprocal_terms(n) >= 0

claim:
    ? $is_nonnegative_sequence(square_reciprocal_terms)
    forall n N_pos:
        square_reciprocal_terms(n) >= 0
    $is_nonnegative_sequence(square_reciprocal_terms)

claim:
    ? $is_convergent_series(square_reciprocal_terms)
    2 $in R_pos
    2 > 1
    by thm p_series_converges_when_exponent_gt_one(2)
    $is_convergent_series(p_series_terms(2))
    $is_convergent_series(square_reciprocal_terms)

thm square_reciprocal_pair_swap_preserves_sum:
    ? forall L R:
        $has_series_sum(square_reciprocal_terms, L)
        =>:
            $has_series_sum(rearranged_series(square_reciprocal_terms, adjacent_pair_swap), L)
    $is_nonnegative_sequence(square_reciprocal_terms)
    $is_permutation_of_positive_integers(adjacent_pair_swap)
    by thm nonnegative_rearrangement(square_reciprocal_terms, adjacent_pair_swap, L)
    $has_series_sum(rearranged_series(square_reciprocal_terms, adjacent_pair_swap), L)

claim:
    ? $is_convergent_series(rearranged_series(square_reciprocal_terms, adjacent_pair_swap))
    $is_convergent_series(square_reciprocal_terms)
    exist L R st {$has_series_sum(square_reciprocal_terms, L)}
    obtain L from exist L R st {$has_series_sum(square_reciprocal_terms, L)}
    by thm square_reciprocal_pair_swap_preserves_sum(L)
    $has_series_sum(rearranged_series(square_reciprocal_terms, adjacent_pair_swap), L)
    witness exist M R st {$has_series_sum(rearranged_series(square_reciprocal_terms, adjacent_pair_swap), M)} from L:
        $has_series_sum(rearranged_series(square_reciprocal_terms, adjacent_pair_swap), L)
    $is_convergent_series(rearranged_series(square_reciprocal_terms, adjacent_pair_swap))

"""
Proposition 7.4.3 (Rearrangement of series). An absolutely convergent series
may be rearranged by any bijection of the index set without changing its sum.
"""

# The proof first rearranges the non-negative absolute-value series, then
# splits the signed series into its positive and negative algebraic parts.
# Absolute convergence makes both non-negative parts convergent; Proposition
# 7.4.1 rearranges those parts without changing their sums, and the series laws
# assemble the signed rearranged series back from the two parts.


thm rearranged_absolute_value_terms_pointwise:
    ? forall a seq(R), phi fn(i N_pos) N_pos, n N_pos:
        rearranged_series(fn(j N_pos) R {abs(a(j))}, phi)(n) = fn(j N_pos) R {abs(rearranged_series(a, phi)(j))}(n)
    rearranged_series(fn(j N_pos) R {abs(a(j))}, phi)(n) = fn(j N_pos) R {abs(a(j))}(phi(n))
    fn(j N_pos) R {abs(a(j))}(phi(n)) = abs(a(phi(n)))
    rearranged_series(a, phi)(n) = a(phi(n))
    fn(j N_pos) R {abs(rearranged_series(a, phi)(j))}(n) = abs(rearranged_series(a, phi)(n))
    abs(rearranged_series(a, phi)(n)) = abs(a(phi(n)))
    rearranged_series(fn(j N_pos) R {abs(a(j))}, phi)(n) = fn(j N_pos) R {abs(rearranged_series(a, phi)(j))}(n)

thm rearranged_series_absolutely_convergent:
    ? forall a seq(R), phi fn(i N_pos) N_pos:
        $is_absolutely_convergent_series(a)
        $is_permutation_of_positive_integers(phi)
        =>:
            $is_absolutely_convergent_series(rearranged_series(a, phi))
    $is_convergent_series(fn(j N_pos) R {abs(a(j))})
    obtain A from exist A R st {$has_series_sum(fn(j N_pos) R {abs(a(j))}, A)}
    claim:
        ? $is_nonnegative_sequence(fn(j N_pos) R {abs(a(j))})
        forall n N_pos:
            fn(j N_pos) R {abs(a(j))}(n) = abs(a(n))
            abs(a(n)) >= 0
            fn(j N_pos) R {abs(a(j))}(n) >= 0
    by thm nonnegative_rearrangement(fn(j N_pos) R {abs(a(j))}, phi, A)
    $has_series_sum(rearranged_series(fn(j N_pos) R {abs(a(j))}, phi), A)
    claim:
        ? forall n N_pos:
            rearranged_series(fn(j N_pos) R {abs(a(j))}, phi)(n) = fn(j N_pos) R {abs(rearranged_series(a, phi)(j))}(n)
        by thm rearranged_absolute_value_terms_pointwise(a, phi, n)
    by thm series_sum_extensional(rearranged_series(fn(j N_pos) R {abs(a(j))}, phi), fn(j N_pos) R {abs(rearranged_series(a, phi)(j))}, A)
    $has_series_sum(fn(j N_pos) R {abs(rearranged_series(a, phi)(j))}, A)
    witness exist B R st {$has_series_sum(fn(j N_pos) R {abs(rearranged_series(a, phi)(j))}, B)} from A:
        $has_series_sum(fn(j N_pos) R {abs(rearranged_series(a, phi)(j))}, A)
    $is_convergent_series(fn(j N_pos) R {abs(rearranged_series(a, phi)(j))})
    $is_absolutely_convergent_series(rearranged_series(a, phi))

have fn positive_part_series(a seq(R)) fn(i N_pos) R = fn(j N_pos) R {(abs(a(j)) + a(j)) / 2}
have fn negative_part_series(a seq(R)) fn(i N_pos) R = fn(j N_pos) R {(abs(a(j)) - a(j)) / 2}

thm positive_part_value_nonnegative:
    ? forall x R:
        (abs(x) + x) / 2 >= 0
    by cases:
        ? (abs(x) + x) / 2 >= 0
        case x > 0:
            abs(x) = x
            (abs(x) + x) / 2 = (x + x) / 2
            (x + x) / 2 = x
            x >= 0
            (abs(x) + x) / 2 >= 0
        case x = 0:
            abs(x) = 0
            (abs(x) + x) / 2 = 0
            (abs(x) + x) / 2 >= 0
        case x < 0:
            abs(x) = -x
            (abs(x) + x) / 2 = (-x + x) / 2
            (-x + x) / 2 = 0
            (abs(x) + x) / 2 >= 0

thm negative_part_value_nonnegative:
    ? forall x R:
        (abs(x) - x) / 2 >= 0
    by cases:
        ? (abs(x) - x) / 2 >= 0
        case x > 0:
            abs(x) = x
            (abs(x) - x) / 2 = (x - x) / 2
            (x - x) / 2 = 0
            (abs(x) - x) / 2 >= 0
        case x = 0:
            abs(x) = 0
            (abs(x) - x) / 2 = 0
            (abs(x) - x) / 2 >= 0
        case x < 0:
            abs(x) = -x
            (abs(x) - x) / 2 = (-x - x) / 2
            (-x - x) / 2 = -x
            -x > 0
            -x >= 0
            (abs(x) - x) / 2 >= 0

thm positive_part_value_le_abs:
    ? forall x R:
        (abs(x) + x) / 2 <= abs(x)
    by cases:
        ? (abs(x) + x) / 2 <= abs(x)
        case x > 0:
            abs(x) = x
            (abs(x) + x) / 2 = (x + x) / 2
            (x + x) / 2 = x
            (abs(x) + x) / 2 <= abs(x)
        case x = 0:
            abs(x) = 0
            (abs(x) + x) / 2 = 0
            (abs(x) + x) / 2 <= abs(x)
        case x < 0:
            abs(x) = -x
            (abs(x) + x) / 2 = (-x + x) / 2
            (-x + x) / 2 = 0
            -x > 0
            0 <= -x
            (abs(x) + x) / 2 <= abs(x)

thm negative_part_value_le_abs:
    ? forall x R:
        (abs(x) - x) / 2 <= abs(x)
    by cases:
        ? (abs(x) - x) / 2 <= abs(x)
        case x > 0:
            abs(x) = x
            (abs(x) - x) / 2 = (x - x) / 2
            (x - x) / 2 = 0
            0 <= x
            (abs(x) - x) / 2 <= abs(x)
        case x = 0:
            abs(x) = 0
            (abs(x) - x) / 2 = 0
            (abs(x) - x) / 2 <= abs(x)
        case x < 0:
            abs(x) = -x
            (abs(x) - x) / 2 = (-x - x) / 2
            (-x - x) / 2 = -x
            (abs(x) - x) / 2 <= abs(x)

thm positive_part_series_nonnegative:
    ? forall a seq(R):
        $is_nonnegative_sequence(positive_part_series(a))
    claim:
        ? forall n N_pos:
            positive_part_series(a)(n) >= 0
        positive_part_series(a)(n) = (abs(a(n)) + a(n)) / 2
        by thm positive_part_value_nonnegative(a(n))
        (abs(a(n)) + a(n)) / 2 >= 0
        positive_part_series(a)(n) >= 0
    $is_nonnegative_sequence(positive_part_series(a))

thm negative_part_series_nonnegative:
    ? forall a seq(R):
        $is_nonnegative_sequence(negative_part_series(a))
    claim:
        ? forall n N_pos:
            negative_part_series(a)(n) >= 0
        negative_part_series(a)(n) = (abs(a(n)) - a(n)) / 2
        by thm negative_part_value_nonnegative(a(n))
        (abs(a(n)) - a(n)) / 2 >= 0
        negative_part_series(a)(n) >= 0
    $is_nonnegative_sequence(negative_part_series(a))

thm positive_part_convergent_from_absolute:
    ? forall a seq(R):
        $is_absolutely_convergent_series(a)
        =>:
            $is_convergent_series(positive_part_series(a))
    $is_convergent_series(fn(j N_pos) R {abs(a(j))})
    claim:
        ? forall n N_pos:
            abs(positive_part_series(a)(n)) <= fn(j N_pos) R {abs(a(j))}(n)
        positive_part_series(a)(n) = (abs(a(n)) + a(n)) / 2
        by thm positive_part_value_nonnegative(a(n))
        (abs(a(n)) + a(n)) / 2 >= 0
        positive_part_series(a)(n) >= 0
        abs(positive_part_series(a)(n)) = positive_part_series(a)(n)
        by thm positive_part_value_le_abs(a(n))
        (abs(a(n)) + a(n)) / 2 <= abs(a(n))
        positive_part_series(a)(n) <= abs(a(n))
        fn(j N_pos) R {abs(a(j))}(n) = abs(a(n))
        abs(positive_part_series(a)(n)) <= fn(j N_pos) R {abs(a(j))}(n)
    by thm comparison_test_for_series(positive_part_series(a), fn(j N_pos) R {abs(a(j))})
    $is_absolutely_convergent_series(positive_part_series(a))
    by thm absolute_convergence_test(positive_part_series(a))
    $is_convergent_series(positive_part_series(a))

thm negative_part_convergent_from_absolute:
    ? forall a seq(R):
        $is_absolutely_convergent_series(a)
        =>:
            $is_convergent_series(negative_part_series(a))
    $is_convergent_series(fn(j N_pos) R {abs(a(j))})
    claim:
        ? forall n N_pos:
            abs(negative_part_series(a)(n)) <= fn(j N_pos) R {abs(a(j))}(n)
        negative_part_series(a)(n) = (abs(a(n)) - a(n)) / 2
        by thm negative_part_value_nonnegative(a(n))
        (abs(a(n)) - a(n)) / 2 >= 0
        negative_part_series(a)(n) >= 0
        abs(negative_part_series(a)(n)) = negative_part_series(a)(n)
        by thm negative_part_value_le_abs(a(n))
        (abs(a(n)) - a(n)) / 2 <= abs(a(n))
        negative_part_series(a)(n) <= abs(a(n))
        fn(j N_pos) R {abs(a(j))}(n) = abs(a(n))
        abs(negative_part_series(a)(n)) <= fn(j N_pos) R {abs(a(j))}(n)
    by thm comparison_test_for_series(negative_part_series(a), fn(j N_pos) R {abs(a(j))})
    $is_absolutely_convergent_series(negative_part_series(a))
    by thm absolute_convergence_test(negative_part_series(a))
    $is_convergent_series(negative_part_series(a))

thm positive_negative_parts_reconstruct_series_sum:
    ? forall a seq(R), P, Qsum R:
        $has_series_sum(positive_part_series(a), P)
        $has_series_sum(negative_part_series(a), Qsum)
        =>:
            $has_series_sum(a, P - Qsum)
    by thm series_laws_scalar_mul(negative_part_series(a), -1, Qsum)
    $has_series_sum(series_scalar_mul(-1, negative_part_series(a)), -1 * Qsum)
    by thm series_laws_add(positive_part_series(a), series_scalar_mul(-1, negative_part_series(a)), P, -1 * Qsum)
    $has_series_sum(series_add(positive_part_series(a), series_scalar_mul(-1, negative_part_series(a))), P + (-1 * Qsum))
    P + (-1 * Qsum) = P - Qsum
    $has_series_sum(series_add(positive_part_series(a), series_scalar_mul(-1, negative_part_series(a))), P - Qsum)
    claim:
        ? forall n N_pos:
            series_add(positive_part_series(a), series_scalar_mul(-1, negative_part_series(a)))(n) = a(n)
        series_add(positive_part_series(a), series_scalar_mul(-1, negative_part_series(a)))(n) = positive_part_series(a)(n) + series_scalar_mul(-1, negative_part_series(a))(n)
        positive_part_series(a)(n) = (abs(a(n)) + a(n)) / 2
        negative_part_series(a)(n) = (abs(a(n)) - a(n)) / 2
        series_scalar_mul(-1, negative_part_series(a))(n) = -1 * negative_part_series(a)(n)
        -1 * negative_part_series(a)(n) = -1 * ((abs(a(n)) - a(n)) / 2)
        positive_part_series(a)(n) + series_scalar_mul(-1, negative_part_series(a))(n) = (abs(a(n)) + a(n)) / 2 + (-1 * ((abs(a(n)) - a(n)) / 2))
        (abs(a(n)) + a(n)) / 2 + (-1 * ((abs(a(n)) - a(n)) / 2)) = a(n)
        series_add(positive_part_series(a), series_scalar_mul(-1, negative_part_series(a)))(n) = a(n)
    by thm series_sum_extensional(series_add(positive_part_series(a), series_scalar_mul(-1, negative_part_series(a))), a, P - Qsum)
    $has_series_sum(a, P - Qsum)

thm rearranged_positive_negative_parts_reconstruct_series_sum:
    ? forall a seq(R), phi fn(i N_pos) N_pos, P, Qsum R:
        $has_series_sum(rearranged_series(positive_part_series(a), phi), P)
        $has_series_sum(rearranged_series(negative_part_series(a), phi), Qsum)
        =>:
            $has_series_sum(rearranged_series(a, phi), P - Qsum)
    by thm series_laws_scalar_mul(rearranged_series(negative_part_series(a), phi), -1, Qsum)
    $has_series_sum(series_scalar_mul(-1, rearranged_series(negative_part_series(a), phi)), -1 * Qsum)
    by thm series_laws_add(rearranged_series(positive_part_series(a), phi), series_scalar_mul(-1, rearranged_series(negative_part_series(a), phi)), P, -1 * Qsum)
    $has_series_sum(series_add(rearranged_series(positive_part_series(a), phi), series_scalar_mul(-1, rearranged_series(negative_part_series(a), phi))), P + (-1 * Qsum))
    P + (-1 * Qsum) = P - Qsum
    $has_series_sum(series_add(rearranged_series(positive_part_series(a), phi), series_scalar_mul(-1, rearranged_series(negative_part_series(a), phi))), P - Qsum)
    claim:
        ? forall n N_pos:
            series_add(rearranged_series(positive_part_series(a), phi), series_scalar_mul(-1, rearranged_series(negative_part_series(a), phi)))(n) = rearranged_series(a, phi)(n)
        series_add(rearranged_series(positive_part_series(a), phi), series_scalar_mul(-1, rearranged_series(negative_part_series(a), phi)))(n) = rearranged_series(positive_part_series(a), phi)(n) + series_scalar_mul(-1, rearranged_series(negative_part_series(a), phi))(n)
        rearranged_series(positive_part_series(a), phi)(n) = positive_part_series(a)(phi(n))
        positive_part_series(a)(phi(n)) = (abs(a(phi(n))) + a(phi(n))) / 2
        rearranged_series(negative_part_series(a), phi)(n) = negative_part_series(a)(phi(n))
        negative_part_series(a)(phi(n)) = (abs(a(phi(n))) - a(phi(n))) / 2
        series_scalar_mul(-1, rearranged_series(negative_part_series(a), phi))(n) = -1 * rearranged_series(negative_part_series(a), phi)(n)
        -1 * rearranged_series(negative_part_series(a), phi)(n) = -1 * ((abs(a(phi(n))) - a(phi(n))) / 2)
        rearranged_series(positive_part_series(a), phi)(n) + series_scalar_mul(-1, rearranged_series(negative_part_series(a), phi))(n) = (abs(a(phi(n))) + a(phi(n))) / 2 + (-1 * ((abs(a(phi(n))) - a(phi(n))) / 2))
        (abs(a(phi(n))) + a(phi(n))) / 2 + (-1 * ((abs(a(phi(n))) - a(phi(n))) / 2)) = a(phi(n))
        rearranged_series(a, phi)(n) = a(phi(n))
        series_add(rearranged_series(positive_part_series(a), phi), series_scalar_mul(-1, rearranged_series(negative_part_series(a), phi)))(n) = rearranged_series(a, phi)(n)
    by thm series_sum_extensional(series_add(rearranged_series(positive_part_series(a), phi), series_scalar_mul(-1, rearranged_series(negative_part_series(a), phi))), rearranged_series(a, phi), P - Qsum)
    $has_series_sum(rearranged_series(a, phi), P - Qsum)

thm absolute_rearrangement:
    ? forall a seq(R), phi fn(i N_pos) N_pos, L R:
        $is_absolutely_convergent_series(a)
        $has_series_sum(a, L)
        $is_permutation_of_positive_integers(phi)
        =>:
            $has_series_sum(rearranged_series(a, phi), L)
            $is_absolutely_convergent_series(rearranged_series(a, phi))
    by thm rearranged_series_absolutely_convergent(a, phi)
    $is_absolutely_convergent_series(rearranged_series(a, phi))
    by thm positive_part_convergent_from_absolute(a)
    $is_convergent_series(positive_part_series(a))
    obtain P from exist P R st {$has_series_sum(positive_part_series(a), P)}
    by thm negative_part_convergent_from_absolute(a)
    $is_convergent_series(negative_part_series(a))
    obtain Qsum from exist Qsum R st {$has_series_sum(negative_part_series(a), Qsum)}
    by thm positive_negative_parts_reconstruct_series_sum(a, P, Qsum)
    $has_series_sum(a, P - Qsum)
    by thm series_sum_unique(a, L, P - Qsum)
    L = P - Qsum
    by thm positive_part_series_nonnegative(a)
    $is_nonnegative_sequence(positive_part_series(a))
    by thm nonnegative_rearrangement(positive_part_series(a), phi, P)
    $has_series_sum(rearranged_series(positive_part_series(a), phi), P)
    by thm negative_part_series_nonnegative(a)
    $is_nonnegative_sequence(negative_part_series(a))
    by thm nonnegative_rearrangement(negative_part_series(a), phi, Qsum)
    $has_series_sum(rearranged_series(negative_part_series(a), phi), Qsum)
    by thm rearranged_positive_negative_parts_reconstruct_series_sum(a, phi, P, Qsum)
    $has_series_sum(rearranged_series(a, phi), P - Qsum)
    $has_series_sum(rearranged_series(a, phi), L)

"""
Example 7.4.4. A conditionally convergent series can change value under
rearrangement.  This example starts from the tail
1/3 - 1/4 + 1/5 - 1/6 + ... and rearranges it so that each positive term is
followed by two negative terms.
"""

# The original tail groups as (1/(2n+1) - 1/(2n+2)), whose grouped partial
# sums are positive.  The two-negative rearrangement groups as
# 1/(2n+1) - 1/(4n) - 1/(4n+2), whose grouped partial sums are negative.
# The remaining source-level limit step needs a grouping/rearrangement lemma
# for conditionally convergent series; the proof below establishes the sign
# mechanism used in the example.

have fn example_7_4_4_original_pair_terms(n N_pos) R = 1 / (2*n + 1) - 1 / (2*n + 2)
have fn example_7_4_4_rearranged_block_terms(n N_pos) R = 1 / (2*n + 1) - 1 / (4*n) - 1 / (4*n + 2)

thm example_7_4_4_original_pair_positive:
    ? forall n N_pos:
        example_7_4_4_original_pair_terms(n) > 0
    example_7_4_4_original_pair_terms(n) = 1 / (2*n + 1) - 1 / (2*n + 2)
    2*n + 1 > 0
    2*n + 2 > 0
    (2*n + 1)*(2*n + 2) > 0
    1 / (2*n + 1) - 1 / (2*n + 2) = (2*n + 2) / ((2*n + 1)*(2*n + 2)) - (2*n + 1) / ((2*n + 1)*(2*n + 2))
    (2*n + 2) / ((2*n + 1)*(2*n + 2)) - (2*n + 1) / ((2*n + 1)*(2*n + 2)) = ((2*n + 2) - (2*n + 1)) / ((2*n + 1)*(2*n + 2))
    ((2*n + 2) - (2*n + 1)) / ((2*n + 1)*(2*n + 2)) = 1 / ((2*n + 1)*(2*n + 2))
    1 / ((2*n + 1)*(2*n + 2)) > 0
    example_7_4_4_original_pair_terms(n) > 0

thm example_7_4_4_original_grouped_partial_sums_positive:
    ? forall k N_pos:
        partial_sum(example_7_4_4_original_pair_terms, k) > 0
    by induc k from 1:
        ? partial_sum(example_7_4_4_original_pair_terms, k) > 0

        ? from k = 1:
            by thm partial_sum_successor(example_7_4_4_original_pair_terms, 1)
            partial_sum(example_7_4_4_original_pair_terms, 1) = partial_sum(example_7_4_4_original_pair_terms, 1 - 1) + example_7_4_4_original_pair_terms(1)
            partial_sum(example_7_4_4_original_pair_terms, 1 - 1) = partial_sum(example_7_4_4_original_pair_terms, 0)
            partial_sum(example_7_4_4_original_pair_terms, 0) = 0
            partial_sum(example_7_4_4_original_pair_terms, 1 - 1) + example_7_4_4_original_pair_terms(1) = partial_sum(example_7_4_4_original_pair_terms, 0) + example_7_4_4_original_pair_terms(1)
            partial_sum(example_7_4_4_original_pair_terms, 0) + example_7_4_4_original_pair_terms(1) = 0 + example_7_4_4_original_pair_terms(1)
            partial_sum(example_7_4_4_original_pair_terms, 1) = 0 + example_7_4_4_original_pair_terms(1)
            0 + example_7_4_4_original_pair_terms(1) = example_7_4_4_original_pair_terms(1)
            by thm example_7_4_4_original_pair_positive(1)
            example_7_4_4_original_pair_terms(1) > 0
            partial_sum(example_7_4_4_original_pair_terms, 1) > 0

        ? induc:
            partial_sum(example_7_4_4_original_pair_terms, k) > 0
            k + 1 $in N_pos
            by thm partial_sum_successor(example_7_4_4_original_pair_terms, k + 1)
            partial_sum(example_7_4_4_original_pair_terms, k + 1) = partial_sum(example_7_4_4_original_pair_terms, (k + 1) - 1) + example_7_4_4_original_pair_terms(k + 1)
            (k + 1) - 1 = k
            partial_sum(example_7_4_4_original_pair_terms, (k + 1) - 1) = partial_sum(example_7_4_4_original_pair_terms, k)
            partial_sum(example_7_4_4_original_pair_terms, (k + 1) - 1) + example_7_4_4_original_pair_terms(k + 1) = partial_sum(example_7_4_4_original_pair_terms, k) + example_7_4_4_original_pair_terms(k + 1)
            partial_sum(example_7_4_4_original_pair_terms, k + 1) = partial_sum(example_7_4_4_original_pair_terms, k) + example_7_4_4_original_pair_terms(k + 1)
            by thm example_7_4_4_original_pair_positive(k + 1)
            example_7_4_4_original_pair_terms(k + 1) > 0
            partial_sum(example_7_4_4_original_pair_terms, k) + example_7_4_4_original_pair_terms(k + 1) > 0
            partial_sum(example_7_4_4_original_pair_terms, k + 1) > 0

thm example_7_4_4_rearranged_block_negative:
    ? forall n N_pos:
        example_7_4_4_rearranged_block_terms(n) < 0
    example_7_4_4_rearranged_block_terms(n) = 1 / (2*n + 1) - 1 / (4*n) - 1 / (4*n + 2)
    4*n + 2 = 2*(2*n + 1)
    1 / (4*n + 2) = 1 / (2*(2*n + 1))
    1 / (2*n + 1) - 1 / (4*n + 2) = 1 / (4*n + 2)
    example_7_4_4_rearranged_block_terms(n) = 1 / (4*n + 2) - 1 / (4*n)
    4*n > 0
    4*n + 2 > 0
    (4*n)*(4*n + 2) > 0
    2 / ((4*n)*(4*n + 2)) > 0
    -1 * (2 / ((4*n)*(4*n + 2))) < 0
    -2 / ((4*n)*(4*n + 2)) = -1 * (2 / ((4*n)*(4*n + 2)))
    -2 / ((4*n)*(4*n + 2)) < 0
    1 / (4*n + 2) - 1 / (4*n) = -2 / ((4*n)*(4*n + 2))
    example_7_4_4_rearranged_block_terms(n) < 0

thm example_7_4_4_rearranged_grouped_partial_sums_negative:
    ? forall k N_pos:
        partial_sum(example_7_4_4_rearranged_block_terms, k) < 0
    by induc k from 1:
        ? partial_sum(example_7_4_4_rearranged_block_terms, k) < 0

        ? from k = 1:
            by thm partial_sum_successor(example_7_4_4_rearranged_block_terms, 1)
            partial_sum(example_7_4_4_rearranged_block_terms, 1) = partial_sum(example_7_4_4_rearranged_block_terms, 1 - 1) + example_7_4_4_rearranged_block_terms(1)
            partial_sum(example_7_4_4_rearranged_block_terms, 1 - 1) = partial_sum(example_7_4_4_rearranged_block_terms, 0)
            partial_sum(example_7_4_4_rearranged_block_terms, 0) = 0
            partial_sum(example_7_4_4_rearranged_block_terms, 1 - 1) + example_7_4_4_rearranged_block_terms(1) = partial_sum(example_7_4_4_rearranged_block_terms, 0) + example_7_4_4_rearranged_block_terms(1)
            partial_sum(example_7_4_4_rearranged_block_terms, 0) + example_7_4_4_rearranged_block_terms(1) = 0 + example_7_4_4_rearranged_block_terms(1)
            partial_sum(example_7_4_4_rearranged_block_terms, 1) = 0 + example_7_4_4_rearranged_block_terms(1)
            0 + example_7_4_4_rearranged_block_terms(1) = example_7_4_4_rearranged_block_terms(1)
            by thm example_7_4_4_rearranged_block_negative(1)
            example_7_4_4_rearranged_block_terms(1) < 0
            partial_sum(example_7_4_4_rearranged_block_terms, 1) < 0

        ? induc:
            partial_sum(example_7_4_4_rearranged_block_terms, k) < 0
            k + 1 $in N_pos
            by thm partial_sum_successor(example_7_4_4_rearranged_block_terms, k + 1)
            partial_sum(example_7_4_4_rearranged_block_terms, k + 1) = partial_sum(example_7_4_4_rearranged_block_terms, (k + 1) - 1) + example_7_4_4_rearranged_block_terms(k + 1)
            (k + 1) - 1 = k
            partial_sum(example_7_4_4_rearranged_block_terms, (k + 1) - 1) = partial_sum(example_7_4_4_rearranged_block_terms, k)
            partial_sum(example_7_4_4_rearranged_block_terms, (k + 1) - 1) + example_7_4_4_rearranged_block_terms(k + 1) = partial_sum(example_7_4_4_rearranged_block_terms, k) + example_7_4_4_rearranged_block_terms(k + 1)
            partial_sum(example_7_4_4_rearranged_block_terms, k + 1) = partial_sum(example_7_4_4_rearranged_block_terms, k) + example_7_4_4_rearranged_block_terms(k + 1)
            by thm example_7_4_4_rearranged_block_negative(k + 1)
            example_7_4_4_rearranged_block_terms(k + 1) < 0
            partial_sum(example_7_4_4_rearranged_block_terms, k) + example_7_4_4_rearranged_block_terms(k + 1) < 0
            partial_sum(example_7_4_4_rearranged_block_terms, k + 1) < 0


# 7.5 The root and ratio tests

"""
Theorem 7.5.1 (Root test). If the limsup of |a_n|^(1/n) is below 1, the series
is absolutely convergent; if it is above 1, the series is divergent by the zero
test.  The case equal to 1 is inconclusive.
"""

# The proof compares `abs(a(n))` with a geometric tail when the limsup is
# below 1, and uses the zero test when the limsup is above 1.

prop is_eventually_below(a seq(R), x R, n0 N_pos):
    forall n N_pos:
        n >= n0
        =>:
            a(n) < x

prop has_late_term_above(a seq(R), x R, n0 N_pos):
    exist n N_pos st {n >= n0 and a(n) > x}

prop exceeds_infinitely_often(a seq(R), x R):
    forall n0 N_pos:
        $has_late_term_above(a, x, n0)

prop has_finite_limit_superior(a seq(R), L R):
    forall x R:
        x > L
        =>:
            exist n0 N_pos st {$is_eventually_below(a, x, n0)}
    forall x R:
        x < L
        =>:
            $exceeds_infinitely_often(a, x)

have fn root_test_terms(a seq(R)) fn(i N_pos) R = fn(j N_pos) R {abs(a(j))^(1 / j)}

thm chapter7_nth_root_nonnegative:
    ? forall x R, n N_pos:
        x >= 0
        =>:
            x^(1 / n) >= 0
    x = 0 or x > 0
    by cases:
        ? x^(1 / n) >= 0
        case x = 0:
            x^(1 / n) = 0^(1 / n) = 0
            x^(1 / n) >= 0
        case x > 0:
            x^(1 / n) > 0
            x^(1 / n) >= 0

thm chapter7_nth_root_power_identity_nonnegative:
    ? forall x R, n N_pos:
        x >= 0
        =>:
            (x^(1 / n))^n = x
    x = 0 or x > 0
    by cases:
        ? (x^(1 / n))^n = x
        case x = 0:
            x^(1 / n) = 0^(1 / n) = 0
            (x^(1 / n))^n = 0^n = 0 = x
        case x > 0:
            (x^(1 / n))^n = x

thm chapter7_nth_root_le_one:
    ? forall x R, n N_pos:
        x >= 0
        x <= 1
        =>:
            x^(1 / n) <= 1
    by contra:
        ? x^(1 / n) <= 1
        x^(1 / n) > 1
        by thm chapter7_nth_root_nonnegative(x, n)
        x^(1 / n) >= 0
        0 <= x^(1 / n)
        (x^(1 / n))^n > 1^n
        by thm chapter7_nth_root_power_identity_nonnegative(x, n)
        (x^(1 / n))^n = x
        1^n = 1
        x > 1
        impossible x <= 1

thm positive_number_between_below_one:
    ? forall alpha R:
        alpha < 1
        =>:
            exist r R_pos st {alpha < r and r < 1}
    alpha < 1 / 2 or alpha >= 1 / 2
    by cases:
        ? exist r R_pos st {alpha < r and r < 1}
        case alpha < 1 / 2:
            witness exist r R_pos st {alpha < r and r < 1} from 1 / 2:
                1 / 2 > 0
                alpha < 1 / 2
                1 / 2 < 1
        case alpha >= 1 / 2:
            witness exist r R_pos st {alpha < r and r < 1} from (alpha + 1) / 2:
                (alpha + 1) / 2 > 0
                (alpha + 1) / 2 - alpha = (1 - alpha) / 2
                (1 - alpha) / 2 > 0
                alpha < (alpha + 1) / 2
                1 - (alpha + 1) / 2 = (1 - alpha) / 2
                1 - (alpha + 1) / 2 > 0
                (alpha + 1) / 2 < 1

thm root_test_tail_bound_by_geometric:
    ? forall a seq(R), r R_pos, n0 N_pos:
        $is_eventually_below(root_test_terms(a), r, n0)
        =>:
            $is_eventually_abs_bounded_by(a, geometric_series_terms_from_one(r), n0)
    claim:
        ? forall n N_pos:
            n >= n0
            =>:
                abs(a(n)) <= geometric_series_terms_from_one(r)(n)
        root_test_terms(a)(n) < r
        root_test_terms(a)(n) = abs(a(n))^(1 / n)
        abs(a(n))^(1 / n) < r
        abs(a(n)) >= 0
        by thm chapter7_nth_root_nonnegative(abs(a(n)), n)
        abs(a(n))^(1 / n) >= 0
        0 <= abs(a(n))^(1 / n)
        (abs(a(n))^(1 / n))^n < r^n
        by thm chapter7_nth_root_power_identity_nonnegative(abs(a(n)), n)
        (abs(a(n))^(1 / n))^n = abs(a(n))
        abs(a(n)) <= r^n
        geometric_series_terms_from_one(r)(n) = r^n
        abs(a(n)) <= geometric_series_terms_from_one(r)(n)
    $is_eventually_abs_bounded_by(a, geometric_series_terms_from_one(r), n0)

thm root_test_absolute_convergence:
    ? forall a seq(R), alpha R:
        $has_finite_limit_superior(root_test_terms(a), alpha)
        alpha < 1
        =>:
            $is_absolutely_convergent_series(a)
    by thm positive_number_between_below_one(alpha)
    obtain r from exist r R_pos st {alpha < r and r < 1}
    alpha < r and r < 1
    alpha < r
    r < 1
    r > alpha
    obtain n0 from exist n0 N_pos st {$is_eventually_below(root_test_terms(a), r, n0)}
    by thm root_test_tail_bound_by_geometric(a, r, n0)
    $is_eventually_abs_bounded_by(a, geometric_series_terms_from_one(r), n0)
    abs(r) = r
    abs(r) < 1
    1 - r > 0
    1 - r != 0
    by thm geometric_series_from_one_formula(r)
    $has_series_sum(geometric_series_terms_from_one(r), r / (1 - r))
    witness exist M R st {$has_series_sum(geometric_series_terms_from_one(r), M)} from r / (1 - r):
        $has_series_sum(geometric_series_terms_from_one(r), r / (1 - r))
    $is_convergent_series(geometric_series_terms_from_one(r))
    by thm eventual_comparison_test_for_series(a, geometric_series_terms_from_one(r), n0)
    $is_absolutely_convergent_series(a)

thm root_test_divergence:
    ? forall a seq(R), alpha R:
        $has_finite_limit_superior(root_test_terms(a), alpha)
        alpha > 1
        =>:
            not $is_convergent_series(a)
    by contra:
        ? not $is_convergent_series(a)
        $is_convergent_series(a)
        by thm series_zero_test(a)
        $has_limit(a, 0)
        1 < alpha
        $exceeds_infinitely_often(root_test_terms(a), 1)
        obtain n0 from exist n0 N_pos st {$is_tail_close_to(a, 0, 1, n0)}
        $has_late_term_above(root_test_terms(a), 1, n0)
        obtain n from exist n N_pos st {n >= n0 and root_test_terms(a)(n) > 1}
        n >= n0 and root_test_terms(a)(n) > 1
        n >= n0
        root_test_terms(a)(n) > 1
        abs(a(n) - 0) <= 1
        root_test_terms(a)(n) = abs(a(n))^(1 / n)
        abs(a(n) - 0) = abs(a(n))
        abs(a(n)) <= 1
        abs(a(n)) >= 0
        by thm chapter7_nth_root_le_one(abs(a(n)), n)
        abs(a(n))^(1 / n) <= 1
        root_test_terms(a)(n) <= 1
        impossible root_test_terms(a)(n) > 1

"""
Lemma 7.5.2. For positive terms c_n, the liminf and limsup of the ratio
c_{n+1}/c_n bound the liminf and limsup of c_n^(1/n).
"""

# Ratio bounds control products of consecutive ratios, and taking nth roots
# gives the corresponding root liminf/limsup estimates.  The middle inequality
# is Proposition 6.4.12(c).

prop is_eventually_above(a seq(R), y R, n0 N_pos):
    forall n N_pos:
        n >= n0
        =>:
            a(n) > y

prop has_late_term_below(a seq(R), y R, n0 N_pos):
    exist n N_pos st {n >= n0 and a(n) < y}

prop falls_infinitely_often(a seq(R), y R):
    forall n0 N_pos:
        $has_late_term_below(a, y, n0)

prop has_finite_limit_inferior(a seq(R), L R):
    forall y R:
        y < L
        =>:
            exist n0 N_pos st {$is_eventually_above(a, y, n0)}
    forall y R:
        y > L
        =>:
            $falls_infinitely_often(a, y)

prop pointwise_equal_sequences(a, b seq(R)):
    forall n N_pos:
        a(n) = b(n)

thm finite_limsup_extensional:
    ? forall a, b seq(R), L R:
        $pointwise_equal_sequences(a, b)
        $has_finite_limit_superior(a, L)
        =>:
            $has_finite_limit_superior(b, L)
    claim:
        ? forall x R:
            x > L
            =>:
                exist n0 N_pos st {$is_eventually_below(b, x, n0)}
        obtain n0 from exist n0 N_pos st {$is_eventually_below(a, x, n0)}
        witness exist n1 N_pos st {$is_eventually_below(b, x, n1)} from n0:
            claim:
                ? forall n N_pos:
                    n >= n0
                    =>:
                        b(n) < x
                a(n) < x
                a(n) = b(n)
                b(n) < x
            $is_eventually_below(b, x, n0)
    claim:
        ? forall x R:
            x < L
            =>:
                $exceeds_infinitely_often(b, x)
        $exceeds_infinitely_often(a, x)
        claim:
            ? forall n0 N_pos:
                $has_late_term_above(b, x, n0)
            $has_late_term_above(a, x, n0)
            obtain n from exist n N_pos st {n >= n0 and a(n) > x}
            witness exist k N_pos st {k >= n0 and b(k) > x} from n:
                n >= n0 and a(n) > x
                n >= n0
                a(n) > x
                a(n) = b(n)
                b(n) > x
                n >= n0 and b(n) > x
        $exceeds_infinitely_often(b, x)
    $has_finite_limit_superior(b, L)

thm finite_liminf_extensional:
    ? forall a, b seq(R), L R:
        $pointwise_equal_sequences(a, b)
        $has_finite_limit_inferior(a, L)
        =>:
            $has_finite_limit_inferior(b, L)
    claim:
        ? forall y R:
            y < L
            =>:
                exist n0 N_pos st {$is_eventually_above(b, y, n0)}
        obtain n0 from exist n0 N_pos st {$is_eventually_above(a, y, n0)}
        witness exist n1 N_pos st {$is_eventually_above(b, y, n1)} from n0:
            claim:
                ? forall n N_pos:
                    n >= n0
                    =>:
                        b(n) > y
                a(n) > y
                a(n) = b(n)
                b(n) > y
            $is_eventually_above(b, y, n0)
    claim:
        ? forall y R:
            y > L
            =>:
                $falls_infinitely_often(b, y)
        $falls_infinitely_often(a, y)
        claim:
            ? forall n0 N_pos:
                $has_late_term_below(b, y, n0)
            $has_late_term_below(a, y, n0)
            obtain n from exist n N_pos st {n >= n0 and a(n) < y}
            witness exist k N_pos st {k >= n0 and b(k) < y} from n:
                n >= n0 and a(n) < y
                n >= n0
                a(n) < y
                a(n) = b(n)
                b(n) < y
                n >= n0 and b(n) < y
        $falls_infinitely_often(b, y)
    $has_finite_limit_inferior(b, L)

thm pointwise_equal_sequences_symmetric:
    ? forall a, b seq(R):
        $pointwise_equal_sequences(a, b)
        =>:
            $pointwise_equal_sequences(b, a)
    claim:
        ? forall n N_pos:
            b(n) = a(n)
        a(n) = b(n)
        b(n) = a(n)
    $pointwise_equal_sequences(b, a)

thm has_limit_extensional:
    ? forall a, b seq(R), L R:
        $pointwise_equal_sequences(a, b)
        $has_limit(a, L)
        =>:
            $has_limit(b, L)
    claim:
        ? forall epsilon R_pos:
            exist n0 N_pos st {$is_tail_close_to(b, L, epsilon, n0)}
        obtain n0 from exist n0 N_pos st {$is_tail_close_to(a, L, epsilon, n0)}
        witness exist n1 N_pos st {$is_tail_close_to(b, L, epsilon, n1)} from n0:
            claim:
                ? forall n N_pos:
                    n >= n0
                    =>:
                        abs(b(n) - L) <= epsilon
                abs(a(n) - L) <= epsilon
                a(n) = b(n)
                b(n) - L = a(n) - L
                abs(b(n) - L) = abs(a(n) - L)
                abs(b(n) - L) <= epsilon
            $is_tail_close_to(b, L, epsilon, n0)
    $has_limit(b, L)

prop is_positive_sequence(c seq(R)):
    forall n N_pos:
        c(n) > 0

thm positive_sequence_term_positive:
    ? forall c seq(R), n N_pos:
        $is_positive_sequence(c)
        =>:
            c(n) > 0
    c(n) > 0

# This is the sequence with kth term `c(k+1)/c(k)`.  The evaluation rule below
# records the ratio notation explicitly.
have fn ratio_terms(c seq(R): $is_positive_sequence(c)) fn(i N_pos) R = fn(k N_pos: c(k) > 0) R {c(k + 1) / c(k)}

thm ratio_terms_eval:
    ? forall c seq(R), n N_pos:
        $is_positive_sequence(c)
        c(n) > 0
        =>:
            ratio_terms(c)(n) = c(n + 1) / c(n)
    # Source handling: the ratio is written simply as `c_{n+1}/c_n`.

thm eventual_ratio_upper_bound_gives_root_limsup_bound:
    ? forall c seq(R), r, A R, n0 N_pos:
        $is_positive_sequence(c)
        $is_eventually_below(ratio_terms(c), r, n0)
        $has_finite_limit_superior(root_test_terms(c), A)
        =>:
            A <= r
    # Source handling: Lemma 7.5.2 expands consecutive ratios into a product
    # and then takes nth roots.
    # proof_debt: this product-to-root limsup estimate is not yet proved.
    trust A <= r

thm eventual_ratio_lower_bound_gives_root_liminf_bound:
    ? forall c seq(R), r, A R, n0 N_pos:
        $is_positive_sequence(c)
        $is_eventually_above(ratio_terms(c), r, n0)
        $has_finite_limit_inferior(root_test_terms(c), A)
        =>:
            r <= A
    # Source handling: Lemma 7.5.2 uses the same product estimate for the
    # lower ratio bound.
    # proof_debt: this product-to-root liminf estimate is not yet proved.
    trust r <= A

thm ratio_limsup_bounds_root_limsup:
    ? forall c seq(R), L, A R:
        $is_positive_sequence(c)
        $has_finite_limit_superior(ratio_terms(c), L)
        $has_finite_limit_superior(root_test_terms(c), A)
        =>:
            A <= L
    by contra:
        ? A <= L
        A > L
        have mid R = (A + L) / 2
        mid - L = (A + L) / 2 - L
        (A + L) / 2 - L = (A - L) / 2
        (A - L) / 2 > 0
        L < mid
        A - mid = A - (A + L) / 2
        A - (A + L) / 2 = (A - L) / 2
        A - mid > 0
        mid < A
        mid > L
        obtain n0 from exist n0 N_pos st {$is_eventually_below(ratio_terms(c), mid, n0)}
        by thm eventual_ratio_upper_bound_gives_root_limsup_bound(c, mid, A, n0)
        A <= mid
        impossible mid < A

thm ratio_liminf_bounds_root_liminf:
    ? forall c seq(R), L, A R:
        $is_positive_sequence(c)
        $has_finite_limit_inferior(ratio_terms(c), L)
        $has_finite_limit_inferior(root_test_terms(c), A)
        =>:
            L <= A
    by contra:
        ? L <= A
        L > A
        have mid R = (L + A) / 2
        mid - A = (L + A) / 2 - A
        (L + A) / 2 - A = (L - A) / 2
        (L - A) / 2 > 0
        A < mid
        L - mid = L - (L + A) / 2
        L - (L + A) / 2 = (L - A) / 2
        L - mid > 0
        mid < L
        obtain n0 from exist n0 N_pos st {$is_eventually_above(ratio_terms(c), mid, n0)}
        by thm eventual_ratio_lower_bound_gives_root_liminf_bound(c, mid, A, n0)
        mid <= A
        impossible A < mid

thm ratio_limsup_less_than_one_gives_root_limsup_below_one:
    ? forall c seq(R), alpha R:
        $is_positive_sequence(c)
        $has_finite_limit_superior(ratio_terms(c), alpha)
        alpha < 1
        =>:
            exist gamma R st {$has_finite_limit_superior(root_test_terms(c), gamma) and gamma < 1}
    # Source handling: Lemma 7.5.2 transfers an upper ratio bound to the
    # limsup of the nth roots.
    # proof_debt: the chapter lacks the combined product-estimate and
    # finite-limsup-existence bridge needed for this consequence.
    trust exist gamma R st {$has_finite_limit_superior(root_test_terms(c), gamma) and gamma < 1}

thm ratio_liminf_greater_than_one_gives_root_limsup_above_one:
    ? forall c seq(R), beta R:
        $is_positive_sequence(c)
        $has_finite_limit_inferior(ratio_terms(c), beta)
        beta > 1
        =>:
            exist gamma R st {$has_finite_limit_superior(root_test_terms(c), gamma) and gamma > 1}
    # Source handling: Lemma 7.5.2 and `liminf <= limsup` transfer the lower
    # ratio bound to a root limsup above one.
    # proof_debt: the local product-estimate/liminf-limsup bridge is missing.
    trust exist gamma R st {$has_finite_limit_superior(root_test_terms(c), gamma) and gamma > 1}

thm positive_sequence_ratio_limit_one_gives_root_limit_one:
    ? forall c seq(R):
        $is_positive_sequence(c)
        $has_limit(ratio_terms(c), 1)
        =>:
            $has_limit(root_test_terms(c), 1)
    # Source handling: Lemma 7.5.2 applies upper and lower ratio bounds
    # tending to one.
    # proof_debt: the equality case of this product estimate remains a local
    # theorem-package gap.
    trust $has_limit(root_test_terms(c), 1)

"""
Corollary 7.5.3 (Ratio test). If the limsup of |a_{n+1}|/|a_n| is less than
1, the series is absolutely convergent.  If the liminf is greater than 1, the
series is divergent.
"""

# The proof combines the root test with Lemma 7.5.2; the remaining
# inconclusive cases are supplied by Exercise 7.5.3.

prop has_no_zero_terms(a seq(R)):
    forall n N_pos:
        a(n) != 0

thm no_zero_terms_abs_positive:
    ? forall a seq(R), n N_pos:
        $has_no_zero_terms(a)
        =>:
            abs(a(n)) > 0
    a(n) != 0
    abs(a(n)) > 0

# This is the sequence with kth term `abs(a(k+1))/abs(a(k))`; the nonzero-term
# predicate supplies the denominator condition.
have fn absolute_ratio_terms(a seq(R): $has_no_zero_terms(a)) fn(i N_pos) R = fn(k N_pos: abs(a(k)) > 0) R {abs(a(k + 1)) / abs(a(k))}

thm absolute_ratio_terms_eval:
    ? forall a seq(R), n N_pos:
        $has_no_zero_terms(a)
        abs(a(n)) > 0
        =>:
            absolute_ratio_terms(a)(n) = abs(a(n + 1)) / abs(a(n))
    # Source handling: Corollary 7.5.3 applies Lemma 7.5.2 to the positive
    # sequence `abs(a_n)`, and writes this ratio directly.

have fn absolute_value_sequence(a seq(R)) fn(i N_pos) R = fn(j N_pos) R {abs(a(j))}

thm abs_sequence_positive_from_no_zero_terms:
    ? forall a seq(R):
        $has_no_zero_terms(a)
        =>:
            $is_positive_sequence(absolute_value_sequence(a))
    claim:
        ? forall n N_pos:
            absolute_value_sequence(a)(n) > 0
        a(n) != 0
        abs(a(n)) > 0
        absolute_value_sequence(a)(n) = abs(a(n))
        absolute_value_sequence(a)(n) > 0
    $is_positive_sequence(absolute_value_sequence(a))

thm absolute_ratio_terms_match_positive_ratio_terms:
    ? forall a seq(R):
        $has_no_zero_terms(a)
        =>:
            $pointwise_equal_sequences(absolute_ratio_terms(a), ratio_terms(absolute_value_sequence(a)))
    by thm abs_sequence_positive_from_no_zero_terms(a)
    $is_positive_sequence(absolute_value_sequence(a))
    claim:
        ? forall n N_pos:
            absolute_ratio_terms(a)(n) = ratio_terms(absolute_value_sequence(a))(n)
        a(n) != 0
        abs(a(n)) > 0
        by thm absolute_ratio_terms_eval(a, n)
        absolute_ratio_terms(a)(n) = abs(a(n + 1)) / abs(a(n))
        absolute_value_sequence(a)(n) > 0
        by thm ratio_terms_eval(absolute_value_sequence(a), n)
        ratio_terms(absolute_value_sequence(a))(n) = absolute_value_sequence(a)(n + 1) / absolute_value_sequence(a)(n)
        absolute_value_sequence(a)(n + 1) = abs(a(n + 1))
        absolute_value_sequence(a)(n) = abs(a(n))
        ratio_terms(absolute_value_sequence(a))(n) = abs(a(n + 1)) / abs(a(n))
        absolute_ratio_terms(a)(n) = ratio_terms(absolute_value_sequence(a))(n)
    $pointwise_equal_sequences(absolute_ratio_terms(a), ratio_terms(absolute_value_sequence(a)))

thm root_test_terms_match_absolute_value_sequence:
    ? forall a seq(R):
        $pointwise_equal_sequences(root_test_terms(a), root_test_terms(absolute_value_sequence(a)))
    claim:
        ? forall n N_pos:
            root_test_terms(a)(n) = root_test_terms(absolute_value_sequence(a))(n)
        root_test_terms(a)(n) = abs(a(n))^(1 / n)
        root_test_terms(absolute_value_sequence(a))(n) = abs(absolute_value_sequence(a)(n))^(1 / n)
        absolute_value_sequence(a)(n) = abs(a(n))
        abs(absolute_value_sequence(a)(n)) = abs(abs(a(n)))
        abs(abs(a(n))) = abs(a(n))
        root_test_terms(absolute_value_sequence(a))(n) = abs(a(n))^(1 / n)
        root_test_terms(a)(n) = root_test_terms(absolute_value_sequence(a))(n)
    $pointwise_equal_sequences(root_test_terms(a), root_test_terms(absolute_value_sequence(a)))

thm ratio_test_absolute_convergence:
    ? forall a seq(R), alpha, beta R:
        $has_no_zero_terms(a)
        $has_finite_limit_superior(absolute_ratio_terms(a), alpha)
        $has_finite_limit_inferior(absolute_ratio_terms(a), beta)
        alpha < 1
        =>:
            $is_absolutely_convergent_series(a)
    by thm abs_sequence_positive_from_no_zero_terms(a)
    $is_positive_sequence(absolute_value_sequence(a))
    by thm absolute_ratio_terms_match_positive_ratio_terms(a)
    $pointwise_equal_sequences(absolute_ratio_terms(a), ratio_terms(absolute_value_sequence(a)))
    by thm finite_limsup_extensional(absolute_ratio_terms(a), ratio_terms(absolute_value_sequence(a)), alpha)
    $has_finite_limit_superior(ratio_terms(absolute_value_sequence(a)), alpha)
    by thm ratio_limsup_less_than_one_gives_root_limsup_below_one(absolute_value_sequence(a), alpha)
    obtain gamma from exist gamma R st {$has_finite_limit_superior(root_test_terms(absolute_value_sequence(a)), gamma) and gamma < 1}
    $has_finite_limit_superior(root_test_terms(absolute_value_sequence(a)), gamma) and gamma < 1
    $has_finite_limit_superior(root_test_terms(absolute_value_sequence(a)), gamma)
    gamma < 1
    by thm root_test_terms_match_absolute_value_sequence(a)
    $pointwise_equal_sequences(root_test_terms(a), root_test_terms(absolute_value_sequence(a)))
    by thm pointwise_equal_sequences_symmetric(root_test_terms(a), root_test_terms(absolute_value_sequence(a)))
    $pointwise_equal_sequences(root_test_terms(absolute_value_sequence(a)), root_test_terms(a))
    by thm finite_limsup_extensional(root_test_terms(absolute_value_sequence(a)), root_test_terms(a), gamma)
    $has_finite_limit_superior(root_test_terms(a), gamma)
    by thm root_test_absolute_convergence(a, gamma)
    $is_absolutely_convergent_series(a)

thm ratio_test_divergence:
    ? forall a seq(R), alpha, beta R:
        $has_no_zero_terms(a)
        $has_finite_limit_superior(absolute_ratio_terms(a), alpha)
        $has_finite_limit_inferior(absolute_ratio_terms(a), beta)
        beta > 1
        =>:
            not $is_convergent_series(a)
    by thm abs_sequence_positive_from_no_zero_terms(a)
    $is_positive_sequence(absolute_value_sequence(a))
    by thm absolute_ratio_terms_match_positive_ratio_terms(a)
    $pointwise_equal_sequences(absolute_ratio_terms(a), ratio_terms(absolute_value_sequence(a)))
    by thm finite_liminf_extensional(absolute_ratio_terms(a), ratio_terms(absolute_value_sequence(a)), beta)
    $has_finite_limit_inferior(ratio_terms(absolute_value_sequence(a)), beta)
    by thm ratio_liminf_greater_than_one_gives_root_limsup_above_one(absolute_value_sequence(a), beta)
    obtain gamma from exist gamma R st {$has_finite_limit_superior(root_test_terms(absolute_value_sequence(a)), gamma) and gamma > 1}
    $has_finite_limit_superior(root_test_terms(absolute_value_sequence(a)), gamma) and gamma > 1
    $has_finite_limit_superior(root_test_terms(absolute_value_sequence(a)), gamma)
    gamma > 1
    by thm root_test_terms_match_absolute_value_sequence(a)
    $pointwise_equal_sequences(root_test_terms(a), root_test_terms(absolute_value_sequence(a)))
    by thm pointwise_equal_sequences_symmetric(root_test_terms(a), root_test_terms(absolute_value_sequence(a)))
    $pointwise_equal_sequences(root_test_terms(absolute_value_sequence(a)), root_test_terms(a))
    by thm finite_limsup_extensional(root_test_terms(absolute_value_sequence(a)), root_test_terms(a), gamma)
    $has_finite_limit_superior(root_test_terms(a), gamma)
    by thm root_test_divergence(a, gamma)
    not $is_convergent_series(a)

"""
Proposition 7.5.4. The sequence n^(1/n) converges to 1.
"""

# The proof uses Lemma 7.5.2, the limit of `(n+1)/n`, and the
# liminf/limsup characterization of convergence.

have positive_natural_sequence seq(R) = fn(j N_pos) R {j}

claim:
    ? forall n N_pos:
        positive_natural_sequence(n) = n

claim:
    ? $is_positive_sequence(positive_natural_sequence)
    claim:
        ? forall n N_pos:
            positive_natural_sequence(n) > 0
        positive_natural_sequence(n) = n
        n > 0
        positive_natural_sequence(n) > 0
    $is_positive_sequence(positive_natural_sequence)

claim:
    ? $has_limit(ratio_terms(positive_natural_sequence), 1)
    $is_positive_sequence(positive_natural_sequence)
    claim:
        ? forall epsilon R_pos:
            exist n0 N_pos st {$is_tail_close_to(ratio_terms(positive_natural_sequence), 1, epsilon, n0)}
        by thm archimedean_property(epsilon)
        exist n_bound N_pos st {1 / n_bound < epsilon}
        obtain n0 from exist n0 N_pos st {1 / n0 < epsilon}
        witness exist n1 N_pos st {$is_tail_close_to(ratio_terms(positive_natural_sequence), 1, epsilon, n1)} from n0:
            claim:
                ? forall n N_pos:
                    n >= n0
                    =>:
                        abs(ratio_terms(positive_natural_sequence)(n) - 1) <= epsilon
                positive_natural_sequence(n) > 0
                by thm ratio_terms_eval(positive_natural_sequence, n)
                ratio_terms(positive_natural_sequence)(n) = positive_natural_sequence(n + 1) / positive_natural_sequence(n)
                n + 1 $in N_pos
                have k N_pos = n + 1
                positive_natural_sequence(k) = k
                positive_natural_sequence(n + 1) = positive_natural_sequence(k)
                positive_natural_sequence(n + 1) = k
                k = n + 1
                positive_natural_sequence(n) = n
                ratio_terms(positive_natural_sequence)(n) = (n + 1) / n
                (n + 1) / n - 1 = 1 / n
                n0 <= n
                n0 * n > 0
                1 / n = n0 / (n0 * n)
                n0 / (n0 * n) <= n / (n0 * n)
                n / (n0 * n) = 1 / n0
                1 / n <= 1 / n0
                1 / n <= 1 / n0 < epsilon
                1 / n < epsilon
                1 / n > 0
                abs((n + 1) / n - 1) = abs(1 / n)
                abs(1 / n) = 1 / n
                abs(ratio_terms(positive_natural_sequence)(n) - 1) = abs((n + 1) / n - 1)
                abs(ratio_terms(positive_natural_sequence)(n) - 1) < epsilon
                abs(ratio_terms(positive_natural_sequence)(n) - 1) <= epsilon
            $is_tail_close_to(ratio_terms(positive_natural_sequence), 1, epsilon, n0)
    $has_limit(ratio_terms(positive_natural_sequence), 1)

claim:
    ? $pointwise_equal_sequences(root_test_terms(positive_natural_sequence), fn(j N_pos) R {j^(1 / j)})
    claim:
        ? forall n N_pos:
            root_test_terms(positive_natural_sequence)(n) = fn(j N_pos) R {j^(1 / j)}(n)
        root_test_terms(positive_natural_sequence)(n) = abs(positive_natural_sequence(n))^(1 / n)
        positive_natural_sequence(n) = n
        abs(positive_natural_sequence(n)) = abs(n)
        abs(n) = n
        root_test_terms(positive_natural_sequence)(n) = n^(1 / n)
        fn(j N_pos) R {j^(1 / j)}(n) = n^(1 / n)
        root_test_terms(positive_natural_sequence)(n) = fn(j N_pos) R {j^(1 / j)}(n)
    $pointwise_equal_sequences(root_test_terms(positive_natural_sequence), fn(j N_pos) R {j^(1 / j)})

claim:
    ? $has_limit(fn(j N_pos) R {j^(1 / j)}, 1)
    $is_positive_sequence(positive_natural_sequence)
    $has_limit(ratio_terms(positive_natural_sequence), 1)
    by thm positive_sequence_ratio_limit_one_gives_root_limit_one(positive_natural_sequence)
    $has_limit(root_test_terms(positive_natural_sequence), 1)
    $pointwise_equal_sequences(root_test_terms(positive_natural_sequence), fn(j N_pos) R {j^(1 / j)})
    by thm has_limit_extensional(root_test_terms(positive_natural_sequence), fn(j N_pos) R {j^(1 / j)}, 1)
    $has_limit(fn(j N_pos) R {j^(1 / j)}, 1)

"""
Remark 7.5.5. The integral test is another important convergence test, but it
belongs with integration in Chapter 11.
"""

# The integral test is postponed until integration has been developed.
