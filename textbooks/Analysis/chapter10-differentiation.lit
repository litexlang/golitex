# 10.2 Local maxima, local minima, and derivatives

"""
Definition 10.2.1 (Local maxima and minima).  A local maximum or minimum at x0
means that a sufficiently small neighborhood of x0 inside the domain has a
global maximum or minimum at x0.
"""

# The source uses a restriction to `X intersect (x0-delta,x0+delta)`.  The
# equivalent inequality form states the same local condition without
# introducing a new restricted function.

prop is_local_maximum_witness(X set, f fn(x X) R, x0 X, delta R_pos):
    X $subset R
    forall x X:
        abs(x - x0) < delta
        =>:
            f(x) <= f(x0)

prop is_local_minimum_witness(X set, f fn(x X) R, x0 X, delta R_pos):
    X $subset R
    forall x X:
        abs(x - x0) < delta
        =>:
            f(x0) <= f(x)

prop is_local_maximum_at(X set, f fn(x X) R, x0 X):
    X $subset R
    exist delta R_pos st {$is_local_maximum_witness(X, f, x0, delta)}

prop is_local_minimum_at(X set, f fn(x X) R, x0 X):
    X $subset R
    exist delta R_pos st {$is_local_minimum_witness(X, f, x0, delta)}

prop is_local_extremum_at(X set, f fn(x X) R, x0 X):
    X $subset R
    $is_local_maximum_at(X, f, x0) or $is_local_minimum_at(X, f, x0)

"""
Remark 10.2.2. A global maximum is certainly a local maximum, and similarly
for minima.
"""

thm global_maximum_implies_local_maximum:
    ? forall X power_set(R), f fn(x X) R, x0 X:
        $chap9::is_maximizer_on(X, f, x0)
        =>:
            $is_local_maximum_at(X, f, x0)
    witness exist delta R_pos st {$is_local_maximum_witness(X, f, x0, delta)} from 1:
        forall x X:
            abs(x - x0) < 1
            =>:
                f(x) <= f(x0)
        $is_local_maximum_witness(X, f, x0, 1)
    $is_local_maximum_at(X, f, x0)

thm global_minimum_implies_local_minimum:
    ? forall X power_set(R), f fn(x X) R, x0 X:
        $chap9::is_minimizer_on(X, f, x0)
        =>:
            $is_local_minimum_at(X, f, x0)
    witness exist delta R_pos st {$is_local_minimum_witness(X, f, x0, delta)} from 1:
        forall x X:
            abs(x - x0) < 1
            =>:
                f(x0) <= f(x)
        $is_local_minimum_witness(X, f, x0, 1)
    $is_local_minimum_at(X, f, x0)

"""
Example 10.2.3.  The function `x^2-x^4` has no global minimum at 0 because
`f(2)=-12<0=f(0)`, but it has a local minimum at 0 on `(-1,1)` since
`x^4 <= x^2` there.
"""

# The global-minimum claim is refuted by the point `2`.  The local-minimum
# claim restricts the domain to `(-1,1)`, where `x^4 <= x^2`.

have fn quartic_minus_fourth_example(x R) R = x^2 - x^4
have fn quartic_minus_fourth_on_open_unit_interval(x '(-1, 1)) R = x^2 - x^4

thm quartic_minus_fourth_zero_is_not_global_minimizer:
    ? forall:
        not $chap9::is_minimizer_on(R, quartic_minus_fourth_example, 0)
    by contra:
        ? not $chap9::is_minimizer_on(R, quartic_minus_fourth_example, 0)
        $chap9::is_minimizer_on(R, quartic_minus_fourth_example, 0)
        quartic_minus_fourth_example(0) <= quartic_minus_fourth_example(2)
        quartic_minus_fourth_example = fn(x R) R {x^2 - x^4}
        quartic_minus_fourth_example(0) = 0^2 - 0^4
        0^2 - 0^4 = 0
        quartic_minus_fourth_example(2) = 2^2 - 2^4
        2^2 = 4
        2^4 = 16
        2^2 - 2^4 = 4 - 16
        4 - 16 = -12
        quartic_minus_fourth_example(2) = -12
        0 <= -12
        impossible 0 <= -12

thm fourth_power_le_square_on_open_unit_interval:
    ? forall x '(-1, 1):
        x^4 <= x^2
    x > -1
    x < 1
    x - 1 < 0
    x - (-1) > 0
    x + 1 = x - (-1)
    x - (-1) = x + 1
    x + 1 > 0
    (x - 1) * (x + 1) < 0
    x^2 - 1 = (x - 1) * (x + 1)
    x^2 - 1 < 0
    x^2 < 1
    x^2 <= 1
    x^2 >= 0
    x^4 = x^2 * x^2
    x^2 * x^2 <= x^2 * 1
    x^2 * 1 = x^2
    x^4 <= x^2

thm quartic_minus_fourth_has_local_minimum_at_zero:
    ? forall:
        $is_local_minimum_at('(-1, 1), quartic_minus_fourth_on_open_unit_interval, 0)
    0 $in '(-1, 1)
    witness exist delta R_pos st {$is_local_minimum_witness('(-1, 1), quartic_minus_fourth_on_open_unit_interval, 0, delta)} from 1:
        claim:
            ? forall x '(-1, 1):
                abs(x - 0) < 1
                =>:
                    quartic_minus_fourth_on_open_unit_interval(0) <= quartic_minus_fourth_on_open_unit_interval(x)
            by thm fourth_power_le_square_on_open_unit_interval(x)
            x^4 <= x^2
            quartic_minus_fourth_on_open_unit_interval(0) = 0^2 - 0^4
            0^2 - 0^4 = 0
            quartic_minus_fourth_on_open_unit_interval(x) = x^2 - x^4
            x^2 - x^4 >= 0
            0 <= x^2 - x^4
            quartic_minus_fourth_on_open_unit_interval(0) <= quartic_minus_fourth_on_open_unit_interval(x)
        $is_local_minimum_witness('(-1, 1), quartic_minus_fourth_on_open_unit_interval, 0, 1)
    $is_local_minimum_at('(-1, 1), quartic_minus_fourth_on_open_unit_interval, 0)


"""
Example 10.2.4.  The identity function on Z has no global maximum or minimum,
but every integer is both a local maximum and a local minimum because Z has
isolated points.
"""

# The global extrema fail because `m+1` is larger than any proposed maximum
# and `m-1` is smaller than any proposed minimum.  The local extrema use the
# half-radius isolation of each integer point.

have fn integer_identity_as_real(x Z) R = x

thm integer_identity_has_no_global_maximum_at:
    ? forall m Z:
        not $chap9::is_maximizer_on(Z, integer_identity_as_real, m)
    by contra:
        ? not $chap9::is_maximizer_on(Z, integer_identity_as_real, m)
        $chap9::is_maximizer_on(Z, integer_identity_as_real, m)
        m + 1 $in Z
        integer_identity_as_real(m + 1) <= integer_identity_as_real(m)
        integer_identity_as_real = fn(x Z) R {x}
        integer_identity_as_real(m + 1) = m + 1
        integer_identity_as_real(m) = m
        m + 1 <= m
        m + 1 > m
        impossible m + 1 <= m

thm integer_identity_has_no_global_minimum_at:
    ? forall m Z:
        not $chap9::is_minimizer_on(Z, integer_identity_as_real, m)
    by contra:
        ? not $chap9::is_minimizer_on(Z, integer_identity_as_real, m)
        $chap9::is_minimizer_on(Z, integer_identity_as_real, m)
        m - 1 $in Z
        integer_identity_as_real(m) <= integer_identity_as_real(m - 1)
        integer_identity_as_real = fn(x Z) R {x}
        integer_identity_as_real(m) = m
        integer_identity_as_real(m - 1) = m - 1
        m <= m - 1
        m - 1 < m
        impossible m <= m - 1

thm integer_identity_attains_no_global_maximum:
    ? forall:
        not $chap9::attains_maximum_on(Z, integer_identity_as_real)
    by contra:
        ? not $chap9::attains_maximum_on(Z, integer_identity_as_real)
        $chap9::attains_maximum_on(Z, integer_identity_as_real)
        obtain c from exist c Z st {$chap9::is_maximizer_on(Z, integer_identity_as_real, c)}
        by thm integer_identity_has_no_global_maximum_at(c)
        not $chap9::is_maximizer_on(Z, integer_identity_as_real, c)
        impossible not $chap9::is_maximizer_on(Z, integer_identity_as_real, c)

thm integer_identity_attains_no_global_minimum:
    ? forall:
        not $chap9::attains_minimum_on(Z, integer_identity_as_real)
    by contra:
        ? not $chap9::attains_minimum_on(Z, integer_identity_as_real)
        $chap9::attains_minimum_on(Z, integer_identity_as_real)
        obtain c from exist c Z st {$chap9::is_minimizer_on(Z, integer_identity_as_real, c)}
        by thm integer_identity_has_no_global_minimum_at(c)
        not $chap9::is_minimizer_on(Z, integer_identity_as_real, c)
        impossible not $chap9::is_minimizer_on(Z, integer_identity_as_real, c)

thm integer_points_are_half_isolated:
    ? forall m, n Z:
        abs(n - m) < 1 / 2
        =>:
            n = m
    n - m $in Z
    n - m > 0 or n - m = 0 or n - m < 0
    by cases:
        ? n = m
        case n - m > 0:
            n - m $in N_pos
            n - m >= 1
            abs(n - m) = n - m
            abs(n - m) >= 1
            1 / 2 < 1
            abs(n - m) < 1 / 2 < 1
            abs(n - m) < 1
            impossible abs(n - m) >= 1
        case n - m = 0:
            n = m
        case n - m < 0:
            -(n - m) > 0
            m - n = -(n - m)
            m - n > 0
            m - n $in Z
            m - n $in N_pos
            m - n >= 1
            -(n - m) = m - n
            abs(n - m) = -(n - m)
            abs(n - m) = m - n
            abs(n - m) >= 1
            1 / 2 < 1
            abs(n - m) < 1 / 2 < 1
            abs(n - m) < 1
            impossible abs(n - m) >= 1

thm integer_identity_every_integer_is_local_maximum:
    ? forall m Z:
        $is_local_maximum_at(Z, integer_identity_as_real, m)
    witness exist delta R_pos st {$is_local_maximum_witness(Z, integer_identity_as_real, m, delta)} from 1 / 2:
        1 / 2 $in R_pos
        claim:
            ? forall x Z:
                abs(x - m) < 1 / 2
                =>:
                    integer_identity_as_real(x) <= integer_identity_as_real(m)
            by thm integer_points_are_half_isolated(m, x)
            x = m
            integer_identity_as_real = fn(x Z) R {x}
            integer_identity_as_real(x) = x
            integer_identity_as_real(m) = m
            x <= m
            integer_identity_as_real(x) <= integer_identity_as_real(m)
        $is_local_maximum_witness(Z, integer_identity_as_real, m, 1 / 2)
    $is_local_maximum_at(Z, integer_identity_as_real, m)

thm integer_identity_every_integer_is_local_minimum:
    ? forall m Z:
        $is_local_minimum_at(Z, integer_identity_as_real, m)
    witness exist delta R_pos st {$is_local_minimum_witness(Z, integer_identity_as_real, m, delta)} from 1 / 2:
        1 / 2 $in R_pos
        claim:
            ? forall x Z:
                abs(x - m) < 1 / 2
                =>:
                    integer_identity_as_real(m) <= integer_identity_as_real(x)
            by thm integer_points_are_half_isolated(m, x)
            x = m
            integer_identity_as_real = fn(x Z) R {x}
            integer_identity_as_real(x) = x
            integer_identity_as_real(m) = m
            m <= x
            integer_identity_as_real(m) <= integer_identity_as_real(x)
        $is_local_minimum_witness(Z, integer_identity_as_real, m, 1 / 2)
    $is_local_minimum_at(Z, integer_identity_as_real, m)

"""
Remark 10.2.5.  Restricting the domain to a subset containing x0 preserves a
local maximum or local minimum at x0.
"""

# This follows by using the same delta witness and quantifying over fewer
# points.

thm local_maximum_restrict_domain:
    ? forall X, Y power_set(R), f fn(x X) R, g fn(y Y) R, x0 X:
        x0 $in Y
        Y $subset X
        forall y Y:
            g(y) = f(y)
        $is_local_maximum_at(X, f, x0)
        =>:
            $is_local_maximum_at(Y, g, x0)
    obtain delta from exist delta R_pos st {$is_local_maximum_witness(X, f, x0, delta)}
    witness exist eta R_pos st {$is_local_maximum_witness(Y, g, x0, eta)} from delta:
        claim:
            ? forall y Y:
                abs(y - x0) < delta
                =>:
                    g(y) <= g(x0)
            y $in X
            f(y) <= f(x0)
            g(y) = f(y)
            g(x0) = f(x0)
            g(y) <= g(x0)
        $is_local_maximum_witness(Y, g, x0, delta)
    $is_local_maximum_at(Y, g, x0)

thm local_minimum_restrict_domain:
    ? forall X, Y power_set(R), f fn(x X) R, g fn(y Y) R, x0 X:
        x0 $in Y
        Y $subset X
        forall y Y:
            g(y) = f(y)
        $is_local_minimum_at(X, f, x0)
        =>:
            $is_local_minimum_at(Y, g, x0)
    obtain delta from exist delta R_pos st {$is_local_minimum_witness(X, f, x0, delta)}
    witness exist eta R_pos st {$is_local_minimum_witness(Y, g, x0, eta)} from delta:
        claim:
            ? forall y Y:
                abs(y - x0) < delta
                =>:
                    g(x0) <= g(y)
            y $in X
            f(x0) <= f(y)
            g(y) = f(y)
            g(x0) = f(x0)
            g(x0) <= g(y)
        $is_local_minimum_witness(Y, g, x0, delta)
    $is_local_minimum_at(Y, g, x0)

"""
Proposition 10.2.6 (Local extrema are stationary).  If f is differentiable at
an interior point x0 of an open interval and has a local maximum or minimum
there, then f'(x0)=0.
"""

# Proof-package helpers for Proposition 10.2.6: choose one-sided
# nearby points in an open interval, record the corresponding quotient signs,
# and squeeze the derivative value from both sides.

thm open_interval_has_nearby_right_point:
    ? forall a, b R, x0 '(a, b), epsilon R_pos:
        exist y '(a, b) st {x0 < y, y != x0, abs(y - x0) <= epsilon}
    x0 < b
    b - x0 > 0
    b - x0 $in R_pos
    min(epsilon, b - x0) $in R_pos
    min(epsilon, b - x0) <= epsilon
    min(epsilon, b - x0) <= b - x0
    have t R_pos = min(epsilon, b - x0)
    t = min(epsilon, b - x0)
    t <= epsilon
    t <= b - x0
    t / 2 > 0
    t / 2 < t
    t / 2 <= t
    have eta R = t / 2
    eta = t / 2
    eta > 0
    eta $in R_pos
    eta < t
    eta <= t
    eta <= t <= epsilon
    eta <= epsilon
    eta < t <= b - x0
    eta < b - x0
    x0 + eta < x0 + (b - x0)
    x0 + (b - x0) = b
    x0 + eta < b
    a < x0
    a < x0 + eta
    x0 < x0 + eta
    x0 + eta $in '(a, b)
    x0 + eta != x0
    (x0 + eta) - x0 = eta
    abs(eta) = eta
    abs((x0 + eta) - x0) = abs(eta)
    abs((x0 + eta) - x0) = eta
    abs((x0 + eta) - x0) <= epsilon
    witness exist y '(a, b) st {x0 < y, y != x0, abs(y - x0) <= epsilon} from x0 + eta:
        x0 < x0 + eta
        x0 + eta != x0
        abs((x0 + eta) - x0) <= epsilon

thm open_interval_has_nearby_left_point:
    ? forall a, b R, x0 '(a, b), epsilon R_pos:
        exist y '(a, b) st {y < x0, y != x0, abs(y - x0) <= epsilon}
    a < x0
    x0 - a > 0
    x0 - a $in R_pos
    min(epsilon, x0 - a) $in R_pos
    min(epsilon, x0 - a) <= epsilon
    min(epsilon, x0 - a) <= x0 - a
    have t R_pos = min(epsilon, x0 - a)
    t = min(epsilon, x0 - a)
    t <= epsilon
    t <= x0 - a
    t / 2 > 0
    t / 2 < t
    t / 2 <= t
    have eta R = t / 2
    eta = t / 2
    eta > 0
    eta $in R_pos
    eta < t
    eta <= t
    eta <= t <= epsilon
    eta <= epsilon
    eta < t <= x0 - a
    eta < x0 - a
    x0 - eta > x0 - (x0 - a)
    x0 - (x0 - a) = a
    x0 - eta > a
    a < x0 - eta
    x0 - eta < x0
    x0 < b
    x0 - eta < b
    x0 - eta $in '(a, b)
    x0 - eta != x0
    (x0 - eta) - x0 = -eta
    abs(-eta) = abs(eta)
    abs(eta) = eta
    abs((x0 - eta) - x0) = abs(-eta)
    abs((x0 - eta) - x0) = eta
    abs((x0 - eta) - x0) <= epsilon
    witness exist y '(a, b) st {y < x0, y != x0, abs(y - x0) <= epsilon} from x0 - eta:
        x0 - eta < x0
        x0 - eta != x0
        abs((x0 - eta) - x0) <= epsilon


thm local_maximum_right_difference_quotient_nonpositive:
    ? forall a, b R, f fn(x '(a, b)) R, x0, y '(a, b), delta R_pos:
        $is_local_maximum_witness('(a, b), f, x0, delta)
        x0 < y
        y != x0
        abs(y - x0) < delta
        =>:
            (f(y) - f(x0)) / (y - x0) <= 0
    y - x0 != 0
    f(y) <= f(x0)
    f(y) - f(x0) <= 0
    y - x0 > 0
    0 / (y - x0) = 0
    (f(y) - f(x0)) / (y - x0) <= 0 / (y - x0)
    (f(y) - f(x0)) / (y - x0) <= 0 / (y - x0) = 0
    (f(y) - f(x0)) / (y - x0) <= 0

thm local_maximum_left_difference_quotient_nonnegative:
    ? forall a, b R, f fn(x '(a, b)) R, x0, y '(a, b), delta R_pos:
        $is_local_maximum_witness('(a, b), f, x0, delta)
        y < x0
        y != x0
        abs(y - x0) < delta
        =>:
            (f(y) - f(x0)) / (y - x0) >= 0
    y - x0 != 0
    f(y) <= f(x0)
    f(y) - f(x0) <= 0
    y - x0 < 0
    0 / (y - x0) = 0
    (f(y) - f(x0)) / (y - x0) >= 0 / (y - x0)
    (f(y) - f(x0)) / (y - x0) >= 0 / (y - x0) = 0
    (f(y) - f(x0)) / (y - x0) >= 0

thm local_minimum_right_difference_quotient_nonnegative:
    ? forall a, b R, f fn(x '(a, b)) R, x0, y '(a, b), delta R_pos:
        $is_local_minimum_witness('(a, b), f, x0, delta)
        x0 < y
        y != x0
        abs(y - x0) < delta
        =>:
            (f(y) - f(x0)) / (y - x0) >= 0
    y - x0 != 0
    f(x0) <= f(y)
    f(y) - f(x0) >= 0
    y - x0 > 0
    0 / (y - x0) = 0
    (f(y) - f(x0)) / (y - x0) >= 0 / (y - x0)
    (f(y) - f(x0)) / (y - x0) >= 0 / (y - x0) = 0
    (f(y) - f(x0)) / (y - x0) >= 0

thm local_minimum_left_difference_quotient_nonpositive:
    ? forall a, b R, f fn(x '(a, b)) R, x0, y '(a, b), delta R_pos:
        $is_local_minimum_witness('(a, b), f, x0, delta)
        y < x0
        y != x0
        abs(y - x0) < delta
        =>:
            (f(y) - f(x0)) / (y - x0) <= 0
    y - x0 != 0
    f(x0) <= f(y)
    f(y) - f(x0) >= 0
    y - x0 < 0
    0 / (y - x0) = 0
    (f(y) - f(x0)) / (y - x0) <= 0 / (y - x0)
    (f(y) - f(x0)) / (y - x0) <= 0 / (y - x0) = 0
    (f(y) - f(x0)) / (y - x0) <= 0


thm local_maximum_derivative_nonpositive_has_derivative_at:
    ? forall a, b R, f fn(x '(a, b)) R, x0 '(a, b), L R:
        $has_derivative_at('(a, b), f, x0, L)
        $is_local_maximum_at('(a, b), f, x0)
        =>:
            L <= 0
    by contra:
        ? L <= 0
        L > 0
        L / 2 $in R_pos
        obtain delta_d from exist delta_d R_pos st {$is_difference_quotient_close_to('(a, b), f, x0, L, L / 2, delta_d)}
        obtain delta_m from exist delta_m R_pos st {$is_local_maximum_witness('(a, b), f, x0, delta_m)}
        min(delta_d, delta_m) $in R_pos
        min(delta_d, delta_m) / 2 $in R_pos
        by thm open_interval_has_nearby_right_point(a, b, x0, min(delta_d, delta_m) / 2)
        obtain y from exist y '(a, b) st {x0 < y, y != x0, abs(y - x0) <= min(delta_d, delta_m) / 2}
        min(delta_d, delta_m) / 2 < min(delta_d, delta_m)
        abs(y - x0) <= min(delta_d, delta_m) / 2 < min(delta_d, delta_m)
        abs(y - x0) < min(delta_d, delta_m)
        min(delta_d, delta_m) <= delta_d
        min(delta_d, delta_m) <= delta_m
        abs(y - x0) < min(delta_d, delta_m) <= delta_d
        abs(y - x0) < delta_d
        abs(y - x0) < min(delta_d, delta_m) <= delta_m
        abs(y - x0) < delta_m
        y - x0 != 0
        by thm local_maximum_right_difference_quotient_nonpositive(a, b, f, x0, y, delta_m)
        (f(y) - f(x0)) / (y - x0) <= 0
        have q R = (f(y) - f(x0)) / (y - x0)
        q = (f(y) - f(x0)) / (y - x0)
        q <= 0
        abs(((f(y) - f(x0)) / (y - x0)) - L) <= L / 2
        ((f(y) - f(x0)) / (y - x0)) - L = q - L
        abs(((f(y) - f(x0)) / (y - x0)) - L) = abs(q - L)
        abs(q - L) <= L / 2
        L - q >= L - 0
        L - 0 = L
        L - q >= L - 0 = L
        L - q >= L
        L > L / 2
        L - q >= L > L / 2
        L - q > L / 2
        q - L < 0
        abs(q - L) = -(q - L)
        -(q - L) = L - q
        abs(q - L) = L - q
        abs(q - L) > L / 2
        impossible abs(q - L) <= L / 2

thm local_minimum_derivative_nonpositive_has_derivative_at:
    ? forall a, b R, f fn(x '(a, b)) R, x0 '(a, b), L R:
        $has_derivative_at('(a, b), f, x0, L)
        $is_local_minimum_at('(a, b), f, x0)
        =>:
            L <= 0
    by contra:
        ? L <= 0
        L > 0
        L / 2 $in R_pos
        obtain delta_d from exist delta_d R_pos st {$is_difference_quotient_close_to('(a, b), f, x0, L, L / 2, delta_d)}
        obtain delta_m from exist delta_m R_pos st {$is_local_minimum_witness('(a, b), f, x0, delta_m)}
        min(delta_d, delta_m) $in R_pos
        min(delta_d, delta_m) / 2 $in R_pos
        by thm open_interval_has_nearby_left_point(a, b, x0, min(delta_d, delta_m) / 2)
        obtain y from exist y '(a, b) st {y < x0, y != x0, abs(y - x0) <= min(delta_d, delta_m) / 2}
        min(delta_d, delta_m) / 2 < min(delta_d, delta_m)
        abs(y - x0) <= min(delta_d, delta_m) / 2 < min(delta_d, delta_m)
        abs(y - x0) < min(delta_d, delta_m)
        min(delta_d, delta_m) <= delta_d
        min(delta_d, delta_m) <= delta_m
        abs(y - x0) < min(delta_d, delta_m) <= delta_d
        abs(y - x0) < delta_d
        abs(y - x0) < min(delta_d, delta_m) <= delta_m
        abs(y - x0) < delta_m
        y - x0 != 0
        by thm local_minimum_left_difference_quotient_nonpositive(a, b, f, x0, y, delta_m)
        (f(y) - f(x0)) / (y - x0) <= 0
        have q R = (f(y) - f(x0)) / (y - x0)
        q = (f(y) - f(x0)) / (y - x0)
        q <= 0
        abs(((f(y) - f(x0)) / (y - x0)) - L) <= L / 2
        ((f(y) - f(x0)) / (y - x0)) - L = q - L
        abs(((f(y) - f(x0)) / (y - x0)) - L) = abs(q - L)
        abs(q - L) <= L / 2
        L - q >= L - 0
        L - 0 = L
        L - q >= L - 0 = L
        L - q >= L
        L > L / 2
        L - q >= L > L / 2
        L - q > L / 2
        q - L < 0
        abs(q - L) = -(q - L)
        -(q - L) = L - q
        abs(q - L) = L - q
        abs(q - L) > L / 2
        impossible abs(q - L) <= L / 2

thm local_maximum_derivative_nonnegative_has_derivative_at:
    ? forall a, b R, f fn(x '(a, b)) R, x0 '(a, b), L R:
        $has_derivative_at('(a, b), f, x0, L)
        $is_local_maximum_at('(a, b), f, x0)
        =>:
            L >= 0
    by contra:
        ? L >= 0
        L < 0
        0 - L > 0
        (0 - L) / 2 $in R_pos
        obtain delta_d from exist delta_d R_pos st {$is_difference_quotient_close_to('(a, b), f, x0, L, (0 - L) / 2, delta_d)}
        obtain delta_m from exist delta_m R_pos st {$is_local_maximum_witness('(a, b), f, x0, delta_m)}
        min(delta_d, delta_m) $in R_pos
        min(delta_d, delta_m) / 2 $in R_pos
        by thm open_interval_has_nearby_left_point(a, b, x0, min(delta_d, delta_m) / 2)
        obtain y from exist y '(a, b) st {y < x0, y != x0, abs(y - x0) <= min(delta_d, delta_m) / 2}
        min(delta_d, delta_m) / 2 < min(delta_d, delta_m)
        abs(y - x0) <= min(delta_d, delta_m) / 2 < min(delta_d, delta_m)
        abs(y - x0) < min(delta_d, delta_m)
        min(delta_d, delta_m) <= delta_d
        min(delta_d, delta_m) <= delta_m
        abs(y - x0) < min(delta_d, delta_m) <= delta_d
        abs(y - x0) < delta_d
        abs(y - x0) < min(delta_d, delta_m) <= delta_m
        abs(y - x0) < delta_m
        y - x0 != 0
        by thm local_maximum_left_difference_quotient_nonnegative(a, b, f, x0, y, delta_m)
        (f(y) - f(x0)) / (y - x0) >= 0
        have q R = (f(y) - f(x0)) / (y - x0)
        q = (f(y) - f(x0)) / (y - x0)
        q >= 0
        abs(((f(y) - f(x0)) / (y - x0)) - L) <= (0 - L) / 2
        ((f(y) - f(x0)) / (y - x0)) - L = q - L
        abs(((f(y) - f(x0)) / (y - x0)) - L) = abs(q - L)
        abs(q - L) <= (0 - L) / 2
        q - L >= 0 - L
        0 - L > (0 - L) / 2
        q - L >= 0 - L > (0 - L) / 2
        q - L > (0 - L) / 2
        q - L >= 0 - L > 0
        q - L > 0
        abs(q - L) = q - L
        abs(q - L) > (0 - L) / 2
        impossible abs(q - L) <= (0 - L) / 2

thm local_minimum_derivative_nonnegative_has_derivative_at:
    ? forall a, b R, f fn(x '(a, b)) R, x0 '(a, b), L R:
        $has_derivative_at('(a, b), f, x0, L)
        $is_local_minimum_at('(a, b), f, x0)
        =>:
            L >= 0
    by contra:
        ? L >= 0
        L < 0
        0 - L > 0
        (0 - L) / 2 $in R_pos
        obtain delta_d from exist delta_d R_pos st {$is_difference_quotient_close_to('(a, b), f, x0, L, (0 - L) / 2, delta_d)}
        obtain delta_m from exist delta_m R_pos st {$is_local_minimum_witness('(a, b), f, x0, delta_m)}
        min(delta_d, delta_m) $in R_pos
        min(delta_d, delta_m) / 2 $in R_pos
        by thm open_interval_has_nearby_right_point(a, b, x0, min(delta_d, delta_m) / 2)
        obtain y from exist y '(a, b) st {x0 < y, y != x0, abs(y - x0) <= min(delta_d, delta_m) / 2}
        min(delta_d, delta_m) / 2 < min(delta_d, delta_m)
        abs(y - x0) <= min(delta_d, delta_m) / 2 < min(delta_d, delta_m)
        abs(y - x0) < min(delta_d, delta_m)
        min(delta_d, delta_m) <= delta_d
        min(delta_d, delta_m) <= delta_m
        abs(y - x0) < min(delta_d, delta_m) <= delta_d
        abs(y - x0) < delta_d
        abs(y - x0) < min(delta_d, delta_m) <= delta_m
        abs(y - x0) < delta_m
        y - x0 != 0
        by thm local_minimum_right_difference_quotient_nonnegative(a, b, f, x0, y, delta_m)
        (f(y) - f(x0)) / (y - x0) >= 0
        have q R = (f(y) - f(x0)) / (y - x0)
        q = (f(y) - f(x0)) / (y - x0)
        q >= 0
        abs(((f(y) - f(x0)) / (y - x0)) - L) <= (0 - L) / 2
        ((f(y) - f(x0)) / (y - x0)) - L = q - L
        abs(((f(y) - f(x0)) / (y - x0)) - L) = abs(q - L)
        abs(q - L) <= (0 - L) / 2
        q - L >= 0 - L
        0 - L > (0 - L) / 2
        q - L >= 0 - L > (0 - L) / 2
        q - L > (0 - L) / 2
        q - L >= 0 - L > 0
        q - L > 0
        abs(q - L) = q - L
        abs(q - L) > (0 - L) / 2
        impossible abs(q - L) <= (0 - L) / 2

thm local_extremum_stationary_has_derivative_at:
    ? forall a, b R, f fn(x '(a, b)) R, x0 '(a, b), L R:
        a < b
        $has_derivative_at('(a, b), f, x0, L)
        $is_local_extremum_at('(a, b), f, x0)
        =>:
            L = 0
    claim:
        ? L <= 0
        $is_local_maximum_at('(a, b), f, x0) or $is_local_minimum_at('(a, b), f, x0)
        by cases:
            ? L <= 0
            case $is_local_maximum_at('(a, b), f, x0):
                by thm local_maximum_derivative_nonpositive_has_derivative_at(a, b, f, x0, L)
                L <= 0
            case $is_local_minimum_at('(a, b), f, x0):
                by thm local_minimum_derivative_nonpositive_has_derivative_at(a, b, f, x0, L)
                L <= 0
    claim:
        ? L >= 0
        $is_local_maximum_at('(a, b), f, x0) or $is_local_minimum_at('(a, b), f, x0)
        by cases:
            ? L >= 0
            case $is_local_maximum_at('(a, b), f, x0):
                by thm local_maximum_derivative_nonnegative_has_derivative_at(a, b, f, x0, L)
                L >= 0
            case $is_local_minimum_at('(a, b), f, x0):
                by thm local_minimum_derivative_nonnegative_has_derivative_at(a, b, f, x0, L)
                L >= 0
    L <= 0
    L >= 0
    L = 0

thm local_extremum_stationary:
    ? forall a, b R, f fn(x '(a, b)) R, x0 '(a, b):
        a < b
        $is_differentiable_at('(a, b), f, x0)
        $is_local_extremum_at('(a, b), f, x0)
        =>:
            derivative('(a, b), f, x0) = 0
    obtain L from exist L R st {$has_derivative_at('(a, b), f, x0, L)}
    by thm local_extremum_stationary_has_derivative_at(a, b, f, x0, L)
    L = 0
    L = derivative('(a, b), f, x0)
    derivative('(a, b), f, x0) = L
    derivative('(a, b), f, x0) = 0

# An interior point sees the same difference quotients whether the ambient
# domain is the closed interval or its open interior.
thm derivative_at_on_open_interval:
    ? forall a, b R, f fn(x '[a, b]) R, x0 '(a, b), L R:
        a < b
        $has_derivative_at('[a, b], f, x0, L)
        =>:
            $has_derivative_at('(a, b), fn(x '(a, b)) R {f(x)}, x0, L)
    by thm chap9::open_interval_points_are_limit_points(a, b, x0)
    $chap9::is_limit_point_of_set('(a, b), x0)
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$is_difference_quotient_close_to('(a, b), fn(x '(a, b)) R {f(x)}, x0, L, epsilon, delta)}
        obtain delta from exist delta R_pos st {$is_difference_quotient_close_to('[a, b], f, x0, L, epsilon, delta)}
        witness exist delta0 R_pos st {$is_difference_quotient_close_to('(a, b), fn(x '(a, b)) R {f(x)}, x0, L, epsilon, delta0)} from delta:
            claim:
                ? forall y '(a, b):
                    y - x0 != 0
                    abs(y - x0) < delta
                    =>:
                        abs(((fn(x '(a, b)) R {f(x)}(y) - fn(x '(a, b)) R {f(x)}(x0)) / (y - x0)) - L) <= epsilon
                abs((f(y) - f(x0)) / (y - x0) - L) <= epsilon
                fn(x '(a, b)) R {f(x)}(y) = f(y)
                fn(x '(a, b)) R {f(x)}(x0) = f(x0)
                (fn(x '(a, b)) R {f(x)}(y) - fn(x '(a, b)) R {f(x)}(x0)) / (y - x0) = (f(y) - f(x0)) / (y - x0)
                abs(((fn(x '(a, b)) R {f(x)}(y) - fn(x '(a, b)) R {f(x)}(x0)) / (y - x0)) - L) = abs((f(y) - f(x0)) / (y - x0) - L)
                abs(((fn(x '(a, b)) R {f(x)}(y) - fn(x '(a, b)) R {f(x)}(x0)) / (y - x0)) - L) <= epsilon
            $is_difference_quotient_close_to('(a, b), fn(x '(a, b)) R {f(x)}, x0, L, epsilon, delta0)
    $has_derivative_at('(a, b), fn(x '(a, b)) R {f(x)}, x0, L)

thm local_extremum_on_closed_interval_is_local_extremum_on_open_interval:
    ? forall a, b R, f fn(x '[a, b]) R, x0 '(a, b):
        $is_local_extremum_at('[a, b], f, x0)
        =>:
            $is_local_extremum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0)
    $is_local_maximum_at('[a, b], f, x0) or $is_local_minimum_at('[a, b], f, x0)
    by cases:
        ? $is_local_extremum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0)
        case $is_local_maximum_at('[a, b], f, x0):
            obtain delta from exist delta R_pos st {$is_local_maximum_witness('[a, b], f, x0, delta)}
            claim:
                ? $is_local_maximum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0)
                witness exist delta0 R_pos st {$is_local_maximum_witness('(a, b), fn(x '(a, b)) R {f(x)}, x0, delta0)} from delta:
                    claim:
                        ? forall y '(a, b):
                            abs(y - x0) < delta
                            =>:
                                fn(x '(a, b)) R {f(x)}(y) <= fn(x '(a, b)) R {f(x)}(x0)
                        f(y) <= f(x0)
                        fn(x '(a, b)) R {f(x)}(y) = f(y)
                        fn(x '(a, b)) R {f(x)}(x0) = f(x0)
                        fn(x '(a, b)) R {f(x)}(y) <= fn(x '(a, b)) R {f(x)}(x0)
                    $is_local_maximum_witness('(a, b), fn(x '(a, b)) R {f(x)}, x0, delta0)
                $is_local_maximum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0)
            '(a, b) $subset R
            $is_local_maximum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0)
            $is_local_maximum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0) or $is_local_minimum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0)
            $is_local_extremum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0)
        case $is_local_minimum_at('[a, b], f, x0):
            obtain delta from exist delta R_pos st {$is_local_minimum_witness('[a, b], f, x0, delta)}
            claim:
                ? $is_local_minimum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0)
                witness exist delta0 R_pos st {$is_local_minimum_witness('(a, b), fn(x '(a, b)) R {f(x)}, x0, delta0)} from delta:
                    claim:
                        ? forall y '(a, b):
                            abs(y - x0) < delta
                            =>:
                                fn(x '(a, b)) R {f(x)}(x0) <= fn(x '(a, b)) R {f(x)}(y)
                        f(x0) <= f(y)
                        fn(x '(a, b)) R {f(x)}(x0) = f(x0)
                        fn(x '(a, b)) R {f(x)}(y) = f(y)
                        fn(x '(a, b)) R {f(x)}(x0) <= fn(x '(a, b)) R {f(x)}(y)
                    $is_local_minimum_witness('(a, b), fn(x '(a, b)) R {f(x)}, x0, delta0)
                $is_local_minimum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0)
            '(a, b) $subset R
            $is_local_minimum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0)
            $is_local_maximum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0) or $is_local_minimum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0)
            $is_local_extremum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0)

thm local_extremum_stationary_on_closed_interval:
    ? forall a, b R, f fn(x '[a, b]) R, x0 '(a, b), L R:
        a < b
        $has_derivative_at('[a, b], f, x0, L)
        $is_local_extremum_at('[a, b], f, x0)
        =>:
            L = 0
    by thm derivative_at_on_open_interval(a, b, f, x0, L)
    $has_derivative_at('(a, b), fn(x '(a, b)) R {f(x)}, x0, L)
    by thm local_extremum_on_closed_interval_is_local_extremum_on_open_interval(a, b, f, x0)
    $is_local_extremum_at('(a, b), fn(x '(a, b)) R {f(x)}, x0)
    by thm local_extremum_stationary_has_derivative_at(a, b, fn(x '(a, b)) R {f(x)}, x0, L)
    L = 0

"""
The discussion after Proposition 10.2.6.  Differentiability and the open
interval hypothesis are necessary, and the converse is false.
"""

# The proposition is one-way and depends on both hypotheses: endpoints, corners,
# and nondifferentiable extrema are outside its scope.

"""
Theorem 10.2.7 (Rolle's theorem).  If a continuous function on `[a,b]` is
differentiable on `(a,b)` and has equal endpoint values, then some interior
point has derivative zero.
"""

# Rolle's theorem combines the maximum principle with Proposition 10.2.6.  The
# equal endpoint values force an interior extremum unless the function is
# constant; at that interior extremum the derivative is zero.

prop has_value_distinct_from_left_endpoint(a, b R, g fn(x '[a, b]) R):
    a <= b
    exist z '[a, b] st {g(z) != g(a)}

thm rolle_theorem:
    ? forall a, b R, g fn(x '[a, b]) R:
        a < b
        $chap9::is_continuous_on('[a, b], g)
        forall x0 '(a, b):
            $is_differentiable_at('[a, b], g, x0)
        g(a) = g(b)
        =>:
            exist x '(a, b), L R st {$has_derivative_at('[a, b], g, x, L), L = 0}
    $has_value_distinct_from_left_endpoint(a, b, g) or not $has_value_distinct_from_left_endpoint(a, b, g)
    by cases:
        ? exist x '(a, b), L R st {$has_derivative_at('[a, b], g, x, L), L = 0}
        case not $has_value_distinct_from_left_endpoint(a, b, g):
            claim:
                ? not exist z '[a, b] st {g(z) != g(a)}
                by contra:
                    ? not exist z '[a, b] st {g(z) != g(a)}
                    exist z '[a, b] st {g(z) != g(a)}
                    a <= b
                    $has_value_distinct_from_left_endpoint(a, b, g)
                    impossible not $has_value_distinct_from_left_endpoint(a, b, g)
            not exist z '[a, b] st {g(z) != g(a)}
            claim:
                ? forall x '[a, b]:
                    g(x) = g(a)
                not g(x) != g(a)
                g(x) = g(a)
            forall x '[a, b]:
                g(x) = g(a)
            b - a > 0
            (b - a) / 2 > 0
            (a + b) / 2 - a = (b - a) / 2
            (a + b) / 2 - a > 0
            a < (a + b) / 2
            b - (a + b) / 2 = (b - a) / 2
            b - (a + b) / 2 > 0
            (a + b) / 2 < b
            (a + b) / 2 $in '(a, b)
            have x0 '(a, b) = (a + b) / 2
            by thm chap9::closed_interval_points_are_limit_points(a, b, x0)
            $chap9::is_limit_point_of_set('[a, b], x0)
            by thm constant_function_has_derivative_at('[a, b], g, x0, g(a))
            $has_derivative_at('[a, b], g, x0, 0)
            witness exist x '(a, b), L R st {$has_derivative_at('[a, b], g, x, L), L = 0} from x0, 0:
                $has_derivative_at('[a, b], g, x0, 0)
                0 = 0
        case $has_value_distinct_from_left_endpoint(a, b, g):
            obtain z from exist z '[a, b] st {g(z) != g(a)}
            g(z) < g(a) or not g(z) < g(a)
            by cases:
                ? exist x '(a, b), L R st {$has_derivative_at('[a, b], g, x, L), L = 0}
                case g(z) < g(a):
                    by thm chap9::continuous_closed_interval_attains_minimum(a, b, g)
                    obtain x from exist x '[a, b] st {$chap9::is_minimizer_on('[a, b], g, x)}
                    g(x) <= g(z) < g(a)
                    g(x) < g(a)
                    claim:
                        ? a < x
                        by contra:
                            ? a < x
                            x <= a
                            a <= x
                            x = a
                            g(x) = g(a)
                            g(x) < g(a)
                            g(a) <= g(x)
                            impossible g(x) < g(a)
                    claim:
                        ? x < b
                        by contra:
                            ? x < b
                            x >= b
                            x <= b
                            x = b
                            g(x) = g(b)
                            g(b) = g(a)
                            g(x) = g(a)
                            g(x) < g(a)
                            g(a) <= g(x)
                            impossible g(x) < g(a)
                    x $in '(a, b)
                    have x0 '(a, b) = x
                    by thm global_minimum_implies_local_minimum('[a, b], g, x0)
                    $is_local_minimum_at('[a, b], g, x0)
                    '[a, b] $subset R
                    $is_local_maximum_at('[a, b], g, x0) or $is_local_minimum_at('[a, b], g, x0)
                    $is_local_extremum_at('[a, b], g, x0)
                    $is_differentiable_at('[a, b], g, x0)
                    obtain L from exist L R st {$has_derivative_at('[a, b], g, x0, L)}
                    by thm local_extremum_stationary_on_closed_interval(a, b, g, x0, L)
                    witness exist x1 '(a, b), L1 R st {$has_derivative_at('[a, b], g, x1, L1), L1 = 0} from x0, L:
                        $has_derivative_at('[a, b], g, x0, L)
                        L = 0
                case not g(z) < g(a):
                    g(z) >= g(a)
                    g(a) < g(z) or not g(a) < g(z)
                    by cases:
                        ? exist x '(a, b), L R st {$has_derivative_at('[a, b], g, x, L), L = 0}
                        case g(a) < g(z):
                            by thm chap9::continuous_closed_interval_attains_maximum(a, b, g)
                            obtain x from exist x '[a, b] st {$chap9::is_maximizer_on('[a, b], g, x)}
                            g(a) < g(z) <= g(x)
                            g(a) < g(x)
                            claim:
                                ? a < x
                                by contra:
                                    ? a < x
                                    x <= a
                                    a <= x
                                    x = a
                                    g(x) = g(a)
                                    g(a) < g(x)
                                    g(x) >= g(a)
                                    impossible g(a) < g(x)
                            claim:
                                ? x < b
                                by contra:
                                    ? x < b
                                    x >= b
                                    x <= b
                                    x = b
                                    g(x) = g(b)
                                    g(b) = g(a)
                                    g(x) = g(a)
                                    g(a) < g(x)
                                    g(x) >= g(a)
                                    impossible g(a) < g(x)
                            x $in '(a, b)
                            have x0 '(a, b) = x
                            by thm global_maximum_implies_local_maximum('[a, b], g, x0)
                            $is_local_maximum_at('[a, b], g, x0)
                            '[a, b] $subset R
                            $is_local_maximum_at('[a, b], g, x0) or $is_local_minimum_at('[a, b], g, x0)
                            $is_local_extremum_at('[a, b], g, x0)
                            $is_differentiable_at('[a, b], g, x0)
                            obtain L from exist L R st {$has_derivative_at('[a, b], g, x0, L)}
                            by thm local_extremum_stationary_on_closed_interval(a, b, g, x0, L)
                            witness exist x1 '(a, b), L1 R st {$has_derivative_at('[a, b], g, x1, L1), L1 = 0} from x0, L:
                                $has_derivative_at('[a, b], g, x0, L)
                                L = 0
                        case not g(a) < g(z):
                            g(a) >= g(z)
                            g(a) = g(z)
                            g(z) = g(a)
                            g(z) != g(a)
                            impossible g(z) != g(a)

thm rolle_theorem_derivative_value:
    ? forall a, b R, g fn(x '[a, b]) R:
        a < b
        $chap9::is_continuous_on('[a, b], g)
        forall x0 '(a, b):
            $is_differentiable_at('[a, b], g, x0)
        g(a) = g(b)
        =>:
            exist x '(a, b) st {$is_differentiable_at('[a, b], g, x), derivative('[a, b], g, x) = 0}
    by thm rolle_theorem(a, b, g)
    obtain x, L from exist x '(a, b), L R st {$has_derivative_at('[a, b], g, x, L), L = 0}
    witness exist x '(a, b) st {$is_differentiable_at('[a, b], g, x), derivative('[a, b], g, x) = 0} from x:
        witness exist L0 R st {$has_derivative_at('[a, b], g, x, L0)} from L:
            $has_derivative_at('[a, b], g, x, L)
        $is_differentiable_at('[a, b], g, x)
        L = derivative('[a, b], g, x)
        L = 0
        derivative('[a, b], g, x) = L
        derivative('[a, b], g, x) = 0

"""
Remark 10.2.8.  Rolle's theorem only assumes differentiability on the open
interval `(a,b)`; differentiability on `[a,b]` is stronger than needed.
"""

# The endpoint differentiability hypotheses are stronger than needed; Rolle's
# theorem only uses differentiability at interior points.

"""
Corollary 10.2.9 (Mean value theorem).  A continuous function on `[a,b]` that
is differentiable on `(a,b)` has an interior point where the derivative equals
the secant slope `(f(b)-f(a))/(b-a)`.
"""

# Let `c` be the secant slope and set `g(x)=f(x)-c(x-a)`.  The three local
# calculations below show that `g` is continuous, has equal endpoint values,
# and has derivative `f'(x)-c`; Rolle's theorem then gives the desired point.

thm mean_value_auxiliary_continuous:
    ? forall a, b R, f fn(x '[a, b]) R:
        a < b
        b - a != 0
        $chap9::is_continuous_on('[a, b], f)
        =>:
            $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)})
    have c R = (f(b) - f(a)) / (b - a)
    by thm chap9::constant_function_continuous('[a, b], a)
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {a})
    by thm chap9::identity_function_continuous('[a, b])
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {x})
    by thm chap9::continuity_closed_under_arithmetic('[a, b], fn(x '[a, b]) R {x}, fn(x '[a, b]) R {a})
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {x - a})
    by thm chap9::constant_function_continuous('[a, b], c)
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {c})
    by thm chap9::continuity_closed_under_arithmetic('[a, b], fn(x '[a, b]) R {c}, fn(x '[a, b]) R {x - a})
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {c * (x - a)})
    by thm chap9::continuity_closed_under_arithmetic('[a, b], f, fn(x '[a, b]) R {c * (x - a)})
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {f(x) - c * (x - a)})
    c = (f(b) - f(a)) / (b - a)
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)})

thm mean_value_auxiliary_equal_endpoints:
    ? forall a, b R, f fn(x '[a, b]) R:
        a < b
        b - a != 0
        =>:
            fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}(a) = fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}(b)
    have c R = (f(b) - f(a)) / (b - a)
    c * (b - a) = ((f(b) - f(a)) / (b - a)) * (b - a)
    ((f(b) - f(a)) / (b - a)) * (b - a) = f(b) - f(a)
    c * (b - a) = f(b) - f(a)
    fn(x '[a, b]) R {f(x) - c * (x - a)}(a) = f(a) - c * (a - a)
    a - a = 0
    c * (a - a) = 0
    fn(x '[a, b]) R {f(x) - c * (x - a)}(a) = f(a)
    fn(x '[a, b]) R {f(x) - c * (x - a)}(b) = f(b) - c * (b - a)
    f(b) - c * (b - a) = f(b) - (f(b) - f(a))
    f(b) - (f(b) - f(a)) = f(a)
    fn(x '[a, b]) R {f(x) - c * (x - a)}(a) = fn(x '[a, b]) R {f(x) - c * (x - a)}(b)
    c = (f(b) - f(a)) / (b - a)
    fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}(a) = fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}(b)

thm mean_value_auxiliary_derivative:
    ? forall a, b R, f fn(x '[a, b]) R, x0 '(a, b), L R:
        a < b
        b - a != 0
        $has_derivative_at('[a, b], f, x0, L)
        =>:
            $has_derivative_at('[a, b], fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}, x0, L - ((f(b) - f(a)) / (b - a)))
    have c R = (f(b) - f(a)) / (b - a)
    by thm chap9::closed_interval_points_are_limit_points(a, b, x0)
    $chap9::is_limit_point_of_set('[a, b], x0)
    by thm identity_function_has_derivative_at('[a, b], fn(x '[a, b]) R {x}, x0)
    $has_derivative_at('[a, b], fn(x '[a, b]) R {x}, x0, 1)
    by thm constant_function_has_derivative_at('[a, b], fn(x '[a, b]) R {a}, x0, a)
    $has_derivative_at('[a, b], fn(x '[a, b]) R {a}, x0, 0)
    by thm derivative_difference_rule('[a, b], fn(x '[a, b]) R {x}, fn(x '[a, b]) R {a}, x0, 1, 0)
    $has_derivative_at('[a, b], fn(x '[a, b]) R {x - a}, x0, 1 - 0)
    1 - 0 = 1
    $has_derivative_at('[a, b], fn(x '[a, b]) R {x - a}, x0, 1)
    by thm derivative_scalar_multiple_rule('[a, b], fn(x '[a, b]) R {x - a}, x0, 1, c)
    $has_derivative_at('[a, b], fn(x '[a, b]) R {c * (x - a)}, x0, c * 1)
    c * 1 = c
    $has_derivative_at('[a, b], fn(x '[a, b]) R {c * (x - a)}, x0, c)
    by thm derivative_difference_rule('[a, b], f, fn(x '[a, b]) R {c * (x - a)}, x0, L, c)
    $has_derivative_at('[a, b], fn(x '[a, b]) R {f(x) - c * (x - a)}, x0, L - c)
    c = (f(b) - f(a)) / (b - a)
    L - c = L - ((f(b) - f(a)) / (b - a))
    $has_derivative_at('[a, b], fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}, x0, L - ((f(b) - f(a)) / (b - a)))

thm mean_value_theorem:
    ? forall a, b R, f fn(x '[a, b]) R:
        a < b
        b - a != 0
        $chap9::is_continuous_on('[a, b], f)
        forall x0 '(a, b):
            $is_differentiable_at('[a, b], f, x0)
        =>:
            exist x '(a, b), L R st {$has_derivative_at('[a, b], f, x, L), L = (f(b) - f(a)) / (b - a)}
    have c R = (f(b) - f(a)) / (b - a)
    have fn g(x '[a, b]) R = f(x) - c * (x - a)
    claim:
        ? forall y '[a, b]:
            fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}(y) = g(y)
        c = (f(b) - f(a)) / (b - a)
        fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}(y) = f(y) - ((f(b) - f(a)) / (b - a)) * (y - a)
        f(y) - ((f(b) - f(a)) / (b - a)) * (y - a) = f(y) - c * (y - a)
        g(y) = f(y) - c * (y - a)
        fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}(y) = g(y)
    forall y '[a, b]:
        fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}(y) = g(y)
    by thm mean_value_auxiliary_continuous(a, b, f)
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)})
    $chap9::is_continuous_on('[a, b], g)
    c * (b - a) = ((f(b) - f(a)) / (b - a)) * (b - a)
    ((f(b) - f(a)) / (b - a)) * (b - a) = f(b) - f(a)
    c * (b - a) = f(b) - f(a)
    g(a) = f(a) - c * (a - a)
    a - a = 0
    c * (a - a) = 0
    g(a) = f(a)
    g(b) = f(b) - c * (b - a)
    f(b) - c * (b - a) = f(b) - (f(b) - f(a))
    f(b) - (f(b) - f(a)) = f(a)
    g(b) = f(a)
    g(a) = g(b)
    claim:
        ? forall x0 '(a, b):
            $is_differentiable_at('[a, b], g, x0)
        $is_differentiable_at('[a, b], f, x0)
        obtain L0 from exist L0 R st {$has_derivative_at('[a, b], f, x0, L0)}
        by thm mean_value_auxiliary_derivative(a, b, f, x0, L0)
        $has_derivative_at('[a, b], fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}, x0, L0 - ((f(b) - f(a)) / (b - a)))
        c = (f(b) - f(a)) / (b - a)
        L0 - c = L0 - ((f(b) - f(a)) / (b - a))
        $has_derivative_at('[a, b], fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}, x0, L0 - c)
        by thm equal_functions_have_equal_derivatives('[a, b], fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}, g, x0, L0 - c)
        $has_derivative_at('[a, b], g, x0, L0 - c)
        witness exist L1 R st {$has_derivative_at('[a, b], g, x0, L1)} from L0 - c:
            $has_derivative_at('[a, b], g, x0, L0 - c)
        $is_differentiable_at('[a, b], g, x0)
    forall x0 '(a, b):
        $is_differentiable_at('[a, b], g, x0)
    by thm rolle_theorem(a, b, g)
    obtain x, Lg from exist x '(a, b), Lg R st {$has_derivative_at('[a, b], g, x, Lg), Lg = 0}
    $is_differentiable_at('[a, b], f, x)
    obtain Lf from exist Lf R st {$has_derivative_at('[a, b], f, x, Lf)}
    by thm mean_value_auxiliary_derivative(a, b, f, x, Lf)
    $has_derivative_at('[a, b], fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}, x, Lf - ((f(b) - f(a)) / (b - a)))
    c = (f(b) - f(a)) / (b - a)
    Lf - c = Lf - ((f(b) - f(a)) / (b - a))
    $has_derivative_at('[a, b], fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}, x, Lf - c)
    by thm equal_functions_have_equal_derivatives('[a, b], fn(x '[a, b]) R {f(x) - ((f(b) - f(a)) / (b - a)) * (x - a)}, g, x, Lf - c)
    $has_derivative_at('[a, b], g, x, Lf - c)
    by thm derivative_value_unique('[a, b], g, x, Lg, Lf - c)
    Lg = Lf - c
    Lg = 0
    Lf - c = 0
    Lf = c
    c = (f(b) - f(a)) / (b - a)
    Lf = (f(b) - f(a)) / (b - a)
    witness exist x0 '(a, b), L0 R st {$has_derivative_at('[a, b], f, x0, L0), L0 = (f(b) - f(a)) / (b - a)} from x, Lf:
        $has_derivative_at('[a, b], f, x, Lf)
        Lf = (f(b) - f(a)) / (b - a)

thm mean_value_theorem_derivative_value:
    ? forall a, b R, f fn(x '[a, b]) R:
        a < b
        b - a != 0
        $chap9::is_continuous_on('[a, b], f)
        forall x0 '(a, b):
            $is_differentiable_at('[a, b], f, x0)
        =>:
            exist x '(a, b) st {$is_differentiable_at('[a, b], f, x), derivative('[a, b], f, x) = (f(b) - f(a)) / (b - a)}
    by thm mean_value_theorem(a, b, f)
    obtain x, L from exist x '(a, b), L R st {$has_derivative_at('[a, b], f, x, L), L = (f(b) - f(a)) / (b - a)}
    witness exist x '(a, b) st {$is_differentiable_at('[a, b], f, x), derivative('[a, b], f, x) = (f(b) - f(a)) / (b - a)} from x:
        witness exist L0 R st {$has_derivative_at('[a, b], f, x, L0)} from L:
            $has_derivative_at('[a, b], f, x, L)
        $is_differentiable_at('[a, b], f, x)
        L = derivative('[a, b], f, x)
        L = (f(b) - f(a)) / (b - a)
        derivative('[a, b], f, x) = L
        derivative('[a, b], f, x) = (f(b) - f(a)) / (b - a)

# To apply the mean value theorem to two points in `[a,b]`, restrict the
# function to their closed subinterval.  These lemmas preserve continuity and
# derivatives and identify the secant slope on that subinterval.

thm continuous_restrict_domain:
    ? forall X, Y power_set(R), f fn(x X) R:
        Y $subset X
        $chap9::is_continuous_on(X, f)
        =>:
            $chap9::is_continuous_on(Y, fn(x Y) R {f(x)})
    claim:
        ? forall x0 Y:
            $chap9::is_continuous_at(Y, fn(y Y) R {f(y)}, x0)
        x0 $in X
        $chap9::is_continuous_at(X, f, x0)
        $chap9::has_function_limit(X, f, x0, f(x0))
        by thm chap9::interval_member_is_adherent(Y, x0)
        $chap9::is_adherent_point(Y, x0)
        by thm chap9::function_limit_on_adherent_subset(X, Y, f, x0, f(x0))
        $chap9::has_function_limit(Y, fn(y Y) R {f(y)}, x0, f(x0))
        fn(y Y) R {f(y)}(x0) = f(x0)
        $chap9::has_function_limit(Y, fn(y Y) R {f(y)}, x0, fn(y Y) R {f(y)}(x0))
        $chap9::is_continuous_at(Y, fn(y Y) R {f(y)}, x0)
    $chap9::is_continuous_on(Y, fn(x Y) R {f(x)})

thm derivative_restrict_domain:
    ? forall X, Y power_set(R), f fn(x X) R, x0 Y, L R:
        Y $subset X
        $chap9::is_limit_point_of_set(Y, x0)
        $has_derivative_at(X, f, x0, L)
        =>:
            $has_derivative_at(Y, fn(x Y) R {f(x)}, x0, L)
    x0 $in X
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$is_difference_quotient_close_to(Y, fn(x Y) R {f(x)}, x0, L, epsilon, delta)}
        obtain delta from exist delta R_pos st {$is_difference_quotient_close_to(X, f, x0, L, epsilon, delta)}
        witness exist delta0 R_pos st {$is_difference_quotient_close_to(Y, fn(x Y) R {f(x)}, x0, L, epsilon, delta0)} from delta:
            claim:
                ? forall y Y:
                    y - x0 != 0
                    abs(y - x0) < delta
                    =>:
                        abs(((fn(x Y) R {f(x)}(y) - fn(x Y) R {f(x)}(x0)) / (y - x0)) - L) <= epsilon
                y $in X
                abs((f(y) - f(x0)) / (y - x0) - L) <= epsilon
                fn(x Y) R {f(x)}(y) = f(y)
                fn(x Y) R {f(x)}(x0) = f(x0)
                (fn(x Y) R {f(x)}(y) - fn(x Y) R {f(x)}(x0)) / (y - x0) = (f(y) - f(x0)) / (y - x0)
                abs(((fn(x Y) R {f(x)}(y) - fn(x Y) R {f(x)}(x0)) / (y - x0)) - L) = abs((f(y) - f(x0)) / (y - x0) - L)
                abs(((fn(x Y) R {f(x)}(y) - fn(x Y) R {f(x)}(x0)) / (y - x0)) - L) <= epsilon
            $is_difference_quotient_close_to(Y, fn(x Y) R {f(x)}, x0, L, epsilon, delta0)
    $has_derivative_at(Y, fn(x Y) R {f(x)}, x0, L)

thm closed_interval_subinterval:
    ? forall a, b R, u, v '[a, b]:
        u <= v
        =>:
            '[u, v] $subset '[a, b]
    claim:
        ? forall x '[u, v]:
            x $in '[a, b]
        a <= u
        u <= x
        a <= x
        x <= v
        v <= b
        x <= b
        x $in '[a, b]
    '[u, v] $subset '[a, b]

thm mean_value_theorem_on_closed_subinterval:
    ? forall a, b R, f fn(x '[a, b]) R, df fn(x '[a, b]) R, u, v '[a, b]:
        a < b
        u < v
        v - u != 0
        '[u, v] $subset '[a, b]
        $has_derivative_function_on('[a, b], f, df)
        =>:
            exist x '(u, v), L R st {$has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, x, L), $has_derivative_at('[a, b], f, x, L), L = (f(v) - f(u)) / (v - u)}
    v - u > 0
    u $in '[u, v]
    v $in '[u, v]
    claim:
        ? $is_differentiable_on('[u, v], fn(y '[u, v]) R {f(y)})
        claim:
            ? forall x0 '[u, v]:
                $is_differentiable_at('[u, v], fn(y '[u, v]) R {f(y)}, x0)
            by thm chap9::closed_interval_points_are_limit_points(u, v, x0)
            $chap9::is_limit_point_of_set('[u, v], x0)
            x0 $in '[a, b]
            by thm chap9::closed_interval_points_are_limit_points(a, b, x0)
            $chap9::is_limit_point_of_set('[a, b], x0)
            $has_derivative_at('[a, b], f, x0, df(x0))
            by thm derivative_restrict_domain('[a, b], '[u, v], f, x0, df(x0))
            $has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, x0, df(x0))
            witness exist L R st {$has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, x0, L)} from df(x0):
                $has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, x0, df(x0))
            $is_differentiable_at('[u, v], fn(y '[u, v]) R {f(y)}, x0)
        $is_differentiable_on('[u, v], fn(y '[u, v]) R {f(y)})
    by thm differentiable_on_implies_continuous_on('[u, v], fn(y '[u, v]) R {f(y)})
    $chap9::is_continuous_on('[u, v], fn(y '[u, v]) R {f(y)})
    claim:
        ? forall x0 '(u, v):
            $is_differentiable_at('[u, v], fn(y '[u, v]) R {f(y)}, x0)
        x0 $in '[u, v]
        $is_differentiable_at('[u, v], fn(y '[u, v]) R {f(y)}, x0)
    by thm mean_value_theorem(u, v, fn(y '[u, v]) R {f(y)})
    obtain x, L from exist x '(u, v), L R st {$has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, x, L), L = (fn(y '[u, v]) R {f(y)}(v) - fn(y '[u, v]) R {f(y)}(u)) / (v - u)}
    x $in '[u, v]
    x $in '[a, b]
    by thm chap9::closed_interval_points_are_limit_points(a, b, x)
    $chap9::is_limit_point_of_set('[a, b], x)
    $has_derivative_at('[a, b], f, x, df(x))
    by thm derivative_restrict_domain('[a, b], '[u, v], f, x, df(x))
    $has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, x, df(x))
    by thm derivative_value_unique('[u, v], fn(y '[u, v]) R {f(y)}, x, L, df(x))
    L = df(x)
    df(x) = L
    $has_derivative_at('[a, b], f, x, L)
    L = (fn(y '[u, v]) R {f(y)}(v) - fn(y '[u, v]) R {f(y)}(u)) / (v - u)
    fn(y '[u, v]) R {f(y)}(v) = f(v)
    fn(y '[u, v]) R {f(y)}(u) = f(u)
    fn(y '[u, v]) R {f(y)}(v) - fn(y '[u, v]) R {f(y)}(u) = f(v) - f(u)
    (fn(y '[u, v]) R {f(y)}(v) - fn(y '[u, v]) R {f(y)}(u)) / (v - u) = (f(v) - f(u)) / (v - u)
    L = (f(v) - f(u)) / (v - u)
    witness exist x0 '(u, v), L0 R st {$has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, x0, L0), $has_derivative_at('[a, b], f, x0, L0), L0 = (f(v) - f(u)) / (v - u)} from x, L:
        $has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, x, L)
        $has_derivative_at('[a, b], f, x, L)
        L = (f(v) - f(u)) / (v - u)


# 10.3 Monotone functions and derivatives

"""
Proposition 10.3.1.  If f is monotone increasing and differentiable at x0, then
f'(x0) >= 0.  If f is monotone decreasing and differentiable at x0, then
f'(x0) <= 0.
"""

# The difference quotients of a monotone increasing function have the correct
# chap9::sign on both sides of x0; passing to the derivative preserves the inequality.
# The formal proof still has to pass the chap9::sign of the difference quotients
# through the derivative limit.

thm monotone_increasing_derivative_nonnegative_has_derivative_at:
    ? forall X power_set(R), f fn(x X) R, x0 X, L R:
        $chap9::is_monotone_increasing_on(X, f)
        $has_derivative_at(X, f, x0, L)
        =>:
            L >= 0
    # In the source, this is the increasing case of Proposition 10.3.1.
    by contra:
        ? L >= 0
        L < 0
        0 - L > 0
        (0 - L) / 2 $in R_pos
        obtain delta from exist delta R_pos st {$is_difference_quotient_close_to(X, f, x0, L, (0 - L) / 2, delta)}
        delta / 2 $in R_pos
        $chap9::is_epsilon_adherent_to_set(set_minus(X, {x0}), x0, delta / 2)
        obtain y from exist y R st {y $in set_minus(X, {x0}), abs(x0 - y) <= delta / 2}
        y $in X
        not y $in {x0}
        claim:
            ? y != x0
            by contra:
                ? y != x0
                y = x0
                y $in {x0}
                impossible not y $in {x0}
        y - x0 != 0
        abs(y - x0) = abs(x0 - y)
        abs(y - x0) <= delta / 2
        delta / 2 < delta
        abs(y - x0) <= delta / 2 < delta
        abs(y - x0) < delta
        have q R = (f(y) - f(x0)) / (y - x0)
        claim:
            ? q >= 0
            y > x0 or y = x0 or y < x0
            by cases:
                ? q >= 0
                case y > x0:
                    x0 < y
                    f(x0) <= f(y)
                    f(y) - f(x0) >= 0
                    y - x0 > 0
                    (f(y) - f(x0)) / (y - x0) >= 0
                    q = (f(y) - f(x0)) / (y - x0)
                    q >= 0
                case y = x0:
                    impossible y != x0
                case y < x0:
                    f(y) <= f(x0)
                    f(y) - f(x0) <= 0
                    y - x0 < 0
                    0 / (y - x0) = 0
                    (f(y) - f(x0)) / (y - x0) >= 0 / (y - x0)
                    (f(y) - f(x0)) / (y - x0) >= 0 / (y - x0) = 0
                    (f(y) - f(x0)) / (y - x0) >= 0
                    q = (f(y) - f(x0)) / (y - x0)
                    q >= 0
        abs(((f(y) - f(x0)) / (y - x0)) - L) <= (0 - L) / 2
        q = (f(y) - f(x0)) / (y - x0)
        (f(y) - f(x0)) / (y - x0) = q
        ((f(y) - f(x0)) / (y - x0)) - L = q - L
        abs(((f(y) - f(x0)) / (y - x0)) - L) = abs(q - L)
        abs(q - L) = abs(((f(y) - f(x0)) / (y - x0)) - L)
        abs(q - L) <= (0 - L) / 2
        q - L >= 0 - L
        0 - L > (0 - L) / 2
        q - L >= 0 - L > (0 - L) / 2
        q - L > (0 - L) / 2
        q - L >= 0 - L > 0
        q - L > 0
        abs(q - L) = q - L
        abs(q - L) > (0 - L) / 2
        impossible abs(q - L) <= (0 - L) / 2

thm monotone_increasing_derivative_nonnegative:
    ? forall X power_set(R), f fn(x X) R, x0 X:
        $chap9::is_monotone_increasing_on(X, f)
        $is_differentiable_at(X, f, x0)
        =>:
            derivative(X, f, x0) >= 0
    obtain L from exist L R st {$has_derivative_at(X, f, x0, L)}
    by thm monotone_increasing_derivative_nonnegative_has_derivative_at(X, f, x0, L)
    L >= 0
    L = derivative(X, f, x0)
    derivative(X, f, x0) >= 0

thm monotone_decreasing_derivative_nonpositive_has_derivative_at:
    ? forall X power_set(R), f fn(x X) R, x0 X, L R:
        $chap9::is_monotone_decreasing_on(X, f)
        $has_derivative_at(X, f, x0, L)
        =>:
            L <= 0
    # In the source, this is the decreasing case of Proposition 10.3.1.
    # Reduce it to the increasing case by applying that theorem to `-f`.
    claim:
        ? $chap9::is_monotone_increasing_on(X, fn(y X) R {-1 * f(y)})
        claim:
            ? forall u, v X:
                u < v
                =>:
                    fn(y X) R {-1 * f(y)}(u) <= fn(y X) R {-1 * f(y)}(v)
            f(u) >= f(v)
            -1 * f(u) <= -1 * f(v)
            fn(y X) R {-1 * f(y)}(u) = -1 * f(u)
            fn(y X) R {-1 * f(y)}(v) = -1 * f(v)
            fn(y X) R {-1 * f(y)}(u) <= fn(y X) R {-1 * f(y)}(v)
        $chap9::is_monotone_increasing_on(X, fn(y X) R {-1 * f(y)})
    by thm derivative_scalar_multiple_rule(X, f, x0, L, -1)
    $has_derivative_at(X, fn(y X) R {-1 * f(y)}, x0, -1 * L)
    by thm monotone_increasing_derivative_nonnegative_has_derivative_at(X, fn(y X) R {-1 * f(y)}, x0, -1 * L)
    -1 * L >= 0
    (-1 * L) / (-1) <= 0 / (-1)
    (-1 * L) / (-1) = L
    0 / (-1) = 0
    L <= 0

thm monotone_decreasing_derivative_nonpositive:
    ? forall X power_set(R), f fn(x X) R, x0 X:
        $chap9::is_monotone_decreasing_on(X, f)
        $is_differentiable_at(X, f, x0)
        =>:
            derivative(X, f, x0) <= 0
    obtain L from exist L R st {$has_derivative_at(X, f, x0, L)}
    by thm monotone_decreasing_derivative_nonpositive_has_derivative_at(X, f, x0, L)
    L <= 0
    L = derivative(X, f, x0)
    derivative(X, f, x0) <= 0

"""
Remark 10.3.2.  The differentiability hypothesis is necessary: monotone
functions can fail to be differentiable at some points.
"""

# Monotonicity alone controls the chap9::sign of any derivative that exists, but it
# does not guarantee differentiability at every point.

"""
The paragraph after Remark 10.3.2.  Strict monotonicity does not force a
strictly positive derivative at every point; examples can have a flat derivative
at one point.
"""

# The standard example is a strictly increasing differentiable function with a
# flat derivative at one point.

"""
Proposition 10.3.3.  On a closed interval, a differentiable function with
positive derivative everywhere is strictly increasing; with negative derivative
everywhere it is strictly decreasing; with zero derivative everywhere it is
constant.
"""

# Apply the mean value theorem to any two distinct points.  The derivative chap9::sign
# at the MVT point determines the chap9::sign of the difference quotient; the
# remaining formal work is the subinterval MVT application and the arithmetic
# that turns it into monotonicity.

thm positive_derivative_strictly_increasing:
    ? forall a, b R, f fn(x '[a, b]) R, df fn(x '[a, b]) R:
        a < b
        $has_derivative_function_on('[a, b], f, df)
        forall x '[a, b]:
            df(x) > 0
        =>:
            $chap9::is_strictly_increasing_on('[a, b], f)
    claim:
        ? forall u, v '[a, b]:
            u < v
            =>:
                f(u) < f(v)
        u <= v
        v - u > 0
        v - u != 0
        by thm closed_interval_subinterval(a, b, u, v)
        '[u, v] $subset '[a, b]
        by thm mean_value_theorem_on_closed_subinterval(a, b, f, df, u, v)
        obtain x, L from exist x '(u, v), L R st {$has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, x, L), $has_derivative_at('[a, b], f, x, L), L = (f(v) - f(u)) / (v - u)}
        $has_derivative_at('[a, b], f, x, df(x))
        by thm derivative_value_unique('[a, b], f, x, L, df(x))
        L = df(x)
        df(x) > 0
        L > 0
        L = (f(v) - f(u)) / (v - u)
        (f(v) - f(u)) / (v - u) > 0
        ((f(v) - f(u)) / (v - u)) * (v - u) > 0
        ((f(v) - f(u)) / (v - u)) * (v - u) = f(v) - f(u)
        f(v) - f(u) > 0
        f(u) < f(v)
    $chap9::is_strictly_increasing_on('[a, b], f)


thm negative_derivative_strictly_decreasing:
    ? forall a, b R, f fn(x '[a, b]) R, df fn(x '[a, b]) R:
        a < b
        $has_derivative_function_on('[a, b], f, df)
        forall x '[a, b]:
            df(x) < 0
        =>:
            $chap9::is_strictly_decreasing_on('[a, b], f)
    # In the source, this is the negative-derivative case of Proposition 10.3.3.
    # Reduce it to the positive-derivative case by applying that theorem to
    # `-f`.
    claim:
        ? $has_derivative_function_on('[a, b], fn(y '[a, b]) R {-1 * f(y)}, fn(y '[a, b]) R {-1 * df(y)})
        claim:
            ? forall x0 '[a, b]:
                $chap9::is_limit_point_of_set('[a, b], x0)
                =>:
                    $has_derivative_at('[a, b], fn(y '[a, b]) R {-1 * f(y)}, x0, fn(y '[a, b]) R {-1 * df(y)}(x0))
            $has_derivative_at('[a, b], f, x0, df(x0))
            by thm derivative_scalar_multiple_rule('[a, b], f, x0, df(x0), -1)
            $has_derivative_at('[a, b], fn(y '[a, b]) R {-1 * f(y)}, x0, -1 * df(x0))
            fn(y '[a, b]) R {-1 * df(y)}(x0) = -1 * df(x0)
            $has_derivative_at('[a, b], fn(y '[a, b]) R {-1 * f(y)}, x0, fn(y '[a, b]) R {-1 * df(y)}(x0))
        $has_derivative_function_on('[a, b], fn(y '[a, b]) R {-1 * f(y)}, fn(y '[a, b]) R {-1 * df(y)})
    claim:
        ? forall x '[a, b]:
            -1 * 1 * df(x) > 0
        df(x) < 0
        -1 * df(x) > 0
        -1 * 1 * df(x) = -1 * df(x)
        -1 * 1 * df(x) > 0
    by thm positive_derivative_strictly_increasing(a, b, fn(y '[a, b]) R {-1 * f(y)}, fn(y '[a, b]) R {-1 * df(y)})
    $chap9::is_strictly_increasing_on('[a, b], fn(y '[a, b]) R {-1 * f(y)})
    claim:
        ? forall u, v '[a, b]:
            u < v
            =>:
                f(u) > f(v)
        fn(y '[a, b]) R {-1 * f(y)}(u) < fn(y '[a, b]) R {-1 * f(y)}(v)
        fn(y '[a, b]) R {-1 * f(y)}(u) = -1 * f(u)
        fn(y '[a, b]) R {-1 * f(y)}(v) = -1 * f(v)
        -1 * f(u) < -1 * f(v)
        (-1 * f(u)) / (-1) > (-1 * f(v)) / (-1)
        (-1 * f(u)) / (-1) = f(u)
        (-1 * f(v)) / (-1) = f(v)
        f(u) > f(v)
    $chap9::is_strictly_decreasing_on('[a, b], f)

prop is_constant_on(X power_set(R), f fn(x X) R):
    forall x, y X:
        f(x) = f(y)

thm zero_derivative_constant:
    ? forall a, b R, f fn(x '[a, b]) R, df fn(x '[a, b]) R:
        a < b
        $has_derivative_function_on('[a, b], f, df)
        forall x '[a, b]:
            df(x) = 0
        =>:
            $is_constant_on('[a, b], f)
    claim:
        ? forall u, v '[a, b]:
            u < v
            =>:
                f(u) = f(v)
        u <= v
        v - u > 0
        v - u != 0
        by thm closed_interval_subinterval(a, b, u, v)
        '[u, v] $subset '[a, b]
        by thm mean_value_theorem_on_closed_subinterval(a, b, f, df, u, v)
        obtain x, L from exist x '(u, v), L R st {$has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, x, L), $has_derivative_at('[a, b], f, x, L), L = (f(v) - f(u)) / (v - u)}
        $has_derivative_at('[a, b], f, x, df(x))
        by thm derivative_value_unique('[a, b], f, x, L, df(x))
        L = df(x)
        df(x) = 0
        L = 0
        L = (f(v) - f(u)) / (v - u)
        (f(v) - f(u)) / (v - u) = 0
        ((f(v) - f(u)) / (v - u)) * (v - u) = 0 * (v - u)
        0 * (v - u) = 0
        ((f(v) - f(u)) / (v - u)) * (v - u) = 0
        ((f(v) - f(u)) / (v - u)) * (v - u) = f(v) - f(u)
        f(v) - f(u) = 0
        f(v) = f(u)
    claim:
        ? forall u, v '[a, b]:
            f(u) = f(v)
        u < v or u = v or u > v
        by cases:
            ? f(u) = f(v)
            case u < v:
                f(u) = f(v)
            case u = v:
                f(u) = f(v)
            case u > v:
                f(v) = f(u)
                f(u) = f(v)
    $is_constant_on('[a, b], f)


# 10.4 Inverse functions and derivatives

prop is_inverse_pair_between_real_subsets(X, Y power_set(R), f fn(x X) R, g fn(y Y) R):
    forall x X:
        f(x) $in Y
        g(f(x)) = x
    forall y Y:
        g(y) $in X
        f(g(y)) = y

"""
Lemma 10.4.1.  If f and its inverse are both differentiable at corresponding
points x0 and y0=f(x0), then the inverse derivative is `1/f'(x0)`.
"""

# The proof applies the chain rule to `f^{-1} o f`, which is the
# identity function, and then using the identity derivative law.

thm inverse_derivative_if_inverse_already_differentiable:
    ? forall X, Y power_set(R), f fn(x X) R, g fn(y Y) R, x0 X, y0 Y, df, dg R:
        $is_inverse_pair_between_real_subsets(X, Y, f, g)
        f(x0) = y0
        $has_derivative_at(X, f, x0, df)
        $has_derivative_at(Y, g, y0, dg)
        =>:
            df != 0
            dg = 1 / df
    forall x X:
        f(x) $in Y
        g(f(x)) = x
    by thm derivative_chain_rule(X, Y, f, g, x0, y0, df, dg)
    $has_derivative_at(X, fn(x X) R {g(f(x))}, x0, dg * df)
    claim:
        ? forall x X:
            fn(z X) R {g(f(z))}(x) = x
        fn(z X) R {g(f(z))}(x) = g(f(x))
        g(f(x)) = x
    by thm identity_function_has_derivative_at(X, fn(z X) R {g(f(z))}, x0)
    $has_derivative_at(X, fn(z X) R {g(f(z))}, x0, 1)
    by thm derivative_value_unique(X, fn(z X) R {g(f(z))}, x0, dg * df, 1)
    dg * df = 1
    # Source handling: after obtaining
    # `(f^{-1})'(y0) f'(x0) = 1`; the remaining step is field algebra.
    claim:
        ? df != 0
        by contra:
            ? df != 0
            df = 0
            dg * df = dg * 0
            dg * 0 = 0
            1 = 0
            1 > 0
            impossible 1 = 0
    dg = (dg * df) / df
    (dg * df) / df = 1 / df

"""
The discussion after Lemma 10.4.1.  If `f'(x0)=0`, the inverse cannot be
differentiable at `f(x0)`.  The cube-root inverse of `x^3` at 0 is the guiding
example.  The notation `dx/dy=1/(dy/dx)` is useful but should be read with the
same caution as earlier differential notation.
"""

"""
Theorem 10.4.2 (Inverse function theorem).  If f is invertible, differentiable
at x0 with nonzero derivative, and the inverse is continuous at y0=f(x0), then
the inverse is differentiable at y0 and has derivative `1/f'(x0)`.
"""

# The proof uses the sequential characterization of function limits:
# send a sequence `y_n -> y0` through the continuous inverse to get
# `x_n -> x0`, invert the nonzero difference quotients, and apply the reciprocal
# limit law.

thm inverse_function_limit_point_transfer:
    ? forall X, Y power_set(R), f fn(x X) R, g fn(y Y) R, x0 X, y0 Y, df R:
        $is_inverse_pair_between_real_subsets(X, Y, f, g)
        f(x0) = y0
        $has_derivative_at(X, f, x0, df)
        $chap9::is_continuous_at(Y, g, y0)
        df != 0
        =>:
            $chap9::is_limit_point_of_set(Y, y0)
    by thm differentiability_implies_continuity_at(X, f, x0, df)
    $chap9::is_continuous_at(X, f, x0)
    $chap9::has_function_limit(X, f, x0, f(x0))
    claim:
        ? forall epsilon R_pos:
            $chap9::is_epsilon_adherent_to_set(set_minus(Y, {y0}), y0, epsilon)
        $chap9::is_locally_epsilon_close_to(X, f, x0, f(x0), epsilon)
        obtain delta_f from exist delta_f R_pos st {$chap9::is_delta_neighborhood_close_to(X, f, x0, f(x0), epsilon, delta_f)}
        delta_f / 2 $in R_pos
        $chap9::is_epsilon_adherent_to_set(set_minus(X, {x0}), x0, delta_f / 2)
        obtain x from exist x R st {x $in set_minus(X, {x0}), abs(x0 - x) <= delta_f / 2}
        x $in X
        not x $in {x0}
        claim:
            ? x != x0
            by contra:
                ? x != x0
                x = x0
                x0 $in {x0}
                x $in {x0}
                impossible not x $in {x0}
        abs(x - x0) = abs(x0 - x)
        abs(x - x0) <= delta_f / 2
        delta_f / 2 < delta_f
        abs(x - x0) <= delta_f / 2 < delta_f
        abs(x - x0) < delta_f
        abs(f(x) - f(x0)) <= epsilon
        forall z X:
            f(z) $in Y
            g(f(z)) = z
        claim:
            ? f(x) != y0
            by contra:
                ? f(x) != y0
                f(x) = y0
                f(x0) = y0
                g(f(x)) = x
                g(f(x0)) = x0
                g(f(x)) = g(y0)
                g(f(x0)) = g(y0)
                x = g(y0)
                x0 = g(y0)
                x = x0
                impossible x != x0
        f(x) $in Y
        not f(x) $in {y0}
        f(x) $in set_minus(Y, {y0})
        witness exist y R st {y $in set_minus(Y, {y0}), abs(y0 - y) <= epsilon} from f(x):
            f(x) $in set_minus(Y, {y0})
            f(x0) = y0
            abs(f(x) - f(x0)) <= epsilon
            f(x) - f(x0) = f(x) - y0
            abs(f(x) - f(x0)) = abs(f(x) - y0)
            abs(y0 - f(x)) = abs(f(x) - y0)
            abs(y0 - f(x)) <= epsilon
        $chap9::is_epsilon_adherent_to_set(set_minus(Y, {y0}), y0, epsilon)
    $chap9::is_adherent_point(set_minus(Y, {y0}), y0)
    $chap9::is_limit_point_of_set(Y, y0)

axiom inverse_function_difference_quotient_estimate:
    ? forall X, Y power_set(R), f fn(x X) R, g fn(y Y) R, x0 X, y0 Y, df R, epsilon R_pos:
        $is_inverse_pair_between_real_subsets(X, Y, f, g)
        f(x0) = y0
        $has_derivative_at(X, f, x0, df)
        $chap9::is_continuous_at(Y, g, y0)
        df != 0
        =>:
            exist delta R_pos st {$is_difference_quotient_close_to(Y, g, y0, 1 / df, epsilon, delta)}

thm inverse_function_theorem:
    ? forall X, Y power_set(R), f fn(x X) R, g fn(y Y) R, x0 X, y0 Y, df R:
        $is_inverse_pair_between_real_subsets(X, Y, f, g)
        f(x0) = y0
        $has_derivative_at(X, f, x0, df)
        $chap9::is_continuous_at(Y, g, y0)
        df != 0
        =>:
            $has_derivative_at(Y, g, y0, 1 / df)
    by thm inverse_function_limit_point_transfer(X, Y, f, g, x0, y0, df)
    $chap9::is_limit_point_of_set(Y, y0)
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$is_difference_quotient_close_to(Y, g, y0, 1 / df, epsilon, delta)}
        by thm inverse_function_difference_quotient_estimate(X, Y, f, g, x0, y0, df, epsilon)
        exist delta R_pos st {$is_difference_quotient_close_to(Y, g, y0, 1 / df, epsilon, delta)}
    $has_derivative_at(Y, g, y0, 1 / df)

thm inverse_function_theorem_derivative_value:
    ? forall X, Y power_set(R), f fn(x X) R, g fn(y Y) R, x0 X, y0 Y, df R:
        $is_inverse_pair_between_real_subsets(X, Y, f, g)
        f(x0) = y0
        $has_derivative_at(X, f, x0, df)
        $chap9::is_continuous_at(Y, g, y0)
        df != 0
        =>:
            $is_differentiable_at(Y, g, y0)
            derivative(Y, g, y0) = 1 / df
    by thm inverse_function_theorem(X, Y, f, g, x0, y0, df)
    $has_derivative_at(Y, g, y0, 1 / df)
    by thm has_derivative_at_to_derivative_value(Y, g, y0, 1 / df)
    $is_differentiable_at(Y, g, y0)
    derivative(Y, g, y0) = 1 / df

# Cauchy's mean value theorem applies Rolle's theorem to the cross-product
# auxiliary function.  It is the two-function form needed for the
# one-sided quotient argument below.

thm cauchy_mean_value_auxiliary_continuous:
    ? forall a, b R, f, g fn(x '[a, b]) R:
        a < b
        $chap9::is_continuous_on('[a, b], f)
        $chap9::is_continuous_on('[a, b], g)
        =>:
            $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)})
    have A R = f(b) - f(a)
    have B R = g(b) - g(a)
    by thm chap9::constant_function_continuous('[a, b], A)
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {A})
    by thm chap9::continuity_closed_under_arithmetic('[a, b], fn(x '[a, b]) R {A}, g)
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {A * g(x)})
    by thm chap9::constant_function_continuous('[a, b], B)
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {B})
    by thm chap9::continuity_closed_under_arithmetic('[a, b], fn(x '[a, b]) R {B}, f)
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {B * f(x)})
    by thm chap9::continuity_closed_under_arithmetic('[a, b], fn(x '[a, b]) R {A * g(x)}, fn(x '[a, b]) R {B * f(x)})
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {A * g(x) - B * f(x)})
    A = f(b) - f(a)
    B = g(b) - g(a)
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)})

thm cauchy_mean_value_auxiliary_equal_endpoints:
    ? forall a, b R, f, g fn(x '[a, b]) R:
        a < b
        =>:
            fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}(a) = fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}(b)
    have A R = f(b) - f(a)
    have B R = g(b) - g(a)
    fn(x '[a, b]) R {A * g(x) - B * f(x)}(a) = A * g(a) - B * f(a)
    fn(x '[a, b]) R {A * g(x) - B * f(x)}(b) = A * g(b) - B * f(b)
    A * g(b) - B * f(b) = (f(b) - f(a)) * g(b) - (g(b) - g(a)) * f(b)
    (f(b) - f(a)) * g(b) - (g(b) - g(a)) * f(b) = f(b) * g(a) - g(b) * f(a)
    A * g(b) - B * f(b) = f(b) * g(a) - g(b) * f(a)
    A * g(a) - B * f(a) = (f(b) - f(a)) * g(a) - (g(b) - g(a)) * f(a)
    (f(b) - f(a)) * g(a) - (g(b) - g(a)) * f(a) = f(b) * g(a) - g(b) * f(a)
    A * g(a) - B * f(a) = f(b) * g(a) - g(b) * f(a)
    A * g(b) - B * f(b) = A * g(a) - B * f(a)
    fn(x '[a, b]) R {A * g(x) - B * f(x)}(a) = fn(x '[a, b]) R {A * g(x) - B * f(x)}(b)
    A = f(b) - f(a)
    B = g(b) - g(a)
    fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}(a) = fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}(b)

thm cauchy_mean_value_auxiliary_derivative:
    ? forall a, b R, f, g fn(x '[a, b]) R, x0 '(a, b), Lf, Lg R:
        a < b
        $has_derivative_at('[a, b], f, x0, Lf)
        $has_derivative_at('[a, b], g, x0, Lg)
        =>:
            $has_derivative_at('[a, b], fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}, x0, (f(b) - f(a)) * Lg - (g(b) - g(a)) * Lf)
    have A R = f(b) - f(a)
    have B R = g(b) - g(a)
    by thm derivative_scalar_multiple_rule('[a, b], g, x0, Lg, A)
    $has_derivative_at('[a, b], fn(y '[a, b]) R {A * g(y)}, x0, A * Lg)
    by thm derivative_scalar_multiple_rule('[a, b], f, x0, Lf, B)
    $has_derivative_at('[a, b], fn(y '[a, b]) R {B * f(y)}, x0, B * Lf)
    by thm derivative_difference_rule('[a, b], fn(y '[a, b]) R {A * g(y)}, fn(y '[a, b]) R {B * f(y)}, x0, A * Lg, B * Lf)
    $has_derivative_at('[a, b], fn(x '[a, b]) R {A * g(x) - B * f(x)}, x0, A * Lg - B * Lf)
    A = f(b) - f(a)
    B = g(b) - g(a)
    $has_derivative_at('[a, b], fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}, x0, (f(b) - f(a)) * Lg - (g(b) - g(a)) * Lf)

thm cauchy_mean_value_theorem:
    ? forall a, b R, f, g fn(x '[a, b]) R:
        a < b
        $chap9::is_continuous_on('[a, b], f)
        $chap9::is_continuous_on('[a, b], g)
        forall x0 '(a, b):
            $is_differentiable_at('[a, b], f, x0)
            $is_differentiable_at('[a, b], g, x0)
        =>:
            exist x '(a, b), Lf, Lg R st {$has_derivative_at('[a, b], f, x, Lf), $has_derivative_at('[a, b], g, x, Lg), (f(b) - f(a)) * Lg = (g(b) - g(a)) * Lf}
    by thm cauchy_mean_value_auxiliary_continuous(a, b, f, g)
    $chap9::is_continuous_on('[a, b], fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)})
    by thm cauchy_mean_value_auxiliary_equal_endpoints(a, b, f, g)
    fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}(a) = fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}(b)
    claim:
        ? forall x0 '(a, b):
            $is_differentiable_at('[a, b], fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}, x0)
        $is_differentiable_at('[a, b], f, x0)
        obtain Lf0 from exist Lf0 R st {$has_derivative_at('[a, b], f, x0, Lf0)}
        $is_differentiable_at('[a, b], g, x0)
        obtain Lg0 from exist Lg0 R st {$has_derivative_at('[a, b], g, x0, Lg0)}
        by thm cauchy_mean_value_auxiliary_derivative(a, b, f, g, x0, Lf0, Lg0)
        $has_derivative_at('[a, b], fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}, x0, (f(b) - f(a)) * Lg0 - (g(b) - g(a)) * Lf0)
        witness exist Lh R st {$has_derivative_at('[a, b], fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}, x0, Lh)} from (f(b) - f(a)) * Lg0 - (g(b) - g(a)) * Lf0:
            $has_derivative_at('[a, b], fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}, x0, (f(b) - f(a)) * Lg0 - (g(b) - g(a)) * Lf0)
        $is_differentiable_at('[a, b], fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}, x0)
    by thm rolle_theorem(a, b, fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)})
    obtain x, Lh from exist x '(a, b), Lh R st {$has_derivative_at('[a, b], fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}, x, Lh), Lh = 0}
    $is_differentiable_at('[a, b], f, x)
    obtain Lf from exist Lf R st {$has_derivative_at('[a, b], f, x, Lf)}
    $is_differentiable_at('[a, b], g, x)
    obtain Lg from exist Lg R st {$has_derivative_at('[a, b], g, x, Lg)}
    by thm cauchy_mean_value_auxiliary_derivative(a, b, f, g, x, Lf, Lg)
    $has_derivative_at('[a, b], fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}, x, (f(b) - f(a)) * Lg - (g(b) - g(a)) * Lf)
    by thm derivative_value_unique('[a, b], fn(x '[a, b]) R {(f(b) - f(a)) * g(x) - (g(b) - g(a)) * f(x)}, x, Lh, (f(b) - f(a)) * Lg - (g(b) - g(a)) * Lf)
    Lh = (f(b) - f(a)) * Lg - (g(b) - g(a)) * Lf
    Lh = 0
    (f(b) - f(a)) * Lg - (g(b) - g(a)) * Lf = 0
    (f(b) - f(a)) * Lg = (g(b) - g(a)) * Lf
    witness exist x0 '(a, b), Lf0, Lg0 R st {$has_derivative_at('[a, b], f, x0, Lf0), $has_derivative_at('[a, b], g, x0, Lg0), (f(b) - f(a)) * Lg0 = (g(b) - g(a)) * Lf0} from x, Lf, Lg:
        $has_derivative_at('[a, b], f, x, Lf)
        $has_derivative_at('[a, b], g, x, Lg)
        (f(b) - f(a)) * Lg = (g(b) - g(a)) * Lf

# 10.5 L'Hopital's rule

"""
Proposition 10.5.1 (L'Hopital's rule I).  If f(x0)=g(x0)=0, f and g are
differentiable at x0, and g'(x0) is nonzero, then near x0 the quotient f/g is
defined away from x0 and tends to f'(x0)/g'(x0).
"""

# Newton's approximation gives non-vanishing of g near x0 and converts the
# quotient of functions to the quotient of derivative approximations.  The
# formal proof still has to choose the punctured neighborhood where the
# nonzero derivative keeps `g(x)` away from zero.

prop is_nonzero_on_punctured_delta_neighborhood(X power_set(R), g fn(x X) R, x0 X, delta R_pos):
    forall x X:
        x - x0 != 0
        abs(x - x0) < delta
        =>:
            g(x) != 0

thm lhopital_rule_first:
    ? forall X power_set(R), f, g fn(x X) R, x0 X, Lf, Lg R:
        f(x0) = 0
        g(x0) = 0
        $has_derivative_at(X, f, x0, Lf)
        $has_derivative_at(X, g, x0, Lg)
        Lg != 0
        =>:
            exist delta R_pos st {$is_nonzero_on_punctured_delta_neighborhood(X, g, x0, delta)}
    abs(Lg) > 0
    abs(Lg) / 2 $in R_pos
    obtain delta_g from exist delta_g R_pos st {$is_difference_quotient_close_to(X, g, x0, Lg, abs(Lg) / 2, delta_g)}
    witness exist delta R_pos st {$is_nonzero_on_punctured_delta_neighborhood(X, g, x0, delta)} from delta_g:
        claim:
            ? forall x X:
                x - x0 != 0
                abs(x - x0) < delta_g
                =>:
                    g(x) != 0
            by contra:
                ? g(x) != 0
                g(x) = 0
                g(x0) = 0
                g(x) - g(x0) = 0
                (g(x) - g(x0)) / (x - x0) = 0 / (x - x0)
                0 / (x - x0) = 0
                abs(((g(x) - g(x0)) / (x - x0)) - Lg) <= abs(Lg) / 2
                ((g(x) - g(x0)) / (x - x0)) - Lg = 0 - Lg
                abs(((g(x) - g(x0)) / (x - x0)) - Lg) = abs(0 - Lg)
                abs(0 - Lg) = abs(Lg)
                abs(Lg) <= abs(Lg) / 2
                abs(Lg) / 2 < abs(Lg)
                abs(Lg) <= abs(Lg) / 2 < abs(Lg)
                abs(Lg) < abs(Lg)
                impossible abs(Lg) < abs(Lg)
        $is_nonzero_on_punctured_delta_neighborhood(X, g, x0, delta)

"""
The paragraph after Proposition 10.5.1.  The delta restriction is necessary
because g may vanish at points other than x0, so f/g may not be defined on all
of `X-{x0}`.
"""

# This is why the theorem first proves a punctured neighborhood on which the
# denominator is nonzero before making any quotient-limit conclusion.

"""
Proposition 10.5.2 (L'Hopital's rule II).  A one-sided version: if f(a)=g(a)=0,
g' is nonzero, and f'/g' has a right-hand limit L at a, then g is nonzero on
`(a,b]` and f/g has the same right-hand limit L.
"""

# The first step uses the mean value theorem to show that g has no zero on
# `(a,b]`; then the quotient comparison comes from Cauchy's mean value theorem
# on each `[a,x]` and a right-limit transport for its intermediate point.

# A right-hand limit estimate also controls every point strictly between `a`
# and a point `x` in the same right neighborhood.  This is the local transport
# needed after Cauchy's mean value theorem produces its intermediate point.

prop right_limit_controls_between_points_at(a, b, L R, q fn(x '(a, b]) R, epsilon, delta R_pos):
    forall x '(a, b], c '(a, x):
        x - a != 0
        abs(x - a) < delta
        c $in '(a, b]
        =>:
            abs(q(c) - L) <= epsilon

prop right_limit_controls_between_points(a, b, L R, q fn(x '(a, b]) R):
    forall epsilon R_pos:
        exist delta R_pos st {$right_limit_controls_between_points_at(a, b, L, q, epsilon, delta)}

thm function_limit_controls_between_points:
    ? forall a, b, L R, q fn(x '(a, b]) R:
        $chap9::has_function_limit('(a, b], q, a, L)
        =>:
            $right_limit_controls_between_points(a, b, L, q)
    claim:
        ? forall epsilon R_pos:
            exist delta R_pos st {$right_limit_controls_between_points_at(a, b, L, q, epsilon, delta)}
        $chap9::is_locally_epsilon_close_to('(a, b], q, a, L, epsilon)
        obtain delta from exist delta R_pos st {$chap9::is_delta_neighborhood_close_to('(a, b], q, a, L, epsilon, delta)}
        witness exist delta0 R_pos st {$right_limit_controls_between_points_at(a, b, L, q, epsilon, delta0)} from delta:
            claim:
                ? forall x '(a, b], c '(a, x):
                    x - a != 0
                    abs(x - a) < delta
                    c $in '(a, b]
                    =>:
                        abs(q(c) - L) <= epsilon
                c > a
                c < x
                x <= b
                c <= b
                c $in '(a, b]
                c - a > 0
                abs(c - a) = c - a
                x - a > 0
                abs(x - a) = x - a
                c - a < x - a
                abs(c - a) < x - a
                abs(c - a) < abs(x - a)
                abs(c - a) < abs(x - a) < delta
                abs(c - a) < delta
                abs(q(c) - L) <= epsilon
            $right_limit_controls_between_points_at(a, b, L, q, epsilon, delta)
    $right_limit_controls_between_points(a, b, L, q)

# Cauchy's mean value conclusion becomes an equality of quotients when both
# denominators are nonzero and the endpoint values vanish.

thm cauchy_cross_product_gives_quotient:
    ? forall fa, fx, ga, gx, Lf, Lg R:
        fa = 0
        ga = 0
        (fx - fa) * Lg = (gx - ga) * Lf
        gx != 0
        Lg != 0
        =>:
            fx / gx = Lf / Lg
    (fx - fa) * Lg = fx * Lg
    (gx - ga) * Lf = gx * Lf
    fx * Lg = (fx - fa) * Lg
    (fx - fa) * Lg = (gx - ga) * Lf
    (gx - ga) * Lf = gx * Lf
    fx * Lg = gx * Lf
    fx / gx = (fx * Lg) / (gx * Lg)
    (fx * Lg) / (gx * Lg) = (gx * Lf) / (gx * Lg)
    (gx * Lf) / (gx * Lg) = Lf / Lg
    fx / gx = Lf / Lg

thm cauchy_mean_value_quotient_at:
    ? forall a, b R, f, g fn(x '[a, b]) R, df, dg fn(x '(a, b]) R, x '(a, b]:
        a < b
        f(a) = 0
        g(a) = 0
        $chap9::is_continuous_on('[a, b], f)
        $chap9::is_continuous_on('[a, b], g)
        forall y '(a, b]:
            $has_derivative_at('[a, b], f, y, df(y))
            $has_derivative_at('[a, b], g, y, dg(y))
            dg(y) != 0
            g(y) != 0
        =>:
            exist c '(a, b] st {c $in '(a, x), dg(c) != 0, f(x) / g(x) = df(c) / dg(c)}
    have u '[a, b] = a
    have v '[a, b] = x
    u < v
    v - u > 0
    v - u != 0
    by thm closed_interval_subinterval(a, b, u, v)
    '[u, v] $subset '[a, b]
    by thm continuous_restrict_domain('[a, b], '[u, v], f)
    $chap9::is_continuous_on('[u, v], fn(y '[u, v]) R {f(y)})
    by thm continuous_restrict_domain('[a, b], '[u, v], g)
    $chap9::is_continuous_on('[u, v], fn(y '[u, v]) R {g(y)})
    claim:
        ? forall c '(u, v):
            $is_differentiable_at('[u, v], fn(y '[u, v]) R {f(y)}, c)
        c > u
        c < v
        c > a
        c < x
        x <= b
        c <= b
        c $in '(a, b]
        c $in '[u, v]
        by thm chap9::closed_interval_points_are_limit_points(u, v, c)
        $chap9::is_limit_point_of_set('[u, v], c)
        $has_derivative_at('[a, b], f, c, df(c))
        by thm derivative_restrict_domain('[a, b], '[u, v], f, c, df(c))
        $has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, c, df(c))
        witness exist K R st {$has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, c, K)} from df(c):
            $has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, c, df(c))
        $is_differentiable_at('[u, v], fn(y '[u, v]) R {f(y)}, c)
    claim:
        ? forall c '(u, v):
            $is_differentiable_at('[u, v], fn(y '[u, v]) R {g(y)}, c)
        c > u
        c < v
        c > a
        c < x
        x <= b
        c <= b
        c $in '(a, b]
        c $in '[u, v]
        by thm chap9::closed_interval_points_are_limit_points(u, v, c)
        $chap9::is_limit_point_of_set('[u, v], c)
        $has_derivative_at('[a, b], g, c, dg(c))
        by thm derivative_restrict_domain('[a, b], '[u, v], g, c, dg(c))
        $has_derivative_at('[u, v], fn(y '[u, v]) R {g(y)}, c, dg(c))
        witness exist K R st {$has_derivative_at('[u, v], fn(y '[u, v]) R {g(y)}, c, K)} from dg(c):
            $has_derivative_at('[u, v], fn(y '[u, v]) R {g(y)}, c, dg(c))
        $is_differentiable_at('[u, v], fn(y '[u, v]) R {g(y)}, c)
    by thm cauchy_mean_value_theorem(u, v, fn(y '[u, v]) R {f(y)}, fn(y '[u, v]) R {g(y)})
    obtain c, Lf, Lg from exist c '(u, v), Lf, Lg R st {$has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, c, Lf), $has_derivative_at('[u, v], fn(y '[u, v]) R {g(y)}, c, Lg), (fn(y '[u, v]) R {f(y)}(v) - fn(y '[u, v]) R {f(y)}(u)) * Lg = (fn(y '[u, v]) R {g(y)}(v) - fn(y '[u, v]) R {g(y)}(u)) * Lf}
    c > u
    c < v
    c > a
    c < x
    x <= b
    c <= b
    c $in '(a, b]
    c $in '[u, v]
    by thm chap9::closed_interval_points_are_limit_points(u, v, c)
    $chap9::is_limit_point_of_set('[u, v], c)
    $has_derivative_at('[a, b], f, c, df(c))
    by thm derivative_restrict_domain('[a, b], '[u, v], f, c, df(c))
    $has_derivative_at('[u, v], fn(y '[u, v]) R {f(y)}, c, df(c))
    by thm derivative_value_unique('[u, v], fn(y '[u, v]) R {f(y)}, c, Lf, df(c))
    Lf = df(c)
    $has_derivative_at('[a, b], g, c, dg(c))
    by thm derivative_restrict_domain('[a, b], '[u, v], g, c, dg(c))
    $has_derivative_at('[u, v], fn(y '[u, v]) R {g(y)}, c, dg(c))
    by thm derivative_value_unique('[u, v], fn(y '[u, v]) R {g(y)}, c, Lg, dg(c))
    Lg = dg(c)
    fn(y '[u, v]) R {f(y)}(v) = f(x)
    fn(y '[u, v]) R {f(y)}(u) = f(a)
    fn(y '[u, v]) R {g(y)}(v) = g(x)
    fn(y '[u, v]) R {g(y)}(u) = g(a)
    (fn(y '[u, v]) R {f(y)}(v) - fn(y '[u, v]) R {f(y)}(u)) * Lg = (f(x) - f(a)) * Lg
    (fn(y '[u, v]) R {g(y)}(v) - fn(y '[u, v]) R {g(y)}(u)) * Lf = (g(x) - g(a)) * Lf
    (f(x) - f(a)) * Lg = (g(x) - g(a)) * Lf
    (f(x) - f(a)) * dg(c) = (f(x) - f(a)) * Lg
    (g(x) - g(a)) * Lf = (g(x) - g(a)) * df(c)
    (f(x) - f(a)) * dg(c) = (g(x) - g(a)) * df(c)
    g(x) != 0
    dg(c) != 0
    by thm cauchy_cross_product_gives_quotient(f(a), f(x), g(a), g(x), df(c), dg(c))
    f(x) / g(x) = df(c) / dg(c)
    witness exist c0 '(a, b] st {c0 $in '(a, x), dg(c0) != 0, f(x) / g(x) = df(c0) / dg(c0)} from c:
        c $in '(a, x)
        dg(c) != 0
        f(x) / g(x) = df(c) / dg(c)

thm lhopital_rule_second:
    ? forall a, b R, f, g fn(x '[a, b]) R, df, dg fn(x '(a, b]) R, L R:
        a < b
        f(a) = 0
        g(a) = 0
        $chap9::is_continuous_on('[a, b], f)
        $chap9::is_continuous_on('[a, b], g)
        forall x '(a, b]:
            $has_derivative_at('[a, b], f, x, df(x))
            $has_derivative_at('[a, b], g, x, dg(x))
            dg(x) != 0
        $chap9::has_function_limit('(a, b], fn(x '(a, b]) R {df(x) / dg(x)}, a, L)
        =>:
            $is_nonzero_on('(a, b], fn(x '(a, b]) R {g(x)})
    claim:
        ? forall x '(a, b]:
            g(x) != 0
        have u '[a, b] = a
        have v '[a, b] = x
        u < v
        v - u > 0
        v - u != 0
        by thm closed_interval_subinterval(a, b, u, v)
        '[u, v] $subset '[a, b]
        by thm continuous_restrict_domain('[a, b], '[u, v], g)
        $chap9::is_continuous_on('[u, v], fn(y '[u, v]) R {g(y)})
        claim:
            ? forall c '(u, v):
                $is_differentiable_at('[u, v], fn(y '[u, v]) R {g(y)}, c)
            u = a
            v = x
            c > u
            c < v
            c > a
            c < x
            x <= b
            c <= b
            c $in '(a, b]
            $has_derivative_at('[a, b], g, c, dg(c))
            c $in '[u, v]
            by thm chap9::closed_interval_points_are_limit_points(u, v, c)
            $chap9::is_limit_point_of_set('[u, v], c)
            by thm derivative_restrict_domain('[a, b], '[u, v], g, c, dg(c))
            $has_derivative_at('[u, v], fn(y '[u, v]) R {g(y)}, c, dg(c))
            witness exist K R st {$has_derivative_at('[u, v], fn(y '[u, v]) R {g(y)}, c, K)} from dg(c):
                $has_derivative_at('[u, v], fn(y '[u, v]) R {g(y)}, c, dg(c))
            $is_differentiable_at('[u, v], fn(y '[u, v]) R {g(y)}, c)
        by thm mean_value_theorem(u, v, fn(y '[u, v]) R {g(y)})
        obtain c, M from exist c '(u, v), M R st {$has_derivative_at('[u, v], fn(y '[u, v]) R {g(y)}, c, M), M = (fn(y '[u, v]) R {g(y)}(v) - fn(y '[u, v]) R {g(y)}(u)) / (v - u)}
        by contra:
            ? g(x) != 0
            g(x) = 0
            u = a
            v = x
            fn(y '[u, v]) R {g(y)}(v) = g(x)
            fn(y '[u, v]) R {g(y)}(u) = g(a)
            g(a) = 0
            fn(y '[u, v]) R {g(y)}(v) - fn(y '[u, v]) R {g(y)}(u) = 0 - 0
            0 - 0 = 0
            (fn(y '[u, v]) R {g(y)}(v) - fn(y '[u, v]) R {g(y)}(u)) / (v - u) = 0 / (v - u)
            0 / (v - u) = 0
            M = 0
            c > u
            c < v
            c > a
            c < x
            x <= b
            c <= b
            c $in '(a, b]
            $has_derivative_at('[a, b], g, c, dg(c))
            c $in '[u, v]
            by thm chap9::closed_interval_points_are_limit_points(u, v, c)
            $chap9::is_limit_point_of_set('[u, v], c)
            by thm derivative_restrict_domain('[a, b], '[u, v], g, c, dg(c))
            $has_derivative_at('[u, v], fn(y '[u, v]) R {g(y)}, c, dg(c))
            by thm derivative_value_unique('[u, v], fn(y '[u, v]) R {g(y)}, c, M, dg(c))
            M = dg(c)
            dg(c) = 0
            dg(c) != 0
            impossible dg(c) != 0
    $is_nonzero_on('(a, b], fn(x '(a, b]) R {g(x)})

thm lhopital_rule_second_limit:
    ? forall a, b R, f, g fn(x '[a, b]) R, df, dg fn(x '(a, b]) R, L R:
        a < b
        f(a) = 0
        g(a) = 0
        $chap9::is_continuous_on('[a, b], f)
        $chap9::is_continuous_on('[a, b], g)
        forall x '(a, b]:
            $has_derivative_at('[a, b], f, x, df(x))
            $has_derivative_at('[a, b], g, x, dg(x))
            dg(x) != 0
            g(x) != 0
        $chap9::has_function_limit('(a, b], fn(x '(a, b]) R {df(x) / dg(x)}, a, L)
        =>:
            $chap9::has_function_limit('(a, b], fn(x '(a, b]) R {f(x) / g(x)}, a, L)
    # Source handling: apply Cauchy's mean value theorem on `[a,x]`, then
    # compare its intermediate derivative quotient with the right-hand limit.
    # The epsilon witness uses the same intermediate point supplied by the
    # checked Cauchy quotient lemma for each nearby x.
    have fn q(x '(a, b]) R = df(x) / dg(x)
    by thm chap9::closure_of_open_closed_interval(a, b)
    a $in '[a, b]
    a $in closure_of_real_set('(a, b])
    by thm chap9::closure_member_is_adherent('(a, b], a)
    $is_adherent_point('(a, b], a)
    claim:
        ? forall epsilon R_pos:
            $chap9::is_locally_epsilon_close_to('(a, b], fn(x '(a, b]) R {f(x) / g(x)}, a, L, epsilon)
        by thm function_limit_controls_between_points(a, b, L, q)
        $right_limit_controls_between_points(a, b, L, q)
        obtain delta from exist delta R_pos st {$right_limit_controls_between_points(a, b, L, q, epsilon, delta)}
        witness exist delta0 R_pos st {$chap9::is_delta_neighborhood_close_to('(a, b], fn(x '(a, b]) R {f(x) / g(x)}, a, L, epsilon, delta0)} from delta:
            claim:
                ? forall x '(a, b]:
                    abs(x - a) < delta
                    =>:
                        abs(f(x) / g(x) - L) <= epsilon
                by thm cauchy_mean_value_quotient_at(a, b, f, g, df, dg, x)
                obtain c from exist c '(a, b] st {c $in '(a, x), dg(c) != 0, f(x) / g(x) = df(c) / dg(c)}
                c $in '(a, b]
                x - a != 0
                by thm right_limit_controls_between_points_at(a, b, L, q, epsilon, delta)
                abs(q(c) - L) <= epsilon
                q(c) = df(c) / dg(c)
                abs(f(x) / g(x) - L) = abs(q(c) - L)
                abs(f(x) / g(x) - L) <= epsilon
            $chap9::is_delta_neighborhood_close_to('(a, b], fn(x '(a, b]) R {f(x) / g(x)}, a, L, epsilon, delta)
        $chap9::is_locally_epsilon_close_to('(a, b], fn(x '(a, b]) R {f(x) / g(x)}, a, L, epsilon)
    $chap9::has_function_limit('(a, b], fn(x '(a, b]) R {f(x) / g(x)}, a, L)

"""
Remark 10.5.3.  This version is a right-hand limit theorem.  Left-hand and
two-sided versions are analogous, but the hypotheses must be checked before
using the informal formula `lim f/g = lim f'/g'`.
"""

# This theorem states the safe right-hand use of the informal formula: first
# prove the non-vanishing side condition for `g`, then invoke the quotient-limit
# theorem with that side condition available.

thm lhopital_rule_second_checked_right_hand_formula:
    ? forall a, b R, f, g fn(x '[a, b]) R, df, dg fn(x '(a, b]) R, L R:
        a < b
        f(a) = 0
        g(a) = 0
        $chap9::is_continuous_on('[a, b], f)
        $chap9::is_continuous_on('[a, b], g)
        forall x '(a, b]:
            $has_derivative_at('[a, b], f, x, df(x))
            $has_derivative_at('[a, b], g, x, dg(x))
            dg(x) != 0
        $chap9::has_function_limit('(a, b], fn(x '(a, b]) R {df(x) / dg(x)}, a, L)
        =>:
            $is_nonzero_on('(a, b], fn(x '(a, b]) R {g(x)})
            $chap9::has_function_limit('(a, b], fn(x '(a, b]) R {f(x) / g(x)}, a, L)
    by thm lhopital_rule_second(a, b, f, g, df, dg, L)
    $is_nonzero_on('(a, b], fn(x '(a, b]) R {g(x)})
    claim:
        ? forall x '(a, b]:
            g(x) != 0
        fn(y '(a, b]) R {g(y)}(x) = g(x)
        fn(y '(a, b]) R {g(y)}(x) != 0
        g(x) != 0
    by thm lhopital_rule_second_limit(a, b, f, g, df, dg, L)
    $chap9::has_function_limit('(a, b], fn(x '(a, b]) R {f(x) / g(x)}, a, L)
