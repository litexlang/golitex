# Chapter 9 continuity citations.

thm positive_base_exponentiation_continuous:
    ? forall a R_pos:
        $is_continuous_on(R, fn(x R) R {a^x})
    trust $is_continuous_on(R, fn(x R) R {a^x})

thm positive_domain_power_function_continuous:
    ? forall p R:
        $is_continuous_on(R_pos, fn(x R_pos) R {x^p})
    trust $is_continuous_on(R_pos, fn(x R_pos) R {x^p})
