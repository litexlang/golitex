
# Chapter 7 — Number Theory

# > _Mathematics is the queen of sciences and number theory is the queen of mathematics._
# >
# > _– Carl Friedrich Gauss_

# This chapter has a different flavor from the earlier chapters. The theorems here
# are classical results, and their proofs often depend on a one-time clever idea
# rather than a reusable template. The question for Litex is simple: once the
# mathematical idea is clear, can the formal proof still look like the proof one
# would write on paper?

# 7.1 Infinitely Many Primes

# The first example in Macbeth's chapter is Euclid's theorem: there are infinitely
# many primes. In Litex, the proof can be written in the same forward order as the
# mathematical idea. Take the factorial-like product
# `product(1, a, fn(x N_pos) N_pos {x})`, then take a prime factor `k` of this product plus
# one. If `k <= a`, then `k` divides the product. But `k` also divides the product
# plus one, so the same remainder would have to be both `0` and `1`, a
# contradiction. Therefore `k > a`.

# The point is not that Litex hides the mathematics. The point is that the proof
# script is mostly the mathematics. The user writes the facts in order: an
# inequality chain, an existential extraction, a case split, a contradiction, and
# then the witness for the final existential statement.

# Before the main proof, we prove three ordinary supporting facts: every positive
# integer `k <= a` divides `1 * 2 * ... * a`; every positive integer at least
# `2` has a prime factor; and `a <= 1 * 2 * ... * a`. These checked derivations
# keep the final Euclid proof focused on its contradiction argument.

claim:
    ? forall a N_pos:
        product(1, a, fn(x N_pos) N_pos {x}) % a = 0 and a <= product(1, a, fn(x N_pos) N_pos {x})

    by induc a from 1:
        ? product(1, a, fn(x N_pos) N_pos {x}) % a = 0 and a <= product(1, a, fn(x N_pos) N_pos {x})

        product(1, 1, fn(x N_pos) N_pos {x}) = 1
        1 <= product(1, 1, fn(x N_pos) N_pos {x})

        claim:
            ? forall k Z:
                k >= 1
                product(1, k, fn(x N_pos) N_pos {x}) % k = 0 and k <= product(1, k, fn(x N_pos) N_pos {x})
                =>:
                    product(1, k + 1, fn(x N_pos) N_pos {x}) % (k + 1) = 0 and k + 1 <= product(1, k + 1, fn(x N_pos) N_pos {x})

            product(1, k + 1, fn(x N_pos) N_pos {x}) = product(1, k, fn(x N_pos) N_pos {x}) * (k + 1)
            witness exist t Z st {product(1, k + 1, fn(x N_pos) N_pos {x}) = t * (k + 1)} from product(1, k, fn(x N_pos) N_pos {x})
            product(1, k + 1, fn(x N_pos) N_pos {x}) % (k + 1) = 0
            k + 1 <= product(1, k + 1, fn(x N_pos) N_pos {x})

claim:
    ? forall a, k N_pos:
        k <= a
        =>:
            product(1, a, fn(x N_pos) N_pos {x}) % k = 0

    by cases:
        ? product(1, a, fn(x N_pos) N_pos {x}) % k = 0
        case k = a:
            product(1, a, fn(x N_pos) N_pos {x}) % a = 0
            product(1, a, fn(x N_pos) N_pos {x}) % k = product(1, a, fn(x N_pos) N_pos {x}) % a = 0
        case k < a:
            by thm basics::integer_successor_le_of_lt(a, k)
            product(1, a, fn(x N_pos) N_pos {x}) = product(1, k, fn(x N_pos) N_pos {x}) * product(k + 1, a, fn(x N_pos) N_pos {x})
            product(1, k, fn(x N_pos) N_pos {x}) % k = 0
            by thm basics::integer_mod_quotient_remainder(product(1, k, fn(x N_pos) N_pos {x}), k)
            obtain r from exist q Z st {product(1, k, fn(x N_pos) N_pos {x}) = k * q + product(1, k, fn(x N_pos) N_pos {x}) % k}
            product(1, k, fn(x N_pos) N_pos {x}) = k * r + product(1, k, fn(x N_pos) N_pos {x}) % k = k * r = r * k
            witness exist t Z st {product(1, a, fn(x N_pos) N_pos {x}) = t * k} from r * product(k + 1, a, fn(x N_pos) N_pos {x}):
                product(1, a, fn(x N_pos) N_pos {x}) = product(1, k, fn(x N_pos) N_pos {x}) * product(k + 1, a, fn(x N_pos) N_pos {x}) = (r * k) * product(k + 1, a, fn(x N_pos) N_pos {x}) = (r * product(k + 1, a, fn(x N_pos) N_pos {x})) * k
            product(1, a, fn(x N_pos) N_pos {x}) % k = 0

claim:
    ? forall a N_pos:
        a <= product(1, a, fn(x N_pos) N_pos {x})

    product(1, a, fn(x N_pos) N_pos {x}) % a = 0 and a <= product(1, a, fn(x N_pos) N_pos {x})

claim:
    ? forall a N_pos:
        2 <= a
        =>:
            exist k N_pos st {$citation::prime(k), a % k = 0}

    by strong_induc x from 2:
        ? exist k N_pos st {$citation::prime(k), x % k = 0}

        claim:
            ? forall b N_pos:
                2 <= b < 2
                =>:
                    2 % b != 0
            by contra 2 % b != 0:
                impossible b < 2
        $citation::prime(2)

        witness exist t Z st {2 = t * 2} from 1
        by thm basics::integer_mod_eq_remainder_of_quotient_remainder(2, 2, 1, 0)
        2 % 2 = 0
        witness exist k N_pos st {$citation::prime(k), 2 % k = 0} from 2

        claim:
            ? forall n Z:
                n >= 2
                forall m Z:
                    2 <= m
                    m <= n
                    =>:
                        exist k N_pos st {$citation::prime(k), m % k = 0}
                =>:
                    exist k N_pos st {$citation::prime(k), (n + 1) % k = 0}

            by cases exist k N_pos st {$citation::prime(k), (n + 1) % k = 0}:
                case $citation::prime(n+1):
                    witness exist t Z st {n + 1 = t * (n + 1)} from 1
                    by thm basics::integer_mod_eq_remainder_of_quotient_remainder(n + 1, n + 1, 1, 0)
                    (n + 1) % (n + 1) = 0
                    witness exist k N_pos st {$citation::prime(k), (n + 1) % k = 0} from n+1
                case not $citation::prime(n+1):
                    by contra:
                        ? not forall b N_pos:
                            2 <= b < n + 1
                            =>:
                                (n + 1) % b != 0
                        2 <= n + 1
                        $citation::prime(n+1)
                        impossible $citation::prime(n+1)

                    obtain c from exist b N_pos st {2 <= b < n+1, not (n + 1) % b != 0}

                    2 <= c < n+1

                    (n+1) % c = 0
                    by thm basics::integer_le_or_ge_successor(c, n)
                    by cases:
                        ? c <= n
                        case c <= n:
                            do_nothing
                        case c >= n + 1:
                            impossible c < n + 1

                    obtain d from exist k N_pos st {$citation::prime(k), c % k = 0}

                    by thm basics::integer_mod_quotient_remainder(n + 1, c)
                    obtain e from exist q Z st {n + 1 = c * q + (n + 1) % c}
                    n + 1 = c * e + (n + 1) % c = c * e = e * c

                    by thm basics::integer_mod_quotient_remainder(c, d)
                    obtain f from exist r Z st {c = d * r + c % d}
                    c = d * f + c % d = d * f = f * d

                    witness exist t Z st {e * f * d = t * d} from e * f
                    by thm basics::integer_mod_eq_remainder_of_quotient_remainder(e * f * d, d, e * f, 0)
                    (e * f * d) % d = 0

                    n + 1 = e * c = e * (f * d) = (e * f) * d
                    by thm basics::integer_mod_eq_remainder_of_quotient_remainder(n + 1, d, e * f, 0)
                    (n + 1) % d = 0
                    witness exist k N_pos st {$citation::prime(k), (n + 1) % k = 0} from d:
                        (n + 1) % d = 0

# With these facts in the context, the whole proof body is the following 11 lines:

claim forall! a N_pos: 2 <= a => {exist k N_pos st {k > a, $citation::prime(k)}}:
    2 <= a <= product(1, a, fn(x N_pos) N_pos {x}) <= product(1, a, fn(x N_pos) N_pos {x}) + 1
    obtain k from exist k N_pos st {$citation::prime(k), (product(1, a, fn(x N_pos) N_pos {x}) + 1) % k = 0}
    by cases k > a:
        case k <= a:
            product(1, a, fn(x N_pos) N_pos {x}) % k = 0
            2 <= k
            by thm basics::integer_mod_add(product(1, a, fn(x N_pos) N_pos {x}), 1, k)
            by thm basics::one_mod_eq_one_of_two_le(k)
            (0 + 1) % k = 1 % k = 1
            (product(1, a, fn(x N_pos) N_pos {x}) + 1) % k = (product(1, a, fn(x N_pos) N_pos {x}) % k + 1 % k) % k = (0 + 1) % k = 1
            impossible (product(1, a, fn(x N_pos) N_pos {x}) + 1) % k = 0
        case k > a:
            do_nothing
    witness exist k N_pos st {k > a, $citation::prime(k)} from k

