have factorial fn(N) N_pos
know:
    factorial(0) = 1
    factorial(1) = 1
    forall n N: n != 0, n != 1 => factorial(n) = factorial(n - 1) * n

know forall n N: n != 0, n != 1 => n - 1 $in N

algo factorial(n):
    if n = 0:
        return 1
    if n = 1:
        return 1
    return factorial(n - 1) * n

eval factorial(10)
factorial(10) = 3628800