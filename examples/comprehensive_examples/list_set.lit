prove:
    $is_nonempty_set({1, 2})
    have a {1, 2}
    a = 1 or a = 2

    $is_nonempty_set({3})

    not $is_nonempty_set({})

prove:
    have a set = {1, 2}
    have b set = {1, 2}

    forall x b:
        x = 1 or x = 2

    forall x a:
        x = 1 or x = 2

prove:
    1 $in {1, 2, 3}

    enum a {1, 2, 3}:
        a $in {3, 2, 1}

    enum a {3, 2, 1}:
        a $in {1, 2, 3}

    equal_set {1, 2, 3}, {3, 2, 1}:
        do_nothing