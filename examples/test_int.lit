run_file Int

# Basic integer predicates from Mathlib generic notation.
witness exist k Z st {12 = 3 * k} from 4:
    12 = 3 * 4
$Int_Dvd(3, 12)

witness exist k Z st {-4 = 2 * k} from -2:
    -4 = 2 * -2
$Int_Even(-4)

witness exist k Z st {-3 = 2 * k + 1} from -2:
    -3 = 2 * -2 + 1
$Int_Odd(-3)

$Int_ModEq(5, 11, 1)

# Mathlib: Int.gcd_def
by thm Int_gcd_def(4, -6)
Int_gcd(4, -6) = Nat_gcd(Int_natAbs(4), Int_natAbs(-6))

# Mathlib: Int.lcm_def
by thm Int_lcm_def(4, -6)
Int_lcm(4, -6) = Nat_lcm(Int_natAbs(4), Int_natAbs(-6))

# Mathlib: Int.gcd_eq_gcd_ab
by thm Int_gcd_eq_gcd_ab(56, 35)
Int_gcd(56, 35) = 56 * Int_gcdA(56, 35) + 35 * Int_gcdB(56, 35)

# Mathlib: Int.gcd_dvd_left / Int.gcd_dvd_right
by thm Int_gcd_dvd_left(56, 35)
$Int_Dvd(Int_gcd(56, 35), 56)

by thm Int_gcd_dvd_right(56, 35)
$Int_Dvd(Int_gcd(56, 35), 35)

Int_floor(3 / 2) <= 3 / 2 < Int_floor(3 / 2) + 1
Int_ceil(3 / 2) - 1 < 3 / 2 <= Int_ceil(3 / 2)
