run_file Int

# Basic integer predicates from Mathlib generic notation.
witness exist k Z st {12 = 3 * k} from 4:
    12 = 3 * 4
$Dvd(3, 12)

witness exist k Z st {-4 = 2 * k} from -2:
    -4 = 2 * -2
$Even(-4)

witness exist k Z st {-3 = 2 * k + 1} from -2:
    -3 = 2 * -2 + 1
$Odd(-3)

$ModEq(5, 11, 1)

# Mathlib: Int.gcd_def
by thm gcd_def(4, -6)
gcd(4, -6) = gcd(natAbs(4), natAbs(-6))

# Mathlib: Int.lcm_def
by thm lcm_def(4, -6)
lcm(4, -6) = lcm(natAbs(4), natAbs(-6))

# Mathlib: Int.gcd_eq_gcd_ab
by thm gcd_eq_gcd_ab(56, 35)
gcd(56, 35) = 56 * gcdA(56, 35) + 35 * gcdB(56, 35)

# Mathlib: Int.gcd_dvd_left / Int.gcd_dvd_right
by thm gcd_dvd_left(56, 35)
$Dvd(gcd(56, 35), 56)

by thm gcd_dvd_right(56, 35)
$Dvd(gcd(56, 35), 35)

floor(3 / 2) <= 3 / 2 < floor(3 / 2) + 1
ceil(3 / 2) - 1 < 3 / 2 <= ceil(3 / 2)
