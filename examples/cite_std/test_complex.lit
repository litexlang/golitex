import complex

(1, 2) $in &complex::C
have z0 &complex::C = (1, 2)

&complex::C{z0}.re = z0[1]
&complex::C{z0}.im = z0[2]
&complex::C{(1, 2)}.re = 1
&complex::C{(1, 2)}.im = 2

forall z &complex::C:
    &complex::C{z}.re $in R
    &complex::C{z}.im $in R

forall a, b &complex::C:
    complex::C_add(a, b) = (&complex::C{a}.re + &complex::C{b}.re, &complex::C{a}.im + &complex::C{b}.im)

forall a &complex::C:
    complex::C_neg(a) = (-&complex::C{a}.re, -&complex::C{a}.im)

forall a, b &complex::C:
    complex::C_sub(a, b) = (&complex::C{a}.re - &complex::C{b}.re, &complex::C{a}.im - &complex::C{b}.im)

forall a, b &complex::C:
    complex::C_mul(a, b) = (&complex::C{a}.re * &complex::C{b}.re - &complex::C{a}.im * &complex::C{b}.im, &complex::C{a}.re * &complex::C{b}.im + &complex::C{a}.im * &complex::C{b}.re)

forall a &complex::C:
    complex::C_conj(a) = (&complex::C{a}.re, -&complex::C{a}.im)

forall z &complex::C:
    complex::C_normSq(z) = &complex::C{z}.re^2 + &complex::C{z}.im^2
    complex::C_abs(z) = complex::C_norm(z)
    complex::C_norm(z)^2 = complex::C_normSq(z)

complex::C_add((1, 2), (3, 4)) = (1 + 3, 2 + 4) = (4, 6)

forall a, b &complex::C:
    complex::C_add(a, b) = (&complex::C{a}.re + &complex::C{b}.re, &complex::C{a}.im + &complex::C{b}.im) = (&complex::C{b}.re + &complex::C{a}.re, &complex::C{b}.im + &complex::C{a}.im) = complex::C_add(b, a)

forall a &complex::C:
    complex::C_add(a, (0, 0)) = (&complex::C{a}.re + 0, &complex::C{a}.im + 0) = (&complex::C{a}.re, &complex::C{a}.im) = a
    complex::C_add((0, 0), a) = (0 + &complex::C{a}.re, 0 + &complex::C{a}.im) = (&complex::C{a}.re, &complex::C{a}.im) = a

complex::C_neg((1, 2)) = (-1 * 1, -1 * 2)
complex::C_sub((5, 7), (2, 3)) = (5 - 2, 7 - 3) = (3, 4)
complex::C_mul((1, 2), (3, 4)) = (1 * 3 - 2 * 4, 1 * 4 + 2 * 3) = (-5, 10)
complex::C_conj((3, 5)) = (3, -1 * 5)
complex::C_normSq((3, 4)) = 3^2 + 4^2 = 25
complex::C_norm((3, 4)) = 5
complex::C_abs((3, 4)) = complex::C_norm((3, 4)) = 5
complex::C_add((1, 2), complex::C_neg((1, 2))) = complex::C_add((1, 2), (-1 * 1, -1 * 2)) = (1 + -1 * 1, 2 + -1 * 2) = (0, 0)
complex::C_add(complex::C_neg((1, 2)), (1, 2)) = complex::C_add((-1 * 1, -1 * 2), (1, 2)) = (-1 * 1 + 1, -1 * 2 + 2) = (0, 0)
