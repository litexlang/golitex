run_file Set
run_file Finset
run_file Fintype

$Mem(1, {1, 2})
$Subset({1}, {1, 2})
$Finite({1, 2})
$Ncard({1, 2}, 2)
ncard({1, 2}) = 2
toFinset({1, 2}) = {1, 2}

by thm subset_refl({1, 2})
{1, 2} $subset {1, 2}

by thm Finite_union({1}, {2})
$is_finite_set(union({1}, {2}))

$Finset({1, 2, 3})
$Mem(2, {1, 2, 3})
$Card({1, 2, 3}, 3)
card({1, 2, 3}) = 3

$range_value(5, range_nat(5))
2 < 5
2 $in range_nat(5)
by thm mem_range(2, 5)
2 < 5

by thm card_range(5)
card(range_nat(5)) = 5

$Icc_value(2, 5, Icc(2, 5))
2 <= 3 <= 5
3 $in Icc(2, 5)
by thm mem_Icc(2, 5, 3)
2 <= 3 <= 5

by thm card_Icc(2, 5)
card(Icc(2, 5)) = 5 - 2 + 1 = 4

$Fintype({1, 2})
$Finite({1, 2})
$Card({1, 2}, 2)
card({1, 2}) = 2

by thm card_eq_count({1, 2})
card({1, 2}) = count({1, 2})
