run_file Set
run_file Finset
run_file Fintype

$Set_Mem(1, {1, 2})
$Set_Subset({1}, {1, 2})
$Set_Finite({1, 2})
$Set_Ncard({1, 2}, 2)
Set_ncard({1, 2}) = 2
Set_toFinset({1, 2}) = {1, 2}

by thm Set_subset_refl({1, 2})
{1, 2} $subset {1, 2}

by thm Set_Finite_union({1}, {2})
$is_finite_set(union({1}, {2}))

$Finset({1, 2, 3})
$Finset_Mem(2, {1, 2, 3})
$Finset_Card({1, 2, 3}, 3)
Finset_card({1, 2, 3}) = 3

$Finset_range_value(5, Finset_range(5))
2 < 5
2 $in Finset_range(5)
by thm Finset_mem_range(2, 5)
2 < 5

by thm Finset_card_range(5)
Finset_card(Finset_range(5)) = 5

$Finset_Icc_value(2, 5, Finset_Icc(2, 5))
2 <= 3 <= 5
3 $in Finset_Icc(2, 5)
by thm Finset_mem_Icc(2, 5, 3)
2 <= 3 <= 5

by thm Finset_card_Icc(2, 5)
Finset_card(Finset_Icc(2, 5)) = 5 - 2 + 1 = 4

$Fintype({1, 2})
$Finite({1, 2})
$Fintype_Card({1, 2}, 2)
Fintype_card({1, 2}) = 2

by thm Fintype_card_eq_count({1, 2})
Fintype_card({1, 2}) = count({1, 2})
