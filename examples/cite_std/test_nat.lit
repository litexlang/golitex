run_file Nat

# Basic natural-number predicates.
witness exist k N st {4 = 2 * k} from 2:
    4 = 2 * 2
$Even(4)

witness exist k N st {5 = 2 * k + 1} from 2:
    5 = 2 * 2 + 1
$Odd(5)

witness exist k N st {12 = 3 * k} from 4:
    12 = 3 * 4
$Dvd(3, 12)

$ModEq(4, 11, 3)

# Prime, gcd, and coprime Mathlib-facing theorem names.
by thm Prime_two(0)
$Prime(2)

by thm Prime_one_lt(2)
1 < 2

by thm gcd_comm(4, 6)
gcd(4, 6) = gcd(6, 4)

by thm gcd_dvd_left(4, 6)
$Dvd(gcd(4, 6), 4)

by thm coprime_one_right(4)
$Coprime(4, 1)

by thm one_coprime(4)
$Coprime(1, 4)

by thm Prime_dvd_or_dvd(2, 4, 3)
$Dvd(2, 4) or $Dvd(2, 3)

by thm exists_prime_and_dvd(91)
exist p N st {$Prime(p), $Dvd(p, 91)}

choose_fn(5, 0) = 1
sqrt_nat(9)^2 <= 9

# Trivial Mathlib Nat facts are examples, not std theorem aliases.
claim:
    prove:
        forall n N:
            n + 1 != 0
    0 <= n < n + 1
    n + 1 != 0

claim:
    prove:
        forall n N:
            0 <= n
    0 <= n

claim:
    prove:
        forall n N_pos:
            n - 1 $in N
    n - 1 $in N
