run_file nat

$even(4)
$odd(5)
$divides(3, 12)
$mod_eq(11, 3, 4)
$coprime(4, 1)
$coprime(1, 4)

claim:
    prove:
        forall q Q:
            exist a Z, b N_pos st {q = a / b, $coprime(a, b)}

claim:
    prove:
        forall d, a, b Z:
            $divides(d, a)
            $divides(d, b)
            =>:
                $divides(d, a + b)
