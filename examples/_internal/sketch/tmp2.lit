forall a, b R:
    a <= b
    =>:
        a = b or a < b

forall a, b R:
    a >= b
    =>:
        a = b or a > b

forall a, b R:
    =>:
        a <= b
    <=>:
        0 <= b - a

forall a, b R:
    =>:
        a < b
    <=>:
        0 < b - a

forall a R:
    a != 0
    =>:
        0 < a * a
        0 < a^2

forall a, b R:
    a * b = 0
    =>:
        a = 0 or b = 0