abstract_prop is_riemann_sum(f, a, b, r)

prop integrable(a, b R, f set):
    $restrict_fn_in(f, fn(x R: (x - a) * (x - b) <= 0)R)
    exist r R st {$is_riemann_sum(f, a, b, r)}

template<a, b R, f set: $integrable(a, b, f)>:
    have by exist r R st {$is_riemann_sum(f, a, b, r)}: integral

forall a, b R, f set:
    $integrable(a, b, f)
    =>:
        \integral<f, a, b> = integral<f, a, b>