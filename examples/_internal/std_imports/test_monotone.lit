import Real
import Monotone

have a seq(R)

know:
    $Monotone::increasing_sequence_R(a)
    $Monotone::bounded_above_sequence_R(a)

by thm Monotone::increasing_bounded_above_sequence_converges_R(a)
$Real::convergent_sequence_R(a)

have b seq(R)

know:
    $Monotone::decreasing_sequence_R(b)
    $Monotone::bounded_below_sequence_R(b)

by thm Monotone::decreasing_bounded_below_sequence_converges_R(b)
$Real::convergent_sequence_R(b)
