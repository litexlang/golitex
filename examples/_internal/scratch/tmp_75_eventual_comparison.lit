run_file "../../../scripts/analysis-one/chapters_in_litex/chap7.lit"

thm scratch_eventual_comparison_test_for_series:
    ? forall a, b seq(R), n0 N_pos:
        $is_convergent_series(b)
        $is_eventually_abs_bounded_by(a, b, n0)
        =>:
            $is_absolutely_convergent_series(a)
    by thm eventual_comparison_test_for_series(a, b, n0)
    $is_absolutely_convergent_series(a)
