run_file "../../../scripts/analysis-one/chapters_in_litex/chap7.lit"

thm scratch_ratio_test_absolute_convergence:
    ? forall a seq(R), alpha, beta R:
        $has_no_zero_terms(a)
        $has_finite_limit_superior(absolute_ratio_terms(a), alpha)
        $has_finite_limit_inferior(absolute_ratio_terms(a), beta)
        alpha < 1
        =>:
            $is_absolutely_convergent_series(a)
    by thm ratio_test_absolute_convergence(a, alpha, beta)
    $is_absolutely_convergent_series(a)

thm scratch_ratio_test_divergence:
    ? forall a seq(R), alpha, beta R:
        $has_no_zero_terms(a)
        $has_finite_limit_superior(absolute_ratio_terms(a), alpha)
        $has_finite_limit_inferior(absolute_ratio_terms(a), beta)
        beta > 1
        =>:
            not $is_convergent_series(a)
    by thm ratio_test_divergence(a, alpha, beta)
    not $is_convergent_series(a)
