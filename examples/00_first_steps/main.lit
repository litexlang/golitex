# snippet 6, source: README.md:113

forall a, b, c, d R:
    b != 0
    d != 0
    b * d != 0
    =>:
        (a + b)^ 2 = a * a + 1.5 * a * b + 2 * b ^2 - b ^ 2 + 0.5*b * a
        (a + b) * (c + d) = a * c + d * b + 2 * b * c + a*d*1 - c * b

        a / b + c / d = (a * d + c * b) / (b * d)
        a / (b * d) + c / (b * d) = (a + c) / (b * d)

        1 / 3 = 3 / 9

