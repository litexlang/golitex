abstract_prop p(a, b)
abstract_prop q(a, b)

know:
    exist a, b, c R st {$p(a, b), $q(b, c)}
    forall a1, b1, c1 R, a2, b2, c2 R:
        $p(a1, b1)
        $q(b1, c1)
        $p(a2, b2)
        $q(b2, c2)
        =>:
            (a1, b1, c1) = (a2, b2, c2)

exist_unique a, b, c R st {$p(a, b), $q(b, c)}

abstract_prop t(a)

know:
    exist a R st {$t(a)}
    forall a1, a2 R:
        $t(a1)
        $t(a2)
        =>:
            a1 = a2

exist_unique a R st {$t(a)}