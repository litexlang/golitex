# Minimal `by induc` example: first block is `prove:` (one or more goals);
# optional proof blocks follow (here empty — lemmas come from `know`).

abstract_prop p(a)

know:
    $p(0)
    forall n Z:
        n >= 0
        $p(n)
        =>:
            $p(n + 1)

by induc n from 0:
    prove:
        $p(n)

forall n Z:
    n >= 0
    =>:
        $p(n)
