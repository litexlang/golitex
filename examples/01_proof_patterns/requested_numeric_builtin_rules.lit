# Direct numeric and integer builtin rules, with no imported theory package.

forall a, b R:
    =>:
        a = 0 and b = 0
    <=>:
        a ^ 2 + b ^ 2 = 0

forall a, b R:
    a * b != 0
    =>:
        a != 0 and b != 0

forall a R_pos, b R_nz:
    a = (a ^ b) ^ (1 / b)
    a = (a ^ (1 / b)) ^ b

forall n Z, k N_pos:
    (-n) % k = (k - (n % k)) % k

forall n Z, m Z:
    n >= m or n <= m - 1

forall n Z, m N_pos, k N_pos:
    n ^ m % k = ((n % k) ^ m) % k
