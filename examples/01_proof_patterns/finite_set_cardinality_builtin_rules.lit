# Finite-set cardinality facts checked directly by the verifier. Subset
# finiteness itself is the `subset_of_finite_set_is_finite` axiom in `basics`.

forall A, B finite_set:
    A $subset B
    =>:
        finite_set_size(A) <= finite_set_size(B)

forall a, b N:
    a <= b
    =>:
        finite_set_size(closed_range(a, b)) = b - a + 1
        finite_set_size(range(a, b)) = b - a
