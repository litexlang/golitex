prove:
    abstract_prop p(a, b)
    abstract_prop q(a, b)

    know forall a, b R:
        $p(a, {x R: $p(x, b)})
        $q(1, {x R: $q(a + b, x)})

    prove:
        $p(1, {x R: $p(x, 2)})
        # $p(1, {x R: $p(x, x)}) 是unknown，因为x作为set builder的参数不能匹配b
        $q(1, {x R: $q(1 + 2, x)})

prove:
    have f fn(x, y R) R

    know forall k Z, k2 R:
        1 <= k
        =>:
            sum(i, 1, k, f(k2, i)) = f(k2, sum(i, 1, k, i))

    sum(i, 1, 3, f(4, i)) = f(4, sum(i, 1, 3, i))