abstract_prop p(x, x2)
abstract_prop F(x, x2, y)
have A set
have B set
have C set

know forall x A, x2 B:
    $p(x, x2)
    =>:
        exist! y C st {$F(x, x2, y)}

have fn f by forall x A, x2 B:
    $p(x, x2)
    =>:
        exist! y C st {$F(x, x2, y)}

f $in fn(x A, x2 B: $p(x, x2)) C

forall x A, x2 B:
    $p(x, x2)
    =>:
        $F(x, x2, f(x, x2))
