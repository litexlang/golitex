prove:
    prop p(x R)

    know exist a R st $p(a)

    exist a R st $p(a)

prove:
    prop q(x R, y R)

    know forall x R: x > 0 => exist y R st $q(x, y)

    exist y R st $q(1, y)

prove:
    prop p(x R)
    prop q(x R, y R)

    know exist a, b R st {$p(a), $q(a, b)}

    exist a, b R st {$p(a), $q(a, b)}

prove:
    prop t(x R, y R)
    prop r(x R, y R)

    know forall x R: x > 0 => exist y R st {$t(x, y), $r(x, y)}

    exist y R st {$t(1, y), $r(1, y)}