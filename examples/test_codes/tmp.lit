prop all_items_in_set_are_nonempty(S set):
	forall x S:
		$is_nonempty_set(x)

know:
	forall S set, s S:
		all_items_in_set_are_nonempty(S)
		=>:
			choice(S, s) $in s

# End of ZFC

prop is_max(r R, s set):
    forall x s: x $in R
	r $in s
	forall x s: x <= r

know:
    forall s power_set(R):
		$is_finite_set(s)
		=>:
			exist z s st $is_max(z, s)

prop is_min(r R, s set):
	forall x s: x $in R
	r $in s
	forall x s: r <= x

know:
    forall s power_set(R):
		$is_finite_set(s)
		=>:
			exist z s st $is_min(z, s)
