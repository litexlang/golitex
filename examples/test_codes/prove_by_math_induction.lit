prop p(n N_pos)

prove:
    know:
        $p(1)
        forall n N_pos: $p(n) => $p(n+1)

    induc n N_pos: $p(n):
        do_nothing

prove:
    know:
        $p(2)
        forall n N_pos: $p(n) => $p(n+1)

    induc n >= 2: $p(n):
        do_nothing

prove:
    know:
        $p(0)
        forall n N_pos: $p(n) => $p(n+1)

    induc n N: $p(n):
        do_nothing

 