struct StandardTwoSimplex:
    x R
    y R
    z R
    <=>:
        0 <= x
        0 <= y
        0 <= z
        x + y + z = 1

forall s &StandardTwoSimplex:
    1 = s[1] + s[2] + s[3] = s[2] + s[1] + s[3]
    (s[2], s[1], s[3]) $in &StandardTwoSimplex

have fn swapXy(s &StandardTwoSimplex) &StandardTwoSimplex = (s[2], s[1], s[3])