prop GroupProperty(s set, inv fn(x s) s, op fn(x, y s) s, e s):
    forall x s:
        op(x, inv(x)) = e
        op(inv(x), x) = e
    forall x, y, z s:
        op(x, op(y, z)) = op(op(x, y), z)
    forall x s:
        op(x, e) = x
        op(e, x) = x

struct Group(s set):
    inv fn(x s) s
    op fn(x, y s) s
    e s
    <=>:
        $GroupProperty(s, inv, op, e)

$GroupProperty(R, 'R(x){-x}, 'R(x, y){x + y}, 0)
('R(x){-x}, 'R(x, y){x + y}, 0) $in &Group(R)