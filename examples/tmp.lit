# --- A3 assistant jsonl:2578 ---
# 这些字段都是为了让 `ModuleManager` 管理 module graph，而不是单纯保存几个环境。逐个解释：
#
# ```rust
# pub module_by_name: HashMap<String, ModuleId>
# ```
#
# 用于把：
#
# ```text
# import Nat
# M.x
# stop import Nat
# ```
#
# 中的模块名解析成 `ModuleId`。
#
# 同时防止：
#
# ```text
# 两个不同路径都叫 Nat
# ```
#
# 造成模块名冲突。
#
# ---
#
# ```rust
# pub module_by_path: HashMap<String, ModuleId>
# ```
#
# 用于根据规范化后的绝对路径查找 module。
#
# 例如：
#
# ```text
# import "./math"
# import "/project/math"
# ```
#
# 如果它们最终是同一个路径，就不能重复加载两次。
#
# 它也支持：
#
# ```text
# 模块已经加载过 → 直接复用
# 模块只是 stop 了 → 重新激活
# ```
#
# ---
#
# ```rust
# pub loading_import_stack: Vec<ModuleId>
# ```
#
# 用于检测循环 import。
#
# 例如：
#
# ```text
# A imports B
# B imports C
# C imports A
# ```
#
# 执行时：
#
# ```text
# loading_import_stack = [A, B, C]
# ```
#
# 发现 A 已经在 stack 中，就可以报告：
#
# ```text
# cyclic import: A -> B -> C -> A
# ```
#
# 它是执行中的调用栈，不是最终的依赖列表。
#
# ---
#
# ```rust
# pub pending_import_dependencies: HashMap<ModuleId, Vec<ModuleId>>
# ```
#
# 这个字段是为了解决“模块还没加载完成，但它已经 import 了其他模块”的问题。
#
# 例如：
#
# ```text
# Int/main.lit:
#     import Nat
# ```
#
# 加载 Int 时：
#
# ```text
# Int 还没有进入 loaded modules
# ```
#
# 但已经需要记录：
#
# ```text
# Int -> Nat
# ```
#
# 因此暂存在：
#
# ```rust
# pending_import_dependencies[Int] = vec![Nat]
# ```
#
# 等 Int 完整执行成功后，再把它放进：
#
# ```rust
# ModuleRunner {
#     imports: vec![Nat],
# }
# ```
#
# 如果加载失败，则丢弃 pending 记录。
#
# 实际上，后面也可以把这个字段简化成：
#
# ```rust
# ModuleRunner {
#     status: ModuleStatus::Loading,
#     imports: Vec<ModuleId>,
# }
# ```
#
# 也就是 loading 期间直接把依赖写进尚未完成的 runner。那样就不一定需要独立的 `pending_import_dependencies`。它主要是当前“加载完成后才注册 runner”模型下的过渡状态。
#
# ---
#
# ```rust
# pub stopped_modules: HashSet<ModuleId>
# ```
#
# 对应现在的：
#
# ```litex
# stop import Nat
# ```
#
# 它表示：
#
# ```text
# Nat 已经加载过，但当前不可参与隐式查找
# ```
#
# 这和删除 module 不同：
#
# ```text
# loaded_modules 中仍然保留 Nat
# Nat 的环境仍然保留
# 只是 lookup 时暂时跳过 Nat
# ```
#
# 之后再次：
#
# ```litex
# import Nat
# ```
#
# 就可以重新激活，而不需要重新执行文件。
#
# 不过也可以把这个状态直接放到 `ModuleRunner`：
#
# ```rust
# pub enum ModuleStatus {
#     Loading,
#     Loaded,
#     Stopped,
# }
# ```
#
# 这样就不需要单独的：
#
# ```rust
# HashSet<ModuleId>
# ```
#
# 我更推荐把状态放入 `ModuleRunner`，因为“是否 stopped”本来就是该 module 自己的属性。
#
# ---
#
# ```rust
# pub next_module_id: usize
# ```
#
# 用于生成新的 `ModuleId`：
#
# ```rust
# let id = ModuleId(self.next_module_id);
# self.next_module_id += 1;
# ```
#
# 这样 module 不依赖名字或路径作为内部身份：
#
# ```text
# ModuleId(0) = main
# ModuleId(1) = Nat
# ModuleId(2) = Int
# ```
#
# 名字和路径可以变化，但内部引用仍然稳定。
#
# 后面如果需要处理 module 删除、重新加载、缓存失效，可以把它换成 generation-based ID 或 `slotmap`。MVP 阶段使用递增整数就够了。
#
# 我会把字段稍微整理成这样：
#
# ```rust
# pub struct ModuleManager {
#     pub builtin_environment: Environment,
#
#     pub modules: HashMap<ModuleId, ModuleRunner>,
#     pub module_by_name: HashMap<String, ModuleId>,
#     pub module_by_path: HashMap<String, ModuleId>,
#
#     pub loading_import_stack: Vec<ModuleId>,
#     pub next_module_id: usize,
# }
# ```
#
# 然后把这两个状态放进 `ModuleRunner`：
#
# ```rust
# pub struct ModuleRunner {
#     pub id: ModuleId,
#     pub module_name: String,
#     pub module_root_path: String,
#
#     pub main_environment: Environment,
#     pub file_environments: Vec<FileEnvironment>,
#     pub imports: Vec<ModuleId>,
#
#     pub status: ModuleStatus,
# }
# ```
#
# 这样：
#
# - `module_by_name/path` 是索引；
# - `loading_import_stack` 是当前加载调用栈；
# - `ModuleRunner.imports` 是最终依赖关系；
# - `ModuleRunner.status` 表示 Loaded/Stopped/Loading；
# - `next_module_id` 是内部 ID 分配器。
#
# 这比把所有状态都集中在 `ModuleManager` 里更清楚。
#
# ============================================================
