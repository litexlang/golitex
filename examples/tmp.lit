            t = 2
            point[1] = t ^ 3 + 7
            point[2] = -3 * t ^ 2 - 6 * t - 5
            =>:
                point = (15, -29)
    point = (point[1], point[2]) = (t ^ 3 + 7, -3 * t ^ 2 - 6 * t - 5) = (2 ^ 3 + 7, -3 * 2 ^ 2 - 6 * 2 - 5) = (15, -29)

