claim:
    prove:
        forall n N:
            2 * n $in even_N
    witness exist k N st {2 * n = 2 * k} from n:
        2 * n = 2 * n
    $is_even_nat(2 * n)
    2 * n $in {m N: $is_even_nat(m)}
    2 * n $in even_N

claim:
    ? forall n N:
        2 * n $in even_N

    witness exist k N st {2 * n = 2 * k} from n:
        2 * n = 2 * n
    $is_even_nat(2 * n)
    2 * n $in {m N: $is_even_nat(m)}
    2 * n $in even_N