# when n is a even number, then a^n >= 0 is verified automatically.
# when 0 <= b, then a <= a + b is verified automatically.
claim:
    prove:
        forall a, b R:
            a^2 + b^2 = 0
            =>:
                a = 0
    by contra:
        prove:
            a = 0
        a != 0
        0 < a ^ 2
        