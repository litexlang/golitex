#
# --- A2 assistant jsonl:2555 message 1 ---
# 我先把当前真正参与这条链路的类型和入口补齐：`Runtime`、`ModuleManager`、`ImportedModule`、`Environment`、文件加载 statement、解析/执行入口，以及当前 import 如何创建子 runtime。然后我会给你一版“目标架构的完整 struct 草图”和一次运行从入口到 module/file 的调用流程，区分哪些是现有字段、哪些是建议新增。
#
# --- A2 assistant jsonl:2568 message 2 ---
# <proposed_plan>
# # Litex Runtime / ModuleRunner 目标架构
#
# ## 1. 总体原则
#
# 不要做 C++ 式的进程级全局变量，也不要让 `ModuleRunner` 互相持有引用。
#
# 一次 top-level 执行对应一个 `Runtime`：
#
# ```text
# Runtime
# ├── ModuleManager                  // 本次运行中的所有 module
# │   ├── builtin environment
# │   ├── main module runner
# │   ├── imported module runner
# │   └── ...
# └── execution_stack                // 当前执行位置
# ```
#
# Rust 中的“全局 module 表”就是 `Runtime` 持有的 `ModuleManager`。不同次运行拥有不同的 Runtime，因此不会互相污染。
#
# `ModuleRunner` 只保存自己的状态和其他 module 的 `ModuleId`，不保存 `Runtime` 引用，也不保存其他 runner 的引用。
#
# ---
#
# ## 2. 基础 ID 和模式类型
#
# ```rust
# #[derive(Clone, Copy, Debug, PartialEq, Eq, Hash)]
# pub struct ModuleId(pub usize);
#
# #[derive(Clone, Copy, Debug, PartialEq, Eq, Hash)]
# pub struct FileEnvId(pub usize);
#
# #[derive(Clone, Copy, Debug, PartialEq, Eq)]
# pub enum FileLoadMode {
#     Run,
#     Trust,
# }
#
# #[derive(Clone, Copy, Debug, PartialEq, Eq)]
# pub enum ModuleStatus {
#     Loading,
#     Loaded,
#     Stopped,
# }
# ```
#
# 使用 `ModuleId` 而不是互相引用：
#
# ```text
# ModuleRunner A  --imports--> ModuleId(B)
# ModuleRunner B  --imports--> ModuleId(C)
# ```
#
# 真正查找 B、C 的动作由 `Runtime.module_manager` 完成。
#
# ---
#
# ## 3. Environment：保持为事实存储层
#
# 现有的 `Environment` 不应该变成 module，也不应该知道 Runtime。
#
# 它继续保存：
#
# ```rust
# pub struct Environment {
#     // definitions
#     pub defined_identifiers: HashMap<IdentifierName, ParamObjType>,
#     pub defined_def_props: HashMap<PropName, DefPropStmt>,
#     pub defined_abstract_props: HashMap<AbstractPropName, DefAbstractPropStmt>,
#     pub defined_algorithms: HashMap<AlgoName, DefAlgoStmt>,
#     pub defined_structs: HashMap<StructName, DefStructStmt>,
#     pub defined_templates: HashMap<TemplateName, DefTemplateStmt>,
#     pub defined_thm_stmts: HashMap<ThmName, DefThmStmt>,
#     pub defined_strategy_stmts: HashMap<StrategyName, DefStrategyStmt>,
#
#     // equality and fact indexes
#     pub known_equality: ...,
#     pub known_atomic_facts_with_1_arg: ...,
#     pub known_atomic_facts_with_2_args: ...,
#     pub known_exist_facts: ...,
#     pub known_or_facts: ...,
#     pub known_atomic_facts_in_forall_facts: ...,
#
#     // object-shape caches
#     pub known_objs_equal_to_tuple: ...,
#     pub known_objs_equal_to_cart: ...,
#     pub known_obj_values: ...,
#     pub known_objs_equal_to_set_builder: ...,
#
#     // verifier caches
#     pub cache_well_defined_obj: ...,
#     pub cache_known_fact: ...,
#     pub cache_known_fact_trust: ...,
#
#     // strategy registrations
#     pub known_transitive_props: ...,
#     pub known_symmetric_props: ...,
#     pub known_reflexive_props: ...,
#     pub known_antisymmetric_props: ...,
# }
# ```
#
# 这里的 `...` 代表现在已有的大量具体索引，不需要因为 module 重构而重新设计。
#
# `Environment` 的职责只有：
#
# ```text
# 保存事实
# 保存定义
# 保存索引
# 保存 verifier cache
# ```
#
# 它不负责：
#
# ```text
# module import
# 文件读取
# 当前执行位置
# 跨 module 查找
# ```
#
# ---
#
# ## 4. FileEnvironment：run_file / trust_file 的独立环境
#
# `run_file` 和 `trust_file` 不再把内容复制到当前环境，也不再通过全局 flag 表达信任状态。
#
# ```rust
# pub struct FileEnvironment {
#     pub id: FileEnvId,
#     pub source_path: String,
#     pub mode: FileLoadMode,
#     pub environment: Environment,
# }
# ```
#
# 一个 module 的结构变成：
#
# ```text
# ModuleRunner
# ├── main_env
# ├── file_envs[0]  // run_file "a.lit"
# ├── file_envs[1]  // trust_file "b.lit"
# └── file_envs[2]  // run_file "c.lit"
# ```
#
# `run_file`：
#
# ```text
# 创建 FileEnvironment(mode = Run)
# 执行文件
# 成功后保留 FileEnvironment
# ```
#
# `trust_file`：
#
# ```text
# 创建 FileEnvironment(mode = Trust)
# 跳过普通 proof verification，但执行环境效果
# 成功后保留 FileEnvironment
# ```
#
# 如果文件执行失败，建议不要把半成品环境挂进 module，而是先在临时环境中运行，成功后再提交。
#
# ---
#
# ## 5. ModuleRunner：单个 module 的本地状态
#
# ```rust
# pub struct ModuleRunner {
#     pub id: ModuleId,
#
#     pub module_name: String,
#     pub module_root_path: String,
#     pub main_file_path: String,
#     pub is_std: bool,
#
#     // module 自己的主环境
#     pub main_environment: Environment,
#
#     // run_file / trust_file 产生的持久环境
#     pub file_environments: Vec<FileEnvironment>,
#
#     // module graph 中的依赖
#     pub imports: Vec<ModuleId>,
#
#     pub status: ModuleStatus,
# }
# ```
#
# `ModuleRunner` 只负责本地状态：
#
# ```rust
# impl ModuleRunner {
#     pub fn main_environment(&self) -> &Environment;
#     pub fn main_environment_mut(&mut self) -> &mut Environment;
#
#     pub fn file_environment(&self, id: FileEnvId) -> Option<&FileEnvironment>;
#     pub fn file_environment_mut(&mut self, id: FileEnvId)
#         -> Option<&mut FileEnvironment>;
#
#     pub fn create_file_environment(
#         &mut self,
#         path: String,
#         mode: FileLoadMode,
#     ) -> FileEnvId;
# }
# ```
#
# 不建议写成：
#
# ```rust
# impl ModuleRunner {
#     pub fn run_stmt(&mut self, stmt: &Stmt, runtime: &mut Runtime);
# }
# ```
#
# 因为这样会导致：
#
# ```text
# ModuleRunner 借用了 Runtime 内部的一部分
# 同时又需要完整借用 Runtime
# ```
#
# 这正是 Rust 借用检查器最容易卡住的地方。
#
# 正确的入口仍然是：
#
# ```rust
# runtime.run_stmt(stmt)
# ```
#
# 而不是：
#
# ```rust
# runtime.current_module().run_stmt(stmt)
# ```
#
# ---
#
# ## 6. ModuleManager：本次运行中的 module world
#
# 现在的 `ModuleManager` 可以演化为：
#
# ```rust
# pub struct ModuleManager {
#     // builtin background
#     pub builtin_environment: Environment,
#
#     // 所有 module runner
#     pub modules: HashMap<ModuleId, ModuleRunner>,
#
#     // lookup indexes
#     pub module_by_name: HashMap<String, ModuleId>,
#     pub module_by_path: HashMap<String, ModuleId>,
#
#     // import lifecycle
#     pub loading_import_stack: Vec<ModuleId>,
#     pub pending_import_dependencies:
#         HashMap<ModuleId, Vec<ModuleId>>,
#
#     // stop import
#     pub stopped_modules: HashSet<ModuleId>,
#
#     pub next_module_id: usize,
# }
# ```
#
# 主要方法：
#
# ```rust
# impl ModuleManager {
#     pub fn create_entry_module(
#         &mut self,
#         name: String,
#         path: String,
#     ) -> ModuleId;
#
#     pub fn begin_import(
#         &mut self,
#         name: String,
#         path: String,
#     ) -> Result<ModuleId, RuntimeError>;
#
#     pub fn finish_import(
#         &mut self,
#         module_id: ModuleId,
#     );
#
#     pub fn module(&self, id: ModuleId) -> Option<&ModuleRunner>;
#
#     pub fn module_mut(
#         &mut self,
#         id: ModuleId,
#     ) -> Option<&mut ModuleRunner>;
#
#     pub fn module_by_name(
#         &self,
#         name: &str,
#     ) -> Option<&ModuleRunner>;
#
#     pub fn resolve_module_name(
#         &self,
#         name: &str,
#     ) -> Result<ModuleId, RuntimeError>;
# }
# ```
#
# 原来的：
#
# ```rust
# ImportedModule {
#     absolute_path,
#     environment,
#     is_std,
#     import_dependencies,
# }
# ```
#
# 可以被 `ModuleRunner` 直接替代，不再只保存一个压缩后的 `Environment`。
#
# ---
#
# ## 7. ExecutionFrame：当前正在执行什么
#
# `Runtime` 需要知道当前正在执行：
#
# - 哪个 module；
# - module 的 main file 还是某个 run_file；
# - 当前 source path；
# - 当前局部 proof environment；
# - 当前解析时的 free parameters。
#
# ```rust
# pub enum ExecutionLayer {
#     Main,
#     File(FileEnvId),
# }
#
# pub struct SourceContext {
#     pub source_path: String,
#     pub layer: ExecutionLayer,
# }
#
# pub struct ExecutionFrame {
#     pub module_id: ModuleId,
#     pub source: SourceContext,
#
#     // claim / forall / exist / cases 等局部环境
#     pub local_environment_stack: Vec<Environment>,
#
#     // 当前 source 的解析状态
#     pub parsing_free_param_collection: FreeParamCollection,
# }
# ```
#
# 这里要区分两种 environment：
#
# ```text
# ModuleRunner.main_environment
# ModuleRunner.file_environments
#     └── 持久的文件环境
#
# ExecutionFrame.local_environment_stack
#     └── 临时的 proof/local scope
# ```
#
# 例如：
#
# ```text
# main_env
# file_envs[0]
# file_envs[1]
# local_env_stack[0]   // claim
# local_env_stack[1]   // forall body
# ```
#
# 局部 proof 结束后，`local_environment_stack` 弹出；`file_envs` 不弹出。
#
# ---
#
# ## 8. Runtime：一次完整执行的总协调者
#
# 目标结构：
#
# ```rust
# pub struct Runtime {
#     // 本次 top-level run 的 module 世界
#     pub module_manager: ModuleManager,
#
#     // 当前执行位置
#     pub execution_stack: Vec<ExecutionFrame>,
#
#     // output / execution options
#     pub detail_output: bool,
#     pub strict_mode: bool,
#     pub output_language: OutputLanguage,
#     pub loading_builtin_code: bool,
# }
# ```
#
# 最终不再需要：
#
# ```rust
# pub environment_stack: Vec<Box<Environment>>;
# pub only_exec_affect_environment: bool;
# ```
#
# 因为：
#
# ```text
# environment_stack
#     → 拆成 ModuleRunner 的 main/file env
#       + ExecutionFrame 的 local env stack
#
# only_exec_affect_environment
#     → 改成 FileLoadMode::Trust
# ```
#
# Runtime 的核心接口：
#
# ```rust
# impl Runtime {
#     pub fn new() -> Self;
#
#     pub fn run_entry_file(
#         &mut self,
#         path: &str,
#     ) -> RunResult;
#
#     pub fn run_source_code(
#         &mut self,
#         source: &str,
#         context: SourceContext,
#     ) -> RunResult;
#
#     pub fn run_stmt(
#         &mut self,
#         stmt: &Stmt,
#     ) -> Result<StmtResult, RuntimeError>;
#
#     pub fn run_import_stmt(
#         &mut self,
#         stmt: &ImportStmt,
#     ) -> Result<StmtResult, RuntimeError>;
#
#     pub fn run_file_stmt(
#         &mut self,
#         stmt: &RunFileStmt,
#     ) -> Result<StmtResult, RuntimeError>;
#
#     pub fn current_module_id(&self) -> ModuleId;
#
#     pub fn current_module(&self) -> &ModuleRunner;
#
#     pub fn current_module_mut(&mut self) -> &mut ModuleRunner;
#
#     pub fn lookup_environment(
#         &self,
#         reference: &Obj,
#     ) -> LookupResult;
# }
# ```
#
# 但是 `ModuleRunner` 不负责调用 `Runtime::run_stmt`。所有 execution dispatch 都从 Runtime 开始。
#
# ---
#
# ## 9. LookupResult：跨 environment / module 查找
#
# 现在很多 verifier 直接遍历：
#
# ```rust
# self.environment_stack.iter().rev()
# ```
#
# 目标是把这件事集中到 Runtime：
#
# ```rust
# pub enum EnvironmentSource {
#     LocalScope,
#     CurrentFile,
#     CurrentModuleMain,
#     Builtin,
#     ImportedModule(ModuleId),
# }
#
# pub struct EnvironmentRef<'a> {
#     pub source: EnvironmentSource,
#     pub environment: &'a Environment,
# }
#
# pub struct LookupResult<'a> {
#     pub environments: Vec<EnvironmentRef<'a>>,
# }
# ```
#
# 逻辑顺序可以是：
#
# ```text
# 1. 当前 execution frame 的 local_environment_stack
# 2. 当前 file environment
# 3. 当前 module 的其他 file environments
# 4. 当前 module 的 main_environment
# 5. builtin_environment
# 6. 被明确引用的 imported module
# ```
#
# 重要的是：`ModuleRunner` 不需要知道所有 module。它只需要自己的 `imports: Vec<ModuleId>`；真正遍历和解析由 `Runtime` / `ModuleManager` 完成。
#
# ---
#
# ## 10. 一次执行的完整入口
#
# ### 入口文件
#
# ```text
# run_source_code_in_file(path)
#     ↓
# 创建 Runtime
#     ↓
# 初始化 builtin_environment
#     ↓
# 创建 entry ModuleRunner
#     ↓
# push ExecutionFrame {
#     module_id: entry_module,
#     layer: Main,
#     source_path: entry_path,
# }
#     ↓
# tokenizer.parse_blocks
#     ↓
# runtime.parse_stmt
#     ↓
# runtime.run_stmt
# ```
#
# ### 普通 statement
#
# ```text
# Runtime::run_stmt(stmt)
#     ↓
# 读取 current ExecutionFrame
#     ↓
# Runtime 构造 lookup view
#     ↓
# 执行 well-definedness
#     ↓
# 执行 verifier
#     ↓
# 执行 infer
#     ↓
# 把新事实写入当前 layer 的 Environment
#     ↓
# 返回 StmtResult
# ```
#
# ### import
#
# ```text
# Runtime::run_stmt(import M)
#     ↓
# ModuleManager.resolve_import
#     ↓
# 创建 ModuleRunner(M)
#     ↓
# 注册 ModuleId(M)
#     ↓
# push ExecutionFrame(module = M, layer = Main)
#     ↓
# 执行 M/main.lit
#     ↓
# 递归处理 M 的 imports
#     ↓
# pop ExecutionFrame
#     ↓
# 将 M 标记为 Loaded
#     ↓
# 回到原 module
# ```
#
# 这里不再创建：
#
# ```rust
# Runtime::new_for_import_from_parent(...)
# ```
#
# 所有 module 都在同一个 Runtime 中执行，只是当前的 `ExecutionFrame.module_id` 发生变化。
#
# ### run_file
#
# ```text
# Runtime::run_stmt(run_file "a.lit")
#     ↓
# 当前 ModuleRunner 创建 FileEnvironment
#     ↓
# push ExecutionFrame {
#     module_id: current_module,
#     layer: File(file_env_id),
#     source_path: "a.lit",
# }
#     ↓
# 执行 a.lit
#     ↓
# pop ExecutionFrame
#     ↓
# 保留 file_env
# ```
#
# ### trust_file
#
# 流程相同，只是：
#
# ```rust
# FileEnvironment {
#     mode: FileLoadMode::Trust,
#     ...
# }
# ```
#
# 执行器根据当前 frame 的 mode 决定是否跳过普通 proof verification。
#
# ---
#
# ## 11. Rust 借用问题的处理方式
#
# 不要写：
#
# ```rust
# runtime.current_module_mut().run_stmt(stmt, runtime)
# ```
#
# 建议由 Runtime 统一调度：
#
# ```rust
# impl Runtime {
#     pub fn run_stmt(&mut self, stmt: &Stmt) -> Result<StmtResult, RuntimeError> {
#         let current_module_id = self.current_module_id();
#         let lookup_view = self.build_lookup_view(current_module_id)?;
#
#         let result = self.verify_stmt(stmt, &lookup_view)?;
#
#         self.apply_stmt_effect(
#             current_module_id,
#             self.current_layer(),
#             result,
#         )
#     }
# }
# ```
#
# 也就是：
#
# ```text
# 先读取 module graph 和 lookup 信息
# 再验证
# 最后单独修改当前 runner
# ```
#
# 如果未来确实需要跨 module 的可变访问，使用：
#
# ```rust
# ModuleId
# ```
#
# 重新从 `ModuleManager` 查询，而不是保存 Rust 引用。
#
# 不要使用：
#
# ```rust
# struct ModuleRunner<'a> {
#     runtime: &'a Runtime,
# }
# ```
#
# 也不要使用：
#
# ```rust
# Rc<RefCell<Runtime>> inside ModuleRunner
# ```
#
# 这两种写法都会让生命周期或循环所有权变得非常复杂。
#
# ---
#
# ## 12. 迁移顺序
#
# 建议分阶段迁移，而不是一次性改掉所有 verifier：
#
# 1. 新增 `ModuleId`、`ModuleRunner`、`FileEnvironment`、`ExecutionFrame`。
# 2. 把现有 `ImportedModule` 的字段迁移到 `ModuleRunner`。
# 3. 保留旧的 `Runtime::top_level_env()`，让它暂时映射到当前 runner 的当前 environment。
# 4. 把 `run_file` 从 `environment_stack` 改为创建 `FileEnvironment`。
# 5. 把 `trust_file` 从 `only_exec_affect_environment` 改为 `FileLoadMode::Trust`。
# 6. 把 verifier 中直接访问 `environment_stack` 的逻辑统一改成 Runtime lookup API。
# 7. 消除 `Runtime::new_for_import_from_parent`，改成同一个 Runtime 的 `execution_stack`。
# 8. 最后删除旧的 `environment_stack`、`ImportedModule.environment` 和 `only_exec_affect_environment`。
#
# 这样最终得到的模型是：
#
# ```text
# 一个 Runtime
#     管理所有 ModuleRunner
#         每个 ModuleRunner 有 main_env
#         每个 ModuleRunner 有 file_envs
#     Runtime 用 execution_stack 管理当前执行位置
#     Runtime 负责跨 module lookup
#     Environment 只保存数学事实和定义
# ```
#
# 这比“全局变量”更适合 Rust，也比让每个 `ModuleRunner` 互相引用更清晰。
# </proposed_plan>
#
