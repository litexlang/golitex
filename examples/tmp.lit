forall a, b R, f fn(x R) R:
    forall x R:
        f(x) = a * x + b
    f(6) - f(2) = 12
    =>:
        f(6) = a * 6 + b
        f(2) = a * 2 + b
        f(12) = a * 12 + b
        12 = f(6) - f(2) = (a * 6 + b) - (a * 2 + b) = 4 * a
        a = 12 / 4 = 3
        f(12) - f(2) = (a * 12 + b) - (a * 2 + b) = 10 * a = 10 * 3 = 30

forall x, y R:
    x + y = 7
    3 * x + y = 45
    =>:
        2 * x = (3 * x + y) - (x + y) = 45 - 7 = 38
        x = (2 * x) / 2 = 19
        y = (x + y) - x = 7 - 19 = -12
        x - y = 19 - (-12) = 31
        x ^ 2 - y ^ 2 = (x + y) * (x - y) = 7 * 31 = 217

