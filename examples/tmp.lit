            after_x = (2, 0)
            result[1] = after_x[1]
            result[2] = 2 + (2 - after_x[2])
            =>:
                result = (2, 4)
    result = (result[1], result[2]) = (after_x[1], 2 + (2 - after_x[2])) = (2, 2 + (2 - 0)) = (2, 4)

