# test/geometry/483.json
claim:
    prove:
        forall interior_angle, exterior_angle, sides R:
            0 < exterior_angle
            interior_angle = 13 / 2 * exterior_angle
            interior_angle + exterior_angle = 180
            sides = 360 / exterior_angle
            =>:
                sides = 15
    15 / 2 * exterior_angle = (13 / 2 * exterior_angle) + exterior_angle = interior_angle + exterior_angle = 180
    exterior_angle = (15 / 2 * exterior_angle) / (15 / 2) = 180 / (15 / 2) = 24
    sides = 360 / exterior_angle = 360 / 24 = 15

