run_file complex

have r R = sqrt(2) / 2
have z &C = (r, r)
have z_inv &C = (r, -r)

r^2 = (sqrt(2) / 2)^2 = sqrt(2)^2 / 4 = 2 / 4 = 1 / 2
C_mul(z, z_inv) = C_mul((r, r), (r, -r))
C_mul((r, r), (r, -r)) = (r * r - r * (-r), r * (-r) + r * r)
r * r = r^2 = 1 / 2
r * -1 * r = -1 * r^2 = -1 / 2
r * r - r * -1 * r = 1
r * -1 * r + r * r = 0
(r * r - r * (-r), r * (-r) + r * r) = (1, 0)
C_mul(z, z_inv) = C_mul((r, r), (r, -r)) = (r * r - r * (-r), r * (-r) + r * r) = (1, 0)

have S &C = (3 * sqrt(2), 3 * sqrt(2))
have T &C = (3 * sqrt(2), -3 * sqrt(2))

C_mul(S, T) = C_mul((3 * sqrt(2), 3 * sqrt(2)), (3 * sqrt(2), -3 * sqrt(2)))
C_mul((3 * sqrt(2), 3 * sqrt(2)), (3 * sqrt(2), -3 * sqrt(2))) = (3 * sqrt(2) * (3 * sqrt(2)) - 3 * sqrt(2) * (-3 * sqrt(2)), 3 * sqrt(2) * (-3 * sqrt(2)) + 3 * sqrt(2) * (3 * sqrt(2)))
3 * sqrt(2) * (3 * sqrt(2)) = 9 * sqrt(2)^2 = 18
3 * sqrt(2) * (-3 * sqrt(2)) = -9 * sqrt(2)^2 = -18
(3 * sqrt(2) * (3 * sqrt(2)) - 3 * sqrt(2) * (-3 * sqrt(2))) = 36
(3 * sqrt(2) * (-3 * sqrt(2)) + 3 * sqrt(2) * (3 * sqrt(2))) = 0
(3 * sqrt(2) * (3 * sqrt(2)) - 3 * sqrt(2) * (-3 * sqrt(2)), 3 * sqrt(2) * (-3 * sqrt(2)) + 3 * sqrt(2) * (3 * sqrt(2))) = (36, 0)
C_mul(S, T) = C_mul((3 * sqrt(2), 3 * sqrt(2)), (3 * sqrt(2), -3 * sqrt(2))) = (3 * sqrt(2) * (3 * sqrt(2)) - 3 * sqrt(2) * (-3 * sqrt(2)), 3 * sqrt(2) * (-3 * sqrt(2)) + 3 * sqrt(2) * (3 * sqrt(2))) = (36, 0)
