prove:
    have tmp_eval_g fn(x Z) Z

    know:
        forall x Z:
            x > 0
            =>:
                tmp_eval_g(x) = tmp_eval_g(x-1) + 1
        tmp_eval_g(0) = 0
        forall x Z:
            x < 0
            =>:
                tmp_eval_g(x) = tmp_eval_g(x+1) - 1

    algo tmp_eval_g(x):
        case x > 0: tmp_eval_g(x-1) + 1
        case x = 0: 0
        case x < 0: tmp_eval_g(x+1) - 1

    eval tmp_eval_g(3)
    tmp_eval_g(3) = 3
