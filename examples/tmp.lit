forall a, b Q:
    a - 3 = 2 * b
    =>:
        a^2 - a + 3 = (a - 3)^2 + 5 * (a - 3) + 9 = (2* b)^2 + 5 * (2 * b) + 9 = 4 * b^2 + 10 * b + 9

forall a, b R, f fn(x R) R:
    forall x R:
        f(x) = a * x + b
    f(7) = 4
    f(6) = 3
    =>:
        4 = f(7) = a * 7 + b
        3 = f(6) = a * 6 + b
        a = (a * 7 + b) - (a * 6 + b) = 1
        b = (a * 6 + b) - a * 6 = 3 - 1 * 6 = -3
        f(3) = a * 3 + b = 1 * 3 + (-3) = 0

forall q, p R:
    q = 2 - 4 + 6 - 8 + 10 - 12 + 14
    p = 3 - 6 + 9 - 12 + 15 - 18 + 21
    =>:
        q = 2 - 4 + 6 - 8 + 10 - 12 + 14 = 8
        p = 3 - 6 + 9 - 12 + 15 - 18 + 21 = 12
        q / p = 8 / 12 = 2 / 3

forall a, c R:
    0 <= (a - (c + 2)) ^ 2 = a ^ 2 + c ^ 2 + 4 * (1 + c) - 2 * a * (2 + c)
    2 * a * (2 + c) <= a ^ 2 + c ^ 2 + 4 * (1 + c)

forall a R, f fn(x R) R:
    forall x R:
        f(x) = a * (x - 2) ^ 2 + 3
    f(4) = 4
    =>:
        4 = f(4) = a * (4 - 2) ^ 2 + 3 = a * 4 + 3
        a * 4 = (a * 4 + 3) - 3 = 1
        a = (a * 4) / 4 = 1 / 4
        f(6) = a * (6 - 2) ^ 2 + 3 = (1 / 4) * 16 + 3 = 7

forall a R:
    0 <= (5 * a - 1) ^ 2
    0 <= 3 * a ^ 2
    0 <= (5 * a - 1) ^ 2 + 3 * a ^ 2 = 28 * a ^ 2 + 1 - 10 * a
    10 * a <= 28 * a ^ 2 + 1

1 + 1 / (1 + 1 / (1 + 1)) = 5 / 3

forall a, b, n N:
    1 <= a
    a <= 9
    0 <= b
    b <= 9
    n = 10 * a + b
    n = a * b + a + b
    =>:
        10 * a + b = n = a * b + a + b
        10 * a = (10 * a + b) - b = (a * b + a + b) - b = a * b + a
        9 * a = 10 * a - a = (a * b + a) - a = a * b
        b = (a * b) / a = (9 * a) / a = 9

forall a, lx, ly, lz R:
    lx - ly = a
    ly - lz = 15
    lz - lx = -7
    =>:
        0 = (lx - ly) + (ly - lz) + (lz - lx) = a + 15 + (-7)
        a = (a + 15 + (-7)) - 8 = -8

forall x, y R:
    x != 0
    y != 0
    x != y
    x + 2 / x = y + 2 / y
    =>:
        x - y = (x + 2 / x) - (y + 2 / x) = (y + 2 / y) - (y + 2 / x) = 2 / y - 2 / x
        x - y = 2 / y - 2 / x = (2 * x - 2 * y) / (x * y) = 2 * (x - y) / (x * y)
        (x - y) * x * y = (2 * (x - y) / (x * y)) * x * y = 2 * (x - y)
        2 * (x - y) = (x - y) * x * y
        x - y != 0
        2 = ((x - y) * x * y) / (x - y) = x * y

count({1, 3, 5, 7}) = 4
forall n N:
    n = count({1, 3, 5, 7})
    =>:
        n = 4
        3 ^ n % 8 = 3 ^ 4 % 8 = 1

