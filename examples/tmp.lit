forall a, b, t, n N:
    (a + 2) * (b + 1) * t = 28
    (a + 1) * (b + 2) * t = 30
    n = (a + 2) * (b + 2) * t
    =>:
        2 = 30 - 28 = ((a + 1) * (b + 2) * t) - ((a + 2) * (b + 1) * t) = (((a + 1) * (b + 2)) - ((a + 2) * (b + 1))) * t = (a - b) * t

