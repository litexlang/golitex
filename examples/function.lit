prove:
    have fn f(a, b R: a > b)R = a + b
    have fn g(c R: c > 0) fn(a, b R: a > b)R = a + b
    forall a, b R:
        a > b
        =>:
            g(2)(a, b) = a + b= f(a, b)
    g(2)(2, 1) = f(2, 1)

prove:
    have f fn(a R) fn(b R) R

    know forall x, y R:
        f(x)(y) = x + y

    f(2)(1) = 2 + 1 = 3

