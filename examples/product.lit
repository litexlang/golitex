forall start ,middle,last Z:
    start <= middle <= middle + 1 <= last
    =>:
        product(i, start, last + 1, i) = product(i, start, last, i) * (last + 1)
        product(i, start, last, i * i) = product(i, start, last, i) * product(i, start, last, i)
        product(i, start, middle, i) * product(i, middle + 1, last, i) = product(i, start, last, i)
        product(i, start, start, i) = start

eval product(i, 1, 3, i)

product(i, 1, 4, i) = product(i, 1, 1, i) * 2 * product(i, 3, 4, i)
