prop bijective_finite_seq_to_finite_set(a finite_set, f set):
    count(a) $in N_pos
    f $in finite_seq(a, count(a))

    forall i, j closed_range(1, count(a)):
        i != j
        =>:
            f(i) != f(j)

    forall item a:
        exist i closed_range(1, count(a)) st {f(i) = item}

know forall a finite_set:
    count(a) $in N_pos
    =>:
        exist f finite_seq(a, count(a)) st {$bijective_finite_seq_to_finite_set(a, f)}